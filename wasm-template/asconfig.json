{
  "targets": {
    "release": {
      "outFile": "build/plugin.wasm",
      "optimizeLevel": 3,
      "shrinkLevel": 0,
      "converge": false,
      "noAssert": true
    },
    "debug": {
      "outFile": "build/plugin.debug.wasm",
      "debug": true
    }
  },
  "options": {
    "bindings": "raw",
    "exportRuntime": false,
    "runtime": "minimal",
    "initialMemory": 4,
    "maximumMemory": 4096,
    "memoryBase": 0,
    "use": ["abort="]
  }
}
