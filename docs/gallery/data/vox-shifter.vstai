{
  "format": 1,
  "name": "Vox Shifter",
  "isInstrument": false,
  "explanation": "A formant-aware vocal pitch shifter in the PSOLA / phase-vocoder family. A twin-grain crossfaded delay-line pitch shifter moves the pitch (Shift, plus/minus 12 semitones) click-free, while an independent Formant control sweeps a pair of resonant vowel formants over the shifted voice, so you can pitch a voice up without the chipmunk formant collapse, or slide the formants for gender and vowel morphs. Mix blends dry and wet; Output trims level. Controls: Shift, Formant, Mix, Output.",
  "params": [
    {
      "name": "Shift",
      "index": 0,
      "min": -12,
      "max": 12,
      "default": 5
    },
    {
      "name": "Formant",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Output",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Vox Shifter</title>\n<style>\n  :root{ --acc:#ff5ab0; --acc2:#5ad0ff; --bg0:#0f060c; --bg1:#1e0c18; --ink:#fae8f3; --dim:#9a708a; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#341830 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,720px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#261024,#0f060c); border:1px solid rgba(255,90,176,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(250,232,243,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.0s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:110px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#180a14,#0e060b); border:1px solid rgba(255,90,176,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(4,1fr); gap:10px; max-width:480px; margin:0 auto; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:76px; height:76px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(238,214,230,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,90,176,.6)); }\n  .pcap{ fill:#160a12; stroke:rgba(255,90,176,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,90,176,.1); padding:1px 8px; border-radius:7px; border:1px solid rgba(255,90,176,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">VOX&nbsp;SHIFTER</span><span class=\"sub\">formant pitch shift</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">FORMANT&nbsp;/&nbsp;PITCH</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Shift\",idx:0,def:5,min:-12,max:12,fmt:\"st\"},{name:\"Formant\",idx:1,def:0.5},{name:\"Mix\",idx:2,def:0.6},{name:\"Output\",idx:3,def:0.7}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\"; var isBip=(p.min!==undefined);\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ff5ab0\"/><stop offset=\"1\" stop-color=\"#5ad0ff\"/></linearGradient></defs><circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle><circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle><line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function norm(v){ return isBip ? (v-p.min)/(p.max-p.min) : v; }\n    function render(v){ var nv=norm(v); var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*nv)).toString()); var ang=(A0+(A1-A0)*nv)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2));\n      val.textContent = isBip ? ((v>0?\"+\":\"\")+Math.round(v)+\" st\") : Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var span=isBip?(p.max-p.min):1; var nv=drag.v+(drag.y-e.clientY)/170*span; nv=Math.max(isBip?p.min:0,Math.min(isBip?p.max:1,nv)); if(isBip)nv=Math.round(nv); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var shift=vals[0], form=vals[1], mix=vals[2]; var baseY=H-14, top=16;\n    // formant peak positions (log-ish x across width)\n    var f1=(320+form*520), f2=(900+form*1500); var fx1=Math.log(f1/200)/Math.log(4000/200), fx2=Math.log(f2/200)/Math.log(4000/200);\n    // pitch-shifted harmonic comb (vertical lines), spacing scaled by 2^(shift/12)\n    var ratio=Math.pow(2,shift/12); var nH=26;\n    for(var h=1;h<=nH;h++){ var f=120*h*ratio; if(f>4500)break; var lx=Math.log(f/200)/Math.log(4000/200); if(lx<0||lx>1)continue;\n      // amplitude shaped by the two formants\n      var e1=Math.exp(-((lx-fx1)*(lx-fx1))/0.02), e2=Math.exp(-((lx-fx2)*(lx-fx2))/0.03)*0.85;\n      var amp=(0.12+e1+e2)/(1+h*0.05); var bh=amp*(baseY-top)*0.8; if(bh>baseY-top)bh=baseY-top;\n      var x=12+lx*(W-24);\n      ctx.strokeStyle=\"rgba(255,90,176,\"+(0.3+amp*0.5)+\")\"; ctx.lineWidth=1.6; ctx.beginPath(); ctx.moveTo(x,baseY); ctx.lineTo(x,baseY-bh); ctx.stroke();\n    }\n    // formant envelope curve (cyan)\n    ctx.beginPath();\n    for(var xx=0;xx<=W-24;xx+=3){ var lx=xx/(W-24); var e1=Math.exp(-((lx-fx1)*(lx-fx1))/0.02), e2=Math.exp(-((lx-fx2)*(lx-fx2))/0.03)*0.85; var env=(0.1+e1+e2); var y=baseY-env*(baseY-top)*0.85; if(xx===0)ctx.moveTo(12+xx,y); else ctx.lineTo(12+xx,y); }\n    ctx.strokeStyle=\"rgba(90,208,255,0.85)\"; ctx.lineWidth=1.8; ctx.shadowColor=\"#5ad0ff\"; ctx.shadowBlur=7; ctx.stroke(); ctx.shadowBlur=0;\n    // formant peak markers\n    [ [fx1,\"F1\"],[fx2,\"F2\"] ].forEach(function(p2){ var x=12+p2[0]*(W-24); ctx.fillStyle=\"#5ad0ff\"; ctx.beginPath(); ctx.arc(x,top+4,3,0,Math.PI*2); ctx.fill(); ctx.fillStyle=\"rgba(90,208,255,0.6)\"; ctx.font=\"8px Inter,sans-serif\"; ctx.fillText(p2[1],x-5,top-2); });\n    // shift readout\n    ctx.fillStyle=\"rgba(255,90,176,0.9)\"; ctx.font=\"bold 11px Inter,sans-serif\"; ctx.textAlign=\"right\"; ctx.fillText((shift>0?\"+\":\"\")+Math.round(shift)+\" st\", W-14, H-6); ctx.textAlign=\"left\";\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  VOX SHIFTER — a formant-aware vocal pitch shifter (PSOLA / phase-\n//  vocoder family). A twin-grain crossfaded delay-line pitch shifter\n//  moves the PITCH (Shift, +/-12 semitones) click-free, while an\n//  independent FORMANT control sweeps a pair of resonant vowel formants\n//  over the shifted voice — so you can pitch a voice up without the\n//  \"chipmunk\" formant collapse, or slide the formants for gender/vowel\n//  morphs. Mix blends dry/wet, Output trims level. Pure algorithm.\n//  Controls: Shift, Formant, Mix, Output.\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst LINE_LEN: i32 = 8192;\nconst WINDOW: f32 = 3600.0;\nconst delayL: StaticArray<f32> = new StaticArray<f32>(LINE_LEN);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(LINE_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\nlet writePos: i32 = 0;\nlet phaseA: f32 = 0.0;\nlet phaseB: f32 = WINDOW * 0.5;\nlet smoothRatio: f32 = 1.0;\n\n// two-formant resonant filter state, per channel\nconst f1lp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst f1bp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst f2lp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst f2bp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_SHIFT: i32 = 0; const P_FORMANT: i32 = 1; const P_MIX: i32 = 2; const P_OUTPUT: i32 = 3;\nconst TWO_PI: f32 = 6.2831853;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0; phaseA = 0.0; phaseB = WINDOW * 0.5; smoothRatio = 1.0;\n  for (let i = 0; i < LINE_LEN; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  for (let c = 0; c < MAX_CHANNELS; c++) { f1lp[c] = 0.0; f1bp[c] = 0.0; f2lp[c] = 0.0; f2bp[c] = 0.0; }\n  params[P_SHIFT] = 5.0; params[P_FORMANT] = 0.5; params[P_MIX] = 0.6; params[P_OUTPUT] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function readLine(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(LINE_LEN);\n  while (rp >= f32(LINE_LEN)) rp -= f32(LINE_LEN);\n  const i0: i32 = i32(rp); let i1: i32 = i0 + 1; if (i1 >= LINE_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  return line[i0] + (line[i1] - line[i0]) * frac;\n}\n\nexport function process(n: i32): void {\n  const semis: f32 = clampf(params[P_SHIFT], -12.0, 12.0);\n  const formantN: f32 = clampf(params[P_FORMANT], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const output: f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n\n  const targetRatio: f32 = f32(Mathf.pow(2.0, semis / 12.0));\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 12.0 / sampleRate));\n  const stereo: bool = channels > 1;\n  const invW: f32 = 1.0 / WINDOW;\n\n  // formant centres sweep with the knob (~ah -> ee), resonant bandpass\n  const f1: f32 = 320.0 + formantN * 520.0;              // 320..840 Hz\n  const f2: f32 = 900.0 + formantN * 1500.0;             // 900..2400 Hz\n  const g1: f32 = f32(Mathf.tan(3.14159265 * f1 / sampleRate));\n  const g2: f32 = f32(Mathf.tan(3.14159265 * f2 / sampleRate));\n  const kf: f32 = 0.35;                                  // resonance (narrow-ish)\n  const a1f1: f32 = 1.0 / (1.0 + g1 * (g1 + kf));\n  const a1f2: f32 = 1.0 / (1.0 + g2 * (g2 + kf));\n\n  for (let f = 0; f < n; f++) {\n    smoothRatio += smoothCoeff * (targetRatio - smoothRatio);\n    const r: f32 = 1.0 - smoothRatio;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n    delayL[writePos] = xL; delayR[writePos] = xR;\n\n    const wA: f32 = f32(0.5 - 0.5 * Mathf.cos(TWO_PI * phaseA * invW));\n    const wB: f32 = f32(0.5 - 0.5 * Mathf.cos(TWO_PI * phaseB * invW));\n\n    // grain shift per channel\n    const sL: f32 = readLine(delayL, phaseA) * wA + readLine(delayL, phaseB) * wB;\n    const sR: f32 = stereo ? (readLine(delayR, phaseA) * wA + readLine(delayR, phaseB) * wB) : sL;\n\n    // two-formant resonant emphasis on the shifted voice\n    // channel 0\n    let hp: f32 = (sL - (g1 + kf) * f1bp[0] - f1lp[0]) * a1f1;\n    let bp1: f32 = g1 * hp + f1bp[0]; let lp1: f32 = g1 * bp1 + f1lp[0]; f1bp[0] = bp1; f1lp[0] = lp1;\n    let hp2: f32 = (sL - (g2 + kf) * f2bp[0] - f2lp[0]) * a1f2;\n    let bp2: f32 = g2 * hp2 + f2bp[0]; let lp2: f32 = g2 * bp2 + f2lp[0]; f2bp[0] = bp2; f2lp[0] = lp2;\n    const vL: f32 = sL * 0.5 + (bp1 + bp2 * 0.8) * 0.9;\n\n    let vR: f32 = vL;\n    if (stereo) {\n      let hpb: f32 = (sR - (g1 + kf) * f1bp[1] - f1lp[1]) * a1f1;\n      let bp1b: f32 = g1 * hpb + f1bp[1]; let lp1b: f32 = g1 * bp1b + f1lp[1]; f1bp[1] = bp1b; f1lp[1] = lp1b;\n      let hp2b: f32 = (sR - (g2 + kf) * f2bp[1] - f2lp[1]) * a1f2;\n      let bp2b: f32 = g2 * hp2b + f2bp[1]; let lp2b: f32 = g2 * bp2b + f2lp[1]; f2bp[1] = bp2b; f2lp[1] = lp2b;\n      vR = sR * 0.5 + (bp1b + bp2b * 0.8) * 0.9;\n    }\n\n    let oL: f32 = (xL * (1.0 - mix) + vL * mix) * (0.5 + output * 1.0);\n    let oR: f32 = (xR * (1.0 - mix) + vR * mix) * (0.5 + output * 1.0);\n    if (oL > 1.4) oL = 1.4; else if (oL < -1.4) oL = -1.4;\n    if (oR > 1.4) oR = 1.4; else if (oR < -1.4) oR = -1.4;\n    outBuf[f] = oL; outBuf[MAX_FRAMES + f] = oR;\n\n    writePos += 1; if (writePos >= LINE_LEN) writePos = 0;\n    phaseA += r; while (phaseA < 0.0) phaseA += WINDOW; while (phaseA >= WINDOW) phaseA -= WINDOW;\n    phaseB += r; while (phaseB < 0.0) phaseB += WINDOW; while (phaseB >= WINDOW) phaseB -= WINDOW;\n  }\n}\n",
  "publishedAt": 1751307800000
}