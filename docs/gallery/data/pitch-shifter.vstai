{
  "format": 1,
  "name": "Pitch Shifter",
  "isInstrument": false,
  "explanation": "A delay-line pitch shifter and harmonizer. A circular delay line is read by two crossfaded pointers that drift at a rate set by the pitch ratio, producing a click-free shifted voice that is regenerated through a feedback path and blended with the dry signal. Controls: Shift (semitones), Fine (cents), Feedback and dry/wet Mix.",
  "params": [
    {
      "name": "Shift",
      "index": 0,
      "min": -12,
      "max": 12,
      "default": 7
    },
    {
      "name": "Fine",
      "index": 1,
      "min": -100,
      "max": 100,
      "default": 0
    },
    {
      "name": "Feedback",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pitch Shifter</title>\n<style>\n  :root {\n    --accent: #7ad0ff;\n    --accent2: #b0a0ff;\n    --bg0: #0b0f15;\n    --bg1: #131a24;\n    --panel: #1a2230;\n    --panel-hi: #243042;\n    --steel: #2c3a4e;\n    --ink: #cdd9e8;\n    --ink-dim: #6f7e93;\n    --lcd: #7dffb0;\n    --lcd-dim: #1d3a2a;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background: radial-gradient(120% 140% at 50% -10%, #182230 0%, #0b0f15 60%, #06080c 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    min-height: 100%;\n  }\n\n  .unit {\n    max-width: 760px;\n    margin: 18px auto;\n    padding: 18px;\n    border-radius: 16px;\n    background:\n      linear-gradient(180deg, #1c2533 0%, #141b27 100%);\n    border: 1px solid #2a3950;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.05) inset,\n      0 -2px 0 rgba(0,0,0,0.5) inset,\n      0 24px 60px rgba(0,0,0,0.55);\n    position: relative;\n  }\n\n  /* rack ears + screws */\n  .unit::before, .unit::after {\n    content: \"\";\n    position: absolute;\n    top: 0; bottom: 0;\n    width: 22px;\n    background: linear-gradient(90deg, #20293a, #161d29);\n    border-radius: 16px 0 0 16px;\n  }\n  .unit::after { right: 0; left: auto; border-radius: 0 16px 16px 0; transform: scaleX(-1); }\n\n  .inner { position: relative; padding: 0 14px; }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    padding-bottom: 14px;\n    margin-bottom: 14px;\n    border-bottom: 1px solid #26344a;\n  }\n\n  .brand { display: flex; flex-direction: column; gap: 3px; }\n  .brand .name {\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .brand .sub {\n    font-size: 9.5px;\n    letter-spacing: 0.34em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .power-dot {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 10px var(--accent), 0 0 3px #fff inset;\n    animation: pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 0.55; box-shadow: 0 0 6px var(--accent); }\n    50%      { opacity: 1;    box-shadow: 0 0 16px var(--accent); }\n  }\n\n  /* ---- LCD readout ---- */\n  .lcd {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    background: linear-gradient(180deg, #07140d, #0a1c12);\n    border: 1px solid #0e2a1b;\n    border-radius: 8px;\n    padding: 9px 16px;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.6) inset, 0 0 0 1px rgba(125,255,176,0.05);\n    color: var(--lcd);\n    font-variant-numeric: tabular-nums;\n    text-shadow: 0 0 8px rgba(125,255,176,0.55);\n  }\n  .lcd .big {\n    font-size: 26px;\n    font-weight: 700;\n    letter-spacing: 0.04em;\n    min-width: 78px;\n  }\n  .lcd .meta { display: flex; flex-direction: column; gap: 2px; font-size: 10px; letter-spacing: 0.16em; }\n  .lcd .meta .lbl { color: #3f8a64; }\n  .lcd .meta .val { color: var(--lcd); }\n\n  /* ---- main stage ---- */\n  .stage {\n    display: grid;\n    grid-template-columns: 1fr 220px;\n    gap: 16px;\n    margin-bottom: 16px;\n  }\n  @media (max-width: 560px) { .stage { grid-template-columns: 1fr; } }\n\n  .ladder {\n    position: relative;\n    height: 240px;\n    border-radius: 12px;\n    background:\n      linear-gradient(180deg, #0c1420 0%, #0a0f18 100%);\n    border: 1px solid #233247;\n    overflow: hidden;\n    box-shadow: 0 2px 14px rgba(0,0,0,0.5) inset;\n  }\n  .ladder .center-line {\n    position: absolute; left: 0; right: 0; top: 50%;\n    height: 1px; background: rgba(122,208,255,0.25);\n  }\n  .rung {\n    position: absolute; left: 12px; right: 12px;\n    height: 1px;\n    background: rgba(255,255,255,0.05);\n    font-size: 9px;\n    color: var(--ink-dim);\n  }\n  .rung span {\n    position: absolute; right: 4px; top: -7px;\n    letter-spacing: 0.1em;\n  }\n\n  /* moving voice bars */\n  .voice {\n    position: absolute;\n    left: 22%;\n    width: 30%;\n    height: 14px;\n    border-radius: 4px;\n    transform: translateY(-50%);\n    transition: top 0.18s cubic-bezier(.22,.9,.3,1);\n    display: flex; align-items: center; justify-content: center;\n    font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;\n    color: #07121b; font-weight: 700;\n  }\n  .voice.dry {\n    left: 16%;\n    background: linear-gradient(90deg, #2c3a4e, #44597a);\n    color: var(--ink);\n    top: 50%;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.5);\n  }\n  .voice.wet {\n    left: 52%;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    box-shadow: 0 0 18px rgba(122,208,255,0.55), 0 2px 8px rgba(0,0,0,0.5);\n  }\n  .voice .glow {\n    position: absolute; inset: 0; border-radius: 4px;\n    box-shadow: 0 0 22px rgba(176,160,255,0.6);\n    opacity: 0.6;\n    animation: breathe 1.8s ease-in-out infinite;\n  }\n  @keyframes breathe { 0%,100%{opacity:.35;} 50%{opacity:.85;} }\n\n  /* the interval ribbon connecting dry->wet */\n  .ribbon { position: absolute; left: 0; top: 0; width: 100%; height: 100%; pointer-events: none; }\n\n  /* scanning shimmer */\n  .scan {\n    position: absolute; top: 0; bottom: 0; width: 80px;\n    background: linear-gradient(90deg, transparent, rgba(122,208,255,0.10), transparent);\n    animation: sweep 3.4s linear infinite;\n  }\n  @keyframes sweep { 0%{left:-80px;} 100%{left:100%;} }\n\n  /* ---- knob column ---- */\n  .controls {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px 10px;\n    align-content: start;\n  }\n  .knob-cell {\n    display: flex; flex-direction: column; align-items: center; gap: 6px;\n    background: linear-gradient(180deg, #18212f, #121925);\n    border: 1px solid #26344a;\n    border-radius: 10px;\n    padding: 10px 6px 8px;\n    box-shadow: 0 1px 0 rgba(255,255,255,0.04) inset, 0 6px 14px rgba(0,0,0,0.35);\n  }\n  .knob-cell .label {\n    font-size: 9.5px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--ink-dim);\n  }\n  .knob-cell .readout {\n    font-size: 12px; font-variant-numeric: tabular-nums; color: var(--ink);\n    letter-spacing: 0.02em;\n  }\n  .knob {\n    width: 64px; height: 64px; cursor: ns-resize; touch-action: none;\n    filter: drop-shadow(0 4px 6px rgba(0,0,0,0.5));\n  }\n  .knob:hover .knob-arc { stroke-width: 6; }\n\n  .foot {\n    margin-top: 4px;\n    font-size: 9px; letter-spacing: 0.22em; text-transform: uppercase;\n    color: var(--ink-dim); text-align: center;\n  }\n  .hint { color: #3c4c66; }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"inner\">\n      <header>\n        <div class=\"brand\">\n          <span class=\"name\">Pitch Shifter</span>\n          <span class=\"sub\">Harmonic Interval Processor</span>\n        </div>\n        <div class=\"lcd\">\n          <div class=\"big\" id=\"lcdInterval\">+7</div>\n          <div class=\"meta\">\n            <div><span class=\"lbl\">SEMI</span> <span class=\"val\" id=\"lcdSemi\">+7</span></div>\n            <div><span class=\"lbl\">CENT</span> <span class=\"val\" id=\"lcdCent\">+0</span></div>\n            <div><span class=\"lbl\">RATIO</span> <span class=\"val\" id=\"lcdRatio\">1.498</span></div>\n          </div>\n        </div>\n        <div class=\"power-dot\"></div>\n      </header>\n\n      <div class=\"stage\">\n        <div class=\"ladder\" id=\"ladder\">\n          <div class=\"scan\"></div>\n          <div class=\"center-line\"></div>\n          <svg class=\"ribbon\" id=\"ribbon\" preserveAspectRatio=\"none\"></svg>\n          <div class=\"voice dry\" id=\"voiceDry\">DRY</div>\n          <div class=\"voice wet\" id=\"voiceWet\"><span class=\"glow\"></span>SHIFT</div>\n        </div>\n\n        <div class=\"controls\" id=\"controls\"></div>\n      </div>\n\n      <div class=\"foot\">\n        Drag knob vertically &middot; double-click to reset &middot;\n        <span class=\"hint\">two crossfaded read taps</span>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Shift\",    index: 0, min: -12, max: 12, def: 7, step: 1,\n      fmt: function (v) { return (v >= 0 ? \"+\" : \"\") + Math.round(v) + \" st\"; } },\n    { name: \"Fine\",     index: 1, min: -100, max: 100, def: 0, step: 0,\n      fmt: function (v) { return (v >= 0 ? \"+\" : \"\") + Math.round(v) + \" c\"; } },\n    { name: \"Feedback\", index: 2, min: 0, max: 1, def: 0, step: 0,\n      fmt: function (v) { return Math.round(v * 100) + \" %\"; } },\n    { name: \"Mix\",      index: 3, min: 0, max: 1, def: 0.5, step: 0,\n      fmt: function (v) { return Math.round(v * 100) + \" %\"; } }\n  ];\n\n  var values = {};\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- knob factory ----\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob-cell\";\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    var svgNS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(svgNS, \"svg\");\n    svg.setAttribute(\"class\", \"knob\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // outer ring\n    var ring = document.createElementNS(svgNS, \"circle\");\n    ring.setAttribute(\"cx\", \"50\"); ring.setAttribute(\"cy\", \"50\"); ring.setAttribute(\"r\", \"42\");\n    ring.setAttribute(\"fill\", \"none\");\n    ring.setAttribute(\"stroke\", \"#0c1420\");\n    ring.setAttribute(\"stroke-width\", \"5\");\n    svg.appendChild(ring);\n\n    // value arc (track)\n    var track = document.createElementNS(svgNS, \"circle\");\n    track.setAttribute(\"cx\", \"50\"); track.setAttribute(\"cy\", \"50\"); track.setAttribute(\"r\", \"42\");\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"#23324a\");\n    track.setAttribute(\"stroke-width\", \"5\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    // arc spans 270deg, gap at the bottom\n    var CIRC = 2 * Math.PI * 42;\n    var ARC = 0.75; // 270deg\n    track.setAttribute(\"stroke-dasharray\", (CIRC * ARC) + \" \" + CIRC);\n    track.setAttribute(\"transform\", \"rotate(135 50 50)\");\n    svg.appendChild(track);\n\n    var arc = document.createElementNS(svgNS, \"circle\");\n    arc.setAttribute(\"class\", \"knob-arc\");\n    arc.setAttribute(\"cx\", \"50\"); arc.setAttribute(\"cy\", \"50\"); arc.setAttribute(\"r\", \"42\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#grad\" + p.index + \")\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    arc.setAttribute(\"transform\", \"rotate(135 50 50)\");\n    svg.appendChild(arc);\n\n    // gradient def\n    var defs = document.createElementNS(svgNS, \"defs\");\n    var grad = document.createElementNS(svgNS, \"linearGradient\");\n    grad.setAttribute(\"id\", \"grad\" + p.index);\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"0\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"1\");\n    var s1 = document.createElementNS(svgNS, \"stop\");\n    s1.setAttribute(\"offset\", \"0%\"); s1.setAttribute(\"stop-color\", \"#7ad0ff\");\n    var s2 = document.createElementNS(svgNS, \"stop\");\n    s2.setAttribute(\"offset\", \"100%\"); s2.setAttribute(\"stop-color\", \"#b0a0ff\");\n    grad.appendChild(s1); grad.appendChild(s2);\n    defs.appendChild(grad);\n    svg.appendChild(defs);\n\n    // body\n    var body = document.createElementNS(svgNS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"30\");\n    body.setAttribute(\"fill\", \"#1a2330\");\n    body.setAttribute(\"stroke\", \"#33455e\");\n    body.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(body);\n\n    // pointer notch\n    var notch = document.createElementNS(svgNS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"26\");\n    notch.setAttribute(\"stroke\", \"#9fb6d4\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    var readout = document.createElement(\"div\");\n    readout.className = \"readout\";\n\n    cell.appendChild(label);\n    cell.appendChild(svg);\n    cell.appendChild(readout);\n\n    var CIRC2 = CIRC;\n    function norm(v) { return (v - p.min) / (p.max - p.min); }\n\n    function render() {\n      var v = values[p.index];\n      var t = norm(v);\n      // arc length\n      arc.setAttribute(\"stroke-dasharray\", (CIRC2 * ARC * t) + \" \" + CIRC2);\n      // pointer angle: 135 -> 405 (i.e. -135..+135 from top)\n      var deg = -135 + t * 270;\n      notch.setAttribute(\"transform\", \"rotate(\" + deg + \" 50 50)\");\n      readout.textContent = p.fmt(v);\n    }\n\n    function setValue(v, push) {\n      v = Math.max(p.min, Math.min(p.max, v));\n      if (p.step) v = Math.round(v / p.step) * p.step;\n      values[p.index] = v;\n      render();\n      if (push) pushParam(p.index, v);\n    }\n\n    // ---- drag interaction ----\n    var dragging = false, startY = 0, startV = 0;\n    function onDown(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = values[p.index];\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = startY - y;\n      var range = p.max - p.min;\n      // fine drag with shift held\n      var speed = (e.shiftKey ? 0.0008 : 0.005);\n      setValue(startV + dy * range * speed, true);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    svg.addEventListener(\"wheel\", function (e) {\n      var range = p.max - p.min;\n      var delta = (e.deltaY < 0 ? 1 : -1) * range * (e.shiftKey ? 0.005 : 0.02);\n      setValue(values[p.index] + delta, true);\n      e.preventDefault();\n    }, { passive: false });\n\n    svg.addEventListener(\"dblclick\", function () { setValue(p.def, true); });\n\n    setValue(p.def, false);\n    return { cell: cell, render: render };\n  }\n\n  // ---- build controls ----\n  var controlsEl = document.getElementById(\"controls\");\n  var knobs = [];\n  PARAMS.forEach(function (p) {\n    var k = makeKnob(p);\n    controlsEl.appendChild(k.cell);\n    knobs.push(k);\n  });\n\n  // ---- visual stage refs ----\n  var voiceWet = document.getElementById(\"voiceWet\");\n  var voiceDry = document.getElementById(\"voiceDry\");\n  var ribbon = document.getElementById(\"ribbon\");\n  var ladder = document.getElementById(\"ladder\");\n  var lcdInterval = document.getElementById(\"lcdInterval\");\n  var lcdSemi = document.getElementById(\"lcdSemi\");\n  var lcdCent = document.getElementById(\"lcdCent\");\n  var lcdRatio = document.getElementById(\"lcdRatio\");\n\n  // build interval rungs (-12..+12 by 3)\n  for (var st = -12; st <= 12; st += 3) {\n    var rung = document.createElement(\"div\");\n    rung.className = \"rung\";\n    var t = (st + 12) / 24; // 0..1 bottom->top\n    rung.style.top = (100 - t * 100) + \"%\";\n    var s = document.createElement(\"span\");\n    s.textContent = (st > 0 ? \"+\" : \"\") + st;\n    rung.appendChild(s);\n    ladder.appendChild(rung);\n  }\n\n  function semisTotal() {\n    return values[0] + values[1] * 0.01;\n  }\n\n  function updateStage() {\n    var shift = values[0];\n    var fine = values[1];\n    var total = semisTotal();\n    // map -12..+12 -> 88%..12% (top = up)\n    var t = (total + 12) / 24;\n    t = Math.max(0, Math.min(1, t));\n    var topPct = 88 - t * 76;\n    voiceWet.style.top = topPct + \"%\";\n\n    // wet bar opacity follows Mix\n    voiceWet.style.opacity = (0.35 + 0.65 * values[3]).toFixed(3);\n    voiceDry.style.opacity = (0.4 + 0.6 * (1 - values[3])).toFixed(3);\n\n    // ribbon line from dry (center 50%) to wet\n    var dryY = 50, wetY = topPct;\n    ribbon.innerHTML =\n      '<defs><linearGradient id=\"rb\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">' +\n      '<stop offset=\"0%\" stop-color=\"#44597a\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#b0a0ff\"/></linearGradient></defs>' +\n      '<path d=\"M 30 ' + dryY + ' C 50 ' + dryY + ', 50 ' + wetY + ', 72 ' + wetY + '\" ' +\n      'vector-effect=\"non-scaling-stroke\" fill=\"none\" stroke=\"url(#rb)\" ' +\n      'stroke-width=\"2\" opacity=\"0.7\"/>';\n    // viewBox in percent-ish coords\n    ribbon.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // LCD\n    var semi = Math.round(shift);\n    var cent = Math.round(fine);\n    lcdInterval.textContent = (total >= 0 ? \"+\" : \"\") + (Math.round(total * 10) / 10);\n    lcdSemi.textContent = (semi >= 0 ? \"+\" : \"\") + semi;\n    lcdCent.textContent = (cent >= 0 ? \"+\" : \"\") + cent;\n    var ratio = Math.pow(2, total / 12);\n    lcdRatio.textContent = ratio.toFixed(3);\n  }\n\n  // re-render stage whenever a knob changes: wrap each knob's render\n  knobs.forEach(function (k) {\n    var orig = k.render;\n    k.render = function () { orig(); updateStage(); };\n  });\n\n  // monkey-patch is fragile across closures; instead just poll on a RAF loop\n  // for stage updates (cheap, keeps everything in sync with drags/wheel).\n  var lastSig = \"\";\n  function loop() {\n    if (!document.hidden) {\n      var sig = values[0] + \"|\" + values[1] + \"|\" + values[3];\n      if (sig !== lastSig) { updateStage(); lastSig = sig; }\n    }\n    requestAnimationFrame(loop);\n  }\n\n  // ---- init: push defaults to engine, draw stage ----\n  function start() {\n    PARAMS.forEach(function (p) { pushParam(p.index, values[p.index]); });\n    updateStage();\n    requestAnimationFrame(loop);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  PITCH SHIFTER — delay-line harmonizer\n//  A real-time pitch shifter built on a circular delay line read by TWO\n//  read pointers that drift at a rate set by the pitch ratio. As each\n//  pointer sweeps across the buffer it is crossfaded with the other using\n//  a raised-cosine window, so the inevitable wrap discontinuity is masked\n//  and the shifted voice stays click-free. The shifted voice is fed back\n//  into the line (regeneration / arpeggiated cascades) and blended with\n//  the dry signal. Shift sets the interval in semitones, Fine trims it in\n//  cents, Feedback regenerates the shifted voice, Mix balances dry/wet.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Circular delay line per channel. ~90 ms window at 48 kHz is plenty for\n// a smooth grain while keeping latency/comb artefacts musical.\nconst LINE_LEN: i32 = 8192;            // power-of-two-ish window per channel\nconst WINDOW: f32 = 4096.0;            // pointer travel before re-seed (samples)\nconst delayL: StaticArray<f32> = new StaticArray<f32>(LINE_LEN);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(LINE_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\n\n// two read phases (0..WINDOW), offset by half a window so one is fading in\n// while the other fades out.\nlet phaseA: f32 = 0.0;\nlet phaseB: f32 = WINDOW * 0.5;\n\n// smoothed pitch ratio to avoid zipper noise when Shift/Fine move\nlet smoothRatio: f32 = 1.0;\n\nconst P_SHIFT: i32 = 0;     // -12..+12 semitones (integer selector, step 1)\nconst P_FINE: i32 = 1;      // -100..+100 cents (continuous)\nconst P_FEEDBACK: i32 = 2;  // 0..1 -> 0..0.85 regeneration\nconst P_MIX: i32 = 3;       // 0..1 dry/wet\n\nconst TWO_PI: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  phaseA = 0.0;\n  phaseB = WINDOW * 0.5;\n  smoothRatio = 1.0;\n  for (let i = 0; i < LINE_LEN; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  params[P_SHIFT] = 7.0;     // a perfect fifth up — instantly hear the harmony\n  params[P_FINE] = 0.0;\n  params[P_FEEDBACK] = 0.0;\n  params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// read a delay line at a fractional sample distance behind the write head,\n// linear interpolation, wrap-safe.\n@inline function readLine(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(LINE_LEN);\n  while (rp >= f32(LINE_LEN)) rp -= f32(LINE_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= LINE_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  // Shift: integer semitones, -12..+12.\n  let semis: f32 = clampf(params[P_SHIFT], -12.0, 12.0);\n  // Fine: cents, -100..+100.\n  const cents: f32 = clampf(params[P_FINE], -100.0, 100.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // target pitch ratio: 2^((semitones + cents/100) / 12)\n  const totalSemis: f32 = semis + cents * 0.01;\n  const targetRatio: f32 = f32(Mathf.pow(2.0, totalSemis / 12.0));\n\n  // feedback gain — bounded well below 1 so cascades stay finite.\n  const fbGain: f32 = fbN * 0.85;\n\n  // The delay-tap pointers move at (1 - ratio) per sample relative to the\n  // write head: when ratio > 1 (up) the read delay must SHRINK so the tap\n  // reads faster than write (higher pitch); when ratio < 1 (down) the delay\n  // grows. We sweep within [0, WINDOW] and wrap, masking the jump with the\n  // raised-cosine crossfade window.\n\n  // smoothing coeff for the ratio (~12 Hz corner) to avoid zipper noise.\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 12.0 / sampleRate));\n\n  const stereo: bool = channels > 1;\n  const invW: f32 = 1.0 / WINDOW;\n\n  for (let f = 0; f < n; f++) {\n    smoothRatio += smoothCoeff * (targetRatio - smoothRatio);\n    const r: f32 = 1.0 - smoothRatio;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n\n    // raised-cosine crossfade weights from the two phases.\n    const wA: f32 = f32(0.5 - 0.5 * Mathf.cos(TWO_PI * phaseA * invW));\n    const wB: f32 = f32(0.5 - 0.5 * Mathf.cos(TWO_PI * phaseB * invW));\n\n    // shifted voice = windowed sum of the two taps (small base delay keeps\n    // the tap inside the line and away from the write head).\n    const base: f32 = 2.0;\n    const shiftedL: f32 = readLine(delayL, base + phaseA) * wA\n                        + readLine(delayL, base + phaseB) * wB;\n    const shiftedR: f32 = stereo\n                        ? (readLine(delayR, base + phaseA) * wA\n                         + readLine(delayR, base + phaseB) * wB)\n                        : shiftedL;\n\n    // write input + regenerated shifted voice back into the line.\n    delayL[writePos] = f32(xL + shiftedL * fbGain);\n    if (stereo) delayR[writePos] = f32(xR + shiftedR * fbGain);\n    else delayR[writePos] = delayL[writePos];\n\n    // advance phases; wrap within the window. The two phases stay a half\n    // window apart so the crossfade is seamless.\n    phaseA += r;\n    phaseB += r;\n    while (phaseA >= WINDOW) phaseA -= WINDOW;\n    while (phaseA < 0.0) phaseA += WINDOW;\n    while (phaseB >= WINDOW) phaseB -= WINDOW;\n    while (phaseB < 0.0) phaseB += WINDOW;\n\n    // gain-stage the wet voice a touch; the windowed sum has unity-ish gain.\n    const wetL: f32 = shiftedL;\n    const wetR: f32 = shiftedR;\n\n    outBuf[f] = f32(xL * (1.0 - mix) + wetL * mix);\n    if (stereo) outBuf[MAX_FRAMES + f] = f32(xR * (1.0 - mix) + wetR * mix);\n    else outBuf[MAX_FRAMES + f] = outBuf[f];\n\n    writePos++;\n    if (writePos >= LINE_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000056000
}