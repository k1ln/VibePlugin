  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Fair Cell</title>\n<style>\n  :root{ --acc:#7ad07a; --acc2:#ffb84a; --bg0:#060c07; --bg1:#0c160c; --ink:#e6f5e6; --dim:#6e8c6e; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#122814 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:13px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#0e1e10,#060c07); border:1px solid rgba(122,208,122,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(230,245,230,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; font-family:\"Courier New\",monospace; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); font-family:\"Courier New\",monospace; }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 1.8s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:100px; border-radius:6px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#08120a,#050b06); border:1px solid rgba(122,208,122,.18); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; font-family:\"Courier New\",monospace; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(210,232,210,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(122,208,122,.6)); }\n  .pcap{ fill:#0a140b; stroke:rgba(122,208,122,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); font-family:\"Courier New\",monospace; } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(122,208,122,.1); padding:1px 7px; border-radius:5px; border:1px solid rgba(122,208,122,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">FAIR&nbsp;CELL</span><span class=\"sub\">8-bit sampler</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">SAMPLE&nbsp;VOICE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Tune\",idx:0,def:0.5},{name:\"Cutoff\",idx:1,def:0.7},{name:\"Decay\",idx:2,def:0.55},{name:\"Crunch\",idx:3,def:0.3},{name:\"Attack\",idx:4,def:0.1},{name:\"Level\",idx:5,def:0.85}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#7ad07a\"/><stop offset=\"1\" stop-color=\"#ffb84a\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  // approximate the baked sample waveform (formant tone, decaying), sampled to columns\n  var NS=200, WAVE=new Float32Array(NS);\n  for(var i=0;i<NS;i++){ var u=i/NS; var t=u*0.5;\n    var v=Math.sin(2*Math.PI*220*t)*0.6 + Math.sin(2*Math.PI*660*t)*0.3 + Math.sin(2*Math.PI*1180*t)*0.25;\n    v*=Math.min(1,t/0.02)*Math.exp(-u*1.4); WAVE[i]=Math.round(v*10)/10; }\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var mid=H*0.52, crunch=vals[3], cutoff=vals[1];\n    // CRT scanlines\n    ctx.globalAlpha=0.06; ctx.strokeStyle=\"#7ad07a\"; ctx.lineWidth=1; for(var y=6;y<H;y+=4){ ctx.beginPath(); ctx.moveTo(0,y); ctx.lineTo(W,y); ctx.stroke(); } ctx.globalAlpha=1;\n    // sample waveform (mirrored, phosphor green). crunch = chunkier steps\n    var padL=12, padR=12, sw=W-padL-padR; var step=Math.max(1, Math.round(1+crunch*5));\n    ctx.fillStyle=\"rgba(122,208,122,0.5)\";\n    for(var x=0;x<sw;x+=step){ var idx=Math.floor(x/sw*NS); var a=Math.abs(WAVE[idx])*(0.5+cutoff*0.6); var h=a*(H*0.42);\n      ctx.globalAlpha=0.35+a*0.55; ctx.fillRect(padL+x, mid-h, Math.max(1,step-1), h*2); }\n    ctx.globalAlpha=1;\n    // outline\n    ctx.beginPath(); for(var x2=0;x2<=sw;x2+=2){ var i2=Math.floor(x2/sw*NS); var vv=WAVE[i2]*(0.5+cutoff*0.6); ctx.lineTo(padL+x2, mid - vv*(H*0.42)); }\n    ctx.strokeStyle=\"rgba(180,255,180,0.8)\"; ctx.lineWidth=1; ctx.shadowColor=\"#7ad07a\"; ctx.shadowBlur=5; ctx.stroke(); ctx.shadowBlur=0;\n    // playback cursor (loops), amber light-pen\n    var cur=(ts/900)%1; var cx=padL+cur*sw;\n    ctx.strokeStyle=\"rgba(255,184,74,0.85)\"; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(cx,8); ctx.lineTo(cx,H-8); ctx.stroke();\n    ctx.fillStyle=\"#ffb84a\"; ctx.beginPath(); ctx.arc(cx,mid,3,0,Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  FAIR CELL — an 8-bit sampler (Fairlight CMI lineage). Plays a baked,\n//  self-authored CC0 sample — a morphing formant-vocal \"aah->ooh\" tone,\n//  bit-crushed to 8-bit for the gritty digital Fairlight character —\n//  pitched across the keyboard with an amp envelope and a resonant\n//  low-pass. The signature CRUNCH re-crushes the playback for more of\n//  that early-digital-sampler grain. 6-voice poly.\n//  Controls: Tune, Cutoff, Decay, Crunch, Attack, Level.\n//  Sample is synthesised at build time (no third-party audio); decoded\n//  from base64 Int16 PCM at init(). No host imports, no alloc in process.\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 6;\nconst SAMP_CAP: i32 = 12000;\nconst SAMP_SR: f32 = 24000.0;\nconst BASE_FREQ: f32 = 220.0;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\nconst samp: StaticArray<f32> = new StaticArray<f32>(SAMP_CAP);\nlet sampLen: i32 = 0;\n\nconst vPos: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vRate: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\nlet holdVal: f32 = 0.0; let holdCnt: i32 = 0;\n\nconst P_TUNE: i32 = 0; const P_CUTOFF: i32 = 1; const P_DECAY: i32 = 2; const P_CRUNCH: i32 = 3; const P_ATTACK: i32 = 4; const P_LEVEL: i32 = 5;\n\nconst SAMPLE_B64: string = \"\";\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\nfunction decodeSample(): void {\n  const s = SAMPLE_B64; const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else {\n        let val = (byte << 8) | lo;\n        if (val >= 32768) val -= 65536;\n        if (si < SAMP_CAP) { samp[si] = f32(val) / 32768.0; si++; }\n        lo = -1;\n      }\n    }\n  }\n  sampLen = si;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vPos[i] = 0.0; vRate[i] = 1.0; vAmp[i] = 0.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_TUNE] = 0.5; params[P_CUTOFF] = 0.7; params[P_DECAY] = 0.55; params[P_CRUNCH] = 0.3; params[P_ATTACK] = 0.1; params[P_LEVEL] = 0.85;\n  decodeSample();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPos[slot] = 0.0; vAmp[slot] = 0.0; vSt[slot] = 1;\n  const nf: f32 = f > 0.0 ? f : BASE_FREQ;\n  vRate[slot] = nf / BASE_FREQ;              // base pitch ratio (Tune applied in process)\n  vVel[slot] = clampf(v, 0.05, 1.0); vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const tuneN: f32 = clampf(params[P_TUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const crunchN: f32 = clampf(params[P_CRUNCH], 0.0, 1.0);\n  const attackN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const srRatio: f32 = SAMP_SR / sampleRate;\n  const tuneMul: f32 = f32(Mathf.exp((tuneN - 0.5) * 1.386));   // +/- 1 octave\n  const baseCut: f32 = 60.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const k: f32 = 1.4;\n  const atkInc: f32 = 1.0 / ((0.001 + attackN * 0.25) * sampleRate);\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / ((0.1 + decayN * 2.5) * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.15 * sampleRate)));\n  const levels: f32 = 128.0 - crunchN * 116.0;               // 128 -> 12 levels\n  const holdLen: i32 = 1 + i32(crunchN * 6.0);               // 1 -> 7x downsample (grain)\n  const out: f32 = level * 0.6;\n\n  let fc: f32 = baseCut; if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n  const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n  const a1c: f32 = 1.0 / (1.0 + g * (g + k));\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      // amp env\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] >= 1.0) { vAmp[s] = 1.0; vSt[s] = 3; } }\n      else {\n        if (vSt[s] == 3) { vAmp[s] *= decCoef; } else { vAmp[s] *= relCoef; }\n        if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; }\n      }\n      // sample read\n      let pos: f32 = vPos[s];\n      let i0: i32 = i32(pos); const frac: f32 = pos - f32(i0);\n      let i1: i32 = i0 + 1;\n      let smp: f32 = 0.0;\n      if (i0 >= 0 && i1 < sampLen) { smp = samp[i0] + (samp[i1] - samp[i0]) * frac; }\n      else if (i0 >= 0 && i0 < sampLen) { smp = samp[i0]; }\n      else { vSt[s] = 0; continue; }\n      // extra crunch\n      smp = f32(Mathf.floor(smp * levels + 0.5)) / levels;\n      // filter\n      const hp: f32 = (smp - (g + k) * vBp[s] - vLp[s]) * a1c;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      mix += lpN * vAmp[s] * vVel[s];\n      // advance\n      pos += vRate[s] * tuneMul * srRatio; vPos[s] = pos;\n      if (pos >= f32(sampLen)) { vSt[s] = 0; }\n    }\n    // Crunch sample-rate reducer (grain) on the summed voices\n    holdCnt += 1;\n    if (holdCnt >= holdLen) { holdCnt = 0; holdVal = mix; }\n    let o: f32 = holdVal * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751307200000
}