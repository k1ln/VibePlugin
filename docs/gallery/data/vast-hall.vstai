{
  "format": 1,
  "name": "Vast Hall",
  "isInstrument": false,
  "explanation": "Large digital hall reverb. An input diffusion chain feeds an 8-line feedback delay network with a lossless Householder feedback matrix and per-line high-frequency damping, for a smooth, dense, long-tailed hall. Controls: dry/wet Mix, room Size, Decay (RT60 up to ~12 s), HF Damping, Pre-Delay and stereo Width.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Size",
      "index": 1,
      "min": 0.3,
      "max": 1,
      "default": 0.75
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Damping",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Pre-Delay",
      "index": 4,
      "min": 0,
      "max": 0.12,
      "default": 0.02
    },
    {
      "name": "Width",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Vast Hall</title>\n<style>\n  :root{\n    --ac:#5ad1ff;       /* accent  */\n    --ac2:#7a8cff;      /* accent2 */\n    --ink:#dfeefc;\n    --dim:#7e93b4;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none}\n  html,body{margin:0;height:100%}\n  body{\n    font:13px/1.4 ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    color:var(--ink);\n    background:#04060b;\n    overflow:hidden;\n    position:relative;\n  }\n  /* ============ THE HALL — receding nave of arches ============ */\n  .stage{position:absolute;inset:0;perspective:760px;perspective-origin:50% 42%;overflow:hidden}\n  .floor{\n    position:absolute;left:-30%;right:-30%;bottom:0;height:62%;\n    background:\n      linear-gradient(180deg,transparent,rgba(90,209,255,.05) 40%,rgba(10,16,28,.9)),\n      repeating-linear-gradient(90deg,transparent 0 48px,rgba(122,140,255,.06) 48px 49px);\n    transform:rotateX(72deg);transform-origin:bottom center;\n    box-shadow:0 0 120px 40px rgba(90,209,255,.06) inset;\n    opacity:.7;\n  }\n  /* nave: depth-stacked archways drawn as one repeating SVG, slow drift */\n  .nave{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\n        transform-style:preserve-3d}\n  .ring{\n    position:absolute;left:50%;top:42%;width:340px;height:430px;margin:-215px 0 0 -170px;\n    border-radius:50% 50% 8% 8% / 60% 60% 5% 5%;\n    border:1.5px solid rgba(160,205,255,.16);\n    border-bottom:0;\n    box-shadow:0 0 24px rgba(90,209,255,.10), inset 0 0 30px rgba(122,140,255,.08);\n    animation:recede 9s linear infinite;\n    will-change:transform,opacity;\n  }\n  /* twelve arches phased through one 9s recede cycle for an endless tunnel */\n  .ring:nth-child(1){animation-delay:0s}\n  .ring:nth-child(2){animation-delay:-.75s}\n  .ring:nth-child(3){animation-delay:-1.5s}\n  .ring:nth-child(4){animation-delay:-2.25s}\n  .ring:nth-child(5){animation-delay:-3s}\n  .ring:nth-child(6){animation-delay:-3.75s}\n  .ring:nth-child(7){animation-delay:-4.5s}\n  .ring:nth-child(8){animation-delay:-5.25s}\n  .ring:nth-child(9){animation-delay:-6s}\n  .ring:nth-child(10){animation-delay:-6.75s}\n  .ring:nth-child(11){animation-delay:-7.5s}\n  .ring:nth-child(12){animation-delay:-8.25s}\n  @keyframes recede{\n    0%  {transform:translateZ(620px) scale(1.9);opacity:0}\n    12% {opacity:.9}\n    100%{transform:translateZ(-1700px) scale(.06);opacity:0}\n  }\n  /* volumetric light shaft pouring down the centre */\n  .shaft{\n    position:absolute;left:50%;top:-8%;width:230px;height:120%;margin-left:-115px;\n    background:linear-gradient(180deg,rgba(90,209,255,.30),rgba(122,140,255,.05) 55%,transparent);\n    filter:blur(20px);\n    transform:rotate(2deg);\n    mix-blend-mode:screen;\n    animation:breathe 7s ease-in-out infinite;\n    pointer-events:none;\n  }\n  .shaft.b{left:32%;width:120px;margin-left:0;transform:rotate(-7deg);animation-delay:-2.4s;opacity:.6}\n  .shaft.c{left:64%;width:140px;margin-left:0;transform:rotate(8deg);animation-delay:-4s;opacity:.55}\n  @keyframes breathe{0%,100%{opacity:.55;filter:blur(20px)}50%{opacity:1;filter:blur(28px)}}\n  /* drifting dust motes — a particle shimmer (pure CSS, transform only) */\n  .motes{position:absolute;inset:0;pointer-events:none;mix-blend-mode:screen}\n  .mote{position:absolute;width:3px;height:3px;border-radius:50%;\n    background:radial-gradient(circle,#cdeeff,rgba(90,209,255,0));\n    animation:rise linear infinite;will-change:transform,opacity}\n  @keyframes rise{\n    0%{transform:translateY(20px) scale(.6);opacity:0}\n    15%{opacity:.9}\n    85%{opacity:.5}\n    100%{transform:translateY(-120px) scale(1.3);opacity:0}\n  }\n  .vignette{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(120% 90% at 50% 38%,transparent 40%,rgba(2,4,9,.7) 88%)}\n\n  /* ============ FOREGROUND UI ============ */\n  .wrap{position:absolute;inset:0;display:flex;flex-direction:column;\n        justify-content:space-between;padding:20px 26px 22px}\n  .head{display:flex;align-items:baseline;gap:14px;text-shadow:0 2px 18px rgba(0,0,0,.7)}\n  .head h1{\n    margin:0;font-size:23px;font-weight:300;letter-spacing:.42em;\n    text-transform:uppercase;\n    background:linear-gradient(90deg,var(--ac),var(--ac2));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n  }\n  .head .tag{font-size:9.5px;letter-spacing:.34em;color:var(--dim);text-transform:uppercase}\n  .head .rt{margin-left:auto;font-size:10px;letter-spacing:.18em;color:var(--dim)}\n  .head .rt b{color:var(--ac);font-variant-numeric:tabular-nums;font-weight:600}\n\n  /* the airy minimalist control bar */\n  .bar{\n    display:flex;gap:6px;align-items:flex-end;justify-content:center;\n    padding:18px 20px 14px;border-radius:20px;\n    background:linear-gradient(180deg,rgba(18,26,42,.46),rgba(8,12,22,.62));\n    border:1px solid rgba(122,140,255,.16);\n    box-shadow:0 24px 60px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.05);\n    backdrop-filter:blur(9px);-webkit-backdrop-filter:blur(9px);\n  }\n  .cell{flex:1;display:flex;flex-direction:column;align-items:center;gap:9px;\n         padding:4px 2px;border-radius:14px;cursor:ns-resize;position:relative;\n         transition:background .25s}\n  .cell:hover{background:rgba(90,209,255,.05)}\n  .cell .name{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:var(--dim);\n              transition:color .25s}\n  .cell:hover .name{color:var(--ac)}\n  .cell .val{font-size:11px;font-variant-numeric:tabular-nums;color:var(--ink);\n             letter-spacing:.04em;min-height:14px}\n  .cell svg{display:block;overflow:visible}\n  /* the dial body */\n  .track{fill:none;stroke:rgba(122,140,255,.18);stroke-width:5;stroke-linecap:round}\n  .fill{fill:none;stroke:url(#g);stroke-width:5;stroke-linecap:round;\n        filter:drop-shadow(0 0 6px var(--ac));transition:filter .2s}\n  .cell:hover .fill,.cell.drag .fill{filter:drop-shadow(0 0 11px var(--ac))}\n  .hub{fill:rgba(10,16,28,.85);stroke:rgba(122,140,255,.25);stroke-width:1}\n  .tick{stroke:var(--ac);stroke-width:2.5;stroke-linecap:round;\n        filter:drop-shadow(0 0 5px var(--ac))}\n  .glow{fill:var(--ac);opacity:0;transition:opacity .2s}\n  .cell.drag .glow{opacity:.10}\n  /* ripple emitted on the surrounding hall when a dial moves */\n  .ping{position:absolute;left:50%;top:0;width:14px;height:14px;margin-left:-7px;\n        border-radius:50%;border:1px solid var(--ac);pointer-events:none;opacity:0}\n  .ping.go{animation:ping .6s ease-out}\n  @keyframes ping{0%{opacity:.7;transform:scale(.4)}100%{opacity:0;transform:scale(7)}}\n\n  @media (prefers-reduced-motion:reduce){\n    .ring,.shaft,.mote{animation-duration:0s !important}\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\" aria-hidden=\"true\">\n    <div class=\"floor\"></div>\n    <div class=\"nave\" id=\"nave\">\n      <div class=\"ring\"></div><div class=\"ring\"></div><div class=\"ring\"></div>\n      <div class=\"ring\"></div><div class=\"ring\"></div><div class=\"ring\"></div>\n      <div class=\"ring\"></div><div class=\"ring\"></div><div class=\"ring\"></div>\n      <div class=\"ring\"></div><div class=\"ring\"></div><div class=\"ring\"></div>\n    </div>\n    <div class=\"shaft\" id=\"shaft\"></div>\n    <div class=\"shaft b\"></div>\n    <div class=\"shaft c\"></div>\n    <div class=\"motes\" id=\"motes\"></div>\n    <div class=\"vignette\"></div>\n  </div>\n\n  <div class=\"wrap\">\n    <div class=\"head\">\n      <h1>Vast&nbsp;Hall</h1>\n      <span class=\"tag\">Cathedral&nbsp;Reverb</span>\n      <span class=\"rt\">RT60&nbsp;·&nbsp;<b id=\"rt\">—</b></span>\n    </div>\n    <div class=\"bar\" id=\"bar\"></div>\n  </div>\n\n<script>\n(function(){\n  // ---- params straight from spec.json (index/min/max/default) ----\n  var PARAMS=[\n    {name:\"Mix\",       index:0, min:0,   max:1,    def:0.3,  unit:\"%\",  fmt:function(v){return Math.round(v*100)+\"%\"}},\n    {name:\"Size\",      index:1, min:0.3, max:1,    def:0.75, unit:\"\",   fmt:function(v){return Math.round(v*100)+\"%\"}},\n    {name:\"Decay\",     index:2, min:0,   max:1,    def:0.6,  unit:\"\",   fmt:function(v){return Math.round(v*100)+\"%\"}},\n    {name:\"Damping\",   index:3, min:0,   max:1,    def:0.45, unit:\"\",   fmt:function(v){return Math.round(v*100)+\"%\"}},\n    {name:\"Pre-Delay\", index:4, min:0,   max:0.12, def:0.02, unit:\"ms\", fmt:function(v){return (v*1000).toFixed(0)+\" ms\"}},\n    {name:\"Width\",     index:5, min:0,   max:1,    def:1,    unit:\"\",   fmt:function(v){return Math.round(v*100)+\"%\"}}\n  ];\n\n  var NS=\"http://www.w3.org/2000/svg\";\n  function el(t,a){var e=document.createElementNS(NS,t);if(a)for(var k in a)e.setAttribute(k,a[k]);return e;}\n\n  var bar=document.getElementById(\"bar\");\n  var cells=[];\n  var state=PARAMS.map(function(p){return p.def;});\n\n  // arc geometry for a 270° dial\n  var R=26, CX=32, CY=33;\n  var A0=135, A1=405;                       // start/sweep in degrees (clockwise from top-left)\n  function pt(deg){var r=deg*Math.PI/180;return [CX+R*Math.cos(r), CY+R*Math.sin(r)];}\n  function arcPath(from,to){\n    var a=pt(from), b=pt(to);\n    var large=(to-from)>180?1:0;\n    return \"M\"+a[0].toFixed(2)+\" \"+a[1].toFixed(2)+\" A\"+R+\" \"+R+\" 0 \"+large+\" 1 \"+b[0].toFixed(2)+\" \"+b[1].toFixed(2);\n  }\n\n  PARAMS.forEach(function(p,ci){\n    var cell=document.createElement(\"div\");\n    cell.className=\"cell\";\n\n    var name=document.createElement(\"div\");name.className=\"name\";name.textContent=p.name;\n    var svg=el(\"svg\",{width:64,height:66,viewBox:\"0 0 64 66\"});\n\n    // gradient def (per-cell so each dial gets its own glow)\n    var defs=el(\"defs\");\n    var grad=el(\"linearGradient\",{id:\"g\"+ci,x1:\"0\",y1:\"0\",x2:\"1\",y2:\"1\"});\n    grad.appendChild(el(\"stop\",{offset:\"0\",\"stop-color\":\"var(--ac2)\"}));\n    grad.appendChild(el(\"stop\",{offset:\"1\",\"stop-color\":\"var(--ac)\"}));\n    defs.appendChild(grad);svg.appendChild(defs);\n\n    var glow=el(\"circle\",{cx:CX,cy:CY,r:R+7,class:\"glow\"});svg.appendChild(glow);\n    svg.appendChild(el(\"path\",{class:\"track\",d:arcPath(A0,A1)}));\n    var fill=el(\"path\",{class:\"fill\",d:arcPath(A0,A0+1)});\n    fill.style.stroke=\"url(#g\"+ci+\")\";svg.appendChild(fill);\n    svg.appendChild(el(\"circle\",{class:\"hub\",cx:CX,cy:CY,r:10}));\n    var tick=el(\"line\",{class:\"tick\",x1:CX,y1:CY,x2:CX,y2:CY-R+2});svg.appendChild(tick);\n\n    var val=document.createElement(\"div\");val.className=\"val\";\n    var ping=document.createElement(\"div\");ping.className=\"ping\";\n\n    cell.appendChild(name);cell.appendChild(svg);cell.appendChild(val);cell.appendChild(ping);\n    bar.appendChild(cell);\n\n    var c={p:p,cell:cell,fill:fill,tick:tick,val:val,ping:ping};\n    cells.push(c);\n    bindDrag(c,ci);\n    render(c);\n  });\n\n  function norm(c){return (state[c.p.index]-c.p.min)/(c.p.max-c.p.min);} // 0..1\n  function render(c){\n    var n=Math.max(0,Math.min(1,norm(c)));\n    var ang=A0+n*(A1-A0);\n    c.fill.setAttribute(\"d\",arcPath(A0, Math.max(A0+0.5,ang)));\n    c.tick.setAttribute(\"transform\",\"rotate(\"+(ang+90)+\" \"+CX+\" \"+CY+\")\");\n    c.val.textContent=c.p.fmt(state[c.p.index]);\n  }\n\n  // ---- host bridge ----\n  function send(c){\n    var v=state[c.p.index];\n    if(window.vstai&&window.vstai.setParam) window.vstai.setParam(c.p.index, v);\n  }\n  function setVal(c,v,push){\n    v=Math.max(c.p.min,Math.min(c.p.max,v));\n    state[c.p.index]=v;\n    render(c);\n    if(push!==false) send(c);\n    updateScene();\n  }\n\n  // ---- pointer drag (vertical = change). dbl-click resets to default ----\n  function bindDrag(c,ci){\n    var cell=c.cell, dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true;cell.classList.add(\"drag\");\n      startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startV=state[c.p.index];\n      e.preventDefault();\n      ripple(c);\n      window.addEventListener(\"pointermove\",move);\n      window.addEventListener(\"pointerup\",up);\n    }\n    function move(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var span=c.p.max-c.p.min;\n      // fine control with shift; 180px ≈ full range\n      var k=(e.shiftKey?4:1);\n      var dv=(startY-y)/180*span/k;\n      setVal(c,startV+dv);\n      ripple(c);\n    }\n    function up(){\n      dragging=false;cell.classList.remove(\"drag\");\n      window.removeEventListener(\"pointermove\",move);\n      window.removeEventListener(\"pointerup\",up);\n    }\n    cell.addEventListener(\"pointerdown\",down);\n    // wheel nudge\n    cell.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      var span=c.p.max-c.p.min;\n      setVal(c, state[c.p.index] - Math.sign(e.deltaY)*span*0.03);\n      ripple(c);\n    },{passive:false});\n    // dbl-click → default\n    cell.addEventListener(\"dblclick\",function(){setVal(c,c.p.def);ripple(c);});\n  }\n\n  var rT=0;\n  function ripple(c){\n    var now=Date.now(); if(now-rT<70)return; rT=now;\n    c.ping.classList.remove(\"go\"); void c.ping.offsetWidth; c.ping.classList.add(\"go\");\n  }\n\n  // ---- live scene response: Size/Decay/Damping/Width reshape the hall ----\n  var nave=document.getElementById(\"nave\");\n  var shaft=document.getElementById(\"shaft\");\n  var rtEl=document.getElementById(\"rt\");\n  function v(i){return state[i];}\n  function updateScene(){\n    var size=v(1), decay=v(2), damp=v(3), width=v(5), mix=v(0);\n    // longer decay → slower, brighter recede; size → wider nave\n    var dur=(11 - decay*6).toFixed(2);              // 5..11s\n    nave.style.setProperty(\"--spd\",dur);\n    var rings=nave.children;\n    for(var i=0;i<rings.length;i++){\n      rings[i].style.animationDuration=dur+\"s\";\n      rings[i].style.opacity=(0.55+mix*0.45);\n      // width spreads the arches horizontally\n      rings[i].style.width=(300+size*120)+\"px\";\n      rings[i].style.marginLeft=(-(300+size*120)/2)+\"px\";\n      // damping dims the high-frequency shimmer (cooler, darker arches)\n      rings[i].style.filter=\"brightness(\"+(1.25-damp*0.6)+\") saturate(\"+(0.6+(1-damp)*0.8)+\")\";\n    }\n    nave.style.transform=\"scaleX(\"+(0.7+width*0.6)+\")\";\n    shaft.style.opacity=(0.4+mix*0.6);\n    // pseudo RT60 readout: decay + size, up to ~12s (matches the spec note)\n    var rt60=(0.3 + decay*decay*11 + (size-0.3)*1.5).toFixed(1);\n    rtEl.textContent=rt60+\" s\";\n  }\n\n  // ---- dust motes (built once, randomised) ----\n  (function(){\n    var box=document.getElementById(\"motes\");\n    for(var i=0;i<34;i++){\n      var m=document.createElement(\"div\");m.className=\"mote\";\n      m.style.left=(Math.random()*100)+\"%\";\n      m.style.top=(30+Math.random()*65)+\"%\";\n      var d=6+Math.random()*9;\n      m.style.animationDuration=d+\"s\";\n      m.style.animationDelay=(-Math.random()*d)+\"s\";\n      var s=0.5+Math.random()*1.4;\n      m.style.transform=\"scale(\"+s+\")\";\n      box.appendChild(m);\n    }\n  })();\n\n  // ---- host ready: init every param to default + push once ----\n  function ready(){\n    cells.forEach(function(c){ render(c); send(c); });\n    updateScene();\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VAST HALL — large digital hall reverb\n//  Modelled on the architecture of classic late-1970s digital hall units:\n//  an input diffusion chain feeding an 8-line feedback delay network (FDN)\n//  with a lossless Householder feedback matrix and per-line HF damping.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- FDN configuration ----------------------------------------------\nconst NLINES: i32 = 8;\nconst LINE_CAP: i32 = 16384;                 // per-line ring capacity (samples)\nconst lines: StaticArray<f32> = new StaticArray<f32>(NLINES * LINE_CAP);\nconst linePos: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineLen: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineGain: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst damp: StaticArray<f32> = new StaticArray<f32>(NLINES);   // one-pole LP state per line\n\n// base delay lengths in samples @48k (prime-ish, spread for density)\nconst baseLen: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst outs: StaticArray<f32> = new StaticArray<f32>(NLINES);   // per-sample line outputs (no alloc in process)\n\n// --- input diffusion (4 Schroeder allpasses) ------------------------\nconst NAP: i32 = 4;\nconst AP_CAP: i32 = 2048;\nconst ap: StaticArray<f32> = new StaticArray<f32>(NAP * AP_CAP);\nconst apPos: StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apLen: StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apBase: StaticArray<i32> = new StaticArray<i32>(NAP);\n\n// --- pre-delay (mono send) ------------------------------------------\nconst PRE_CAP: i32 = 32768;\nconst preBuf: StaticArray<f32> = new StaticArray<f32>(PRE_CAP);\nlet prePos: i32 = 0;\n\n// parameter indices\nconst P_MIX: i32 = 0;      // 0..1 dry/wet\nconst P_SIZE: i32 = 1;     // 0.3..1.0 scales delay lengths\nconst P_DECAY: i32 = 2;    // 0..1 -> RT60\nconst P_DAMP: i32 = 3;     // 0..1 HF damping\nconst P_PRE: i32 = 4;      // 0..0.12 s pre-delay\nconst P_WIDTH: i32 = 5;    // 0..1 stereo width\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  baseLen[0] = 911;  baseLen[1] = 1129; baseLen[2] = 1399; baseLen[3] = 1747;\n  baseLen[4] = 1951; baseLen[5] = 2099; baseLen[6] = 2503; baseLen[7] = 2843;\n  apBase[0] = 142; apBase[1] = 379; apBase[2] = 107; apBase[3] = 277;\n\n  for (let i = 0; i < NLINES; i++) { linePos[i] = 0; damp[i] = 0.0; lineLen[i] = baseLen[i]; lineGain[i] = 0.0; }\n  for (let i = 0; i < NAP; i++)   { apPos[i] = 0; apLen[i] = apBase[i]; }\n  for (let i = 0; i < NLINES * LINE_CAP; i++) lines[i] = 0.0;\n  for (let i = 0; i < NAP * AP_CAP; i++) ap[i] = 0.0;\n  for (let i = 0; i < PRE_CAP; i++) preBuf[i] = 0.0;\n  prePos = 0;\n\n  params[P_MIX] = 0.30; params[P_SIZE] = 0.75; params[P_DECAY] = 0.60;\n  params[P_DAMP] = 0.45; params[P_PRE] = 0.02; params[P_WIDTH] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Freeverb-style allpass diffuser\n@inline function allpass(i: i32, x: f32): f32 {\n  const base: i32 = i * AP_CAP;\n  let p: i32 = apPos[i];\n  const buffered: f32 = ap[base + p];\n  const y: f32 = buffered - x;            // allpass output\n  ap[base + p] = x + buffered * 0.5;      // g = 0.5\n  p++; if (p >= apLen[i]) p = 0;\n  apPos[i] = p;\n  return y;\n}\n\nexport function process(n: i32): void {\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const size: f32 = clampf(params[P_SIZE], 0.3, 1.0);\n  const decay: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const damping: f32 = clampf(params[P_DAMP], 0.0, 1.0);\n  const preSec: f32 = clampf(params[P_PRE], 0.0, 0.12);\n  const width: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n\n  const srRatio: f32 = sampleRate / 48000.0;\n\n  // recompute per-line delay lengths and feedback gains for this block\n  const rt60: f32 = 0.3 + decay * decay * 11.7;       // 0.3 .. 12 s\n  const ln1000: f32 = 6.9077553;\n  for (let i = 0; i < NLINES; i++) {\n    let L: i32 = i32(f32(baseLen[i]) * size * srRatio);\n    if (L < 4) L = 4; if (L >= LINE_CAP) L = LINE_CAP - 1;\n    lineLen[i] = L;\n    const tSec: f32 = f32(L) / sampleRate;\n    lineGain[i] = f32(Mathf.exp(-ln1000 * tSec / rt60));\n  }\n  for (let i = 0; i < NAP; i++) {\n    let L: i32 = i32(f32(apBase[i]) * srRatio);\n    if (L < 1) L = 1; if (L >= AP_CAP) L = AP_CAP - 1;\n    apLen[i] = L;\n  }\n\n  // pre-delay length in samples\n  let preLen: i32 = i32(preSec * sampleRate);\n  if (preLen < 1) preLen = 1; if (preLen >= PRE_CAP) preLen = PRE_CAP - 1;\n\n  // damping coefficient (one-pole LP in feedback); higher damping = darker tail\n  const dcoef: f32 = clampf(0.05 + damping * 0.9, 0.0, 0.98);\n\n  const outScale: f32 = 0.30;\n\n  for (let f = 0; f < n; f++) {\n    const l: f32 = inBuf[f];\n    const r: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : l;\n    const dryL: f32 = l;\n    const dryR: f32 = r;\n    let send: f32 = (l + r) * 0.5;\n\n    // pre-delay\n    const rp: i32 = (prePos - preLen + PRE_CAP) % PRE_CAP;\n    preBuf[prePos] = send;\n    send = preBuf[rp];\n    prePos++; if (prePos >= PRE_CAP) prePos = 0;\n\n    // input diffusion\n    send = allpass(0, send);\n    send = allpass(1, send);\n    send = allpass(2, send);\n    send = allpass(3, send);\n\n    // read the 8 delay-line outputs (with HF damping), build feedback\n    for (let i = 0; i < NLINES; i++) {\n      const base: i32 = i * LINE_CAP;\n      const rpos: i32 = (linePos[i] - lineLen[i] + LINE_CAP) % LINE_CAP;\n      let v: f32 = lines[base + rpos];\n      // damp the line output\n      const d: f32 = damp[i] + dcoef * (v - damp[i]);\n      damp[i] = d;\n      outs[i] = d;\n    }\n\n    // Householder feedback matrix: y = x - (2/N) * sum(x)\n    let sum: f32 = 0.0;\n    for (let i = 0; i < NLINES; i++) sum += outs[i];\n    const corr: f32 = (2.0 / f32(NLINES)) * sum;\n\n    // write back: scaled, sign-alternated input injection + matrixed feedback * gain\n    for (let i = 0; i < NLINES; i++) {\n      const base: i32 = i * LINE_CAP;\n      const inj: f32 = ((i & 1) == 0 ? send : -send) * 0.30;\n      const fb: f32 = (outs[i] - corr) * lineGain[i];\n      lines[base + linePos[i]] = inj + fb;\n      linePos[i]++; if (linePos[i] >= LINE_CAP) linePos[i] = 0;\n    }\n\n    // stereo output: decorrelated taps\n    const wetL: f32 = (outs[0] - outs[1] + outs[4] - outs[5]) * outScale;\n    const wetR: f32 = (outs[2] - outs[3] + outs[6] - outs[7]) * outScale;\n    const mid: f32 = (wetL + wetR) * 0.5;\n    const sideL: f32 = (wetL - mid) * width + mid;\n    const sideR: f32 = (wetR - mid) * width + mid;\n\n    outBuf[f] = dryL * (1.0 - mix) + sideL * mix;\n    outBuf[MAX_FRAMES + f] = dryR * (1.0 - mix) + sideR * mix;\n  }\n}\n",
  "publishedAt": 1751000001000
}