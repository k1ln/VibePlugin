  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Vector Eight</title>\n<style>\n  :root{ --acc:#6ce0a0; --acc2:#ffd24a; --bg0:#060f0b; --bg1:#0c1a14; --ink:#e7f6ee; --dim:#6d9484; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#102a20 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#0e2018,#060f0b); border:1px solid rgba(108,224,160,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(225,246,238,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.0s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:128px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0a1812,#06100b); border:1px solid rgba(108,224,160,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(214,238,228,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(108,224,160,.6)); }\n  .pcap{ fill:#0a1812; stroke:rgba(108,224,160,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(108,224,160,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(108,224,160,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">VECTOR&nbsp;EIGHT</span><span class=\"sub\">vector-scan poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">VECTOR&nbsp;PAD</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.6},{name:\"Reso\",idx:1,def:0.25},{name:\"Vec X\",idx:2,def:0.4},{name:\"Vec Y\",idx:3,def:0.6},{name:\"Scan\",idx:4,def:0.4},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#6ce0a0\"/><stop offset=\"1\" stop-color=\"#ffd24a\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  var trail=[];\n  var CORN=[[\"A·SIN\",\"#6ce0a0\",0,0],[\"B·SAW\",\"#ffd24a\",1,0],[\"C·SQR\",\"#ff7ad0\",1,1],[\"D·DIG\",\"#56c0e0\",0,1]]; // x,y corner (0=left/top,1=right/bottom)\n  function frame(ts){ ctx.clearRect(0,0,W,H);\n    var pad=22; var sz=H-pad*2; var ox=pad+8, oy=(H-sz)/2;\n    // pad frame + crosshair grid\n    ctx.strokeStyle=\"rgba(108,224,160,0.14)\"; ctx.lineWidth=1; ctx.strokeRect(ox,oy,sz,sz);\n    ctx.beginPath(); ctx.moveTo(ox+sz/2,oy); ctx.lineTo(ox+sz/2,oy+sz); ctx.moveTo(ox,oy+sz/2); ctx.lineTo(ox+sz,oy+sz/2); ctx.stroke();\n    // corner labels with glow proportional to current weight\n    var vx=vals[2], vy=vals[3], scan=vals[4], reso=vals[1];\n    var ang=ts/1000*(0.4+scan*5.0)*0.5;\n    var px=(vx*2-1)+scan*0.9*Math.sin(ang); var py=(vy*2-1)+scan*0.9*Math.cos(ang*0.73);\n    px=Math.max(-1,Math.min(1,px)); py=Math.max(-1,Math.min(1,py));\n    var fx=(px+1)/2, fy=(py+1)/2;\n    var wts=[(1-fx)*(1-fy),(fx)*(1-fy),(fx)*(fy),(1-fx)*(fy)];\n    for(var k=0;k<4;k++){ var c=CORN[k]; var cx=ox+c[2]*sz, cy=oy+c[3]*sz;\n      var g=ctx.createRadialGradient(cx,cy,0,cx,cy,sz*0.5); g.addColorStop(0,c[1]+\"\"); g.addColorStop(1,\"rgba(0,0,0,0)\");\n      ctx.globalAlpha=0.10+wts[k]*0.5; ctx.fillStyle=g; ctx.beginPath(); ctx.arc(cx,cy,sz*0.5,0,Math.PI*2); ctx.fill(); ctx.globalAlpha=1;\n      ctx.fillStyle=c[1]; ctx.font=\"8px Inter,sans-serif\"; ctx.textAlign=c[2]?\"right\":\"left\"; ctx.textBaseline=c[3]?\"bottom\":\"top\";\n      ctx.fillText(c[0], cx+(c[2]?-4:4), cy+(c[3]?-3:3)); }\n    ctx.textAlign=\"left\"; ctx.textBaseline=\"alphabetic\";\n    // orbit trail\n    var dx=ox+fx*sz, dy=oy+fy*sz; trail.push([dx,dy]); if(trail.length>40) trail.shift();\n    ctx.beginPath(); for(var i=0;i<trail.length;i++){ if(i===0)ctx.moveTo(trail[i][0],trail[i][1]); else ctx.lineTo(trail[i][0],trail[i][1]); }\n    ctx.strokeStyle=\"rgba(255,210,74,0.45)\"; ctx.lineWidth=1.4; ctx.stroke();\n    // position dot\n    ctx.fillStyle=\"#fff\"; ctx.shadowColor=\"#6ce0a0\"; ctx.shadowBlur=12; ctx.beginPath(); ctx.arc(dx,dy,4,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;\n    // right side: live blended-output scope\n    var sx=ox+sz+22, sw=W-12-sx, smid=H*0.5;\n    if(sw>40){ ctx.fillStyle=\"rgba(108,224,160,0.45)\"; ctx.font=\"8px Inter,sans-serif\"; ctx.fillText(\"OUTPUT\", sx, oy+8);\n      ctx.beginPath();\n      for(var x=0;x<=sw;x+=2){ var t=x/sw*6+ts/300; var ph=(t)%1; var a2=ph*6.2831853;\n        var oA=Math.sin(a2), oB=2*ph-1, oC=ph<0.5?1:-1, oD=(Math.sin(a2)+0.5*Math.sin(a2*3)+0.3*Math.sin(a2*5))*0.6;\n        var v=(oA*wts[0]+oB*wts[1]+oC*wts[2]+oD*wts[3]); // weights order A,B(top), C(bot-r), D(bot-l) -> reuse wts indices\n        ctx.lineTo(sx+x, smid - v*(H*0.32)); }\n      ctx.strokeStyle=\"rgba(255,210,74,0.9)\"; ctx.lineWidth=1.8; ctx.shadowColor=\"#ffd24a\"; ctx.shadowBlur=6; ctx.stroke(); ctx.shadowBlur=0;\n    }\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  VECTOR EIGHT — a vector-synthesis poly (Sequential Prophet VS\n//  lineage). Four oscillators (sine A, saw B, square C, hollow-digital D)\n//  sit at the corners of a vector square and are blended by an X/Y\n//  position. The signature SCAN orbits that position with an LFO, so the\n//  timbre is in constant motion even on a single held chord. 8-voice poly\n//  through a resonant two-pole low-pass.\n//  Controls: Cutoff, Resonance, Vector X, Vector Y, Scan, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\nconst vDrift: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGL: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGR: StaticArray<f32> = new StaticArray<f32>(NVOX);\n\nconst vPh: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet lfo: f32 = 0.0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_VX: i32 = 2; const P_VY: i32 = 3; const P_SCAN: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\nlet rngState: i32 = 0x2b9f17;\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0; lfo = 0.0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vPh[i] = 0.0; vAmp[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.6; params[P_RESO] = 0.25; params[P_VX] = 0.4; params[P_VY] = 0.6; params[P_SCAN] = 0.4; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPh[slot] = 0.0; vAmp[slot] = 0.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const vxN: f32 = clampf(params[P_VX], 0.0, 1.0);\n  const vyN: f32 = clampf(params[P_VY], 0.0, 1.0);\n  const scanN: f32 = clampf(params[P_SCAN], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.01 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate)));\n  const baseCut: f32 = 60.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const k: f32 = 2.0 - 1.9 * resoN;\n  const lfoInc: f32 = (0.4 + scanN * 5.0) / sampleRate * 6.2831853;   // scan speed\n  const scanDepth: f32 = scanN * 0.9;\n  const out: f32 = level * 1.0;\n\n    const _width: f32 = 0.55;\n  for (let _s = 0; _s < NVOX; _s++) { const _pr: i32 = (_s + 1) / 2; const _mg: f32 = _s == 0 ? 0.0 : (1.0 - f32(_pr - 1) / f32(NVOX)); const _pan: f32 = ((_s % 2 == 1) ? -_mg : _mg) * _width; vGL[_s] = f32(Mathf.sqrt(0.5 * (1.0 - _pan))); vGR[_s] = f32(Mathf.sqrt(0.5 * (1.0 + _pan))); }\n  const _dLeak: f32 = 0.9998; const _dStep: f32 = 0.00006;\n\n  for (let i = 0; i < n; i++) {\n    lfo += lfoInc; if (lfo > 6.2831853) lfo -= 6.2831853;\n    // vector position: center (from VX/VY) + orbiting scan\n    let px: f32 = (vxN * 2.0 - 1.0) + scanDepth * f32(Mathf.sin(lfo));\n    let py: f32 = (vyN * 2.0 - 1.0) + scanDepth * f32(Mathf.cos(lfo * 0.73));\n    if (px < -1.0) px = -1.0; else if (px > 1.0) px = 1.0;\n    if (py < -1.0) py = -1.0; else if (py > 1.0) py = 1.0;\n    const fx: f32 = (px + 1.0) * 0.5; const fy: f32 = (py + 1.0) * 0.5;\n    const wA: f32 = (1.0 - fx) * fy;        // A top-left  (sine)\n    const wB: f32 = fx * fy;                // B top-right (saw)\n    const wC: f32 = fx * (1.0 - fy);        // C bot-right (square)\n    const wD: f32 = (1.0 - fx) * (1.0 - fy);// D bot-left  (hollow digital)\n\n    let fc: f32 = baseCut;\n    if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n    const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n    const a1: f32 = 1.0 / (1.0 + g * (g + k));\n\n    let mixL: f32 = 0.0; let mixR: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      vDrift[s] = vDrift[s] * _dLeak + rnd() * _dStep;\n      const fr: f32 = vFreq[s] * (1.0 + vDrift[s]);\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let ph: f32 = vPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; vPh[s] = ph;\n      const ang: f32 = ph * 6.2831853;\n      const oA: f32 = f32(Mathf.sin(ang));\n      const oB: f32 = ph * 2.0 - 1.0;\n      const oC: f32 = ph < 0.5 ? 1.0 : -1.0;\n      const oD: f32 = (f32(Mathf.sin(ang)) + 0.5 * f32(Mathf.sin(ang * 3.0)) + 0.3 * f32(Mathf.sin(ang * 5.0))) * 0.6;\n      let osc: f32 = (oA * wA + oB * wB + oC * wC + oD * wD) * 0.7;\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const _v: f32 = lpN * vAmp[s] * vVel[s]; mixL += _v * vGL[s]; mixR += _v * vGR[s];\n    }\n    let oL: f32 = f32(Mathf.tanh(mixL * out)); let oR: f32 = f32(Mathf.tanh(mixR * out));\n    outBuf[i] = oL; outBuf[MAX_FRAMES + i] = oR;\n  }\n}\n",
  "publishedAt": 1751303600000
}