{
  "format": 1,
  "name": "Bias Tremolo",
  "isInstrument": false,
  "explanation": "An amp-style amplitude tremolo: a low-frequency oscillator pulses the signal level for that vintage combo-amp throb. Shape morphs the modulation from a glassy sine sweep into a hard, choppy bias chop, Stereo spreads the L/R phase for a wider image, and Output trims the level. Controls: Rate, Depth, Shape, Stereo and Output.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.42
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Shape",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Stereo",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n/* ===== Bias Tremolo — tweed amp panel, pulsing waveform, vintage pilot lamp ===== */\n:root{\n  --ac:#5ad19b; --ac2:#8ae0b0;\n  --tweed1:#c7a567; --tweed2:#9a7a3f; --tweed3:#6e5526;\n  --cream:#efe4c4; --gold:#d9b25a;\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#efe7d2;\n  background:#1a140c;\n  display:flex;align-items:center;justify-content:center;padding:16px;overflow:hidden}\n\n/* ---- the amp cabinet ---- */\n.amp{\n  position:relative;width:100%;max-width:640px;border-radius:20px;\n  padding:16px;\n  /* tweed fabric: diagonal woven threads */\n  background:\n    repeating-linear-gradient(48deg, rgba(60,42,18,.45) 0 2px, rgba(60,42,18,0) 2px 5px),\n    repeating-linear-gradient(-42deg, rgba(255,240,200,.10) 0 2px, rgba(255,240,200,0) 2px 5px),\n    repeating-linear-gradient(48deg, var(--tweed3) 0 3px, var(--tweed2) 3px 6px, var(--tweed1) 6px 9px, var(--tweed2) 9px 12px),\n    linear-gradient(160deg,#b59458,#7c5f2e);\n  box-shadow:\n    0 34px 70px rgba(0,0,0,.62),\n    inset 0 2px 0 rgba(255,255,255,.18),\n    inset 0 -3px 8px rgba(0,0,0,.5);\n  border:3px solid #4a3818}\n/* leather corner protectors */\n.amp::before,.amp::after{content:\"\";position:absolute;width:34px;height:34px;\n  background:radial-gradient(circle at 35% 35%,#2a2018,#0b0805);border-radius:7px;\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.18),0 2px 4px rgba(0,0,0,.5);z-index:5}\n.amp::before{top:-3px;left:-3px;border-radius:18px 4px 14px 4px}\n.amp::after{top:-3px;right:-3px;border-radius:4px 18px 4px 14px}\n\n/* ---- the brushed-gold control plate ---- */\n.plate{\n  position:relative;z-index:2;border-radius:12px;padding:14px 18px 16px;\n  background:\n    repeating-linear-gradient(90deg, rgba(255,255,255,.05) 0 1px, rgba(0,0,0,.05) 1px 2px),\n    linear-gradient(180deg,#2a2c30,#15171a 60%,#0d0e10);\n  border:1px solid rgba(255,255,255,.10);\n  box-shadow:inset 0 1px 0 rgba(255,255,255,.14),inset 0 -2px 10px rgba(0,0,0,.6),0 6px 18px rgba(0,0,0,.5)}\n/* plate mounting screws */\n.scr{position:absolute;width:10px;height:10px;border-radius:50%;z-index:3;\n  background:radial-gradient(circle at 35% 30%,#cfd3d8,#5a5e64 60%,#26282b);\n  box-shadow:0 1px 2px rgba(0,0,0,.6)}\n.scr::after{content:\"\";position:absolute;inset:2px;border-top:1.5px solid rgba(0,0,0,.5);transform:rotate(35deg)}\n.scr.tl{top:7px;left:7px}.scr.tr{top:7px;right:7px}.scr.bl{bottom:7px;left:7px}.scr.br{bottom:7px;right:7px}\n\n/* ---- header: badge + pilot lamp ---- */\n.head{display:flex;align-items:center;gap:14px;margin:2px 6px 12px}\n.brand{flex:1}\n.brand h1{margin:0;font-size:20px;letter-spacing:.16em;font-weight:900;font-style:italic;\n  color:var(--gold);text-shadow:0 1px 0 #000,0 0 12px rgba(217,178,90,.35);font-family:\"Times New Roman\",Georgia,serif}\n.brand .sub{font-size:9px;letter-spacing:.34em;text-transform:uppercase;color:#8a8478;margin-top:3px}\n\n/* vintage jewel pilot lamp — blinks with the tremolo */\n.lamp{position:relative;width:42px;height:42px;flex:none}\n.lamp .bezel{position:absolute;inset:0;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#777,#2c2c2c 62%,#0a0a0a);\n  box-shadow:inset 0 2px 3px rgba(255,255,255,.3),inset 0 -3px 6px rgba(0,0,0,.7),0 2px 5px rgba(0,0,0,.6)}\n.lamp .jewel{position:absolute;inset:8px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#ffe6a0,#ff3b2e 55%,#7a1008 100%);\n  box-shadow:inset 0 0 6px rgba(255,255,255,.55),0 0 0 1px rgba(0,0,0,.4)}\n.lamp .glow{position:absolute;inset:-10px;border-radius:50%;pointer-events:none;\n  background:radial-gradient(circle,rgba(255,80,40,.85),transparent 65%);\n  opacity:.25;animation:lampBlink calc(2.2s / var(--rate,1)) ease-in-out infinite}\n.lamp .jewel{animation:lampJewel calc(2.2s / var(--rate,1)) ease-in-out infinite}\n@keyframes lampBlink{0%,100%{opacity:calc(.12 + var(--depth,.5)*.05)}50%{opacity:calc(.45 + var(--depth,.5)*.55)}}\n@keyframes lampJewel{0%,100%{filter:brightness(calc(.55 + (1 - var(--depth,.5))*.45))}\n  50%{filter:brightness(calc(1.05 + var(--depth,.5)*.9)) saturate(1.2)}}\n\n/* ---- the speaker-grille scope window ---- */\n.scope{position:relative;height:86px;margin:0 0 14px;border-radius:9px;overflow:hidden;\n  background:linear-gradient(180deg,#070a07,#0c130c);\n  border:1px solid rgba(0,0,0,.7);\n  box-shadow:inset 0 2px 10px rgba(0,0,0,.85),inset 0 0 0 1px rgba(255,255,255,.04),0 1px 0 rgba(255,255,255,.08)}\n/* grille cloth weave overlaid faintly */\n.scope::after{content:\"\";position:absolute;inset:0;pointer-events:none;opacity:.18;\n  background:\n    repeating-linear-gradient(0deg,rgba(255,255,255,.5) 0 1px,transparent 1px 4px),\n    repeating-linear-gradient(90deg,rgba(255,255,255,.4) 0 1px,transparent 1px 4px)}\n.scope svg{position:absolute;inset:0;width:100%;height:100%}\n.tracer{fill:none;stroke:var(--ac);stroke-width:2;stroke-linecap:round;stroke-linejoin:round;\n  filter:drop-shadow(0 0 5px var(--ac))}\n.tracerFill{fill:var(--ac);opacity:.10}\n.midline{stroke:rgba(255,255,255,.10);stroke-width:1;stroke-dasharray:3 4}\n\n/* ---- knob row ---- */\n.row{display:grid;grid-template-columns:repeat(5,1fr);gap:6px}\n.ctl{display:flex;flex-direction:column;align-items:center;gap:8px;padding:6px 2px 4px;\n  animation:rise .5s both;animation-delay:var(--d)}\n@keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n\n/* chickenhead-style amp knob */\n.knob{position:relative;width:76px;height:76px;cursor:ns-resize;user-select:none;touch-action:none}\n.knob .num{position:absolute;inset:-3px;border-radius:50%;\n  /* tick numerals ring as conic dashes */\n  background:repeating-conic-gradient(from 215deg, rgba(255,255,255,.5) 0 1.2deg, transparent 1.2deg 27deg);\n  -webkit-mask:radial-gradient(circle,transparent 36px,#000 37px,#000 39px,transparent 40px);\n          mask:radial-gradient(circle,transparent 36px,#000 37px,#000 39px,transparent 40px)}\n.knob .arc{position:absolute;inset:1px;border-radius:50%;\n  background:conic-gradient(from 215deg,\n    var(--ac) calc(var(--n,0)*290deg), rgba(255,255,255,.07) calc(var(--n,0)*290deg) 290deg, transparent 290deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n,0)*8px) color-mix(in srgb,var(--ac) 65%,transparent))}\n.knob .body{position:absolute;inset:9px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 24%, #4a4035 0%, #221d16 58%, #0c0a07 100%);\n  box-shadow:inset 0 2px 5px rgba(255,235,190,.18),inset 0 -4px 9px rgba(0,0,0,.75),0 3px 6px rgba(0,0,0,.55);\n  transition:transform .12s}\n/* the bakelite pointer wing */\n.knob .wing{position:absolute;top:8px;left:50%;width:7px;height:30px;margin-left:-3.5px;border-radius:4px 4px 2px 2px;\n  background:linear-gradient(180deg,#1a140d,#000);transform-origin:50% 30px;\n  transform:rotate(calc((var(--n,0) - 0.5) * 290deg));transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.knob .wing::after{content:\"\";position:absolute;top:2px;left:50%;width:2px;height:11px;margin-left:-1px;border-radius:2px;\n  background:var(--ac2);box-shadow:0 0 6px var(--ac)}\n.knob.act .body{transform:scale(.97)}\n\n.nm{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#cdb87f;font-weight:700;\n  font-family:\"Times New Roman\",Georgia,serif}\n.val{font-size:13px;font-weight:800;color:#fff;font-variant-numeric:tabular-nums;letter-spacing:.02em;\n  background:rgba(0,0,0,.4);padding:1px 8px;border-radius:5px;min-width:42px;text-align:center;\n  box-shadow:inset 0 1px 2px rgba(0,0,0,.6)}\n</style></head><body>\n<div class=\"amp\">\n  <div class=\"plate\">\n    <span class=\"scr tl\"></span><span class=\"scr tr\"></span><span class=\"scr bl\"></span><span class=\"scr br\"></span>\n    <div class=\"head\">\n      <div class=\"lamp\"><span class=\"glow\"></span><span class=\"bezel\"></span><span class=\"jewel\"></span></div>\n      <div class=\"brand\">\n        <h1>Bias&nbsp;Tremolo</h1>\n        <div class=\"sub\">Vintage Combo · Amplitude Throb</div>\n      </div>\n    </div>\n    <div class=\"scope\">\n      <svg viewBox=\"0 0 600 86\" preserveAspectRatio=\"none\">\n        <line class=\"midline\" x1=\"0\" y1=\"43\" x2=\"600\" y2=\"43\"></line>\n        <path class=\"tracerFill\" id=\"fill\"></path>\n        <path class=\"tracer\" id=\"wave\"></path>\n      </svg>\n    </div>\n    <div class=\"row\" id=\"row\"></div>\n  </div>\n</div>\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Rate\",  index:0, min:0, max:1, def:0.42},\n    {name:\"Depth\", index:1, min:0, max:1, def:0.7},\n    {name:\"Shape\", index:2, min:0, max:1, def:0.3},\n    {name:\"Stereo\",index:3, min:0, max:1, def:0},\n    {name:\"Output\",index:4, min:0, max:1, def:0.7}\n  ];\n  var state={};\n  var root=document.documentElement;\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n\n  function buildKnob(p,d){\n    var ctl=document.createElement('div'); ctl.className='ctl'; ctl.style.setProperty('--d',d+'ms');\n    ctl.innerHTML=\n      '<div class=\"knob\"><i class=\"num\"></i><i class=\"arc\"></i><i class=\"body\"></i><i class=\"wing\"></i></div>'+\n      '<div class=\"nm\">'+p.name+'</div><div class=\"val\"></div>';\n    var knob=ctl.querySelector('.knob'),\n        arc=ctl.querySelector('.arc'),\n        wing=ctl.querySelector('.wing'),\n        out=ctl.querySelector('.val');\n    var val=p.def;\n    function norm(){return (val-p.min)/((p.max-p.min)||1);}\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n); wing.style.setProperty('--n',n);\n      out.textContent=Math.round(n*100)+(p.name==='Rate'?'':'%');\n      // Rate shows percent too but feed a label; keep simple: percent for all 0..1\n      out.textContent=Math.round(n*100);\n      state[p.name]=val; send(p.index,val); reflect();\n    }\n    function setN(n){ n=n<0?0:(n>1?1:n); val=p.min+(p.max-p.min)*n; paint(); }\n    knob.addEventListener('pointerdown',function(e){\n      knob._d=1;knob._y=e.clientY;knob._n=norm();knob.classList.add('act');\n      knob.setPointerCapture(e.pointerId);e.preventDefault();});\n    knob.addEventListener('pointermove',function(e){ if(!knob._d)return; setN(knob._n+(knob._y-e.clientY)/180); });\n    function end(){knob._d=0;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',end); knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){val=p.def;paint();});\n    knob.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?0.02:-0.02));},{passive:false});\n    document.getElementById('row').appendChild(ctl);\n    paint();\n  }\n\n  // ---- live waveform + lamp reaction ----\n  function reflect(){\n    var rate=state.Rate||0, depth=state.Depth||0;\n    root.style.setProperty('--rate',(0.35+rate*2.6).toFixed(3));\n    root.style.setProperty('--depth',(depth).toFixed(3));\n  }\n\n  var wave=document.getElementById('wave'), fill=document.getElementById('fill');\n  var t0=performance.now();\n  function shapeFn(ph,shape){\n    // morph: sine (glassy) -> hard chop (bias) as shape rises\n    var s=Math.sin(ph);            // -1..1\n    var sq=s>=0?1:-1;              // hard square\n    // soft-clip blend for the \"choppy bias chop\"\n    var k=1+shape*22;\n    var hard=Math.tanh(s*k)/Math.tanh(k);\n    return s*(1-shape)+hard*shape;\n  }\n  function tick(now){\n    var rate=state.Rate||0, depth=state.Depth||0, shape=state.Shape||0,\n        stereo=state.Stereo||0, out=state.Output!=null?state.Output:0.7;\n    var hz=0.4+rate*7.5;                 // visual LFO speed\n    var t=(now-t0)/1000;\n    var N=120, dL='', dR='', H=86, mid=43, amp=30*(0.25+out*0.85);\n    var lagR=stereo*Math.PI;             // stereo phase spread\n    for(var i=0;i<=N;i++){\n      var x=i/N*600;\n      var ph=2*Math.PI*hz*t - i/N*6.0;   // travelling wave\n      var modL=1-depth*(0.5-0.5*shapeFn(ph,shape));        // 0..1 amplitude env\n      var carrier=Math.sin(i/N*Math.PI*9 + t*6);           // carrier tone\n      var yL=mid - carrier*amp*modL;\n      dL+=(i?'L':'M')+x.toFixed(1)+' '+yL.toFixed(1)+' ';\n    }\n    wave.setAttribute('d',dL);\n    fill.setAttribute('d',dL+'L600 '+H+' L0 '+H+' Z');\n    requestAnimationFrame(tick);\n  }\n\n  function ready(){\n    PARAMS.forEach(function(p,idx){ buildKnob(p,idx*60); });\n    reflect();\n    requestAnimationFrame(tick);\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  BIAS TREMOLO — amp-style amplitude tremolo\n//  A low-frequency oscillator amplitude-modulates the signal, the way a\n//  vintage combo amp's bias-vary tremolo pulses the output. SHAPE morphs\n//  the LFO from a glassy sine sweep into a hard, choppy bias chop; STEREO\n//  spreads the L/R LFO phase for a rotary-style image. A short smoothing\n//  filter on the gain keeps the choppy setting click-free. Pure algorithm.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst TWO_PI: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel LFO phase (0..1) and per-channel gain smoother state\nconst lfoPhase:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst gainState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_RATE:   i32 = 0; // 0..1 -> 0.1..12 Hz\nconst P_DEPTH:  i32 = 1; // 0..1 modulation depth (0 = bypassed amplitude)\nconst P_SHAPE:  i32 = 2; // 0..1 smooth sine -> choppy bias square\nconst P_STEREO: i32 = 3; // 0..1 L/R LFO phase offset (0..0.5 of a cycle)\nconst P_OUTPUT: i32 = 4; // 0..1 -> 0..1.5 output gain\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lfoPhase[c] = 0.0;\n    gainState[c] = 1.0;\n  }\n  params[P_RATE] = 0.42;   // ~5 Hz\n  params[P_DEPTH] = 0.7;\n  params[P_SHAPE] = 0.3;\n  params[P_STEREO] = 0.0;\n  params[P_OUTPUT] = 0.7;  // -> ~0.84 gain, headroom below clip\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Unit-amplitude oscillator, ph in 0..1, morphing sine -> square as shape 0..1.\n// Returned in -1..1; we map it to a gain below.\n@inline function lfoShape(ph: f32, shape: f32): f32 {\n  // smooth sine\n  const sine: f32 = f32(Mathf.sin(ph * TWO_PI));\n  // choppy: a soft-saturated sine -> approaches a square as drive rises.\n  // tanh of a heavily-driven sine gives a rounded square with no aliasing-y edges.\n  const driven: f32 = sine * 6.0;\n  const square: f32 = f32(Mathf.tanh(driven));\n  return sine + (square - sine) * shape;\n}\n\nexport function process(n: i32): void {\n  const rateN: f32 = clampf(params[P_RATE], 0.0, 1.0);\n  const depth: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const shape: f32 = clampf(params[P_SHAPE], 0.0, 1.0);\n  const stereo: f32 = clampf(params[P_STEREO], 0.0, 1.0);\n  const outGain: f32 = clampf(params[P_OUTPUT], 0.0, 1.0) * 1.2;\n\n  // 0.1..12 Hz, perceptually-spaced (quadratic)\n  const rateHz: f32 = 0.1 + rateN * rateN * 11.9;\n  const sr: f32 = sampleRate > 0.0 ? sampleRate : 48000.0;\n  const phaseInc: f32 = rateHz / sr; // cycles per sample\n\n  // L/R phase offset, up to half a cycle for full stereo width\n  const stereoOff: f32 = stereo * 0.5;\n\n  // gain smoothing: ~2 ms one-pole, removes clicks at the choppy/square setting\n  const smoothC: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.002 * sr)));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let ph: f32 = lfoPhase[c];\n    let g: f32 = gainState[c];\n    // right channel rides ahead by the stereo offset\n    const chOff: f32 = c == 1 ? stereoOff : 0.0;\n\n    for (let f = 0; f < n; f++) {\n      let p: f32 = ph + chOff;\n      p -= Mathf.floor(p); // wrap to 0..1\n      // LFO in -1..1 -> unipolar 0..1\n      const lfo01: f32 = lfoShape(p, shape) * 0.5 + 0.5;\n      // target gain: swings between (1-depth) and 1 -> Depth=0 leaves signal intact\n      const targetG: f32 = 1.0 - depth * (1.0 - lfo01);\n      g += smoothC * (targetG - g);\n\n      outBuf[base + f] = inBuf[base + f] * g * outGain;\n\n      ph += phaseInc;\n      if (ph >= 1.0) ph -= 1.0;\n    }\n    lfoPhase[c] = ph;\n    gainState[c] = g;\n  }\n}\n",
  "publishedAt": 1751000035000
}