{
  "format": 1,
  "name": "Open Room",
  "isInstrument": false,
  "explanation": "A bright, efficient algorithmic room/hall reverb. Eight parallel damped comb filters per channel feed four series all-pass diffusers, with a small stereo offset between the left/right comb tunings for a wide image. Controls: Mix, Room Size, Damping, Width and Pre-Delay; Mix=0 is bit-exact dry.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Room Size",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Damping",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Width",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Pre-Delay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  :root{\n    --ac:#45c8e0; --ac2:#7ae0f0;\n    --ink:#0c1116; --line:#1f2a33;\n    --paper:#0a0e12;\n    --wall:#2a3a44;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0; color:#dfeef4;\n    font:13px/1.4 ui-sans-serif,system-ui,-apple-system,\"Helvetica Neue\",sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% 8%, #10171d 0%, #070a0d 60%, #04060899 100%);\n    display:flex; align-items:center; justify-content:center; padding:18px;\n    overflow:hidden;\n  }\n  .room{\n    position:relative; width:100%; max-width:660px; aspect-ratio:1.42/1; min-height:430px;\n    border-radius:6px; overflow:hidden;\n    background:\n      linear-gradient(180deg, rgba(20,30,38,.5), rgba(6,9,12,.85));\n    box-shadow:\n      0 40px 90px rgba(0,0,0,.7),\n      inset 0 0 0 1px rgba(122,224,240,.10),\n      inset 0 0 120px rgba(0,0,0,.6);\n  }\n  /* faint Bauhaus grid floor */\n  .room::before{\n    content:\"\"; position:absolute; inset:0; z-index:0; opacity:.07; pointer-events:none;\n    background-image:\n      linear-gradient(rgba(122,224,240,.6) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(122,224,240,.6) 1px, transparent 1px);\n    background-size:34px 34px;\n    -webkit-mask:linear-gradient(180deg, transparent 40%, #000 100%);\n    mask:linear-gradient(180deg, transparent 40%, #000 100%);\n  }\n\n  /* ---- the architectural wireframe SVG ---- */\n  svg.scene{position:absolute; inset:0; width:100%; height:100%; z-index:1; pointer-events:none}\n  .edge{fill:none; stroke:var(--ac); stroke-width:1.1; vector-effect:non-scaling-stroke;\n        filter:drop-shadow(0 0 3px color-mix(in srgb,var(--ac) 50%,transparent))}\n  .edge.back{stroke:color-mix(in srgb,var(--ac) 55%,#26323b); stroke-width:.9}\n  .edge.faint{stroke:rgba(122,224,240,.16); stroke-width:.8}\n  .floorshade{fill:url(#fg); opacity:.5}\n  .corner{fill:var(--ac2)}\n  .ray{fill:none; stroke:var(--ac2); stroke-width:1.4; vector-effect:non-scaling-stroke;\n       stroke-linecap:round; filter:drop-shadow(0 0 4px var(--ac2));\n       stroke-dasharray:14 240; opacity:.9}\n  .pulse{fill:var(--ac2); filter:drop-shadow(0 0 6px var(--ac2))}\n  .source{fill:#fff; filter:drop-shadow(0 0 8px var(--ac))}\n\n  @keyframes travel{ to{ stroke-dashoffset:-254 } }\n  @keyframes hit{ 0%,82%{ r:0; opacity:0 } 88%{ r:7; opacity:.9 } 100%{ r:14; opacity:0 } }\n  @keyframes breathe{ 0%,100%{ r:4; opacity:.85 } 50%{ r:6.5; opacity:1 } }\n\n  /* ---- header ---- */\n  .hd{position:absolute; top:0; left:0; right:0; z-index:4;\n      display:flex; align-items:baseline; gap:12px; padding:16px 20px 0}\n  .hd .mark{width:14px; height:14px; flex:0 0 auto; align-self:center; position:relative}\n  .hd .mark i{position:absolute; inset:0; border:1.5px solid var(--ac); border-radius:1px}\n  .hd .mark i:nth-child(2){inset:4px; border-color:var(--ac2); border-radius:50%;\n      animation:breathe 3.4s ease-in-out infinite}\n  h1{margin:0; font-size:15px; font-weight:800; letter-spacing:.34em; text-transform:uppercase;\n     color:#eaf7fb}\n  h1 span{color:var(--ac)}\n  .sub{font-size:9.5px; letter-spacing:.26em; text-transform:uppercase; color:#5f7686; margin-left:auto;\n       white-space:nowrap}\n\n  /* ---- Bauhaus control rail (bottom) ---- */\n  .rail{position:absolute; left:0; right:0; bottom:0; z-index:5;\n        display:grid; grid-template-columns:repeat(5,1fr); gap:0;\n        padding:0; background:linear-gradient(0deg, rgba(5,8,11,.94), rgba(5,8,11,.0));\n        border-top:1px solid rgba(122,224,240,.14)}\n  .ctl{position:relative; padding:14px 8px 16px; display:flex; flex-direction:column;\n       align-items:center; gap:9px; cursor:ns-resize; user-select:none; touch-action:none;\n       border-right:1px solid rgba(122,224,240,.07);\n       transition:background .2s ease}\n  .ctl:last-child{border-right:0}\n  .ctl:hover{background:rgba(122,224,240,.05)}\n  .ctl .arc{position:relative; width:54px; height:54px}\n  .ctl .arc svg{width:100%; height:100%; overflow:visible}\n  .trk{fill:none; stroke:rgba(122,224,240,.13); stroke-width:3.2; stroke-linecap:round}\n  .fil{fill:none; stroke:var(--ac); stroke-width:3.2; stroke-linecap:round;\n       filter:drop-shadow(0 0 5px color-mix(in srgb,var(--ac) 60%,transparent));\n       transition:stroke-dashoffset .12s cubic-bezier(.2,.8,.25,1)}\n  /* the Bauhaus index: a bar that points to value */\n  .hub{position:absolute; left:50%; top:50%; width:3px; height:20px; margin:-20px 0 0 -1.5px;\n       background:linear-gradient(var(--ac2),var(--ac)); border-radius:2px;\n       transform-origin:50% 100%; box-shadow:0 0 6px var(--ac2);\n       transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n  .dot{position:absolute; left:50%; top:50%; width:8px; height:8px; margin:-4px 0 0 -4px;\n       border-radius:50%; background:#0a0e12; box-shadow:inset 0 0 0 1.5px var(--ac2)}\n  .ctl .nm{font-size:9px; letter-spacing:.2em; text-transform:uppercase; color:#7f95a4; font-weight:700}\n  .ctl .va{font-size:14px; font-weight:800; color:#eaf7fb; font-variant-numeric:tabular-nums;\n           letter-spacing:.02em; line-height:1}\n  .ctl .va small{font-size:8.5px; color:#5f7686; font-weight:600; margin-left:1px}\n  .ctl.act{background:rgba(122,224,240,.07)}\n  .ctl.act .fil{stroke:var(--ac2)}\n  /* primitive accent square (Bauhaus) per control, lit when high */\n  .ctl .chip{position:absolute; top:9px; right:10px; width:6px; height:6px; border-radius:1px;\n       background:var(--ac); opacity:.18; transition:opacity .15s, transform .15s}\n  .ctl:nth-child(2) .chip{border-radius:50%}\n  .ctl:nth-child(3) .chip{transform:rotate(45deg)}\n  .ctl:nth-child(5) .chip{border-radius:50% 50% 50% 0}\n\n  /* entrance */\n  .ctl{animation:rise .55s both} .ctl{animation-delay:calc(.12s + var(--i)*.06s)}\n  @keyframes rise{from{opacity:0; transform:translateY(14px)}to{opacity:1; transform:none}}\n  .room svg.scene .edge{stroke-dasharray:1; animation:none}\n\n  .hint{position:absolute; left:20px; bottom:96px; z-index:4; font-size:9px; letter-spacing:.18em;\n        text-transform:uppercase; color:#4a5f6e; opacity:.0; transition:opacity .3s}\n  .room:hover .hint{opacity:.7}\n</style>\n</head>\n<body>\n  <div class=\"room\" id=\"room\">\n    <svg class=\"scene\" id=\"scene\" viewBox=\"0 0 660 460\" preserveAspectRatio=\"xMidYMid slice\">\n      <defs>\n        <radialGradient id=\"fg\" cx=\"50%\" cy=\"38%\" r=\"60%\">\n          <stop offset=\"0%\" stop-color=\"#7ae0f0\" stop-opacity=\".22\"/>\n          <stop offset=\"100%\" stop-color=\"#7ae0f0\" stop-opacity=\"0\"/>\n        </radialGradient>\n      </defs>\n      <!-- one-point-perspective wireframe room.\n           OUTER = front opening (room walls), INNER = back wall.\n           These get repositioned by JS based on Room Size -->\n      <polygon class=\"floorshade\" id=\"floorshade\" points=\"0,0 0,0 0,0 0,0\"/>\n\n      <!-- perspective connectors (corners front->back) -->\n      <line class=\"edge faint\" id=\"c1\"/>\n      <line class=\"edge faint\" id=\"c2\"/>\n      <line class=\"edge faint\" id=\"c3\"/>\n      <line class=\"edge faint\" id=\"c4\"/>\n\n      <!-- back wall rectangle -->\n      <rect class=\"edge back\" id=\"back\" rx=\"2\"/>\n      <!-- front opening rectangle -->\n      <rect class=\"edge\" id=\"front\" rx=\"2\"/>\n\n      <!-- corner nodes (front) -->\n      <circle class=\"corner\" id=\"n1\" r=\"2.4\"/>\n      <circle class=\"corner\" id=\"n2\" r=\"2.4\"/>\n      <circle class=\"corner\" id=\"n3\" r=\"2.4\"/>\n      <circle class=\"corner\" id=\"n4\" r=\"2.4\"/>\n\n      <!-- sound source -->\n      <circle class=\"source\" id=\"src\" r=\"4\"><animate attributeName=\"r\" values=\"3.4;5;3.4\" dur=\"2.6s\" repeatCount=\"indefinite\"/></circle>\n\n      <!-- bouncing sound rays (paths set by JS) -->\n      <g id=\"rays\"></g>\n    </svg>\n\n    <div class=\"hd\">\n      <div class=\"mark\"><i></i><i></i></div>\n      <h1>OPEN&nbsp;<span>ROOM</span></h1>\n      <div class=\"sub\">Algorithmic Hall</div>\n    </div>\n\n    <div class=\"hint\">drag · dbl-click resets · wheel fine</div>\n\n    <div class=\"rail\" id=\"rail\"></div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- spec params (index, min, max, default) ----\n  var PARAMS = [\n    {i:0, name:\"Mix\",       min:0, max:1, def:0.35, unit:\"%\",  pct:true},\n    {i:1, name:\"Room Size\", min:0, max:1, def:0.7,  unit:\"%\",  pct:true},\n    {i:2, name:\"Damping\",   min:0, max:1, def:0.4,  unit:\"%\",  pct:true},\n    {i:3, name:\"Width\",     min:0, max:1, def:1,    unit:\"%\",  pct:true},\n    {i:4, name:\"Pre-Delay\", min:0, max:1, def:0,    unit:\"ms\", pct:false, ms:120}\n  ];\n\n  var state = {}; // index -> value\n  var ARC_R = 22, CIRC = 2*Math.PI*ARC_R;\n  var GAP = 0.32; // fraction of circle left open at bottom (Bauhaus open arc)\n  var SWEEP = 1-GAP, START = 90 + (GAP*180); // degrees\n\n  function fmt(p,v){\n    if(p.pct) return Math.round(v*100) + \"\";\n    if(p.ms)  return Math.round(v*p.ms) + \"\";\n    return (Math.round(v*100)/100)+\"\";\n  }\n\n  // ---------- build controls ----------\n  var rail = document.getElementById('rail');\n  var ctlMap = {};\n  PARAMS.forEach(function(p,idx){\n    var el = document.createElement('div');\n    el.className='ctl'; el.style.setProperty('--i', idx);\n    el.innerHTML =\n      '<span class=\"chip\"></span>'+\n      '<div class=\"arc\"><svg viewBox=\"0 0 54 54\">'+\n        '<circle class=\"trk\" cx=\"27\" cy=\"27\" r=\"'+ARC_R+'\"></circle>'+\n        '<circle class=\"fil\" cx=\"27\" cy=\"27\" r=\"'+ARC_R+'\"></circle>'+\n        '</svg>'+\n        '<div class=\"hub\"></div><div class=\"dot\"></div>'+\n      '</div>'+\n      '<div class=\"va\"><span class=\"num\">0</span><small>'+p.unit+'</small></div>'+\n      '<div class=\"nm\">'+p.name+'</div>';\n    rail.appendChild(el);\n    ctlMap[p.i]={el:el,\n      fil:el.querySelector('.fil'),\n      hub:el.querySelector('.hub'),\n      num:el.querySelector('.num'),\n      chip:el.querySelector('.chip'),\n      p:p};\n    // open-arc dasharray\n    var f=el.querySelector('.fil'), t=el.querySelector('.trk');\n    f.style.strokeDasharray = CIRC; t.style.strokeDasharray = (CIRC*SWEEP)+' '+CIRC;\n    f.style.transform='rotate('+START+'deg)'; f.style.transformOrigin='27px 27px';\n    t.style.transform='rotate('+START+'deg)'; t.style.transformOrigin='27px 27px';\n  });\n\n  function norm(p,v){ return (v-p.min)/((p.max-p.min)||1); }\n\n  function paint(p){\n    var c=ctlMap[p.i], n=norm(p,state[p.i]);\n    // arc fill: dashoffset from full(empty) to sweep\n    var visible = CIRC*SWEEP*n;\n    c.fil.style.strokeDashoffset = (CIRC - visible);\n    // hub angle: maps n in [0,1] over the swept range, pointing outward\n    var ang = -SWEEP*180 + n*(SWEEP*360); // degrees, 0 = straight up\n    c.hub.style.transform='rotate('+ang+'deg)';\n    c.num.textContent = fmt(p,state[p.i]);\n    c.chip.style.opacity = (0.18+0.82*n).toFixed(3);\n    c.chip.style.transform = (p.i===2?'rotate(45deg) ':'')+'scale('+(0.7+0.5*n).toFixed(2)+')';\n    if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.i, state[p.i]);\n    syncRoom();\n  }\n\n  function setN(p,n){\n    n = n<0?0:(n>1?1:n);\n    state[p.i] = p.min + (p.max-p.min)*n;\n    paint(p);\n  }\n\n  // ---------- drag wiring ----------\n  PARAMS.forEach(function(p){\n    var c=ctlMap[p.i], el=c.el, drag=null;\n    el.addEventListener('pointerdown', function(e){\n      drag={y:e.clientY, n:norm(p,state[p.i])};\n      el.classList.add('act'); el.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    el.addEventListener('pointermove', function(e){\n      if(!drag) return;\n      var dy=(drag.y-e.clientY)/200;\n      setN(p, drag.n+dy);\n    });\n    function end(){ drag=null; el.classList.remove('act'); }\n    el.addEventListener('pointerup', end);\n    el.addEventListener('pointercancel', end);\n    el.addEventListener('dblclick', function(){ state[p.i]=p.def; paint(p); });\n    el.addEventListener('wheel', function(e){\n      e.preventDefault();\n      setN(p, norm(p,state[p.i]) + (e.deltaY<0?0.02:-0.02));\n    }, {passive:false});\n  });\n\n  // =================================================================\n  //  ARCHITECTURAL WIREFRAME ROOM  (driven by params)\n  // =================================================================\n  var VB=660, VH=460, CX=330, CY=205;\n  var els={\n    front:document.getElementById('front'),\n    back:document.getElementById('back'),\n    fs:document.getElementById('floorshade'),\n    c:[document.getElementById('c1'),document.getElementById('c2'),document.getElementById('c3'),document.getElementById('c4')],\n    n:[document.getElementById('n1'),document.getElementById('n2'),document.getElementById('n3'),document.getElementById('n4')],\n    src:document.getElementById('src'),\n    rays:document.getElementById('rays')\n  };\n\n  function syncRoom(){\n    var size = state[1]!=null?state[1]:0.7;   // Room Size -> depth of back wall\n    var width = state[3]!=null?state[3]:1;     // Width -> horizontal spread\n    var damp = state[2]!=null?state[2]:0.4;    // Damping -> ray brightness/length\n    var mix  = state[0]!=null?state[0]:0.35;   // Mix -> number/opacity of rays\n    var pre  = state[4]!=null?state[4]:0;      // Pre-Delay -> source offset\n\n    // front opening — fixed-ish, modulated a touch by width\n    var fw = (300 + width*120);                 // front half-width*2\n    var fh = 230;\n    var fx = CX - fw/2, fy = CY - fh/2 + 6;\n    els.front.setAttribute('x',fx); els.front.setAttribute('y',fy);\n    els.front.setAttribute('width',fw); els.front.setAttribute('height',fh);\n\n    // back wall — smaller & higher as size grows (deeper room = vanishing point)\n    var depth = 0.30 + size*0.42;               // 0..1 perspective shrink\n    var bw = fw*(1-depth*0.74), bh = fh*(1-depth*0.74);\n    var bx = CX - bw/2, by = CY - bh/2 - size*18; // recede upward slightly\n    els.back.setAttribute('x',bx); els.back.setAttribute('y',by);\n    els.back.setAttribute('width',bw); els.back.setAttribute('height',bh);\n\n    // front corners\n    var FC=[[fx,fy],[fx+fw,fy],[fx+fw,fy+fh],[fx,fy+fh]];\n    var BC=[[bx,by],[bx+bw,by],[bx+bw,by+bh],[bx,by+bh]];\n    for(var k=0;k<4;k++){\n      els.n[k].setAttribute('cx',FC[k][0]); els.n[k].setAttribute('cy',FC[k][1]);\n      els.c[k].setAttribute('x1',FC[k][0]); els.c[k].setAttribute('y1',FC[k][1]);\n      els.c[k].setAttribute('x2',BC[k][0]); els.c[k].setAttribute('y2',BC[k][1]);\n    }\n    // floor shade quad (front-bottom to back-bottom)\n    els.fs.setAttribute('points',\n      FC[3][0]+','+FC[3][1]+' '+FC[2][0]+','+FC[2][1]+' '+BC[2][0]+','+BC[2][1]+' '+BC[3][0]+','+BC[3][1]);\n\n    // source position — center of back wall, nudged by pre-delay\n    var sx = CX + (pre-0.5)*bw*0.5*pre, sy = by+bh*0.55;\n    els.src.setAttribute('cx', CX + (pre)*bw*0.32);\n    els.src.setAttribute('cy', sy);\n\n    // ----- rays: bounce between front opening and back wall edges -----\n    // ray count grows with mix; reach grows with size; brightness with low damping\n    var count = Math.max(2, Math.round(2 + mix*6));\n    var reach = 0.55 + size*0.45;\n    var bright = 0.30 + (1-damp)*0.70;\n    var srcX = +els.src.getAttribute('cx'), srcY = +els.src.getAttribute('cy');\n\n    // rebuild ray set only if count changed (cheap)\n    if(els.rays.childElementCount !== count){\n      els.rays.innerHTML='';\n      for(var r=0;r<count;r++){\n        var path=document.createElementNS('http://www.w3.org/2000/svg','path');\n        path.setAttribute('class','ray');\n        els.rays.appendChild(path);\n        var p2=document.createElementNS('http://www.w3.org/2000/svg','circle');\n        p2.setAttribute('class','pulse'); p2.setAttribute('r','0');\n        els.rays.appendChild(p2);\n      }\n    }\n    var paths = els.rays.querySelectorAll('.ray');\n    var pulses = els.rays.querySelectorAll('.pulse');\n    var corners = FC.concat(BC); // 8 reflection targets\n\n    for(var r=0;r<paths.length;r++){\n      // each ray zig-zags from source to a few wall points\n      var a = (r/paths.length)*Math.PI*2;\n      var t1 = corners[(r*3)%8], t2 = corners[(r*5+2)%8], t3=corners[(r*7+4)%8];\n      // pull bounce points toward source by (1-reach) so short rooms = tight bounce\n      function lerp(p,q,t){ return [p[0]+(q[0]-p[0])*t, p[1]+(q[1]-p[1])*t]; }\n      var bp1=lerp([srcX,srcY],t1,reach);\n      var bp2=lerp([srcX,srcY],t2,reach*0.85);\n      var bp3=lerp([srcX,srcY],t3,reach);\n      var d='M'+srcX+' '+srcY+' L'+bp1[0]+' '+bp1[1]+' L'+bp2[0]+' '+bp2[1]+' L'+bp3[0]+' '+bp3[1];\n      var pa=paths[r];\n      pa.setAttribute('d',d);\n      pa.style.opacity = (bright* (0.55+0.45*Math.sin(r))).toFixed(3);\n      // animate travel along the ray\n      var dur = (2.2 + r*0.35 + (1-size)*1.5).toFixed(2);\n      pa.style.animation = 'travel '+dur+'s linear infinite';\n      pa.style.animationDelay = (-r*0.4)+'s';\n      // pulse rides to bounce endpoint timed with damp (longer dwell = less damp)\n      var pu=pulses[r];\n      pu.setAttribute('cx',bp3[0]); pu.setAttribute('cy',bp3[1]);\n      pu.style.animation='hit '+dur+'s ease-in infinite';\n      pu.style.animationDelay=(-r*0.4)+'s';\n      pu.style.opacity=bright.toFixed(2);\n    }\n  }\n\n  // ---------- init / host ----------\n  function ready(){\n    PARAMS.forEach(function(p){ state[p.i]=p.def; });\n    PARAMS.forEach(function(p){ paint(p); });\n    syncRoom();\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  OPEN ROOM — bright, efficient algorithmic room/hall reverb\n//  Eight parallel damped comb filters per channel feed four series\n//  all-pass diffusers; a small stereo offset between the L/R comb\n//  tunings opens up the image. Room Size sets the comb feedback (tail\n//  length), Damping rolls off the highs inside the combs, Width blends\n//  the stereo spread, Pre-Delay offsets the wet onset. Pure algorithm,\n//  no samples. Mix=0 is bit-exact dry.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst P_MIX:     i32 = 0; // 0..1 dry/wet\nconst P_SIZE:    i32 = 1; // 0..1 -> comb feedback (room size / decay)\nconst P_DAMP:    i32 = 2; // 0..1 -> HF damping inside combs\nconst P_WIDTH:   i32 = 3; // 0..1 -> stereo width\nconst P_PREDLY:  i32 = 4; // 0..1 -> pre-delay 0..120 ms\n\n// ---- Freeverb-style topology constants -------------------------------\nconst NUM_COMBS:   i32 = 8;\nconst NUM_ALLPASS: i32 = 4;\n// Stereo offset (samples) added to the right channel comb tunings.\nconst STEREO_SPREAD: i32 = 23;\n\n// Base comb delay lengths (samples @ 44.1 kHz) — classic tunings.\nconst combTune: StaticArray<i32> = new StaticArray<i32>(NUM_COMBS);\n// Base all-pass delay lengths.\nconst apTune: StaticArray<i32> = new StaticArray<i32>(NUM_ALLPASS);\n\n// Max delay buffer sizes (scaled for up to 96 kHz: *2.2 headroom).\nconst COMB_MAX:  i32 = 4096;  // covers longest comb (~1617 @44.1k) * SR scale\nconst AP_MAX:    i32 = 1024;  // covers longest allpass (~556) * SR scale\nconst PRE_MAX:   i32 = 16384; // 120 ms @ up to ~96 kHz fits\n\n// Comb state: delay lines + per-channel low-pass damping memory.\nconst combBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_COMBS * COMB_MAX);\nconst combIdx: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_COMBS);\nconst combLen: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_COMBS);\nconst combLP:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_COMBS);\n\n// All-pass state.\nconst apBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_ALLPASS * AP_MAX);\nconst apIdx: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_ALLPASS);\nconst apLen: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_ALLPASS);\n\n// Pre-delay line (per channel).\nconst preBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * PRE_MAX);\nconst preIdx: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nfunction buildDelays(): void {\n  // classic comb tunings (samples @ 44.1 kHz)\n  combTune[0] = 1116; combTune[1] = 1188; combTune[2] = 1277; combTune[3] = 1356;\n  combTune[4] = 1422; combTune[5] = 1491; combTune[6] = 1557; combTune[7] = 1617;\n  // classic all-pass tunings\n  apTune[0] = 556; apTune[1] = 441; apTune[2] = 341; apTune[3] = 225;\n\n  const srScale: f32 = sampleRate / 44100.0;\n\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    const spread: i32 = (c == 1) ? STEREO_SPREAD : 0;\n    for (let k = 0; k < NUM_COMBS; k++) {\n      let len: i32 = i32(f32(combTune[k] + spread) * srScale);\n      if (len < 1) len = 1;\n      if (len > COMB_MAX) len = COMB_MAX;\n      const ci: i32 = c * NUM_COMBS + k;\n      combLen[ci] = len;\n      combIdx[ci] = 0;\n      combLP[ci] = 0.0;\n      const off: i32 = ci * COMB_MAX;\n      for (let s = 0; s < len; s++) combBuf[off + s] = 0.0;\n    }\n    for (let k = 0; k < NUM_ALLPASS; k++) {\n      let len: i32 = i32(f32(apTune[k] + spread) * srScale);\n      if (len < 1) len = 1;\n      if (len > AP_MAX) len = AP_MAX;\n      const ai: i32 = c * NUM_ALLPASS + k;\n      apLen[ai] = len;\n      apIdx[ai] = 0;\n      const off: i32 = ai * AP_MAX;\n      for (let s = 0; s < len; s++) apBuf[off + s] = 0.0;\n    }\n    preIdx[c] = 0;\n    const poff: i32 = c * PRE_MAX;\n    for (let s = 0; s < PRE_MAX; s++) preBuf[poff + s] = 0.0;\n  }\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  if (channels < 1) channels = 1;\n  buildDelays();\n  params[P_MIX] = 0.35; params[P_SIZE] = 0.7; params[P_DAMP] = 0.4;\n  params[P_WIDTH] = 1.0; params[P_PREDLY] = 0.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const mix:    f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const sizeN:  f32 = clampf(params[P_SIZE], 0.0, 1.0);\n  const dampN:  f32 = clampf(params[P_DAMP], 0.0, 1.0);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const preN:   f32 = clampf(params[P_PREDLY], 0.0, 1.0);\n\n  // Mix=0 -> bit-exact dry passthrough.\n  if (mix <= 0.0) {\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      for (let f = 0; f < n; f++) outBuf[base + f] = inBuf[base + f];\n    }\n    return;\n  }\n\n  // comb feedback: 0.7..~0.98 (room size). guarded < 1.\n  const feedback: f32 = 0.70 + sizeN * 0.28;\n  // damping low-pass coefficient inside combs.\n  const damp1: f32 = dampN * 0.4;       // 0..0.4\n  const damp2: f32 = 1.0 - damp1;\n  // input gain into the reverb network (keeps the tail bounded).\n  const inGain: f32 = 0.015;\n  // pre-delay length in samples (0..120 ms).\n  let preSamp: i32 = i32(preN * 0.120 * sampleRate);\n  if (preSamp < 0) preSamp = 0;\n  if (preSamp >= PRE_MAX) preSamp = PRE_MAX - 1;\n\n  // equal-power dry/wet\n  const wetG: f32 = mix;\n  const dryG: f32 = 1.0 - mix;\n\n  // Width: blend mono(0) .. full stereo(1) of the wet signal.\n  const wWet: f32 = 0.5 + 0.5 * widthN; // this channel weight\n  const wCross: f32 = 0.5 - 0.5 * widthN; // other channel weight\n\n  // process per channel; we need both wet channels before width mixing,\n  // so compute wet into outBuf scratch (channel-separated), then blend.\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const poff: i32 = c * PRE_MAX;\n    let pIdx: i32 = preIdx[c];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n\n      // ---- pre-delay ----\n      let rIdx: i32 = pIdx - preSamp;\n      if (rIdx < 0) rIdx += PRE_MAX;\n      const preOut: f32 = preBuf[poff + rIdx];\n      preBuf[poff + pIdx] = dry;\n      pIdx++;\n      if (pIdx >= PRE_MAX) pIdx = 0;\n\n      const input: f32 = preOut * inGain;\n\n      // ---- parallel damped combs ----\n      let acc: f32 = 0.0;\n      for (let k = 0; k < NUM_COMBS; k++) {\n        const ci: i32 = c * NUM_COMBS + k;\n        const off: i32 = ci * COMB_MAX;\n        const len: i32 = combLen[ci];\n        let idx: i32 = combIdx[ci];\n        const y: f32 = combBuf[off + idx];\n        acc += y;\n        // one-pole LP damping in the feedback path\n        let lp: f32 = combLP[ci];\n        lp = y * damp2 + lp * damp1;\n        combLP[ci] = lp;\n        combBuf[off + idx] = input + lp * feedback;\n        idx++;\n        if (idx >= len) idx = 0;\n        combIdx[ci] = idx;\n      }\n\n      // ---- series all-pass diffusers ----\n      let s: f32 = acc;\n      for (let k = 0; k < NUM_ALLPASS; k++) {\n        const ai: i32 = c * NUM_ALLPASS + k;\n        const off: i32 = ai * AP_MAX;\n        const len: i32 = apLen[ai];\n        let idx: i32 = apIdx[ai];\n        const buf: f32 = apBuf[off + idx];\n        const out: f32 = buf - s;        // allpass output\n        apBuf[off + idx] = s + buf * 0.5; // feedback coeff 0.5\n        idx++;\n        if (idx >= len) idx = 0;\n        apIdx[ai] = idx;\n        s = out;\n      }\n\n      // store the raw wet for this channel in outBuf scratch\n      outBuf[base + f] = s;\n    }\n    preIdx[c] = pIdx;\n  }\n\n  // ---- width blend + dry/wet mix ----\n  if (channels >= 2) {\n    for (let f = 0; f < n; f++) {\n      const wl: f32 = outBuf[f];\n      const wr: f32 = outBuf[MAX_FRAMES + f];\n      const wetL: f32 = wl * wWet + wr * wCross;\n      const wetR: f32 = wr * wWet + wl * wCross;\n      const dryL: f32 = inBuf[f];\n      const dryR: f32 = inBuf[MAX_FRAMES + f];\n      outBuf[f] = dryL * dryG + wetL * wetG;\n      outBuf[MAX_FRAMES + f] = dryR * dryG + wetR * wetG;\n    }\n  } else {\n    for (let f = 0; f < n; f++) {\n      const w: f32 = outBuf[f];\n      const d: f32 = inBuf[f];\n      outBuf[f] = d * dryG + w * wetG;\n    }\n  }\n}\n",
  "publishedAt": 1751000020000
}