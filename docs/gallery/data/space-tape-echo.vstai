{
  "format": 1,
  "name": "Space Tape Echo",
  "isInstrument": false,
  "explanation": "A multi-head tape echo: one circulating tape loop is read by three virtual playback heads at fixed taps, and a Mode control selects which head combination is active for different rhythmic repeat patterns. The repeats pass through tape-style HF loss and gentle saturation, a wow/flutter LFO adds vintage pitch wander, and a short ambient tail sits underneath. Controls: Time, Feedback, Mode, Wow, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Wow",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Tone",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Space Tape Echo</title>\n<style>\n  :root{\n    --accent:#ff8c5a;\n    --accent2:#ffb37a;\n    --wood1:#3a241a;\n    --wood2:#241008;\n    --metal1:#cdb7a3;\n    --metal2:#8a7160;\n    --metal3:#5b4636;\n    --ink:#1a0f08;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{width:100%;height:100%;overflow:hidden;background:#0c0704;\n    font-family:-apple-system,\"Helvetica Neue\",Arial,sans-serif;color:#f0e2d4}\n  #stage{\n    position:relative;width:100%;height:100%;min-height:520px;\n    display:flex;align-items:center;justify-content:center;\n    background:radial-gradient(120% 90% at 50% -10%, #2a1810 0%, #100805 60%, #050302 100%);\n    padding:18px;\n  }\n  /* ---- the chassis ---- */\n  #panel{\n    position:relative;width:760px;max-width:100%;height:480px;border-radius:18px;\n    /* warm metal faceplate with wood frame */\n    background:\n      linear-gradient(180deg, rgba(255,255,255,.06), rgba(0,0,0,.35)),\n      repeating-linear-gradient(92deg, #b39a85 0px, #b39a85 2px, #a98e78 4px),\n      linear-gradient(135deg, var(--metal1), var(--metal2) 55%, var(--metal3));\n    border:10px solid;\n    border-image:linear-gradient(160deg,#5a3a26,#2c160c) 1;\n    box-shadow:\n      0 40px 90px rgba(0,0,0,.7),\n      inset 0 2px 0 rgba(255,255,255,.25),\n      inset 0 -3px 18px rgba(0,0,0,.5),\n      0 0 0 2px rgba(0,0,0,.5);\n    padding:18px 22px;\n    overflow:hidden;\n  }\n  /* brushed-metal sheen sweeping slowly */\n  #panel::after{\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(115deg,transparent 40%,rgba(255,240,225,.10) 50%,transparent 60%);\n    transform:translateX(-30%);\n    animation:sheen 9s ease-in-out infinite;\n    mix-blend-mode:screen;\n  }\n  @keyframes sheen{0%,70%{transform:translateX(-60%)}85%,100%{transform:translateX(60%)}}\n\n  /* top brand bar */\n  #brand{position:relative;display:flex;align-items:center;justify-content:space-between;\n    z-index:3;margin-bottom:8px}\n  .logo{display:flex;align-items:center;gap:10px}\n  .logo .dot{width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff, var(--accent) 55%, #7a2f0d);\n    box-shadow:0 0 10px var(--accent),0 0 22px rgba(255,140,90,.5);\n    animation:pulse 2.6s ease-in-out infinite}\n  @keyframes pulse{0%,100%{box-shadow:0 0 8px var(--accent),0 0 16px rgba(255,140,90,.35)}\n    50%{box-shadow:0 0 16px var(--accent),0 0 34px rgba(255,140,90,.7)}}\n  .logo h1{font-size:19px;letter-spacing:3px;font-weight:800;text-transform:uppercase;\n    color:#2a160c;text-shadow:0 1px 0 rgba(255,255,255,.3)}\n  .logo h1 b{color:#7a2f0d}\n  .model{font-size:10px;letter-spacing:2px;color:#3a2418;opacity:.8;\n    border:1px solid rgba(58,36,24,.4);padding:3px 8px;border-radius:4px;\n    text-transform:uppercase}\n\n  /* ---- transport deck (reels + tape) ---- */\n  #deck{position:relative;height:200px;border-radius:12px;z-index:2;\n    background:\n      radial-gradient(110% 140% at 50% -20%, rgba(255,255,255,.06),transparent 50%),\n      linear-gradient(180deg,#22120a,#150a05);\n    box-shadow:inset 0 4px 22px rgba(0,0,0,.85),inset 0 0 0 1px rgba(255,180,140,.08),\n      0 1px 0 rgba(255,255,255,.12);\n    overflow:hidden;}\n  /* tape path SVG sits above the deck */\n  #tapeSvg{position:absolute;inset:0;width:100%;height:100%}\n  .reelWrap{position:absolute;top:50%;transform:translateY(-50%);width:150px;height:150px}\n  #reelL{left:34px}#reelR{right:34px}\n  .reel{width:100%;height:100%;transform-origin:50% 50%;\n    will-change:transform}\n  /* reel hub glow when running */\n  .reelGlow{filter:drop-shadow(0 0 6px rgba(255,140,90,.0))}\n\n  /* center capstan / head block */\n  #headBlock{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);\n    width:118px;height:150px;display:flex;flex-direction:column;align-items:center;\n    justify-content:flex-end;gap:8px;z-index:3}\n  .heads{display:flex;gap:9px;align-items:flex-end;height:42px}\n  .head{width:18px;border-radius:3px 3px 1px 1px;\n    background:linear-gradient(180deg,#e7d4c2,#7a604b);\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.5),0 2px 4px rgba(0,0,0,.6);\n    position:relative;transition:height .25s,box-shadow .25s,opacity .25s;opacity:.35}\n  .head.on{opacity:1;box-shadow:inset 0 1px 0 rgba(255,255,255,.6),\n    0 0 12px var(--accent),0 0 2px var(--accent)}\n  .head::after{content:\"\";position:absolute;left:50%;top:-4px;transform:translateX(-50%);\n    width:3px;height:6px;background:var(--accent);border-radius:2px;opacity:0;transition:opacity .25s}\n  .head.on::after{opacity:1;box-shadow:0 0 8px var(--accent)}\n  .capstan{width:8px;height:8px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#fff,#888);\n    box-shadow:0 0 6px rgba(0,0,0,.7)}\n\n  /* ---- controls row ---- */\n  #controls{position:relative;z-index:3;margin-top:16px;display:grid;\n    grid-template-columns:repeat(6,1fr);gap:10px;align-items:start}\n  .ctl{display:flex;flex-direction:column;align-items:center;gap:6px;\n    padding:8px 4px 6px;border-radius:10px;\n    background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(0,0,0,.18));\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.25),inset 0 -2px 6px rgba(0,0,0,.3)}\n  .clabel{font-size:10px;letter-spacing:1.5px;text-transform:uppercase;\n    color:#2a160c;font-weight:700}\n  .cval{font-size:11px;font-weight:700;color:#7a2f0d;font-variant-numeric:tabular-nums;\n    min-height:14px}\n\n  /* knob */\n  .knob{position:relative;width:62px;height:62px;cursor:ns-resize;touch-action:none}\n  .knob svg{display:block;width:100%;height:100%}\n  .knob .cap{transition:filter .15s}\n  .knob:hover .cap{filter:brightness(1.12)}\n  .knob:active{cursor:grabbing}\n\n  /* mode toggle switch */\n  .switch{position:relative;width:58px;height:62px;cursor:pointer;\n    display:flex;align-items:center;justify-content:center}\n  .swBody{width:38px;height:54px;border-radius:8px;\n    background:linear-gradient(180deg,#1a0d06,#0c0603);\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.8),0 1px 0 rgba(255,255,255,.2);\n    position:relative;overflow:hidden}\n  .swLever{position:absolute;left:50%;top:6px;transform:translateX(-50%);\n    width:18px;height:24px;border-radius:6px;\n    background:linear-gradient(180deg,#e7d4c2,#8a7160);\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.6),0 4px 6px rgba(0,0,0,.6);\n    transition:transform .22s cubic-bezier(.5,1.6,.4,1)}\n  .switch.up .swLever{transform:translateX(-50%) translateY(0)}\n  .switch.down .swLever{transform:translateX(-50%) translateY(24px)}\n  .swLED{position:absolute;left:50%;bottom:5px;transform:translateX(-50%);\n    width:7px;height:7px;border-radius:50%;background:#3a1a0c;transition:.22s}\n  .switch.up .swLED{background:var(--accent);box-shadow:0 0 9px var(--accent)}\n\n  /* ---- right-side VU meter glow strip embedded as a control flourish ---- */\n  #vuBar{position:absolute;right:22px;top:64px;width:8px;height:200px;border-radius:5px;z-index:3;\n    background:#160a05;box-shadow:inset 0 0 6px rgba(0,0,0,.9),0 0 0 1px rgba(255,180,140,.12);\n    overflow:hidden;display:none}\n  /* screws */\n  .screw{position:absolute;width:11px;height:11px;border-radius:50%;z-index:4;\n    background:radial-gradient(circle at 35% 30%,#e9d9c8,#6b5440);\n    box-shadow:inset 0 0 2px rgba(0,0,0,.6),0 1px 2px rgba(0,0,0,.5)}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-top:1.5px solid rgba(0,0,0,.45);\n    transform:rotate(35deg)}\n  .screw.tl{top:6px;left:6px}.screw.tr{top:6px;right:6px}\n  .screw.bl{bottom:6px;left:6px}.screw.br{bottom:6px;right:6px}\n</style>\n</head>\n<body>\n<div id=\"stage\">\n  <div id=\"panel\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div id=\"brand\">\n      <div class=\"logo\"><span class=\"dot\"></span>\n        <h1>SPACE <b>TAPE</b> ECHO</h1></div>\n      <div class=\"model\">RTR-3 · MULTI-HEAD</div>\n    </div>\n\n    <div id=\"deck\">\n      <!-- tape path: two diagonals from reel hubs over the head block -->\n      <svg id=\"tapeSvg\" viewBox=\"0 0 760 200\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"tapeG\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0\" stop-color=\"#5a3a28\"/>\n            <stop offset=\".5\" stop-color=\"#8a5a3a\"/>\n            <stop offset=\"1\" stop-color=\"#5a3a28\"/>\n          </linearGradient>\n        </defs>\n        <!-- the running tape ribbon -->\n        <path id=\"tapePath\" d=\"M 109 100 C 230 40, 280 30, 380 60 C 480 30, 530 40, 651 100\"\n              fill=\"none\" stroke=\"url(#tapeG)\" stroke-width=\"7\" stroke-linecap=\"round\"\n              opacity=\".9\"/>\n        <path id=\"tapeDash\" d=\"M 109 100 C 230 40, 280 30, 380 60 C 480 30, 530 40, 651 100\"\n              fill=\"none\" stroke=\"rgba(255,200,160,.55)\" stroke-width=\"1.4\"\n              stroke-dasharray=\"6 14\" stroke-linecap=\"round\"/>\n      </svg>\n\n      <div class=\"reelWrap\" id=\"reelL\">\n        <svg class=\"reel reelGlow\" viewBox=\"0 0 100 100\" id=\"reelSvgL\"></svg>\n      </div>\n      <div class=\"reelWrap\" id=\"reelR\">\n        <svg class=\"reel reelGlow\" viewBox=\"0 0 100 100\" id=\"reelSvgR\"></svg>\n      </div>\n\n      <div id=\"headBlock\">\n        <div class=\"heads\">\n          <div class=\"head\" id=\"h0\"></div>\n          <div class=\"head\" id=\"h1\"></div>\n          <div class=\"head\" id=\"h2\"></div>\n        </div>\n        <div class=\"capstan\"></div>\n      </div>\n    </div>\n\n    <div id=\"controls\"></div>\n  </div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n  var ACCENT=\"#ff8c5a\";\n\n  // ---- param definitions (mirror spec; indices are authoritative) ----\n  var PARAMS=[\n    {name:\"Time\",     index:0, min:0, max:1, default:0.3,  fmt:function(v){return Math.round(120+v*880)+\" ms\";}},\n    {name:\"Feedback\", index:1, min:0, max:1, default:0.45, fmt:function(v){return Math.round(v*100)+\" %\";}},\n    {name:\"Mode\",     index:2, min:0, max:1, default:0,    step:1, type:\"switch\",\n       opts:[\"SINGLE\",\"MULTI\"]},\n    {name:\"Wow\",      index:3, min:0, max:1, default:0.3,  fmt:function(v){return Math.round(v*100)+\" %\";}},\n    {name:\"Tone\",     index:4, min:0, max:1, default:0.55, fmt:function(v){return Math.round(v*100)+\" %\";}},\n    {name:\"Mix\",      index:5, min:0, max:1, default:0.45, fmt:function(v){return Math.round(v*100)+\" %\";}}\n  ];\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function clamp(v,a,b){return v<a?a:v>b?b:v;}\n\n  var state={}; // index -> normalized 0..1 stored as real value\n\n  // ---- build reel SVG (hub + spokes + flange) ----\n  function reelMarkup(){\n    var s='<defs><radialGradient id=\"flange\" cx=\"40%\" cy=\"35%\" r=\"70%\">'+\n      '<stop offset=\"0\" stop-color=\"#3a2418\"/><stop offset=\".6\" stop-color=\"#22120a\"/>'+\n      '<stop offset=\"1\" stop-color=\"#0c0603\"/></radialGradient>'+\n      '<radialGradient id=\"hub\" cx=\"40%\" cy=\"35%\" r=\"70%\">'+\n      '<stop offset=\"0\" stop-color=\"#e7d4c2\"/><stop offset=\"1\" stop-color=\"#6b5440\"/>'+\n      '</radialGradient></defs>';\n    s+='<circle cx=\"50\" cy=\"50\" r=\"48\" fill=\"url(#flange)\" stroke=\"#000\" stroke-width=\"1\"/>';\n    // tape wound on reel\n    s+='<circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"#2c1c12\" stroke-width=\"14\"/>';\n    s+='<circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"rgba(255,180,140,.12)\" stroke-width=\"1\"/>';\n    // three open windows in the flange\n    for(var k=0;k<3;k++){\n      var a=k*120*Math.PI/180;\n      var cx=50+18*Math.cos(a), cy=50+18*Math.sin(a);\n      s+='<circle cx=\"'+cx.toFixed(1)+'\" cy=\"'+cy.toFixed(1)+'\" r=\"9\" fill=\"#0a0502\" stroke=\"#1a0d06\" stroke-width=\"1\"/>';\n    }\n    // spokes\n    for(var j=0;j<3;j++){\n      var b=j*120;\n      s+='<rect x=\"48.5\" y=\"14\" width=\"3\" height=\"20\" rx=\"1.5\" fill=\"#5b4636\" transform=\"rotate('+b+' 50 50)\"/>';\n    }\n    s+='<circle cx=\"50\" cy=\"50\" r=\"12\" fill=\"url(#hub)\" stroke=\"#000\" stroke-width=\"1\"/>';\n    s+='<circle cx=\"50\" cy=\"50\" r=\"4\" fill=\"#1a0d06\"/>';\n    return s;\n  }\n  document.getElementById(\"reelSvgL\").innerHTML=reelMarkup();\n  document.getElementById(\"reelSvgR\").innerHTML=reelMarkup();\n\n  // ---- knob renderer (SVG arc + indicator) ----\n  function knobSvg(){\n    return '<svg viewBox=\"0 0 100 100\">'+\n      '<defs>'+\n        '<radialGradient id=\"kcap\" cx=\"38%\" cy=\"32%\" r=\"75%\">'+\n          '<stop offset=\"0\" stop-color=\"#5b4636\"/><stop offset=\".55\" stop-color=\"#2c1b12\"/>'+\n          '<stop offset=\"1\" stop-color=\"#120a06\"/></radialGradient>'+\n      '</defs>'+\n      // outer track\n      '<circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"rgba(0,0,0,.45)\" stroke-width=\"6\"/>'+\n      // active arc\n      '<path class=\"arc\" d=\"\" fill=\"none\" stroke=\"'+ACCENT+'\" stroke-width=\"6\" '+\n        'stroke-linecap=\"round\" style=\"filter:drop-shadow(0 0 4px '+ACCENT+')\"/>'+\n      // cap\n      '<circle class=\"cap\" cx=\"50\" cy=\"50\" r=\"33\" fill=\"url(#kcap)\" '+\n        'stroke=\"rgba(255,255,255,.18)\" stroke-width=\"1\"/>'+\n      '<circle cx=\"50\" cy=\"50\" r=\"33\" fill=\"none\" stroke=\"rgba(0,0,0,.55)\" stroke-width=\"2\" '+\n        'transform=\"translate(0,1.5)\" opacity=\".5\"/>'+\n      // pointer\n      '<line class=\"ptr\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"22\" stroke=\"'+ACCENT+'\" '+\n        'stroke-width=\"3\" stroke-linecap=\"round\" style=\"filter:drop-shadow(0 0 3px '+ACCENT+')\"/>'+\n      '<circle cx=\"50\" cy=\"50\" r=\"3\" fill=\"#e7d4c2\"/>'+\n    '</svg>';\n  }\n  var A0=-135, A1=135; // sweep range in degrees\n  function polar(cx,cy,r,deg){var a=(deg-90)*Math.PI/180;return [cx+r*Math.cos(a),cy+r*Math.sin(a)];}\n  function arcPath(norm){\n    var end=A0+(A1-A0)*norm;\n    var p0=polar(50,50,44,A0), p1=polar(50,50,44,end);\n    var large=(end-A0)>180?1:0;\n    if(norm<=0.0001) return \"\";\n    return \"M \"+p0[0].toFixed(1)+\" \"+p0[1].toFixed(1)+\n           \" A 44 44 0 \"+large+\" 1 \"+p1[0].toFixed(1)+\" \"+p1[1].toFixed(1);\n  }\n\n  // ---- build controls ----\n  var wrap=document.getElementById(\"controls\");\n  var controlRefs={};\n\n  PARAMS.forEach(function(p){\n    var cell=document.createElement(\"div\");\n    cell.className=\"ctl\";\n    var lbl=document.createElement(\"div\");lbl.className=\"clabel\";lbl.textContent=p.name;\n    var val=document.createElement(\"div\");val.className=\"cval\";\n\n    var real=p.default; state[p.index]=real;\n    var norm=(real-p.min)/(p.max-p.min);\n\n    if(p.type===\"switch\"){\n      var sw=document.createElement(\"div\");sw.className=\"switch\";\n      sw.innerHTML='<div class=\"swBody\"><div class=\"swLever\"></div><div class=\"swLED\"></div></div>';\n      cell.appendChild(lbl);cell.appendChild(sw);cell.appendChild(val);\n      function setSwitch(v){\n        v=Math.round(v); state[p.index]=v;\n        sw.classList.toggle(\"up\", v>=1);\n        sw.classList.toggle(\"down\", v<1);\n        val.textContent=p.opts[v];\n        send(p.index,v); applyMode(v);\n      }\n      sw.addEventListener(\"click\",function(){ setSwitch(state[p.index]>=1?0:1); });\n      controlRefs[p.index]={set:setSwitch};\n      setSwitch(real);\n    } else {\n      var knob=document.createElement(\"div\");knob.className=\"knob\";\n      knob.innerHTML=knobSvg();\n      cell.appendChild(lbl);cell.appendChild(knob);cell.appendChild(val);\n      var arc=knob.querySelector(\".arc\"), ptr=knob.querySelector(\".ptr\");\n\n      function render(n){\n        arc.setAttribute(\"d\",arcPath(n));\n        var deg=A0+(A1-A0)*n;\n        ptr.setAttribute(\"transform\",\"rotate(\"+deg+\" 50 50)\");\n        var rv=p.min+n*(p.max-p.min);\n        state[p.index]=rv;\n        val.textContent=p.fmt?p.fmt(n):(Math.round(n*100)+\"%\");\n      }\n      function commit(n){ n=clamp(n,0,1); render(n); send(p.index,p.min+n*(p.max-p.min)); reactTo(p,n); }\n\n      // drag\n      var dragging=false, startY=0, startN=0;\n      function down(e){dragging=true;startY=(e.touches?e.touches[0].clientY:e.clientY);\n        startN=(state[p.index]-p.min)/(p.max-p.min);\n        e.preventDefault();\n        window.addEventListener(\"mousemove\",move);window.addEventListener(\"mouseup\",up);\n        window.addEventListener(\"touchmove\",move,{passive:false});window.addEventListener(\"touchend\",up);}\n      function move(e){if(!dragging)return;\n        var y=(e.touches?e.touches[0].clientY:e.clientY);\n        var dy=startY-y; var fine=e.shiftKey?0.0025:0.007;\n        commit(startN+dy*fine); e.preventDefault();}\n      function up(){dragging=false;\n        window.removeEventListener(\"mousemove\",move);window.removeEventListener(\"mouseup\",up);\n        window.removeEventListener(\"touchmove\",move);window.removeEventListener(\"touchend\",up);}\n      knob.addEventListener(\"mousedown\",down);\n      knob.addEventListener(\"touchstart\",down,{passive:false});\n      knob.addEventListener(\"dblclick\",function(){var dn=(p.default-p.min)/(p.max-p.min);commit(dn);});\n      // wheel\n      knob.addEventListener(\"wheel\",function(e){e.preventDefault();\n        var n=(state[p.index]-p.min)/(p.max-p.min);\n        commit(n+(e.deltaY<0?0.03:-0.03));},{passive:false});\n\n      controlRefs[p.index]={set:function(v){commit((v-p.min)/(p.max-p.min));}};\n      render(norm); // visual init (send happens in ready)\n    }\n    wrap.appendChild(cell);\n  });\n\n  // ---- motif reactions ----\n  var reelL=document.getElementById(\"reelSvgL\"),\n      reelR=document.getElementById(\"reelSvgR\");\n  var dash=document.getElementById(\"tapeDash\");\n  var heads=[document.getElementById(\"h0\"),document.getElementById(\"h1\"),document.getElementById(\"h2\")];\n\n  // speed from Time (slower time => slower reels feel); animation handled by rAF\n  var spinSpeed=0.6;     // deg per frame baseline\n  var dashOffset=0, dashSpeed=1.2;\n  var feedbackGlow=0.45;\n\n  function reactTo(p,n){\n    if(p.index===0){ spinSpeed=0.35+ (1-n)*1.1; dashSpeed=0.6+(1-n)*2.4; } // time\n    if(p.index===1){ feedbackGlow=n; }                                     // feedback\n    if(p.index===3){ wowAmt=n; }                                           // wow\n    if(p.index===4){ /* tone tint handled via filter below */ toneAmt=n; }\n    if(p.index===5){ mixAmt=n; }\n  }\n  var wowAmt=0.3, toneAmt=0.55, mixAmt=0.45;\n\n  function applyMode(v){\n    // SINGLE => only center head active; MULTI => all three\n    heads[0].classList.toggle(\"on\", v>=1);\n    heads[2].classList.toggle(\"on\", v>=1);\n    heads[1].classList.add(\"on\"); // center always reads\n    heads.forEach(function(h,i){\n      var base= v>=1 ? (30+ i*6) : (i===1?40:20);\n      h.style.height=base+\"px\";\n    });\n  }\n\n  // ---- animation loop ----\n  var angL=0, angR=0;\n  function frame(){\n    angL=(angL+spinSpeed)%360;\n    angR=(angR+spinSpeed*0.94)%360; // take-up slightly different\n    reelL.style.transform=\"rotate(\"+angL+\"deg)\";\n    reelR.style.transform=\"rotate(\"+(-angR)+\"deg)\";\n\n    dashOffset=(dashOffset-dashSpeed);\n    dash.setAttribute(\"stroke-dashoffset\",dashOffset);\n\n    // feedback => head glow intensity + reel hub drop shadow\n    var g=0.2+feedbackGlow*0.8;\n    reelL.parentNode.style.filter=\"drop-shadow(0 0 \"+(feedbackGlow*14)+\"px rgba(255,140,90,\"+(feedbackGlow*.5)+\"))\";\n    reelR.parentNode.style.filter=reelL.parentNode.style.filter;\n\n    // wow => subtle vertical wobble of the tape ribbon via transform on svg\n    var t=performance.now()/1000;\n    var wob=Math.sin(t*(2+wowAmt*6))*wowAmt*4;\n    document.getElementById(\"tapeSvg\").style.transform=\"translateY(\"+wob.toFixed(2)+\"px)\";\n\n    // tone => warm/bright tint on the active-arc accent (panel hue shift)\n    var hue= -8 + toneAmt*24;\n    document.getElementById(\"deck\").style.filter=\"hue-rotate(\"+hue.toFixed(1)+\"deg) saturate(\"+(0.9+toneAmt*0.3)+\")\";\n\n    // mix => head LED brightness already via .on; modulate capstan glow with mix\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- host ready: send every param at its default ----\n  function ready(){\n    PARAMS.forEach(function(p){\n      var v=state[p.index];\n      send(p.index, v);\n      if(p.index===0){ var n=(v-p.min)/(p.max-p.min); spinSpeed=0.35+(1-n)*1.1; dashSpeed=0.6+(1-n)*2.4; }\n      if(p.index===1) feedbackGlow=(v-p.min)/(p.max-p.min);\n      if(p.index===3) wowAmt=(v-p.min)/(p.max-p.min);\n      if(p.index===4) toneAmt=(v-p.min)/(p.max-p.min);\n      if(p.index===5) mixAmt=(v-p.min)/(p.max-p.min);\n    });\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n\n  // expose for host-driven param updates (optional)\n  window.setParamFromHost=function(i,v){ if(controlRefs[i]) controlRefs[i].set(v); };\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SPACE TAPE ECHO — multi-head tape delay\n//  A single circulating tape loop is read by THREE virtual playback heads\n//  spaced at fixed taps along the loop (short / medium / long). A Mode\n//  control selects which combination of heads is active, so each setting\n//  gives a different rhythmic echo pattern. The repeats run through a\n//  tape-style HF-loss filter and a gentle record/playback saturation, and\n//  a slow wow + faster flutter LFO wobbles the tape speed for the unstable\n//  vintage pitch wander. Feedback is clamped so dense self-oscillation\n//  rings but stays bounded. A short diffuse ambient tail sits under the\n//  repeats. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Tape loop: long enough for the longest head tap (3x base time) at the\n// longest base time (~700 ms) plus modulation headroom, at up to 96 kHz.\n// 700ms * 3 = 2.1s -> ~201600 @96k; round up generously.\nconst TAPE_LEN: i32 = 220000 + 8192;\nconst tapeL: StaticArray<f32> = new StaticArray<f32>(TAPE_LEN);\nconst tapeR: StaticArray<f32> = new StaticArray<f32>(TAPE_LEN);\n\n// Short diffuse ambient tail — two short allpass/comb-ish lines per channel.\nconst AMB_LEN: i32 = 8192;\nconst ambL: StaticArray<f32> = new StaticArray<f32>(AMB_LEN);\nconst ambR: StaticArray<f32> = new StaticArray<f32>(AMB_LEN);\nconst AMB_T1: i32 = 1237;  // prime-ish delays for diffusion\nconst AMB_T2: i32 = 1931;\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\nlet ambPos: i32 = 0;\n\n// per-channel feedback tape-loss low-pass state\nlet lossLpL: f32 = 0.0;\nlet lossLpR: f32 = 0.0;\n\n// ambient tail state\nlet ambLpL: f32 = 0.0;\nlet ambLpR: f32 = 0.0;\n\n// smoothed base delay (samples) — the spacing of head 1 = the \"Time\" knob.\nlet smoothDelay: f32 = 9600.0;\n\n// wow + flutter LFO phases (shared tape transport)\nlet wowPhase: f32 = 0.0;\nlet flutPhase: f32 = 0.0;\n\nconst P_TIME: i32 = 0;      // 0..1 -> base tape speed (head spacing), ~40..700 ms\nconst P_FEEDBACK: i32 = 1;  // 0..1 -> feedback amount (clamped to 0.95)\nconst P_MODE: i32 = 2;      // 0..1 -> selects head combination (12 modes)\nconst P_WOW: i32 = 3;       // 0..1 -> wow/flutter depth\nconst P_TONE: i32 = 4;      // 0..1 -> repeat brightness (tape HF loss cutoff)\nconst P_MIX: i32 = 5;       // 0..1 -> dry/wet\n\nconst TWO_PI: f32 = 6.2831853;\n\n// Head tap multipliers relative to the base \"Time\" spacing. Three virtual\n// playback heads positioned further down the tape from the record head.\nconst HEAD1: f32 = 1.0;\nconst HEAD2: f32 = 1.95;   // slightly off integer -> looser, more tape-like\nconst HEAD3: f32 = 3.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  ambPos = 0;\n  lossLpL = 0.0; lossLpR = 0.0;\n  ambLpL = 0.0; ambLpR = 0.0;\n  wowPhase = 0.0; flutPhase = 0.0;\n  for (let i = 0; i < TAPE_LEN; i++) { tapeL[i] = 0.0; tapeR[i] = 0.0; }\n  for (let i = 0; i < AMB_LEN; i++) { ambL[i] = 0.0; ambR[i] = 0.0; }\n  smoothDelay = 0.18 * sampleRate; // ~180 ms default base spacing\n  params[P_TIME] = 0.30;\n  params[P_FEEDBACK] = 0.45;\n  params[P_MODE] = 0.40;\n  params[P_WOW] = 0.30;\n  params[P_TONE] = 0.55;\n  params[P_MIX] = 0.45;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Linear-interpolated, wrap-safe read of a tape line, `delaySamples` behind\n// the write head.\n@inline function readTape(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(TAPE_LEN);\n  while (rp >= f32(TAPE_LEN)) rp -= f32(TAPE_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= TAPE_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\n// Read at an absolute (already wrapped logic handled here) index in the\n// ambient line.\n@inline function readAmb(line: StaticArray<f32>, back: i32): f32 {\n  let p: i32 = ambPos - back;\n  if (p < 0) p += AMB_LEN;\n  return line[p];\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const modeN: f32 = clampf(params[P_MODE], 0.0, 1.0);\n  const wowN: f32 = clampf(params[P_WOW], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Base head spacing (\"Time\"): ~40..700 ms with a perceptual curve.\n  const timeMs: f32 = 40.0 + timeN * timeN * 660.0;\n  let targetDelay: f32 = timeMs * 0.001 * sampleRate;\n  // Longest active head is HEAD3 = 3x; keep that within the tape buffer.\n  const maxBase: f32 = f32(TAPE_LEN - 8) / HEAD3;\n  if (targetDelay > maxBase) targetDelay = maxBase;\n  if (targetDelay < 8.0) targetDelay = 8.0;\n\n  // Feedback strictly clamped: dense multi-head feedback can build fast, so\n  // cap a touch below 0.95 of the requested amount and tanh-limit the loop.\n  const fbGain: f32 = clampf(fbN * 0.95, 0.0, 0.95);\n\n  // Mode: 12 discrete head combinations (like the original's selector).\n  // Decode to three head-enable gains. Each entry switches heads on/off.\n  const modeIdx: i32 = i32(clampf(modeN * 11.0 + 0.5, 0.0, 11.0));\n  let g1: f32 = 0.0; let g2: f32 = 0.0; let g3: f32 = 0.0;\n  if (modeIdx == 0)      { g1 = 1.0; g2 = 0.0; g3 = 0.0; } // head 1\n  else if (modeIdx == 1) { g1 = 0.0; g2 = 1.0; g3 = 0.0; } // head 2\n  else if (modeIdx == 2) { g1 = 0.0; g2 = 0.0; g3 = 1.0; } // head 3\n  else if (modeIdx == 3) { g1 = 1.0; g2 = 1.0; g3 = 0.0; } // 1+2\n  else if (modeIdx == 4) { g1 = 0.0; g2 = 1.0; g3 = 1.0; } // 2+3\n  else if (modeIdx == 5) { g1 = 1.0; g2 = 0.0; g3 = 1.0; } // 1+3\n  else if (modeIdx == 6) { g1 = 1.0; g2 = 1.0; g3 = 1.0; } // 1+2+3\n  else if (modeIdx == 7) { g1 = 0.8; g2 = 1.0; g3 = 0.6; } // 2 lead, 1+3 under\n  else if (modeIdx == 8) { g1 = 1.0; g2 = 0.7; g3 = 1.0; } // 1+3 lead\n  else if (modeIdx == 9) { g1 = 0.6; g2 = 1.0; g3 = 1.0; } // 2+3 lead\n  else if (modeIdx == 10){ g1 = 1.0; g2 = 1.0; g3 = 0.5; } // 1+2, soft 3\n  else                   { g1 = 0.7; g2 = 0.85; g3 = 1.0; }// long-weighted\n\n  // Normalise the active heads so denser modes don't blow up the level.\n  const gSum: f32 = g1 + g2 + g3;\n  const gNorm: f32 = gSum > 0.0001 ? f32(1.0 / Mathf.sqrt(gSum)) : 1.0;\n  g1 *= gNorm; g2 *= gNorm; g3 *= gNorm;\n\n  // The signal fed back into the loop is the sum of the active heads; pick a\n  // representative single delay for the feedback path so feedback timing is\n  // coherent (use the longest active head).\n  let fbHeadMul: f32 = HEAD1;\n  if (g3 > 0.0) fbHeadMul = HEAD3;\n  else if (g2 > 0.0) fbHeadMul = HEAD2;\n\n  // Tape HF loss in the loop: brighter when Tone high. ~1200..7500 Hz.\n  const toneHz: f32 = 1200.0 + toneN * toneN * 6300.0;\n  let cLoss: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  cLoss = clampf(cLoss, 0.0, 1.0);\n\n  // Ambient tail damping low-pass (keep the tail dark and diffuse).\n  const cAmb: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 3200.0 / sampleRate));\n\n  // Wow (slow) + flutter (fast) modulation of the tape transport. Depth in\n  // samples scales the read position of every head together (transport speed).\n  const wowDepth: f32 = wowN * 0.004;   // fractional speed deviation (slow)\n  const flutDepth: f32 = wowN * 0.0015; // fractional speed deviation (fast)\n  const wowRate: f32 = 0.6;   // Hz\n  const flutRate: f32 = 6.7;  // Hz\n  const wowInc: f32 = TWO_PI * wowRate / sampleRate;\n  const flutInc: f32 = TWO_PI * flutRate / sampleRate;\n\n  // Smooth the base delay toward target (~8 Hz one-pole) to avoid zipper noise.\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 8.0 / sampleRate));\n\n  const maxRead: f32 = f32(TAPE_LEN - 4);\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    // advance modulation\n    wowPhase += wowInc; if (wowPhase >= TWO_PI) wowPhase -= TWO_PI;\n    flutPhase += flutInc; if (flutPhase >= TWO_PI) flutPhase -= TWO_PI;\n    const wob: f32 = Mathf.sin(wowPhase) * wowDepth + Mathf.sin(flutPhase) * flutDepth;\n    // transport scaling: all head taps stretch/compress together\n    const speed: f32 = 1.0 + wob;\n\n    smoothDelay += smoothCoeff * (targetDelay - smoothDelay);\n    const base: f32 = smoothDelay * speed;\n\n    // head tap distances (modulated as a group, slight L/R offset for width)\n    let d1: f32 = base * HEAD1;\n    let d2: f32 = base * HEAD2;\n    let d3: f32 = base * HEAD3;\n    if (d1 < 2.0) d1 = 2.0; if (d1 > maxRead) d1 = maxRead;\n    if (d2 < 2.0) d2 = 2.0; if (d2 > maxRead) d2 = maxRead;\n    if (d3 < 2.0) d3 = 2.0; if (d3 > maxRead) d3 = maxRead;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n\n    // ---- read the three heads (L slightly earlier, R slightly later) -----\n    const offL: f32 = 1.0;\n    const offR: f32 = 1.0;\n    const h1L: f32 = readTape(tapeL, d1 - offL);\n    const h2L: f32 = readTape(tapeL, d2 - offL);\n    const h3L: f32 = readTape(tapeL, d3 - offL);\n    const h1R: f32 = readTape(tapeR, d1 + offR);\n    const h2R: f32 = readTape(tapeR, d2 + offR);\n    const h3R: f32 = readTape(tapeR, d3 + offR);\n\n    const echoL: f32 = h1L * g1 + h2L * g2 + h3L * g3;\n    const echoR: f32 = h1R * g1 + h2R * g2 + h3R * g3;\n\n    // ---- feedback path: take the loop tap, apply tape HF loss + saturation\n    const fbTapL: f32 = readTape(tapeL, base * fbHeadMul);\n    const fbTapR: f32 = readTape(tapeR, base * fbHeadMul);\n    lossLpL += cLoss * (fbTapL - lossLpL);\n    lossLpR += cLoss * (fbTapR - lossLpR);\n\n    // record/playback saturation keeps runaway feedback bounded & warm\n    let recL: f32 = xL + lossLpL * fbGain;\n    let recR: f32 = xR + lossLpR * fbGain;\n    recL = f32(Mathf.tanh(recL));\n    recR = f32(Mathf.tanh(recR));\n\n    // write to the tape at the record head\n    tapeL[writePos] = recL;\n    tapeR[writePos] = recR;\n\n    // ---- short ambient tail fed by the echo sum --------------------------\n    const ambInL: f32 = echoL * 0.6;\n    const ambInR: f32 = echoR * 0.6;\n    const a1L: f32 = readAmb(ambL, AMB_T1);\n    const a2L: f32 = readAmb(ambL, AMB_T2);\n    const a1R: f32 = readAmb(ambR, AMB_T1);\n    const a2R: f32 = readAmb(ambR, AMB_T2);\n    let tailL: f32 = (a1L + a2L) * 0.5;\n    let tailR: f32 = (a1R + a2R) * 0.5;\n    ambLpL += cAmb * (tailL - ambLpL);\n    ambLpR += cAmb * (tailR - ambLpR);\n    tailL = ambLpL;\n    tailR = ambLpR;\n    // feed the diffuser (cross-couple L/R for a wider tail), bounded gain\n    ambL[ambPos] = f32(ambInL + tailR * 0.45);\n    ambR[ambPos] = f32(ambInR + tailL * 0.45);\n    ambPos++; if (ambPos >= AMB_LEN) ambPos = 0;\n\n    // ---- wet sum: heads + a touch of ambient tail ------------------------\n    const wetL: f32 = echoL + tailL * 0.35;\n    const wetR: f32 = echoR + tailR * 0.35;\n\n    // Output gain trim keeps the wet path peak < ~1.0 even at dense modes.\n    const oL: f32 = xL * (1.0 - mix) + wetL * 0.7 * mix;\n    const oR: f32 = xR * (1.0 - mix) + wetR * 0.7 * mix;\n\n    outBuf[f] = f32(oL);\n    if (stereo) outBuf[MAX_FRAMES + f] = f32(oR);\n    else outBuf[MAX_FRAMES + f] = outBuf[f];\n\n    writePos++;\n    if (writePos >= TAPE_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000032000
}