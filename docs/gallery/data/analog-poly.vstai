{
  "format": 1,
  "name": "Analog Poly",
  "isInstrument": true,
  "explanation": "A warm polyphonic analog-style synthesizer with up to eight independent voices. Each voice runs two detuned oscillators (a band-limited saw and pulse) into a resonant 4-pole low-pass shaped by its own filter envelope, then an amplitude ADSR; chords ring with independent contours. Controls: Detune, Cutoff, Resonance, Filter Env Amount and a full ADSR.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "FilterEnvAmt",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.02
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Sustain",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Release",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.3
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --p{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --ac:#ff7ad1; --ac2:#b08cff;\n  --cream:#efe7d4; --cream2:#e2d7bd; --ink:#2b2620;\n  --wood:#5a3d28; --wood2:#3c2718;\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(120% 90% at 50% -10%,#23211c 0%,#13110d 60%,#0a0907 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;-webkit-font-smoothing:antialiased;\n}\n\n/* ---- the boutique chassis: cream surface in a wood frame ---- */\n.synth{\n  position:relative;width:100%;max-width:760px;\n  border-radius:14px;\n  padding:9px;\n  background:\n    linear-gradient(150deg,var(--wood) 0%,var(--wood2) 100%);\n  box-shadow:\n    0 36px 80px rgba(0,0,0,.62),\n    0 2px 0 rgba(255,255,255,.06) inset,\n    0 -3px 14px rgba(0,0,0,.5) inset;\n  animation:rise .7s cubic-bezier(.2,.8,.2,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(22px) scale(.985)}to{opacity:1;transform:none}}\n.surface{\n  position:relative;border-radius:8px;overflow:hidden;\n  background:\n    linear-gradient(180deg,#f4ecda,#e7dcc2 62%,#ddd0b2 100%);\n  box-shadow:\n    0 1px 0 rgba(255,255,255,.7) inset,\n    0 -10px 26px rgba(120,96,52,.22) inset,\n    0 0 0 1px rgba(90,61,40,.35);\n}\n/* faint silk-screen print noise / brushed feel */\n.surface::before{\n  content:\"\";position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.5;\n  background:\n    repeating-linear-gradient(92deg,rgba(120,96,52,.045) 0 2px,transparent 2px 5px),\n    radial-gradient(140% 70% at 50% 0%,rgba(255,255,255,.5),transparent 60%);\n  mix-blend-mode:multiply;\n}\n\n/* ---------------- header / brand plate ---------------- */\n.head{\n  position:relative;z-index:2;display:flex;align-items:flex-end;gap:14px;\n  padding:16px 22px 12px;\n  border-bottom:2px solid rgba(90,61,40,.28);\n}\n.brand{display:flex;flex-direction:column;line-height:1}\n.brand .mk{font-size:9.5px;letter-spacing:.42em;color:#8a7048;font-weight:700;text-transform:uppercase}\n.brand h1{\n  margin:3px 0 0;font-size:25px;font-weight:900;letter-spacing:.02em;\n  color:#2b2620;\n  text-shadow:0 1px 0 rgba(255,255,255,.55), 0 -1px 0 rgba(90,61,40,.2);\n}\n.brand h1 em{font-style:normal;\n  background:linear-gradient(90deg,var(--ac),var(--ac2));\n  -webkit-background-clip:text;background-clip:text;color:transparent}\n.tag{font-size:9.5px;letter-spacing:.28em;color:#9a8255;text-transform:uppercase;margin-top:3px}\n\n/* ---------------- VOICE LED bank (the motif) ---------------- */\n.voices{margin-left:auto;display:flex;flex-direction:column;align-items:flex-end;gap:7px}\n.voices .vlbl{font-size:8.5px;letter-spacing:.34em;color:#8a7048;text-transform:uppercase;font-weight:700}\n.bank{display:flex;gap:9px;padding:8px 11px;border-radius:9px;\n  background:linear-gradient(180deg,#26211a,#161209);\n  box-shadow:0 1px 0 rgba(255,255,255,.18),0 -2px 6px rgba(0,0,0,.5) inset, 0 2px 5px rgba(0,0,0,.4)}\n.voice{position:relative;width:13px;height:13px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#5e564a,#221d15 75%);\n  box-shadow:0 1px 1px rgba(0,0,0,.6) inset,0 1px 0 rgba(255,255,255,.07)}\n.voice::after{content:\"\";position:absolute;inset:2px;border-radius:50%;\n  background:var(--ac);opacity:0;transform:scale(.55);\n  box-shadow:0 0 9px var(--ac),0 0 18px var(--ac);transition:opacity .12s,transform .12s}\n.voice.on::after{opacity:1;transform:scale(1)}\n.voice .num{position:absolute;bottom:-13px;left:50%;transform:translateX(-50%);\n  font-size:7px;color:#8a7048;font-weight:700}\n\n/* ---------------- main body ---------------- */\n.body{position:relative;z-index:2;padding:18px 22px 6px}\n\n/* section title rule, screen-printed style */\n.sect{display:grid;gap:14px}\n.row{display:flex;gap:22px;align-items:stretch;flex-wrap:wrap}\n.module{\n  flex:1 1 0;min-width:220px;position:relative;\n  padding:14px 16px 16px;border-radius:9px;\n  background:linear-gradient(180deg,rgba(255,255,255,.34),rgba(255,255,255,0));\n  box-shadow:0 0 0 1px rgba(90,61,40,.18),0 1px 0 rgba(255,255,255,.5) inset;\n}\n.module>.mt{font-size:9px;letter-spacing:.3em;color:#8a7048;text-transform:uppercase;font-weight:800;margin-bottom:12px;\n  display:flex;align-items:center;gap:8px}\n.module>.mt::after{content:\"\";flex:1;height:1px;background:repeating-linear-gradient(90deg,rgba(90,61,40,.3) 0 5px,transparent 5px 9px)}\n\n.knobs{display:flex;gap:8px;justify-content:space-around;flex-wrap:wrap}\n\n/* ---------------- bakelite knob ---------------- */\n.cell{display:flex;flex-direction:column;align-items:center;gap:8px;width:80px;\n  animation:pop .55s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(9px) scale(.92)}to{opacity:1;transform:none}}\n.knob{--p:0;position:relative;width:62px;height:62px;cursor:ns-resize;touch-action:none;user-select:none}\n/* outer scale ticks etched into cream */\n.knob .scale{position:absolute;inset:-9px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(90,61,40,.55) 0 1.1deg,transparent 1.1deg 13.5deg);\n  -webkit-mask:radial-gradient(circle,transparent 33px,#000 34px,#000 36px,transparent 37px);\n  mask:radial-gradient(circle,transparent 33px,#000 34px,#000 36px,transparent 37px)}\n/* glowing active arc, themed */\n.knob .arc{position:absolute;inset:-5px;border-radius:50%;\n  background:conic-gradient(from 215deg,\n    var(--ac) calc(var(--p)*290deg),\n    color-mix(in srgb,var(--ac2) 60%,var(--ac)) calc(var(--p)*290deg),\n    rgba(90,61,40,.14) calc(var(--p)*290deg) 290deg,\n    transparent 290deg);\n  -webkit-mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33.5px,transparent 34.5px);\n  mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33.5px,transparent 34.5px);\n  filter:drop-shadow(0 0 calc(2px + var(--p)*7px) color-mix(in srgb,var(--ac) 70%,transparent));\n  transition:--p .12s cubic-bezier(.2,.8,.25,1)}\n/* the cap — ivory/bakelite */\n.knob .cap{position:absolute;inset:8px;border-radius:50%;\n  background:\n    radial-gradient(circle at 42% 30%,#fbf5e8,#e6dcc6 52%,#bcaa86 100%);\n  box-shadow:\n    0 2px 5px rgba(60,39,24,.45),\n    0 1px 0 rgba(255,255,255,.85) inset,\n    0 -4px 8px rgba(120,96,52,.35) inset}\n.knob.act .cap{box-shadow:0 2px 5px rgba(60,39,24,.45),0 1px 0 rgba(255,255,255,.85) inset,0 -4px 8px rgba(120,96,52,.35) inset,0 0 0 2px color-mix(in srgb,var(--ac) 60%,transparent)}\n/* pointer notch */\n.knob .ptr{position:absolute;left:50%;top:9px;width:3px;height:18px;margin-left:-1.5px;border-radius:2px;\n  background:linear-gradient(var(--ink),#5a3d28);\n  box-shadow:0 0 0 1px rgba(255,255,255,.3);\n  transform-origin:50% 22px;\n  transform:rotate(calc((var(--p) - .5)*290deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.cnm{font-size:9.5px;letter-spacing:.13em;color:#6a5536;text-transform:uppercase;font-weight:800;text-align:center}\n.cval{font-size:11px;font-weight:800;color:#2b2620;font-variant-numeric:tabular-nums;\n  background:rgba(90,61,40,.1);padding:1px 8px;border-radius:5px;min-width:38px;text-align:center}\n.cell:hover .cval{background:color-mix(in srgb,var(--ac) 28%,rgba(90,61,40,.1))}\n\n/* ---------------- ADSR module : live envelope graph ---------------- */\n.envwrap{display:flex;gap:16px;align-items:center;flex-wrap:wrap}\n.graph{flex:1 1 200px;min-width:200px;height:96px;border-radius:7px;position:relative;\n  background:linear-gradient(180deg,#1b1710,#0e0b06);\n  box-shadow:0 -2px 7px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.18)}\n.graph svg{position:absolute;inset:0;width:100%;height:100%}\n.graph .grid line{stroke:rgba(255,255,255,.05)}\n.envline{fill:none;stroke:url(#eg);stroke-width:2.4;stroke-linejoin:round;\n  filter:drop-shadow(0 0 5px var(--ac))}\n.envfill{fill:url(#ef);opacity:.5}\n.dot{fill:#fff;filter:drop-shadow(0 0 4px var(--ac))}\n.sweep{stroke:var(--ac);stroke-width:1.5;opacity:.0}\n\nfooter{position:relative;z-index:2;display:flex;align-items:center;gap:10px;\n  padding:11px 22px 16px;font-size:10px;color:#8a7048;letter-spacing:.04em}\nfooter .dotL{width:7px;height:7px;border-radius:50%;background:var(--ac);\n  box-shadow:0 0 8px var(--ac);animation:bp 2.4s ease-in-out infinite}\n@keyframes bp{0%,100%{opacity:.5}50%{opacity:1}}\nfooter b{color:#6a5536;font-weight:800;letter-spacing:.22em;text-transform:uppercase}\nfooter .sp{margin-left:auto;font-style:italic;color:#9a8255;max-width:430px;text-align:right;line-height:1.4}\n</style></head><body>\n<div class=\"synth\">\n <div class=\"surface\">\n  <div class=\"head\">\n    <div class=\"brand\">\n      <span class=\"mk\">Vibe Instruments</span>\n      <h1>Analog <em>Poly</em></h1>\n      <span class=\"tag\">8-Voice · Two-Oscillator · 4-Pole</span>\n    </div>\n    <div class=\"voices\">\n      <span class=\"vlbl\">Voices</span>\n      <div class=\"bank\" id=\"bank\"></div>\n    </div>\n  </div>\n\n  <div class=\"body\">\n   <div class=\"sect\">\n    <div class=\"row\">\n\n      <!-- OSCILLATOR / DETUNE -->\n      <div class=\"module\">\n        <div class=\"mt\">Oscillators</div>\n        <div class=\"knobs\" id=\"oscK\"></div>\n      </div>\n\n      <!-- FILTER -->\n      <div class=\"module\">\n        <div class=\"mt\">Resonant Filter</div>\n        <div class=\"knobs\" id=\"filtK\"></div>\n      </div>\n\n    </div>\n\n    <!-- ENVELOPE -->\n    <div class=\"module\">\n      <div class=\"mt\">Amplitude Envelope</div>\n      <div class=\"envwrap\">\n        <div class=\"graph\">\n          <svg viewBox=\"0 0 300 96\" preserveAspectRatio=\"none\">\n            <defs>\n              <linearGradient id=\"eg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n                <stop offset=\"0\" stop-color=\"#ff7ad1\"/><stop offset=\"1\" stop-color=\"#b08cff\"/>\n              </linearGradient>\n              <linearGradient id=\"ef\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#ff7ad1\" stop-opacity=\".55\"/>\n                <stop offset=\"1\" stop-color=\"#b08cff\" stop-opacity=\"0\"/>\n              </linearGradient>\n            </defs>\n            <g class=\"grid\">\n              <line x1=\"0\" y1=\"24\" x2=\"300\" y2=\"24\"/><line x1=\"0\" y1=\"48\" x2=\"300\" y2=\"48\"/><line x1=\"0\" y1=\"72\" x2=\"300\" y2=\"72\"/>\n            </g>\n            <path class=\"envfill\" id=\"envfill\" d=\"\"/>\n            <path class=\"envline\" id=\"envline\" d=\"\"/>\n            <line class=\"sweep\" id=\"sweep\" x1=\"0\" y1=\"6\" x2=\"0\" y2=\"90\"/>\n            <circle class=\"dot\" id=\"dA\" r=\"2.6\"/><circle class=\"dot\" id=\"dD\" r=\"2.6\"/><circle class=\"dot\" id=\"dS\" r=\"2.6\"/>\n          </svg>\n        </div>\n        <div class=\"knobs\" id=\"envK\"></div>\n      </div>\n    </div>\n   </div>\n  </div>\n\n  <footer>\n    <span class=\"dotL\"></span><b>Analog Poly</b>\n    <span class=\"sp\" id=\"sp\"></span>\n  </footer>\n </div>\n</div>\n\n<script>\n(function(){\n  // ---- exact param contract (re-read from spec) ----\n  var P=[\n    {name:\"Detune\",      index:0,min:0,max:1,def:0.3 },\n    {name:\"Cutoff\",      index:1,min:0,max:1,def:0.55},\n    {name:\"Resonance\",   index:2,min:0,max:1,def:0.35},\n    {name:\"FilterEnvAmt\",index:3,min:0,max:1,def:0.6 },\n    {name:\"Attack\",      index:4,min:0,max:1,def:0.02},\n    {name:\"Decay\",       index:5,min:0,max:1,def:0.35},\n    {name:\"Sustain\",     index:6,min:0,max:1,def:0.7 },\n    {name:\"Release\",     index:7,min:0,max:1,def:0.3 }\n  ];\n  var byName={}; P.forEach(function(p){byName[p.name]=p;});\n  var SP=document.getElementById('sp');\n  SP.textContent=\"A warm polyphonic analog synth — two detuned oscillators per voice into a resonant 4-pole low-pass.\";\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmtPct(v){ return Math.round(v*100)+\"%\"; }\n  function fmtMs(v){ // map 0..1 to a friendly time-ish readout\n    var ms = Math.round((v*v)*4000)+1;\n    return ms>=1000 ? (ms/1000).toFixed(2)+\"s\" : ms+\"ms\";\n  }\n  function labelFor(p,v){\n    if(p.name===\"Attack\"||p.name===\"Decay\"||p.name===\"Release\") return fmtMs(v);\n    if(p.name===\"Cutoff\"){ var hz=Math.round(40*Math.pow(360,v)); return hz>=1000?(hz/1000).toFixed(1)+\"k\":hz+\"Hz\"; }\n    return fmtPct(v);\n  }\n\n  // store live normalized values for the env graph\n  var live={}; P.forEach(function(p){ live[p.name]=(p.def-p.min)/(p.max-p.min); });\n\n  function makeKnob(host,p){\n    var cell=document.createElement('div'); cell.className='cell';\n    cell.style.setProperty('--d',(p.index*55)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\"><i class=\"scale\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i></div>'+\n      '<div class=\"cnm\">'+p.name.replace(\"FilterEnvAmt\",\"Env Amt\")+'</div>'+\n      '<div class=\"cval\"></div>';\n    host.appendChild(cell);\n    var knob=cell.querySelector('.knob'), arc=cell.querySelector('.arc'), val=cell.querySelector('.cval');\n    var v=p.def;\n    function norm(){ return (v-p.min)/(p.max-p.min||1); }\n    function paint(){\n      var n=norm(); knob.style.setProperty('--p',n);\n      val.textContent=labelFor(p,n);\n      live[p.name]=n;\n      send(p.index,v);\n      if(p.name===\"Attack\"||p.name===\"Decay\"||p.name===\"Sustain\"||p.name===\"Release\") drawEnv();\n    }\n    function setN(n){ n=n<0?0:n>1?1:n; v=p.min+(p.max-p.min)*n; paint(); }\n    knob.addEventListener('pointerdown',function(e){\n      knob._d=1; knob._y=e.clientY; knob._n=norm(); knob.classList.add('act');\n      knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!knob._d)return;\n      var spd = e.shiftKey ? 620 : 200;\n      setN(knob._n+(knob._y-e.clientY)/spd);\n    });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n    paint();\n  }\n\n  makeKnob(document.getElementById('oscK'),  byName[\"Detune\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"Cutoff\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"Resonance\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"FilterEnvAmt\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Attack\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Decay\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Sustain\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Release\"]);\n\n  // ---- live ADSR envelope graph ----\n  var W=300,H=96, fillEl=document.getElementById('envfill'), lineEl=document.getElementById('envline');\n  var dA=document.getElementById('dA'),dD=document.getElementById('dD'),dS=document.getElementById('dS');\n  function drawEnv(){\n    var a=live[\"Attack\"], d=live[\"Decay\"], s=live[\"Sustain\"], r=live[\"Release\"];\n    var x0=4, top=8, bot=H-8;\n    var aw=8+a*90, dw=8+d*80, sw=46, rw=8+r*80;\n    var total=aw+dw+sw+rw, scale=(W-x0*2)/total;\n    aw*=scale; dw*=scale; sw*=scale; rw*=scale;\n    var xa=x0+aw, xd=xa+dw, xs=xd+sw, xr=xs+rw;\n    var yA=top, yS=bot-(bot-top)*s, yB=bot;\n    var line=\"M \"+x0+\" \"+yB+\" L \"+xa.toFixed(1)+\" \"+yA.toFixed(1)+\n             \" L \"+xd.toFixed(1)+\" \"+yS.toFixed(1)+\n             \" L \"+xs.toFixed(1)+\" \"+yS.toFixed(1)+\n             \" L \"+xr.toFixed(1)+\" \"+yB+\" \";\n    lineEl.setAttribute('d',line);\n    fillEl.setAttribute('d',line+\" L \"+x0+\" \"+yB+\" Z\");\n    dA.setAttribute('cx',xa);dA.setAttribute('cy',yA);\n    dD.setAttribute('cx',xd);dD.setAttribute('cy',yS);\n    dS.setAttribute('cx',xs);dS.setAttribute('cy',yS);\n  }\n  drawEnv();\n\n  // ---- voice LED bank: 8 voices light per active note ----\n  var BANK=document.getElementById('bank'), voices=[];\n  for(var i=0;i<8;i++){\n    var vv=document.createElement('div'); vv.className='voice';\n    vv.innerHTML='<span class=\"num\">'+(i+1)+'</span>';\n    BANK.appendChild(vv); voices.push(vv);\n  }\n  // round-robin voice allocation driven by host noteOn/noteOff if available,\n  // otherwise a gentle idle shimmer so the bank always feels alive.\n  var held=[], nextV=0, voiceOfNote={};\n  function lightOn(note){\n    if(voiceOfNote[note]!=null) return;\n    var v=nextV; nextV=(nextV+1)%8;\n    voiceOfNote[note]=v; voices[v].classList.add('on');\n  }\n  function lightOff(note){\n    var v=voiceOfNote[note];\n    if(v!=null){ voices[v].classList.remove('on'); delete voiceOfNote[note]; }\n  }\n  // expose hooks; host bench posts note events we can mirror\n  window.addEventListener('message',function(e){\n    var d=e.data||{};\n    if(d.t==='on') lightOn(d.id);\n    else if(d.t==='off') lightOff(d.id);\n  });\n\n  // idle shimmer (only when nothing is actively held) via rAF, no busy loop\n  var t0=performance.now(), idleV=-1, idleT=0;\n  function idle(now){\n    requestAnimationFrame(idle);\n    if(Object.keys(voiceOfNote).length) return; // real notes take over\n    if(now-idleT>520){\n      idleT=now;\n      if(idleV>=0) voices[idleV].classList.remove('on');\n      idleV=(idleV+1)%8;\n      voices[idleV].classList.add('on');\n    }\n  }\n  requestAnimationFrame(idle);\n\n  function ready(){ /* params already initialised on construction */ }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  ANALOG POLY — a polyphonic analog-style synthesizer instrument.\n//  Eight independent voices, each: two detuned oscillators (a saw + a\n//  pulse) summed, fed through a resonant 4-pole (24 dB/oct) low-pass\n//  driven by its own ADSR contour (Cutoff + envelope amount), then an\n//  amplitude ADSR. Voices are allocated per noteId so chords ring with\n//  independent envelopes. Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_DETUNE:  i32 = 0;  // 0..1  -> oscillator spread\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount\nconst P_ATTACK:  i32 = 4;  // 0..1  -> seconds\nconst P_DECAY:   i32 = 5;  // 0..1  -> seconds\nconst P_SUSTAIN: i32 = 6;  // 0..1  -> level\nconst P_RELEASE: i32 = 7;  // 0..1  -> seconds\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:     StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhase1:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw phase\nconst vPhase2:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse phase\n\n// amplitude envelope\nconst vAEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 sus 4 rel\n// filter envelope\nconst vFEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhase1[v] = 0.0; vPhase2[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_DETUNE]  = 0.3;\n  params[P_CUTOFF]  = 0.55;\n  params[P_RESO]    = 0.35;\n  params[P_ENVAMT]  = 0.6;\n  params[P_ATTACK]  = 0.02;\n  params[P_DECAY]   = 0.35;\n  params[P_SUSTAIN] = 0.7;\n  params[P_RELEASE] = 0.3;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // prefer a free voice, else steal the oldest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  // fresh phases offset so detune beats start coherently but not phase-locked\n  vPhase1[slot] = 0.0;\n  vPhase2[slot] = 0.25;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const detune: f32  = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n\n  const atkS: f32 = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.5;\n  const decS: f32 = 0.005 + clampf(params[P_DECAY], 0.0, 1.0)   * 1.5;\n  const susL: f32 = clampf(params[P_SUSTAIN], 0.0, 1.0);\n  const relS: f32 = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 2.0;\n\n  // per-sample envelope coefficients (linear-ish rates)\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune in semitone fraction: up to ~ +/-0.18 semitone -> richer beating\n  const detSemi: f32 = detune * 0.18;\n  const ratioUp: f32   = f32(Mathf.pow(2.0, detSemi / 12.0));\n  const ratioDown: f32 = f32(Mathf.pow(2.0, -detSemi / 12.0));\n\n  // base cutoff in Hz, exponential 60 Hz .. ~16 kHz\n  const baseHz: f32 = 60.0 * f32(Mathf.pow(256.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6 octaves\n  const envOct: f32 = envAmt * 6.0;\n  // resonance feedback 0..~4 (self-oscillation near top)\n  const reso: f32 = resoN * 4.0;\n\n  // headroom: 8 voices summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.5;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude ADSR ---------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // decay\n        aenv -= decRate * (1.0 - susL);\n        if (aenv <= susL) { aenv = susL; astg = 3; }\n      } else if (astg == 3) {     // sustain\n        aenv = susL;\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      // voice finished?\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter ADSR ------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * (1.0 - susL);\n        if (fenv <= susL) { fenv = susL; fstg = 3; }\n      } else if (fstg == 3) {\n        fenv = susL;\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- oscillators (2 detuned: saw + pulse) -----------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const inc1: f32 = baseInc * ratioDown;   // saw, tuned down\n      const inc2: f32 = baseInc * ratioUp;     // pulse, tuned up\n\n      let p1: f32 = vPhase1[v];\n      p1 += inc1; if (p1 >= 1.0) p1 -= 1.0;\n      // band-limited saw\n      let saw: f32 = 2.0 * p1 - 1.0;\n      saw -= polyBlep(p1, inc1);\n      vPhase1[v] = p1;\n\n      let p2: f32 = vPhase2[v];\n      p2 += inc2; if (p2 >= 1.0) p2 -= 1.0;\n      // band-limited pulse (50% duty) via two saws\n      const pw: f32 = 0.5;\n      let sq: f32 = p2 < pw ? 1.0 : -1.0;\n      sq += polyBlep(p2, inc2);\n      let p2b: f32 = p2 + (1.0 - pw);\n      if (p2b >= 1.0) p2b -= 1.0;\n      sq -= polyBlep(p2b, inc2);\n      vPhase2[v] = p2;\n\n      // mix oscillators (saw a touch louder for body)\n      let osc: f32 = saw * 0.62 + sq * 0.45;\n\n      // ---- resonant 4-pole low-pass -----------------------------\n      // cutoff from base + filter envelope (octaves), per-voice\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      // one-pole coefficient\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      // resonance feedback from last stage; tanh keeps it stable\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      let voice: f32 = s3 * aenv * vVel[v];\n      outL += voice;\n    }\n\n    // ---- sum + soft saturate for analog glue --------------------\n    let mix: f32 = outL * voiceScale;\n    mix = f32(Mathf.tanh(mix * 1.2));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000018000
}