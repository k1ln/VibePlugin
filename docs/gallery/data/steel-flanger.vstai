{
  "format": 1,
  "name": "Steel Flanger",
  "isInstrument": false,
  "explanation": "An extreme, metallic jet-engine flanger. A swept short delay with strong regeneration drives the comb filter into clangy, almost-pitched stainless resonance. A triangle LFO sweeps a fractional delay around a Manual base position over a very wide range, while bipolar Feedback intensifies the metallic ring (positive) or hollows it out (negative through-zero hiss). A soft saturator inside the feedback path keeps the resonance bounded but aggressive. Controls: Rate, Depth, Manual, Feedback and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.22
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.85
    },
    {
      "name": "Manual",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.78
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Steel Flanger</title>\n<style>\n  :root{\n    --steel:#b8c4d0;\n    --cyan:#5ad0ff;\n    --bg0:#10141a;\n    --bg1:#1b2230;\n    --line:rgba(184,196,208,.18);\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:radial-gradient(120% 120% at 50% -10%,#222c3a 0%,var(--bg0) 60%);\n    color:var(--steel);\n    display:flex;align-items:center;justify-content:center;\n    overflow:hidden;\n  }\n\n  /* ---------- faceplate ---------- */\n  .pedal{\n    position:relative;\n    width:560px;height:430px;\n    border-radius:18px;\n    padding:22px 26px 26px;\n    background:\n      repeating-linear-gradient(96deg,\n        rgba(255,255,255,.045) 0px,\n        rgba(255,255,255,.045) 1px,\n        rgba(0,0,0,.05) 2px,\n        rgba(0,0,0,.05) 3px),\n      linear-gradient(160deg,#39434f 0%,#222a34 45%,#2c3742 70%,#1a2027 100%);\n    box-shadow:\n      0 30px 60px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(255,255,255,.18),\n      inset 0 -2px 8px rgba(0,0,0,.6);\n    border:1px solid rgba(255,255,255,.06);\n    overflow:hidden;\n  }\n  /* brushed-metal sheen sweeping across */\n  .pedal::after{\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(115deg,transparent 35%,rgba(255,255,255,.10) 48%,rgba(90,208,255,.10) 52%,transparent 65%);\n    background-size:280% 100%;\n    animation:sheen 7s linear infinite;\n    mix-blend-mode:screen;\n  }\n  @keyframes sheen{0%{background-position:160% 0}100%{background-position:-160% 0}}\n\n  /* corner bolts */\n  .bolt{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#e8eef4,#7d8896 55%,#3a434e);\n    box-shadow:inset 0 1px 1px rgba(255,255,255,.8),0 1px 2px rgba(0,0,0,.7);}\n  .bolt::after{content:\"\";position:absolute;inset:3px;border-top:1.5px solid rgba(0,0,0,.35);transform:rotate(35deg)}\n  .bolt.tl{top:10px;left:10px}.bolt.tr{top:10px;right:10px}\n  .bolt.bl{bottom:10px;left:10px}.bolt.br{bottom:10px;right:10px}\n\n  header{display:flex;align-items:baseline;justify-content:space-between;margin:4px 6px 12px}\n  .title{font-weight:800;font-size:26px;letter-spacing:3px;\n    background:linear-gradient(180deg,#fff,#9fb0bf 60%,#6d7d8c);\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 1px 0 rgba(0,0,0,.4)}\n  .sub{font-size:10px;letter-spacing:4px;color:rgba(184,196,208,.55);text-transform:uppercase}\n\n  /* ---------- comb / jet display ---------- */\n  .scope{\n    position:relative;height:118px;border-radius:10px;margin:0 6px 18px;\n    background:linear-gradient(180deg,#0a0e14,#11161f);\n    border:1px solid var(--line);\n    box-shadow:inset 0 2px 14px rgba(0,0,0,.8),inset 0 0 0 1px rgba(90,208,255,.05);\n    overflow:hidden;\n  }\n  .scope svg{position:absolute;inset:0;width:100%;height:100%}\n\n  /* ---------- knob row ---------- */\n  .row{display:flex;justify-content:space-between;padding:0 4px;gap:6px}\n  .knobwrap{display:flex;flex-direction:column;align-items:center;width:96px}\n  .knob{\n    position:relative;width:74px;height:74px;border-radius:50%;cursor:grab;\n    background:\n      radial-gradient(circle at 50% 38%,#f2f6fa 0%,#cdd6df 18%,#8e9aa6 46%,#5a6571 70%,#39424c 100%);\n    box-shadow:\n      0 6px 14px rgba(0,0,0,.55),\n      inset 0 2px 3px rgba(255,255,255,.7),\n      inset 0 -4px 8px rgba(0,0,0,.55);\n    touch-action:none;\n  }\n  .knob:active{cursor:grabbing}\n  /* fine concentric machining */\n  .knob::before{content:\"\";position:absolute;inset:9px;border-radius:50%;\n    background:\n      repeating-conic-gradient(from 0deg,rgba(255,255,255,.10) 0deg 2deg,rgba(0,0,0,.10) 2deg 4deg),\n      radial-gradient(circle at 50% 40%,#cdd6df,#5a6571);\n    box-shadow:inset 0 1px 2px rgba(255,255,255,.5),inset 0 -2px 4px rgba(0,0,0,.5)}\n  /* pointer */\n  .knob .ptr{position:absolute;left:50%;top:7px;width:3px;height:24px;\n    margin-left:-1.5px;border-radius:2px;\n    background:linear-gradient(180deg,var(--cyan),#cfe9ff);\n    box-shadow:0 0 6px var(--cyan),0 0 2px #fff;\n    transform-origin:50% 30px}\n  /* glowing arc */\n  .knob .ring{position:absolute;inset:-7px;border-radius:50%;pointer-events:none}\n  .knob .ring svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}\n\n  .plabel{margin-top:9px;font-size:10px;letter-spacing:2.5px;text-transform:uppercase;color:rgba(184,196,208,.75)}\n  .pval{margin-top:2px;font-size:12px;font-weight:700;color:var(--cyan);\n    font-variant-numeric:tabular-nums;text-shadow:0 0 8px rgba(90,208,255,.5)}\n\n  /* status LED */\n  .led{position:absolute;top:16px;right:34px;width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#bff0ff,var(--cyan) 50%,#1d4f63);\n    box-shadow:0 0 10px var(--cyan),0 0 22px rgba(90,208,255,.6);\n    animation:pulse 1.6s ease-in-out infinite}\n  @keyframes pulse{0%,100%{opacity:.55}50%{opacity:1}}\n</style>\n</head>\n<body>\n  <div class=\"pedal\">\n    <span class=\"bolt tl\"></span><span class=\"bolt tr\"></span>\n    <span class=\"bolt bl\"></span><span class=\"bolt br\"></span>\n    <span class=\"led\"></span>\n\n    <header>\n      <div class=\"title\">STEEL&nbsp;FLANGER</div>\n      <div class=\"sub\">metallic&nbsp;jet&nbsp;sweep</div>\n    </header>\n\n    <div class=\"scope\">\n      <svg id=\"scope\" viewBox=\"0 0 520 118\" preserveAspectRatio=\"none\"></svg>\n    </div>\n\n    <div class=\"row\" id=\"row\"></div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  /* ---- params (must match assembly indices) ---- */\n  var PARAMS=[\n    {name:\"Rate\",    index:0,min:0,max:1,def:0.22},\n    {name:\"Depth\",   index:1,min:0,max:1,def:0.85},\n    {name:\"Manual\",  index:2,min:0,max:1,def:0.25},\n    {name:\"Feedback\",index:3,min:0,max:1,def:0.78},\n    {name:\"Mix\",     index:4,min:0,max:1,def:0.55}\n  ];\n  var state={};\n\n  function send(i,v){\n    try{ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }catch(e){}\n  }\n  function fmt(p,v){\n    if(p.name===\"Rate\")     return (0.02*Math.pow(500,v)).toFixed(2)+\" Hz\";\n    if(p.name===\"Manual\")   return (0.1+v*13.9).toFixed(1)+\" ms\";\n    if(p.name===\"Feedback\") return Math.round((v*1.94-0.97)*100)+\"%\";\n    return Math.round(v*100)+\"%\";\n  }\n\n  /* ---- build knobs ---- */\n  var row=document.getElementById(\"row\");\n  PARAMS.forEach(function(p){\n    state[p.index]=p.def;\n    var wrap=document.createElement(\"div\");wrap.className=\"knobwrap\";\n    var knob=document.createElement(\"div\");knob.className=\"knob\";\n    var ring=document.createElement(\"div\");ring.className=\"ring\";\n    ring.innerHTML='<svg viewBox=\"0 0 100 100\"><circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"rgba(184,196,208,.15)\" stroke-width=\"3\"/><path class=\"arc\" fill=\"none\" stroke=\"url(#g'+p.index+')\" stroke-width=\"3.5\" stroke-linecap=\"round\"/><defs><linearGradient id=\"g'+p.index+'\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#b8c4d0\"/><stop offset=\"1\" stop-color=\"#5ad0ff\"/></linearGradient></defs></svg>';\n    var ptr=document.createElement(\"div\");ptr.className=\"ptr\";\n    knob.appendChild(ring);knob.appendChild(ptr);\n    var label=document.createElement(\"div\");label.className=\"plabel\";label.textContent=p.name;\n    var val=document.createElement(\"div\");val.className=\"pval\";\n    wrap.appendChild(knob);wrap.appendChild(label);wrap.appendChild(val);\n    row.appendChild(wrap);\n\n    p._knob=knob;p._ptr=ptr;p._val=val;p._arc=ring.querySelector(\".arc\");\n\n    function render(){\n      var v=state[p.index];\n      var ang=-135+v*270;                 // -135..135 deg\n      ptr.style.transform=\"rotate(\"+ang+\"deg)\";\n      val.textContent=fmt(p,v);\n      // arc\n      var a0=-135*Math.PI/180, a1=ang*Math.PI/180, r=44, cx=50,cy=50;\n      var x0=cx+r*Math.cos(a0-Math.PI/2), y0=cy+r*Math.sin(a0-Math.PI/2);\n      var x1=cx+r*Math.cos(a1-Math.PI/2), y1=cy+r*Math.sin(a1-Math.PI/2);\n      var large=(ang-(-135))>180?1:0;\n      p._arc.setAttribute(\"d\",\"M \"+x0.toFixed(2)+\" \"+y0.toFixed(2)+\" A \"+r+\" \"+r+\" 0 \"+large+\" 1 \"+x1.toFixed(2)+\" \"+y1.toFixed(2));\n    }\n    p._render=render;render();\n\n    /* drag */\n    var dragging=false,startY=0,startV=0;\n    function down(e){\n      dragging=true;startY=(e.touches?e.touches[0].clientY:e.clientY);startV=state[p.index];\n      e.preventDefault();\n    }\n    function move(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/200;\n      var v=Math.max(0,Math.min(1,startV+dv));\n      state[p.index]=v;render();send(p.index,v);\n      e.preventDefault();\n    }\n    function up(){dragging=false;}\n    knob.addEventListener(\"mousedown\",down);\n    knob.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"mouseup\",up);\n    window.addEventListener(\"touchend\",up);\n    knob.addEventListener(\"dblclick\",function(){state[p.index]=p.def;render();send(p.index,p.def);});\n  });\n\n  /* ---- init all params to default ---- */\n  function init(){\n    PARAMS.forEach(function(p){ state[p.index]=p.def; p._render(); send(p.index,p.def); });\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(init); else init();\n\n  /* ---- animated jet/comb scope ---- */\n  var svg=document.getElementById(\"scope\"),NS=\"http://www.w3.org/2000/svg\";\n  var W=520,H=118,N=24,bars=[];\n  for(var i=0;i<N;i++){\n    var r=document.createElementNS(NS,\"rect\");\n    r.setAttribute(\"x\",(i*(W/N)+1).toFixed(1));\n    r.setAttribute(\"width\",(W/N-2).toFixed(1));\n    r.setAttribute(\"rx\",\"1.5\");\n    svg.appendChild(r);bars.push(r);\n  }\n  // horizontal scan line\n  var scan=document.createElementNS(NS,\"line\");\n  scan.setAttribute(\"y1\",\"0\");scan.setAttribute(\"y2\",H);\n  scan.setAttribute(\"stroke\",\"rgba(90,208,255,.35)\");scan.setAttribute(\"stroke-width\",\"2\");\n  svg.appendChild(scan);\n\n  var t=0;\n  function frame(){\n    t+=0.016;\n    var rateN=state[0], depthN=state[1], manualN=state[2], fbN=state[3], mixN=state[4];\n    var rateHz=0.02*Math.pow(500,rateN);\n    var lfo=Math.sin(t*rateHz*2*Math.PI);            // -1..1\n    var center=manualN*(N-1) + lfo*depthN*(N*0.5);   // moving comb center\n    var fbAmt=Math.abs(fbN*1.94-0.97);               // resonance intensity\n    for(var i=0;i<N;i++){\n      // metallic comb: ripples spaced by manual, sharpened by feedback\n      var d=Math.abs(i-center);\n      var comb=Math.cos(d*(0.6+fbAmt*1.8))*Math.exp(-d*(0.12-fbAmt*0.06));\n      var amp=(0.5+0.5*comb)*(0.4+mixN*0.6);\n      amp=Math.max(0.04,Math.min(1,amp));\n      var h=amp*H;\n      bars[i].setAttribute(\"y\",((H-h)/2).toFixed(1));\n      bars[i].setAttribute(\"height\",h.toFixed(1));\n      // silver -> cyan glint, brighter near the comb peak\n      var glint=Math.max(0,comb);\n      var rr=Math.round(184-glint*120), gg=Math.round(196-glint*0), bb=Math.round(208+glint*47);\n      bars[i].setAttribute(\"fill\",\"rgb(\"+rr+\",\"+gg+\",\"+Math.min(255,bb)+\")\");\n      bars[i].setAttribute(\"opacity\",(0.45+amp*0.55).toFixed(2));\n    }\n    var sx=((lfo*0.5+0.5)*W);\n    scan.setAttribute(\"x1\",sx.toFixed(1));scan.setAttribute(\"x2\",sx.toFixed(1));\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STEEL FLANGER — extreme, metallic, jet-engine flanger (effect)\n//  A swept short delay with STRONG regeneration. Where a gentle flanger\n//  whispers, this one screams: a very wide manual/sweep range lets the\n//  comb dive into clangy, almost-pitched metallic resonance. A triangle\n//  LFO modulates a fractional (linear-interpolated) delay around a Manual\n//  base position. Bipolar Feedback feeds the delayed signal back through\n//  the line — positive gives a bright stainless ring, negative a hollow\n//  through-zero hiss. A soft tanh-ish saturator inside the feedback path\n//  keeps the resonance bounded while preserving the aggressive character.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: wide range. Up to ~20 ms @ 96k -> 1920 samples. 4096 is ample.\nconst DLY_LEN: i32 = 4096;\nconst dline:  StaticArray<f32> = new StaticArray<f32>(DLY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // 0..1\nconst fbState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // last fed-back delayed out\nconst dampState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // one-pole tone in regen\n\nconst P_RATE:     i32 = 0;  // 0..1 -> 0.02..10 Hz (exp)\nconst P_DEPTH:    i32 = 1;  // 0..1 sweep depth\nconst P_MANUAL:   i32 = 2;  // 0..1 -> base delay 0.1..14 ms (wide!)\nconst P_FEEDBACK: i32 = 3;  // 0..1 -> -0.97..0.97 regen (bipolar, metallic)\nconst P_MIX:      i32 = 4;  // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0;\n    lfoPhase[c] = c == 1 ? 0.3 : 0.0;   // stereo offset for width\n    fbState[c] = 0.0;\n    dampState[c] = 0.0;\n  }\n  for (let i = 0; i < DLY_LEN * MAX_CHANNELS; i++) dline[i] = 0.0;\n  params[P_RATE] = 0.22; params[P_DEPTH] = 0.85; params[P_MANUAL] = 0.25;\n  params[P_FEEDBACK] = 0.78; params[P_MIX] = 0.55;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// soft saturator — bounds the regen so high feedback stays metallic, not blown\n@inline function sat(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return c - (c * c * c) * f32(0.111111); // ~tanh-ish cubic, |out| < ~1.0 near edges\n}\n\nexport function process(n: i32): void {\n  const rateN: f32     = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32    = clampf(params[P_DEPTH], 0.0, 1.0);\n  const manualN: f32   = clampf(params[P_MANUAL], 0.0, 1.0);\n  const feedbackN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const mix: f32       = clampf(params[P_MIX], 0.0, 1.0);\n\n  // LFO rate: exponential 0.02..10 Hz\n  const rateHz: f32 = f32(0.02 * Mathf.pow(500.0, rateN));\n  const phInc: f32  = rateHz / sampleRate;\n\n  // VERY wide delay range for the extreme metallic A/DA-style sweep.\n  const minMs: f32  = 0.1;\n  const baseMs: f32 = minMs + manualN * 13.9;           // 0.1..14.0 ms base\n  const sweepMs: f32 = depthN * 9.0;                    // up to +9 ms of sweep\n  const baseSamp: f32  = baseMs  * sampleRate * 0.001;\n  const sweepSamp: f32 = sweepMs * sampleRate * 0.001;\n\n  // Bipolar feedback -0.97..0.97 — strong regeneration => clangy resonance\n  const fb: f32 = clampf(feedbackN * 1.94 - 0.97, -0.97, 0.97);\n\n  // light damping in the regen path so the very top doesn't run away\n  const damp: f32 = 0.35;\n\n  for (let c = 0; c < channels; c++) {\n    const cbase: i32 = c * DLY_LEN;\n    let wp: i32 = writePos[c];\n    let ph: f32 = lfoPhase[c];\n    let fbs: f32 = fbState[c];\n    let dmp: f32 = dampState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // Triangle LFO 0..1 — symmetric sweep edges suit the jet character\n      const tri: f32 = ph < 0.5 ? (ph * 2.0) : (2.0 - ph * 2.0);\n      let dSamp: f32 = baseSamp + tri * sweepSamp;\n      const maxD: f32 = f32(DLY_LEN - 2);\n      dSamp = clampf(dSamp, 1.0, maxD);\n\n      // fractional read position behind the write pointer\n      let rp: f32 = f32(wp) - dSamp;\n      while (rp < 0.0) rp += f32(DLY_LEN);\n      const i0: i32 = i32(rp);\n      const frac: f32 = rp - f32(i0);\n      let i1: i32 = i0 + 1;\n      if (i1 >= DLY_LEN) i1 -= DLY_LEN;\n      const s0: f32 = dline[cbase + i0];\n      const s1: f32 = dline[cbase + i1];\n      const delayed: f32 = s0 + (s1 - s0) * frac;\n\n      // damp the fed-back signal a touch (one-pole LP) and saturate it\n      dmp = dmp + damp * (delayed - dmp);\n      const fbSig: f32 = sat(x + dmp * fb);\n\n      // write input + saturated feedback into the line\n      dline[cbase + wp] = fbSig;\n\n      // flanger sum: equal dry+wet keeps comb peaks bounded\n      const wet: f32 = x * 0.6 + delayed * 0.7;\n      outBuf[c * MAX_FRAMES + f] = clampf(x * (1.0 - mix) + wet * mix, -1.0, 1.0);\n\n      fbs = delayed;\n\n      wp++;\n      if (wp >= DLY_LEN) wp = 0;\n      ph += phInc;\n      if (ph >= 1.0) ph -= 1.0;\n    }\n\n    writePos[c] = wp;\n    lfoPhase[c] = ph;\n    fbState[c] = fbs;\n    dampState[c] = dmp;\n  }\n}\n",
  "publishedAt": 1751000120000
}