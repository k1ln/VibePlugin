{
  "format": 1,
  "name": "Acid Bass",
  "isInstrument": true,
  "explanation": "A monophonic squelch-bass synth: one saw<->square morphing oscillator feeding a 4-pole resonant low-pass with a fast-decaying filter envelope for the classic acid sweep. Accent boosts the filter envelope and level on hard hits, Glide slides pitch between notes (last-note priority), and high Resonance pushes toward self-oscillation while staying bounded.",
  "params": [
    {
      "name": "Waveform",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.78
    },
    {
      "name": "Env Mod",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Accent",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Glide",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Acid Bass</title>\n<style>\n  :root{\n    --acc:#c6ff3d;\n    --acc2:#9ae66e;\n    --acc-dim:#5a7a1f;\n    --metal0:#0f1113;\n    --metal1:#23282b;\n    --metal2:#3a4044;\n    --metal3:#565d62;\n    --ink:#0a0c0d;\n    --face:#c9d0d4;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}\n  html,body{height:100%}\n  body{\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a2f33 0%, #14181a 45%, #090b0c 100%);\n    color:#dfe6e9;\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    letter-spacing:.02em;\n  }\n\n  /* ====== THE BOX ====== */\n  .box{\n    position:relative;\n    width:760px;height:430px;\n    border-radius:18px;\n    padding:18px 22px 20px;\n    /* brushed silver chassis */\n    background:\n      linear-gradient(180deg,#e9eef1 0%,#aeb6bb 6%,#7c858a 7%,#9aa3a8 8%,#6f777c 50%,#565d62 92%,#42484c 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.6) inset,\n      0 -2px 6px rgba(0,0,0,.5) inset,\n      0 30px 60px rgba(0,0,0,.65),\n      0 2px 0 #20262a;\n    overflow:hidden;\n  }\n  /* brushed-metal micro grain */\n  .box::before{\n    content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.05) 0 1px,rgba(0,0,0,.04) 1px 2px);\n    mix-blend-mode:overlay;opacity:.5;\n  }\n  /* moving sheen */\n  .box::after{\n    content:\"\";position:absolute;top:0;left:-40%;width:35%;height:100%;\n    background:linear-gradient(105deg,transparent,rgba(255,255,255,.28),transparent);\n    transform:skewX(-18deg);pointer-events:none;\n    animation:sheen 7s ease-in-out infinite;\n  }\n  @keyframes sheen{0%,72%{left:-45%}90%{left:130%}100%{left:130%}}\n\n  /* corner screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#f2f5f6,#888f93 55%,#4a5054 100%);\n    box-shadow:0 1px 1px rgba(0,0,0,.5),0 0 0 1px rgba(0,0,0,.25) inset;}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#2b3033 44% 56%,transparent 56%);transform:rotate(28deg)}\n  .screw.tl{top:9px;left:9px}.screw.tr{top:9px;right:9px}\n  .screw.bl{bottom:9px;left:9px}.screw.br{bottom:9px;right:9px}\n\n  /* ====== HEADER / READOUT ====== */\n  .head{display:flex;align-items:flex-end;justify-content:space-between;margin:2px 6px 12px}\n  .brand{display:flex;flex-direction:column;line-height:1}\n  .brand .sub{font-size:9px;letter-spacing:.42em;color:#3a4145;font-weight:700;margin-bottom:5px;text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(255,255,255,.5)}\n  .brand .name{font-size:30px;font-weight:800;font-style:italic;letter-spacing:-.01em;\n    color:#1b2023;text-shadow:0 1px 0 rgba(255,255,255,.55),0 -1px 1px rgba(0,0,0,.3)}\n  .brand .name b{color:var(--acc-dim);\n    text-shadow:0 0 8px rgba(198,255,61,.55),0 1px 0 rgba(255,255,255,.4)}\n\n  /* LCD-ish resonance/cutoff scope */\n  .readout{\n    position:relative;width:236px;height:74px;border-radius:8px;\n    background:linear-gradient(180deg,#04150a,#020c06);\n    border:2px solid #1d2326;\n    box-shadow:0 2px 4px rgba(0,0,0,.6) inset,0 1px 0 rgba(255,255,255,.35);\n    overflow:hidden;\n  }\n  .readout canvas{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .ro-grid{position:absolute;inset:0;pointer-events:none;\n    background:\n      repeating-linear-gradient(0deg,rgba(154,230,110,.07) 0 1px,transparent 1px 11px),\n      repeating-linear-gradient(90deg,rgba(154,230,110,.07) 0 1px,transparent 1px 13px);}\n  .ro-glass{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(120% 70% at 50% 0%,rgba(180,255,160,.14),transparent 60%)}\n  .ro-tags{position:absolute;inset:0;pointer-events:none;font-size:8px;color:var(--acc2);\n    text-shadow:0 0 5px rgba(154,230,110,.8);font-weight:700;letter-spacing:.1em}\n  .ro-tags .t1{position:absolute;top:5px;left:8px}\n  .ro-tags .t2{position:absolute;bottom:5px;left:8px}\n  .ro-tags .t3{position:absolute;top:5px;right:8px;color:var(--acc)}\n\n  /* ====== STEP STRIP ====== */\n  .strip{\n    display:grid;grid-template-columns:repeat(16,1fr);gap:5px;\n    padding:11px 12px;margin:0 4px 16px;border-radius:10px;\n    background:linear-gradient(180deg,#14181a,#080a0b);\n    box-shadow:0 2px 5px rgba(0,0,0,.6) inset,0 1px 0 rgba(255,255,255,.3);\n  }\n  .step{position:relative;height:30px;border-radius:5px;cursor:pointer;\n    background:radial-gradient(circle at 50% 35%,#1c2123,#0c0f10);\n    box-shadow:0 1px 0 rgba(255,255,255,.07) inset,0 -2px 3px rgba(0,0,0,.5) inset;\n    transition:transform .08s}\n  .step .led{position:absolute;inset:6px;border-radius:3px;background:#0d2410;\n    box-shadow:0 0 0 1px rgba(0,0,0,.4) inset;transition:background .12s,box-shadow .12s}\n  .step.on .led{background:var(--acc-dim);box-shadow:0 0 0 1px rgba(0,0,0,.4) inset}\n  .step.acc .led{background:linear-gradient(180deg,#fff,var(--acc))}\n  /* the chaser highlights whichever step is current */\n  .step.cur .led{background:var(--acc);\n    box-shadow:0 0 9px 2px var(--acc),0 0 18px var(--acc2),0 0 0 1px rgba(0,0,0,.3) inset}\n  .step.cur.acc .led{background:#fff;box-shadow:0 0 12px 3px var(--acc),0 0 22px #fff}\n  .step:active{transform:translateY(1px)}\n  .step .n{position:absolute;bottom:-13px;left:0;right:0;text-align:center;font-size:7px;color:#5d6469}\n\n  /* ====== KNOB ROW ====== */\n  .rack{display:grid;grid-template-columns:repeat(8,1fr);gap:6px;padding:0 2px}\n  .cell{display:flex;flex-direction:column;align-items:center;gap:5px}\n  .label{font-size:8.5px;letter-spacing:.13em;text-transform:uppercase;color:#2a3033;font-weight:800;\n    text-shadow:0 1px 0 rgba(255,255,255,.45)}\n  .knob{position:relative;width:60px;height:60px;cursor:ns-resize;touch-action:none}\n  .knob svg{display:block;width:60px;height:60px;overflow:visible}\n  .knob .cap{filter:drop-shadow(0 3px 4px rgba(0,0,0,.55))}\n  .knob:hover .ringGlow{opacity:1}\n  .ringGlow{transition:opacity .2s;opacity:.35}\n  .vbox{font-size:10px;font-weight:700;color:#10130f;\n    background:linear-gradient(180deg,#d8ff8c,#b6ef4d);\n    border:1px solid #4d5b1f;border-radius:4px;padding:1px 6px;min-width:42px;text-align:center;\n    box-shadow:0 1px 0 rgba(255,255,255,.5) inset,0 1px 2px rgba(0,0,0,.4);\n    text-shadow:0 1px 0 rgba(255,255,255,.3)}\n\n  .knob.dragging .ringGlow{opacity:1}\n  .knob.dragging~.vbox,.dragging .vbox{}\n\n  .credit{position:absolute;bottom:6px;right:54px;font-size:7px;letter-spacing:.3em;\n    color:#2c3236;font-weight:700;text-shadow:0 1px 0 rgba(255,255,255,.4)}\n</style>\n</head>\n<body>\n  <div class=\"box\" id=\"box\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <span class=\"sub\">303 · monosquelch</span>\n        <span class=\"name\">Acid<b>Bass</b></span>\n      </div>\n      <div class=\"readout\">\n        <canvas id=\"scope\" width=\"472\" height=\"148\"></canvas>\n        <div class=\"ro-grid\"></div>\n        <div class=\"ro-glass\"></div>\n        <div class=\"ro-tags\">\n          <span class=\"t1\" id=\"roCut\">CUT 035</span>\n          <span class=\"t2\" id=\"roReso\">RES 078</span>\n          <span class=\"t3\">SELF-OSC</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"strip\" id=\"strip\"></div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n    <div class=\"credit\">VIBE · BOUTIQUE</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- params straight from spec.json ----\n  var PARAMS = [\n    {name:\"Waveform\",  index:0, min:0, max:1, def:0.15, fmt:\"morph\"},\n    {name:\"Cutoff\",    index:1, min:0, max:1, def:0.35, fmt:\"pct\"},\n    {name:\"Resonance\", index:2, min:0, max:1, def:0.78, fmt:\"pct\"},\n    {name:\"Env Mod\",   index:3, min:0, max:1, def:0.70, fmt:\"pct\"},\n    {name:\"Decay\",     index:4, min:0, max:1, def:0.40, fmt:\"ms\"},\n    {name:\"Accent\",    index:5, min:0, max:1, def:0.50, fmt:\"pct\"},\n    {name:\"Glide\",     index:6, min:0, max:1, def:0.25, fmt:\"ms\"},\n    {name:\"Level\",     index:7, min:0, max:1, def:0.80, fmt:\"pct\"}\n  ];\n  var ACC=\"#c6ff3d\", ACC2=\"#9ae66e\";\n\n  function clamp(v,a,b){return v<a?a:v>b?b:v;}\n  function fmtVal(p,v){\n    var n=(v-p.min)/(p.max-p.min);\n    if(p.fmt===\"pct\") return Math.round(n*100)+\"%\";\n    if(p.fmt===\"ms\")  return Math.round(2+n*n*900)+\"ms\";\n    if(p.fmt===\"morph\") return n<0.04?\"SAW\":n>0.96?\"SQR\":Math.round(n*100)+\"%\";\n    return n.toFixed(2);\n  }\n\n  // live state shared with scope + readout\n  var STATE={};\n  PARAMS.forEach(function(p){STATE[p.index]=p.def;});\n\n  var host = window.vstai || null;\n  function send(i,v){ if(host&&host.setParam) host.setParam(i,v); }\n\n  // ============== KNOBS (custom SVG) ==============\n  var rack=document.getElementById(\"rack\");\n  var SW=270; // sweep degrees\n  function buildKnob(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var lab=document.createElement(\"div\"); lab.className=\"label\"; lab.textContent=p.name;\n    var knob=document.createElement(\"div\"); knob.className=\"knob\"; knob.setAttribute(\"title\",\"drag · double-click resets\");\n    var vbox=document.createElement(\"div\"); vbox.className=\"vbox\";\n\n    var ns=\"http://www.w3.org/2000/svg\";\n    var svg=document.createElementNS(ns,\"svg\"); svg.setAttribute(\"viewBox\",\"0 0 60 60\");\n    // arc geometry helper\n    var cx=30,cy=31,r=23;\n    function pt(deg,rr){var a=(deg-90)*Math.PI/180;return [cx+Math.cos(a)*rr, cy+Math.sin(a)*rr];}\n    function arc(a0,a1,rr){\n      var s=pt(a0,rr),e=pt(a1,rr),large=(a1-a0)>180?1:0;\n      return \"M\"+s[0]+\" \"+s[1]+\" A\"+rr+\" \"+rr+\" 0 \"+large+\" 1 \"+e[0]+\" \"+e[1];\n    }\n    var start=-(SW/2), end=(SW/2);\n\n    // glow ring behind\n    var glow=document.createElementNS(ns,\"path\"); glow.setAttribute(\"class\",\"ringGlow\");\n    glow.setAttribute(\"d\",arc(start,end,r+4)); glow.setAttribute(\"fill\",\"none\");\n    glow.setAttribute(\"stroke\",ACC); glow.setAttribute(\"stroke-width\",\"2\");\n    glow.setAttribute(\"stroke-linecap\",\"round\");\n    glow.setAttribute(\"filter\",\"url(#blur)\"); svg.appendChild(glow);\n\n    // track\n    var track=document.createElementNS(ns,\"path\");\n    track.setAttribute(\"d\",arc(start,end,r)); track.setAttribute(\"fill\",\"none\");\n    track.setAttribute(\"stroke\",\"#0c0f10\"); track.setAttribute(\"stroke-width\",\"3.5\");\n    track.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(track);\n\n    // value arc\n    var val=document.createElementNS(ns,\"path\"); val.setAttribute(\"fill\",\"none\");\n    val.setAttribute(\"stroke\",\"url(#grad)\"); val.setAttribute(\"stroke-width\",\"3.5\");\n    val.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(val);\n\n    // metal cap\n    var cap=document.createElementNS(ns,\"circle\"); cap.setAttribute(\"class\",\"cap\");\n    cap.setAttribute(\"cx\",cx); cap.setAttribute(\"cy\",cy); cap.setAttribute(\"r\",\"16\");\n    cap.setAttribute(\"fill\",\"url(#cap)\"); cap.setAttribute(\"stroke\",\"#23282b\"); cap.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(cap);\n    var capRim=document.createElementNS(ns,\"circle\");\n    capRim.setAttribute(\"cx\",cx); capRim.setAttribute(\"cy\",cy); capRim.setAttribute(\"r\",\"16\");\n    capRim.setAttribute(\"fill\",\"none\"); capRim.setAttribute(\"stroke\",\"rgba(255,255,255,.18)\"); capRim.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(capRim);\n\n    // pointer (notch)\n    var notch=document.createElementNS(ns,\"line\");\n    notch.setAttribute(\"stroke\",ACC); notch.setAttribute(\"stroke-width\",\"2.6\");\n    notch.setAttribute(\"stroke-linecap\",\"round\");\n    notch.setAttribute(\"filter\",\"url(#nglow)\"); svg.appendChild(notch);\n\n    // shared defs (once)\n    if(!document.getElementById(\"kdefs\")){\n      var defs=document.createElementNS(ns,\"defs\"); defs.setAttribute(\"id\",\"kdefs\");\n      defs.innerHTML=\n        '<radialGradient id=\"cap\" cx=\"38%\" cy=\"30%\" r=\"80%\">'+\n          '<stop offset=\"0%\" stop-color=\"#5b6469\"/><stop offset=\"45%\" stop-color=\"#3a4044\"/>'+\n          '<stop offset=\"100%\" stop-color=\"#14181a\"/></radialGradient>'+\n        '<linearGradient id=\"grad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n          '<stop offset=\"0%\" stop-color=\"'+ACC2+'\"/><stop offset=\"100%\" stop-color=\"'+ACC+'\"/></linearGradient>'+\n        '<filter id=\"blur\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\"><feGaussianBlur stdDeviation=\"2.4\"/></filter>'+\n        '<filter id=\"nglow\" x=\"-80%\" y=\"-80%\" width=\"260%\" height=\"260%\"><feGaussianBlur stdDeviation=\"1.1\" result=\"b\"/>'+\n          '<feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>';\n      svg.appendChild(defs);\n    }\n\n    knob.appendChild(svg);\n    cell.appendChild(lab); cell.appendChild(knob); cell.appendChild(vbox);\n    rack.appendChild(cell);\n\n    var cur=p.def;\n    function render(){\n      var n=(cur-p.min)/(p.max-p.min);\n      var ang=start+n*(end-start);\n      val.setAttribute(\"d\", arc(start, n<=0.0001?start+0.001:ang, r));\n      glow.setAttribute(\"d\", arc(start, n<=0.0001?start+0.001:ang, r+4));\n      var inner=pt(ang,6), outer=pt(ang,14.5);\n      notch.setAttribute(\"x1\",inner[0]); notch.setAttribute(\"y1\",inner[1]);\n      notch.setAttribute(\"x2\",outer[0]); notch.setAttribute(\"y2\",outer[1]);\n      vbox.textContent=fmtVal(p,cur);\n      STATE[p.index]=cur;\n    }\n    function setVal(v,push){\n      cur=clamp(v,p.min,p.max); render();\n      if(push) send(p.index,cur);\n    }\n    render();\n\n    // ---- drag ----\n    var dragging=false,startY=0,startV=0;\n    function onMove(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=startY-y;\n      var span=p.max-p.min;\n      var fine=e.shiftKey?0.25:1;\n      setVal(startV+ dy/180*span*fine, true);\n      e.preventDefault();\n    }\n    function onUp(){ if(!dragging)return; dragging=false; knob.classList.remove(\"dragging\");\n      window.removeEventListener(\"pointermove\",onMove);\n      window.removeEventListener(\"pointerup\",onUp);\n    }\n    knob.addEventListener(\"pointerdown\",function(e){\n      dragging=true; knob.classList.add(\"dragging\");\n      startY=e.clientY; startV=cur;\n      window.addEventListener(\"pointermove\",onMove);\n      window.addEventListener(\"pointerup\",onUp);\n      e.preventDefault();\n    });\n    knob.addEventListener(\"dblclick\",function(e){ setVal(p.def,true); e.preventDefault(); });\n    // wheel for fine tweaking\n    knob.addEventListener(\"wheel\",function(e){\n      setVal(cur - Math.sign(e.deltaY)*(p.max-p.min)*0.02, true); e.preventDefault();\n    },{passive:false});\n\n    return {set:setVal,get:function(){return cur;}};\n  }\n  var knobs=PARAMS.map(buildKnob);\n\n  // ============== STEP STRIP (the chaser) ==============\n  var strip=document.getElementById(\"strip\");\n  var STEPS=16, steps=[];\n  // a default acid pattern (purely decorative chaser; accents on the 1,5,9,11)\n  var pattern=[1,0,1,1, 1,0,0,1, 1,1,0,1, 0,1,1,0];\n  var accents=[1,0,0,0, 1,0,0,0, 1,0,1,0, 0,0,0,0];\n  for(var i=0;i<STEPS;i++){\n    var s=document.createElement(\"div\"); s.className=\"step\";\n    if(pattern[i]) s.classList.add(\"on\");\n    if(accents[i]) s.classList.add(\"acc\");\n    var led=document.createElement(\"div\"); led.className=\"led\"; s.appendChild(led);\n    if(i%4===0){var n=document.createElement(\"div\"); n.className=\"n\"; n.textContent=(i/4+1); s.appendChild(n);}\n    (function(idx,el){\n      el.addEventListener(\"click\",function(){\n        // toggle the step's accent state for tactile feedback\n        if(el.classList.contains(\"on\")){\n          if(el.classList.contains(\"acc\")) el.classList.remove(\"acc\",\"on\");\n          else el.classList.add(\"acc\");\n        } else { el.classList.add(\"on\"); }\n        pattern[idx]=el.classList.contains(\"on\")?1:0;\n        accents[idx]=el.classList.contains(\"acc\")?1:0;\n      });\n    })(i,s);\n    strip.appendChild(s); steps.push(s);\n  }\n\n  // ============== ANIMATION LOOP ==============\n  var scope=document.getElementById(\"scope\");\n  var sctx=scope.getContext(\"2d\");\n  var W=scope.width,H=scope.height;\n  var roCut=document.getElementById(\"roCut\"), roReso=document.getElementById(\"roReso\");\n\n  var cur=0, lastStep=-1, phase=0, t0=performance.now();\n  function applyCur(idx){\n    steps.forEach(function(s,i){ s.classList.toggle(\"cur\", i===idx && (pattern[i]===1)); });\n  }\n\n  function pad3(v){return (\"00\"+Math.round(v*100)).slice(-3);}\n\n  function loop(now){\n    var dt=(now-t0)/1000; t0=now;\n    // tempo: glide & decay nudge the chase speed for character\n    var decay=STATE[4], glide=STATE[6];\n    var bps = 2.0 + (1-decay)*2.6;       // faster with shorter decay\n    phase += dt*bps;\n    if(phase>=1){ phase-=1; cur=(cur+1)%STEPS;\n      // skip to next active-ish step occasionally for a \"chase\" feel\n    }\n    if(cur!==lastStep){ applyCur(cur); lastStep=cur; }\n\n    // ---- scope: resonant low-pass squelch waveform ----\n    var cut=STATE[1], reso=STATE[2], envm=STATE[3], wave=STATE[0], lvl=STATE[7], acc=STATE[5];\n    roCut.textContent=\"CUT \"+pad3(cut);\n    roReso.textContent=\"RES \"+pad3(reso);\n\n    sctx.clearRect(0,0,W,H);\n    // glow under-curve\n    var freq = 2 + cut*9;                 // visible cycles\n    var q = 1 + reso*9;                    // resonant ringing depth\n    var env = Math.exp(-((phase)) * (1.5+ (1-STATE[4])*6)); // filter-env sweep per step\n    var amp = (0.30 + lvl*0.55) * (1 + acc*0.35* (accents[cur]?1:0));\n\n    sctx.lineWidth=2;\n    var grad=sctx.createLinearGradient(0,0,W,0);\n    grad.addColorStop(0,ACC2); grad.addColorStop(1,ACC);\n    sctx.strokeStyle=grad;\n    sctx.shadowColor=ACC; sctx.shadowBlur=8;\n    sctx.beginPath();\n    for(var x=0;x<=W;x+=2){\n      var u=x/W;\n      // base osc: saw<->square morph\n      var saw = 2*((u*freq)%1)-1;\n      var sq  = ((u*freq)%1)<0.5?1:-1;\n      var osc = saw*(1-wave)+sq*wave;\n      // resonant ring riding on the cutoff sweep, modulated by env\n      var ring = Math.sin(u*freq*Math.PI*2*(1+ q*0.18)) * Math.exp(-((u*freq)%1)*q*0.7) * (0.4+envm*0.6) * env;\n      var y = (osc*0.5 + ring) * amp;\n      var py = H/2 - y*(H*0.42);\n      if(x===0) sctx.moveTo(x,py); else sctx.lineTo(x,py);\n    }\n    sctx.stroke();\n    sctx.shadowBlur=0;\n\n    // scan line that tracks the step\n    var sx = (cur+phase)/STEPS * W;\n    sctx.fillStyle=\"rgba(198,255,61,.10)\";\n    sctx.fillRect(sx-1,0,3,H);\n\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n\n  // ============== HOST WIRING ==============\n  function ready(){\n    // push every param at its default so host + UI agree\n    knobs.forEach(function(k,i){ send(PARAMS[i].index, k.get()); });\n  }\n  if(host && host.onReady) host.onReady(ready); else ready();\n\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  ACID BASS — monophonic resonant squelch-bass synth (303-style voice)\n//  A single morphing saw<->square oscillator drives a 4-pole resonant\n//  low-pass with a fast-decaying filter envelope (the \"squelch\"). Accent\n//  boosts the filter envelope and level on hard hits; Glide slides pitch\n//  between notes (last-note priority). Pure algorithm, no samples.\n//\n//  Signal path per note:\n//    osc (saw<->square morph) -> drive/shaper -> 4-pole resonant LPF\n//    cutoff = base + envMod * filterEnv(+accent) -> amp env -> level\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32  = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_WAVE:  i32 = 0; // 0 = saw, 1 = square (morph)\nconst P_CUTOFF: i32 = 1; // base cutoff 0..1\nconst P_RESO:  i32 = 2; // resonance 0..1\nconst P_ENVMOD: i32 = 3; // filter envelope amount 0..1\nconst P_DECAY: i32 = 4; // filter+amp decay 0..1\nconst P_ACCENT: i32 = 5; // accent amount 0..1\nconst P_GLIDE: i32 = 6; // glide / portamento time 0..1\nconst P_LEVEL: i32 = 7; // output level 0..1\n\n// ---- voice state ----\nlet phase: f32 = 0.0;       // oscillator phase 0..1\nlet targetFreq: f32 = 0.0;  // freq requested by the note\nlet curFreq: f32 = 0.0;     // current (glided) freq\nlet gate: i32 = 0;          // 1 while a note is held\nlet note: i32 = -1;         // currently sounding note id\nlet accentAmt: f32 = 0.0;   // 0..1 accent strength for the current note (from velocity)\n\n// envelopes\nlet fenv: f32 = 0.0;        // filter envelope (decays from 1 -> 0)\nlet aenv: f32 = 0.0;        // amplitude envelope (AD-ish with sustain)\n\n// 4-pole (Moog-style) ladder filter state\nlet f0: f32 = 0.0;\nlet f1: f32 = 0.0;\nlet f2: f32 = 0.0;\nlet f3: f32 = 0.0;\n\n// gentle DC blocker on the output\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  phase = 0.0;\n  targetFreq = 0.0;\n  curFreq = 0.0;\n  gate = 0;\n  note = -1;\n  accentAmt = 0.0;\n  fenv = 0.0;\n  aenv = 0.0;\n  f0 = 0.0; f1 = 0.0; f2 = 0.0; f3 = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_WAVE]   = 0.15;\n  params[P_CUTOFF] = 0.35;\n  params[P_RESO]   = 0.78;\n  params[P_ENVMOD] = 0.7;\n  params[P_DECAY]  = 0.4;\n  params[P_ACCENT] = 0.5;\n  params[P_GLIDE]  = 0.25;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// soft saturator to tame self-oscillating resonance and add analog grit\n@inline function satf(x: f32): f32 {\n  // fast tanh-ish: bounded, smooth, cheap\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// Host passes frequency in Hz. Last-note priority; new notes (re-)trigger the\n// envelopes. Velocity sets the per-note accent strength.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const newFreq: f32 = f > 0.0 ? f : 0.0001;\n  // If nothing was sounding, jump straight to pitch so the first note doesn't\n  // glide up from silence in an unexpected way... but a tiny seed gives glide\n  // something audible to ride for very first note too.\n  if (gate == 0 && curFreq <= 0.0) {\n    curFreq = newFreq * 0.5; // start an octave down so the first note glides\n  }\n  targetFreq = newFreq;\n  note = id;\n  gate = 1;\n  // velocity -> accent strength for this note\n  accentAmt = clampf(v, 0.0, 1.0);\n  // (re)trigger envelopes\n  fenv = 1.0;\n  aenv = 1.0;\n}\n\nexport function noteOff(id: i32): void {\n  if (id == note) gate = 0;\n}\n\nexport function process(n: i32): void {\n  const wave:   f32 = clampf(params[P_WAVE],   0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN:  f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envModN: f32 = clampf(params[P_ENVMOD], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const accentN: f32 = clampf(params[P_ACCENT], 0.0, 1.0);\n  const glideN: f32 = clampf(params[P_GLIDE],  0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Filter-envelope decay: ~30 ms (snappy) up to ~1.2 s (long sweep).\n  const fdecaySec: f32 = 0.03 + decayN * decayN * 1.2;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n\n  // Amp envelope: a touch longer than the filter so notes ring out musically.\n  const adecaySec: f32 = 0.06 + decayN * decayN * 1.6;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n\n  // Glide time: 0 (instant) .. ~120 ms per-sample one-pole toward target.\n  // Build a one-pole coefficient; glideN==0 means snap.\n  const glideSec: f32 = glideN * 0.12;\n  const glideCoef: f32 = glideSec > 0.0\n    ? f32(Mathf.exp(-1.0 / (glideSec * sampleRate)))\n    : 0.0;\n\n  // Accent: boosts filter-env amount and a bit of level on hard hits.\n  // accentN scales how strong the accent system is; accentAmt is per-note vel.\n  const accent: f32 = accentN * accentAmt;            // 0..1 effective accent\n  const envModEff: f32 = envModN * (1.0 + 1.3 * accent); // accent opens filter more\n  const ampBoost: f32 = 1.0 + 0.6 * accent;            // accent is louder\n\n  // Resonance 0..~3.9 (approaches self-oscillation but stays bounded by satf).\n  const reso: f32 = resoN * 3.9;\n\n  // Base cutoff in Hz (exponential, musical): ~80 Hz .. ~9 kHz.\n  const baseCut: f32 = f32(80.0 * Mathf.exp(cutoffN * 4.72)); // 80 * e^4.72 ~ 9000\n\n  // Envelope sweep span in Hz added on top of base.\n  const sweepSpan: f32 = envModEff * 8500.0;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  // Drive into the filter (square is hotter; keep saw clean-ish).\n  const oscDrive: f32 = 1.0 + wave * 0.6;\n\n  for (let i = 0; i < n; i++) {\n    // ---- glide pitch toward target ----\n    if (glideCoef > 0.0) {\n      curFreq = targetFreq + (curFreq - targetFreq) * glideCoef;\n    } else {\n      curFreq = targetFreq;\n    }\n\n    // ---- oscillator: phase ramp -> saw, derive square, morph ----\n    let inc: f32 = curFreq / sampleRate;\n    if (inc < 0.0) inc = 0.0;\n    if (inc > 0.5) inc = 0.5;\n    phase += inc;\n    if (phase >= 1.0) phase -= 1.0;\n\n    const saw: f32 = phase * 2.0 - 1.0;\n    const sq:  f32 = phase < 0.5 ? 1.0 : -1.0;\n    // morph saw -> square\n    let osc: f32 = saw + (sq - saw) * wave;\n    osc *= oscDrive;\n\n    // ---- envelopes (decay toward 0; amp holds a small sustain while gated) ----\n    fenv *= fenvCoef;\n    if (gate != 0) {\n      // amp sustains at a floor while held, then releases on noteOff\n      const sustain: f32 = 0.0;\n      aenv = sustain + (aenv - sustain) * aenvCoef;\n      // keep amp from collapsing fully while held: gentle floor\n      if (aenv < 0.25) aenv = 0.25;\n    } else {\n      aenv *= aenvCoef;\n    }\n\n    // ---- compute cutoff for this sample ----\n    let cutHz: f32 = baseCut + sweepSpan * fenv;\n    // accent adds a brief extra \"click\" of brightness at note start via fenv^2\n    cutHz += sweepSpan * 0.5 * accent * (fenv * fenv);\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- 4-pole resonant ladder (normalized cutoff) ----\n    // g = tan-ish frequency warp approximated; use simple one-pole cascade.\n    let fc: f32 = cutHz / nyq; // 0..0.49\n    if (fc > 0.49) fc = 0.49;\n    // tuning coefficient for the cascade\n    const g: f32 = fc * (1.8 - 0.8 * fc); // empirical tuning curve\n\n    // resonance feedback (clamped); satf on feedback keeps it bounded\n    const fb: f32 = reso * (1.0 - 0.15 * g);\n    let input: f32 = osc - fb * satf(f3);\n\n    // four cascaded one-pole low-passes\n    f0 += g * (input - f0);\n    f1 += g * (f0 - f1);\n    f2 += g * (f1 - f2);\n    f3 += g * (f2 - f3);\n\n    let filtered: f32 = f3;\n    // saturate the output of the ladder for analog warmth + safety\n    filtered = satf(filtered * 1.4);\n\n    // ---- amp + accent + level ----\n    let s: f32 = filtered * aenv * ampBoost;\n\n    // DC blocker\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // final level + headroom guard\n    s = satf(s * level * 1.3) * 0.85;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000017000
}