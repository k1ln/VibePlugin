{
  "format": 1,
  "name": "Vocal Plate",
  "isInstrument": false,
  "explanation": "A bright, dense studio plate reverb in the EMT 140 lineage — the classic vocal and snare plate, brighter and longer than an algorithmic Dattorro plate. An input diffusion chain (four series allpasses) feeds a lightly-modulated figure-of-eight tank (two allpasses and two long delays with high-frequency damping) for a lush, shimmering metallic-to-smooth tail. Controls: dry/wet Mix, Decay, Tone (brightness), Pre-Delay and plate Size.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Decay",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Pre-Delay",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.06
    },
    {
      "name": "Size",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Vocal Plate</title>\n<style>\n  :root{ --acc:#cdd5e2; --acc2:#ffd24a; --bg0:#08090c; --bg1:#13161c; --ink:#eef2ف7; --ink:#eef2f7; --dim:#7c8696; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#1e232c 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#222731,#0a0c10); border:1px solid rgba(205,213,226,.18);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px;\n    background:linear-gradient(90deg,#fff,var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:104px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#1a1e25,#0e1116); border:1px solid rgba(205,213,226,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.24em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(205,213,226,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(205,213,226,.5)); }\n  .pcap{ fill:#12161c; stroke:rgba(205,213,226,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc2)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(205,213,226,.08); padding:1px 8px; border-radius:7px; border:1px solid rgba(205,213,226,.18); }\n  .knob:hover .kn{ color:#fff; }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">VOCAL&nbsp;PLATE</span><span class=\"sub\">studio plate reverb</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">PLATE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Mix\",idx:0,def:0.35},{name:\"Decay\",idx:1,def:0.7},{name:\"Tone\",idx:2,def:0.7},{name:\"Pre\",idx:3,def:0.06},{name:\"Size\",idx:4,def:0.6}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffffff\"/><stop offset=\"1\" stop-color=\"#ffd24a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle>'+\n      '<line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2));\n      val.textContent=(p.name===\"Pre\")?Math.round(v*120)+\" ms\":Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  // vibrating metal plate: concentric shimmer ripples, density ~ Size, brightness ~ Tone\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H); var dec=vals[1], tone=vals[2], size=vals[4];\n    var cx=W*0.5, cy=H*0.55;\n    var rings=8+Math.round(size*10);\n    for(var k=0;k<rings;k++){ var rr=(k/rings); var rad=rr*W*0.6 + 10*Math.sin(ts/600+k);\n      var a=(1-rr)*(0.15+dec*0.35);\n      ctx.beginPath(); ctx.ellipse(cx,cy,rad,rad*0.42,0,0,Math.PI*2);\n      ctx.strokeStyle=\"rgba(\"+Math.round(205+tone*50)+\",\"+Math.round(213+tone*40)+\",226,\"+a+\")\"; ctx.lineWidth=1; ctx.stroke(); }\n    // shimmer highlights\n    ctx.globalAlpha=0.4+tone*0.4;\n    for(var s=0;s<5;s++){ var px=cx + Math.cos(ts/500+s*1.3)*W*0.3; var py=cy+Math.sin(ts/700+s)*H*0.18;\n      ctx.fillStyle=\"rgba(255,210,74,0.5)\"; ctx.beginPath(); ctx.arc(px,py,1.5,0,Math.PI*2); ctx.fill(); }\n    ctx.globalAlpha=1;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VOCAL PLATE — a bright, dense studio PLATE reverb (EMT 140 lineage).\n//  The classic vocal/snare plate: brighter, denser and longer than the\n//  Dattorro-style Steel Plate already in the factory. Input diffusion (4\n//  series allpasses) feeds a modulated figure-of-eight tank (2 allpasses +\n//  2 long delays with HF damping) for a lush metallic-to-smooth tail.\n//  Controls: Mix, Decay, Tone (brightness), Pre-Delay, Size.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// predelay\nconst PD_LEN: i32 = 8192; const PD_MASK: i32 = PD_LEN - 1;\nconst pd: StaticArray<f32> = new StaticArray<f32>(PD_LEN);\nlet pdW: i32 = 0;\n\n// input diffusion allpasses (fixed prime-ish lengths)\nconst A0L: i32 = 142; const A1L: i32 = 107; const A2L: i32 = 379; const A3L: i32 = 277;\nconst ap0: StaticArray<f32> = new StaticArray<f32>(A0L);\nconst ap1: StaticArray<f32> = new StaticArray<f32>(A1L);\nconst ap2: StaticArray<f32> = new StaticArray<f32>(A2L);\nconst ap3: StaticArray<f32> = new StaticArray<f32>(A3L);\nlet i0: i32 = 0; let i1: i32 = 0; let i2: i32 = 0; let i3: i32 = 0;\n\n// tank: 2 allpasses + 2 delays (sized for the longest at high Size)\nconst T0L: i32 = 2186; const T1L: i32 = 2620; const TAP0: i32 = 1402; const TAP1: i32 = 1733;\nconst t0: StaticArray<f32> = new StaticArray<f32>(T0L);\nconst t1: StaticArray<f32> = new StaticArray<f32>(T1L);\nconst tap0: StaticArray<f32> = new StaticArray<f32>(TAP0);\nconst tap1: StaticArray<f32> = new StaticArray<f32>(TAP1);\nlet it0: i32 = 0; let it1: i32 = 0; let ita0: i32 = 0; let ita1: i32 = 0;\nlet dampA: f32 = 0.0; let dampB: f32 = 0.0;\nlet modPh: f32 = 0.0;\n\nlet sampleRate: f32 = 48000.0;\n\nconst P_MIX: i32 = 0; const P_DECAY: i32 = 1; const P_TONE: i32 = 2; const P_PRE: i32 = 3; const P_SIZE: i32 = 4;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function allpass(buf: StaticArray<f32>, idx: i32, len: i32, x: f32, g: f32): f32 {\n  const d: f32 = buf[idx];\n  const y: f32 = d - g * x;\n  buf[idx] = x + g * y;\n  return y;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  pdW = 0; i0 = 0; i1 = 0; i2 = 0; i3 = 0; it0 = 0; it1 = 0; ita0 = 0; ita1 = 0; dampA = 0.0; dampB = 0.0; modPh = 0.0;\n  for (let i = 0; i < PD_LEN; i++) pd[i] = 0.0;\n  for (let i = 0; i < A0L; i++) ap0[i] = 0.0;\n  for (let i = 0; i < A1L; i++) ap1[i] = 0.0;\n  for (let i = 0; i < A2L; i++) ap2[i] = 0.0;\n  for (let i = 0; i < A3L; i++) ap3[i] = 0.0;\n  for (let i = 0; i < T0L; i++) t0[i] = 0.0;\n  for (let i = 0; i < T1L; i++) t1[i] = 0.0;\n  for (let i = 0; i < TAP0; i++) tap0[i] = 0.0;\n  for (let i = 0; i < TAP1; i++) tap1[i] = 0.0;\n  params[P_MIX] = 0.3; params[P_DECAY] = 0.7; params[P_TONE] = 0.7; params[P_PRE] = 0.06; params[P_SIZE] = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const preN: f32 = clampf(params[P_PRE], 0.0, 1.0);\n  const sizeN: f32 = clampf(params[P_SIZE], 0.0, 1.0);\n\n  const decay: f32 = 0.5 + decayN * 0.49;       // tank feedback (bounded < 1)\n  const damp: f32 = 0.05 + (1.0 - toneN) * 0.8; // HF damping (low tone -> dark)\n  let pdSamp: i32 = i32(preN * 0.12 * sampleRate); if (pdSamp < 0) pdSamp = 0; if (pdSamp > PD_LEN - 1) pdSamp = PD_LEN - 1;\n  // size scales tank delay read lengths\n  const t0len: i32 = i32(f32(T0L) * (0.55 + 0.45 * sizeN));\n  const t1len: i32 = i32(f32(T1L) * (0.55 + 0.45 * sizeN));\n  const ta0len: i32 = i32(f32(TAP0) * (0.55 + 0.45 * sizeN));\n  const ta1len: i32 = i32(f32(TAP1) * (0.55 + 0.45 * sizeN));\n  const dry: f32 = 1.0 - mix;\n  const wet: f32 = mix;\n  const stereo: i32 = 1;\n\n  for (let f = 0; f < n; f++) {\n    const xl: f32 = inBuf[f];\n    const xr: f32 = stereo ? inBuf[MAX_FRAMES + f] : xl;\n    let x: f32 = (xl + xr) * 0.5;\n\n    // predelay\n    pd[pdW] = x;\n    const prd: f32 = pd[(pdW - pdSamp) & PD_MASK];\n    pdW = (pdW + 1) & PD_MASK;\n\n    // input diffusion\n    let s: f32 = prd;\n    s = allpass(ap0, i0, A0L, s, 0.7); i0 = (i0 + 1) % A0L;\n    s = allpass(ap1, i1, A1L, s, 0.7); i1 = (i1 + 1) % A1L;\n    s = allpass(ap2, i2, A2L, s, 0.625); i2 = (i2 + 1) % A2L;\n    s = allpass(ap3, i3, A3L, s, 0.625); i3 = (i3 + 1) % A3L;\n\n    // tank read (with light modulation for shimmer)\n    modPh += 0.7 / sampleRate * 6.2831853; if (modPh > 6.2831853) modPh -= 6.2831853;\n    const mod: i32 = i32(6.0 * f32(Mathf.sin(modPh)));\n    let ri0: i32 = (ita0 - ta0len + mod) % TAP0; if (ri0 < 0) ri0 += TAP0;\n    let ri1: i32 = (ita1 - ta1len - mod) % TAP1; if (ri1 < 0) ri1 += TAP1;\n    const r0: f32 = tap0[ri0];\n    const r1: f32 = tap1[ri1];\n\n    // figure-8: input + cross-fed delayed, through allpasses + damping\n    let n0: f32 = s + r1 * decay;\n    dampA += (n0 - dampA) * (1.0 - damp); n0 = dampA;\n    n0 = allpass(t0, it0, T0L, n0, 0.5); it0 = (it0 + 1) % T0L;\n    tap0[ita0] = n0; ita0 = (ita0 + 1) % TAP0;\n\n    let n1: f32 = s + r0 * decay;\n    dampB += (n1 - dampB) * (1.0 - damp); n1 = dampB;\n    n1 = allpass(t1, it1, T1L, n1, 0.5); it1 = (it1 + 1) % T1L;\n    tap1[ita1] = n1; ita1 = (ita1 + 1) % TAP1;\n\n    // output taps\n    let wl: f32 = (r0 + n1) * 0.6;\n    let wr: f32 = (r1 + n0) * 0.6;\n\n    let ol: f32 = xl * dry + wl * wet;\n    let orr: f32 = xr * dry + wr * wet;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[f] = ol;\n    outBuf[MAX_FRAMES + f] = orr;\n  }\n}\n",
  "publishedAt": 1751000162000
}