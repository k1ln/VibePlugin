  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pocket Rhythm</title>\n<style>\n  :root{ --acc:#ffb347; --acc2:#ff6a8c; --bg0:#100a06; --bg1:#211609; --ink:#f7ecdc; --dim:#a98e6e; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#33240f 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#352513,#140d07); border:1px solid rgba(255,179,71,.2);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,235,200,.07); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }\n  .logo{ font-weight:800; letter-spacing:.14em; font-size:20px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .bpm{ margin-left:auto; font-size:11px; letter-spacing:.1em; color:var(--acc); font-variant-numeric:tabular-nums; background:#1d1409; padding:3px 9px; border-radius:5px; border:1px solid rgba(255,179,71,.25); }\n  .pads{ display:grid; grid-template-columns:repeat(6,1fr); gap:8px; margin-bottom:16px; }\n  .pad{ position:relative; border-radius:50%; aspect-ratio:1/1; display:flex; align-items:flex-end; justify-content:center; padding-bottom:6px;\n    background:radial-gradient(circle at 50% 35%,#2c1e10,#170f07); border:1px solid rgba(255,179,71,.22); overflow:hidden; }\n  .pad .glow{ position:absolute; inset:0; border-radius:50%; background:radial-gradient(circle at 50% 40%,var(--acc),transparent 65%); opacity:0; }\n  .pad .pn{ position:relative; z-index:2; font-size:8px; letter-spacing:.04em; text-transform:uppercase; color:var(--dim); }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,210,160,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,179,71,.6)); }\n  .pcap{ fill:#170f07; stroke:rgba(255,179,71,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,179,71,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,179,71,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">POCKET&nbsp;RHYTHM</span><span class=\"sub\">latin rhythm box</span><span class=\"bpm\" id=\"bpm\">BOSSA</span></header>\n    <div class=\"pads\" id=\"pads\"></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var VOICES=[\"Bongo\",\"Conga\",\"Claves\",\"Maracas\",\"Cowbell\",\"Cymbal\"];\n  var P=[{name:\"Pitch\",idx:0,def:0.5},{name:\"Decay\",idx:1,def:0.5},{name:\"Shaker\",idx:2,def:0.5},{name:\"Cowbell\",idx:3,def:0.5},{name:\"Tone\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.85}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var padWrap=document.getElementById(\"pads\");\n  var glows=VOICES.map(function(nm){ var el=document.createElement(\"div\"); el.className=\"pad\"; el.innerHTML='<div class=\"glow\"></div><div class=\"pn\">'+nm+'</div>'; padWrap.appendChild(el); return el.querySelector(\".glow\"); });\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffb347\"/><stop offset=\"1\" stop-color=\"#ff6a8c\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle>'+\n      '<circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle>'+\n      '<line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2)); ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  // bossa-ish pattern lighting the percussion pads\n  var PAT=[0,3,2,3, 1,3,0,3, 4,3,2,3, 1,3,5,3];\n  var step=-1,last=0,acc=0;\n  function frame(ts){ if(!last)last=ts; var dt=ts-last; last=ts; acc+=dt; var ms=60000/108/4;\n    if(acc>=ms){ acc-=ms; step=(step+1)%16; var v=PAT[step]; if(v>=0&&glows[v]) glows[v].style.opacity=\"0.9\"; }\n    for(var i=0;i<6;i++){ var o=parseFloat(glows[i].style.opacity||\"0\"); if(o>0) glows[i].style.opacity=Math.max(0,o-dt/240).toFixed(3); }\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  POCKET RHYTHM — a vintage LATIN preset rhythm box (Korg Mini-Pops\n//  lineage). Distinct from the factory's kick/snare drum machines: an\n//  analog PERCUSSION set — bongo, conga, claves, maracas, cowbell and a\n//  cymbal — all synthesised in real time. A MIDI note picks a voice\n//  (note % 6) into an 8-slot pool. Controls: Pitch (membrane tuning),\n//  Decay, Shaker (maracas/cymbal length), Cowbell (level/tone), Tone, Level.\n//  No samples, no host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NV: i32 = 6;     // 0 bongo,1 conga,2 claves,3 maracas,4 cowbell,5 cymbal\nconst POOL: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst baseHz: StaticArray<f32> = new StaticArray<f32>(NV);\n\nconst pType: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pPh: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pPh2: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pAEnv: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pPEnv: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pAct: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pVel: StaticArray<f32> = new StaticArray<f32>(POOL);\nlet pNext: i32 = 0;\n\nlet sampleRate: f32 = 48000.0;\nlet rngState: i32 = 24680;\nlet hp: f32 = 0.0;\nlet toneZ: f32 = 0.0;\n\nconst P_PITCH: i32 = 0;\nconst P_DECAY: i32 = 1;\nconst P_SHAKER: i32 = 2;\nconst P_COW: i32 = 3;\nconst P_TONE: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  pNext = 0; hp = 0.0; toneZ = 0.0;\n  for (let i = 0; i < POOL; i++) { pAct[i] = 0; pPh[i] = 0.0; pPh2[i] = 0.0; pAEnv[i] = 0.0; pPEnv[i] = 0.0; pType[i] = 0; pVel[i] = 0.0; }\n  baseHz[0] = 280.0; baseHz[1] = 160.0; baseHz[2] = 2400.0; baseHz[3] = 0.0; baseHz[4] = 540.0; baseHz[5] = 0.0;\n  params[P_PITCH] = 0.5; params[P_DECAY] = 0.5; params[P_SHAKER] = 0.5; params[P_COW] = 0.5; params[P_TONE] = 0.6; params[P_LEVEL] = 0.85;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let t: i32 = id % NV; if (t < 0) t += NV;\n  const slot: i32 = pNext; pNext = (pNext + 1) % POOL;\n  pType[slot] = t; pPh[slot] = 0.0; pPh2[slot] = 0.0; pAEnv[slot] = 1.0; pPEnv[slot] = 1.0; pAct[slot] = 1; pVel[slot] = clampf(v, 0.05, 1.0);\n}\nexport function noteOff(id: i32): void { /* one-shots */ }\n\nexport function process(n: i32): void {\n  const pitchN: f32 = clampf(params[P_PITCH], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const shakerN: f32 = clampf(params[P_SHAKER], 0.0, 1.0);\n  const cowN: f32 = clampf(params[P_COW], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const pitchMul: f32 = f32(Mathf.exp((pitchN - 0.5) * 1.0));\n  const memDec: f32 = f32(Mathf.exp(-1.0 / ((0.05 + decayN * 0.4) * sampleRate)));   // bongo/conga\n  const claveDec: f32 = f32(Mathf.exp(-1.0 / (0.04 * sampleRate)));\n  const shakeDec: f32 = f32(Mathf.exp(-1.0 / ((0.03 + shakerN * 0.12) * sampleRate)));\n  const cymDec: f32 = f32(Mathf.exp(-1.0 / ((0.15 + shakerN * 0.5) * sampleRate)));\n  const cowDec: f32 = f32(Mathf.exp(-1.0 / (0.18 * sampleRate)));\n  const pDec: f32 = f32(Mathf.exp(-1.0 / (0.02 * sampleRate)));\n  const lpco: f32 = 0.06 + 0.93 * toneN;\n  const out: f32 = level * 0.55;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < POOL; s++) {\n      if (pAct[s] == 0) continue;\n      const t: i32 = pType[s];\n      let v: f32 = 0.0;\n      pPEnv[s] *= pDec;\n      if (t == 0 || t == 1) {           // bongo / conga membranes\n        const fr: f32 = baseHz[t] * pitchMul * (1.0 + 0.5 * pPEnv[s]);\n        let ph: f32 = pPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; pPh[s] = ph;\n        v = f32(Mathf.sin(ph * 6.2831853)) + (pPEnv[s] > 0.7 ? rnd() * 0.25 : 0.0);\n        pAEnv[s] *= memDec;\n      } else if (t == 2) {              // claves: short bright tone\n        const fr: f32 = baseHz[2] * pitchMul;\n        let ph: f32 = pPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; pPh[s] = ph;\n        v = f32(Mathf.sin(ph * 6.2831853)) * 0.9;\n        pAEnv[s] *= claveDec;\n      } else if (t == 3) {              // maracas: high-passed noise burst\n        const raw: f32 = rnd(); hp += (raw - hp) * 0.7; v = (raw - hp) * (0.7 + shakerN * 0.3);\n        pAEnv[s] *= shakeDec;\n      } else if (t == 4) {              // cowbell: two detuned squares\n        const f1: f32 = 540.0 * pitchMul, f2: f32 = 800.0 * pitchMul;\n        let p1: f32 = pPh[s] + f1 / sampleRate; if (p1 >= 1.0) p1 -= 1.0; pPh[s] = p1;\n        let p2: f32 = pPh2[s] + f2 / sampleRate; if (p2 >= 1.0) p2 -= 1.0; pPh2[s] = p2;\n        const sq: f32 = ((p1 < 0.5 ? 1.0 : -1.0) + (p2 < 0.5 ? 1.0 : -1.0)) * 0.5;\n        v = sq * (0.5 + cowN * 0.6);\n        pAEnv[s] *= cowDec;\n      } else {                          // cymbal: bright noise\n        const raw: f32 = rnd(); hp += (raw - hp) * 0.85; v = (raw - hp) * 0.6;\n        pAEnv[s] *= cymDec;\n      }\n      mix += v * pAEnv[s] * pVel[s];\n      if (pAEnv[s] < 0.0004) pAct[s] = 0;\n    }\n    toneZ += (mix - toneZ) * lpco;\n    let o: f32 = toneZ * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000166000
}