{
  "format": 1,
  "name": "Gush Phaser",
  "isInstrument": false,
  "explanation": "A 4-stage OTA phaser with a gushy, watery, deep sweep. Four cascaded allpass filters are swept by a triangle LFO so the notches glide up and down the spectrum (Rate sets the speed, Depth the span). A Color control feeds part of the chain output back into its input, adding bounded resonant feedback that sharpens the sweep into a vocal, gushing whoosh. Controls: Rate, Depth, Color and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Color",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Gush Phaser</title>\n<style>\n:root{\n  --cy:#5ad0ff; --mg:#ff5ad0;\n  --face1:#0b2c4a; --face2:#06192e;\n  --ink:#dff3ff;\n}\n*{box-sizing:border-box;-webkit-user-select:none;user-select:none}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px/1.3 ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:var(--ink);\n  background:radial-gradient(120% 90% at 50% -10%,#0a3357 0%,#04101e 60%,#020812 100%);\n  display:flex;align-items:center;justify-content:center;min-height:100vh;overflow:hidden;\n}\n/* ===== PEDAL ===== */\n.pedal{\n  position:relative;width:340px;border-radius:26px;padding:22px 22px 26px;\n  background:\n    linear-gradient(160deg,#10416c 0%,#0a2c4c 38%,#072037 100%);\n  box-shadow:\n    0 30px 60px -18px rgba(0,0,0,.75),\n    0 2px 0 rgba(255,255,255,.10) inset,\n    0 -22px 50px -28px rgba(90,208,255,.5) inset;\n  border:1px solid rgba(120,210,255,.18);\n  overflow:hidden;\n}\n/* phthalo gloss sheen */\n.pedal::before{\n  content:\"\";position:absolute;inset:0;border-radius:26px;pointer-events:none;\n  background:\n    radial-gradient(70% 40% at 25% 8%,rgba(255,255,255,.22),transparent 60%),\n    radial-gradient(60% 50% at 90% 100%,rgba(255,90,208,.10),transparent 60%);\n  mix-blend-mode:screen;\n}\n/* corner bolts */\n.bolt{position:absolute;width:11px;height:11px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#cfe9ff,#3a6f94 60%,#173247);\n  box-shadow:0 1px 2px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.3)}\n.bolt.tl{top:10px;left:10px}.bolt.tr{top:10px;right:10px}\n.bolt.bl{bottom:10px;left:10px}.bolt.br{bottom:10px;right:10px}\n\n.brand{display:flex;align-items:baseline;gap:8px;justify-content:center;margin:2px 0 14px}\n.brand b{\n  font-size:22px;letter-spacing:.16em;font-weight:800;\n  background:linear-gradient(90deg,var(--cy),#bfe9ff 45%,var(--mg));\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 0 18px rgba(90,208,255,.25);\n}\n.brand span{font-size:9px;letter-spacing:.34em;color:#7fb6d8;text-transform:uppercase}\n\n/* ===== SPECTRUM / NOTCH WAVES ===== */\n.scope{\n  position:relative;height:96px;border-radius:14px;margin:0 2px 18px;\n  background:linear-gradient(180deg,#031322,#01070f);\n  border:1px solid rgba(90,208,255,.22);\n  box-shadow:0 0 22px rgba(90,208,255,.12) inset,0 2px 6px rgba(0,0,0,.5);\n  overflow:hidden;\n}\n.scope svg{display:block;width:100%;height:100%}\n.grid line{stroke:rgba(120,200,255,.07);stroke-width:1}\n.notch{filter:drop-shadow(0 0 4px rgba(90,208,255,.6))}\n\n/* ===== KNOB ROW ===== */\n.knobs{display:flex;justify-content:space-around;align-items:flex-start;margin:4px 0 6px}\n.kc{display:flex;flex-direction:column;align-items:center;width:88px}\n.knob{\n  position:relative;width:70px;height:70px;border-radius:50%;cursor:ns-resize;touch-action:none;\n  background:\n    radial-gradient(circle at 38% 30%,#1d557f,#0c2c47 55%,#06182a);\n  box-shadow:\n    0 6px 14px rgba(0,0,0,.55),\n    0 1px 0 rgba(255,255,255,.18) inset,\n    0 -8px 16px -8px rgba(90,208,255,.5) inset;\n  border:1px solid rgba(120,210,255,.22);\n  transition:box-shadow .15s, transform .08s;\n}\n.knob:hover{box-shadow:0 6px 18px rgba(0,0,0,.6),0 1px 0 rgba(255,255,255,.22) inset,0 0 24px rgba(90,208,255,.4)}\n.knob:active{transform:translateY(1px)}\n.knob .dial{position:absolute;inset:0;border-radius:50%}\n.knob .ind{\n  position:absolute;left:50%;top:7px;width:3px;height:24px;border-radius:2px;margin-left:-1.5px;\n  background:linear-gradient(180deg,#eaffff,var(--cy));\n  box-shadow:0 0 8px var(--cy);transform-origin:50% 28px;\n}\n.ring{position:absolute;inset:-7px;border-radius:50%;pointer-events:none}\n.kc label{margin-top:9px;font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:#9ed0ec}\n.kc .val{margin-top:2px;font-size:11px;font-variant-numeric:tabular-nums;color:var(--cy);text-shadow:0 0 8px rgba(90,208,255,.4)}\n\n/* big rate knob emphasis */\n.kc.big .knob{width:88px;height:88px}\n.kc.big{width:108px}\n.kc.big .ind{top:8px;height:30px;transform-origin:50% 36px}\n\n/* ===== COLOR SWITCH ===== */\n.colorbox{display:flex;flex-direction:column;align-items:center;gap:6px;margin-top:6px}\n.csw{\n  position:relative;width:104px;height:40px;border-radius:22px;cursor:pointer;touch-action:none;\n  background:linear-gradient(180deg,#0a2138,#04101d);\n  border:1px solid rgba(255,90,208,.35);\n  box-shadow:0 2px 8px rgba(0,0,0,.5) inset;overflow:hidden;\n}\n.csw .fill{position:absolute;left:0;top:0;bottom:0;width:50%;\n  background:linear-gradient(90deg,rgba(90,208,255,.25),rgba(255,90,208,.55));\n  box-shadow:0 0 24px rgba(255,90,208,.6);transition:filter .2s}\n.csw .cap{\n  position:absolute;top:3px;left:3px;width:34px;height:34px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#fff,#ffb8e8 40%,#ff5ad0 75%,#b3267e);\n  box-shadow:0 2px 6px rgba(0,0,0,.5),0 0 18px rgba(255,90,208,.7);\n}\n.csw .lbl{position:absolute;inset:0;display:flex;align-items:center;justify-content:flex-end;\n  padding-right:12px;font-size:9px;letter-spacing:.2em;color:#ffd2f0;text-transform:uppercase;pointer-events:none}\n.colorbox .name{font-size:10px;letter-spacing:.2em;text-transform:uppercase;color:#ffb3e6}\n.colorbox .v{font-size:11px;color:var(--mg);font-variant-numeric:tabular-nums;text-shadow:0 0 8px rgba(255,90,208,.5)}\n\n/* gushy idle pulse on the whole face */\n@keyframes breathe{0%,100%{filter:saturate(1)}50%{filter:saturate(1.12)}}\n.pedal{animation:breathe 6s ease-in-out infinite}\n.hint{text-align:center;font-size:9px;color:#5f93b6;margin-top:14px;letter-spacing:.08em}\n</style></head>\n<body>\n<div class=\"pedal\">\n  <i class=\"bolt tl\"></i><i class=\"bolt tr\"></i><i class=\"bolt bl\"></i><i class=\"bolt br\"></i>\n  <div class=\"brand\"><b>GUSH</b><span>Phaser</span></div>\n\n  <div class=\"scope\">\n    <svg id=\"scope\" viewBox=\"0 0 320 96\" preserveAspectRatio=\"none\">\n      <g class=\"grid\" id=\"grid\"></g>\n      <path id=\"wave2\" class=\"notch\" fill=\"none\" stroke=\"#ff5ad0\" stroke-width=\"2\" opacity=\".55\"/>\n      <path id=\"wave1\" class=\"notch\" fill=\"none\" stroke=\"#5ad0ff\" stroke-width=\"2.2\"/>\n    </svg>\n  </div>\n\n  <div class=\"knobs\">\n    <div class=\"kc big\" id=\"kc-0\">\n      <div class=\"knob\"><div class=\"ring\"></div><div class=\"dial\"><div class=\"ind\"></div></div></div>\n      <label>Rate</label><div class=\"val\">—</div>\n    </div>\n    <div class=\"kc\" id=\"kc-1\">\n      <div class=\"knob\"><div class=\"ring\"></div><div class=\"dial\"><div class=\"ind\"></div></div></div>\n      <label>Depth</label><div class=\"val\">—</div>\n    </div>\n    <div class=\"kc\" id=\"kc-3\">\n      <div class=\"knob\"><div class=\"ring\"></div><div class=\"dial\"><div class=\"ind\"></div></div></div>\n      <label>Mix</label><div class=\"val\">—</div>\n    </div>\n  </div>\n\n  <div class=\"colorbox\">\n    <div class=\"csw\" id=\"csw\"><div class=\"fill\" id=\"cfill\"></div><div class=\"cap\" id=\"ccap\"></div><span class=\"lbl\">Color</span></div>\n    <div class=\"name\">Color · Feedback</div>\n    <div class=\"v\" id=\"cval\">—</div>\n  </div>\n\n  <div class=\"hint\">drag knobs · drag Color switch · double-click to reset</div>\n</div>\n\n<script>\n(function(){\n  // ---- host bridge ----\n  var V = window.vstai || null;\n  function setParam(i,v){ if(V && V.setParam) V.setParam(i, v); }\n\n  var DEF = {0:0.35, 1:0.7, 2:0.5, 3:0.5};\n  var state = {0:DEF[0], 1:DEF[1], 2:DEF[2], 3:DEF[3]};\n\n  // ---- knobs (Rate, Depth, Mix) ----\n  var KNOBS = [0,1,3];\n  function fmt(i){\n    if(i===0){ var hz=(0.03*Math.exp(state[0]*5.7)); return hz<1? hz.toFixed(2)+\" Hz\" : hz.toFixed(1)+\" Hz\"; }\n    return Math.round(state[i]*100)+\"%\";\n  }\n  function drawKnob(i){\n    var el=document.getElementById('kc-'+i);\n    var ind=el.querySelector('.ind');\n    var ang=-135 + state[i]*270;\n    ind.style.transform='rotate('+ang+'deg)';\n    var ring=el.querySelector('.ring');\n    var deg = state[i]*270;\n    var ac = i===3 ? 'var(--mg)' : 'var(--cy)';\n    ring.style.background='conic-gradient(from -135deg, '+ac+' '+deg+'deg, rgba(120,200,255,.10) 0)';\n    ring.style.webkitMaskImage='radial-gradient(circle, transparent 60%, #000 61%)';\n    ring.style.maskImage='radial-gradient(circle, transparent 60%, #000 61%)';\n    el.querySelector('.val').textContent=fmt(i);\n  }\n  KNOBS.forEach(function(i){\n    var el=document.getElementById('kc-'+i);\n    var knob=el.querySelector('.knob');\n    var dragging=false, sy=0, sv=0;\n    knob.addEventListener('pointerdown',function(e){dragging=true;sy=e.clientY;sv=state[i];knob.setPointerCapture(e.pointerId);e.preventDefault();});\n    knob.addEventListener('pointermove',function(e){\n      if(!dragging)return;\n      var dv=(sy-e.clientY)/180;\n      state[i]=Math.max(0,Math.min(1,sv+dv));\n      setParam(i,state[i]); drawKnob(i);\n    });\n    function up(){dragging=false;}\n    knob.addEventListener('pointerup',up);knob.addEventListener('pointercancel',up);\n    knob.addEventListener('dblclick',function(){state[i]=DEF[i];setParam(i,state[i]);drawKnob(i);});\n  });\n\n  // ---- Color switch (param 2) ----\n  var csw=document.getElementById('csw'), cfill=document.getElementById('cfill'),\n      ccap=document.getElementById('ccap'), cval=document.getElementById('cval');\n  function drawColor(){\n    var v=state[2];\n    cfill.style.width=(v*100)+'%';\n    cfill.style.filter='brightness('+(0.8+v*0.9)+')';\n    var x=3 + v*(104-3-34);\n    ccap.style.left=x+'px';\n    ccap.style.boxShadow='0 2px 6px rgba(0,0,0,.5),0 0 '+(8+v*26)+'px rgba(255,90,208,'+(0.4+v*0.5)+')';\n    cval.textContent=Math.round(v*100)+'%';\n  }\n  (function(){\n    var dragging=false;\n    function pos(e){\n      var r=csw.getBoundingClientRect();\n      var v=(e.clientX-r.left-17)/(r.width-34);\n      state[2]=Math.max(0,Math.min(1,v)); setParam(2,state[2]); drawColor();\n    }\n    csw.addEventListener('pointerdown',function(e){dragging=true;csw.setPointerCapture(e.pointerId);pos(e);e.preventDefault();});\n    csw.addEventListener('pointermove',function(e){if(dragging)pos(e);});\n    function up(){dragging=false;}\n    csw.addEventListener('pointerup',up);csw.addEventListener('pointercancel',up);\n    csw.addEventListener('dblclick',function(){state[2]=DEF[2];setParam(2,state[2]);drawColor();});\n  })();\n\n  // ---- spectrum grid ----\n  (function(){\n    var g=document.getElementById('grid'),s='';\n    for(var i=1;i<8;i++){var x=i*40;s+='<line x1=\"'+x+'\" y1=\"0\" x2=\"'+x+'\" y2=\"96\"/>';}\n    for(var j=1;j<4;j++){var y=j*24;s+='<line x1=\"0\" y1=\"'+y+'\" x2=\"320\" y2=\"'+y+'\"/>';}\n    g.innerHTML=s;\n  })();\n\n  // ---- animated notch waves ----\n  var w1=document.getElementById('wave1'), w2=document.getElementById('wave2');\n  var t=0;\n  function frame(){\n    var rate=0.03*Math.exp(state[0]*5.7);\n    t += rate*0.05 + 0.004;\n    var depth=state[1], color=state[2];\n    // notch sweep center 0..1 across spectrum (triangle)\n    var ph=(t%1); var tri=ph<0.5? ph*2 : 2-ph*2;\n    var center=0.12 + tri*(0.18+depth*0.6);\n    var width=0.05 + (1-color)*0.16;        // color sharpens\n    var dip=0.55 + color*0.42;               // color deepens\n    function build(off,amp){\n      var d='', N=80;\n      for(var k=0;k<=N;k++){\n        var fx=k/N;                 // 0..1\n        var x=fx*320;\n        // base wavy spectrum\n        var base=0.5 + 0.12*Math.sin(fx*22 + t*2 + off);\n        // 4 stacked notches (4-stage) around center harmonics\n        var notch=0;\n        for(var s=0;s<4;s++){\n          var c2=center*(1+s*0.6); if(c2>1)c2-=1;\n          var dd=(fx-c2)/width;\n          notch += dip*Math.exp(-dd*dd);\n        }\n        var y=base + Math.sin(fx*40+t*3+off)*0.04*amp - notch*0.34;\n        y=Math.max(0.04,Math.min(0.96,y));\n        d+=(k?'L':'M')+x.toFixed(1)+' '+(y*96).toFixed(1)+' ';\n      }\n      return d;\n    }\n    w1.setAttribute('d',build(0,1));\n    w2.setAttribute('d',build(1.6,0.7));\n    requestAnimationFrame(frame);\n  }\n\n  function boot(){\n    KNOBS.forEach(function(i){ setParam(i,state[i]); drawKnob(i); });\n    setParam(2,state[2]); drawColor();\n    requestAnimationFrame(frame);\n  }\n  if(V && V.onReady) V.onReady(boot); else boot();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  GUSH PHASER — 4-stage OTA phaser (Small Stone lineage)\n//  A chain of four first-order allpass filters whose break frequency is\n//  swept by a triangle LFO (Rate/Depth move the notches up and down the\n//  spectrum). A Color control routes part of the chain output back into\n//  its input as resonant FEEDBACK, sharpening the notches into a vocal,\n//  \"gushing\" whoosh. Bounded feedback (no runaway) and a dry/wet Mix.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst NSTAGES: i32 = 4;\n// Allpass z-1 state per stage per channel: [channel * NSTAGES + stage]\nconst apState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NSTAGES);\n// Feedback memory (one-sample) per channel\nconst fbState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n// LFO phase per channel (slight stereo offset for width)\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_RATE:  i32 = 0;  // 0..1 -> 0.03 .. 9 Hz (log-ish)\nconst P_DEPTH: i32 = 1;  // 0..1 -> sweep span of the notches\nconst P_COLOR: i32 = 2;  // 0..1 -> feedback amount (0 -> intense resonance)\nconst P_MIX:   i32 = 3;  // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    for (let s = 0; s < NSTAGES; s++) apState[c * NSTAGES + s] = 0.0;\n    fbState[c] = 0.0;\n    lfoPhase[c] = c == 0 ? 0.0 : 0.25; // 90deg stereo offset\n  }\n  params[P_RATE] = 0.35; params[P_DEPTH] = 0.7; params[P_COLOR] = 0.5; params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  const rateN:  f32 = clampf(params[P_RATE],  0.0, 1.0);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const colorN: f32 = clampf(params[P_COLOR], 0.0, 1.0);\n  const mix:    f32 = clampf(params[P_MIX],   0.0, 1.0);\n\n  // Rate: exponential map 0.03 .. 9 Hz\n  const rateHz: f32 = f32(0.03 * Mathf.exp(rateN * 5.7)); // 0.03 .. ~9\n  const lfoInc: f32 = rateHz / sampleRate; // phase per sample (0..1 cycle)\n\n  // Sweep range of the allpass break frequency (Hz). Depth widens/deepens.\n  const fLo: f32 = 120.0;\n  const fHi: f32 = 120.0 + depthN * 2400.0; // up to ~2.5 kHz top\n  const fMid: f32 = f32(Mathf.sqrt(fLo * fHi));\n\n  // Feedback gain, bounded < 0.95 to stay stable & avoid runaway\n  const fb: f32 = colorN * 0.92;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const sBase: i32 = c * NSTAGES;\n    let ph: f32 = lfoPhase[c];\n    let z0: f32 = apState[sBase + 0];\n    let z1: f32 = apState[sBase + 1];\n    let z2: f32 = apState[sBase + 2];\n    let z3: f32 = apState[sBase + 3];\n    let fbk: f32 = fbState[c];\n\n    for (let f = 0; f < n; f++) {\n      // triangle LFO 0..1 from phase\n      const tri: f32 = ph < 0.5 ? (ph * 2.0) : (2.0 - ph * 2.0);\n      // log-sweep the break frequency between fLo and fHi\n      const fc: f32 = f32(fLo * Mathf.exp(tri * Mathf.log(fHi / fLo)));\n      // first-order allpass coefficient: a = (1 - tanFc) / (1 + tanFc)\n      const t: f32 = f32(Mathf.tan(PI * fc / sampleRate));\n      const a: f32 = (1.0 - t) / (1.0 + t);\n\n      const x: f32 = inBuf[base + f];\n      // inject bounded feedback from previous chain output\n      let v: f32 = x + fbk * fb;\n\n      // 4 cascaded allpass stages: y = -a*x + z ; z = x + a*y\n      let y0: f32 = -a * v + z0;  z0 = v + a * y0;\n      let y1: f32 = -a * y0 + z1; z1 = y0 + a * y1;\n      let y2: f32 = -a * y1 + z2; z2 = y1 + a * y2;\n      let y3: f32 = -a * y2 + z3; z3 = y2 + a * y3;\n\n      fbk = y3; // store for next-sample feedback\n\n      // Classic phaser = dry + phase-shifted (notches at cancellations)\n      const wet: f32 = (x + y3) * 0.5;\n      const o: f32 = x * (1.0 - mix) + wet * mix;\n      outBuf[base + f] = clampf(o, -1.0, 1.0);\n\n      ph += lfoInc;\n      if (ph >= 1.0) ph -= 1.0;\n    }\n\n    lfoPhase[c] = ph;\n    apState[sBase + 0] = z0;\n    apState[sBase + 1] = z1;\n    apState[sBase + 2] = z2;\n    apState[sBase + 3] = z3;\n    fbState[c] = fbk;\n  }\n}\n",
  "publishedAt": 1751000111000
}