{
  "format": 1,
  "name": "Solo One",
  "isInstrument": true,
  "explanation": "An aggressive monophonic lead/bass synth: two oscillators (saw + detuned pulse) hard-synced for biting grit, feeding a snappy resonant 4-pole low-pass driven by a fast, punchy filter envelope. Cutoff, Resonance and Env Amount sweep and bite the timbre; Decay sets the snap, Detune fattens, Drive adds pre-filter grit, and the voice is mono with last-note priority while pitch tracks the keyboard.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.8
    },
    {
      "name": "Decay",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Drive",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Solo One</title>\n<style>\n  :root {\n    --accent: #ff5a4d;\n    --accent2: #ffb13d;\n    --bg0: #1a0f0c;\n    --bg1: #2a1410;\n    --panel: #221310;\n    --ink: #ffe9df;\n    --ink-dim: #c99a8c;\n    --line: rgba(255,90,77,0.18);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    align-items: flex-start;\n    justify-content: center;\n    padding: 16px;\n  }\n\n  .shell {\n    width: 100%;\n    max-width: 560px;\n    border-radius: 18px;\n    padding: 18px 20px 22px;\n    background:\n      radial-gradient(120% 80% at 15% -10%, rgba(255,90,77,0.18), transparent 55%),\n      radial-gradient(140% 90% at 110% 120%, rgba(255,177,61,0.12), transparent 50%),\n      linear-gradient(160deg, var(--bg1), var(--bg0));\n    border: 1px solid var(--line);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.05),\n      inset 0 -2px 14px rgba(0,0,0,0.5);\n    position: relative;\n    overflow: hidden;\n  }\n\n  .shell::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      repeating-linear-gradient(0deg, rgba(255,255,255,0.018) 0 1px, transparent 1px 3px);\n    pointer-events: none;\n    opacity: 0.5;\n  }\n\n  /* ---- header ---- */\n  .head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 10px;\n    margin-bottom: 14px;\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .sigil {\n    width: 38px; height: 38px;\n    border-radius: 10px;\n    position: relative;\n    background: linear-gradient(150deg, var(--accent), var(--accent2));\n    box-shadow:\n      0 0 18px rgba(255,90,77,0.55),\n      inset 0 1px 0 rgba(255,255,255,0.4);\n    display: grid; place-items: center;\n    animation: pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { box-shadow: 0 0 14px rgba(255,90,77,0.45), inset 0 1px 0 rgba(255,255,255,0.4); }\n    50%      { box-shadow: 0 0 26px rgba(255,177,61,0.7), inset 0 1px 0 rgba(255,255,255,0.5); }\n  }\n  .sigil svg { width: 22px; height: 22px; display: block; }\n\n  .title { line-height: 1; }\n  .title .name {\n    font-size: 21px;\n    font-weight: 800;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .title .sub {\n    margin-top: 4px;\n    font-size: 9px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .badge {\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid var(--line);\n    border-radius: 999px;\n    padding: 5px 10px;\n    background: rgba(255,90,77,0.06);\n  }\n\n  /* ---- visualisers ---- */\n  .viz {\n    display: grid;\n    grid-template-columns: 1fr 1.3fr;\n    gap: 12px;\n    margin-bottom: 16px;\n  }\n\n  .glass {\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(0,0,0,0.45), rgba(0,0,0,0.25));\n    border: 1px solid var(--line);\n    box-shadow: inset 0 2px 12px rgba(0,0,0,0.6);\n    padding: 8px 10px 6px;\n    position: relative;\n  }\n  .glass .lbl {\n    font-size: 8px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-bottom: 4px;\n  }\n  canvas { display: block; width: 100%; height: 78px; border-radius: 6px; }\n\n  /* ---- knobs ---- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 10px 6px;\n  }\n\n  .cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n    padding: 8px 4px 10px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0.18));\n    border: 1px solid rgba(255,255,255,0.04);\n    transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;\n  }\n  .cell.hot {\n    border-color: var(--line);\n    box-shadow: 0 0 18px rgba(255,90,77,0.25);\n    transform: translateY(-1px);\n  }\n  .cell.big { grid-column: span 2; grid-row: span 2; }\n\n  .knob {\n    cursor: ns-resize;\n    touch-action: none;\n    filter: drop-shadow(0 4px 8px rgba(0,0,0,0.5));\n  }\n  .knob svg { display: block; overflow: visible; }\n\n  .pname {\n    font-size: 9px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .pval {\n    font-size: 11px;\n    font-weight: 700;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent2);\n    letter-spacing: 0.5px;\n  }\n  .cell.big .pname { font-size: 11px; letter-spacing: 2.4px; color: var(--ink); }\n  .cell.big .pval  { font-size: 16px; }\n\n  /* ---- keyboard ---- */\n  .keys {\n    margin-top: 16px;\n    display: flex;\n    position: relative;\n    height: 78px;\n    border-radius: 10px;\n    overflow: hidden;\n    background: #0c0705;\n    border: 1px solid var(--line);\n    box-shadow: inset 0 3px 10px rgba(0,0,0,0.7);\n    user-select: none;\n    touch-action: none;\n  }\n  .wkey {\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #f4e6df, #cbb6ac);\n    box-shadow: inset 0 -6px 8px rgba(0,0,0,0.18);\n    transition: background 0.06s, box-shadow 0.06s;\n  }\n  .wkey.on {\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: inset 0 -6px 12px rgba(0,0,0,0.3), 0 0 16px rgba(255,90,77,0.6);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 6.2%;\n    height: 60%;\n    margin-left: -3.1%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a1a15, #0a0504);\n    box-shadow: inset 0 -3px 5px rgba(255,255,255,0.06), 0 3px 6px rgba(0,0,0,0.6);\n    z-index: 3;\n    transition: background 0.06s;\n  }\n  .bkey.on {\n    background: linear-gradient(180deg, var(--accent), #b53026);\n    box-shadow: 0 0 14px rgba(255,90,77,0.7);\n  }\n\n  .foot {\n    margin-top: 10px;\n    text-align: center;\n    font-size: 8px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    opacity: 0.7;\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"sigil\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#2a0b06\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n            <path d=\"M3 14 L7 14 L9 5 L13 19 L15 14 L21 14\"/>\n          </svg>\n        </div>\n        <div class=\"title\">\n          <div class=\"name\">Solo One</div>\n          <div class=\"sub\">Mono Lead Engine</div>\n        </div>\n      </div>\n      <div class=\"badge\">Monophonic</div>\n    </div>\n\n    <div class=\"viz\">\n      <div class=\"glass\">\n        <div class=\"lbl\">Filter Envelope</div>\n        <canvas id=\"envCanvas\"></canvas>\n      </div>\n      <div class=\"glass\">\n        <div class=\"lbl\">Lead Scope</div>\n        <canvas id=\"scopeCanvas\"></canvas>\n      </div>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"keys\" id=\"keys\"></div>\n    <div class=\"foot\">Drag knobs · double-click resets · play the keys</div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- param model (indices match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.35, big: true,  unit: \"%\" },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.70, unit: \"%\" },\n    { name: \"Env Amount\", index: 2, min: 0, max: 1, def: 0.80, unit: \"%\" },\n    { name: \"Decay\",      index: 3, min: 0, max: 1, def: 0.30, unit: \"%\" },\n    { name: \"Detune\",     index: 4, min: 0, max: 1, def: 0.25, unit: \"%\" },\n    { name: \"Drive\",      index: 5, min: 0, max: 1, def: 0.40, unit: \"%\" },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.80, unit: \"%\" }\n  ];\n\n  var values = {};\n  var bridge = null;\n\n  function pushParam(index, value) {\n    if (bridge && typeof bridge.setParam === \"function\") {\n      try { bridge.setParam(index, value); } catch (e) {}\n    }\n  }\n\n  // ---- knob factory ----\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\" + (p.big ? \" big\" : \"\");\n\n    var R = p.big ? 46 : 30;\n    var sw = p.big ? 12 : 8;\n    var size = (R + sw) * 2 + 8;\n    var cx = size / 2, cy = size / 2;\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.innerHTML =\n      '<svg width=\"' + size + '\" height=\"' + size + '\" viewBox=\"0 0 ' + size + ' ' + size + '\">' +\n        '<defs>' +\n          '<radialGradient id=\"g' + p.index + '\" cx=\"50%\" cy=\"35%\" r=\"70%\">' +\n            '<stop offset=\"0%\" stop-color=\"#3a201a\"/>' +\n            '<stop offset=\"100%\" stop-color=\"#160c09\"/>' +\n          '</radialGradient>' +\n          '<linearGradient id=\"arc' + p.index + '\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n            '<stop offset=\"0%\" stop-color=\"#ffb13d\"/>' +\n            '<stop offset=\"100%\" stop-color=\"#ff5a4d\"/>' +\n          '</linearGradient>' +\n        '</defs>' +\n        '<circle cx=\"' + cx + '\" cy=\"' + cy + '\" r=\"' + (R + sw / 2) + '\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"' + sw + '\"/>' +\n        '<path id=\"track' + p.index + '\" fill=\"none\" stroke=\"rgba(0,0,0,0.5)\" stroke-width=\"' + sw + '\" stroke-linecap=\"round\"/>' +\n        '<path id=\"fill' + p.index + '\" fill=\"none\" stroke=\"url(#arc' + p.index + ')\" stroke-width=\"' + sw + '\" stroke-linecap=\"round\"/>' +\n        '<circle cx=\"' + cx + '\" cy=\"' + cy + '\" r=\"' + R + '\" fill=\"url(#g' + p.index + ')\" stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>' +\n        '<circle cx=\"' + cx + '\" cy=\"' + cy + '\" r=\"' + R + '\" fill=\"none\" stroke=\"rgba(255,90,77,0.0)\" stroke-width=\"2\" id=\"glow' + p.index + '\"/>' +\n        '<line id=\"ptr' + p.index + '\" x1=\"' + cx + '\" y1=\"' + cy + '\" x2=\"' + cx + '\" y2=\"' + (cy - R + sw * 0.4) + '\" stroke=\"#ffe9df\" stroke-width=\"' + (p.big ? 3 : 2.2) + '\" stroke-linecap=\"round\"/>' +\n      '</svg>';\n\n    var name = document.createElement(\"div\");\n    name.className = \"pname\";\n    name.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"pval\";\n\n    cell.appendChild(knob);\n    cell.appendChild(name);\n    cell.appendChild(val);\n\n    // arc geometry: 270deg sweep, gap at the bottom\n    var A0 = 135, A1 = 405; // degrees\n    function polar(ang, r) {\n      var rad = (ang - 90) * Math.PI / 180;\n      return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];\n    }\n    function arcPath(fromDeg, toDeg, r) {\n      var a = polar(fromDeg, r), b = polar(toDeg, r);\n      var large = (toDeg - fromDeg) > 180 ? 1 : 0;\n      return \"M\" + a[0] + \" \" + a[1] + \" A\" + r + \" \" + r + \" 0 \" + large + \" 1 \" + b[0] + \" \" + b[1];\n    }\n    knob.querySelector(\"#track\" + p.index).setAttribute(\"d\", arcPath(A0, A1, R + sw / 2));\n\n    var fillEl = knob.querySelector(\"#fill\" + p.index);\n    var ptrEl = knob.querySelector(\"#ptr\" + p.index);\n\n    function render() {\n      var v = values[p.index];\n      var t = (v - p.min) / (p.max - p.min);\n      var ang = A0 + t * (A1 - A0);\n      if (t > 0.001) fillEl.setAttribute(\"d\", arcPath(A0, ang, R + sw / 2));\n      else fillEl.setAttribute(\"d\", \"\");\n      var rad = (ang - 90) * Math.PI / 180;\n      ptrEl.setAttribute(\"transform\", \"rotate(\" + (ang - 0) + \" \" + cx + \" \" + cy + \")\");\n      val.textContent = Math.round(t * 100) + (p.unit || \"\");\n    }\n\n    function setVal(v, push) {\n      v = Math.max(p.min, Math.min(p.max, v));\n      values[p.index] = v;\n      render();\n      if (push !== false) pushParam(p.index, v);\n    }\n\n    // drag\n    var dragging = false, startY = 0, startV = 0;\n    function down(e) {\n      dragging = true;\n      cell.classList.add(\"hot\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = values[p.index];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", move);\n      window.addEventListener(\"touchmove\", move, { passive: false });\n      window.addEventListener(\"mouseup\", up);\n      window.addEventListener(\"touchend\", up);\n    }\n    function move(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var fine = e.shiftKey ? 0.25 : 1;\n      var dv = (startY - y) / 200 * fine * (p.max - p.min);\n      setVal(startV + dv);\n      e.preventDefault();\n    }\n    function up() {\n      dragging = false;\n      cell.classList.remove(\"hot\");\n      window.removeEventListener(\"mousemove\", move);\n      window.removeEventListener(\"touchmove\", move);\n      window.removeEventListener(\"mouseup\", up);\n      window.removeEventListener(\"touchend\", up);\n    }\n    knob.addEventListener(\"mousedown\", down);\n    knob.addEventListener(\"touchstart\", down, { passive: false });\n    knob.addEventListener(\"dblclick\", function () { setVal(p.def); });\n    knob.addEventListener(\"wheel\", function (e) {\n      var fine = e.shiftKey ? 0.2 : 1;\n      setVal(values[p.index] - Math.sign(e.deltaY) * 0.02 * fine * (p.max - p.min));\n      e.preventDefault();\n    }, { passive: false });\n\n    values[p.index] = p.def;\n    setVal(p.def, false);\n    return { cell: cell, render: render };\n  }\n\n  var rack = document.getElementById(\"rack\");\n  var knobs = [];\n  PARAMS.forEach(function (p) {\n    var k = makeKnob(p);\n    knobs.push(k);\n    rack.appendChild(k.cell);\n  });\n\n  // ---- keyboard ----\n  // build two octaves starting at C3 (MIDI 48)\n  var keysEl = document.getElementById(\"keys\");\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 }; // white-index -> black semitone offset\n  var BASE = 48;\n  var OCTAVES = 2;\n  var whiteEls = [];\n  var totalWhite = WHITE.length * OCTAVES;\n\n  for (var o = 0; o < OCTAVES; o++) {\n    for (var w = 0; w < WHITE.length; w++) {\n      var midi = BASE + o * 12 + WHITE[w];\n      var el = document.createElement(\"div\");\n      el.className = \"wkey\";\n      el.dataset.midi = midi;\n      keysEl.appendChild(el);\n      whiteEls.push(el);\n    }\n  }\n  // black keys positioned after layout\n  function placeBlacks() {\n    var w = keysEl.clientWidth / totalWhite;\n    var idx = 0;\n    for (var o = 0; o < OCTAVES; o++) {\n      for (var i = 0; i < WHITE.length; i++) {\n        if (BLACK.hasOwnProperty(i)) {\n          var midi = BASE + o * 12 + BLACK[i];\n          var b = document.createElement(\"div\");\n          b.className = \"bkey\";\n          b.dataset.midi = midi;\n          b.style.left = (w * (idx + 1)) + \"px\";\n          keysEl.appendChild(b);\n        }\n        idx++;\n      }\n    }\n  }\n  placeBlacks();\n  window.addEventListener(\"resize\", function () {\n    var olds = keysEl.querySelectorAll(\".bkey\");\n    for (var i = 0; i < olds.length; i++) olds[i].remove();\n    placeBlacks();\n  });\n\n  var held = {};\n  function noteOn(midi, el) {\n    if (held[midi]) return;\n    held[midi] = el;\n    el.classList.add(\"on\");\n    if (bridge && typeof bridge.noteOn === \"function\") {\n      try { bridge.noteOn(midi, 0.92); } catch (e) {}\n    }\n    scopeActive = true;\n  }\n  function noteOff(midi) {\n    var el = held[midi];\n    if (!el) return;\n    el.classList.remove(\"on\");\n    delete held[midi];\n    if (bridge && typeof bridge.noteOff === \"function\") {\n      try { bridge.noteOff(midi); } catch (e) {}\n    }\n  }\n\n  var pointerDown = false;\n  function keyAt(target) {\n    if (!target || !target.dataset || !target.dataset.midi) return null;\n    return { midi: +target.dataset.midi, el: target };\n  }\n  keysEl.addEventListener(\"mousedown\", function (e) {\n    pointerDown = true;\n    var k = keyAt(e.target);\n    if (k) noteOn(k.midi, k.el);\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"mouseover\", function (e) {\n    if (!pointerDown) return;\n    var k = keyAt(e.target);\n    if (k) noteOn(k.midi, k.el);\n  });\n  keysEl.addEventListener(\"mouseout\", function (e) {\n    var k = keyAt(e.target);\n    if (k && pointerDown) noteOff(k.midi);\n  });\n  window.addEventListener(\"mouseup\", function () {\n    pointerDown = false;\n    for (var m in held) noteOff(+m);\n  });\n  keysEl.addEventListener(\"touchstart\", function (e) {\n    for (var i = 0; i < e.changedTouches.length; i++) {\n      var t = e.changedTouches[i];\n      var k = keyAt(document.elementFromPoint(t.clientX, t.clientY));\n      if (k) noteOn(k.midi, k.el);\n    }\n    e.preventDefault();\n  }, { passive: false });\n  keysEl.addEventListener(\"touchend\", function (e) {\n    for (var i = 0; i < e.changedTouches.length; i++) {\n      var t = e.changedTouches[i];\n      var k = keyAt(document.elementFromPoint(t.clientX, t.clientY));\n      if (k) noteOff(k.midi);\n    }\n    e.preventDefault();\n  }, { passive: false });\n\n  // computer keyboard mapping (a row -> white, w/e/t/y/u -> black)\n  var KEYMAP = { a: 48, w: 49, s: 50, e: 51, d: 52, f: 53, t: 54, g: 55, y: 56, h: 57, u: 58, j: 59, k: 60, o: 61, l: 62 };\n  document.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var midi = KEYMAP[e.key];\n    if (midi == null) return;\n    var el = document.querySelector('[data-midi=\"' + midi + '\"]');\n    if (el) noteOn(midi, el);\n  });\n  document.addEventListener(\"keyup\", function (e) {\n    var midi = KEYMAP[e.key];\n    if (midi != null) noteOff(midi);\n  });\n\n  // ---- visualisers ----\n  var envC = document.getElementById(\"envCanvas\");\n  var scopeC = document.getElementById(\"scopeCanvas\");\n  var envX = envC.getContext(\"2d\");\n  var scopeX = scopeC.getContext(\"2d\");\n\n  function fit(cv) {\n    var dpr = window.devicePixelRatio || 1;\n    var r = cv.getBoundingClientRect();\n    cv.width = Math.max(2, r.width * dpr);\n    cv.height = Math.max(2, r.height * dpr);\n    return dpr;\n  }\n  var envDpr = fit(envC), scopeDpr = fit(scopeC);\n  window.addEventListener(\"resize\", function () { envDpr = fit(envC); scopeDpr = fit(scopeC); });\n\n  var t0 = performance.now();\n  var scopeActive = false;\n  var anyHeld = function () { for (var k in held) return true; return false; };\n\n  function drawEnv(now) {\n    var w = envC.width, h = envC.height;\n    envX.clearRect(0, 0, w, h);\n    // shape from Decay + Env Amount; spiking attack, exp decay\n    var decay = values[3];\n    var amt = values[2];\n    var attack = 0.04;\n    var decTime = 0.1 + decay * 0.85;\n    envX.lineWidth = 2 * envDpr;\n    // grid\n    envX.strokeStyle = \"rgba(255,90,77,0.08)\";\n    envX.lineWidth = 1 * envDpr;\n    for (var gx = 0; gx <= 4; gx++) {\n      var x = w * gx / 4;\n      envX.beginPath(); envX.moveTo(x, 0); envX.lineTo(x, h); envX.stroke();\n    }\n    // moving phase so it feels alive\n    var ph = ((now - t0) / 2200) % 1;\n    var grad = envX.createLinearGradient(0, 0, w, 0);\n    grad.addColorStop(0, \"#ffb13d\");\n    grad.addColorStop(1, \"#ff5a4d\");\n    envX.strokeStyle = grad;\n    envX.lineWidth = 2.4 * envDpr;\n    envX.beginPath();\n    var top = h * (0.92 - amt * 0.78);\n    for (var i = 0; i <= 120; i++) {\n      var tt = i / 120;\n      var v;\n      if (tt < attack) v = tt / attack;\n      else v = Math.exp(-(tt - attack) / decTime * 4.5);\n      var y = h - 4 - v * (h - top - 4);\n      var px = tt * w;\n      if (i === 0) envX.moveTo(px, y); else envX.lineTo(px, y);\n    }\n    envX.stroke();\n    // glowing playhead dot riding the curve\n    var tt = ph;\n    var vv = tt < attack ? tt / attack : Math.exp(-(tt - attack) / decTime * 4.5);\n    var hy = h - 4 - vv * (h - top - 4);\n    envX.fillStyle = \"#fff3e6\";\n    envX.shadowColor = \"#ff5a4d\";\n    envX.shadowBlur = 12 * envDpr;\n    envX.beginPath();\n    envX.arc(tt * w, hy, 3 * envDpr, 0, Math.PI * 2);\n    envX.fill();\n    envX.shadowBlur = 0;\n  }\n\n  var scopeEnv = 0;\n  function drawScope(now) {\n    var w = scopeC.width, h = scopeC.height;\n    scopeX.clearRect(0, 0, w, h);\n    var mid = h / 2;\n    // baseline\n    scopeX.strokeStyle = \"rgba(255,90,77,0.10)\";\n    scopeX.lineWidth = 1 * scopeDpr;\n    scopeX.beginPath(); scopeX.moveTo(0, mid); scopeX.lineTo(w, mid); scopeX.stroke();\n\n    // ease the trace amplitude toward whether a note is held\n    var target = anyHeld() ? 1 : 0;\n    scopeEnv += (target - scopeEnv) * 0.06;\n\n    // synth-derived waveform: saw + detuned pulse, filtered look\n    var cutoff = values[0], reso = values[1], detune = values[4], drive = values[5];\n    var tphase = (now - t0) / 1000;\n    var cycles = 3;\n    var grad = scopeX.createLinearGradient(0, 0, w, 0);\n    grad.addColorStop(0, \"#ffb13d\");\n    grad.addColorStop(1, \"#ff5a4d\");\n    scopeX.strokeStyle = grad;\n    scopeX.lineWidth = 2.2 * scopeDpr;\n    scopeX.shadowColor = \"rgba(255,90,77,0.6)\";\n    scopeX.shadowBlur = 8 * scopeDpr * scopeEnv;\n    scopeX.beginPath();\n    var amp = (0.18 + scopeEnv * 0.66) * mid;\n    for (var i = 0; i <= w; i += 2) {\n      var u = i / w;\n      var ph1 = (u * cycles + tphase) % 1;\n      var saw = ph1 * 2 - 1;\n      var ph2 = (u * cycles * (1 + detune * 0.04) + tphase) % 1;\n      var pulse = ph2 < 0.5 ? 1 : -1;\n      var sig = saw + pulse * 0.7;\n      // crude \"filter\": blend toward smooth as cutoff/reso change, drive sharpens\n      sig = sig * (0.5 + drive * 0.4);\n      // resonant ripple emphasis near the edges\n      sig += Math.sin(ph1 * Math.PI * 2) * reso * 0.35 * Math.exp(-cutoff * 1.5);\n      sig = Math.max(-1.4, Math.min(1.4, sig * (0.4 + cutoff * 0.7)));\n      var y = mid - sig * amp;\n      if (i === 0) scopeX.moveTo(i, y); else scopeX.lineTo(i, y);\n    }\n    scopeX.stroke();\n    scopeX.shadowBlur = 0;\n  }\n\n  function loop(now) {\n    if (!document.hidden) {\n      drawEnv(now);\n      drawScope(now);\n    }\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n\n  // ---- host bridge ----\n  function bind() {\n    bridge = window.vstai || null;\n    // (re)push all defaults to the engine\n    PARAMS.forEach(function (p) { pushParam(p.index, values[p.index]); });\n  }\n  function boot() {\n    if (window.vstai && typeof window.vstai.onReady === \"function\") {\n      window.vstai.onReady(bind);\n    } else {\n      bind();\n    }\n  }\n  boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SOLO ONE — aggressive monophonic lead/bass synth (Pro-One lineage)\n//  Two oscillators (saw + pulse) with OSC-2 detune feed a snappy hard-edged\n//  resonant 4-pole low-pass driven by a FAST punchy filter envelope. A little\n//  oscillator cross-mod / hard-sync grit gives the biting lead character. Mono\n//  with last-note priority; pitch tracks; everything bounded. Pure algorithm.\n//\n//  Signal path per note:\n//    osc1 saw (master) + osc2 pulse (detuned, hard-synced to osc1)\n//      -> cross-mod grit -> drive shaper -> 4-pole resonant LPF\n//      cutoff = base + envAmount * fastFilterEnv -> amp env -> level\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF: i32 = 0; // base cutoff 0..1\nconst P_RESO:   i32 = 1; // resonance 0..1\nconst P_ENVAMT: i32 = 2; // filter envelope amount 0..1\nconst P_DECAY:  i32 = 3; // filter + amp decay 0..1\nconst P_DETUNE: i32 = 4; // osc-2 detune 0..1\nconst P_DRIVE:  i32 = 5; // pre-filter drive / grit 0..1\nconst P_LEVEL:  i32 = 6; // output level 0..1\n\n// ---- voice state ----\nlet phase1: f32 = 0.0;     // osc1 (master saw) phase 0..1\nlet phase2: f32 = 0.0;     // osc2 (pulse) phase 0..1\nlet freq:   f32 = 0.0;     // note frequency in Hz\nlet gate:   i32 = 0;       // 1 while a note is held\nlet note:   i32 = -1;      // currently sounding note id\nlet vel:    f32 = 0.0;     // 0..1 velocity of current note\n\n// envelopes\nlet fenv: f32 = 0.0;       // fast filter envelope (decays 1 -> 0)\nlet aenv: f32 = 0.0;       // amplitude envelope\n\n// 4-pole (Moog-style) ladder filter state\nlet f0: f32 = 0.0;\nlet f1: f32 = 0.0;\nlet f2: f32 = 0.0;\nlet f3: f32 = 0.0;\n\n// DC blocker on the output\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  phase1 = 0.0;\n  phase2 = 0.0;\n  freq = 0.0;\n  gate = 0;\n  note = -1;\n  vel = 0.0;\n  fenv = 0.0;\n  aenv = 0.0;\n  f0 = 0.0; f1 = 0.0; f2 = 0.0; f3 = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_CUTOFF] = 0.35;\n  params[P_RESO]   = 0.7;\n  params[P_ENVAMT] = 0.8;\n  params[P_DECAY]  = 0.3;\n  params[P_DETUNE] = 0.25;\n  params[P_DRIVE]  = 0.4;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// fast tanh-ish soft saturator: bounded, smooth, cheap\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// Host passes frequency in Hz. Last-note priority; new notes retrigger the\n// envelopes (snappy, like a Pro-One). Velocity tracked per note.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  freq = f > 0.0 ? f : 0.0001;\n  note = id;\n  gate = 1;\n  vel = clampf(v, 0.0, 1.0);\n  // hard retrigger -> snappy attack\n  fenv = 1.0;\n  aenv = 1.0;\n  // reset osc2 phase relative to osc1 for a consistent biting transient\n  phase2 = phase1;\n}\n\nexport function noteOff(id: i32): void {\n  if (id == note) gate = 0;\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN:   f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envAmtN: f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const decayN:  f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const driveN:  f32 = clampf(params[P_DRIVE],  0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Filter-envelope decay: FAST & punchy — ~8 ms (very snappy) to ~700 ms.\n  const fdecaySec: f32 = 0.008 + decayN * decayN * 0.69;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n\n  // Amp envelope: a touch longer than the filter so notes have body.\n  const adecaySec: f32 = 0.04 + decayN * decayN * 1.4;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n\n  // Resonance 0..~4.0 — hard-edged, approaches self-oscillation but bounded.\n  const reso: f32 = resoN * 4.0;\n\n  // Base cutoff in Hz (exponential, musical): ~60 Hz .. ~11 kHz.\n  const baseCut: f32 = f32(60.0 * Mathf.exp(cutoffN * 5.2));\n\n  // Filter envelope sweep span in Hz on top of base.\n  const sweepSpan: f32 = envAmtN * 10000.0;\n\n  // Detune: OSC-2 up to ~+0.6 semitone-ish ratio swing for a fat, beating bite.\n  // Ratio centered at 1.0 going up to ~1.012 (about a fifth of a semitone) plus\n  // a small fine-detune for movement. Kept subtle but clearly audible.\n  const detuneRatio: f32 = 1.0 + detuneN * 0.04;\n\n  // Drive into the filter and grit amount.\n  const drive: f32 = 1.0 + driveN * 4.0;\n  const crossMod: f32 = driveN * 0.5; // osc cross-mod grit amount\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // ---- oscillators ----\n    let inc1: f32 = freq / sampleRate;\n    if (inc1 < 0.0) inc1 = 0.0;\n    if (inc1 > 0.5) inc1 = 0.5;\n    let inc2: f32 = (freq * detuneRatio) / sampleRate;\n    if (inc2 < 0.0) inc2 = 0.0;\n    if (inc2 > 0.5) inc2 = 0.5;\n\n    // osc1 master saw\n    phase1 += inc1;\n    let synced: i32 = 0;\n    if (phase1 >= 1.0) { phase1 -= 1.0; synced = 1; }\n    const saw1: f32 = phase1 * 2.0 - 1.0;\n\n    // osc2 pulse, hard-synced to osc1 (the bite of a Pro-One)\n    phase2 += inc2;\n    if (phase2 >= 1.0) phase2 -= 1.0;\n    if (synced != 0) phase2 = phase1; // hard sync reset on master wrap\n    const pulse2: f32 = phase2 < 0.5 ? 1.0 : -1.0;\n\n    // cross-mod grit: osc1 modulates osc2's effective level a touch\n    const osc2: f32 = pulse2 * (1.0 + crossMod * saw1);\n\n    // mix: saw + pulse (osc2 sits a touch lower so the lead stays focused)\n    let osc: f32 = saw1 + osc2 * 0.85;\n    osc *= 0.55; // headroom before drive\n\n    // pre-filter drive / grit\n    osc = satf(osc * drive);\n\n    // ---- envelopes ----\n    fenv *= fenvCoef;\n    if (gate != 0) {\n      // amp decays toward a sustain floor while held\n      aenv = aenvCoef * aenv;\n      if (aenv < 0.3) aenv = 0.3;\n    } else {\n      aenv *= aenvCoef;\n    }\n\n    // ---- cutoff for this sample (velocity opens it a touch more) ----\n    let cutHz: f32 = baseCut + sweepSpan * fenv * (0.6 + 0.4 * vel);\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- 4-pole resonant ladder ----\n    let fc: f32 = cutHz / nyq;\n    if (fc > 0.49) fc = 0.49;\n    const g: f32 = fc * (1.8 - 0.8 * fc);\n\n    const fb: f32 = reso * (1.0 - 0.15 * g);\n    const input: f32 = osc - fb * satf(f3);\n\n    f0 += g * (input - f0);\n    f1 += g * (f0 - f1);\n    f2 += g * (f1 - f2);\n    f3 += g * (f2 - f3);\n\n    let filtered: f32 = f3;\n    filtered = satf(filtered * 1.4);\n\n    // ---- amp + level ----\n    let s: f32 = filtered * aenv * (0.5 + 0.5 * vel);\n\n    // DC blocker\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // final level + headroom guard (peak stays under ~1.0)\n    s = satf(s * level * 1.25) * 0.8;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000093000
}