{
  "format": 1,
  "name": "Brit Distortion",
  "isInstrument": false,
  "explanation": "An amp-in-a-box British distortion. A tightening high-pass feeds a hot gain stage into a soft-knee/hard-rail clipper (the diode + op-amp behaviour of a cranked British amp), which then drives an interactive passive 3-band tone stack: a low shelf (Bass), a peaking bell around 650 Hz (Mid) and a high shelf (Treble). The bands load each other like a real passive network, so you can dial scooped 'crunch' or mid-forward 'roar'. Controls: Gain, Bass, Mid, Treble and Level.",
  "params": [
    {
      "name": "Gain",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Bass",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mid",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Treble",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Level",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --gold:#ffcf3d;        /* faceplate gold accent */\n  --ember:#d94a2a;       /* hot clipping ember */\n  --panel:#0c0b0a;       /* black tolex */\n  --brass:#caa23b;\n  --ink:#15110a;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:#f3e6c4;\n  background:\n    radial-gradient(130% 100% at 50% -20%,#211a12 0%,#0d0a07 60%,#040302 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:22px;overflow:hidden;\n}\n\n/* ===================== AMP CABINET ===================== */\n.amp{\n  position:relative;\n  width:360px;\n  border-radius:16px;\n  padding:16px;\n  background:\n    linear-gradient(180deg,#1c1714 0%,#100c09 55%,#070504 100%);\n  box-shadow:\n    0 44px 90px -22px rgba(0,0,0,.85),\n    0 0 0 2px #060403,\n    0 0 0 10px #18130d,           /* black tolex border */\n    0 0 0 12px #2a2014,\n    0 0 0 13px rgba(255,207,61,.08);\n  animation:rise .7s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(26px) scale(.96)}to{opacity:1;transform:none}}\n\n/* tolex grain over the whole cab */\n.amp::before{\n  content:\"\";position:absolute;inset:0;border-radius:16px;pointer-events:none;\n  background:\n    repeating-linear-gradient(58deg,rgba(255,255,255,.022) 0 1px,transparent 1px 4px),\n    repeating-linear-gradient(-58deg,rgba(0,0,0,.18) 0 1px,transparent 1px 4px);\n  opacity:.6;mix-blend-mode:overlay;\n}\n\n/* corner protectors */\n.corner{position:absolute;width:24px;height:24px;z-index:3;\n  background:radial-gradient(circle at 35% 30%,#3a3326,#1a160f 70%);\n  box-shadow:0 1px 2px rgba(0,0,0,.7),inset 0 1px 1px rgba(255,255,255,.12);}\n.corner.tl{top:-7px;left:-7px;border-radius:14px 4px 14px 4px}\n.corner.tr{top:-7px;right:-7px;border-radius:4px 14px 4px 14px}\n.corner.bl{bottom:-7px;left:-7px;border-radius:4px 14px 4px 14px}\n.corner.br{bottom:-7px;right:-7px;border-radius:14px 4px 14px 4px}\n\n/* ===================== GOLD FACEPLATE ===================== */\n.faceplate{\n  position:relative;\n  border-radius:9px;\n  padding:14px 16px 12px;\n  background:\n    linear-gradient(180deg,#ffe07a 0%,#f2bb33 18%,#d99a1e 55%,#b97e16 100%);\n  box-shadow:\n    inset 0 1px 0 rgba(255,255,255,.7),\n    inset 0 -3px 8px rgba(80,45,0,.5),\n    0 2px 4px rgba(0,0,0,.6),\n    0 0 0 1px #6e4d0d;\n}\n/* brushed gold sheen */\n.faceplate::before{\n  content:\"\";position:absolute;inset:0;border-radius:9px;pointer-events:none;\n  background:\n    repeating-linear-gradient(90deg,rgba(255,255,255,.10) 0 1px,transparent 1px 3px),\n    radial-gradient(120% 80% at 25% 0%,rgba(255,255,255,.45),transparent 50%);\n  mix-blend-mode:screen;opacity:.55;\n}\n\n/* brand row */\n.brandrow{display:flex;align-items:center;justify-content:space-between;\n  position:relative;z-index:2;margin-bottom:6px}\n.logo{\n  font-family:\"Brush Script MT\",\"Segoe Script\",cursive;\n  font-size:30px;font-weight:700;font-style:italic;\n  color:#1a1206;\n  text-shadow:0 1px 0 rgba(255,255,255,.55),0 2px 3px rgba(80,50,0,.5);\n  letter-spacing:.5px;line-height:1;\n}\n.modeltag{\n  font:700 9px/1 ui-sans-serif,system-ui;letter-spacing:.22em;\n  color:#3a2807;text-transform:uppercase;\n  border:1px solid rgba(58,40,7,.5);border-radius:3px;padding:4px 6px;\n  background:rgba(255,255,255,.12);\n}\n\n/* power lamp (jewel) */\n.jewel{\n  position:relative;width:16px;height:16px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#ffe8a0,var(--ember) 55%,#5c1503 100%);\n  box-shadow:0 0 12px 3px rgba(217,74,42,.7),inset 0 0 4px rgba(0,0,0,.4);\n  animation:flicker 3.4s ease-in-out infinite;\n}\n@keyframes flicker{\n  0%,100%{box-shadow:0 0 12px 3px rgba(217,74,42,.7),inset 0 0 4px rgba(0,0,0,.4)}\n  50%{box-shadow:0 0 18px 5px rgba(255,160,60,.85),inset 0 0 4px rgba(0,0,0,.4)}\n}\n\n/* ===================== CLIPPING SCOPE ===================== */\n.scope{\n  position:relative;z-index:2;\n  margin:4px 0 10px;border-radius:6px;height:78px;overflow:hidden;\n  background:\n    radial-gradient(120% 140% at 50% 0%,#2a1404 0%,#170a02 70%,#0a0401 100%);\n  box-shadow:inset 0 0 0 1px #6e4d0d,inset 0 4px 14px rgba(0,0,0,.7);\n}\n.scope svg{display:block;width:100%;height:100%}\n.grid{stroke:rgba(255,207,61,.10);stroke-width:1}\n.wave{fill:none;stroke:url(#emberg);stroke-width:2.4;\n  filter:drop-shadow(0 0 5px rgba(217,74,42,.85));\n  stroke-linejoin:round;stroke-linecap:round}\n.rail{stroke:rgba(255,207,61,.28);stroke-width:1;stroke-dasharray:4 5}\n.glow{animation:pulse 1.6s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:.92}50%{opacity:.6}}\n\n/* ===================== TWEED GRILLE + KNOBS ===================== */\n.deck{\n  position:relative;z-index:2;\n  border-radius:7px;padding:16px 8px 12px;\n  background:\n    repeating-linear-gradient(48deg,#7a6336 0 2px,#5e4c28 2px 4px),\n    repeating-linear-gradient(-48deg,rgba(0,0,0,.22) 0 2px,transparent 2px 4px),\n    linear-gradient(180deg,#6b572f,#4a3c20);\n  box-shadow:inset 0 0 0 1px #2c2310,inset 0 2px 10px rgba(0,0,0,.6),\n             0 1px 0 rgba(255,255,255,.06);\n}\n.deck::after{ /* grille cloth weave shimmer */\n  content:\"\";position:absolute;inset:0;border-radius:7px;pointer-events:none;\n  background:repeating-linear-gradient(90deg,rgba(0,0,0,.10) 0 3px,transparent 3px 6px);\n  opacity:.5;\n}\n.knobs{display:flex;justify-content:space-around;position:relative;z-index:2}\n\n.pot{display:flex;flex-direction:column;align-items:center;gap:7px;\n  opacity:0;transform:translateY(10px);\n  animation:potin .55s cubic-bezier(.2,.8,.25,1) forwards;animation-delay:var(--d)}\n@keyframes potin{to{opacity:1;transform:none}}\n\n.knob{position:relative;width:64px;height:64px;cursor:ns-resize;touch-action:none;\n  outline:none;transition:transform .12s ease}\n.knob:hover{transform:translateY(-2px)}\n.knob.act{transform:scale(1.04)}\n\n/* glowing ring behind the cap reflects value */\n.arc{position:absolute;inset:-7px;border-radius:50%;\n  background:conic-gradient(from 220deg,\n     var(--ember) 0deg,\n     var(--gold) calc(var(--n,0)*280deg),\n     rgba(255,255,255,.06) calc(var(--n,0)*280deg),\n     rgba(255,255,255,.06) 280deg,\n     transparent 280deg);\n  -webkit-mask:radial-gradient(circle,transparent 56%,#000 58%);\n          mask:radial-gradient(circle,transparent 56%,#000 58%);\n  filter:drop-shadow(0 0 6px rgba(255,180,60,.55));}\n\n.skirt{position:absolute;inset:2px;border-radius:50%;\n  background:radial-gradient(circle at 50% 38%,#2a2a2c,#101012 70%,#050506);\n  box-shadow:0 5px 10px rgba(0,0,0,.6),inset 0 1px 1px rgba(255,255,255,.08);}\n\n/* chicken-head pointer cap */\n.cap{position:absolute;inset:11px;border-radius:50%;\n  background:\n    radial-gradient(circle at 42% 32%,#fff4cf 0%,var(--gold) 30%,#b9821a 70%,#6e4d0d 100%);\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.7),inset 0 -3px 6px rgba(80,45,0,.6),\n             0 2px 3px rgba(0,0,0,.5);\n  transform:rotate(calc(-140deg + var(--n,0)*280deg));transition:transform .05s linear;}\n.cap::after{content:\"\";position:absolute;left:50%;top:5px;width:5px;height:16px;\n  margin-left:-2.5px;border-radius:2px;\n  background:linear-gradient(#1a1206,#3a2807);\n  box-shadow:0 0 5px rgba(217,74,42,.7);}\n\n.pname{font:700 10px/1 ui-sans-serif,system-ui;letter-spacing:.16em;\n  text-transform:uppercase;color:#f0d690;text-shadow:0 1px 1px rgba(0,0,0,.7)}\n.pval{font:700 11px/1 ui-monospace,Menlo,monospace;color:var(--gold);\n  text-shadow:0 0 6px rgba(255,180,60,.6);min-height:11px}\n\n/* bottom strip / serial */\n.foot{display:flex;justify-content:space-between;align-items:center;\n  margin-top:10px;position:relative;z-index:2;\n  font:600 9px/1 ui-monospace,Menlo,monospace;letter-spacing:.14em;color:#7c6a3c}\n.foot .input{display:flex;align-items:center;gap:6px}\n.jack{width:13px;height:13px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#3a3326,#0c0a06 70%);\n  box-shadow:inset 0 0 3px rgba(0,0,0,.9),0 0 0 2px #4a3c20}\n</style>\n</head>\n<body>\n<div class=\"amp\">\n  <i class=\"corner tl\"></i><i class=\"corner tr\"></i><i class=\"corner bl\"></i><i class=\"corner br\"></i>\n\n  <div class=\"faceplate\">\n    <div class=\"brandrow\">\n      <div class=\"logo\">Brit&nbsp;Distortion</div>\n      <div class=\"jewel\" title=\"Power\"></div>\n    </div>\n\n    <div class=\"scope\">\n      <svg viewBox=\"0 0 320 78\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"emberg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ffe07a\"/>\n            <stop offset=\"0.5\" stop-color=\"var(--gold)\"/>\n            <stop offset=\"1\" stop-color=\"#d94a2a\"/>\n          </linearGradient>\n        </defs>\n        <line class=\"grid\" x1=\"0\" y1=\"39\" x2=\"320\" y2=\"39\"/>\n        <line class=\"grid\" x1=\"80\" y1=\"0\" x2=\"80\" y2=\"78\"/>\n        <line class=\"grid\" x1=\"160\" y1=\"0\" x2=\"160\" y2=\"78\"/>\n        <line class=\"grid\" x1=\"240\" y1=\"0\" x2=\"240\" y2=\"78\"/>\n        <line class=\"rail\" id=\"railT\" x1=\"0\" y1=\"12\" x2=\"320\" y2=\"12\"/>\n        <line class=\"rail\" id=\"railB\" x1=\"0\" y1=\"66\" x2=\"320\" y2=\"66\"/>\n        <path class=\"wave glow\" id=\"wave\" d=\"\"/>\n      </svg>\n    </div>\n\n    <div class=\"deck\">\n      <div class=\"knobs\" id=\"knobs\"></div>\n    </div>\n\n    <div class=\"foot\">\n      <div class=\"input\"><span class=\"jack\"></span>INPUT</div>\n      <div>BD-1 &middot; CLASS-A PREAMP</div>\n      <div class=\"modeltag\">Amp&nbsp;In&nbsp;A&nbsp;Box</div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Gain\",  index:0,min:0,max:1,def:0.55},\n    {name:\"Bass\",  index:1,min:0,max:1,def:0.5},\n    {name:\"Mid\",   index:2,min:0,max:1,def:0.5},\n    {name:\"Treble\",index:3,min:0,max:1,def:0.55},\n    {name:\"Level\", index:4,min:0,max:1,def:0.6}\n  ];\n  var state={};\n  var knobsEl=document.getElementById('knobs');\n  var waveEl=document.getElementById('wave');\n\n  function disp(v){ return Math.round(v*10); } // 0..10 amp-knob feel\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*70)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\" title=\"'+p.name+'\">'+\n        '<i class=\"arc\"></i><i class=\"skirt\"></i><i class=\"cap\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    knobsEl.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var cap=cell.querySelector('.cap');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var nrm=norm();\n      arc.style.setProperty('--n',nrm);\n      cap.style.setProperty('--n',nrm);\n      val.textContent=disp(nrm);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(nrm){\n      nrm=nrm<0?0:nrm>1?1:nrm;\n      v=p.min+(p.max-p.min)*nrm;\n      paint();\n    }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true;startY=e.clientY;startN=norm();\n      knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?620:210;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){drag=false;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){v=p.def;paint();});\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ---- live amp-in-a-box clip + tone-stack visualisation ----\n  function onChange(){\n    var gain =state[0]!=null?state[0]:0.55;\n    var bass =state[1]!=null?state[1]:0.5;\n    var mid  =state[2]!=null?state[2]:0.5;\n    var treb =state[3]!=null?state[3]:0.55;\n    var level=state[4]!=null?state[4]:0.6;\n\n    var g=1+gain*22;                         // visual drive\n    var amp=18+22*level;\n    var bassG=0.35+bass*1.85, midG=0.18+mid*2.42, trebG=0.30+treb*2.10;\n\n    var pts=[],N=160;\n    for(var x=0;x<=N;x++){\n      var t=x/N;\n      var ph=t*Math.PI*4;\n      var dry=Math.sin(ph);\n      // tone stack reshaping: low fundamental + mid harmonic + treble fizz\n      var shaped=dry*(0.5+0.5*bassG/2.2)\n               + 0.35*Math.sin(ph*2)*(midG/2.6)\n               + 0.20*Math.sin(ph*4)*(trebG/2.4);\n      // soft-knee -> hard tanh rail (amp-in-a-box clipper)\n      var soft=shaped*g; soft=soft-(soft*soft*soft)/9;\n      var wet=Math.tanh(soft*0.7)*0.92;\n      var y=39 - wet*amp;\n      pts.push((x*(320/N)).toFixed(1)+\",\"+y.toFixed(2));\n    }\n    waveEl.setAttribute('d','M'+pts.join(' L'));\n    // clip rails tighten as gain climbs\n    var railY=amp*0.92;\n    document.getElementById('railT').setAttribute('y1',(39-railY).toFixed(1));\n    document.getElementById('railT').setAttribute('y2',(39-railY).toFixed(1));\n    document.getElementById('railB').setAttribute('y1',(39+railY).toFixed(1));\n    document.getElementById('railB').setAttribute('y2',(39+railY).toFixed(1));\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ onChange(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BRIT DISTORTION — amp-in-a-box British distortion + 3-band tone stack\n//  (Marshall Guv'nor lineage, modelled, not copied)\n//\n//  Signal flow:\n//    in -> input HP (~70 Hz, tighten lows)\n//       -> x Gain  (crunch .. roar)\n//       -> hard-ish clipper (soft knee feeding a hard rail) — diode/op-amp\n//          pair behaviour of an amp-in-a-box gain stage\n//       -> passive British tone stack (interactive Bass / Mid / Treble):\n//            * Treble: high shelf  (bright tilt)\n//            * Mid:    peaking bell ~650 Hz (scoop <-> mid-forward)\n//            * Bass:   low shelf\n//          implemented as three one-pole-derived shaping stages whose\n//          gains INTERACT through a shared makeup so turning Bass up\n//          fattens and slightly veils the top, like a real FMV stack.\n//       -> Level (master volume)\n//\n//  All math is f32 (Mathf.*), no allocation in process(), planar stride 8192.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst hpState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // input high-pass\nconst lowState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low band split\nconst midState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // mid bell low side\nconst midState2:StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // mid bell high side\nconst hiState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // treble split\n\nconst P_GAIN: i32   = 0; // 0..1 -> input drive 1..60\nconst P_BASS: i32   = 1; // 0..1 -> low shelf  -/+\nconst P_MID: i32    = 2; // 0..1 -> mid bell  scoop/boost\nconst P_TREBLE: i32 = 3; // 0..1 -> high shelf -/+\nconst P_LEVEL: i32  = 4; // 0..1 -> 0..1.2 master\n\nconst PI: f32 = 3.14159265358979;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    hpState[c] = 0.0; lowState[c] = 0.0; midState[c] = 0.0; midState2[c] = 0.0; hiState[c] = 0.0;\n  }\n  params[P_GAIN] = 0.55;\n  params[P_BASS] = 0.5;\n  params[P_MID] = 0.5;\n  params[P_TREBLE] = 0.55;\n  params[P_LEVEL] = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// one-pole low-pass coefficient for a given corner (Hz)\n@inline function lpCoeff(hz: f32, sr: f32): f32 {\n  return f32(1.0 - Mathf.exp(-2.0 * PI * hz / sr));\n}\n\n// amp-in-a-box clipper: soft cubic knee that runs into a hard tanh rail.\n// Harder than a pure overdrive — crunch into roar — but bounded < 1.0.\n@inline function ampClip(x: f32): f32 {\n  // soft cubic region for low level, then tanh rail to hold the ceiling\n  const a: f32 = clampf(x, -3.0, 3.0);\n  const soft: f32 = a - (a * a * a) * f32(1.0 / 9.0); // gentle asymmetric-free knee\n  return f32(Mathf.tanh(soft * 0.7)) * 0.92;          // hard ceiling ~0.92\n}\n\nexport function process(n: i32): void {\n  const gain: f32  = 1.0 + clampf(params[P_GAIN], 0.0, 1.0) * 59.0; // 1..60\n  const bassN: f32 = clampf(params[P_BASS], 0.0, 1.0);\n  const midN: f32  = clampf(params[P_MID], 0.0, 1.0);\n  const trebN: f32 = clampf(params[P_TREBLE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.2;\n\n  // ---- tone-stack band gains (interactive) -------------------------\n  // Bass low-shelf gain: 0.35x .. 2.2x around 180 Hz\n  const bassG: f32 = 0.35 + bassN * 1.85;\n  // Treble high-shelf gain: 0.30x .. 2.4x above 2.5 kHz\n  const trebG: f32 = 0.30 + trebN * 2.10;\n  // Mid bell ~650 Hz: deep scoop (0.18x) .. mid-forward (2.6x)\n  const midG: f32  = 0.18 + midN * 2.42;\n\n  // British-stack interaction: lots of bass slightly veils the treble,\n  // and a mid scoop opens the extremes — couple them so the controls\n  // visibly reshape each other like a passive FMV network.\n  const trebTilt: f32 = trebG * (1.0 - 0.18 * bassN);          // bass loads the highs\n  const bassTilt: f32 = bassG * (1.0 + 0.12 * (1.0 - midN));   // mid scoop fattens lows\n  // makeup so the overall stack stays near unity loudness across settings\n  const stackMakeup: f32 = 1.0 / (0.45 + 0.30 * (bassTilt + midG + trebTilt) * f32(1.0 / 3.0));\n\n  // ---- crossover corners -------------------------------------------\n  const cHP:  f32 = lpCoeff(70.0,   sampleRate); // input tightening high-pass\n  const cLow: f32 = lpCoeff(180.0,  sampleRate); // low band\n  const cMidL:f32 = lpCoeff(420.0,  sampleRate); // mid bell lower edge\n  const cMidH:f32 = lpCoeff(950.0,  sampleRate); // mid bell upper edge\n  const cHi:  f32 = lpCoeff(2500.0, sampleRate); // treble band\n\n  // gain compensation so cranking Gain doesn't simply get louder\n  const comp: f32 = 2.2 / f32(Mathf.sqrt(gain));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let hp: f32  = hpState[c];\n    let lo: f32  = lowState[c];\n    let mL: f32  = midState[c];\n    let mH: f32  = midState2[c];\n    let hi: f32  = hiState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // input high-pass (remove sub-mud before the gain stage)\n      hp = hp + cHP * (x - hp);\n      const tight: f32 = x - hp;\n\n      // gain stage + amp-in-a-box clipping\n      const driven: f32 = ampClip(tight * gain) * comp;\n\n      // ---- 3-band passive-style tone stack ----\n      // low band (everything below ~180 Hz)\n      lo = lo + cLow * (driven - lo);\n      const lowBand: f32 = lo;\n\n      // mid band: band-pass via difference of two low-passes (~420..950 Hz center ~650)\n      mL = mL + cMidL * (driven - mL);\n      mH = mH + cMidH * (driven - mH);\n      const midBand: f32 = mH - mL;     // peaking region\n\n      // treble band: everything above ~2.5 kHz\n      hi = hi + cHi * (driven - hi);\n      const hiBand: f32 = driven - hi;\n\n      // remaining \"neutral\" middle content (keeps body when bands are cut)\n      const rest: f32 = driven - lowBand - midBand - hiBand;\n\n      const shaped: f32 =\n          rest\n        + lowBand * bassTilt\n        + midBand * midG\n        + hiBand  * trebTilt;\n\n      const wet: f32 = shaped * stackMakeup * level;\n      outBuf[base + f] = clampf(wet, -1.5, 1.5);\n    }\n\n    hpState[c]  = hp;\n    lowState[c] = lo;\n    midState[c] = mL;\n    midState2[c]= mH;\n    hiState[c]  = hi;\n  }\n}\n",
  "publishedAt": 1751000113000
}