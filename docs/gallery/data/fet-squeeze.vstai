{
  "format": 1,
  "name": "FET Squeeze",
  "isInstrument": false,
  "explanation": "A fast FET-style peak compressor. A very fast peak detector feeds a dB-domain gain computer with a selectable ratio (about 2:1 to 20:1) and a soft knee, plus a program-dependent release for punchy, glued dynamics. Controls: Input (how hard it hits the detector), Attack, Release, Ratio and Output makeup gain.",
  "params": [
    {
      "name": "Input",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Attack",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Release",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Ratio",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>FET Squeeze</title>\n<style>\n  :root{\n    --accent:#ff5a6e;\n    --accent2:#ff9a6a;\n    --metal0:#2b2d31;\n    --metal1:#4a4d54;\n    --metal2:#6b6f78;\n    --ink:#0d0e10;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent;}\n  html,body{margin:0;height:100%;background:#101113;overflow:hidden;\n    font-family:\"Helvetica Neue\",Helvetica,Arial,sans-serif;color:#e8e9ec;}\n  #stage{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\n    background:radial-gradient(120% 120% at 50% -10%,#26282c 0%,#0c0d0f 70%);}\n\n  /* ---------- the rack unit ---------- */\n  .unit{\n    position:relative;width:760px;height:392px;border-radius:10px;\n    background:\n      linear-gradient(180deg,rgba(255,255,255,.06),rgba(0,0,0,.30)),\n      repeating-linear-gradient(90deg,#54585f 0px,#62666e 1px,#4d5158 2px,#5a5e66 3px),\n      linear-gradient(180deg,#5a5e66,#3e4148);\n    background-blend-mode:overlay,overlay,normal;\n    border:1px solid #2b2d31;\n    box-shadow:\n      0 30px 60px rgba(0,0,0,.6),\n      0 2px 0 rgba(255,255,255,.18) inset,\n      0 -3px 8px rgba(0,0,0,.5) inset;\n    display:flex;\n  }\n  /* brushed sheen sweeping across the faceplate */\n  .unit::after{\n    content:\"\";position:absolute;inset:0;border-radius:10px;pointer-events:none;\n    background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.10) 47%,rgba(255,255,255,.18) 50%,rgba(255,255,255,.10) 53%,transparent 70%);\n    background-size:300% 100%;\n    animation:sheen 9s linear infinite;\n    mix-blend-mode:screen;opacity:.5;\n  }\n  @keyframes sheen{0%{background-position:130% 0}100%{background-position:-130% 0}}\n\n  /* ---------- rack ears ---------- */\n  .ear{width:54px;flex:0 0 54px;position:relative;\n    background:linear-gradient(180deg,#3b3e44,#23252a);\n    border-right:1px solid rgba(0,0,0,.5);box-shadow:1px 0 0 rgba(255,255,255,.06) inset;}\n  .ear.right{border-right:none;border-left:1px solid rgba(0,0,0,.5);box-shadow:-1px 0 0 rgba(255,255,255,.06) inset;}\n  .screw{position:absolute;left:50%;width:22px;height:22px;border-radius:50%;transform:translateX(-50%);\n    background:radial-gradient(circle at 35% 30%,#9aa,#4c4f55 60%,#222 100%);\n    box-shadow:0 1px 2px rgba(0,0,0,.7),0 0 0 2px rgba(0,0,0,.25);}\n  .screw::before,.screw::after{content:\"\";position:absolute;left:50%;top:50%;background:#1a1b1e;border-radius:1px;}\n  .screw::before{width:14px;height:2.5px;transform:translate(-50%,-50%) rotate(var(--sl,28deg));}\n  .screw.t{top:16px}.screw.b{bottom:16px}\n\n  /* ---------- main faceplate ---------- */\n  .face{flex:1;position:relative;padding:16px 22px 14px;display:flex;flex-direction:column;}\n\n  .brand{display:flex;align-items:baseline;gap:10px;}\n  .brand .mark{\n    width:14px;height:14px;border-radius:3px;transform:rotate(45deg);\n    background:linear-gradient(135deg,var(--accent),var(--accent2));\n    box-shadow:0 0 10px var(--accent),0 0 3px #fff inset;align-self:center;}\n  .brand h1{margin:0;font-size:20px;font-weight:800;letter-spacing:3px;\n    background:linear-gradient(180deg,#fff,#aeb1b8);-webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 1px 0 rgba(0,0,0,.4);}\n  .brand .sub{margin-left:auto;font-size:9px;letter-spacing:3px;color:#8b8f97;font-weight:700;text-transform:uppercase;}\n  .pwr{width:8px;height:8px;border-radius:50%;background:var(--accent);\n    box-shadow:0 0 8px var(--accent),0 0 2px #fff inset;animation:pulse 2.4s ease-in-out infinite;align-self:center;}\n  @keyframes pulse{0%,100%{opacity:.55}50%{opacity:1}}\n\n  .body{flex:1;display:flex;gap:18px;margin-top:12px;}\n\n  /* ---------- VU meter ---------- */\n  .meter{flex:0 0 268px;position:relative;border-radius:8px;padding:8px;\n    background:linear-gradient(180deg,#1b1c1f,#0a0b0c);\n    border:1px solid #000;box-shadow:0 2px 6px rgba(0,0,0,.6) inset,0 1px 0 rgba(255,255,255,.08);}\n  .meter .glass{position:relative;height:178px;border-radius:6px;overflow:hidden;\n    background:radial-gradient(120% 150% at 50% 120%,#f3e7c4 0%,#e9d59a 45%,#d9be78 100%);\n    box-shadow:0 0 0 2px #0a0b0c, 0 6px 14px rgba(0,0,0,.5) inset;}\n  .meter svg{display:block;width:100%;height:100%;}\n  .meter .label{position:absolute;left:0;right:0;bottom:9px;text-align:center;\n    font-size:9px;letter-spacing:3px;color:#6b5a2e;font-weight:800;}\n  .meter .vu{position:absolute;left:50%;top:14px;transform:translateX(-50%);\n    font-size:12px;letter-spacing:6px;color:#7a6630;font-weight:800;}\n  /* glass reflection */\n  .meter .glass::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(125deg,rgba(255,255,255,.45),transparent 40%);}\n  .meter .gr{position:absolute;left:8px;bottom:8px;font-size:8px;letter-spacing:1px;color:#3aa;}\n\n  /* ---------- knob bank ---------- */\n  .knobs{flex:1;display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:1fr 1fr;\n    gap:8px 6px;align-content:center;}\n  .knob{position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;\n    padding:4px 2px;border-radius:7px;}\n  /* 5 knobs auto-flow into the 3x2 grid (last bottom-right cell stays empty) */\n  .dial{position:relative;width:74px;height:74px;cursor:grab;touch-action:none;}\n  .dial.drag{cursor:grabbing;}\n  .dial svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible;pointer-events:none;}\n  .cap{position:absolute;inset:9px;border-radius:50%;\n    background:\n      radial-gradient(circle at 38% 30%,#5b5f67,#33363c 55%,#1b1d20 100%);\n    box-shadow:0 4px 8px rgba(0,0,0,.6),0 1px 0 rgba(255,255,255,.18) inset,0 -3px 6px rgba(0,0,0,.5) inset;}\n  .cap::before{content:\"\";position:absolute;inset:0;border-radius:50%;\n    background:conic-gradient(from 0deg,rgba(255,255,255,.10),transparent 25%,rgba(0,0,0,.25) 50%,transparent 75%,rgba(255,255,255,.10));}\n  /* pointer notch on the cap */\n  .pointer{position:absolute;left:50%;top:8px;width:4px;height:20px;border-radius:2px;transform:translateX(-50%);\n    transform-origin:50% 29px;\n    background:linear-gradient(180deg,var(--accent),var(--accent2));\n    box-shadow:0 0 8px var(--accent),0 0 2px #fff;}\n  .ring{fill:none;stroke:#0c0d0f;stroke-width:5;}\n  .ringFill{fill:none;stroke:url(#kg);stroke-width:5;stroke-linecap:round;\n    filter:drop-shadow(0 0 3px var(--accent));transition:stroke-dashoffset .03s linear;}\n  .tick{stroke:#1d1f23;stroke-width:1.5;}\n  .name{font-size:9px;letter-spacing:2px;color:#cdd0d6;font-weight:800;text-transform:uppercase;text-shadow:0 1px 0 rgba(0,0,0,.5);}\n  .val{font-size:10px;font-weight:700;color:var(--accent);letter-spacing:.5px;\n    font-variant-numeric:tabular-nums;min-height:12px;}\n\n  .footer{display:flex;justify-content:space-between;align-items:center;margin-top:8px;\n    font-size:8px;letter-spacing:2px;color:#7d818a;font-weight:700;}\n  .footer .vents{display:flex;gap:4px;}\n  .footer .vents i{width:26px;height:5px;border-radius:3px;\n    background:linear-gradient(180deg,#15161a,#2a2c31);box-shadow:0 1px 0 rgba(255,255,255,.05);}\n\n  @media (max-width:780px){\n    .unit{transform:scale(.82);}\n  }\n</style>\n</head>\n<body>\n<div id=\"stage\">\n  <div class=\"unit\">\n    <!-- left ear -->\n    <div class=\"ear\">\n      <div class=\"screw t\" style=\"--sl:35deg\"></div>\n      <div class=\"screw b\" style=\"--sl:-15deg\"></div>\n    </div>\n\n    <!-- faceplate -->\n    <div class=\"face\">\n      <div class=\"brand\">\n        <span class=\"mark\"></span>\n        <h1>FET&nbsp;SQUEEZE</h1>\n        <span class=\"pwr\"></span>\n        <span class=\"sub\">peak&nbsp;compressor</span>\n      </div>\n\n      <div class=\"body\">\n        <!-- VU / gain-reduction meter -->\n        <div class=\"meter\">\n          <div class=\"glass\">\n            <svg viewBox=\"0 0 252 178\" id=\"vuSvg\">\n              <!-- scale arc -->\n              <path d=\"M26 150 A 120 120 0 0 1 226 150\" fill=\"none\" stroke=\"#8a7536\" stroke-width=\"2\"/>\n              <path d=\"M26 150 A 120 120 0 0 1 226 150\" fill=\"none\" stroke=\"#c0392b\" stroke-width=\"3\"\n                    stroke-dasharray=\"0 250 64 0\"/>\n              <g id=\"vuTicks\" stroke=\"#5a4d24\" stroke-width=\"2\"></g>\n              <text x=\"126\" y=\"92\" text-anchor=\"middle\" font-size=\"11\" font-weight=\"800\"\n                    fill=\"#7a6630\" letter-spacing=\"2\">GAIN&nbsp;REDUCTION</text>\n              <!-- needle -->\n              <g id=\"needle\" transform=\"rotate(-50 126 168)\">\n                <line x1=\"126\" y1=\"168\" x2=\"126\" y2=\"40\" stroke=\"#1a1208\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n                <line x1=\"126\" y1=\"168\" x2=\"126\" y2=\"44\" stroke=\"#b03028\" stroke-width=\"1.6\" stroke-linecap=\"round\"/>\n              </g>\n              <circle cx=\"126\" cy=\"168\" r=\"9\" fill=\"#2a2415\" stroke=\"#6b5a2e\" stroke-width=\"1.5\"/>\n              <circle cx=\"126\" cy=\"168\" r=\"3\" fill=\"#7a6630\"/>\n            </svg>\n            <div class=\"vu\">VU</div>\n            <div class=\"gr\" id=\"grReadout\">-0.0 dB</div>\n          </div>\n        </div>\n\n        <!-- knob bank -->\n        <div class=\"knobs\" id=\"knobs\"></div>\n      </div>\n\n      <div class=\"footer\">\n        <span>FET&nbsp;·&nbsp;CLASS-A&nbsp;DISCRETE</span>\n        <span class=\"vents\"><i></i><i></i><i></i><i></i></span>\n        <span>MADE&nbsp;BY&nbsp;VIBE</span>\n      </div>\n    </div>\n\n    <!-- right ear -->\n    <div class=\"ear right\">\n      <div class=\"screw t\" style=\"--sl:18deg\"></div>\n      <div class=\"screw b\" style=\"--sl:48deg\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- params from spec (indices are load-bearing) ----\n  var PARAMS = [\n    { name:\"Input\",   index:0, min:0, max:1, def:0.5, unit:\"dB\",  fmt:gainFmt },\n    { name:\"Attack\",  index:1, min:0, max:1, def:0.7, unit:\"ms\",  fmt:attackFmt },\n    { name:\"Release\", index:2, min:0, max:1, def:0.5, unit:\"ms\",  fmt:releaseFmt },\n    { name:\"Ratio\",   index:3, min:0, max:1, def:0.5, unit:\":1\",  fmt:ratioFmt },\n    { name:\"Output\",  index:4, min:0, max:1, def:0.5, unit:\"dB\",  fmt:gainFmt }\n  ];\n\n  // ---- value formatters (display only; setParam always gets raw [min,max]) ----\n  function gainFmt(v){ var db=(v*2-1)*24; return (db>=0?\"+\":\"\")+db.toFixed(1)+\" dB\"; }\n  function attackFmt(v){ var ms=0.05*Math.pow(2000,v); return ms<10?ms.toFixed(2)+\" ms\":ms.toFixed(0)+\" ms\"; }\n  function releaseFmt(v){ var ms=20*Math.pow(75,v); return ms<1000?ms.toFixed(0)+\" ms\":(ms/1000).toFixed(2)+\" s\"; }\n  function ratioFmt(v){ var r=2+v*18; return r.toFixed(1)+\":1\"; }\n\n  var ARC_START = -135, ARC_SWEEP = 270; // degrees\n\n  // current values keyed by index, for the meter sim\n  var state = {};\n\n  // ---- build VU ticks ----\n  (function(){\n    var g=document.getElementById(\"vuTicks\");\n    for(var i=0;i<=8;i++){\n      var a=(-50 + (i/8)*100) * Math.PI/180; // -50..+50 deg\n      var cx=126, cy=168, r1=118, r2=128;\n      var sx=cx+Math.sin(a)*r1, sy=cy-Math.cos(a)*r1;\n      var ex=cx+Math.sin(a)*r2, ey=cy-Math.cos(a)*r2;\n      var ln=document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      ln.setAttribute(\"x1\",sx.toFixed(1));ln.setAttribute(\"y1\",sy.toFixed(1));\n      ln.setAttribute(\"x2\",ex.toFixed(1));ln.setAttribute(\"y2\",ey.toFixed(1));\n      if(i>=6){ln.setAttribute(\"stroke\",\"#b03028\");ln.setAttribute(\"stroke-width\",\"3\");}\n      g.appendChild(ln);\n    }\n  })();\n\n  // ---- build knobs ----\n  var knobsEl = document.getElementById(\"knobs\");\n  var ARC_LEN = 2*Math.PI*30 * (ARC_SWEEP/360);\n\n  PARAMS.forEach(function(p){\n    state[p.index] = p.def;\n\n    var cell=document.createElement(\"div\"); cell.className=\"knob\";\n\n    var nm=document.createElement(\"div\"); nm.className=\"name\"; nm.textContent=p.name;\n\n    var dial=document.createElement(\"div\"); dial.className=\"dial\"; dial.dataset.idx=p.index;\n\n    dial.innerHTML =\n      '<svg viewBox=\"0 0 74 74\">'+\n        '<defs><linearGradient id=\"kg'+p.index+'\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n          '<stop offset=\"0\" stop-color=\"var(--accent)\"/>'+\n          '<stop offset=\"1\" stop-color=\"var(--accent2)\"/>'+\n        '</linearGradient></defs>'+\n        '<circle class=\"ring\" cx=\"37\" cy=\"37\" r=\"30\" '+\n          'stroke-dasharray=\"'+ARC_LEN+' 1000\" transform=\"rotate(135 37 37)\"/>'+\n        '<circle class=\"ringFill\" cx=\"37\" cy=\"37\" r=\"30\" stroke=\"url(#kg'+p.index+')\" '+\n          'stroke-dasharray=\"'+ARC_LEN+' 1000\" stroke-dashoffset=\"'+ARC_LEN+'\" '+\n          'transform=\"rotate(135 37 37)\"/>'+\n      '</svg>'+\n      '<div class=\"cap\"></div>'+\n      '<div class=\"pointer\"></div>';\n\n    var val=document.createElement(\"div\"); val.className=\"val\";\n\n    cell.appendChild(nm); cell.appendChild(dial); cell.appendChild(val);\n    knobsEl.appendChild(cell);\n\n    var fill = dial.querySelector(\".ringFill\");\n    var ptr  = dial.querySelector(\".pointer\");\n\n    function render(v){\n      var t=(v-p.min)/(p.max-p.min);\n      ptr.style.transform = \"translateX(-50%) rotate(\"+(ARC_START + t*ARC_SWEEP)+\"deg)\";\n      fill.setAttribute(\"stroke-dashoffset\", (ARC_LEN*(1-t)).toFixed(2));\n      val.textContent = p.fmt(v);\n    }\n\n    function commit(v){\n      v=Math.max(p.min,Math.min(p.max,v));\n      state[p.index]=v;\n      render(v);\n      if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.index,v);\n    }\n\n    // pointer-drag (vertical) — full travel ~ 220px\n    var dragging=false, startY=0, startV=0;\n    dial.addEventListener(\"pointerdown\",function(e){\n      dragging=true; startY=e.clientY; startV=state[p.index];\n      dial.classList.add(\"drag\"); dial.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    dial.addEventListener(\"pointermove\",function(e){\n      if(!dragging) return;\n      var dy=startY-e.clientY;\n      var range=p.max-p.min;\n      var fine=e.shiftKey?0.25:1;\n      commit(startV + (dy/220)*range*fine);\n    });\n    function end(e){ if(!dragging)return; dragging=false; dial.classList.remove(\"drag\");\n      try{dial.releasePointerCapture(e.pointerId);}catch(_){ } }\n    dial.addEventListener(\"pointerup\",end);\n    dial.addEventListener(\"pointercancel\",end);\n    dial.addEventListener(\"dblclick\",function(){ commit(p.def); });\n    dial.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      var step=(p.max-p.min)*0.04*(e.shiftKey?0.25:1);\n      commit(state[p.index] + (e.deltaY<0?step:-step));\n    },{passive:false});\n\n    p._render=render; p._commit=commit;\n  });\n\n  // ---- animated VU needle: react to Input/Ratio, idle sway ----\n  var needle=document.getElementById(\"needle\");\n  var grOut=document.getElementById(\"grReadout\");\n  var t0=performance.now();\n  var shownGR=0;\n  function loop(now){\n    var t=(now-t0)/1000;\n    // pseudo gain-reduction \"amount\" from settings + a musical wobble\n    var input = state[0], ratio = state[3];\n    var drive = input*0.85 + 0.15;\n    var ratioGain = 0.25 + ratio*0.75;\n    // target GR 0..1 with breathing + transient bumps\n    var breathe = 0.5 + 0.5*Math.sin(t*1.7);\n    var transient = Math.max(0, Math.sin(t*5.3)*Math.sin(t*2.1));\n    var target = drive*ratioGain*(0.35 + 0.4*breathe + 0.35*transient);\n    target = Math.max(0,Math.min(1,target));\n    // smooth toward target (asymmetric: fast attack, slow recover) influenced by Release knob\n    var rel = 0.02 + state[2]*0.10;\n    var k = target>shownGR ? 0.35 : rel;\n    shownGR += (target-shownGR)*k;\n    // map to needle angle -50..+50 deg\n    var ang = -50 + shownGR*100;\n    needle.setAttribute(\"transform\",\"rotate(\"+ang.toFixed(2)+\" 126 168)\");\n    grOut.textContent = \"-\"+(shownGR*18).toFixed(1)+\" dB\";\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n\n  // ---- init + host hook ----\n  function ready(){\n    PARAMS.forEach(function(p){\n      p._render(p.def);\n      if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.index,p.def);\n    });\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  FET SQUEEZE — fast FET-style peak compressor\n//  A very fast peak detector feeds a dB-domain gain computer with a\n//  selectable ratio and a soft knee, then a program-dependent release.\n//  Input drives how hard the signal hits the detector; Output is makeup\n//  gain. Loud transients are clamped hard and fast for that punchy,\n//  glued, in-your-face character. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (shared across channels for stereo-linked GR)\nlet envDb: f32 = 0.0;   // smoothed gain-reduction in dB (>= 0 means reducing by that much)\nlet peakEnv: f32 = 0.0; // fast peak follower of the (driven) detector signal\n\n// program-dependent release: a slower second stage that trails the fast one\nlet relSlow: f32 = 0.0;\n\nconst P_INPUT: i32 = 0;   // 0..1 -> drive into detector (how hard it hits)\nconst P_ATTACK: i32 = 1;  // 0..1 -> higher = faster (sub-ms..ms)\nconst P_RELEASE: i32 = 2; // 0..1 -> higher = faster\nconst P_RATIO: i32 = 3;   // 0..1 -> ~2:1 .. 20:1\nconst P_OUTPUT: i32 = 4;  // 0..1 -> makeup gain, default near unity\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  envDb = 0.0;\n  peakEnv = 0.0;\n  relSlow = 0.0;\n  params[P_INPUT]   = 0.5;\n  params[P_ATTACK]  = 0.7;\n  params[P_RELEASE] = 0.5;\n  params[P_RATIO]   = 0.5;\n  params[P_OUTPUT]  = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linear amplitude -> dB, guarded\n@inline function lin2db(x: f32): f32 {\n  const a: f32 = x > 1e-7 ? x : f32(1e-7);\n  return f32(20.0 * Mathf.log10(a));\n}\n// dB -> linear amplitude\n@inline function db2lin(d: f32): f32 {\n  return f32(Mathf.pow(10.0, d * f32(0.05)));\n}\n\n// one-pole time-constant -> per-sample coefficient (guarded)\n@inline function tcCoeff(ms: f32, sr: f32): f32 {\n  const t: f32 = ms > 0.01 ? ms : f32(0.01);\n  return f32(1.0 - Mathf.exp(-1.0 / (f32(0.001) * t * sr)));\n}\n\nexport function process(n: i32): void {\n  const inputN: f32   = clampf(params[P_INPUT], 0.0, 1.0);\n  const attackN: f32  = clampf(params[P_ATTACK], 0.0, 1.0);\n  const releaseN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const ratioN: f32   = clampf(params[P_RATIO], 0.0, 1.0);\n  const outputN: f32  = clampf(params[P_OUTPUT], 0.0, 1.0);\n\n  // Input drive: 0..1 -> -6..+30 dB into the detector. More drive => more GR.\n  const driveDb: f32 = f32(-6.0) + inputN * f32(36.0);\n  const drive: f32 = db2lin(driveDb);\n\n  // Fixed FET-style threshold; the Input knob pushes the signal past it.\n  const threshDb: f32 = f32(-22.0);\n  const kneeDb: f32 = f32(6.0); // soft knee width\n\n  // Ratio ~2:1 .. 20:1\n  const ratio: f32 = f32(2.0) + ratioN * f32(18.0);\n  const slope: f32 = f32(1.0) - f32(1.0) / ratio; // 0..~0.95\n\n  // Attack: higher = faster. 0 -> 8 ms, 1 -> ~0.05 ms (sub-ms, FET-fast).\n  const atkMs: f32 = f32(8.0) * f32(Mathf.pow(160.0, -attackN));\n  // Release fast stage: higher = faster. 0 -> 800 ms, 1 -> ~30 ms.\n  const relMs: f32 = f32(800.0) * f32(Mathf.pow(26.7, -releaseN));\n  // program-dependent slow release stage (a few times slower, capped)\n  const relSlowMs: f32 = relMs * f32(6.0);\n\n  const atkC: f32 = tcCoeff(atkMs, sampleRate);\n  const relC: f32 = tcCoeff(relMs, sampleRate);\n  const relSlowC: f32 = tcCoeff(relSlowMs, sampleRate);\n\n  // peak detector smoothing (very fast — defines the \"peak\" feel)\n  const peakC: f32 = tcCoeff(f32(0.05), sampleRate);\n\n  // makeup gain: 0..1 -> -12..+24 dB. Default 0.5 -> ~ +6 dB (near unity\n  // perceived after typical GR). Keep headroom so broadband bed stays < 1.\n  const makeupDb: f32 = f32(-12.0) + outputN * f32(36.0);\n  const makeup: f32 = db2lin(makeupDb);\n\n  let env: f32 = envDb;\n  let pk: f32 = peakEnv;\n  let rs: f32 = relSlow;\n\n  for (let f = 0; f < n; f++) {\n    // stereo-linked detection: max abs across channels, then drive it\n    let det: f32 = 0.0;\n    for (let c = 0; c < channels; c++) {\n      const a: f32 = Mathf.abs(inBuf[c * MAX_FRAMES + f]);\n      if (a > det) det = a;\n    }\n    det = det * drive;\n\n    // fast peak follower (instant attack, quick release)\n    if (det > pk) pk = det;\n    else pk = pk + peakC * (det - pk);\n\n    // dB-domain gain computer with soft knee\n    const inDb: f32 = lin2db(pk);\n    const over: f32 = inDb - threshDb;\n    let grTarget: f32 = 0.0; // desired gain reduction (dB, >= 0)\n    if (over <= -kneeDb * f32(0.5)) {\n      grTarget = 0.0;\n    } else if (over >= kneeDb * f32(0.5)) {\n      grTarget = slope * over;\n    } else {\n      // quadratic soft knee\n      const x: f32 = over + kneeDb * f32(0.5);\n      grTarget = slope * f32(x * x) / (f32(2.0) * kneeDb);\n    }\n    if (grTarget < 0.0) grTarget = 0.0;\n\n    // attack / release ballistics in the dB (gain-reduction) domain.\n    // program-dependent release: env trails the slower of two release stages.\n    if (grTarget > env) {\n      // attacking: snap down fast\n      env = env + atkC * (grTarget - env);\n      rs = env; // keep slow stage primed during attack\n    } else {\n      // releasing: fast stage chases target, slow stage lags behind,\n      // and we release toward the slower (higher) of the two for that\n      // characteristic auto-release recovery.\n      const fast: f32 = env + relC * (grTarget - env);\n      rs = rs + relSlowC * (grTarget - rs);\n      env = fast > rs ? fast : rs;\n    }\n    if (env < 0.0) env = 0.0;\n\n    // apply: gain = makeup * 10^(-env/20)\n    const grLin: f32 = db2lin(-env);\n    const g: f32 = grLin * makeup;\n\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      outBuf[base + f] = f32(inBuf[base + f] * g);\n    }\n  }\n\n  envDb = env;\n  peakEnv = pk;\n  relSlow = rs;\n}\n",
  "publishedAt": 1751000004000
}