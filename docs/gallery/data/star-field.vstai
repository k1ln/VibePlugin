{
  "format": 1,
  "name": "Star Field",
  "isInstrument": false,
  "explanation": "A multitap space reverb. A network of discrete, scattered early-reflection taps pings outward across the stereo field and then blossoms into a diffuse, gently modulated ambient tail — a constellation of reflections decaying into deep space rather than a smooth hall. Controls: Size, Taps/Spread, Decay, Modulation and dry/wet Mix.",
  "params": [
    {
      "name": "Size",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Taps/Spread",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Modulation",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Star Field</title>\n<style>\n  :root {\n    --accent: #7a8cff;\n    --accent2: #54d1ff;\n    --vector: #54f1a8;      /* retro sci-fi vector green */\n    --vector-dim: #1d6b4c;\n    --bg0: #04060f;\n    --bg1: #0a1020;\n    --panel: #0c1226;\n    --line: rgba(122,140,255,0.14);\n    --ink: #cfd8ff;\n    --ink-dim: #6b76a8;\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background: radial-gradient(120% 90% at 50% -10%, #0d1530 0%, var(--bg0) 70%);\n    color: var(--ink);\n    min-height: 100%;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 16px;\n  }\n\n  .station {\n    width: 100%;\n    max-width: 720px;\n    background:\n      linear-gradient(180deg, rgba(20,28,56,0.9), rgba(8,12,28,0.95));\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    box-shadow:\n      0 30px 80px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(160,180,255,0.08);\n    overflow: hidden;\n    position: relative;\n  }\n\n  /* ---------- header ---------- */\n  .head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 14px 20px;\n    border-bottom: 1px solid var(--line);\n    background: linear-gradient(180deg, rgba(122,140,255,0.07), transparent);\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .sigil {\n    width: 34px; height: 34px;\n    position: relative;\n    flex: none;\n  }\n  .sigil svg { display: block; }\n  .sigil .core { transform-origin: 17px 17px; animation: spin 14s linear infinite; }\n\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  .title {\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .subtitle {\n    font-size: 9.5px;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 2px;\n  }\n\n  .status {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 9px;\n    letter-spacing: 0.3em;\n    text-transform: uppercase;\n    color: var(--vector);\n    font-variant-numeric: tabular-nums;\n  }\n  .status .dot {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--vector);\n    box-shadow: 0 0 8px var(--vector);\n    animation: blink 2.2s ease-in-out infinite;\n  }\n  @keyframes blink { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }\n\n  /* ---------- radar / starfield viewport ---------- */\n  .scope {\n    position: relative;\n    margin: 16px;\n    height: 240px;\n    border: 1px solid rgba(84,241,168,0.18);\n    border-radius: 12px;\n    background:\n      radial-gradient(120% 140% at 50% 120%, rgba(84,241,168,0.05), transparent 60%),\n      linear-gradient(180deg, #030810, #02060c);\n    overflow: hidden;\n    cursor: crosshair;\n  }\n  .scope canvas { position: absolute; inset: 0; width: 100%; height: 100%; }\n\n  .scope .scan {\n    position: absolute; inset: 0;\n    background: linear-gradient(180deg, transparent, rgba(84,241,168,0.06) 50%, transparent);\n    height: 40%;\n    animation: scan 5.5s linear infinite;\n    mix-blend-mode: screen;\n    pointer-events: none;\n  }\n  @keyframes scan {\n    0% { transform: translateY(-120%); }\n    100% { transform: translateY(360%); }\n  }\n\n  .readout {\n    position: absolute;\n    left: 12px; bottom: 10px;\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    color: var(--vector);\n    text-shadow: 0 0 6px rgba(84,241,168,0.5);\n    font-variant-numeric: tabular-nums;\n    pointer-events: none;\n    line-height: 1.6;\n  }\n  .readout span { color: #aef7d4; }\n\n  .vlabel {\n    position: absolute;\n    right: 12px; top: 10px;\n    font-size: 8.5px;\n    letter-spacing: 0.3em;\n    color: var(--vector-dim);\n    text-transform: uppercase;\n    pointer-events: none;\n  }\n\n  /* ---------- controls ---------- */\n  .deck {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 8px;\n    padding: 6px 16px 22px;\n  }\n  @media (max-width: 560px) {\n    .deck { grid-template-columns: repeat(3, 1fr); }\n  }\n\n  .cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    padding: 14px 6px 12px;\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(122,140,255,0.04), rgba(0,0,0,0.18));\n  }\n\n  .knob {\n    position: relative;\n    width: 84px; height: 84px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob svg { display: block; overflow: visible; }\n\n  .knob .face {\n    fill: url(#knobGrad);\n    stroke: rgba(160,180,255,0.18);\n    stroke-width: 1;\n  }\n  .knob .pointer {\n    stroke: var(--accent2);\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    filter: drop-shadow(0 0 4px var(--accent2));\n  }\n  .knob .arc-bg { stroke: rgba(122,140,255,0.16); }\n  .knob .arc {\n    stroke: url(#arcGrad);\n    filter: drop-shadow(0 0 5px rgba(84,209,255,0.55));\n    transition: stroke-dashoffset 0.04s linear;\n  }\n  .knob:hover .arc { filter: drop-shadow(0 0 9px rgba(84,209,255,0.9)); }\n\n  .name {\n    font-size: 9.5px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n  }\n  .val {\n    font-size: 12px;\n    font-weight: 600;\n    color: var(--accent2);\n    font-variant-numeric: tabular-nums;\n    text-shadow: 0 0 8px rgba(84,209,255,0.35);\n  }\n\n  .foot {\n    border-top: 1px solid var(--line);\n    padding: 8px 20px 12px;\n    display: flex;\n    justify-content: space-between;\n    font-size: 8px;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n</style>\n</head>\n<body>\n  <div class=\"station\">\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"sigil\">\n          <svg width=\"34\" height=\"34\" viewBox=\"0 0 34 34\">\n            <circle cx=\"17\" cy=\"17\" r=\"15.5\" fill=\"none\" stroke=\"rgba(122,140,255,0.35)\" stroke-width=\"1\"/>\n            <g class=\"core\">\n              <circle cx=\"17\" cy=\"17\" r=\"3.4\" fill=\"#54d1ff\"/>\n              <circle cx=\"17\" cy=\"4\" r=\"1.6\" fill=\"#7a8cff\"/>\n              <circle cx=\"29\" cy=\"20\" r=\"1.3\" fill=\"#54f1a8\"/>\n              <circle cx=\"6\" cy=\"22\" r=\"1.2\" fill=\"#7a8cff\"/>\n              <line x1=\"17\" y1=\"17\" x2=\"17\" y2=\"4\" stroke=\"rgba(84,209,255,0.4)\" stroke-width=\"0.7\"/>\n              <line x1=\"17\" y1=\"17\" x2=\"29\" y2=\"20\" stroke=\"rgba(84,209,255,0.3)\" stroke-width=\"0.7\"/>\n            </g>\n          </svg>\n        </div>\n        <div>\n          <div class=\"title\">Star Field</div>\n          <div class=\"subtitle\">Multitap Space Station</div>\n        </div>\n      </div>\n      <div class=\"status\"><span class=\"dot\"></span> Online</div>\n    </div>\n\n    <div class=\"scope\" id=\"scope\">\n      <canvas id=\"cv\"></canvas>\n      <div class=\"scan\"></div>\n      <div class=\"vlabel\">SECTOR // RVB-01</div>\n      <div class=\"readout\">\n        FIELD DEPTH <span id=\"roSize\">0.00</span> &nbsp; SPREAD <span id=\"roSpread\">0.00</span><br>\n        DECAY <span id=\"roDecay\">0.00</span> &nbsp; DRIFT <span id=\"roMod\">0.00</span> &nbsp; MIX <span id=\"roMix\">0.00</span>\n      </div>\n    </div>\n\n    <div class=\"deck\" id=\"deck\"></div>\n\n    <div class=\"foot\">\n      <span>Drag &middot; Wheel fine &middot; Dbl-click reset</span>\n      <span>Vector Reverb Array</span>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  var PARAMS = [\n    { name: \"Size\",   index: 0, min: 0, max: 1, def: 0.55 },\n    { name: \"Spread\", index: 1, min: 0, max: 1, def: 0.70 },\n    { name: \"Decay\",  index: 2, min: 0, max: 1, def: 0.55 },\n    { name: \"Drift\",  index: 3, min: 0, max: 1, def: 0.35 },\n    { name: \"Mix\",    index: 4, min: 0, max: 1, def: 0.35 }\n  ];\n\n  var state = PARAMS.map(function (p) { return p.def; });\n\n  // ----- host bridge ------------------------------------------------\n  function push(idx, val) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(idx, val);\n    }\n  }\n\n  // ----- shared SVG defs (knob gradients) ---------------------------\n  var SVG_DEFS =\n    '<defs>' +\n    '<radialGradient id=\"knobGrad\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n      '<stop offset=\"0%\" stop-color=\"#2a3566\"/>' +\n      '<stop offset=\"55%\" stop-color=\"#141b38\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#070b1c\"/>' +\n    '</radialGradient>' +\n    '<linearGradient id=\"arcGrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n      '<stop offset=\"0%\" stop-color=\"#7a8cff\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#54d1ff\"/>' +\n    '</linearGradient>' +\n    '</defs>';\n\n  // arc geometry\n  var R = 33, CX = 42, CY = 42;\n  var A0 = 135, A1 = 405; // sweep degrees (270deg gap at bottom)\n  var ARC_LEN = 2 * Math.PI * R * ((A1 - A0) / 360);\n\n  function polar(deg) {\n    var a = deg * Math.PI / 180;\n    return { x: CX + R * Math.cos(a), y: CY + R * Math.sin(a) };\n  }\n\n  function arcPath() {\n    var s = polar(A0), e = polar(A1);\n    var large = (A1 - A0) > 180 ? 1 : 0;\n    return \"M \" + s.x.toFixed(2) + \" \" + s.y.toFixed(2) +\n           \" A \" + R + \" \" + R + \" 0 \" + large + \" 1 \" + e.x.toFixed(2) + \" \" + e.y.toFixed(2);\n  }\n\n  var deck = document.getElementById(\"deck\");\n  var knobs = [];\n\n  PARAMS.forEach(function (p, i) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    var path = arcPath();\n    knob.innerHTML =\n      '<svg width=\"84\" height=\"84\" viewBox=\"0 0 84 84\">' +\n        SVG_DEFS +\n        '<path class=\"arc-bg\" d=\"' + path + '\" fill=\"none\" stroke-width=\"4\" stroke-linecap=\"round\"/>' +\n        '<path class=\"arc\" d=\"' + path + '\" fill=\"none\" stroke-width=\"4\" stroke-linecap=\"round\" ' +\n          'stroke-dasharray=\"' + ARC_LEN.toFixed(2) + '\" stroke-dashoffset=\"' + ARC_LEN.toFixed(2) + '\"/>' +\n        '<circle class=\"face\" cx=\"42\" cy=\"42\" r=\"26\"/>' +\n        '<line class=\"pointer\" x1=\"42\" y1=\"42\" x2=\"42\" y2=\"22\" transform=\"rotate(0 42 42)\"/>' +\n        '<circle cx=\"42\" cy=\"42\" r=\"3\" fill=\"#54d1ff\"/>' +\n      '</svg>';\n\n    var nm = document.createElement(\"div\");\n    nm.className = \"name\";\n    nm.textContent = p.name;\n\n    var vv = document.createElement(\"div\");\n    vv.className = \"val\";\n    vv.textContent = p.def.toFixed(2);\n\n    cell.appendChild(knob);\n    cell.appendChild(nm);\n    cell.appendChild(vv);\n    deck.appendChild(cell);\n\n    var arc = knob.querySelector(\".arc\");\n    var ptr = knob.querySelector(\".pointer\");\n\n    function render() {\n      var v = state[i];\n      var frac = (v - p.min) / (p.max - p.min);\n      arc.setAttribute(\"stroke-dashoffset\", (ARC_LEN * (1 - frac)).toFixed(2));\n      var deg = A0 + (A1 - A0) * frac;\n      // pointer points outward along the arc angle\n      ptr.setAttribute(\"transform\", \"rotate(\" + (deg + 90).toFixed(1) + \" 42 42)\");\n      vv.textContent = v.toFixed(2);\n    }\n\n    function setVal(v) {\n      if (v < p.min) v = p.min;\n      if (v > p.max) v = p.max;\n      state[i] = v;\n      push(p.index, v);\n      render();\n    }\n\n    // drag (vertical)\n    var dragging = false, lastY = 0;\n    knob.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; lastY = e.clientY;\n      knob.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    knob.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.clientY;\n      lastY = e.clientY;\n      var span = p.max - p.min;\n      setVal(state[i] + dy / 180 * span);\n    });\n    knob.addEventListener(\"pointerup\", function (e) {\n      dragging = false;\n      try { knob.releasePointerCapture(e.pointerId); } catch (err) {}\n    });\n    knob.addEventListener(\"dblclick\", function () { setVal(p.def); });\n    knob.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var span = p.max - p.min;\n      setVal(state[i] - Math.sign(e.deltaY) * span * 0.01);\n    }, { passive: false });\n\n    knobs.push({ p: p, render: render, setVal: setVal });\n    render();\n  });\n\n  // ----- starfield / multitap radar canvas --------------------------\n  var cv = document.getElementById(\"cv\");\n  var ctx = cv.getContext(\"2d\");\n  var W = 0, H = 0, DPR = 1;\n\n  function resize() {\n    DPR = window.devicePixelRatio || 1;\n    var r = cv.getBoundingClientRect();\n    W = r.width; H = r.height;\n    cv.width = Math.max(1, Math.round(W * DPR));\n    cv.height = Math.max(1, Math.round(H * DPR));\n    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);\n  }\n  window.addEventListener(\"resize\", resize);\n\n  // background stars\n  var stars = [];\n  for (var s = 0; s < 90; s++) {\n    stars.push({\n      x: Math.random(), y: Math.random(),\n      z: 0.3 + Math.random() * 0.7,\n      tw: Math.random() * 6.28\n    });\n  }\n\n  // pings: discrete echoes that expand outward from the centre\n  var pings = [];\n  var pingTimer = 0;\n\n  function spawnPing(t) {\n    var size = state[0], spread = state[1], mix = state[4];\n    var n = Math.round(3 + spread * 9); // density of taps\n    for (var k = 0; k < n; k++) {\n      var ang = (k / n) * Math.PI * 2 + (Math.random() - 0.5) * 0.6;\n      // spread widens the horizontal fan\n      var wob = 0.5 + spread * 1.2;\n      pings.push({\n        born: t,\n        ang: ang,\n        wob: wob,\n        speed: 0.18 + size * 0.5,\n        life: 1.6 + state[2] * 3.2,    // decay -> longer-lived\n        amp: (0.5 + mix * 0.5) * (1 - k / (n + 4))\n      });\n    }\n  }\n\n  var ro = {\n    Size: document.getElementById(\"roSize\"),\n    Spread: document.getElementById(\"roSpread\"),\n    Decay: document.getElementById(\"roDecay\"),\n    Mod: document.getElementById(\"roMod\"),\n    Mix: document.getElementById(\"roMix\")\n  };\n\n  var running = true;\n  var startT = performance.now();\n\n  function frame(now) {\n    if (!running) return;\n    var t = (now - startT) / 1000;\n\n    if (W === 0) resize();\n    ctx.clearRect(0, 0, W, H);\n\n    var size = state[0], spread = state[1], decay = state[2], mod = state[3], mix = state[4];\n\n    // horizon grid (perspective floor)\n    var hy = H * 0.62;\n    ctx.strokeStyle = \"rgba(84,241,168,0.12)\";\n    ctx.lineWidth = 1;\n    var rows = 7;\n    for (var g = 0; g <= rows; g++) {\n      var f = g / rows;\n      var y = hy + (H - hy) * f * f;\n      ctx.globalAlpha = 0.4 * (1 - f) + 0.1;\n      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();\n    }\n    var cols = 12;\n    for (var c2 = 0; c2 <= cols; c2++) {\n      var fx = c2 / cols - 0.5;\n      ctx.globalAlpha = 0.16;\n      ctx.beginPath();\n      ctx.moveTo(W / 2 + fx * W * 0.18, hy);\n      ctx.lineTo(W / 2 + fx * W * 1.6, H);\n      ctx.stroke();\n    }\n    ctx.globalAlpha = 1;\n\n    // twinkling stars, drifting with Drift/mod\n    var drift = t * (0.005 + mod * 0.05);\n    for (var i = 0; i < stars.length; i++) {\n      var st = stars[i];\n      var sx = ((st.x + drift * st.z) % 1) * W;\n      var sy = st.y * hy;\n      var tw = 0.5 + 0.5 * Math.sin(t * (1 + st.z) + st.tw);\n      var rad = st.z * 1.4;\n      ctx.fillStyle = \"rgba(180,200,255,\" + (0.25 + 0.55 * tw * st.z) + \")\";\n      ctx.beginPath(); ctx.arc(sx, sy, rad, 0, 6.28); ctx.fill();\n    }\n\n    // central station core glow\n    var cx = W / 2, cy = hy;\n    var pulse = 0.5 + 0.5 * Math.sin(t * 2.2);\n    var grd = ctx.createRadialGradient(cx, cy, 0, cx, cy, 26 + pulse * 8);\n    grd.addColorStop(0, \"rgba(84,209,255,0.55)\");\n    grd.addColorStop(1, \"rgba(84,209,255,0)\");\n    ctx.fillStyle = grd;\n    ctx.beginPath(); ctx.arc(cx, cy, 30, 0, 6.28); ctx.fill();\n    ctx.fillStyle = \"#7a8cff\";\n    ctx.beginPath(); ctx.arc(cx, cy, 3.2, 0, 6.28); ctx.fill();\n\n    // spawn pings at a rate tied to size (bigger space = slower revolutions)\n    pingTimer += 0.016;\n    var interval = 0.55 + size * 0.7;\n    if (pingTimer >= interval) {\n      pingTimer = 0;\n      spawnPing(t);\n    }\n\n    // draw + advance pings (the multitap echoes)\n    var maxR = Math.min(W, H) * 0.7;\n    for (var pidx = pings.length - 1; pidx >= 0; pidx--) {\n      var pg = pings[pidx];\n      var age = t - pg.born;\n      if (age > pg.life) { pings.splice(pidx, 1); continue; }\n      var prog = age / pg.life;\n      var rr = age * pg.speed * maxR;\n      var px = cx + Math.cos(pg.ang) * rr * pg.wob;\n      var py = cy + Math.sin(pg.ang) * rr * 0.55; // flatten vertically toward horizon\n      var a = pg.amp * (1 - prog);\n      // tap dot\n      ctx.fillStyle = \"rgba(84,241,168,\" + a + \")\";\n      ctx.shadowColor = \"rgba(84,241,168,0.9)\";\n      ctx.shadowBlur = 8 * a;\n      ctx.beginPath(); ctx.arc(px, py, 2 + a * 2.5, 0, 6.28); ctx.fill();\n      // faint trail back toward core\n      ctx.shadowBlur = 0;\n      ctx.strokeStyle = \"rgba(122,140,255,\" + (a * 0.35) + \")\";\n      ctx.lineWidth = 1;\n      ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(px, py); ctx.stroke();\n    }\n    ctx.shadowBlur = 0;\n\n    // readout\n    ro.Size.textContent = size.toFixed(2);\n    ro.Spread.textContent = spread.toFixed(2);\n    ro.Decay.textContent = decay.toFixed(2);\n    ro.Mod.textContent = mod.toFixed(2);\n    ro.Mix.textContent = mix.toFixed(2);\n\n    requestAnimationFrame(frame);\n  }\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (document.hidden) {\n      running = false;\n    } else if (!running) {\n      running = true;\n      startT = performance.now() - 0;\n      requestAnimationFrame(frame);\n    }\n  });\n\n  // ----- init: push defaults to engine ------------------------------\n  function boot() {\n    resize();\n    for (var i = 0; i < PARAMS.length; i++) {\n      push(PARAMS[i].index, state[i]);\n    }\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STAR FIELD — a multitap \"space\" reverb\n//  An early-reflection multitap delay network (discrete, scattered taps\n//  that \"ping\" outward across the stereo field) feeding a diffuse modulated\n//  tail (an 8-line feedback delay network with allpass diffusion and slow\n//  per-line LFOs for a spacey, shimmering blossom). The character is NOT a\n//  smooth hall — it is a constellation of discrete reflections that decay\n//  into deep ambient space.\n//\n//  Controls: Size, Taps/Spread, Decay, Modulation, Mix.\n//  Pure algorithm, no samples, all f32, allocation-free process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831855;\n\n// ---- multitap early-reflection delay line (mono send -> scattered taps) ----\nconst TAP_CAP: i32 = 65536;   // ~1.36 s @ 48k headroom for tap spread * size\nconst tapBuf: StaticArray<f32> = new StaticArray<f32>(TAP_CAP);\nlet tapPos: i32 = 0;\n\nconst NTAPS: i32 = 12;\n// base tap delays in samples @48k (prime-ish, irregular so taps don't comb)\nconst tapBase: StaticArray<i32> = new StaticArray<i32>(NTAPS);\n// per-tap stereo pan (-1 left .. +1 right) and a base gain\nconst tapPan:  StaticArray<f32> = new StaticArray<f32>(NTAPS);\nconst tapGain: StaticArray<f32> = new StaticArray<f32>(NTAPS);\n\n// ---- diffuse FDN tail ----\nconst NLINES: i32 = 8;\nconst LINE_CAP: i32 = 16384;\nconst lines: StaticArray<f32> = new StaticArray<f32>(NLINES * LINE_CAP);\nconst linePos:  StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineLen:  StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineGain: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst damp:     StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst lfoPh:    StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst lfoInc:   StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst baseLen:  StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst outs:     StaticArray<f32> = new StaticArray<f32>(NLINES);\n\n// ---- input diffusion allpasses (smear the send before the FDN) ----\nconst NAP: i32 = 4;\nconst AP_CAP: i32 = 2048;\nconst ap: StaticArray<f32> = new StaticArray<f32>(NAP * AP_CAP);\nconst apPos:  StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apLen:  StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apBase: StaticArray<i32> = new StaticArray<i32>(NAP);\n\nconst P_SIZE:  i32 = 0;  // 0..1 -> scales tap times and tail line lengths\nconst P_SPREAD: i32 = 1; // 0..1 -> stereo spread + how many taps active (density)\nconst P_DECAY: i32 = 2;  // 0..1 -> tail RT60\nconst P_MOD:   i32 = 3;  // 0..1 -> shimmer modulation depth of tail taps\nconst P_MIX:   i32 = 4;  // 0..1 -> dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  // scattered, irregular early-reflection tap times (samples @48k)\n  tapBase[0]  = 563;   tapBase[1]  = 1129;  tapBase[2]  = 1801;  tapBase[3]  = 2477;\n  tapBase[4]  = 3251;  tapBase[5]  = 4099;  tapBase[6]  = 5023;  tapBase[7]  = 6121;\n  tapBase[8]  = 7253;  tapBase[9]  = 8669;  tapBase[10] = 10193; tapBase[11] = 12101;\n\n  // pan each tap across the field; alternate sides and widen with index\n  for (let i = 0; i < NTAPS; i++) {\n    const side: f32 = ((i & 1) == 0) ? -1.0 : 1.0;\n    const widen: f32 = 0.25 + f32(i) / f32(NTAPS) * 0.75;\n    tapPan[i] = side * widen;\n    // later taps a touch quieter (reflections lose energy with path length)\n    tapGain[i] = f32(0.95 - f32(i) * 0.045);\n    if (tapGain[i] < 0.25) tapGain[i] = 0.25;\n  }\n\n  baseLen[0] = 887;  baseLen[1] = 1153; baseLen[2] = 1373; baseLen[3] = 1789;\n  baseLen[4] = 1993; baseLen[5] = 2143; baseLen[6] = 2477; baseLen[7] = 2917;\n  apBase[0] = 167; apBase[1] = 353; apBase[2] = 113; apBase[3] = 293;\n\n  for (let i = 0; i < NLINES; i++) {\n    linePos[i] = 0; damp[i] = 0.0; lineLen[i] = baseLen[i]; lineGain[i] = 0.0;\n    lfoPh[i] = f32(i) * 0.41;\n    lfoInc[i] = (0.18 + f32(i) * 0.07) * TWO_PI / sampleRate; // 0.18..0.67 Hz slow drift\n  }\n  for (let i = 0; i < NAP; i++) { apPos[i] = 0; apLen[i] = apBase[i]; }\n\n  for (let i = 0; i < NLINES * LINE_CAP; i++) lines[i] = 0.0;\n  for (let i = 0; i < NAP * AP_CAP; i++) ap[i] = 0.0;\n  for (let i = 0; i < TAP_CAP; i++) tapBuf[i] = 0.0;\n  tapPos = 0;\n\n  params[P_SIZE]   = 0.55;\n  params[P_SPREAD] = 0.70;\n  params[P_DECAY]  = 0.55;\n  params[P_MOD]    = 0.35;\n  params[P_MIX]    = 0.35;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function allpass(i: i32, x: f32): f32 {\n  const base: i32 = i * AP_CAP;\n  let p: i32 = apPos[i];\n  const buffered: f32 = ap[base + p];\n  const y: f32 = buffered - x;\n  ap[base + p] = x + buffered * 0.5;\n  p++; if (p >= apLen[i]) p = 0;\n  apPos[i] = p;\n  return y;\n}\n\n// fractional, interpolated read from a tail line's ring buffer, `d` behind write\n@inline function readFrac(line: i32, d: f32): f32 {\n  const base: i32 = line * LINE_CAP;\n  const wp: i32 = linePos[line];\n  let di: i32 = i32(d);\n  const fr: f32 = d - f32(di);\n  let a: i32 = wp - di; while (a < 0) a += LINE_CAP; if (a >= LINE_CAP) a -= LINE_CAP;\n  let b: i32 = a - 1; if (b < 0) b += LINE_CAP;\n  return lines[base + a] * (1.0 - fr) + lines[base + b] * fr;\n}\n\n// read the multitap line `d` samples behind its write head (no interpolation)\n@inline function readTap(d: i32): f32 {\n  let a: i32 = tapPos - d;\n  while (a < 0) a += TAP_CAP;\n  if (a >= TAP_CAP) a -= TAP_CAP;\n  return tapBuf[a];\n}\n\nexport function process(n: i32): void {\n  const size: f32   = clampf(params[P_SIZE],   0.0, 1.0);\n  const spread: f32 = clampf(params[P_SPREAD], 0.0, 1.0);\n  const decay: f32  = clampf(params[P_DECAY],  0.0, 1.0);\n  const modAmt: f32 = clampf(params[P_MOD],    0.0, 1.0);\n  const mix: f32    = clampf(params[P_MIX],    0.0, 1.0);\n\n  const srRatio: f32 = sampleRate / 48000.0;\n\n  // Size: 0.35..1.4 scale on tap and line lengths -> small room to huge space\n  const sizeScale: f32 = 0.35 + size * 1.05;\n\n  // tail RT60 driven by Decay\n  const rt60: f32 = 0.25 + decay * decay * 11.0;\n  const ln1000: f32 = 6.9077553;\n\n  for (let i = 0; i < NLINES; i++) {\n    let L: i32 = i32(f32(baseLen[i]) * sizeScale * srRatio);\n    if (L < 8) L = 8; if (L >= LINE_CAP - 4) L = LINE_CAP - 4;\n    lineLen[i] = L;\n    const tSec: f32 = f32(L) / sampleRate;\n    lineGain[i] = f32(Mathf.exp(-ln1000 * tSec / rt60));\n  }\n  for (let i = 0; i < NAP; i++) {\n    let L: i32 = i32(f32(apBase[i]) * srRatio);\n    if (L < 1) L = 1; if (L >= AP_CAP) L = AP_CAP - 1;\n    apLen[i] = L;\n  }\n\n  // Spread controls both the stereo width of taps AND how many taps \"open up\"\n  // (density). At 0 only the first few near taps fire (tight cluster); at 1 all\n  // taps fan out wide across deep space.\n  const activeF: f32 = 3.0 + spread * f32(NTAPS - 3);\n  const widthAmt: f32 = 0.15 + spread * 0.85;\n\n  // shimmer modulation depth (samples) of the tail read taps\n  const modDepth: f32 = modAmt * 18.0 * srRatio;\n\n  const erScale: f32 = 0.5;   // early-reflection level into the wet bus\n  const tailScale: f32 = 0.28; // FDN tail output level\n\n  for (let f = 0; f < n; f++) {\n    const l: f32 = inBuf[f];\n    const r: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : l;\n    const monoIn: f32 = (l + r) * 0.5;\n\n    // write the dry send into the multitap line\n    tapBuf[tapPos] = monoIn;\n\n    // ---- early reflections: discrete scattered taps, panned ----\n    let erL: f32 = 0.0;\n    let erR: f32 = 0.0;\n    let tailFeed: f32 = 0.0;\n    for (let i = 0; i < NTAPS; i++) {\n      // smooth on/off of each tap based on Spread (density)\n      let amt: f32 = activeF - f32(i);\n      if (amt > 1.0) amt = 1.0;\n      if (amt < 0.0) amt = 0.0;\n      if (amt <= 0.0) continue;\n\n      let d: i32 = i32(f32(tapBase[i]) * sizeScale * srRatio);\n      if (d < 1) d = 1; if (d >= TAP_CAP) d = TAP_CAP - 1;\n      const tv: f32 = readTap(d) * tapGain[i] * amt;\n\n      // equal-power-ish pan from tapPan widened by Spread\n      const pan: f32 = clampf(tapPan[i] * widthAmt, -1.0, 1.0);\n      const gL: f32 = 0.5 * (1.0 - pan);\n      const gR: f32 = 0.5 * (1.0 + pan);\n      erL += tv * gL;\n      erR += tv * gR;\n      tailFeed += tv;\n    }\n    erL *= erScale;\n    erR *= erScale;\n\n    tapPos++; if (tapPos >= TAP_CAP) tapPos = 0;\n\n    // ---- feed the diffuse tail from the early reflections ----\n    let send: f32 = tailFeed * 0.18 + monoIn * 0.12;\n    send = allpass(0, send);\n    send = allpass(1, send);\n    send = allpass(2, send);\n    send = allpass(3, send);\n\n    for (let i = 0; i < NLINES; i++) {\n      let ph: f32 = lfoPh[i] + lfoInc[i];\n      if (ph >= TWO_PI) ph -= TWO_PI;\n      lfoPh[i] = ph;\n      const d: f32 = f32(lineLen[i]) + modDepth * Mathf.sin(ph);\n      const v: f32 = readFrac(i, d);\n      // gentle fixed damping so the tail stays smooth and ambient\n      const dd: f32 = damp[i] + 0.35 * (v - damp[i]);\n      damp[i] = dd;\n      outs[i] = dd;\n    }\n\n    let sum: f32 = 0.0;\n    for (let i = 0; i < NLINES; i++) sum += outs[i];\n    const corr: f32 = (2.0 / f32(NLINES)) * sum; // Householder-ish mixing\n\n    for (let i = 0; i < NLINES; i++) {\n      const base: i32 = i * LINE_CAP;\n      const inj: f32 = ((i & 1) == 0 ? send : -send) * 0.30;\n      const fb: f32 = (outs[i] - corr) * lineGain[i];\n      lines[base + linePos[i]] = inj + fb;\n      linePos[i]++; if (linePos[i] >= LINE_CAP) linePos[i] = 0;\n    }\n\n    const tailL: f32 = (outs[0] - outs[2] + outs[4] - outs[6]) * tailScale;\n    const tailR: f32 = (outs[1] - outs[3] + outs[5] - outs[7]) * tailScale;\n\n    const wetL: f32 = erL + tailL;\n    const wetR: f32 = erR + tailR;\n\n    outBuf[f] = l * (1.0 - mix) + wetL * mix;\n    outBuf[MAX_FRAMES + f] = r * (1.0 - mix) + wetR * mix;\n  }\n}\n",
  "publishedAt": 1751000078000
}