  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Clav</title>\n<style>\n  :root {\n    --accent:  #d06a3a;\n    --accent2: #ffae5a;\n    --wood0:   #2a1a12;\n    --wood1:   #3a241a;\n    --panel0:  #1c130d;\n    --panel1:  #281a11;\n    --ink:     #f5e6d4;\n    --ink-dim: #b79a82;\n    --tab-off: #2d1d13;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background: #140d08;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .shell {\n    max-width: 880px;\n    margin: 0 auto;\n    padding: 18px;\n  }\n\n  /* ---- the cabinet ------------------------------------------------ */\n  .cabinet {\n    position: relative;\n    border-radius: 16px;\n    padding: 18px 20px 20px;\n    background:\n      linear-gradient(180deg, #3a2519 0%, #2c1b11 55%, #1f130b 100%);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(255,200,150,.14),\n      inset 0 -2px 8px rgba(0,0,0,.55);\n    border: 1px solid #110a05;\n    overflow: hidden;\n  }\n  /* faint wood grain */\n  .cabinet::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    background:\n      repeating-linear-gradient(92deg,\n        rgba(255,180,120,.035) 0px,\n        rgba(0,0,0,.04) 3px,\n        rgba(255,180,120,.02) 6px,\n        rgba(0,0,0,.05) 11px);\n    mix-blend-mode: overlay;\n    opacity: .8;\n  }\n\n  /* ---- header ----------------------------------------------------- */\n  .head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    position: relative;\n    z-index: 2;\n  }\n  .brand {\n    display: flex;\n    align-items: baseline;\n    gap: 12px;\n  }\n  .logo {\n    font-weight: 800;\n    font-size: 30px;\n    letter-spacing: 3px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,.4);\n  }\n  .tagline {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* the \"wah-mouth\" hint — an animated grille that opens/closes */\n  .mouth {\n    width: 120px;\n    height: 38px;\n    border-radius: 22px;\n    background: radial-gradient(ellipse at 50% 40%, #120b06 0%, #241710 70%);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,.7), inset 0 -1px 0 rgba(255,180,120,.1);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 4px;\n    overflow: hidden;\n  }\n  .mouth .bar {\n    width: 5px;\n    border-radius: 3px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    animation: wah 1.6s ease-in-out infinite;\n    opacity: .85;\n  }\n  @keyframes wah {\n    0%, 100% { height: 8px; }\n    50%      { height: 26px; }\n  }\n\n  /* ---- strings panel --------------------------------------------- */\n  .strings-wrap {\n    position: relative;\n    z-index: 2;\n    margin: 16px 0 14px;\n    padding: 12px 14px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, #160e08, #0f0905);\n    box-shadow: inset 0 2px 10px rgba(0,0,0,.7), inset 0 -1px 0 rgba(255,170,110,.08);\n  }\n  #strings { display: block; width: 100%; height: 92px; }\n\n  /* ---- rocker tabs (params) -------------------------------------- */\n  .tabs {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(6, 1fr);\n    gap: 12px;\n    margin-top: 6px;\n  }\n  .tab {\n    position: relative;\n    border-radius: 10px;\n    padding: 10px 8px 12px;\n    background: linear-gradient(180deg, #2c1c12, #1d120b);\n    box-shadow: inset 0 1px 0 rgba(255,190,140,.12), 0 4px 10px rgba(0,0,0,.45);\n    user-select: none;\n  }\n  .tab .name {\n    font-size: 9.5px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n    margin-bottom: 8px;\n  }\n\n  /* the rocker switch body */\n  .rocker {\n    position: relative;\n    height: 66px;\n    margin: 0 auto;\n    width: 40px;\n    border-radius: 8px;\n    background: linear-gradient(180deg, #0e0805, #1a110a);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,.8);\n    cursor: ns-resize;\n    overflow: hidden;\n  }\n  /* the lit fill that tracks the value (bottom-up) */\n  .rocker .fill {\n    position: absolute;\n    left: 3px;\n    right: 3px;\n    bottom: 3px;\n    border-radius: 6px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: 0 0 12px rgba(255,140,60,.55);\n    transition: height .04s linear;\n  }\n  /* the physical cap that rides on top of the fill */\n  .rocker .cap {\n    position: absolute;\n    left: 3px;\n    right: 3px;\n    height: 16px;\n    border-radius: 5px;\n    background: linear-gradient(180deg, #f3d8bd, #b98a63);\n    box-shadow: 0 2px 5px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.6);\n    transition: bottom .04s linear;\n  }\n  .rocker:hover .fill { filter: brightness(1.12); }\n  .rocker.drag .cap { box-shadow: 0 0 14px var(--accent2), inset 0 1px 0 rgba(255,255,255,.7); }\n\n  .tab .val {\n    margin-top: 8px;\n    text-align: center;\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent2);\n    font-weight: 700;\n  }\n\n  /* ---- keyboard --------------------------------------------------- */\n  .kb-wrap {\n    position: relative;\n    z-index: 2;\n    margin-top: 16px;\n    padding: 10px 10px 12px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, #20140c, #150d07);\n    box-shadow: inset 0 1px 0 rgba(255,180,120,.1), 0 6px 14px rgba(0,0,0,.5);\n  }\n  .kb-label {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-bottom: 8px;\n    display: flex;\n    justify-content: space-between;\n  }\n  .keys {\n    position: relative;\n    height: 110px;\n    display: flex;\n    user-select: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 6px 6px;\n    background: linear-gradient(180deg, #fbf1e4 0%, #e9d6c0 88%, #d6bfa3 100%);\n    box-shadow: inset 0 -3px 6px rgba(0,0,0,.18), 0 3px 5px rgba(0,0,0,.4);\n    cursor: pointer;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: inset 0 3px 8px rgba(120,40,0,.5);\n  }\n  .bkeys {\n    position: absolute;\n    top: 0;\n    left: 0;\n    right: 0;\n    height: 66px;\n    pointer-events: none;\n  }\n  .bkey {\n    position: absolute;\n    width: 5.6%;\n    height: 100%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a1c12, #0c0703);\n    box-shadow: 0 3px 5px rgba(0,0,0,.6), inset 0 -2px 3px rgba(255,180,120,.12);\n    pointer-events: auto;\n    cursor: pointer;\n    transform: translateX(-50%);\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #8a3c14);\n  }\n</style>\n</head>\n<body>\n<div class=\"shell\">\n  <div class=\"cabinet\">\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"logo\">CLAV</div>\n        <div class=\"tagline\">Funk&nbsp;Clavier&nbsp;·&nbsp;Plucked&nbsp;String</div>\n      </div>\n      <div class=\"mouth\" id=\"mouth\" title=\"wah\">\n        <div class=\"bar\" style=\"animation-delay:0s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.12s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.24s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.36s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.48s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.60s\"></div>\n        <div class=\"bar\" style=\"animation-delay:.72s\"></div>\n      </div>\n    </div>\n\n    <div class=\"strings-wrap\">\n      <canvas id=\"strings\"></canvas>\n    </div>\n\n    <div class=\"tabs\" id=\"tabs\"></div>\n\n    <div class=\"kb-wrap\">\n      <div class=\"kb-label\"><span>Keyboard</span><span>drag tabs · double-click resets</span></div>\n      <div class=\"keys\" id=\"keys\">\n        <div class=\"bkeys\" id=\"bkeys\"></div>\n      </div>\n    </div>\n\n  </div>\n</div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match the DSP module) -----------\n  var PARAMS = [\n    { name: \"Attack\",     index: 0, min: 0, max: 1, def: 0.15 },\n    { name: \"Decay\",      index: 1, min: 0, max: 1, def: 0.55 },\n    { name: \"Brightness\", index: 2, min: 0, max: 1, def: 0.65 },\n    { name: \"Pickup\",     index: 3, min: 0, max: 1, def: 0.45 },\n    { name: \"Damping\",    index: 4, min: 0, max: 1, def: 0.30 },\n    { name: \"Level\",      index: 5, min: 0, max: 1, def: 0.70 }\n  ];\n\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  // ---- safe bridge to the host ------------------------------------\n  function pushParam(idx, val) {\n    if (window.vstai && window.vstai.setParam) {\n      try { window.vstai.setParam(idx, val); } catch (e) {}\n    }\n  }\n  function fmt(v) { return Math.round(v * 100) + \"%\"; }\n\n  // ---- build the rocker tabs --------------------------------------\n  var tabEls = [];\n  function buildTabs() {\n    var host = document.getElementById(\"tabs\");\n    PARAMS.forEach(function (p, i) {\n      var tab = document.createElement(\"div\");\n      tab.className = \"tab\";\n\n      var name = document.createElement(\"div\");\n      name.className = \"name\";\n      name.textContent = p.name;\n\n      var rocker = document.createElement(\"div\");\n      rocker.className = \"rocker\";\n      var fill = document.createElement(\"div\");\n      fill.className = \"fill\";\n      var cap = document.createElement(\"div\");\n      cap.className = \"cap\";\n      rocker.appendChild(fill);\n      rocker.appendChild(cap);\n\n      var val = document.createElement(\"div\");\n      val.className = \"val\";\n\n      tab.appendChild(name);\n      tab.appendChild(rocker);\n      tab.appendChild(val);\n      host.appendChild(tab);\n\n      var rec = { p: p, rocker: rocker, fill: fill, cap: cap, val: val };\n      tabEls.push(rec);\n      wireRocker(rec, i);\n      paint(i);\n    });\n  }\n\n  function norm(i) {\n    var p = PARAMS[i];\n    return (values[i] - p.min) / (p.max - p.min);\n  }\n\n  function paint(i) {\n    var rec = tabEls[i];\n    var t = norm(i);\n    var travel = 66 - 16 - 6; // track height minus cap minus padding\n    rec.fill.style.height = (6 + t * (66 - 12)) + \"px\";\n    rec.cap.style.bottom = (3 + t * travel) + \"px\";\n    rec.val.textContent = fmt(t);\n  }\n\n  function setValue(i, v) {\n    var p = PARAMS[i];\n    if (v < p.min) v = p.min;\n    if (v > p.max) v = p.max;\n    values[i] = v;\n    pushParam(p.index, v);\n    paint(i);\n  }\n\n  function wireRocker(rec, i) {\n    var dragging = false, startY = 0, startVal = 0;\n\n    function down(ev) {\n      dragging = true;\n      rec.rocker.classList.add(\"drag\");\n      startY = (ev.touches ? ev.touches[0].clientY : ev.clientY);\n      startVal = norm(i);\n      ev.preventDefault();\n      window.addEventListener(\"mousemove\", move);\n      window.addEventListener(\"mouseup\", up);\n      window.addEventListener(\"touchmove\", move, { passive: false });\n      window.addEventListener(\"touchend\", up);\n    }\n    function move(ev) {\n      if (!dragging) return;\n      var y = (ev.touches ? ev.touches[0].clientY : ev.clientY);\n      var dt = (startY - y) / 140;            // up = increase\n      var p = PARAMS[i];\n      var nv = startVal + dt;\n      if (nv < 0) nv = 0; if (nv > 1) nv = 1;\n      setValue(i, p.min + nv * (p.max - p.min));\n      ev.preventDefault();\n    }\n    function up() {\n      dragging = false;\n      rec.rocker.classList.remove(\"drag\");\n      window.removeEventListener(\"mousemove\", move);\n      window.removeEventListener(\"mouseup\", up);\n      window.removeEventListener(\"touchmove\", move);\n      window.removeEventListener(\"touchend\", up);\n    }\n\n    rec.rocker.addEventListener(\"mousedown\", down);\n    rec.rocker.addEventListener(\"touchstart\", down, { passive: false });\n    rec.rocker.addEventListener(\"dblclick\", function () { setValue(i, rec.p.def); });\n    rec.rocker.addEventListener(\"wheel\", function (ev) {\n      var p = PARAMS[i];\n      var step = (p.max - p.min) * 0.03;\n      setValue(i, values[i] - Math.sign(ev.deltaY) * step);\n      ev.preventDefault();\n    }, { passive: false });\n  }\n\n  // ---- animated strings canvas ------------------------------------\n  var canvas = document.getElementById(\"strings\");\n  var ctx = canvas.getContext(\"2d\");\n  var NSTRINGS = 9;\n  // each string: phase, amplitude (decays), pitch-ish freq\n  var sStr = [];\n  for (var s = 0; s < NSTRINGS; s++) {\n    sStr.push({ amp: 0, phase: Math.random() * 6.28, freq: 9 + s * 1.4 });\n  }\n\n  function pluckString(noteNumber) {\n    var idx = ((noteNumber % 12) * NSTRINGS / 12) | 0;\n    if (idx < 0) idx = 0; if (idx >= NSTRINGS) idx = NSTRINGS - 1;\n    sStr[idx].amp = 1;\n    sStr[idx].phase = 0;\n  }\n\n  function sizeCanvas() {\n    var dpr = window.devicePixelRatio || 1;\n    var w = canvas.clientWidth, h = canvas.clientHeight;\n    canvas.width = w * dpr;\n    canvas.height = h * dpr;\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n\n  var t0 = performance.now();\n  function drawStrings(now) {\n    if (document.hidden) { requestAnimationFrame(drawStrings); return; }\n    var w = canvas.clientWidth, h = canvas.clientHeight;\n    ctx.clearRect(0, 0, w, h);\n    var bright = values[2];      // Brightness tints the glow\n    var decay = values[1];       // Decay controls visible ring length\n    var dt = (now - t0) / 1000;\n\n    for (var i = 0; i < NSTRINGS; i++) {\n      var st = sStr[i];\n      var y = (i + 0.5) * (h / NSTRINGS);\n      // vibration amplitude in px\n      var a = st.amp * (5 + bright * 9);\n      // string color: warm orange, brighter when freshly plucked\n      var g = ctx.createLinearGradient(0, 0, w, 0);\n      var lit = 0.35 + st.amp * 0.65;\n      g.addColorStop(0, \"rgba(120,80,55,\" + (0.5 + 0.4 * lit) + \")\");\n      g.addColorStop(0.5, \"rgba(\" + (208 + 40 * lit) + \",\" + (106 + 70 * lit) + \",\" + (58 + 40 * lit) + \",\" + (0.6 + 0.4 * lit) + \")\");\n      g.addColorStop(1, \"rgba(120,80,55,\" + (0.5 + 0.4 * lit) + \")\");\n      ctx.strokeStyle = g;\n      ctx.lineWidth = 1.4 + (1 - i / NSTRINGS) * 1.6 + st.amp * 0.8;\n      ctx.shadowBlur = st.amp * 10 * (0.4 + bright);\n      ctx.shadowColor = \"rgba(255,150,70,0.7)\";\n\n      ctx.beginPath();\n      var seg = 40;\n      for (var k = 0; k <= seg; k++) {\n        var x = (k / seg) * w;\n        // standing-wave-ish shape, fundamental + slight 2nd\n        var env = Math.sin((k / seg) * Math.PI);\n        var osc = Math.sin(dt * st.freq * 6.28 + st.phase) ;\n        var yy = y + env * a * osc;\n        if (k === 0) ctx.moveTo(x, yy); else ctx.lineTo(x, yy);\n      }\n      ctx.stroke();\n      ctx.shadowBlur = 0;\n\n      // decay the amplitude — slower when Decay is high\n      var d = 0.985 + decay * 0.012;\n      st.amp *= d;\n      if (st.amp < 0.001) st.amp = 0;\n    }\n    requestAnimationFrame(drawStrings);\n  }\n\n  // ---- on-screen keyboard -----------------------------------------\n  var BASE_NOTE = 48; // C3\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var NUM_OCT = 2;\n  var heldKeys = {};\n\n  function buildKeyboard() {\n    var keys = document.getElementById(\"keys\");\n    var bkeys = document.getElementById(\"bkeys\");\n    var whiteCount = WHITE.length * NUM_OCT + 1; // +1 top C\n    var whiteEls = [];\n\n    for (var o = 0; o < NUM_OCT; o++) {\n      for (var wi = 0; wi < WHITE.length; wi++) {\n        var note = BASE_NOTE + o * 12 + WHITE[wi];\n        whiteEls.push(makeWhite(note, keys));\n      }\n    }\n    whiteEls.push(makeWhite(BASE_NOTE + NUM_OCT * 12, keys));\n\n    // black keys positioned relative to white-key slots\n    var blackPattern = [0, 1, 3, 4, 5]; // which gaps within an octave get a black key\n    var slot = 100 / whiteCount;\n    var wIndex = 0;\n    for (var oo = 0; oo < NUM_OCT; oo++) {\n      for (var bi = 0; bi < WHITE.length; bi++) {\n        var hasBlack = (bi === 0 || bi === 1 || bi === 3 || bi === 4 || bi === 5);\n        if (hasBlack) {\n          // semitone above the white note\n          var bnote = BASE_NOTE + oo * 12 + WHITE[bi] + 1;\n          var leftPct = (wIndex + 1) * slot;\n          makeBlack(bnote, leftPct, bkeys);\n        }\n        wIndex++;\n      }\n    }\n  }\n\n  function makeWhite(note, parent) {\n    var el = document.createElement(\"div\");\n    el.className = \"wkey\";\n    bindKey(el, note);\n    // insert before the bkeys overlay so order is correct\n    parent.insertBefore(el, document.getElementById(\"bkeys\"));\n    return el;\n  }\n  function makeBlack(note, leftPct, parent) {\n    var el = document.createElement(\"div\");\n    el.className = \"bkey\";\n    el.style.left = leftPct + \"%\";\n    bindKey(el, note);\n    parent.appendChild(el);\n    return el;\n  }\n\n  function noteDown(note, el) {\n    if (heldKeys[note]) return;\n    heldKeys[note] = true;\n    el.classList.add(\"down\");\n    if (window.vstai && window.vstai.noteOn) {\n      try { window.vstai.noteOn(note, 0.9); } catch (e) {}\n    }\n    pluckString(note);\n  }\n  function noteUp(note, el) {\n    if (!heldKeys[note]) return;\n    delete heldKeys[note];\n    el.classList.remove(\"down\");\n    if (window.vstai && window.vstai.noteOff) {\n      try { window.vstai.noteOff(note); } catch (e) {}\n    }\n  }\n\n  function bindKey(el, note) {\n    el.addEventListener(\"mousedown\", function (e) { noteDown(note, el); e.preventDefault(); });\n    el.addEventListener(\"mouseup\", function () { noteUp(note, el); });\n    el.addEventListener(\"mouseleave\", function () { noteUp(note, el); });\n    el.addEventListener(\"touchstart\", function (e) { noteDown(note, el); e.preventDefault(); }, { passive: false });\n    el.addEventListener(\"touchend\", function (e) { noteUp(note, el); e.preventDefault(); });\n  }\n\n  // computer keyboard row plays too (a..k as white keys)\n  var KEYMAP = { \"a\": 0, \"s\": 2, \"d\": 4, \"f\": 5, \"g\": 7, \"h\": 9, \"j\": 11, \"k\": 12 };\n  var allKeyEls = {};\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var k = e.key.toLowerCase();\n    if (KEYMAP[k] === undefined) return;\n    var note = BASE_NOTE + KEYMAP[k];\n    pluckString(note);\n    if (window.vstai && window.vstai.noteOn) { try { window.vstai.noteOn(note, 0.9); } catch (er) {} }\n    heldKeys[note] = true;\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var k = e.key.toLowerCase();\n    if (KEYMAP[k] === undefined) return;\n    var note = BASE_NOTE + KEYMAP[k];\n    if (window.vstai && window.vstai.noteOff) { try { window.vstai.noteOff(note); } catch (er) {} }\n    delete heldKeys[note];\n  });\n\n  // ---- init -------------------------------------------------------\n  function init() {\n    buildTabs();\n    buildKeyboard();\n    sizeCanvas();\n    window.addEventListener(\"resize\", sizeCanvas);\n    // push all defaults to the engine\n    PARAMS.forEach(function (p, i) { pushParam(p.index, values[i]); });\n    requestAnimationFrame(drawStrings);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CLAV — a polyphonic plucked-string funk-clav instrument.\n//  Models the percussive, springy pluck of a tine-and-string electro-\n//  mechanical clavier. Each of 8 voices is an independent Karplus-Strong\n//  string: a short noise/impulse excitation burst is injected into a\n//  tuned delay line whose feedback loop carries a damping low-pass, so\n//  the string rings then decays. A one-pole \"Brightness\" tilt and a\n//  comb-style \"Pickup\" tap colour the tone like the magnetic pickup of\n//  the real instrument. A fast percussive amp envelope gives the snap.\n//  Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\n// delay-line capacity per voice: enough for the lowest expected note.\n// 48000 / ~27.5 Hz (A0) ≈ 1746; round up generously.\nconst DLINE: i32 = 2048;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_ATTACK: i32 = 0;  // 0..1 -> pluck excitation length / softness\nconst P_DECAY:  i32 = 1;  // 0..1 -> string ring time (loop damping)\nconst P_BRIGHT: i32 = 2;  // 0..1 -> excitation/tone brightness tilt\nconst P_PICKUP: i32 = 3;  // 0..1 -> pickup comb tap position (tone)\nconst P_DAMP:   i32 = 4;  // 0..1 -> loop low-pass damping (string dullness)\nconst P_LEVEL:  i32 = 5;  // 0..1 -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// Karplus-Strong delay line per voice (flattened: voice v -> base v*DLINE)\nconst dl:      StaticArray<f32> = new StaticArray<f32>(NUM_VOICES * DLINE);\nconst vWrite:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // write head\nconst vDelay:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // fractional loop length\n\nconst vLoopLp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // loop damping one-pole state\nconst vPickLp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pickup tilt state\n\n// excitation burst: remaining samples + per-voice noise rng\nconst vBurst:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\nconst vRng:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// fast percussive amp envelope (attack ramp then exp release while ringing)\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 hold/decay 3 release\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vWrite[v] = 0; vDelay[v] = 100.0;\n    vLoopLp[v] = 0.0; vPickLp[v] = 0.0;\n    vBurst[v] = 0; vRng[v] = 0x1234 + v * 7919;\n    vEnv[v] = 0.0; vStage[v] = 0;\n    const base: i32 = v * DLINE;\n    for (let i = 0; i < DLINE; i++) dl[base + i] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_ATTACK] = 0.15;\n  params[P_DECAY]  = 0.55;\n  params[P_BRIGHT] = 0.65;\n  params[P_PICKUP] = 0.45;\n  params[P_DAMP]   = 0.30;\n  params[P_LEVEL]  = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// per-voice xorshift noise in [-1, 1]\n@inline function vnoise(v: i32): f32 {\n  let s: i32 = vRng[v];\n  s ^= s << 13; s ^= s >>> 17; s ^= s << 5;\n  vRng[v] = s;\n  return f32(s) * f32(4.6566128e-10); // /2^31\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, vel: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  const freq: f32 = f > 20.0 ? f : 20.0;\n  // loop length in samples = period; clamp into the delay line\n  let d: f32 = sampleRate / freq;\n  if (d < 2.0) d = 2.0;\n  if (d > f32(DLINE - 2)) d = f32(DLINE - 2);\n\n  vNote[slot]   = id;\n  vFreq[slot]   = freq;\n  vVel[slot]    = clampf(vel, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vDelay[slot]  = d;\n  vWrite[slot]  = 0;\n  vLoopLp[slot] = 0.0;\n  vPickLp[slot] = 0.0;\n  vEnv[slot]    = 0.0;\n  vStage[slot]  = 1; // attack\n  vAge[slot]    = ageCounter++;\n\n  // clear this voice's delay line so a stolen voice doesn't carry old ring\n  const base: i32 = slot * DLINE;\n  for (let i = 0; i < DLINE; i++) dl[base + i] = 0.0;\n\n  // excitation burst length proportional to a fraction of the period:\n  // a short burst => sharp pluck; controlled by Attack (longer = softer).\n  const atkN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  let burst: i32 = i32(d * (0.12 + atkN * 0.55));\n  if (burst < 2) burst = 2;\n  if (burst > DLINE - 1) burst = DLINE - 1;\n  vBurst[slot] = burst;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3; // release -> mute the loop faster (key lift damps the string)\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const decayN:  f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const brightN: f32 = clampf(params[P_BRIGHT], 0.0, 1.0);\n  const pickupN: f32 = clampf(params[P_PICKUP], 0.0, 1.0);\n  const dampN:   f32 = clampf(params[P_DAMP], 0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 0.9;\n\n  // Loop feedback gain: higher Decay -> longer ring (closer to 1.0).\n  // Keep strictly < 1 for stability.\n  const fb: f32 = 0.95 + decayN * 0.048; // 0.95 .. 0.998\n\n  // Loop damping low-pass coefficient: more Damp -> duller, faster HF loss.\n  // coef is the one-pole smoothing amount (0..1); lower = more damping.\n  const loopLpCoef: f32 = 1.0 - (0.05 + dampN * 0.55); // 0.95 .. 0.40\n\n  // Brightness tilt on excitation + pickup: a one-pole high-shelf-ish blend.\n  // higher Bright -> more high content passed through.\n  const brightCoef: f32 = 0.15 + brightN * 0.80; // 0.15 .. 0.95\n\n  // attack ramp rate (samples): short, percussive\n  const atkN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const atkRate: f32 = 1.0 / (f32(sr) * (0.0008 + atkN * 0.012)); // ~0.8..13 ms\n  // natural release while key held: string keeps ringing (slow); after key-off, faster\n  const relRate: f32 = 1.0 / (f32(sr) * 0.06); // ~60 ms key-off mute\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      const base: i32 = v * DLINE;\n      const d: f32 = vDelay[v];\n\n      // ---- read from the delay line (fractional, linear interp) -----\n      // read position = write head - delay (one loop behind)\n      let rp: f32 = f32(vWrite[v]) - d;\n      while (rp < 0.0) rp += f32(DLINE);\n      const ri: i32 = i32(rp);\n      let ri1: i32 = ri + 1; if (ri1 >= DLINE) ri1 -= DLINE;\n      const frac: f32 = rp - f32(ri);\n      const a: f32 = dl[base + ri];\n      const b: f32 = dl[base + ri1];\n      let delayed: f32 = a + (b - a) * frac;\n\n      // ---- loop damping low-pass (string HF loss) -------------------\n      let lp: f32 = vLoopLp[v];\n      lp = lp + loopLpCoef * (delayed - lp);\n      vLoopLp[v] = lp;\n\n      // ---- excitation: inject a brightness-shaped noise burst -------\n      let exc: f32 = 0.0;\n      if (vBurst[v] > 0) {\n        // noise burst, tilted by brightness (mix of raw + smoothed noise)\n        const raw: f32 = vnoise(v);\n        // a touch of pluck \"pick\" shape: scale burst by velocity\n        exc = raw * vVel[v];\n        vBurst[v] -= 1;\n      }\n\n      // new sample fed into the line: damped feedback + excitation,\n      // brightness controls how much HF survives in the feedback path.\n      // blend the damped (lp) with the full-band delayed signal by brightCoef\n      let fbSig: f32 = lp + (delayed - lp) * brightCoef;\n      let newSamp: f32 = exc + fbSig * fb;\n\n      // safety clamp inside the loop to stay bounded\n      if (newSamp > 1.5) newSamp = 1.5;\n      if (newSamp < -1.5) newSamp = -1.5;\n\n      dl[base + vWrite[v]] = newSamp;\n\n      // advance write head\n      let w: i32 = vWrite[v] + 1; if (w >= DLINE) w -= DLINE;\n      vWrite[v] = w;\n\n      // ---- pickup comb: tap the line a fraction of a period back ----\n      // pickup position 0..1 maps to a tap 0.06..0.5 of the period earlier;\n      // (delayed - tap) emulates the magnetic pickup's comb-filter colour.\n      const tapDist: f32 = d * (0.06 + pickupN * 0.44);\n      let tp: f32 = f32(w) - 1.0 - tapDist; // relative to most-recent sample\n      while (tp < 0.0) tp += f32(DLINE);\n      const ti: i32 = i32(tp);\n      let ti1: i32 = ti + 1; if (ti1 >= DLINE) ti1 -= DLINE;\n      const tfrac: f32 = tp - f32(ti);\n      const ta: f32 = dl[base + ti];\n      const tb: f32 = dl[base + ti1];\n      const tap: f32 = ta + (tb - ta) * tfrac;\n\n      // combed output (pickup): difference gives the hollow clav tone\n      let sig: f32 = delayed - tap * 0.6;\n\n      // pickup tone tilt one-pole (slightly removes harshness, adds body)\n      let pk: f32 = vPickLp[v];\n      pk = pk + (0.35 + pickupN * 0.5) * (sig - pk);\n      vPickLp[v] = pk;\n      sig = pk;\n\n      // ---- percussive amp envelope ----------------------------------\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {\n        // held: envelope stays open; the string's own loop damping\n        // provides the natural decay, so keep env at 1.\n        env = 1.0;\n      } else if (stg == 3) {\n        // key released: quickly fade the voice out\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      let voice: f32 = sig * env;\n      outL += voice;\n\n      // ---- voice-finished detection ---------------------------------\n      // when the string has rung down to silence (loop tiny) or released,\n      // free the voice so it can be reused.\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n      // auto-cull a near-silent sustained voice (string fully damped)\n      if (stg == 2 && vGate[v] == 0) {\n        // (shouldn't happen: gate clears -> stage 3) — defensive no-op\n      }\n    }\n\n    // ---- sum + gentle soft saturate -------------------------------\n    let mix: f32 = outL * level;\n    mix = f32(Mathf.tanh(mix * 1.1));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000081000
}