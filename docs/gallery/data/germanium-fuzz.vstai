{
  "format": 1,
  "name": "Germanium Fuzz",
  "isInstrument": false,
  "explanation": "A vintage two-transistor germanium fuzz: an AC-coupled, very high-gain stage feeds an asymmetric clipper (soft knee into a hard ceiling) that mimics a cascaded transistor pair. The Bias control shifts the operating point and, turned down, starves the circuit for gated, spitty fuzz; Tone tilts dark-to-bright and Volume sets the output. Controls: Fuzz, Bias, Tone, Volume.",
  "params": [
    {
      "name": "Fuzz",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.75
    },
    {
      "name": "Bias",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Volume",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  @property --n0{syntax:'<number>';inherits:false;initial-value:0}\n  @property --n1{syntax:'<number>';inherits:false;initial-value:0}\n  :root{\n    --ac:#d98b4a;            /* germanium amber */\n    --ac2:#e8a860;           /* warm highlight */\n    --case:#b56a2e;          /* hammered enclosure */\n    --caseD:#5e3414;         /* shadow side */\n    --eye:#f4ead6;           /* knob face cream */\n    --smile:#3a2412;         /* engraving brown */\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    color:#f3e6d2;\n    background:\n      radial-gradient(120% 95% at 50% 8%,#2a1b10 0%,#160d07 55%,#0a0603 100%);\n    display:flex;align-items:center;justify-content:center;\n    padding:18px;overflow:hidden;\n    -webkit-tap-highlight-color:transparent;\n  }\n\n  /* ---- floor shadow + workbench glow -------------------------------- */\n  .stage{\n    position:relative;width:100%;max-width:420px;\n    display:flex;flex-direction:column;align-items:center;gap:14px;\n    animation:rise .8s cubic-bezier(.2,.8,.2,1) both;\n  }\n  @keyframes rise{from{opacity:0;transform:translateY(22px) scale(.94)}to{opacity:1;transform:none}}\n\n  /* ===================================================================\n     THE PEDAL — a round die-cast fuzz-face enclosure\n     =================================================================== */\n  .pedal{\n    position:relative;width:340px;height:340px;flex:0 0 auto;\n    border-radius:50%;\n    /* warm rim light + a slow idle wobble like it's alive */\n    animation:idle 7s ease-in-out infinite;\n    will-change:transform;\n    cursor:default;\n  }\n  @keyframes idle{0%,100%{transform:rotate(-1.1deg)}50%{transform:rotate(1.1deg)}}\n\n  /* hammered metal body */\n  .body{\n    position:absolute;inset:0;border-radius:50%;\n    background:\n      radial-gradient(60% 55% at 38% 30%,#e89a52 0%,#c4742f 38%,#9a531f 70%,#5e3414 100%);\n    box-shadow:\n      0 26px 50px -10px rgba(0,0,0,.7),\n      0 8px 18px rgba(0,0,0,.55),\n      inset 0 -14px 30px rgba(0,0,0,.55),\n      inset 0 14px 26px rgba(255,225,180,.35);\n  }\n  /* hammered speckle texture (pure CSS) */\n  .body::before{\n    content:\"\";position:absolute;inset:0;border-radius:50%;opacity:.5;mix-blend-mode:overlay;\n    background:\n      radial-gradient(2px 2px at 20% 30%,rgba(255,255,255,.5),transparent 60%),\n      radial-gradient(2px 2px at 70% 22%,rgba(0,0,0,.4),transparent 60%),\n      radial-gradient(3px 3px at 48% 60%,rgba(255,255,255,.35),transparent 60%),\n      radial-gradient(2px 2px at 33% 78%,rgba(0,0,0,.45),transparent 60%),\n      radial-gradient(2px 2px at 82% 65%,rgba(255,255,255,.4),transparent 60%),\n      radial-gradient(2px 2px at 60% 40%,rgba(0,0,0,.35),transparent 60%),\n      radial-gradient(3px 3px at 12% 55%,rgba(255,255,255,.3),transparent 60%);\n  }\n  /* moving specular sweep — a soft light gliding across the metal */\n  .body::after{\n    content:\"\";position:absolute;inset:0;border-radius:50%;pointer-events:none;\n    background:linear-gradient(115deg,transparent 38%,rgba(255,240,210,.5) 50%,transparent 62%);\n    mix-blend-mode:screen;animation:sweep 6.5s ease-in-out infinite;\n  }\n  @keyframes sweep{0%,100%{transform:translateX(-30%);opacity:.25}50%{transform:translateX(30%);opacity:.85}}\n\n  /* outer engraved ring + bolts */\n  .ring{position:absolute;inset:14px;border-radius:50%;\n    border:2px solid rgba(60,30,12,.55);\n    box-shadow:inset 0 0 0 6px rgba(255,225,180,.12),inset 0 0 22px rgba(0,0,0,.45);\n    pointer-events:none;}\n  .bolt{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#f0d9b3,#7a4a22 70%,#3a2310);\n    box-shadow:0 1px 2px rgba(0,0,0,.6),inset 0 1px 1px rgba(255,255,255,.5);}\n  .bolt::after{content:\"\";position:absolute;inset:4px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 45%,rgba(40,20,8,.8) 45% 55%,transparent 55%);\n    transform:rotate(35deg);}\n  .b0{top:8px;left:50%;margin-left:-6.5px}\n  .b1{bottom:8px;left:50%;margin-left:-6.5px}\n  .b2{top:50%;left:8px;margin-top:-6.5px}\n  .b3{top:50%;right:8px;margin-top:-6.5px}\n\n  /* the engraved SMILE — an SVG arc with eyebrow ticks */\n  .face{position:absolute;inset:0;pointer-events:none;overflow:visible}\n  .smile{\n    fill:none;stroke:var(--smile);stroke-width:9;stroke-linecap:round;\n    filter:drop-shadow(0 1px 0 rgba(255,225,180,.35));\n    opacity:.85;\n  }\n  /* the smile brightens & widens a touch when the fuzz is cranked */\n  .smileGlow{\n    fill:none;stroke:var(--ac2);stroke-width:5;stroke-linecap:round;\n    opacity:calc(.15 + var(--fuzzn,.5)*.7);\n    filter:drop-shadow(0 0 6px var(--ac));\n    transition:opacity .25s ease;\n  }\n\n  /* nose: the germanium status LED / footswitch jewel */\n  .nose{\n    position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);\n    width:30px;height:30px;border-radius:50%;cursor:pointer;\n    background:radial-gradient(circle at 38% 32%,#fff5e6,var(--ac) 45%,#7a3d12 90%);\n    box-shadow:\n      0 0 0 5px rgba(40,20,8,.6),\n      0 0 14px var(--ac),\n      inset 0 -2px 4px rgba(0,0,0,.5),\n      inset 0 2px 3px rgba(255,255,255,.6);\n    animation:beat 2.2s ease-in-out infinite;\n    z-index:6;\n  }\n  @keyframes beat{0%,100%{box-shadow:0 0 0 5px rgba(40,20,8,.6),0 0 8px var(--ac),inset 0 -2px 4px rgba(0,0,0,.5),inset 0 2px 3px rgba(255,255,255,.6)}\n    50%{box-shadow:0 0 0 5px rgba(40,20,8,.6),0 0 22px var(--ac2),inset 0 -2px 4px rgba(0,0,0,.5),inset 0 2px 3px rgba(255,255,255,.7)}}\n\n  /* ---- the two EYES (knobs) ----------------------------------------- */\n  .eye{\n    position:absolute;width:104px;height:104px;cursor:ns-resize;\n    touch-action:none;user-select:none;z-index:5;\n  }\n  .eyeL{left:58px;top:78px}\n  .eyeR{right:58px;top:78px}\n\n  /* dark eye-socket recess */\n  .socket{position:absolute;inset:-9px;border-radius:50%;\n    background:radial-gradient(circle at 50% 38%,rgba(0,0,0,.15),rgba(0,0,0,.55) 75%);\n    box-shadow:inset 0 4px 10px rgba(0,0,0,.65),0 1px 0 rgba(255,225,180,.25);}\n\n  /* the value arc that wraps the knob (filled by --nX) */\n  .arc{position:absolute;inset:-2px;border-radius:50%;}\n  .arcL{background:conic-gradient(from 225deg,\n      var(--ac) calc(var(--n0)*270deg),\n      rgba(0,0,0,.35) calc(var(--n0)*270deg) 270deg,\n      transparent 270deg);\n    filter:drop-shadow(0 0 calc(2px + var(--n0)*8px) var(--ac));}\n  .arcR{background:conic-gradient(from 225deg,\n      var(--ac) calc(var(--n1)*270deg),\n      rgba(0,0,0,.35) calc(var(--n1)*270deg) 270deg,\n      transparent 270deg);\n    filter:drop-shadow(0 0 calc(2px + var(--n1)*8px) var(--ac));}\n  .arc{-webkit-mask:radial-gradient(circle,transparent 49px,#000 50px);\n       mask:radial-gradient(circle,transparent 49px,#000 50px);}\n\n  /* the cream chicken-head knob cap */\n  .cap{position:absolute;inset:4px;border-radius:50%;\n    background:\n      radial-gradient(circle at 42% 30%,#fffaf0 0%,var(--eye) 40%,#d8c5a0 78%,#9a8460 100%);\n    box-shadow:\n      inset 0 -6px 12px rgba(120,90,50,.5),\n      inset 0 5px 10px rgba(255,255,255,.7),\n      0 4px 9px rgba(0,0,0,.5);\n    transition:transform .12s ease;\n  }\n  .eye:active .cap,.eye.act .cap{transform:scale(.97)}\n  /* the iris / pointer indent that rotates */\n  .iris{position:absolute;inset:0;border-radius:50%;\n    transform:rotate(calc((var(--nn,0) - 0.5)*270deg));\n    transition:transform .12s cubic-bezier(.2,.75,.25,1);}\n  .pupil{position:absolute;top:9px;left:50%;width:11px;height:11px;margin-left:-5.5px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#5a3a18,#1c0f04);\n    box-shadow:0 0 5px rgba(0,0,0,.6),inset 0 1px 1px rgba(255,255,255,.25);}\n  .pupil::after{content:\"\";position:absolute;left:50%;top:13px;transform:translateX(-50%);\n    width:3px;height:13px;border-radius:2px;background:var(--smile);opacity:.55}\n\n  /* value bubble over each eye */\n  .bub{position:absolute;left:50%;top:-6px;transform:translate(-50%,-100%) scale(.85);\n    opacity:0;pointer-events:none;font-weight:800;font-size:12px;color:#1c0f04;\n    background:linear-gradient(var(--ac2),var(--ac));padding:3px 9px;border-radius:7px;\n    font-variant-numeric:tabular-nums;box-shadow:0 6px 14px rgba(0,0,0,.45);\n    transition:.16s;white-space:nowrap;z-index:9;}\n  .bub::after{content:\"\";position:absolute;left:50%;bottom:-4px;transform:translateX(-50%) rotate(45deg);\n    width:8px;height:8px;background:var(--ac);}\n  .eye:hover .bub,.eye.act .bub{opacity:1;transform:translate(-50%,-100%) scale(1)}\n\n  /* tiny etched label under each eye */\n  .eyelbl{position:absolute;left:50%;bottom:-22px;transform:translateX(-50%);\n    font-size:10px;letter-spacing:.22em;font-weight:800;color:#3a2412;\n    text-shadow:0 1px 0 rgba(255,225,180,.4);white-space:nowrap;}\n\n  /* ===================================================================\n     CHASSIS RAIL — Tone & Volume as boutique vertical slide-faders\n     mounted on a brushed plate below the round can\n     =================================================================== */\n  .rail{\n    position:relative;width:340px;border-radius:16px;padding:14px 20px 16px;\n    background:linear-gradient(180deg,#3a2615,#241409);\n    border:1px solid rgba(255,225,180,.14);\n    box-shadow:0 14px 30px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,225,180,.18);\n    display:flex;gap:18px;\n  }\n  .plate{position:absolute;inset:0;border-radius:16px;pointer-events:none;opacity:.5;mix-blend-mode:overlay;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.08) 0 1px,transparent 1px 3px);}\n  .fader{flex:1;display:flex;flex-direction:column;align-items:center;gap:8px;position:relative;z-index:1}\n  .track{position:relative;width:100%;height:118px;border-radius:9px;cursor:ns-resize;\n    touch-action:none;user-select:none;\n    background:linear-gradient(180deg,#0c0703,#1c0f06);\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.7),inset 0 -1px 0 rgba(255,225,180,.1);\n    border:1px solid rgba(0,0,0,.5);overflow:hidden;}\n  /* the slot the cap rides in */\n  .slot{position:absolute;left:50%;top:10px;bottom:10px;width:5px;margin-left:-2.5px;border-radius:3px;\n    background:#000;box-shadow:inset 0 0 4px rgba(0,0,0,.9);}\n  /* glowing fill from bottom up to the cap */\n  .fill{position:absolute;left:50%;width:7px;margin-left:-3.5px;bottom:10px;border-radius:3px;\n    background:linear-gradient(var(--ac2),var(--ac));\n    box-shadow:0 0 9px var(--ac);\n    height:calc((var(--fn,0))*98px);\n    transition:height .1s linear;}\n  /* the fader knob */\n  .grip{position:absolute;left:50%;width:46px;height:22px;margin-left:-23px;border-radius:6px;\n    bottom:calc(10px + (var(--fn,0))*98px - 11px);\n    background:linear-gradient(180deg,#fffaf0,#d8c5a0 55%,#9a8460);\n    box-shadow:0 3px 7px rgba(0,0,0,.55),inset 0 1px 1px rgba(255,255,255,.8),inset 0 -2px 3px rgba(120,90,50,.5);\n    transition:bottom .1s linear,filter .15s;}\n  .grip::after{content:\"\";position:absolute;left:8px;right:8px;top:50%;height:2px;margin-top:-1px;border-radius:2px;\n    background:linear-gradient(90deg,transparent,var(--ac),transparent);box-shadow:0 0 5px var(--ac);}\n  .track:hover .grip,.track.act .grip{filter:brightness(1.06)}\n  .flbl{font-size:10px;letter-spacing:.2em;font-weight:800;color:#e8a860;text-transform:uppercase}\n  .fval{font-size:13px;font-weight:800;color:#fff;font-variant-numeric:tabular-nums}\n\n  /* maker's mark */\n  .mark{display:flex;align-items:center;gap:8px;font-size:9.5px;letter-spacing:.28em;\n    text-transform:uppercase;color:#a8753f;font-weight:700;opacity:.85}\n  .mark .dot{width:6px;height:6px;border-radius:50%;background:var(--ac);box-shadow:0 0 8px var(--ac)}\n\n  @media(max-width:380px){\n    .pedal{width:300px;height:300px}\n    .eyeL{left:48px}.eyeR{right:48px}\n    .rail{width:300px}\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\">\n\n    <!-- ============ THE ROUND FUZZ-FACE PEDAL ============ -->\n    <div class=\"pedal\" id=\"pedal\">\n      <div class=\"body\"></div>\n      <div class=\"ring\"></div>\n      <span class=\"bolt b0\"></span><span class=\"bolt b1\"></span>\n      <span class=\"bolt b2\"></span><span class=\"bolt b3\"></span>\n\n      <!-- engraved smile -->\n      <svg class=\"face\" id=\"faceSvg\" viewBox=\"0 0 340 340\">\n        <path class=\"smile\"     d=\"M96 214 Q170 286 244 214\"></path>\n        <path class=\"smileGlow\" id=\"smileGlow\" d=\"M96 214 Q170 286 244 214\"></path>\n      </svg>\n\n      <!-- LEFT EYE = FUZZ (param 0) -->\n      <div class=\"eye eyeL\" id=\"eye0\" data-i=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.75\" data-step=\"0.001\" data-nv=\"n0\">\n        <div class=\"socket\"></div>\n        <div class=\"arc arcL\"></div>\n        <div class=\"cap\"><div class=\"iris\"><span class=\"pupil\"></span></div></div>\n        <span class=\"bub\"></span>\n        <span class=\"eyelbl\">FUZZ</span>\n      </div>\n\n      <!-- RIGHT EYE = BIAS (param 1) -->\n      <div class=\"eye eyeR\" id=\"eye1\" data-i=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.65\" data-step=\"0.001\" data-nv=\"n1\">\n        <div class=\"socket\"></div>\n        <div class=\"arc arcR\"></div>\n        <div class=\"cap\"><div class=\"iris\"><span class=\"pupil\"></span></div></div>\n        <span class=\"bub\"></span>\n        <span class=\"eyelbl\">BIAS</span>\n      </div>\n\n      <!-- nose jewel / status LED -->\n      <div class=\"nose\" id=\"nose\" title=\"germanium status\"></div>\n    </div>\n\n    <!-- ============ TONE / VOLUME FADER RAIL ============ -->\n    <div class=\"rail\">\n      <div class=\"plate\"></div>\n\n      <!-- TONE (param 2) -->\n      <div class=\"fader\">\n        <div class=\"track\" id=\"fad2\" data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\">\n          <div class=\"slot\"></div><div class=\"fill\"></div><div class=\"grip\"></div>\n        </div>\n        <div class=\"flbl\">Tone</div><div class=\"fval\" id=\"v2\"></div>\n      </div>\n\n      <!-- VOLUME (param 3) -->\n      <div class=\"fader\">\n        <div class=\"track\" id=\"fad3\" data-i=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\">\n          <div class=\"slot\"></div><div class=\"fill\"></div><div class=\"grip\"></div>\n        </div>\n        <div class=\"flbl\">Volume</div><div class=\"fval\" id=\"v3\"></div>\n      </div>\n    </div>\n\n    <div class=\"mark\"><span class=\"dot\"></span>GERMANIUM FUZZ &nbsp;·&nbsp; HAND-WIRED</div>\n  </div>\n\n<script>\n(function(){\n  function fmt(v){ return (Math.round(v*100)).toString(); } // 0–100 % display\n  function clamp(n){ return n<0?0:(n>1?1:n); }\n\n  var pedal = document.getElementById('pedal');\n  var smileGlow = document.getElementById('smileGlow');\n\n  function send(i,val){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(i,val); }\n\n  // ---- the two EYE knobs ----\n  function initEye(el){\n    var i=+el.dataset.i, mn=+el.dataset.min, mx=+el.dataset.max,\n        def=+el.dataset.def, step=+el.dataset.step||0.001, nv=el.dataset.nv;\n    var iris=el.querySelector('.iris'), bub=el.querySelector('.bub');\n    var val=def, dragging=false, sy=0, sn=0;\n    function norm(){ return (val-mn)/((mx-mn)||1); }\n    function paint(){\n      var n=norm();\n      pedal.style.setProperty('--'+nv, n.toFixed(4));     // arc + glow filter\n      iris.style.setProperty('--nn', n.toFixed(4));        // pointer rotation\n      bub.textContent = fmt(n);\n      if(i===0){ pedal.style.setProperty('--fuzzn', n.toFixed(4));\n                 smileGlow.style.setProperty('--fuzzn', n.toFixed(4)); }\n      send(i,val);\n    }\n    function setN(n){ n=clamp(n); var v=mn+(mx-mn)*n; v=Math.round(v/step)*step; val=v; paint(); }\n    el.addEventListener('pointerdown',function(e){\n      dragging=true; sy=e.clientY; sn=norm(); el.classList.add('act');\n      el.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    el.addEventListener('pointermove',function(e){\n      if(!dragging) return; setN(sn + (sy - e.clientY)/220);\n    });\n    function end(){ dragging=false; el.classList.remove('act'); }\n    el.addEventListener('pointerup',end);\n    el.addEventListener('pointercancel',end);\n    el.addEventListener('dblclick',function(){ val=def; paint(); });\n    el.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.02:-0.02)); },{passive:false});\n    paint();\n  }\n\n  // ---- the two vertical FADERS ----\n  function initFader(el){\n    var i=+el.dataset.i, mn=+el.dataset.min, mx=+el.dataset.max,\n        def=+el.dataset.def, step=+el.dataset.step||0.001;\n    var out=document.getElementById('v'+i);\n    var val=def, dragging=false;\n    function norm(){ return (val-mn)/((mx-mn)||1); }\n    function paint(){\n      var n=norm();\n      el.style.setProperty('--fn', n.toFixed(4));\n      if(out) out.textContent=fmt(n);\n      send(i,val);\n    }\n    function setN(n){ n=clamp(n); var v=mn+(mx-mn)*n; v=Math.round(v/step)*step; val=v; paint(); }\n    function fromY(e){\n      var r=el.getBoundingClientRect();\n      // active travel is inset 10px top & bottom (slot)\n      var top=r.top+10, h=r.height-20;\n      setN(1-((e.clientY-top)/h));\n    }\n    el.addEventListener('pointerdown',function(e){\n      dragging=true; el.classList.add('act'); el.setPointerCapture(e.pointerId);\n      fromY(e); e.preventDefault();\n    });\n    el.addEventListener('pointermove',function(e){ if(dragging) fromY(e); });\n    function end(){ dragging=false; el.classList.remove('act'); }\n    el.addEventListener('pointerup',end);\n    el.addEventListener('pointercancel',end);\n    el.addEventListener('dblclick',function(){ val=def; paint(); });\n    el.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.03:-0.03)); },{passive:false});\n    paint();\n  }\n\n  function ready(){\n    initEye(document.getElementById('eye0'));\n    initEye(document.getElementById('eye1'));\n    initFader(document.getElementById('fad2'));\n    initFader(document.getElementById('fad3'));\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  GERMANIUM FUZZ — vintage two-transistor germanium fuzz model\n//  An original model of the classic 1960s germanium fuzz circuit: an AC-\n//  coupled, very high-gain stage feeding an asymmetric clipper (soft knee\n//  into a hard ceiling) that mimics a cascaded transistor pair. A Bias\n//  control shifts the operating point — turned down it starves the\n//  \"circuit\", producing the gated, spitty, note-collapsing fuzz the real\n//  thing is famous for. A passive Tone tilt and output Volume finish it.\n//  Pure algorithm, no samples, bounded output.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter / coupling state\nconst inHpState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // input AC-coupling LP (for HP)\nconst midHpState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // inter-stage AC coupling LP (for HP)\nconst biasEnv:     StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // slow envelope -> dynamic bias sag/gate\nconst toneLpState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone low-pass\nconst outHpState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // output DC blocker LP (for HP)\n\nconst P_FUZZ:   i32 = 0; // 0..1 -> gain into the clipper\nconst P_BIAS:   i32 = 1; // 0..1 -> circuit bias (low = starved/gated, high = open/fat)\nconst P_TONE:   i32 = 2; // 0..1 -> dark .. bright\nconst P_VOLUME: i32 = 3; // 0..1 -> output level\n\nconst PI: f32 = 3.14159265358979;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    inHpState[c] = 0.0;\n    midHpState[c] = 0.0;\n    biasEnv[c] = 0.0;\n    toneLpState[c] = 0.0;\n    outHpState[c] = 0.0;\n  }\n  params[P_FUZZ] = 0.75;\n  params[P_BIAS] = 0.65;\n  params[P_TONE] = 0.5;\n  params[P_VOLUME] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// one-pole low-pass coefficient for a given corner frequency\n@inline function lpCoeff(hz: f32, sr: f32): f32 {\n  return f32(1.0 - Mathf.exp(-2.0 * PI * hz / sr));\n}\n\n// Asymmetric soft->hard saturator. tanh gives the soft knee of a transistor\n// stage; the asymmetry from the shifted bias makes the positive and negative\n// halves clip differently (even-harmonic, \"vocal\" germanium character), and a\n// hard ceiling caps the runaway high-gain output.\n@inline function fuzzStage(x: f32, bias: f32): f32 {\n  // bias is a small DC offset injected before the nonlinearity\n  const b: f32 = x + bias;\n  let y: f32 = f32(Mathf.tanh(b));\n  // remove the resulting DC so the asymmetry stays as waveform shape, not offset\n  y = y - f32(Mathf.tanh(bias));\n  // hard ceiling for the most extreme excursions (saturated transistor)\n  return clampf(y, -0.98, 0.98);\n}\n\nexport function process(n: i32): void {\n  const fuzzN: f32 = clampf(params[P_FUZZ], 0.0, 1.0);\n  const biasN: f32 = clampf(params[P_BIAS], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const volN:  f32 = clampf(params[P_VOLUME], 0.0, 1.0);\n\n  // FUZZ -> drive into the first clipper. Very high range like the real thing.\n  const drive1: f32 = f32(2.0 + fuzzN * fuzzN * 120.0);\n  // second cascaded stage adds the extra grind at high settings\n  const drive2: f32 = f32(1.5 + fuzzN * 6.0);\n\n  // BIAS -> static operating-point offset. Low bias = large offset that the\n  // signal cannot fully overcome on every cycle -> gating/spitty fuzz. High\n  // bias = near-symmetric, fat and open.\n  // staticBias is large & negative-leaning when starved.\n  const starve: f32 = 1.0 - biasN;                 // 0 (open) .. 1 (starved)\n  const staticBias: f32 = f32(0.05 + starve * 1.6); // offset magnitude\n  // how strongly the program-dependent envelope pulls the bias around (sag)\n  const sagAmt: f32 = f32(0.2 + starve * 1.3);\n\n  // input AC coupling ~ 80 Hz (sensitive, lets low end push the gain stage)\n  const cInHp: f32 = lpCoeff(80.0, sampleRate);\n  // inter-stage coupling ~ 160 Hz tightens before the second clip\n  const cMidHp: f32 = lpCoeff(160.0, sampleRate);\n  // bias envelope follower (slow): ~ 25 Hz response\n  const cEnv: f32 = lpCoeff(25.0, sampleRate);\n  // TONE -> post low-pass, dark 700 Hz .. bright 6500 Hz\n  const toneHz: f32 = f32(700.0 + toneN * toneN * 5800.0);\n  const cTone: f32 = lpCoeff(toneHz, sampleRate);\n  // output DC blocker ~ 25 Hz\n  const cOutHp: f32 = lpCoeff(25.0, sampleRate);\n\n  // output level; level-compensated a touch so cranking Fuzz isn't just louder\n  const comp: f32 = f32(0.9 / (1.0 + fuzzN * 0.6));\n  const vol: f32 = f32(volN * 1.2 * comp);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let inLp: f32 = inHpState[c];\n    let midLp: f32 = midHpState[c];\n    let env: f32 = biasEnv[c];\n    let tn: f32 = toneLpState[c];\n    let outLp: f32 = outHpState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // --- input AC coupling (high-pass) ---\n      inLp = inLp + cInHp * (x - inLp);\n      const hpIn: f32 = x - inLp;\n\n      // --- envelope of the input drives dynamic bias sag (gating) ---\n      const rect: f32 = hpIn < 0.0 ? -hpIn : hpIn;\n      env = env + cEnv * (rect - env);\n      // when starved, a louder signal momentarily \"opens\" the bias (sag),\n      // so quiet tails collapse/gate and transients spit through.\n      const dynBias: f32 = f32(-staticBias + env * sagAmt * 3.0);\n\n      // --- first high-gain germanium stage (asymmetric) ---\n      const s1: f32 = fuzzStage(hpIn * drive1, dynBias);\n\n      // --- inter-stage AC coupling, then second cascaded clip ---\n      midLp = midLp + cMidHp * (s1 - midLp);\n      const hpMid: f32 = s1 - midLp;\n      const s2: f32 = fuzzStage(hpMid * drive2, dynBias * 0.5);\n\n      // --- passive tone low-pass ---\n      tn = tn + cTone * (s2 - tn);\n\n      // --- output DC blocker ---\n      outLp = outLp + cOutHp * (tn - outLp);\n      const dcFree: f32 = tn - outLp;\n\n      let y: f32 = f32(dcFree * vol);\n      // final safety clamp — always bounded\n      y = clampf(y, -1.0, 1.0);\n      outBuf[base + f] = y;\n    }\n\n    inHpState[c] = inLp;\n    midHpState[c] = midLp;\n    biasEnv[c] = env;\n    toneLpState[c] = tn;\n    outHpState[c] = outLp;\n  }\n}\n",
  "publishedAt": 1751000023000
}