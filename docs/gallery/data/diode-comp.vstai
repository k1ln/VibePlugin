{
  "format": 1,
  "name": "Diode Comp",
  "isInstrument": false,
  "explanation": "A diode-bridge style bus compressor with a smooth, slightly coloured character. A stereo-linked peak/RMS detector feeds a dB-domain gain computer with a wide over-easy soft knee; Attack and Release shape the gain-reduction envelope. The signal passes through a gentle asymmetric diode-bridge transfer that adds a touch of even-harmonic warmth, so loud material is squeezed and coloured more than quiet passages for a classy, glued sound. Controls: Threshold, Ratio, Attack, Release and Makeup.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.32
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Makeup",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.28
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Diode Comp</title>\n<style>\n  :root {\n    --accent:  #b0b8c0;\n    --accent2: #d96a6a;\n    --panel:   #c9cdce;\n    --panel-d: #a7adae;\n    --ink:     #2a2e30;\n    --screw:   #6f7577;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    width: 100%;\n    height: 100%;\n    background: #1b1d1e;\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .stage {\n    min-height: 100%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 22px;\n    background:\n      radial-gradient(120% 90% at 50% -10%, rgba(217,106,106,0.10), transparent 55%),\n      radial-gradient(140% 120% at 50% 120%, rgba(0,0,0,0.55), transparent 60%),\n      #18191a;\n  }\n\n  /* ---------- the console module ---------- */\n  .module {\n    width: clamp(540px, 96vw, 880px);\n    border-radius: 14px;\n    padding: 20px 22px 24px;\n    position: relative;\n    background:\n      linear-gradient(180deg, #d4d7d8 0%, #c2c6c7 18%, #b2b7b8 50%, #c2c6c7 82%, #d0d3d4 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.65) inset,\n      0 -2px 6px rgba(0,0,0,0.22) inset,\n      0 22px 50px rgba(0,0,0,0.55),\n      0 4px 0 #6f7375;\n    border: 1px solid #8d9293;\n  }\n\n  /* brushed-metal sheen */\n  .module::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    border-radius: 14px;\n    pointer-events: none;\n    background:\n      repeating-linear-gradient(90deg,\n        rgba(255,255,255,0.05) 0px,\n        rgba(255,255,255,0.05) 1px,\n        rgba(0,0,0,0.025) 2px,\n        rgba(0,0,0,0.025) 3px);\n    mix-blend-mode: overlay;\n    opacity: 0.5;\n  }\n\n  .screw {\n    position: absolute;\n    width: 13px; height: 13px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #babfc0, var(--screw) 70%, #4d5152);\n    box-shadow: 0 1px 1px rgba(255,255,255,0.5) inset, 0 1px 2px rgba(0,0,0,0.45);\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute;\n    left: 2px; top: 50%;\n    width: 9px; height: 1.6px;\n    background: rgba(0,0,0,0.45);\n    transform: translateY(-50%) rotate(40deg);\n    border-radius: 1px;\n  }\n  .screw.tl { top: 9px; left: 9px; }\n  .screw.tr { top: 9px; right: 9px; }\n  .screw.bl { bottom: 9px; left: 9px; }\n  .screw.br { bottom: 9px; right: 9px; }\n\n  /* ---------- header ---------- */\n  .header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 14px 14px;\n    border-bottom: 1px solid rgba(0,0,0,0.18);\n    margin-bottom: 18px;\n    position: relative;\n  }\n  .brand { display: flex; align-items: baseline; gap: 12px; }\n  .brand .mark {\n    font-weight: 800;\n    font-size: 22px;\n    letter-spacing: 1.5px;\n    color: var(--ink);\n    text-shadow: 0 1px 0 rgba(255,255,255,0.55);\n  }\n  .brand .mark b { color: var(--accent2); }\n  .brand .sub {\n    font-size: 9px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #5a5f60;\n  }\n  .badge {\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #6a6f70;\n    border: 1px solid rgba(0,0,0,0.22);\n    border-radius: 4px;\n    padding: 4px 8px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.4), rgba(0,0,0,0.05));\n  }\n\n  /* ---------- main layout ---------- */\n  .body {\n    display: grid;\n    grid-template-columns: 1.15fr 1.4fr;\n    gap: 22px;\n    align-items: stretch;\n  }\n  @media (max-width: 620px) {\n    .body { grid-template-columns: 1fr; }\n  }\n\n  /* ---------- VU meter ---------- */\n  .meter-wrap {\n    background: linear-gradient(180deg, #2b2d2e, #1a1c1d);\n    border-radius: 10px;\n    padding: 12px;\n    border: 1px solid #0c0d0d;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.5) inset, 0 1px 0 rgba(255,255,255,0.18);\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n  .vu-face {\n    position: relative;\n    border-radius: 7px;\n    overflow: hidden;\n    background:\n      radial-gradient(120% 130% at 50% 120%, #f4ead0, #efe2c0 55%, #e6d4a8 100%);\n    box-shadow: 0 0 0 2px #0a0b0b, 0 4px 10px rgba(0,0,0,0.4) inset;\n    aspect-ratio: 2 / 1.18;\n  }\n  .vu-glass {\n    position: absolute; inset: 0;\n    background: linear-gradient(140deg, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0) 40%);\n    pointer-events: none;\n    z-index: 4;\n  }\n  .vu-label {\n    text-align: center;\n    font-size: 8px;\n    letter-spacing: 2.5px;\n    color: #7a715a;\n    text-transform: uppercase;\n  }\n\n  /* ---------- controls grid ---------- */\n  .controls {\n    background: linear-gradient(180deg, rgba(0,0,0,0.05), rgba(255,255,255,0.18));\n    border-radius: 10px;\n    padding: 16px 14px 12px;\n    border: 1px solid rgba(0,0,0,0.14);\n    box-shadow: 0 1px 0 rgba(255,255,255,0.5) inset;\n  }\n  .section-title {\n    font-size: 9px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #5a5f60;\n    margin-bottom: 14px;\n    padding-left: 4px;\n  }\n  .knobs {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 8px;\n  }\n  @media (max-width: 520px) {\n    .knobs { grid-template-columns: repeat(3, 1fr); row-gap: 18px; }\n  }\n\n  .knob-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n  .knob {\n    width: 74px; height: 74px;\n    position: relative;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; }\n  .knob .arc-bg { stroke: rgba(0,0,0,0.22); }\n  .knob .arc-fg {\n    stroke: var(--accent2);\n    transition: stroke 0.15s;\n    filter: drop-shadow(0 0 3px rgba(217,106,106,0.55));\n  }\n  .knob.active .arc-fg { stroke: #ec8585; }\n\n  .knob-cap {\n    position: absolute;\n    left: 50%; top: 50%;\n    width: 46px; height: 46px;\n    transform: translate(-50%, -50%);\n    border-radius: 50%;\n    background:\n      radial-gradient(circle at 38% 30%, #6a6f71 0%, #4a4e50 45%, #34383a 100%);\n    box-shadow:\n      0 2px 5px rgba(0,0,0,0.5),\n      0 1px 0 rgba(255,255,255,0.18) inset,\n      0 -3px 6px rgba(0,0,0,0.4) inset;\n    pointer-events: none;\n  }\n  /* stepped knurling ring */\n  .knob-cap::before {\n    content: \"\";\n    position: absolute;\n    inset: 3px;\n    border-radius: 50%;\n    background:\n      repeating-conic-gradient(from 0deg,\n        rgba(255,255,255,0.10) 0deg 4deg,\n        rgba(0,0,0,0.22) 4deg 8deg);\n    -webkit-mask: radial-gradient(circle, transparent 56%, #000 57%);\n            mask: radial-gradient(circle, transparent 56%, #000 57%);\n    opacity: 0.55;\n  }\n  .knob-pointer {\n    position: absolute;\n    left: 50%; top: 50%;\n    width: 3px; height: 22px;\n    background: linear-gradient(180deg, var(--accent2), #b04a4a);\n    border-radius: 2px;\n    transform-origin: 50% 100%;\n    transform: translate(-50%, -100%) rotate(0deg);\n    box-shadow: 0 0 4px rgba(217,106,106,0.7);\n    pointer-events: none;\n  }\n\n  .knob-name {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #4c5051;\n    font-weight: 600;\n  }\n  .knob-val {\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    background: linear-gradient(180deg, #e7eaea, #cfd3d4);\n    border-radius: 4px;\n    padding: 2px 7px;\n    min-width: 52px;\n    text-align: center;\n    box-shadow: 0 1px 2px rgba(0,0,0,0.25) inset;\n    border: 1px solid rgba(0,0,0,0.12);\n  }\n\n  /* power lamp */\n  .lamp {\n    width: 9px; height: 9px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #ff9a9a, var(--accent2));\n    box-shadow: 0 0 8px var(--accent2), 0 0 2px #fff inset;\n    animation: pulse 2.6s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { box-shadow: 0 0 6px var(--accent2), 0 0 2px #fff inset; }\n    50%      { box-shadow: 0 0 13px var(--accent2), 0 0 3px #fff inset; }\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"module\">\n      <span class=\"screw tl\"></span>\n      <span class=\"screw tr\"></span>\n      <span class=\"screw bl\"></span>\n      <span class=\"screw br\"></span>\n\n      <div class=\"header\">\n        <div class=\"brand\">\n          <span class=\"mark\">DIODE<b> COMP</b></span>\n          <span class=\"sub\">Diode-Bridge Compressor</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:12px;\">\n          <span class=\"lamp\"></span>\n          <span class=\"badge\">Type 33 · Bus Dynamics</span>\n        </div>\n      </div>\n\n      <div class=\"body\">\n        <div class=\"meter-wrap\">\n          <div class=\"vu-face\">\n            <svg viewBox=\"0 0 200 118\" id=\"vu\" aria-label=\"gain reduction meter\">\n              <!-- arc ticks -->\n              <g id=\"vu-ticks\" stroke=\"#8c7c54\" stroke-width=\"1\"></g>\n              <text x=\"100\" y=\"40\" text-anchor=\"middle\" font-size=\"9\"\n                    fill=\"#8a7a52\" letter-spacing=\"1.5\" font-family=\"ui-sans-serif\">GAIN REDUCTION</text>\n              <text x=\"36\" y=\"100\" font-size=\"7\" fill=\"#9a8a60\" font-family=\"ui-sans-serif\">0</text>\n              <text x=\"158\" y=\"100\" font-size=\"7\" fill=\"#b85a3a\" font-family=\"ui-sans-serif\">-20 dB</text>\n              <!-- needle -->\n              <line id=\"needle\" x1=\"100\" y1=\"110\" x2=\"100\" y2=\"30\"\n                    stroke=\"#3a2f24\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n              <circle cx=\"100\" cy=\"110\" r=\"6\" fill=\"#2c2620\"/>\n              <circle cx=\"100\" cy=\"110\" r=\"2.4\" fill=\"#c9b888\"/>\n            </svg>\n            <div class=\"vu-glass\"></div>\n          </div>\n          <div class=\"vu-label\">VU · Diode Bridge · Even-Harmonic Warmth</div>\n        </div>\n\n        <div class=\"controls\">\n          <div class=\"section-title\">Compression</div>\n          <div class=\"knobs\" id=\"knobs\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Threshold\", index: 0, def: 0.32, fmt: function (v) { return (-42 + v * 42).toFixed(1) + \" dB\"; } },\n    { name: \"Ratio\",     index: 1, def: 0.40, fmt: function (v) { return (1.5 + v * 10.5).toFixed(1) + \":1\"; } },\n    { name: \"Attack\",    index: 2, def: 0.30, fmt: function (v) { return (0.3 + v * v * 119.7).toFixed(1) + \" ms\"; } },\n    { name: \"Release\",   index: 3, def: 0.35, fmt: function (v) {\n        var ms = 50 + v * v * 1450;\n        return ms >= 1000 ? (ms / 1000).toFixed(2) + \" s\" : ms.toFixed(0) + \" ms\";\n      } },\n    { name: \"Makeup\",    index: 4, def: 0.28, fmt: function (v) { return \"+\" + (v * 24).toFixed(1) + \" dB\"; } }\n  ];\n\n  var ARC_LO = -135, ARC_HI = 135; // degrees for the pointer sweep\n\n  var state = PARAMS.map(function (p) { return p.def; });\n\n  // ---- host bridge ----\n  function pushParam(i, v) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(i, v);\n    }\n  }\n\n  // ---- build the VU tick marks ----\n  function buildTicks() {\n    var g = document.getElementById(\"vu-ticks\");\n    var cx = 100, cy = 110, r = 78;\n    for (var i = 0; i <= 8; i++) {\n      var a = (-130 + (260 / 8) * i) * Math.PI / 180;\n      var x1 = cx + Math.sin(a) * r;\n      var y1 = cy - Math.cos(a) * r;\n      var x2 = cx + Math.sin(a) * (r - (i % 2 ? 5 : 9));\n      var y2 = cy - Math.cos(a) * (r - (i % 2 ? 5 : 9));\n      var ln = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n      ln.setAttribute(\"x1\", x1.toFixed(1));\n      ln.setAttribute(\"y1\", y1.toFixed(1));\n      ln.setAttribute(\"x2\", x2.toFixed(1));\n      ln.setAttribute(\"y2\", y2.toFixed(1));\n      ln.setAttribute(\"stroke\", i >= 6 ? \"#b85a3a\" : \"#8c7c54\");\n      g.appendChild(ln);\n    }\n  }\n\n  // ---- VU needle animation (eased, follows estimated gain reduction) ----\n  var needle = document.getElementById(\"needle\");\n  var grShown = 0, grTarget = 0, phase = 0;\n\n  function estimateGR() {\n    // Visualise expected gain reduction from the current settings + a slow\n    // synthetic programme envelope, so the meter feels alive without audio taps.\n    var thr = state[0];          // 0..1 (higher = less reduction)\n    var ratio = 1.5 + state[1] * 10.5;\n    var slope = 1 - 1 / ratio;\n    phase += 0.018;\n    var prog = 0.5 + 0.5 * Math.sin(phase) * Math.sin(phase * 0.37 + 1.1); // 0..1 swell\n    // \"over threshold\" amount: more when threshold is low\n    var over = Math.max(0, (prog * 26) - thr * 30); // dB above threshold-ish\n    return Math.min(20, slope * over); // dB GR, capped at meter range\n  }\n\n  var lastTick = 0;\n  function tick(now) {\n    if (document.hidden) { rafId = requestAnimationFrame(tick); return; }\n    if (now - lastTick > 30) {\n      lastTick = now;\n      grTarget = estimateGR();\n      // attack/release tint the needle ballistics: faster attack = snappier\n      // fall toward more GR; longer release = slower recovery\n      var follow = grTarget > grShown\n        ? 0.30 - state[2] * 0.22   // attack: 0.30 (fast) .. 0.08 (slow)\n        : 0.12 - state[3] * 0.10;  // release: 0.12 (fast) .. 0.02 (slow)\n      grShown += (grTarget - grShown) * follow;\n      var frac = grShown / 20;                  // 0..1\n      var deg = -130 + frac * 260;              // sweep left->right\n      needle.setAttribute(\"transform\", \"rotate(\" + deg.toFixed(2) + \" 100 110)\");\n    }\n    rafId = requestAnimationFrame(tick);\n  }\n  var rafId = 0;\n\n  // ---- builders ----\n  function buildAll() {\n    var host = document.getElementById(\"knobs\");\n    PARAMS.forEach(function (p) {\n      buildOne(host, p);\n    });\n    PARAMS.forEach(function (p) { pushParam(p.index, state[p.index]); });\n    buildTicks();\n    if (!rafId) rafId = requestAnimationFrame(tick);\n  }\n\n  function buildOne(host, p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob-cell\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.setAttribute(\"tabindex\", \"0\");\n\n    var R = 31, CIRC = 2 * Math.PI * R, SWEEP = 0.74;\n    knob.innerHTML =\n      '<svg viewBox=\"0 0 74 74\">' +\n        '<circle class=\"arc-bg\" cx=\"37\" cy=\"37\" r=\"' + R + '\" fill=\"none\" stroke-width=\"5\"' +\n          ' stroke-linecap=\"round\" transform=\"rotate(135 37 37)\"' +\n          ' stroke-dasharray=\"' + (CIRC * SWEEP).toFixed(2) + ' ' + CIRC + '\"></circle>' +\n        '<circle class=\"arc-fg\" cx=\"37\" cy=\"37\" r=\"' + R + '\" fill=\"none\" stroke-width=\"5\"' +\n          ' stroke-linecap=\"round\" transform=\"rotate(135 37 37)\"' +\n          ' stroke-dasharray=\"0 ' + CIRC + '\"></circle>' +\n      '</svg>' +\n      '<div class=\"knob-cap\"></div>' +\n      '<div class=\"knob-pointer\"></div>';\n\n    var arcFg = knob.querySelector(\".arc-fg\");\n    var pointer = knob.querySelector(\".knob-pointer\");\n\n    var name = document.createElement(\"div\");\n    name.className = \"knob-name\";\n    name.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"knob-val\";\n\n    cell.appendChild(knob);\n    cell.appendChild(name);\n    cell.appendChild(val);\n    host.appendChild(cell);\n\n    function render() {\n      var v = state[p.index];\n      var deg = ARC_LO + (ARC_HI - ARC_LO) * v;\n      pointer.style.transform = \"translate(-50%, -100%) rotate(\" + deg.toFixed(1) + \"deg)\";\n      arcFg.setAttribute(\"stroke-dasharray\", (CIRC * SWEEP * v).toFixed(2) + \" \" + CIRC);\n      val.textContent = p.fmt(v);\n    }\n\n    function commit(v) {\n      v = Math.max(0, Math.min(1, v));\n      state[p.index] = v;\n      pushParam(p.index, v);\n      render();\n    }\n\n    var dragging = false, startY = 0, startV = 0;\n    knob.addEventListener(\"mousedown\", function (e) {\n      dragging = true; knob.classList.add(\"active\");\n      startY = e.clientY; startV = state[p.index]; e.preventDefault();\n    });\n    window.addEventListener(\"mousemove\", function (e) {\n      if (!dragging) return;\n      commit(startV + (startY - e.clientY) / 200);\n    });\n    window.addEventListener(\"mouseup\", function () {\n      dragging = false; knob.classList.remove(\"active\");\n    });\n    knob.addEventListener(\"touchstart\", function (e) {\n      dragging = true; knob.classList.add(\"active\");\n      startY = e.touches[0].clientY; startV = state[p.index]; e.preventDefault();\n    }, { passive: false });\n    window.addEventListener(\"touchmove\", function (e) {\n      if (!dragging) return;\n      commit(startV + (startY - e.touches[0].clientY) / 200); e.preventDefault();\n    }, { passive: false });\n    window.addEventListener(\"touchend\", function () {\n      dragging = false; knob.classList.remove(\"active\");\n    });\n    knob.addEventListener(\"wheel\", function (e) {\n      commit(state[p.index] - Math.sign(e.deltaY) * 0.02); e.preventDefault();\n    }, { passive: false });\n    knob.addEventListener(\"dblclick\", function () { commit(p.def); });\n    knob.addEventListener(\"keydown\", function (e) {\n      if (e.key === \"ArrowUp\" || e.key === \"ArrowRight\") { commit(state[p.index] + 0.02); e.preventDefault(); }\n      else if (e.key === \"ArrowDown\" || e.key === \"ArrowLeft\") { commit(state[p.index] - 0.02); e.preventDefault(); }\n    });\n\n    render();\n  }\n\n  function boot() {\n    buildAll();\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden && !rafId) rafId = requestAnimationFrame(tick);\n  });\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DIODE COMP — a diode-bridge style bus compressor\n//  Models the smooth, slightly coloured compression of a classic British\n//  diode-bridge dynamics unit. A stereo-linked peak/RMS detector feeds a\n//  dB-domain gain computer with a soft (over-easy) knee; Attack/Release\n//  shape the gain-reduction envelope. The signal passes through a gentle\n//  diode-bridge transfer (an asymmetric soft-clip) that adds a touch of\n//  even-harmonic warmth — louder inputs are squeezed and coloured more\n//  than quiet ones for a classy, glued character. Output is bounded.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (shared across the stereo pair = stereo-linked)\nlet rmsState: f32 = 0.0;   // running mean-square for the RMS detector\nlet grDb: f32 = 0.0;       // current gain reduction in dB (>= 0), smoothed\nlet dcL: f32 = 0.0;        // DC blockers after the asymmetric bridge stage\nlet dcR: f32 = 0.0;\nlet xpL: f32 = 0.0;        // DC blocker input memory\nlet xpR: f32 = 0.0;\n\nconst P_THRESH:  i32 = 0;  // 0..1 -> threshold  -42..0 dBFS  (low = more comp)\nconst P_RATIO:   i32 = 1;  // 0..1 -> ratio      1.5..12:1\nconst P_ATTACK:  i32 = 2;  // 0..1 -> attack     0.3..120 ms\nconst P_RELEASE: i32 = 3;  // 0..1 -> release    50..1500 ms\nconst P_MAKEUP:  i32 = 4;  // 0..1 -> makeup     0..+24 dB\n\nconst KNEE_DB: f32 = 8.0;        // wide, smooth over-easy knee (classy)\nconst LN10_20: f32 = 0.11512925; // ln(10)/20, for dB<->linear\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// linear amplitude -> dBFS (guarded), and back\n@inline function lin2db(x: f32): f32 {\n  const a: f32 = x < 1e-9 ? 1e-9 : x;\n  return f32(8.6858896 * Mathf.log(a)); // 20/ln(10) * ln(a)\n}\n@inline function db2lin(db: f32): f32 {\n  return f32(Mathf.exp(db * LN10_20));\n}\n\n// Diode-bridge transfer: a gentle asymmetric soft-clip. The two diode legs\n// of the bridge conduct slightly differently, biasing the curve so even\n// harmonics appear — that is the bridge \"warmth\". Bounded to ~±1.\n@inline function bridge(x: f32, amt: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  // tanh-like soft clip via a rational approximation (cheap, smooth)\n  const s: f32 = c / f32(1.0 + 0.28 * c * c);\n  // asymmetric second-order term -> even harmonics; scaled by amt (drive)\n  const even: f32 = 0.12 * amt * (s * s - 0.18 * s);\n  return f32(s + even);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  rmsState = 0.0;\n  grDb = 0.0;\n  dcL = 0.0; dcR = 0.0; xpL = 0.0; xpR = 0.0;\n  params[P_THRESH]  = 0.32; // ~ -28.5 dBFS — bites on the test bed\n  params[P_RATIO]   = 0.40; // ~ 5.7:1\n  params[P_ATTACK]  = 0.30; // medium-fast\n  params[P_RELEASE] = 0.35; // medium\n  params[P_MAKEUP]  = 0.28; // ~ +6.7 dB makeup\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  // ---- map params to engineering units ----\n  const tN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const threshDb: f32 = -42.0 + tN * 42.0;               // -42..0 dBFS\n\n  const rN: f32 = clampf(params[P_RATIO], 0.0, 1.0);\n  const ratio: f32 = 1.5 + rN * 10.5;                    // 1.5..12 : 1\n  const slope: f32 = 1.0 - 1.0 / ratio;                  // ~0.33..0.92\n\n  const aN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const atkMs: f32 = 0.3 + aN * aN * 119.7;              // 0.3..120 ms (curved)\n  const relN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const relMs: f32 = 50.0 + relN * relN * 1450.0;        // 50..1500 ms (curved)\n\n  // one-pole time-constant coefficients (per-sample) for the dB envelope\n  const atkCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (atkMs * 0.001 * sampleRate)));\n  const relCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (relMs * 0.001 * sampleRate)));\n\n  // RMS detector window ~ 8 ms (smooth, programme-dependent feel)\n  const rmsCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.008 * sampleRate)));\n\n  const makeupDb: f32 = clampf(params[P_MAKEUP], 0.0, 1.0) * 24.0; // 0..+24 dB\n  const makeup: f32 = db2lin(makeupDb);\n\n  // DC blocker coefficient (~5 Hz) for the asymmetric bridge stage\n  const dcCoef: f32 = f32(1.0 - 2.0 * 3.14159265 * 5.0 / sampleRate);\n\n  const halfKnee: f32 = KNEE_DB * 0.5;\n\n  let rms: f32 = rmsState;\n  let gr: f32 = grDb;\n  let bL: f32 = dcL, bR: f32 = dcR;\n  let pL: f32 = xpL, pR: f32 = xpR;\n\n  const baseL: i32 = 0;\n  const baseR: i32 = MAX_FRAMES;\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    const xL: f32 = inBuf[baseL + f];\n    const xR: f32 = stereo ? inBuf[baseR + f] : xL;\n\n    // ---- detector: stereo-linked peak with RMS floor (smooth + responsive) ----\n    const peakL: f32 = (xL < 0.0 ? -xL : xL);\n    const peakR: f32 = (xR < 0.0 ? -xR : xR);\n    const pk: f32 = peakL > peakR ? peakL : peakR;\n\n    const sq: f32 = (xL * xL + xR * xR) * 0.5;\n    rms = rms + rmsCoef * (sq - rms);            // running mean square\n    const rmsAmp: f32 = f32(Mathf.sqrt(rms));\n\n    const det: f32 = pk > rmsAmp ? pk : rmsAmp;\n    const detDb: f32 = lin2db(det);\n\n    // ---- gain computer: over-easy knee static curve -> target GR (dB) ----\n    const over: f32 = detDb - threshDb;\n    let targetGr: f32;\n    if (over <= -halfKnee) {\n      targetGr = 0.0;                            // below knee: no reduction\n    } else if (over >= halfKnee) {\n      targetGr = slope * over;                   // above knee: full ratio\n    } else {\n      const t: f32 = over + halfKnee;            // 0..KNEE_DB\n      targetGr = slope * (t * t) / (2.0 * KNEE_DB);\n    }\n    if (targetGr < 0.0) targetGr = 0.0;\n\n    // ---- ballistics: attack when clamping down, release when letting go ----\n    const coef: f32 = targetGr > gr ? atkCoef : relCoef;\n    gr = gr + coef * (targetGr - gr);\n\n    // ---- apply gain reduction + makeup ----\n    const g: f32 = db2lin(-gr);\n    // bridge \"drive\" tracks gain reduction: harder squeeze => warmer colour\n    const drive: f32 = clampf(gr * 0.12, 0.0, 1.0);\n\n    let yL: f32 = bridge(xL * g, drive) * makeup;\n    let yR: f32 = stereo ? bridge(xR * g, drive) * makeup : yL;\n\n    // DC-block the asymmetric bridge output so the even-harmonic bias\n    // doesn't pump a DC offset into the bus\n    const oL: f32 = yL - pL + dcCoef * bL;\n    pL = yL; bL = oL;\n    let outL: f32 = oL;\n    let outR: f32 = yR;\n    if (stereo) {\n      const oR: f32 = yR - pR + dcCoef * bR;\n      pR = yR; bR = oR;\n      outR = oR;\n    }\n\n    // final safety clamp (bounded output)\n    outBuf[baseL + f] = clampf(outL, -1.5, 1.5);\n    if (stereo) outBuf[baseR + f] = clampf(outR, -1.5, 1.5);\n  }\n\n  rmsState = rms;\n  grDb = gr;\n  dcL = bL; dcR = bR; xpL = pL; xpR = pR;\n}\n",
  "publishedAt": 1751000085000
}