{
  "format": 1,
  "name": "Grit Sampler",
  "isInstrument": true,
  "explanation": "A gritty 12-bit drum sampler built around a short public-domain (CC0 / US Navy) drum-cadence segment baked right into the plugin. Each played note pitch-tracks the sample, then deliberately degrades it with variable bit-depth quantization and sample-rate decimation for a crunchy vintage character, finished with a soft-clip drive, a tone low-pass and an amp envelope. Controls: Pitch, Grit, Crush, Tone, Drive, Decay and Level.",
  "params": [
    {
      "name": "Pitch",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Grit",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Crush",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Drive",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Grit Sampler</title>\n<style>\n/* ============================================================\n   GRIT SAMPLER — 12-bit gritty hardware sampler.\n   MPC/SP-style rubber pads + a faders strip + a bit-crushed\n   stepped waveform display. Everything bespoke, inline, animated.\n   ============================================================ */\n:root{\n  --ac:#ff9e54;          /* warm amber accent */\n  --ac2:#ffc080;         /* lighter amber */\n  --case:#1a1410;        /* dark chassis */\n  --case2:#0d0a07;\n  --steel:#2a2622;\n  --pad:#231d18;\n  --ink:#f3e7d8;\n  --dim:#9b8a78;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace;color:var(--ink);\n  background:\n    radial-gradient(120% 90% at 50% -10%, #3a2c20 0%, #1a130d 50%, #070503 100%);\n  display:flex;align-items:center;justify-content:center;padding:16px;\n  overflow:hidden;\n}\n\n/* ---------- the hardware unit ---------- */\n.unit{\n  position:relative;width:100%;max-width:640px;border-radius:18px;overflow:hidden;\n  background:\n    linear-gradient(160deg,#241c15,#13100c 60%,#0a0805);\n  border:1px solid #3a2e22;\n  box-shadow:\n    0 34px 70px rgba(0,0,0,.7),\n    0 2px 0 rgba(255,255,255,.05) inset,\n    0 0 0 1px rgba(0,0,0,.6) inset,\n    0 -30px 50px rgba(255,158,84,.04) inset;\n  animation:boot .7s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes boot{from{opacity:0;transform:translateY(14px) scale(.985)}to{opacity:1;transform:none}}\n/* brushed-metal speckle overlay across the whole unit */\n.unit::before{\n  content:\"\";position:absolute;inset:0;z-index:0;pointer-events:none;opacity:.5;\n  background:\n    repeating-linear-gradient(115deg,rgba(255,255,255,.018) 0 2px,transparent 2px 5px),\n    repeating-linear-gradient(0deg,rgba(0,0,0,.10) 0 1px,transparent 1px 3px);\n  mix-blend-mode:overlay;\n}\n/* warm bloom that breathes behind the panel */\n.unit::after{\n  content:\"\";position:absolute;left:50%;top:-30%;width:120%;height:90%;z-index:0;\n  transform:translateX(-50%);pointer-events:none;\n  background:radial-gradient(closest-side,rgba(255,158,84,.16),transparent 70%);\n  filter:blur(20px);animation:bloom 8s ease-in-out infinite alternate;\n}\n@keyframes bloom{from{opacity:.5;transform:translate(-52%,0)}to{opacity:.95;transform:translate(-48%,3%)}}\n\n/* ---------- top brand bar ---------- */\n.brand{\n  position:relative;z-index:2;display:flex;align-items:center;gap:12px;\n  padding:13px 18px 12px;\n  background:linear-gradient(180deg,rgba(255,255,255,.05),rgba(0,0,0,.18));\n  border-bottom:1px solid #000;\n}\n.brand .pwr{\n  width:11px;height:11px;border-radius:50%;flex:none;\n  background:radial-gradient(circle at 35% 30%,#ffd9a8,var(--ac) 60%,#7a3d12);\n  box-shadow:0 0 10px var(--ac),0 0 2px #fff inset;\n  animation:beat 1.9s ease-in-out infinite;\n}\n@keyframes beat{0%,100%{box-shadow:0 0 5px var(--ac)}50%{box-shadow:0 0 16px var(--ac),0 0 3px #fff inset}}\n.logo{display:flex;flex-direction:column;line-height:1;flex:1}\n.logo b{\n  font-size:18px;letter-spacing:.18em;font-weight:800;\n  background:linear-gradient(92deg,var(--ac2),var(--ac) 55%,#c96b2a);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 1px 0 rgba(0,0,0,.4);\n}\n.logo small{font-size:9px;letter-spacing:.34em;color:var(--dim);margin-top:5px;text-transform:uppercase}\n.model{\n  font-size:9px;letter-spacing:.2em;color:#0c0805;text-transform:uppercase;\n  background:linear-gradient(var(--ac2),var(--ac));padding:4px 9px;border-radius:4px;\n  font-weight:800;box-shadow:0 1px 0 rgba(255,255,255,.4) inset,0 2px 6px rgba(0,0,0,.4);\n}\n\n/* ---------- LCD waveform window ---------- */\n.lcd{\n  position:relative;z-index:2;margin:14px 18px 4px;border-radius:9px;overflow:hidden;\n  background:linear-gradient(180deg,#0b1a14,#06120d);\n  border:1px solid #02100a;\n  box-shadow:0 2px 0 rgba(255,255,255,.05) inset,0 -10px 22px rgba(0,0,0,.6) inset,0 1px 2px rgba(0,0,0,.5);\n}\n.lcd::after{ /* scanline glass */\n  content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:repeating-linear-gradient(0deg,rgba(0,0,0,.18) 0 1px,transparent 1px 3px);\n  opacity:.5;\n}\n.lcd .scr{display:block;width:100%;height:96px}\n.lcd .tag{\n  position:absolute;top:7px;left:10px;font-size:9px;letter-spacing:.18em;color:#3ddc97;\n  text-shadow:0 0 6px rgba(61,220,151,.6);text-transform:uppercase;z-index:3;\n}\n.lcd .rate{\n  position:absolute;top:7px;right:10px;font-size:9px;letter-spacing:.12em;color:#3ddc97;\n  text-shadow:0 0 6px rgba(61,220,151,.6);z-index:3;font-variant-numeric:tabular-nums;\n}\n\n/* ---------- main work area: pads + faders ---------- */\n.work{position:relative;z-index:2;display:flex;gap:14px;padding:14px 18px 16px}\n\n/* pad grid */\n.pads{\n  display:grid;grid-template-columns:repeat(4,1fr);gap:9px;flex:1;\n}\n.pad{\n  position:relative;aspect-ratio:1/1;border-radius:9px;cursor:pointer;user-select:none;\n  background:linear-gradient(165deg,#2b2118,#161009 70%,#0d0905);\n  border:1px solid #070402;\n  box-shadow:\n    0 3px 0 #000,0 5px 9px rgba(0,0,0,.6),\n    0 1px 0 rgba(255,255,255,.06) inset,\n    0 -6px 12px rgba(0,0,0,.5) inset;\n  transition:transform .07s ease,box-shadow .07s ease;\n}\n.pad span{ /* corner number */\n  position:absolute;top:6px;left:8px;font-size:9px;color:#6a5847;letter-spacing:.05em;\n}\n.pad .glow{ /* hit glow */\n  position:absolute;inset:0;border-radius:9px;pointer-events:none;opacity:0;\n  background:radial-gradient(circle at 50% 45%,var(--ac2),var(--ac) 45%,transparent 72%);\n  box-shadow:0 0 22px var(--ac),0 0 4px #fff inset;\n}\n.pad.lit .glow{animation:hit .45s ease-out}\n@keyframes hit{0%{opacity:.95}100%{opacity:0}}\n.pad.lit{\n  transform:translateY(3px);\n  box-shadow:0 0 0 #000,0 1px 3px rgba(0,0,0,.6),0 0 16px rgba(255,158,84,.35) inset;\n}\n.pad:hover{box-shadow:0 3px 0 #000,0 5px 9px rgba(0,0,0,.6),0 0 0 1px rgba(255,158,84,.25) inset,0 -6px 12px rgba(0,0,0,.5) inset}\n\n/* fader strip on the right */\n.strip{\n  width:118px;flex:none;display:flex;flex-direction:column;gap:9px;\n  padding:11px 12px;border-radius:11px;\n  background:linear-gradient(180deg,#181208,#0c0805);\n  border:1px solid #050302;\n  box-shadow:0 1px 0 rgba(255,255,255,.05) inset,0 -8px 16px rgba(0,0,0,.5) inset;\n}\n.striphd{font-size:8.5px;letter-spacing:.22em;color:var(--dim);text-transform:uppercase;text-align:center}\n.fader{\n  position:relative;display:flex;flex-direction:column;align-items:center;\n}\n.fname{font-size:8.5px;letter-spacing:.12em;color:var(--dim);text-transform:uppercase;margin-bottom:5px}\n.track{\n  position:relative;width:100%;height:74px;border-radius:5px;cursor:ns-resize;touch-action:none;\n  background:linear-gradient(90deg,#0a0604,#160f08,#0a0604);\n  box-shadow:0 0 0 1px #000 inset,0 2px 5px rgba(0,0,0,.6) inset;\n}\n.track .fill{ /* lit portion below the cap */\n  position:absolute;left:50%;bottom:6px;width:3px;transform:translateX(-50%);border-radius:2px;\n  background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 7px var(--ac);\n  transition:height .08s linear;\n}\n.cap{\n  position:absolute;left:50%;width:34px;height:15px;transform:translate(-50%,50%);\n  border-radius:4px;\n  background:linear-gradient(180deg,#4a4036,#1d1610);\n  border:1px solid #000;\n  box-shadow:0 2px 4px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.12) inset;\n  transition:bottom .08s linear;\n}\n.cap::before{ /* grip line */\n  content:\"\";position:absolute;left:5px;right:5px;top:50%;height:2px;transform:translateY(-50%);\n  border-radius:2px;background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 5px var(--ac);\n}\n.fval{font-size:9px;color:var(--ink);margin-top:5px;font-variant-numeric:tabular-nums}\n\n/* ---------- bottom control row: 6 mini-knobs ---------- */\n.knobs{\n  position:relative;z-index:2;display:grid;grid-template-columns:repeat(6,1fr);gap:6px;\n  padding:0 18px 8px;\n}\n.kn{\n  display:flex;flex-direction:column;align-items:center;gap:6px;padding:9px 2px 8px;\n  border-radius:10px;transition:background .15s ease,transform .15s ease;\n  animation:rise .55s both;\n}\n.kn:nth-child(1){animation-delay:.05s}.kn:nth-child(2){animation-delay:.10s}\n.kn:nth-child(3){animation-delay:.15s}.kn:nth-child(4){animation-delay:.20s}\n.kn:nth-child(5){animation-delay:.25s}.kn:nth-child(6){animation-delay:.30s}\n@keyframes rise{from{opacity:0;transform:translateY(9px)}to{opacity:1;transform:none}}\n.kn:hover{background:rgba(255,158,84,.05);transform:translateY(-2px)}\n.dial{\n  position:relative;width:54px;height:54px;cursor:ns-resize;touch-action:none;user-select:none;\n}\n.dial .ring{ /* progress arc */\n  position:absolute;inset:0;border-radius:50%;--n:0;\n  background:conic-gradient(from 220deg,var(--ac) calc(var(--n)*280deg),rgba(255,255,255,.06) calc(var(--n)*280deg) 280deg,transparent 280deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*7px) rgba(255,158,84,.55));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1);\n}\n.dial .knurl{ /* knurled body */\n  position:absolute;inset:7px;border-radius:50%;\n  background:\n    repeating-conic-gradient(#3a2e22 0 4deg,#241c15 4deg 8deg),\n    radial-gradient(circle at 50% 32%,#4a3c2c,#16100a 75%);\n  background-blend-mode:overlay,normal;\n  box-shadow:0 2px 5px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.08) inset;\n}\n.dial .ptr{\n  position:absolute;top:6px;left:50%;width:3px;height:16px;margin-left:-1.5px;border-radius:2px;\n  background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 6px var(--ac);\n  transform-origin:50% 21px;transform:rotate(calc((var(--n) - .5)*280deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1);\n}\n.dial.act .knurl{box-shadow:0 0 0 1px var(--ac) inset,0 2px 5px rgba(0,0,0,.7)}\n.knm{font-size:8.5px;letter-spacing:.1em;color:var(--dim);text-transform:uppercase}\n.knv{font-size:10px;color:var(--ink);font-variant-numeric:tabular-nums;font-weight:600}\n\n/* footer plate */\n.plate{\n  position:relative;z-index:2;font-size:9.5px;line-height:1.5;color:#7a6957;\n  padding:9px 18px 13px;border-top:1px solid #000;\n  background:linear-gradient(180deg,rgba(0,0,0,.18),rgba(255,255,255,.02));\n  letter-spacing:.02em;\n}\n@property --n{syntax:'<number>';inherits:true;initial-value:0}\n</style></head>\n<body>\n<div class=\"unit\">\n\n  <div class=\"brand\">\n    <span class=\"pwr\"></span>\n    <div class=\"logo\"><b>GRIT&nbsp;SAMPLER</b><small>12-BIT DRUM ENGINE</small></div>\n    <span class=\"model\">SP·12</span>\n  </div>\n\n  <div class=\"lcd\">\n    <span class=\"tag\">WAVE</span>\n    <span class=\"rate\" id=\"rateLbl\">12-BIT</span>\n    <canvas class=\"scr\" id=\"scr\" width=\"600\" height=\"96\"></canvas>\n  </div>\n\n  <div class=\"work\">\n    <div class=\"pads\" id=\"pads\"></div>\n    <div class=\"strip\">\n      <div class=\"striphd\">LEVEL</div>\n      <!-- the master fader (Level param) -->\n      <div class=\"fader\" id=\"lvlFader\">\n        <div class=\"fname\" id=\"lvlName\">LEVEL</div>\n        <div class=\"track\" id=\"lvlTrack\">\n          <div class=\"fill\" id=\"lvlFill\"></div>\n          <div class=\"cap\" id=\"lvlCap\"></div>\n        </div>\n        <div class=\"fval\" id=\"lvlVal\"></div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"knobs\" id=\"knobs\"></div>\n\n  <div class=\"plate\" id=\"plate\"></div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  /* -------- param table re-read from spec.json (exact indices) -------- */\n  var PARAMS = [\n    {name:\"Pitch\", index:0, min:0, max:1, def:0.5},\n    {name:\"Grit\",  index:1, min:0, max:1, def:0.55},\n    {name:\"Crush\", index:2, min:0, max:1, def:0.4},\n    {name:\"Tone\",  index:3, min:0, max:1, def:0.6},\n    {name:\"Drive\", index:4, min:0, max:1, def:0.35},\n    {name:\"Decay\", index:5, min:0, max:1, def:0.7},\n    {name:\"Level\", index:6, min:0, max:1, def:0.8}\n  ];\n  var byName={}; PARAMS.forEach(function(p){byName[p.name]=p;});\n\n  /* live normalized state per index, drives the waveform render */\n  var state={};\n  PARAMS.forEach(function(p){state[p.index]=(p.def-p.min)/(p.max-p.min||1);});\n\n  function send(p,val){\n    if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,val);\n    state[p.index]=(val-p.min)/(p.max-p.min||1);\n  }\n  function fmt(v){ return (Math.round(v*100)).toString(); } /* 0..1 -> 0..100 */\n\n  /* -------- the six bottom knobs: every param except Level -------- */\n  function buildKnobs(){\n    var host=document.getElementById('knobs');\n    PARAMS.filter(function(p){return p.name!==\"Level\";}).forEach(function(p){\n      var cell=document.createElement('div'); cell.className='kn';\n      cell.innerHTML=\n        '<div class=\"dial\"><i class=\"ring\"></i><i class=\"knurl\"></i><i class=\"ptr\"></i></div>'+\n        '<div class=\"knm\">'+p.name+'</div><div class=\"knv\"></div>';\n      host.appendChild(cell);\n\n      var dial=cell.querySelector('.dial'), ring=cell.querySelector('.ring'),\n          ptr=cell.querySelector('.ptr'), out=cell.querySelector('.knv');\n      var val=p.def;\n      function norm(){return (val-p.min)/(p.max-p.min||1);}\n      function paint(){\n        var n=norm(); ring.style.setProperty('--n',n); ptr.style.setProperty('--n',n);\n        out.textContent=fmt(n); send(p,val);\n      }\n      function setN(n){ n=n<0?0:n>1?1:n; val=p.min+(p.max-p.min)*n; paint(); }\n\n      dial.addEventListener('pointerdown',function(e){\n        dial._d=1;dial._y=e.clientY;dial._n=norm();dial.classList.add('act');\n        dial.setPointerCapture(e.pointerId);e.preventDefault();\n      });\n      dial.addEventListener('pointermove',function(e){\n        if(!dial._d)return; setN(dial._n+(dial._y-e.clientY)/180);\n      });\n      var stop=function(){dial._d=0;dial.classList.remove('act');};\n      dial.addEventListener('pointerup',stop);\n      dial.addEventListener('pointercancel',stop);\n      dial.addEventListener('dblclick',function(){val=p.def;paint();});\n      dial.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?.03:-.03));},{passive:false});\n      paint();\n    });\n  }\n\n  /* -------- the master fader (Level) -------- */\n  function buildFader(){\n    var p=byName[\"Level\"];\n    document.getElementById('lvlName').textContent=p.name;\n    var track=document.getElementById('lvlTrack'),\n        fill=document.getElementById('lvlFill'),\n        cap=document.getElementById('lvlCap'),\n        out=document.getElementById('lvlVal');\n    var val=p.def, H=74, pad=6, range=H-pad*2-7;\n    function norm(){return (val-p.min)/(p.max-p.min||1);}\n    function paint(){\n      var n=norm();\n      cap.style.bottom=(pad+n*range)+\"px\";\n      fill.style.height=(n*range)+\"px\";\n      out.textContent=fmt(n); send(p,val);\n    }\n    function setN(n){n=n<0?0:n>1?1:n;val=p.min+(p.max-p.min)*n;paint();}\n    function fromEvent(e){\n      var r=track.getBoundingClientRect();\n      var y=(r.bottom-e.clientY-pad-3.5)/range;\n      setN(y);\n    }\n    track.addEventListener('pointerdown',function(e){\n      track._d=1;track.setPointerCapture(e.pointerId);fromEvent(e);e.preventDefault();\n    });\n    track.addEventListener('pointermove',function(e){if(track._d)fromEvent(e);});\n    var stop=function(){track._d=0;};\n    track.addEventListener('pointerup',stop);\n    track.addEventListener('pointercancel',stop);\n    track.addEventListener('dblclick',function(){val=p.def;paint();});\n    track.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?.03:-.03));},{passive:false});\n    paint();\n  }\n\n  /* -------- 16 trigger pads (perform; optional noteOn) -------- */\n  function buildPads(){\n    var host=document.getElementById('pads');\n    /* MPC layout: bottom-left is the lowest note. Map to a small kit spread. */\n    var base=48;\n    for(var r=0;r<4;r++){\n      for(var c=0;c<4;c++){\n        var idx=r*4+c, note=base+( (3-r)*4 + c ); /* top rows = higher */\n        var pad=document.createElement('div'); pad.className='pad';\n        pad.dataset.note=note;\n        pad.innerHTML='<i class=\"glow\"></i><span>'+(idx+1)+'</span>';\n        host.appendChild(pad);\n      }\n    }\n    var pads=host.querySelectorAll('.pad'), active={};\n    function hz(m){return 440*Math.pow(2,(m-69)/12);}\n    function trigger(pad){\n      var n=+pad.dataset.note;\n      pad.classList.remove('lit'); void pad.offsetWidth; pad.classList.add('lit');\n      if(window.vstai&&window.vstai.noteOn) window.vstai.noteOn(n,hz(n),0.95);\n      pulseScope();\n    }\n    function release(pad){\n      var n=+pad.dataset.note;\n      if(window.vstai&&window.vstai.noteOff) window.vstai.noteOff(n);\n    }\n    pads.forEach(function(pad){\n      pad.addEventListener('pointerdown',function(e){e.preventDefault();active[pad.dataset.note]=1;trigger(pad);});\n      pad.addEventListener('pointerup',function(){release(pad);});\n      pad.addEventListener('pointerleave',function(){if(active[pad.dataset.note]){active[pad.dataset.note]=0;release(pad);}});\n      pad.addEventListener('pointercancel',function(){release(pad);});\n    });\n  }\n\n  /* -------- bit-crushed waveform display (rAF) -------- */\n  var cv=document.getElementById('scr'), g=cv.getContext('2d');\n  var rateLbl=document.getElementById('rateLbl');\n  var t=0, hitEnv=0;\n  function pulseScope(){ hitEnv=1; }\n  function draw(){\n    requestAnimationFrame(draw);\n    var W=cv.width,H=cv.height; g.clearRect(0,0,W,H);\n    t+=0.018; hitEnv*=0.94;\n\n    /* params steer the look */\n    var pitch=state[0], grit=state[1], crush=state[2], tone=state[3],\n        drive=state[4], decay=state[5];\n\n    /* crush -> fewer horizontal steps (bit reduction look) */\n    var steps=Math.max(6,Math.round(64-crush*52));     /* fewer = more crushed */\n    /* grit -> quantization levels (vertical staircase) */\n    var levels=Math.max(3,Math.round(28-grit*22));\n    rateLbl.textContent=Math.round(16-crush*5)+\"-BIT · \"+(Math.round(8+grit*30))+\"k\";\n\n    /* baseline grid */\n    g.strokeStyle='rgba(61,220,151,.10)';g.lineWidth=1;\n    g.beginPath();g.moveTo(0,H/2);g.lineTo(W,H/2);g.stroke();\n\n    /* build a decaying drum-ish envelope * carrier, then quantize both axes */\n    var amp=0.30+drive*0.5+hitEnv*0.45;\n    var freq=2.2+pitch*5.5;\n    var col='rgba(61,220,151,'+(0.55+hitEnv*0.4)+')';\n    g.strokeStyle=col; g.lineWidth=2;\n    g.shadowBlur=8+hitEnv*14; g.shadowColor='#3ddc97';\n\n    g.beginPath();\n    var prevY=null;\n    for(var sx=0; sx<=steps; sx++){\n      var u=sx/steps;                 /* 0..1 across screen */\n      var env=Math.exp(-u*(2.2+(1-decay)*5));        /* decay shapes tail */\n      /* layered carrier + a little noise for grit */\n      var phase=u*freq*6.28318 + t;\n      var car=Math.sin(phase)+0.4*Math.sin(phase*2.0)*tone+(grit*0.25)*( (Math.sin(phase*13.7+t*3)) );\n      var raw=car*env*amp;\n      raw=raw>1?1:raw<-1?-1:raw;\n      /* vertical quantize -> staircase (bit reduction) */\n      var q=Math.round(raw*levels)/levels;\n      var x=u*W;\n      var y=H/2 - q*(H*0.42);\n      if(prevY===null){ g.moveTo(x,y); }\n      else { g.lineTo(x,prevY); g.lineTo(x,y); } /* sample-and-hold step */\n      prevY=y;\n    }\n    g.stroke();\n    g.shadowBlur=0;\n\n    /* faint sample-point dots */\n    g.fillStyle='rgba(61,220,151,.35)';\n    for(var dx=0; dx<=steps; dx++){\n      var uu=dx/steps;\n      var ee=Math.exp(-uu*(2.2+(1-decay)*5));\n      var ph=uu*freq*6.28318+t;\n      var cc=Math.sin(ph)*ee*amp;\n      cc=Math.round((cc>1?1:cc<-1?-1:cc)*levels)/levels;\n      g.fillRect(uu*W-1, H/2-cc*(H*0.42)-1, 2,2);\n    }\n  }\n  draw();\n\n  /* -------- footer -------- */\n  document.getElementById('plate').textContent=\n    \"12-bit drum engine · pitch-tracked CC0 cadence · variable bit-crush + decimation · soft-clip drive · play the pads\";\n\n  /* -------- init under host hook -------- */\n  function ready(){\n    buildPads();\n    buildFader();\n    buildKnobs();\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  GRIT SAMPLER — a 12-bit, gritty drum sampler instrument.\n//  An embedded short public-domain (US Navy / CC0) drum-cadence segment is\n//  baked in as base64 Int16 PCM, decoded to an f32 buffer at init(), then\n//  pitch-tracked per played note and deliberately degraded: variable\n//  bit-depth quantization + sample-rate decimation (sample & hold) give the\n//  classic crunchy 12-bit character, followed by a soft-clip drive, a one-\n//  pole tone low-pass and an amp envelope. Pure algorithm, no host imports,\n//  no allocation in process(). Planar f32 buffers, stride 8192.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// --- embedded sample (base64 of Int16-LE mono PCM @ 22050 Hz) ---\nconst SAMPLE_B64: string = \"\";\nconst SAMPLE_SR: f32 = 22050;\nconst BASE_HZ: f32 = 220;\nconst SAMP_CAP: i32 = 44085;\nconst samp: StaticArray<f32> = new StaticArray<f32>(SAMP_CAP);\nlet sampLen: i32 = 0;\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- parameter indices (must match spec.json) ----------------------\nconst P_PITCH: i32 = 0;   // 0..1 -> -12..+12 semitones\nconst P_GRIT:  i32 = 1;   // 0..1 -> bit-depth reduction (12 bits .. ~5 bits)\nconst P_CRUSH: i32 = 2;   // 0..1 -> sample-rate decimation amount\nconst P_TONE:  i32 = 3;   // 0..1 -> low-pass tone (dark .. open)\nconst P_DRIVE: i32 = 4;   // 0..1 -> input drive into soft-clip\nconst P_DECAY: i32 = 5;   // 0..1 -> amp decay time\nconst P_LEVEL: i32 = 6;   // 0..1 -> output level\n\n// ---- per-voice state (no alloc) ------------------------------------\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\nconst vId:     StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\nconst vPos:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // playhead in sample frames\nconst vRate:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // playback rate (semitones)\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // trigger velocity\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // current env value 0..1\nconst vReleased: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n// decimator sample&hold state, per voice\nconst vHold:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n// tone low-pass state, per voice\nconst vLP:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\n\nfunction decodeSample(): void {\n  const s = SAMPLE_B64;\n  const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else {\n        let val = (byte << 8) | lo;\n        if (val >= 32768) val -= 65536;\n        if (si < SAMP_CAP) { samp[si] = f32(val) / 32768.0; si++; }\n        lo = -1;\n      }\n    }\n  }\n  sampLen = si;\n}\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    vActive[i] = 0; vId[i] = -1; vPos[i] = 0.0; vRate[i] = 1.0;\n    vAmp[i] = 0.0; vEnv[i] = 0.0; vReleased[i] = 0;\n    vHold[i] = 0.0; vPhase[i] = 0.0; vLP[i] = 0.0;\n  }\n  params[P_PITCH] = 0.5;\n  params[P_GRIT]  = 0.55;\n  params[P_CRUSH] = 0.4;\n  params[P_TONE]  = 0.6;\n  params[P_DRIVE] = 0.35;\n  params[P_DECAY] = 0.7;\n  params[P_LEVEL] = 0.8;\n  decodeSample();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // find a free voice, else steal the oldest-furthest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) { if (vActive[i] == 0) { slot = i; break; } }\n  if (slot < 0) {\n    let best: f32 = -1.0; let bi: i32 = 0;\n    for (let i = 0; i < NUM_VOICES; i++) { if (vPos[i] > best) { best = vPos[i]; bi = i; } }\n    slot = bi;\n  }\n  const semi: f32 = (params[P_PITCH] - 0.5) * 24.0;        // -12..+12\n  vActive[slot] = 1;\n  vId[slot] = id;\n  vPos[slot] = 0.0;\n  vRate[slot] = (f / BASE_HZ) * f32(Mathf.pow(2.0, semi / 12.0));\n  vAmp[slot] = clampf(v, 0.0, 1.0);\n  vEnv[slot] = 1.0;\n  vReleased[slot] = 0;\n  vHold[slot] = 0.0;\n  vPhase[slot] = 1.0;   // force a fresh sample on first frame\n  vLP[slot] = 0.0;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vId[i] == id) vReleased[i] = 1;\n  }\n}\n\nexport function process(n: i32): void {\n  const grit: f32  = params[P_GRIT];\n  const crush: f32 = params[P_CRUSH];\n  const tone: f32  = params[P_TONE];\n  const drive: f32 = params[P_DRIVE];\n  const decay: f32 = params[P_DECAY];\n  const level: f32 = params[P_LEVEL];\n\n  // bit-depth: 12 bits (clean-ish) down to ~5 bits (very crunchy)\n  const bits: f32 = 12.0 - grit * 7.0;\n  const steps: f32 = f32(Mathf.pow(2.0, bits));     // quantization levels\n  const invSteps: f32 = 1.0 / steps;\n\n  // decimation: hold ratio 1 (none) .. ~0.06 (heavy aliasing)\n  const decim: f32 = 1.0 - crush * 0.94;            // phase increment per output frame\n\n  // tone one-pole LP coefficient (0..1). darker when tone low.\n  const fc: f32 = 200.0 + tone * tone * 9000.0;     // Hz\n  let lpC: f32 = 1.0 - f32(Mathf.exp(-6.2831853 * fc / sampleRate));\n  lpC = clampf(lpC, 0.0, 1.0);\n\n  // drive gain (1 .. ~9) into a tanh-ish soft clip\n  const dg: f32 = 1.0 + drive * 8.0;\n\n  // amp decay coefficient (per-sample multiplicative). longer when decay high.\n  const decaySec: f32 = 0.12 + decay * 3.2;\n  const decK: f32 = f32(Mathf.exp(-1.0 / (decaySec * sampleRate)));\n  // release is always quick\n  const relK: f32 = f32(Mathf.exp(-1.0 / (0.08 * sampleRate)));\n\n  const step: f32 = SAMPLE_SR / sampleRate;          // resample to host rate\n\n  // compensate the drive's perceived loudness so LEVEL stays the master\n  const driveComp: f32 = 1.0 / (0.6 + drive * 0.9);\n  const outGain: f32 = level * 0.9 * driveComp;\n\n  for (let f = 0; f < n; f++) {\n    let mix: f32 = 0.0;\n\n    for (let vi = 0; vi < NUM_VOICES; vi++) {\n      if (vActive[vi] == 0) continue;\n\n      const inc: f32 = vRate[vi] * step;\n\n      // advance decimator phase; refresh held sample when it crosses 1.0\n      let ph: f32 = vPhase[vi] + decim;\n      let s: f32 = vHold[vi];\n      if (ph >= 1.0) {\n        ph -= 1.0;\n        if (ph >= 1.0) ph = 0.0; // guard for extreme rates\n        const p: f32 = vPos[vi];\n        const ip: i32 = i32(p);\n        if (ip + 1 < sampLen) {\n          const fr: f32 = p - f32(ip);\n          s = samp[ip] * (1.0 - fr) + samp[ip + 1] * fr;\n        } else {\n          s = 0.0;\n          vActive[vi] = 0; vId[vi] = -1;\n        }\n        vHold[vi] = s;\n      }\n      vPhase[vi] = ph;\n\n      if (vActive[vi] == 0) continue;\n\n      // bit-depth quantize (the 12-bit grit)\n      s = f32(Mathf.floor(s * steps + 0.5)) * invSteps;\n\n      // soft-clip drive\n      const d: f32 = s * dg;\n      s = d / (1.0 + (d < 0.0 ? -d : d));   // fast tanh-like fold, keeps |s|<1\n\n      // tone low-pass (per voice)\n      let lp: f32 = vLP[vi] + lpC * (s - vLP[vi]);\n      vLP[vi] = lp;\n      s = lp;\n\n      // amp envelope\n      let e: f32 = vEnv[vi];\n      e *= (vReleased[vi] == 1) ? relK : decK;\n      vEnv[vi] = e;\n\n      mix += s * e * vAmp[vi];\n\n      // advance playhead; deactivate at end-of-sample or near-silent\n      vPos[vi] += inc;\n      if (vPos[vi] >= f32(sampLen - 1)) { vActive[vi] = 0; vId[vi] = -1; }\n      else if (e < 0.0003) { vActive[vi] = 0; vId[vi] = -1; }\n    }\n\n    let o: f32 = mix * outGain;\n    if (o > 1.2) o = 1.2; else if (o < -1.2) o = -1.2;\n    outBuf[f] = o;\n    outBuf[MAX_FRAMES + f] = o;\n  }\n}\n",
  "publishedAt": 1751000029000
}