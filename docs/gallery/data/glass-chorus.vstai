{
  "format": 1,
  "name": "Glass Chorus",
  "isInstrument": false,
  "explanation": "A pristine hi-fi stereo chorus/flanger combo. Two fractional delay lines (one per channel) are read with linear interpolation and modulated by quadrature LFOs so the left and right voices sweep in counter-phase for a wide, glassy stereo image. A single Mode control morphs the effect from a lush, gently detuned multi-voice chorus into a short, sweeping flanger comb; the Feedback control adds the resonant flange whoosh, Width spreads the stereo voices and Depth/Rate shape the sweep. The signal path stays clean with no saturation or grit. Controls: Rate, Depth, Mode, Feedback, Width and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Width",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Glass Chorus</title>\n<style>\n  :root{\n    --cyan:#7ae0ff;\n    --lilac:#c0b0ff;\n    --bg0:#080b14;\n    --bg1:#0e1626;\n    --glass:rgba(122,224,255,.06);\n    --ink:#dceaf6;\n    --ink-dim:#7f93ab;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Inter,system-ui,sans-serif;\n    background:\n      radial-gradient(120% 80% at 20% -10%, rgba(122,224,255,.16), transparent 55%),\n      radial-gradient(120% 90% at 90% 110%, rgba(192,176,255,.18), transparent 55%),\n      linear-gradient(160deg,var(--bg1),var(--bg0));\n    color:var(--ink);\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n  }\n  .rack{\n    position:relative;\n    width:660px;max-width:96vw;\n    border-radius:22px;\n    padding:22px 24px 26px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.01) 30%, rgba(0,0,0,.18)),\n      linear-gradient(160deg, #11203a, #0a1120);\n    border:1px solid rgba(122,224,255,.22);\n    box-shadow:\n      0 30px 80px rgba(0,0,0,.6),\n      0 0 0 1px rgba(0,0,0,.4),\n      inset 0 1px 0 rgba(255,255,255,.10),\n      inset 0 -30px 60px rgba(0,0,0,.4);\n  }\n  /* glass sheen sweeping across the rack */\n  .rack::before{\n    content:\"\";position:absolute;inset:0;border-radius:22px;pointer-events:none;\n    background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.10) 47%,rgba(255,255,255,.02) 53%,transparent 70%);\n    background-size:300% 100%;\n    animation:sheen 9s linear infinite;\n    mix-blend-mode:screen;opacity:.7;\n  }\n  @keyframes sheen{0%{background-position:160% 0}100%{background-position:-160% 0}}\n\n  /* rack screws */\n  .screw{position:absolute;width:9px;height:9px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#cfe6f2,#5b7184 60%,#2a3543);\n    box-shadow:inset 0 0 2px rgba(0,0,0,.6),0 1px 1px rgba(0,0,0,.5)}\n  .screw.a{top:11px;left:11px}.screw.b{top:11px;right:11px}\n  .screw.c{bottom:11px;left:11px}.screw.d{bottom:11px;right:11px}\n\n  header{display:flex;align-items:flex-end;justify-content:space-between;margin:0 6px 14px}\n  .brand{display:flex;align-items:center;gap:11px}\n  .logo{width:30px;height:30px;flex:none}\n  .title h1{\n    font-size:19px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;\n    background:linear-gradient(90deg,var(--cyan),var(--lilac));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 0 18px rgba(122,224,255,.25);\n  }\n  .title .sub{font-size:9.5px;letter-spacing:.36em;color:var(--ink-dim);text-transform:uppercase;margin-top:2px}\n  .pwr{display:flex;align-items:center;gap:7px;font-size:9px;letter-spacing:.22em;color:var(--ink-dim);text-transform:uppercase}\n  .led{width:8px;height:8px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#dffaff,var(--cyan));\n    box-shadow:0 0 8px var(--cyan),0 0 16px rgba(122,224,255,.6);\n    animation:pulse 2.4s ease-in-out infinite}\n  @keyframes pulse{0%,100%{opacity:.55;transform:scale(.9)}50%{opacity:1;transform:scale(1.1)}}\n\n  /* ---- visualizer: dual crystalline stereo waveforms ---- */\n  .scope{\n    position:relative;height:158px;border-radius:14px;overflow:hidden;\n    background:\n      radial-gradient(120% 140% at 50% 0%, rgba(122,224,255,.10), transparent 60%),\n      linear-gradient(180deg,#060a12,#0a1322);\n    border:1px solid rgba(122,224,255,.18);\n    box-shadow:inset 0 0 40px rgba(0,0,0,.7),inset 0 1px 0 rgba(255,255,255,.06);\n  }\n  .scope svg{display:block;width:100%;height:100%}\n  .grid line{stroke:rgba(122,224,255,.07);stroke-width:1}\n  .chTag{position:absolute;font-size:9px;letter-spacing:.2em;color:var(--ink-dim);font-weight:600}\n  .chTag.l{top:8px;left:12px;color:var(--cyan)}\n  .chTag.r{bottom:8px;left:12px;color:var(--lilac)}\n  .mtag{position:absolute;top:8px;right:12px;font-size:9px;letter-spacing:.18em;color:var(--ink-dim);text-transform:uppercase}\n  .mtag b{color:var(--cyan)}\n\n  /* ---- morph slider ---- */\n  .morph{margin:16px 4px 4px}\n  .morph .row{display:flex;justify-content:space-between;font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink-dim);margin-bottom:7px}\n  .morph .row b{color:var(--ink)}\n  .mtrack{\n    position:relative;height:26px;border-radius:14px;cursor:ew-resize;\n    background:linear-gradient(90deg,rgba(122,224,255,.16),rgba(192,176,255,.16));\n    border:1px solid rgba(255,255,255,.10);\n    box-shadow:inset 0 2px 8px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.06);\n  }\n  .mfill{position:absolute;top:0;left:0;bottom:0;border-radius:14px;\n    background:linear-gradient(90deg,rgba(122,224,255,.45),rgba(192,176,255,.55));\n    box-shadow:0 0 14px rgba(150,200,255,.4)}\n  .mknob{position:absolute;top:50%;width:30px;height:30px;border-radius:50%;transform:translate(-50%,-50%);\n    background:radial-gradient(circle at 38% 32%,#ffffff,#bfe9ff 38%,#7aa6d8 75%,#3b5a82);\n    box-shadow:0 3px 8px rgba(0,0,0,.55),0 0 16px rgba(122,224,255,.6),inset 0 1px 1px rgba(255,255,255,.8);\n    cursor:grab}\n  .mknob:active{cursor:grabbing}\n\n  /* ---- knob row ---- */\n  .knobs{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:18px}\n  .knob{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .dial{position:relative;width:70px;height:70px;cursor:ns-resize}\n  .dial svg{display:block;width:100%;height:100%;overflow:visible}\n  .dial .cap{transition:filter .15s}\n  .dial:hover .cap{filter:drop-shadow(0 0 7px rgba(122,224,255,.55))}\n  .klabel{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-dim)}\n  .kval{font-size:11px;font-weight:700;color:var(--cyan);font-variant-numeric:tabular-nums}\n  .knob:nth-child(2) .kval,.knob:nth-child(4) .kval{color:var(--lilac)}\n  .hint{text-align:center;margin-top:14px;font-size:8.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(127,147,171,.5)}\n</style>\n</head>\n<body>\n  <div class=\"rack\">\n    <span class=\"screw a\"></span><span class=\"screw b\"></span>\n    <span class=\"screw c\"></span><span class=\"screw d\"></span>\n\n    <header>\n      <div class=\"brand\">\n        <svg class=\"logo\" viewBox=\"0 0 40 40\" fill=\"none\">\n          <defs>\n            <linearGradient id=\"lg\" x1=\"0\" y1=\"0\" x2=\"40\" y2=\"40\">\n              <stop offset=\"0\" stop-color=\"#7ae0ff\"/><stop offset=\"1\" stop-color=\"#c0b0ff\"/>\n            </linearGradient>\n          </defs>\n          <path d=\"M20 3 L34 12 L34 28 L20 37 L6 28 L6 12 Z\" stroke=\"url(#lg)\" stroke-width=\"2\" fill=\"rgba(122,224,255,.06)\"/>\n          <path d=\"M20 3 L20 37 M6 12 L34 28 M34 12 L6 28\" stroke=\"url(#lg)\" stroke-width=\"1\" opacity=\".5\"/>\n        </svg>\n        <div class=\"title\">\n          <h1>Glass Chorus</h1>\n          <div class=\"sub\">Stereo Modulation</div>\n        </div>\n      </div>\n      <div class=\"pwr\"><span class=\"led\"></span>Active</div>\n    </header>\n\n    <div class=\"scope\">\n      <span class=\"chTag l\">L</span>\n      <span class=\"chTag r\">R</span>\n      <span class=\"mtag\" id=\"mtag\">CHORUS</span>\n      <svg viewBox=\"0 0 600 158\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"wlC\" x1=\"0\" y1=\"0\" x2=\"600\" y2=\"0\">\n            <stop offset=\"0\" stop-color=\"#7ae0ff\" stop-opacity=\".2\"/>\n            <stop offset=\".5\" stop-color=\"#7ae0ff\"/>\n            <stop offset=\"1\" stop-color=\"#7ae0ff\" stop-opacity=\".2\"/>\n          </linearGradient>\n          <linearGradient id=\"wlR\" x1=\"0\" y1=\"0\" x2=\"600\" y2=\"0\">\n            <stop offset=\"0\" stop-color=\"#c0b0ff\" stop-opacity=\".2\"/>\n            <stop offset=\".5\" stop-color=\"#c0b0ff\"/>\n            <stop offset=\"1\" stop-color=\"#c0b0ff\" stop-opacity=\".2\"/>\n          </linearGradient>\n          <filter id=\"glow\"><feGaussianBlur stdDeviation=\"2.2\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n        </defs>\n        <g class=\"grid\">\n          <line x1=\"0\" y1=\"39.5\" x2=\"600\" y2=\"39.5\"/>\n          <line x1=\"0\" y1=\"79.5\" x2=\"600\" y2=\"79.5\"/>\n          <line x1=\"0\" y1=\"118.5\" x2=\"600\" y2=\"118.5\"/>\n        </g>\n        <path id=\"waveL\" fill=\"none\" stroke=\"url(#wlC)\" stroke-width=\"2.2\" filter=\"url(#glow)\"/>\n        <path id=\"waveR\" fill=\"none\" stroke=\"url(#wlR)\" stroke-width=\"2.2\" filter=\"url(#glow)\"/>\n        <path id=\"waveLg\" fill=\"none\" stroke=\"#7ae0ff\" stroke-opacity=\".14\" stroke-width=\"6\"/>\n        <path id=\"waveRg\" fill=\"none\" stroke=\"#c0b0ff\" stroke-opacity=\".14\" stroke-width=\"6\"/>\n      </svg>\n    </div>\n\n    <div class=\"morph\">\n      <div class=\"row\"><span>Chorus</span><span>Mode &nbsp;<b id=\"modeReadout\">25%</b></span><span>Flanger</span></div>\n      <div class=\"mtrack\" id=\"mtrack\">\n        <div class=\"mfill\" id=\"mfill\"></div>\n        <div class=\"mknob\" id=\"mknob\"></div>\n      </div>\n    </div>\n\n    <div class=\"knobs\" id=\"knobs\"></div>\n    <div class=\"hint\">Drag knobs &middot; double-click to reset</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // param model — index MUST match assembly.ts\n  var PARAMS = [\n    { name:\"Rate\",     index:0, min:0, max:1, def:0.30 },\n    { name:\"Depth\",    index:1, min:0, max:1, def:0.55 },\n    { name:\"Feedback\", index:3, min:0, max:1, def:0.40 },\n    { name:\"Width\",    index:4, min:0, max:1, def:0.70 },\n    { name:\"Mix\",      index:5, min:0, max:1, def:0.50 }\n  ];\n  var MODE = { name:\"Mode\", index:2, min:0, max:1, def:0.25 };\n\n  var values = {}; // index -> 0..1\n  function send(idx,v){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(idx, v); }\n  function setVal(idx,v){ v = v<0?0:(v>1?1:v); values[idx]=v; send(idx,v); }\n\n  // ---------- knob construction ----------\n  var R=30, CX=35, CY=35, A0=135, A1=405; // arc 135°..405° (270° sweep)\n  function polar(cx,cy,r,deg){ var a=(deg-90)*Math.PI/180; return [cx+r*Math.cos(a), cy+r*Math.sin(a)]; }\n  function arcPath(cx,cy,r,from,to){\n    var p0=polar(cx,cy,r,from), p1=polar(cx,cy,r,to);\n    var large=(to-from)<=180?0:1;\n    return \"M\"+p0[0].toFixed(2)+\" \"+p0[1].toFixed(2)+\" A\"+r+\" \"+r+\" 0 \"+large+\" 1 \"+p1[0].toFixed(2)+\" \"+p1[1].toFixed(2);\n  }\n\n  var knobsEl = document.getElementById(\"knobs\");\n  var dials = {};\n\n  PARAMS.forEach(function(p){\n    var wrap=document.createElement(\"div\"); wrap.className=\"knob\";\n    var dial=document.createElement(\"div\"); dial.className=\"dial\"; dial.tabIndex=0;\n    dial.innerHTML =\n      '<svg viewBox=\"0 0 70 70\">'+\n        '<path d=\"'+arcPath(CX,CY,R,A0,A1)+'\" fill=\"none\" stroke=\"rgba(122,224,255,.12)\" stroke-width=\"4\" stroke-linecap=\"round\"/>'+\n        '<path class=\"fill\" d=\"\" fill=\"none\" stroke=\"url(#dg)\" stroke-width=\"4\" stroke-linecap=\"round\"/>'+\n        '<defs><linearGradient id=\"dg\" x1=\"0\" y1=\"0\" x2=\"70\" y2=\"70\">'+\n          '<stop offset=\"0\" stop-color=\"#7ae0ff\"/><stop offset=\"1\" stop-color=\"#c0b0ff\"/></linearGradient></defs>'+\n        '<circle class=\"cap\" cx=\"35\" cy=\"35\" r=\"20\" fill=\"url(#capg'+p.index+')\" stroke=\"rgba(255,255,255,.18)\"/>'+\n        '<defs><radialGradient id=\"capg'+p.index+'\" cx=\"38%\" cy=\"32%\" r=\"75%\">'+\n          '<stop offset=\"0\" stop-color=\"#22364f\"/><stop offset=\"1\" stop-color=\"#0c1626\"/></radialGradient></defs>'+\n        '<line class=\"ind\" x1=\"35\" y1=\"35\" x2=\"35\" y2=\"19\" stroke=\"#dffaff\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>'+\n      '</svg>';\n    var label=document.createElement(\"div\"); label.className=\"klabel\"; label.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"kval\";\n    wrap.appendChild(dial); wrap.appendChild(label); wrap.appendChild(val);\n    knobsEl.appendChild(wrap);\n\n    var fill=dial.querySelector(\".fill\"), ind=dial.querySelector(\".ind\");\n    dials[p.index]={fill:fill,ind:ind,val:val,p:p};\n    attachKnob(dial,p);\n  });\n\n  function renderKnob(idx){\n    var d=dials[idx], v=values[idx];\n    var ang=A0+(A1-A0)*v;\n    d.fill.setAttribute(\"d\", arcPath(CX,CY,R-0,A0,ang));\n    var rad=(ang-90)*Math.PI/180;\n    var x2=35+16*Math.cos(rad), y2=35+16*Math.sin(rad);\n    d.ind.setAttribute(\"x2\",x2.toFixed(2)); d.ind.setAttribute(\"y2\",y2.toFixed(2));\n    var disp = idx===0 ? rateHz(v) : Math.round(v*100)+\"%\";\n    d.val.textContent = disp;\n  }\n  function rateHz(v){ return (0.05*Math.pow(120,v)).toFixed(2)+\"Hz\"; }\n\n  function attachKnob(dial,p){\n    var dragging=false, startY=0, startV=0;\n    function down(e){ dragging=true; startY=(e.touches?e.touches[0].clientY:e.clientY); startV=values[p.index];\n      e.preventDefault(); window.addEventListener(\"mousemove\",move); window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false}); window.addEventListener(\"touchend\",up); }\n    function move(e){ if(!dragging)return; var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/220; setVal(p.index, startV+dv); renderKnob(p.index); e.preventDefault(); }\n    function up(){ dragging=false; window.removeEventListener(\"mousemove\",move); window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move); window.removeEventListener(\"touchend\",up); }\n    dial.addEventListener(\"mousedown\",down);\n    dial.addEventListener(\"touchstart\",down,{passive:false});\n    dial.addEventListener(\"dblclick\",function(){ setVal(p.index,p.def); renderKnob(p.index); });\n    dial.addEventListener(\"wheel\",function(e){ setVal(p.index, values[p.index]-e.deltaY*0.0012); renderKnob(p.index); e.preventDefault(); },{passive:false});\n  }\n\n  // ---------- morph slider ----------\n  var mtrack=document.getElementById(\"mtrack\"),\n      mfill=document.getElementById(\"mfill\"),\n      mknob=document.getElementById(\"mknob\"),\n      mreadout=document.getElementById(\"modeReadout\"),\n      mtag=document.getElementById(\"mtag\");\n\n  function renderMorph(){\n    var v=values[MODE.index];\n    var pct=(v*100);\n    mfill.style.width=pct+\"%\";\n    mknob.style.left=pct+\"%\";\n    mreadout.textContent=Math.round(pct)+\"%\";\n    mtag.innerHTML = v<0.4 ? \"<b>CHORUS</b>\" : (v>0.6 ? \"<b>FLANGER</b>\" : \"MORPH\");\n  }\n  function morphFromX(clientX){\n    var r=mtrack.getBoundingClientRect();\n    var v=(clientX-r.left)/r.width;\n    setVal(MODE.index,v); renderMorph();\n  }\n  (function(){\n    var dragging=false;\n    function down(e){ dragging=true; morphFromX(e.touches?e.touches[0].clientX:e.clientX);\n      window.addEventListener(\"mousemove\",move); window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false}); window.addEventListener(\"touchend\",up); e.preventDefault(); }\n    function move(e){ if(!dragging)return; morphFromX(e.touches?e.touches[0].clientX:e.clientX); e.preventDefault(); }\n    function up(){ dragging=false; window.removeEventListener(\"mousemove\",move); window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move); window.removeEventListener(\"touchend\",up); }\n    mtrack.addEventListener(\"mousedown\",down);\n    mtrack.addEventListener(\"touchstart\",down,{passive:false});\n    mtrack.addEventListener(\"dblclick\",function(){ setVal(MODE.index,MODE.def); renderMorph(); });\n  })();\n\n  // ---------- animated stereo waveforms ----------\n  var waveL=document.getElementById(\"waveL\"), waveR=document.getElementById(\"waveR\"),\n      waveLg=document.getElementById(\"waveLg\"), waveRg=document.getElementById(\"waveRg\");\n  var W=600, t=0;\n  function buildWave(yc, phaseOff, amp, freq, modeV){\n    var pts=[], N=72;\n    // mode bends the carrier: chorus -> smooth wide; flanger -> tighter comb ripple\n    var combo = 1 + modeV*3;\n    for(var i=0;i<=N;i++){\n      var x=i/N*W;\n      var base=Math.sin((i/N)*Math.PI*2*freq + t + phaseOff);\n      var ripple=Math.sin((i/N)*Math.PI*2*freq*combo + t*1.7 + phaseOff)*modeV*0.45;\n      var shimmer=Math.sin((i/N)*Math.PI*9 - t*2.3)*0.06;\n      var y=yc + (base*(1-modeV*0.3) + ripple + shimmer)*amp;\n      pts.push(x.toFixed(1)+\" \"+y.toFixed(1));\n    }\n    return \"M\"+pts.join(\" L\");\n  }\n  function frame(){\n    var rate=values[0], depth=values[1], modeV=values[2], width=values[4], mix=values[5];\n    var spd=0.02 + rate*0.16;\n    t += spd;\n    var amp = (6 + depth*22) * (0.3 + mix*0.7);\n    var freq = 1.4 + depth*1.2;\n    // width pushes the two waves apart in phase\n    var ph = 0.4 + width*2.6;\n    var d1=buildWave(48, 0, amp, freq, modeV);\n    var d2=buildWave(110, ph, amp, freq, modeV);\n    waveL.setAttribute(\"d\",d1); waveLg.setAttribute(\"d\",d1);\n    waveR.setAttribute(\"d\",d2); waveRg.setAttribute(\"d\",d2);\n    requestAnimationFrame(frame);\n  }\n\n  // ---------- init ----------\n  function ready(){\n    PARAMS.forEach(function(p){ setVal(p.index,p.def); renderKnob(p.index); });\n    setVal(MODE.index, MODE.def); renderMorph();\n    requestAnimationFrame(frame);\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  GLASS CHORUS — pristine hi-fi stereo chorus / flanger combo\n//  A studio-grade stereo modulation effect that morphs\n//  between a lush multi-voice CHORUS and a sweeping FLANGER via a single\n//  Mode control. Two fractional delay lines (one per channel) are read\n//  with linear interpolation and modulated by quadrature LFOs so the left\n//  and right voices sweep in counter-phase for a wide, glassy stereo image.\n//\n//  Mode morphs the delay range + dry/wet voicing: at 0 the lines sit in\n//  the long, gently detuned CHORUS region (~7..30 ms) and the wet voices\n//  are summed with the dry for thick width; at 1 they collapse into the\n//  short FLANGER comb region (~0.2..6 ms) where the resonant Feedback path\n//  produces the metallic flange whoosh. Width spreads the stereo voices.\n//  Clean signal path — no saturation, no grit. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: chorus needs up to ~30 ms. 30 ms @ 96k -> 2880 samples.\n// Give generous headroom -> 4096 per channel.\nconst DLY_LEN: i32 = 4096;\nconst dline:  StaticArray<f32> = new StaticArray<f32>(DLY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // 0..1\nconst fbState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // last delayed out (feedback)\nconst dampState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // gentle wet de-fizz LP\n\nconst P_RATE:  i32 = 0;  // 0..1 -> 0.05..6 Hz\nconst P_DEPTH: i32 = 1;  // 0..1 sweep depth\nconst P_MODE:  i32 = 2;  // 0..1 chorus<->flanger morph\nconst P_FB:    i32 = 3;  // 0..1 -> flange resonance (feedback)\nconst P_WIDTH: i32 = 4;  // 0..1 stereo spread\nconst P_MIX:   i32 = 5;  // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0;\n    lfoPhase[c] = 0.0;   // channels start in phase; Width opens the quadrature spread\n    fbState[c] = 0.0;\n    dampState[c] = 0.0;\n  }\n  for (let i = 0; i < DLY_LEN * MAX_CHANNELS; i++) dline[i] = 0.0;\n  params[P_RATE] = 0.3; params[P_DEPTH] = 0.55; params[P_MODE] = 0.25;\n  params[P_FB] = 0.4; params[P_WIDTH] = 0.7; params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  const rateN:  f32 = clampf(params[P_RATE],  0.0, 1.0);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const modeN:  f32 = clampf(params[P_MODE],  0.0, 1.0);\n  const fbN:    f32 = clampf(params[P_FB],    0.0, 1.0);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const mix:    f32 = clampf(params[P_MIX],   0.0, 1.0);\n\n  // LFO rate: gentle exponential map 0.05..6 Hz\n  const rateHz: f32 = f32(0.05 * Mathf.pow(120.0, rateN));\n  const phInc:  f32 = rateHz / sampleRate;\n\n  // --- Mode morph (chorus -> flanger) -------------------------------\n  // Chorus: long, slowly detuned delays (lush). Flanger: short comb.\n  // Base delay centre collapses from ~14 ms (chorus) to ~1.4 ms (flanger).\n  const baseMsChorus: f32 = 14.0;\n  const baseMsFlange: f32 = 1.4;\n  const baseMs: f32 = baseMsChorus + (baseMsFlange - baseMsChorus) * modeN;\n  // Sweep span: chorus uses a wide gentle sweep; flanger a tight fast comb.\n  const sweepMsChorus: f32 = 8.0;\n  const sweepMsFlange: f32 = 3.0;\n  const sweepMs: f32 = (sweepMsChorus + (sweepMsFlange - sweepMsChorus) * modeN) * depthN;\n\n  const baseSamp:  f32 = baseMs  * sampleRate * 0.001;\n  const sweepSamp: f32 = sweepMs * sampleRate * 0.001;\n\n  // Feedback (flange resonance) only meaningfully engages as we morph toward\n  // flanger — but keep a little active in chorus too so the knob is alive.\n  // fbGate scales from ~0.25 (chorus end) up to 1.0 (flanger end).\n  const fbGate: f32 = 0.25 + 0.75 * modeN;\n  const fb: f32 = clampf(fbN * 0.85 * fbGate, 0.0, 0.85);\n\n  // Wet voicing: chorus blends dry+wet for body; flanger is a tighter comb.\n  // wetGain trims the wet a touch in flanger to keep peaks bounded with fb.\n  const wetGain: f32 = 0.72 - 0.12 * modeN;\n\n  // Width: phase spread between the two channel LFOs. 0 -> mono-ish (both in\n  // phase), 1 -> full counter-phase quadrature for a wide glassy image.\n  const widthSpread: f32 = widthN; // applied as extra R-channel phase offset\n\n  // Gentle wet damping LP to keep it glassy-clean (de-fizz the comb highs).\n  const dampHz: f32 = 9000.0;\n  const cDamp: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * dampHz / sampleRate));\n\n  const maxD: f32 = f32(DLY_LEN - 2);\n\n  for (let c = 0; c < channels; c++) {\n    const cbase: i32 = c * DLY_LEN;\n    let wp: i32  = writePos[c];\n    let ph: f32  = lfoPhase[c];\n    let fbs: f32 = fbState[c];\n    let dmp: f32 = dampState[c];\n\n    // Per-channel LFO phase offset scaled by Width (R leads more as width up).\n    const chOffset: f32 = c == 1 ? widthSpread * 0.5 : 0.0;\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // Sine LFO 0..1 with per-channel width offset.\n      let lph: f32 = ph + chOffset;\n      if (lph >= 1.0) lph -= 1.0;\n      const s: f32 = f32(Mathf.sin(lph * 6.2831853));\n      const lfo01: f32 = 0.5 + 0.5 * s;\n\n      let dSamp: f32 = baseSamp + lfo01 * sweepSamp;\n      dSamp = clampf(dSamp, 1.0, maxD);\n\n      // fractional read position behind the write pointer.\n      // Wrap into [0, DLY_LEN) then clamp hard below the top index so f32\n      // rounding (e.g. baseSamp not being exact) can never produce rp == DLY_LEN.\n      let rp: f32 = f32(wp) - dSamp;\n      while (rp < 0.0) rp += f32(DLY_LEN);\n      if (rp >= f32(DLY_LEN)) rp -= f32(DLY_LEN);\n      rp = clampf(rp, 0.0, f32(DLY_LEN) - 1.0001);\n      let i0: i32 = i32(rp);\n      // Belt-and-braces integer clamp: the delay read can never index out of\n      // range regardless of any residual f32 rounding.\n      i0 = i0 < 0 ? 0 : (i0 >= DLY_LEN ? DLY_LEN - 1 : i0);\n      const frac: f32 = rp - f32(i0);\n      let i1: i32 = i0 + 1;\n      if (i1 >= DLY_LEN) i1 -= DLY_LEN;\n      i1 = i1 < 0 ? 0 : (i1 >= DLY_LEN ? DLY_LEN - 1 : i1);\n      const a0: f32 = dline[cbase + i0];\n      const a1: f32 = dline[cbase + i1];\n      let delayed: f32 = a0 + (a1 - a0) * frac;\n\n      // glassy de-fizz on the delayed signal\n      dmp = dmp + cDamp * (delayed - dmp);\n      delayed = dmp;\n\n      // write input + feedback (resonant flange path)\n      dline[cbase + wp] = x + delayed * fb;\n\n      // wet voice: dry body + modulated voice (chorus blends, flanger combs)\n      const wet: f32 = x * 0.55 + delayed * wetGain;\n\n      // Width: spread wet voices in stereo. Keep dry centred; pan the wet\n      // voice in opposite directions per channel as width increases.\n      const wetPan: f32 = c == 0 ? (1.0 + widthSpread * 0.3) : (1.0 - widthSpread * 0.3);\n      const wetW: f32 = wet * wetPan;\n\n      outBuf[c * MAX_FRAMES + f] = x * (1.0 - mix) + wetW * mix;\n\n      fbs = delayed;\n\n      wp++;\n      if (wp >= DLY_LEN) wp = 0;\n      ph += phInc;\n      if (ph >= 1.0) ph -= 1.0;\n    }\n\n    writePos[c]  = wp;\n    lfoPhase[c]  = ph;\n    fbState[c]   = fbs;\n    dampState[c] = dmp;\n  }\n}\n",
  "publishedAt": 1751000144000
}