  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Rover Mono</title>\n<style>\n  :root{ --acc:#e08040; --acc2:#3a90c0; --bg0:#0e0a06; --bg1:#1b130b; --ink:#f4ece0; --dim:#988570; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#2a1e10 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#231810,#0e0a06); border:1px solid rgba(224,128,64,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(244,236,224,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.0s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:100px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#19110a,#0e0906); border:1px solid rgba(224,128,64,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(230,220,205,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(224,128,64,.6)); }\n  .pcap{ fill:#170f09; stroke:rgba(224,128,64,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(224,128,64,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(224,128,64,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">ROVER&nbsp;MONO</span><span class=\"sub\">two-osc moog mono</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">OSC&nbsp;·&nbsp;LADDER</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.45},{name:\"Reso\",idx:1,def:0.5},{name:\"Env\",idx:2,def:0.6},{name:\"Interval\",idx:3,def:0.52},{name:\"Osc Mix\",idx:4,def:0.5},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#e08040\"/><stop offset=\"1\" stop-color=\"#3a90c0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=(p.idx===3)?((Math.round(v*24-12)>0?\"+\":\"\")+Math.round(v*24-12)+\" st\"):Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], reso=vals[1], env=vals[2], interval=vals[3], mix=vals[4]; var mid=H*0.54;\n    var ratio2=Math.pow(2,(interval*24-12)/12);\n    var fenv=Math.exp(-((ts/1300)%1)*(1+env*3)); var effCut=cut+env*0.5*fenv; if(effCut>1)effCut=1;\n    // faint osc1 (orange) and osc2 (blue at interval)\n    function saw(rt,col,amp,off){ ctx.beginPath(); for(var x=0;x<=W;x+=2){ var t=x/W; var ph=((t*3*rt+ts/1100+off)%1); var v=(ph*2-1); ctx.lineTo(x, mid - v*amp); } ctx.strokeStyle=col; ctx.lineWidth=1; ctx.stroke(); }\n    saw(1,\"rgba(224,128,64,0.3)\",H*0.12,0); saw(ratio2,\"rgba(58,144,192,0.3)\",H*0.12,0.3);\n    // combined + ladder-rolloff output (thicker, gradient)\n    ctx.beginPath();\n    for(var x2=0;x2<=W;x2+=1.5){ var t=x2/W; var ph1=((t*3+ts/1100)%1); var ph2=((t*3*ratio2+ts/1100+0.3)%1);\n      var o1=(ph1*2-1), o2=(ph2*2-1); var s=(o1*(1-mix)+o2*mix);\n      // crude lowpass shaping by cutoff (attenuate high-freq wiggle)\n      var v=s*(0.35+effCut*0.55); v = v/(1+reso*0.2) + Math.sin(t*40*6.2831853+ts/200)*reso*0.05*effCut;\n      ctx.lineTo(x2, mid - v*(H*0.30)); }\n    var grd=ctx.createLinearGradient(0,0,W,0); grd.addColorStop(0,\"#e08040\"); grd.addColorStop(1,\"#3a90c0\");\n    ctx.strokeStyle=grd; ctx.lineWidth=2; ctx.shadowColor=\"#e08040\"; ctx.shadowBlur=7; ctx.stroke(); ctx.shadowBlur=0;\n    // ladder cutoff bar at bottom\n    var bx=12+effCut*(W-24); ctx.fillStyle=\"rgba(58,144,192,0.6)\"; ctx.fillRect(12, H-8, effCut*(W-24), 3);\n    ctx.strokeStyle=\"rgba(224,128,64,0.7)\"; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(bx,H-12); ctx.lineTo(bx,H-4); ctx.stroke();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  ROVER MONO — a budget two-oscillator Moog mono (Moog Rogue lineage).\n//  Two sawtooth oscillators: osc1 tracks the note, OSC2 INTERVAL tunes\n//  the second up to +/- an octave for fat detune, unison, fifths or\n//  octave stacks, and OSC MIX balances them. They run through a warm,\n//  resonant FOUR-POLE Moog-style ladder low-pass with its own envelope\n//  for the classic squelchy Moog bass and lead. Mono, last-note.\n//  Controls: Cutoff, Resonance, Env Amount, Osc2 Interval, Osc Mix, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet ph1: f32 = 0.0; let ph2: f32 = 0.0;\nlet curFreq: f32 = 110.0; let targetFreq: f32 = 110.0;\nlet gate: i32 = 0; let note: i32 = -1; let amp: f32 = 0.0; let fenv: f32 = 0.0;\nlet lp1: f32 = 0.0; let bp1: f32 = 0.0; let lp2: f32 = 0.0; let bp2: f32 = 0.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_INTERVAL: i32 = 3; const P_MIX: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  ph1 = 0.0; ph2 = 0.0; curFreq = 110.0; targetFreq = 110.0; gate = 0; note = -1; amp = 0.0; fenv = 0.0;\n  lp1 = 0.0; bp1 = 0.0; lp2 = 0.0; bp2 = 0.0;\n  params[P_CUTOFF] = 0.45; params[P_RESO] = 0.5; params[P_ENV] = 0.6; params[P_INTERVAL] = 0.52; params[P_MIX] = 0.5; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 110.0;\n  if (gate == 0) curFreq = nf;\n  targetFreq = nf; note = id; gate = 1; fenv = 1.0; amp = clampf(v, 0.1, 1.0);\n}\nexport function noteOff(id: i32): void { if (id == note) gate = 0; }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const intervalN: f32 = clampf(params[P_INTERVAL], 0.0, 1.0);\n  const mixN: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const semis: f32 = intervalN * 24.0 - 12.0;                 // -12..+12 st\n  const ratio2: f32 = f32(Mathf.pow(2.0, semis / 12.0));\n  const glide: f32 = f32(Mathf.exp(-1.0 / (0.012 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate)));\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / (1.5 * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.2 * sampleRate)));\n  const baseCut: f32 = 45.0 * f32(Mathf.exp(cutoffN * 5.4));\n  const envSpan: f32 = envN * 7500.0;\n  const k: f32 = 1.7 - 1.55 * resoN;                         // per-stage damping\n  const g1: f32 = mixN;                                       // osc mix\n  const out: f32 = level * 0.55;\n\n  for (let i = 0; i < n; i++) {\n    curFreq = targetFreq + (curFreq - targetFreq) * glide;\n    if (gate != 0) { if (amp < 1.0) { amp += 0.004; if (amp > 1.0) amp = 1.0; } else { amp *= decCoef; } }\n    else { amp *= relCoef; }\n    fenv *= fEnvCoef;\n\n    let p1: f32 = ph1 + curFreq / sampleRate; if (p1 >= 1.0) p1 -= 1.0; ph1 = p1;\n    let p2: f32 = ph2 + (curFreq * ratio2) / sampleRate; if (p2 >= 1.0) p2 -= 1.0; ph2 = p2;\n    const o1: f32 = p1 * 2.0 - 1.0;\n    const o2: f32 = p2 * 2.0 - 1.0;\n    let osc: f32 = (o1 * (1.0 - g1) + o2 * g1) * 0.9;\n\n    let fc: f32 = baseCut + envSpan * fenv;\n    if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n    const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n    const a1: f32 = 1.0 / (1.0 + g * (g + k));\n    // ladder = 2 cascaded SVF LP stages (4-pole)\n    const hp1: f32 = (osc - (g + k) * bp1 - lp1) * a1;\n    const b1: f32 = g * hp1 + bp1; const l1: f32 = g * b1 + lp1; bp1 = b1; lp1 = l1;\n    const hp2: f32 = (l1 - (g + k) * bp2 - lp2) * a1;\n    const b2: f32 = g * hp2 + bp2; const l2: f32 = g * b2 + lp2; bp2 = b2; lp2 = l2;\n\n    let o: f32 = f32(Mathf.tanh(l2 * amp * out * 1.4));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751312600000
}