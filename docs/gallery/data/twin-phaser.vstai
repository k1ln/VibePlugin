{
  "format": 1,
  "name": "Twin Phaser",
  "isInstrument": false,
  "explanation": "A dual phaser built from two independent 4-stage allpass engines, each swept by its own LFO. Run them summed for wide, beating notch patterns or chained in series for deep stacked sweeps, with per-engine feedback that sharpens the moving notches into vocal resonances.",
  "params": [
    {
      "name": "Rate A",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Rate B",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Depth",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mode",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Twin Phaser</title>\n<style>\n  :root {\n    --acc:  #7ad0c0;\n    --acc2: #9ad0ff;\n    --bg0:  #0d1416;\n    --bg1:  #14201f;\n    --panel:#1b2a2b;\n    --panel2:#15211f;\n    --ink:  #d8e8e6;\n    --dim:  #6f8a89;\n    --line: rgba(122,208,192,0.16);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background:\n      radial-gradient(1200px 600px at 50% -10%, #1d3231 0%, transparent 60%),\n      linear-gradient(160deg, #0d1416 0%, #0a1011 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .wrap {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 18px 18px 28px;\n  }\n\n  /* ===== panel shell ===== */\n  .panel {\n    position: relative;\n    border-radius: 18px;\n    padding: 18px 20px 22px;\n    background:\n      linear-gradient(180deg, #21302f 0%, #16221f 55%, #111a18 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.06) inset,\n      0 -2px 0 rgba(0,0,0,0.55) inset,\n      0 22px 50px rgba(0,0,0,0.55),\n      0 2px 0 rgba(0,0,0,0.6);\n    border: 1px solid rgba(255,255,255,0.04);\n  }\n  /* corner screws */\n  .screw {\n    position: absolute; width: 11px; height: 11px; border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #4a5b59, #1a2322 70%);\n    box-shadow: 0 1px 1px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,0,0,0.4);\n  }\n  .screw::after {\n    content: \"\"; position: absolute; inset: 3px; border-radius: 1px;\n    background: linear-gradient(90deg, transparent 44%, #0c1211 44%, #0c1211 56%, transparent 56%);\n  }\n  .screw.tl { top: 10px; left: 10px; } .screw.tr { top: 10px; right: 10px; }\n  .screw.bl { bottom: 10px; left: 10px; } .screw.br { bottom: 10px; right: 10px; }\n\n  /* ===== header ===== */\n  header {\n    display: flex; align-items: center; justify-content: space-between;\n    padding: 2px 6px 14px;\n    border-bottom: 1px solid var(--line);\n    margin-bottom: 16px;\n  }\n  .brand { display: flex; align-items: center; gap: 12px; }\n  .glyph {\n    width: 40px; height: 40px; flex: 0 0 auto;\n    filter: drop-shadow(0 0 6px rgba(122,208,192,0.4));\n  }\n  .titles h1 {\n    margin: 0; font-size: 20px; letter-spacing: 5px; font-weight: 700;\n    background: linear-gradient(90deg, var(--acc), var(--acc2));\n    -webkit-background-clip: text; background-clip: text; color: transparent;\n  }\n  .titles p {\n    margin: 2px 0 0; font-size: 9.5px; letter-spacing: 3.5px;\n    text-transform: uppercase; color: var(--dim);\n  }\n  .stamp {\n    font-size: 8.5px; letter-spacing: 2px; text-transform: uppercase;\n    color: var(--dim); text-align: right; line-height: 1.5;\n    border: 1px solid var(--line); border-radius: 8px; padding: 6px 9px;\n  }\n  .stamp b { color: var(--acc); }\n\n  /* ===== twin scope ===== */\n  .scopes {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;\n    margin-bottom: 18px;\n  }\n  .scope {\n    position: relative; border-radius: 12px; overflow: hidden;\n    background:\n      radial-gradient(120% 80% at 50% 0%, #16302d 0%, #0a1413 70%);\n    border: 1px solid rgba(122,208,192,0.18);\n    box-shadow: 0 2px 0 rgba(0,0,0,0.5) inset, 0 0 24px rgba(0,0,0,0.4) inset;\n  }\n  .scope .tag {\n    position: absolute; top: 7px; left: 10px; z-index: 2;\n    font-size: 9px; letter-spacing: 3px; text-transform: uppercase;\n    color: var(--dim);\n  }\n  .scope .rateread {\n    position: absolute; top: 7px; right: 10px; z-index: 2;\n    font-size: 10px; letter-spacing: 1px; color: var(--acc);\n    font-variant-numeric: tabular-nums;\n  }\n  .scope.b .rateread { color: var(--acc2); }\n  .scope canvas { display: block; width: 100%; height: 120px; }\n\n  .modepill {\n    position: absolute; left: 50%; top: 50%; transform: translate(-50%,-50%);\n    z-index: 5; pointer-events: none;\n    font-size: 9px; letter-spacing: 3px; text-transform: uppercase;\n    color: var(--ink); background: rgba(8,16,15,0.7);\n    border: 1px solid var(--line); border-radius: 20px; padding: 4px 12px;\n    opacity: 0; transition: opacity 0.35s;\n  }\n  .scopes.linkflash .modepill { opacity: 1; }\n\n  /* link bracket between scopes */\n  .linkrow {\n    grid-column: 1 / -1; display: flex; justify-content: center;\n    margin-top: -4px;\n  }\n\n  /* ===== controls ===== */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(96px, 1fr));\n    gap: 14px;\n    align-items: start;\n  }\n  .cell {\n    display: flex; flex-direction: column; align-items: center; gap: 8px;\n    padding: 12px 6px 10px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.18));\n    border: 1px solid rgba(255,255,255,0.03);\n  }\n  .cell .lab {\n    font-size: 9.5px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--dim);\n  }\n  .cell .val {\n    font-size: 12px; color: var(--ink); font-variant-numeric: tabular-nums;\n    letter-spacing: 0.5px;\n  }\n  .knob { width: 72px; height: 72px; cursor: ns-resize; touch-action: none; }\n  .knob:focus { outline: none; }\n\n  /* mode toggle (discrete) */\n  .modecell { justify-content: space-between; }\n  .seg {\n    display: flex; gap: 4px; padding: 4px;\n    background: rgba(0,0,0,0.32); border-radius: 10px;\n    border: 1px solid rgba(0,0,0,0.4);\n  }\n  .seg button {\n    font: inherit; font-size: 9.5px; letter-spacing: 1.5px; text-transform: uppercase;\n    color: var(--dim); background: transparent; border: 0; cursor: pointer;\n    padding: 8px 10px; border-radius: 7px; transition: all 0.2s;\n  }\n  .seg button.on {\n    color: #07110f;\n    background: linear-gradient(180deg, var(--acc2), var(--acc));\n    box-shadow: 0 0 12px rgba(122,208,192,0.5), 0 1px 0 rgba(255,255,255,0.3) inset;\n  }\n\n  footer {\n    margin-top: 14px; text-align: center;\n    font-size: 8.5px; letter-spacing: 2px; text-transform: uppercase; color: var(--dim);\n  }\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"panel\">\n      <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n      <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n      <header>\n        <div class=\"brand\">\n          <svg class=\"glyph\" viewBox=\"0 0 48 48\" fill=\"none\">\n            <defs>\n              <linearGradient id=\"gg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#9ad0ff\"/>\n                <stop offset=\"1\" stop-color=\"#7ad0c0\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M2 30 Q10 6 16 30 T30 30\" stroke=\"url(#gg)\" stroke-width=\"2.4\" fill=\"none\" stroke-linecap=\"round\"/>\n            <path d=\"M18 18 Q26 42 32 18 T46 18\" stroke=\"#7ad0c0\" stroke-width=\"2.4\" fill=\"none\" stroke-linecap=\"round\" opacity=\"0.7\"/>\n          </svg>\n          <div class=\"titles\">\n            <h1>TWIN&nbsp;PHASER</h1>\n            <p>Dual Allpass &middot; Two LFOs</p>\n          </div>\n        </div>\n        <div class=\"stamp\">Model <b>TP&middot;2</b><br>Stereo Sweep</div>\n      </header>\n\n      <div class=\"scopes\" id=\"scopes\">\n        <div class=\"scope a\">\n          <span class=\"tag\">Engine A</span>\n          <span class=\"rateread\" id=\"readA\">0.00 Hz</span>\n          <canvas id=\"scA\" width=\"340\" height=\"120\"></canvas>\n        </div>\n        <div class=\"scope b\">\n          <span class=\"tag\">Engine B</span>\n          <span class=\"rateread\" id=\"readB\">0.00 Hz</span>\n          <canvas id=\"scB\" width=\"340\" height=\"120\"></canvas>\n        </div>\n        <div class=\"modepill\" id=\"modepill\">Sum</div>\n      </div>\n\n      <div class=\"rack\">\n        <div class=\"cell\">\n          <canvas class=\"knob\" id=\"k0\" tabindex=\"0\"></canvas>\n          <span class=\"lab\">Rate A</span><span class=\"val\" id=\"v0\"></span>\n        </div>\n        <div class=\"cell\">\n          <canvas class=\"knob\" id=\"k1\" tabindex=\"0\"></canvas>\n          <span class=\"lab\">Rate B</span><span class=\"val\" id=\"v1\"></span>\n        </div>\n        <div class=\"cell\">\n          <canvas class=\"knob\" id=\"k2\" tabindex=\"0\"></canvas>\n          <span class=\"lab\">Depth</span><span class=\"val\" id=\"v2\"></span>\n        </div>\n        <div class=\"cell\">\n          <canvas class=\"knob\" id=\"k3\" tabindex=\"0\"></canvas>\n          <span class=\"lab\">Feedback</span><span class=\"val\" id=\"v3\"></span>\n        </div>\n        <div class=\"cell modecell\">\n          <div class=\"seg\" id=\"modeSeg\">\n            <button data-m=\"0\">Sum</button>\n            <button data-m=\"1\">Series</button>\n          </div>\n          <span class=\"lab\">Routing</span><span class=\"val\" id=\"v4\"></span>\n        </div>\n        <div class=\"cell\">\n          <canvas class=\"knob\" id=\"k5\" tabindex=\"0\"></canvas>\n          <span class=\"lab\">Mix</span><span class=\"val\" id=\"v5\"></span>\n        </div>\n      </div>\n\n      <footer>Two phasers, one signal &mdash; sum for shimmer, series for depth</footer>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match the DSP) ----\n  var PARAMS = [\n    { i: 0, name: \"Rate A\",   min: 0, max: 1, def: 0.30, fmt: rateFmt },\n    { i: 1, name: \"Rate B\",   min: 0, max: 1, def: 0.55, fmt: rateFmt },\n    { i: 2, name: \"Depth\",    min: 0, max: 1, def: 0.70, fmt: pctFmt  },\n    { i: 3, name: \"Feedback\", min: 0, max: 1, def: 0.45, fmt: pctFmt  },\n    { i: 4, name: \"Mode\",     min: 0, max: 1, def: 0,    step: 1      },\n    { i: 5, name: \"Mix\",      min: 0, max: 1, def: 1.00, fmt: pctFmt  }\n  ];\n  var state = {};\n\n  function rateFmt(v) {\n    // mirror the DSP curve: 0.02 + v^2 * 7.98 Hz\n    var hz = 0.02 + v * v * 7.98;\n    return hz.toFixed(2) + \" Hz\";\n  }\n  function pctFmt(v) { return Math.round(v * 100) + \" %\"; }\n\n  // ---- host bridge ----\n  function push(idx, val) {\n    state[idx] = val;\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(idx, val);\n  }\n\n  // =====================================================================\n  //  KNOB  — SVG-free canvas knob, drag vertical, wheel fine, dblclick reset\n  // =====================================================================\n  function Knob(canvas, p) {\n    var dpr = Math.max(1, window.devicePixelRatio || 1);\n    var size = 72;\n    canvas.width = size * dpr; canvas.height = size * dpr;\n    canvas.style.width = size + \"px\"; canvas.style.height = size + \"px\";\n    var ctx = canvas.getContext(\"2d\");\n    ctx.scale(dpr, dpr);\n\n    var val = p.def;\n    var hot = 0; // glow on interaction\n\n    function norm() { return (val - p.min) / (p.max - p.min); }\n\n    function draw() {\n      var cx = size / 2, cy = size / 2, r = 26;\n      ctx.clearRect(0, 0, size, size);\n\n      var a0 = Math.PI * 0.75, a1 = Math.PI * 2.25;\n      var n = norm();\n      var ang = a0 + (a1 - a0) * n;\n\n      // outer ring shadow / inset well\n      ctx.beginPath();\n      ctx.arc(cx, cy, r + 4, 0, Math.PI * 2);\n      ctx.fillStyle = \"rgba(0,0,0,0.35)\";\n      ctx.fill();\n\n      // track\n      ctx.beginPath();\n      ctx.lineWidth = 4;\n      ctx.lineCap = \"round\";\n      ctx.strokeStyle = \"rgba(122,208,192,0.13)\";\n      ctx.arc(cx, cy, r, a0, a1);\n      ctx.stroke();\n\n      // value arc (gradient accent)\n      var grad = ctx.createLinearGradient(0, 0, size, size);\n      grad.addColorStop(0, \"#9ad0ff\");\n      grad.addColorStop(1, \"#7ad0c0\");\n      ctx.beginPath();\n      ctx.lineWidth = 4;\n      ctx.strokeStyle = grad;\n      ctx.shadowColor = \"rgba(122,208,192,\" + (0.4 + hot * 0.5) + \")\";\n      ctx.shadowBlur = 8 + hot * 12;\n      ctx.arc(cx, cy, r, a0, ang);\n      ctx.stroke();\n      ctx.shadowBlur = 0;\n\n      // body\n      var bg = ctx.createRadialGradient(cx - 6, cy - 8, 2, cx, cy, r);\n      bg.addColorStop(0, \"#2b3a39\");\n      bg.addColorStop(1, \"#16201f\");\n      ctx.beginPath();\n      ctx.arc(cx, cy, r - 6, 0, Math.PI * 2);\n      ctx.fillStyle = bg;\n      ctx.fill();\n      ctx.lineWidth = 1;\n      ctx.strokeStyle = \"rgba(255,255,255,0.06)\";\n      ctx.stroke();\n\n      // pointer\n      ctx.save();\n      ctx.translate(cx, cy);\n      ctx.rotate(ang);\n      ctx.beginPath();\n      ctx.moveTo(r - 18, 0);\n      ctx.lineTo(r - 8, 0);\n      ctx.lineWidth = 3;\n      ctx.lineCap = \"round\";\n      ctx.strokeStyle = \"#cdeee8\";\n      ctx.shadowColor = \"rgba(122,208,192,0.8)\";\n      ctx.shadowBlur = 6;\n      ctx.stroke();\n      ctx.restore();\n    }\n\n    function setVal(v, silent) {\n      v = Math.min(p.max, Math.max(p.min, v));\n      val = v;\n      var el = document.getElementById(\"v\" + p.i);\n      if (el) el.textContent = p.fmt ? p.fmt(v) : v.toFixed(2);\n      draw();\n      if (!silent) push(p.i, v);\n    }\n\n    // drag\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true; hot = 1;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y; lastY = y;\n      var span = p.max - p.min;\n      setVal(val + dy / 180 * span);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; hot = 0; draw(); }\n\n    canvas.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    canvas.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    canvas.addEventListener(\"wheel\", function (e) {\n      var span = p.max - p.min;\n      setVal(val - Math.sign(e.deltaY) * span * 0.02);\n      hot = 1; setTimeout(function () { hot = 0; draw(); }, 180);\n      e.preventDefault();\n    }, { passive: false });\n\n    canvas.addEventListener(\"dblclick\", function () { setVal(p.def); });\n\n    canvas.addEventListener(\"mouseenter\", function () { hot = 0.6; draw(); });\n    canvas.addEventListener(\"mouseleave\", function () { if (!dragging) { hot = 0; draw(); } });\n\n    setVal(p.def, true);   // init display + state without pushing yet\n    return { setVal: setVal, get: function () { return val; } };\n  }\n\n  // =====================================================================\n  //  TWIN SCOPE — animated sweeping-notch frequency displays\n  // =====================================================================\n  var scopes = {};\n  function makeScope(id, accent) {\n    var c = document.getElementById(id);\n    var dpr = Math.max(1, window.devicePixelRatio || 1);\n    var W = 340, H = 120;\n    c.width = W * dpr; c.height = H * dpr;\n    var ctx = c.getContext(\"2d\");\n    ctx.scale(dpr, dpr);\n    return { ctx: ctx, W: W, H: H, accent: accent, lfo: 0 };\n  }\n\n  function drawScope(s, rateNorm, depth, feedback, lfoPhase) {\n    var ctx = s.ctx, W = s.W, H = s.H;\n    ctx.clearRect(0, 0, W, H);\n\n    // grid\n    ctx.strokeStyle = \"rgba(122,208,192,0.07)\";\n    ctx.lineWidth = 1;\n    for (var gx = 0; gx <= W; gx += W / 8) {\n      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();\n    }\n    for (var gy = 0; gy <= H; gy += H / 4) {\n      ctx.beginPath(); ctx.moveTo(0, gy); ctx.lineTo(W, gy); ctx.stroke();\n    }\n\n    // triangle LFO position 0..1\n    var tri = lfoPhase < 0.5 ? lfoPhase * 2 : 2 - lfoPhase * 2;\n    // notch centre swept across the band, widened by depth\n    var notchX = (0.18 + tri * 0.64 * depth) * W;\n    var mid = H * 0.5;\n\n    // response curve: flat at top, dipping at the moving notch(es)\n    ctx.beginPath();\n    var sharp = 6 + feedback * 60; // feedback sharpens\n    for (var x = 0; x <= W; x += 2) {\n      var nx = x / W;\n      var d = (x - notchX) / W;\n      // primary notch + a secondary harmonic notch for the 4-stage character\n      var dip1 = 1 / (1 + sharp * d * d);\n      var d2 = (x - (notchX + W * 0.34)) / W;\n      var dip2 = 0.7 / (1 + sharp * d2 * d2);\n      var amp = 1 - (dip1 + dip2);\n      if (amp < 0.04) amp = 0.04;\n      var y = H - amp * H * 0.78 - H * 0.08;\n      if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n    }\n\n    var g = ctx.createLinearGradient(0, 0, W, 0);\n    g.addColorStop(0, \"#9ad0ff\");\n    g.addColorStop(1, s.accent);\n    ctx.strokeStyle = g;\n    ctx.lineWidth = 2;\n    ctx.shadowColor = s.accent;\n    ctx.shadowBlur = 10;\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    // fill under curve\n    ctx.lineTo(W, H); ctx.lineTo(0, H); ctx.closePath();\n    var fillG = ctx.createLinearGradient(0, 0, 0, H);\n    fillG.addColorStop(0, \"rgba(122,208,192,0.18)\");\n    fillG.addColorStop(1, \"rgba(122,208,192,0)\");\n    ctx.fillStyle = fillG;\n    ctx.fill();\n\n    // moving notch marker\n    ctx.beginPath();\n    ctx.arc(notchX, mid, 3, 0, Math.PI * 2);\n    ctx.fillStyle = s.accent;\n    ctx.shadowColor = s.accent; ctx.shadowBlur = 12;\n    ctx.fill();\n    ctx.shadowBlur = 0;\n  }\n\n  // =====================================================================\n  //  MODE TOGGLE\n  // =====================================================================\n  function setMode(m, silent) {\n    var btns = document.querySelectorAll(\"#modeSeg button\");\n    btns.forEach(function (b) {\n      b.classList.toggle(\"on\", +b.dataset.m === m);\n    });\n    var labels = [\"Sum\", \"Series\"];\n    var v = document.getElementById(\"v4\");\n    if (v) v.textContent = labels[m];\n    document.getElementById(\"modepill\").textContent = labels[m];\n    var sc = document.getElementById(\"scopes\");\n    sc.classList.add(\"linkflash\");\n    clearTimeout(setMode._t);\n    setMode._t = setTimeout(function () { sc.classList.remove(\"linkflash\"); }, 700);\n    state[4] = m;\n    if (!silent) push(4, m);\n  }\n\n  // =====================================================================\n  //  BOOT\n  // =====================================================================\n  var knobs = {};\n  function boot() {\n    PARAMS.forEach(function (p) {\n      if (p.i === 4) return; // mode handled separately\n      knobs[p.i] = Knob(document.getElementById(\"k\" + p.i), p);\n      push(p.i, p.def); // initialise engine to default\n    });\n\n    document.querySelectorAll(\"#modeSeg button\").forEach(function (b) {\n      b.addEventListener(\"click\", function () { setMode(+b.dataset.m); });\n    });\n    setMode(0); // default Sum, pushes default\n\n    scopes.a = makeScope(\"scA\", \"#7ad0c0\");\n    scopes.b = makeScope(\"scB\", \"#9ad0ff\");\n    requestAnimationFrame(loop);\n  }\n\n  var lfA = 0, lfB = 0, last = 0;\n  function loop(t) {\n    if (document.hidden) { last = t; requestAnimationFrame(loop); return; }\n    var dt = Math.min(0.05, (t - last) / 1000 || 0);\n    last = t;\n\n    var rA = state[0], rB = state[1], depth = state[2], fb = state[3];\n    var hzA = 0.02 + rA * rA * 7.98;\n    var hzB = 0.02 + rB * rB * 7.98;\n    lfA = (lfA + hzA * dt) % 1;\n    lfB = (lfB + hzB * dt) % 1;\n\n    document.getElementById(\"readA\").textContent = hzA.toFixed(2) + \" Hz\";\n    document.getElementById(\"readB\").textContent = hzB.toFixed(2) + \" Hz\";\n\n    drawScope(scopes.a, rA, depth, fb, lfA);\n    drawScope(scopes.b, rB, depth, fb, lfB);\n    requestAnimationFrame(loop);\n  }\n\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(boot);\n  else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  TWIN PHASER — a dual sweeping-notch phaser\n//  Two INDEPENDENT 4-stage allpass phasers, each driven by its own LFO\n//  running at its own rate. The two engines can be SUMMED (parallel) for\n//  wide, beating notch patterns, or chained in SERIES for deep, stacked\n//  8-notch sweeps. Per-engine feedback sharpens the notches into vocal\n//  resonances. A steady tone shows several notches drifting at two rates.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// Per-engine, per-channel allpass state. 4 stages each.\n// Layout: [engine * MAX_CHANNELS * STAGES + channel * STAGES + stage]\nconst STAGES: i32 = 4;\nconst apState: StaticArray<f32> = new StaticArray<f32>(2 * MAX_CHANNELS * STAGES);\n// Per-engine, per-channel feedback memory.\nconst fbState: StaticArray<f32> = new StaticArray<f32>(2 * MAX_CHANNELS);\n\n// LFO phases (per engine). Slight stereo offset gives a wide image.\nlet phaseA: f32 = 0.0;\nlet phaseB: f32 = 0.25;\n\nconst PI2: f32 = 6.2831853;\n\nconst P_RATE_A:   i32 = 0; // 0..1 -> 0.02..8 Hz\nconst P_RATE_B:   i32 = 1; // 0..1 -> 0.02..8 Hz\nconst P_DEPTH:    i32 = 2; // 0..1 sweep depth\nconst P_FEEDBACK: i32 = 3; // 0..1 -> 0..0.92 resonance\nconst P_MODE:     i32 = 4; // 0 = SUM (parallel), 1 = SERIES (chained)\nconst P_MIX:      i32 = 5; // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < 2 * MAX_CHANNELS * STAGES; i++) apState[i] = 0.0;\n  for (let i = 0; i < 2 * MAX_CHANNELS; i++) fbState[i] = 0.0;\n  phaseA = 0.0;\n  phaseB = 0.25;\n  params[P_RATE_A]   = 0.30;\n  params[P_RATE_B]   = 0.55;\n  params[P_DEPTH]    = 0.70;\n  params[P_FEEDBACK] = 0.45;\n  params[P_MODE]     = 0.0;\n  params[P_MIX]      = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// map 0..1 to an LFO rate in Hz with a perceptual (quadratic) curve\n@inline function rateHz(n: f32): f32 {\n  const k: f32 = clampf(n, 0.0, 1.0);\n  return f32(0.02 + k * k * 7.98);\n}\n\nexport function process(n: i32): void {\n  const rA: f32 = rateHz(params[P_RATE_A]);\n  const rB: f32 = rateHz(params[P_RATE_B]);\n  const depth: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const fb: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0) * 0.92;\n  const series: bool = params[P_MODE] >= 0.5;\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  const incA: f32 = rA / sampleRate;\n  const incB: f32 = rB / sampleRate;\n\n  // Allpass break frequency sweeps between ~200 Hz and ~1600 Hz.\n  // Convert to the one-pole allpass coefficient g = (1 - t) / (1 + t),\n  // t = tan(pi * fc / sr). We sweep in a normalised domain and rebuild g\n  // per sample (cheap, only a few mul/div) so notches glide smoothly.\n  const baseLo: f32 = 200.0;\n  const baseHi: f32 = 1600.0;\n  const span: f32 = (baseHi - baseLo) * depth;\n\n  // small stereo phase offset so L/R notches differ -> wide image\n  const stOff: f32 = 0.05;\n\n  let pA: f32 = phaseA;\n  let pB: f32 = phaseB;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const stPh: f32 = c == 1 ? stOff : 0.0;\n    const apBaseA: i32 = (0 * MAX_CHANNELS + c) * STAGES;\n    const apBaseB: i32 = (1 * MAX_CHANNELS + c) * STAGES;\n    const fbIdxA: i32 = 0 * MAX_CHANNELS + c;\n    const fbIdxB: i32 = 1 * MAX_CHANNELS + c;\n\n    let lpA: f32 = pA;\n    let lpB: f32 = pB;\n\n    let s0A: f32 = apState[apBaseA + 0];\n    let s1A: f32 = apState[apBaseA + 1];\n    let s2A: f32 = apState[apBaseA + 2];\n    let s3A: f32 = apState[apBaseA + 3];\n    let s0B: f32 = apState[apBaseB + 0];\n    let s1B: f32 = apState[apBaseB + 1];\n    let s2B: f32 = apState[apBaseB + 2];\n    let s3B: f32 = apState[apBaseB + 3];\n    let zfA: f32 = fbState[fbIdxA];\n    let zfB: f32 = fbState[fbIdxB];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // --- LFO A (triangle) -> break frequency -> coefficient gA ---\n      let triA: f32 = lpA + stPh; triA -= Mathf.floor(triA);\n      let tA: f32 = triA < 0.5 ? triA * 2.0 : 2.0 - triA * 2.0; // 0..1\n      const fcA: f32 = baseLo + span * tA;\n      const tanA: f32 = Mathf.tan(3.14159265 * fcA / sampleRate);\n      const gA: f32 = (1.0 - tanA) / (1.0 + tanA);\n\n      // --- LFO B (triangle) -> break frequency -> coefficient gB ---\n      let triB: f32 = lpB + stPh; triB -= Mathf.floor(triB);\n      let tB: f32 = triB < 0.5 ? triB * 2.0 : 2.0 - triB * 2.0;\n      const fcB: f32 = baseLo + span * tB;\n      const tanB: f32 = Mathf.tan(3.14159265 * fcB / sampleRate);\n      const gB: f32 = (1.0 - tanB) / (1.0 + tanB);\n\n      // ===== Engine A =====\n      let inA: f32 = x + zfA * fb;\n      let yA: f32 = inA;\n      // stage 1\n      let aOut: f32 = f32(-gA * yA + s0A); s0A = f32(yA + gA * aOut); yA = aOut;\n      aOut = f32(-gA * yA + s1A); s1A = f32(yA + gA * aOut); yA = aOut;\n      aOut = f32(-gA * yA + s2A); s2A = f32(yA + gA * aOut); yA = aOut;\n      aOut = f32(-gA * yA + s3A); s3A = f32(yA + gA * aOut); yA = aOut;\n      zfA = yA;\n      const phA: f32 = f32(0.5 * (inA + yA)); // classic phaser sum\n\n      // ===== Engine B =====\n      // In SERIES mode B processes A's notched output; in SUM it processes dry.\n      const srcB: f32 = series ? phA : x;\n      let inB: f32 = srcB + zfB * fb;\n      let yB: f32 = inB;\n      let bOut: f32 = f32(-gB * yB + s0B); s0B = f32(yB + gB * bOut); yB = bOut;\n      bOut = f32(-gB * yB + s1B); s1B = f32(yB + gB * bOut); yB = bOut;\n      bOut = f32(-gB * yB + s2B); s2B = f32(yB + gB * bOut); yB = bOut;\n      bOut = f32(-gB * yB + s3B); s3B = f32(yB + gB * bOut); yB = bOut;\n      zfB = yB;\n      const phB: f32 = f32(0.5 * (inB + yB));\n\n      // Combine: SERIES -> phB already carries both; SUM -> average A & B.\n      let wet: f32 = series ? phB : f32(0.5 * (phA + phB));\n      // gentle safety clip\n      if (wet > 1.5) wet = 1.5; else if (wet < -1.5) wet = -1.5;\n\n      outBuf[base + f] = f32(x * (1.0 - mix) + wet * mix);\n\n      lpA += incA; if (lpA >= 1.0) lpA -= 1.0;\n      lpB += incB; if (lpB >= 1.0) lpB -= 1.0;\n    }\n\n    apState[apBaseA + 0] = s0A; apState[apBaseA + 1] = s1A;\n    apState[apBaseA + 2] = s2A; apState[apBaseA + 3] = s3A;\n    apState[apBaseB + 0] = s0B; apState[apBaseB + 1] = s1B;\n    apState[apBaseB + 2] = s2B; apState[apBaseB + 3] = s3B;\n    fbState[fbIdxA] = zfA;\n    fbState[fbIdxB] = zfB;\n  }\n\n  phaseA = pA + incA * f32(n); phaseA -= Mathf.floor(phaseA);\n  phaseB = pB + incB * f32(n); phaseB -= Mathf.floor(phaseB);\n}\n",
  "publishedAt": 1751000042000
}