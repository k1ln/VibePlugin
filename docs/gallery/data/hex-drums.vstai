  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Hex Drums</title>\n<style>\n  :root{ --acc:#ff3d5a; --acc2:#3d8cff; --bg0:#060608; --bg1:#101218; --ink:#e8ecf4; --dim:#6a7388; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#1a1d28 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#181b24,#08090d); border:1px solid rgba(255,61,90,.18);\n    box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(255,255,255,.05); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .pads{ display:grid; grid-template-columns:repeat(6,1fr); gap:10px; margin-bottom:16px; padding:0 4px; }\n  .pad{ position:relative; aspect-ratio:1/1; display:flex; align-items:center; justify-content:center; }\n  .hex{ position:absolute; inset:0; clip-path:polygon(50% 0,100% 25%,100% 75%,50% 100%,0 75%,0 25%);\n    background:linear-gradient(180deg,#1c2230,#10141d); border:0; box-shadow:inset 0 0 0 1px rgba(255,61,90,.25); transition:filter .08s; }\n  .glow{ position:absolute; inset:0; clip-path:polygon(50% 0,100% 25%,100% 75%,50% 100%,0 75%,0 25%);\n    background:radial-gradient(circle at 50% 45%,var(--acc),transparent 65%); opacity:0; }\n  .pl{ position:relative; z-index:2; font-size:8.5px; letter-spacing:.08em; text-transform:uppercase; color:var(--dim); }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(180,190,210,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,61,90,.6)); }\n  .pcap{ fill:#10141d; stroke:rgba(255,61,90,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,61,90,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,61,90,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">HEX&nbsp;DRUMS</span><span class=\"sub\">analog e-drums</span><span class=\"led\"></span></header>\n    <div class=\"pads\" id=\"pads\"></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var VOICES=[\"Kick\",\"Snare\",\"Tom Hi\",\"Tom Mid\",\"Tom Lo\",\"Hat\"];\n  var P=[{name:\"Pitch\",idx:0,def:0.5},{name:\"Sweep\",idx:1,def:0.6},{name:\"Decay\",idx:2,def:0.5},{name:\"Noise\",idx:3,def:0.4},{name:\"Tone\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.85}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var padWrap=document.getElementById(\"pads\");\n  var glows=VOICES.map(function(nm){\n    var el=document.createElement(\"div\"); el.className=\"pad\";\n    el.innerHTML='<div class=\"hex\"></div><div class=\"glow\"></div><span class=\"pl\">'+nm+'</span>';\n    padWrap.appendChild(el); return el.querySelector(\".glow\");\n  });\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ff3d5a\"/><stop offset=\"1\" stop-color=\"#3d8cff\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle>'+\n      '<circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle>'+\n      '<line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2)); ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  // demo pattern lighting the hex pads in time\n  var PAT=[0,5,2,5, 1,5,3,5, 0,5,4,5, 1,5,2,3];\n  var step=-1, last=0, acc=0;\n  function frame(ts){\n    if(!last)last=ts; var dt=ts-last; last=ts; acc+=dt;\n    var stepMs=60000/104/4;\n    if(acc>=stepMs){ acc-=stepMs; step=(step+1)%16; var v=PAT[step]; if(v>=0&&glows[v]) glows[v].style.opacity=\"0.95\"; }\n    for(var i=0;i<6;i++){ var o=parseFloat(glows[i].style.opacity||\"0\"); if(o>0) glows[i].style.opacity=Math.max(0,o-dt/200).toFixed(3); }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  HEX DRUMS — analog electronic drums (Simmons SDS-V lineage).\n//  Distinct from sampled drum machines: every hit is SYNTHESISED in real\n//  time — the iconic 80s pitch-swept \"pew\" toms (a sine whose pitch sweeps\n//  down) plus a noisy click, with kick, snare and hat. A MIDI note selects\n//  a voice (note % 6) and triggers it into an 8-slot pool. Controls: Pitch,\n//  Sweep (the pitch-drop), Decay, Noise (click/snap), Tone, Level.\n//  No samples, no host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NV: i32 = 6;     // drum voice types\nconst POOL: i32 = 8;   // simultaneous hits\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// base pitch per voice type: 0 kick,1 snare,2 tom-hi,3 tom-mid,4 tom-lo,5 hat\nconst baseHz: StaticArray<f32> = new StaticArray<f32>(NV);\nconst isNoise: StaticArray<f32> = new StaticArray<f32>(NV); // 1 = noise-led (snare/hat)\n\nconst pType: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pPhase: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pAEnv: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pPEnv: StaticArray<f32> = new StaticArray<f32>(POOL);  // pitch env (1->0)\nconst pNEnv: StaticArray<f32> = new StaticArray<f32>(POOL);  // noise/click env\nconst pAct: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pVel: StaticArray<f32> = new StaticArray<f32>(POOL);\nlet pNext: i32 = 0;\n\nlet sampleRate: f32 = 48000.0;\nlet rngState: i32 = 22222;\nlet toneZ: f32 = 0.0;\n\nconst P_PITCH: i32 = 0;\nconst P_SWEEP: i32 = 1;\nconst P_DECAY: i32 = 2;\nconst P_NOISE: i32 = 3;\nconst P_TONE: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  pNext = 0; toneZ = 0.0;\n  for (let i = 0; i < POOL; i++) { pAct[i] = 0; pPhase[i] = 0.0; pAEnv[i] = 0.0; pPEnv[i] = 0.0; pNEnv[i] = 0.0; pType[i] = 0; pVel[i] = 0.0; }\n  baseHz[0] = 55.0;  isNoise[0] = 0.0;  // kick\n  baseHz[1] = 185.0; isNoise[1] = 1.0;  // snare\n  baseHz[2] = 320.0; isNoise[2] = 0.0;  // tom hi\n  baseHz[3] = 200.0; isNoise[3] = 0.0;  // tom mid\n  baseHz[4] = 130.0; isNoise[4] = 0.0;  // tom lo\n  baseHz[5] = 0.0;   isNoise[5] = 1.0;  // hat\n  params[P_PITCH] = 0.5; params[P_SWEEP] = 0.6; params[P_DECAY] = 0.5; params[P_NOISE] = 0.4; params[P_TONE] = 0.6; params[P_LEVEL] = 0.85;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let t: i32 = id % NV; if (t < 0) t += NV;\n  const slot: i32 = pNext; pNext = (pNext + 1) % POOL;\n  pType[slot] = t; pPhase[slot] = 0.0; pAEnv[slot] = 1.0; pPEnv[slot] = 1.0; pNEnv[slot] = 1.0; pAct[slot] = 1; pVel[slot] = clampf(v, 0.05, 1.0);\n}\nexport function noteOff(id: i32): void { /* one-shot drums */ }\n\nexport function process(n: i32): void {\n  const pitchN: f32 = clampf(params[P_PITCH], 0.0, 1.0);\n  const sweepN: f32 = clampf(params[P_SWEEP], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const noiseN: f32 = clampf(params[P_NOISE], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const decaySec: f32 = 0.05 + decayN * decayN * 0.9;\n  const aCoef: f32 = f32(Mathf.exp(-1.0 / (decaySec * sampleRate)));\n  const pCoef: f32 = f32(Mathf.exp(-1.0 / (0.03 * sampleRate)));   // ~30 ms pitch sweep\n  const nCoef: f32 = f32(Mathf.exp(-1.0 / (0.012 * sampleRate)));  // ~12 ms click/noise\n  const pitchMul: f32 = f32(Mathf.exp((pitchN - 0.5) * 1.6));      // global tuning +/- ~ octave\n  const sweepDepth: f32 = sweepN * 4.0;                            // pitch starts up to 5x base\n  const lpco: f32 = 0.04 + 0.95 * toneN;\n  const out: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < POOL; s++) {\n      if (pAct[s] == 0) continue;\n      const t: i32 = pType[s];\n      const bf: f32 = baseHz[t] * pitchMul;\n      // pitch env sweep (the Simmons \"pew\")\n      pPEnv[s] *= pCoef;\n      const fr: f32 = bf * (1.0 + sweepDepth * pPEnv[s]);\n      let ph: f32 = pPhase[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; pPhase[s] = ph;\n      const sine: f32 = f32(Mathf.sin(ph * 6.2831853));\n      // noise / click\n      pNEnv[s] *= nCoef;\n      const noise: f32 = rnd();\n      let v: f32;\n      if (isNoise[t] > 0.5) {\n        // snare/hat: noise-led + a little tone\n        v = noise * (0.7 + 0.3 * noiseN) + sine * 0.25;\n      } else {\n        // kick/toms: tonal sine + click transient\n        v = sine + noise * pNEnv[s] * noiseN * 0.9;\n      }\n      pAEnv[s] *= aCoef;\n      mix += v * pAEnv[s] * pVel[s];\n      if (pAEnv[s] < 0.0004) pAct[s] = 0;\n    }\n    toneZ += (mix - toneZ) * lpco;\n    let o: f32 = toneZ * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000159000
}