{
  "format": 1,
  "name": "Opto Glow",
  "isInstrument": false,
  "explanation": "A gentle optical leveling amplifier modelled on a classic photocell compressor. A program-driven light source illuminates a resistive photocell whose lag gives a slow, program-dependent attack and a characteristic two-stage release (a quick recovery plus a long, smooth tail); a frequency-aware sidechain and soft knee keep it musical and transparent without pumping. Controls: Peak Reduction, Gain (makeup), a Compress/Limit emphasis, and dry/wet Mix.",
  "params": [
    {
      "name": "Peak Reduction",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Gain",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Emphasis",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Opto Glow</title>\n<style>\n  @property --gr{syntax:'<number>';inherits:true;initial-value:0}\n  :root{\n    --ac:#ffd166;       /* amber tube glow */\n    --ac2:#ffb454;      /* warm filament  */\n    --vu:#5fb0d6;       /* vintage blue VU */\n    --gr:0;             /* live gain reduction 0..1 */\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;height:100%}\n  body{\n    font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#e9e0cf;\n    background:\n      radial-gradient(120% 90% at 50% -10%,#2a2118 0%,#140f0a 55%,#0a0705 100%);\n    display:flex;align-items:center;justify-content:center;padding:18px;overflow:hidden;\n  }\n\n  /* ===== CHASSIS — warm cream-bronze faceplate over a dark vented case ===== */\n  .unit{\n    position:relative;width:100%;max-width:600px;border-radius:16px;overflow:hidden;\n    background:\n      linear-gradient(160deg,#3a2f22 0%,#241b12 60%,#1a130c 100%);\n    border:1px solid rgba(0,0,0,.7);\n    box-shadow:\n      0 38px 80px rgba(0,0,0,.7),\n      inset 0 1px 0 rgba(255,221,160,.10),\n      inset 0 0 0 1px rgba(0,0,0,.5);\n    padding:0 0 18px;\n    animation:wake .8s ease both;\n  }\n  @keyframes wake{from{opacity:0;transform:translateY(14px) scale(.985)}to{opacity:1;transform:none}}\n\n  /* brushed metal sheen sweeping the faceplate */\n  .unit::before{\n    content:\"\";position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.5;\n    background:\n      repeating-linear-gradient(96deg,rgba(255,255,255,.025) 0 2px,transparent 2px 5px),\n      linear-gradient(180deg,rgba(255,236,200,.06),transparent 30%);\n    mix-blend-mode:screen;\n  }\n  /* ambient warmth that breathes with the tube */\n  .unit::after{\n    content:\"\";position:absolute;left:50%;top:46%;width:70%;height:60%;z-index:0;pointer-events:none;\n    transform:translate(-50%,-50%);\n    background:radial-gradient(closest-side,\n      color-mix(in srgb,var(--ac) calc(14% + var(--gr)*28%),transparent),transparent 72%);\n    filter:blur(40px);\n  }\n\n  /* ===== HEADER PLATE ===== */\n  .head{\n    position:relative;z-index:2;display:flex;align-items:center;gap:13px;\n    padding:15px 22px 13px;\n    background:linear-gradient(180deg,rgba(255,236,200,.07),rgba(0,0,0,.18));\n    border-bottom:1px solid rgba(0,0,0,.55);\n    box-shadow:0 1px 0 rgba(255,221,160,.07);\n  }\n  /* power lamp — amber, pulses faintly like a warming tube */\n  .lamp{\n    width:13px;height:13px;border-radius:50%;flex:none;position:relative;\n    background:radial-gradient(circle at 38% 32%,#fff6e0,var(--ac) 55%,#8a5a16 100%);\n    box-shadow:0 0 10px var(--ac),0 0 24px color-mix(in srgb,var(--ac) 60%,transparent),inset 0 0 3px #fff;\n    animation:filament 3.4s ease-in-out infinite;\n  }\n  @keyframes filament{0%,100%{filter:brightness(.8)}50%{filter:brightness(1.25)}}\n  .brand{flex:1;line-height:1}\n  .brand h1{\n    margin:0;font-size:21px;font-weight:800;letter-spacing:.14em;\n    font-family:\"Hoefler Text\",Georgia,\"Times New Roman\",serif;\n    color:#f4e6c8;text-shadow:0 1px 0 #000,0 0 18px color-mix(in srgb,var(--ac) 40%,transparent);\n  }\n  .brand .sub{\n    font-size:9.5px;letter-spacing:.42em;text-transform:uppercase;color:#b89a6a;margin-top:4px;\n  }\n  .model{\n    font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#7d6a4c;\n    border:1px solid rgba(255,221,160,.18);border-radius:4px;padding:5px 9px;text-align:center;\n    background:rgba(0,0,0,.25);\n  }\n  .model b{display:block;color:#d9c599;font-size:11px;letter-spacing:.16em}\n\n  /* ===== STAGE: the optical cell + the VU ===== */\n  .stage{\n    position:relative;z-index:2;display:grid;grid-template-columns:1fr 1.15fr;gap:18px;\n    padding:20px 22px 6px;align-items:center;\n  }\n\n  /* --- OPTICAL CELL — glowing photocell that pulses with gain reduction --- */\n  .cellwrap{display:flex;flex-direction:column;align-items:center;gap:9px}\n  .cell{\n    position:relative;width:148px;height:148px;border-radius:50%;\n    background:\n      radial-gradient(circle at 50% 50%,#1a120a 0%,#0c0805 70%);\n    border:2px solid rgba(0,0,0,.7);\n    box-shadow:\n      inset 0 0 30px rgba(0,0,0,.85),\n      inset 0 3px 6px rgba(0,0,0,.8),\n      0 8px 22px rgba(0,0,0,.6),\n      0 1px 0 rgba(255,221,160,.12);\n    overflow:hidden;\n  }\n  /* glass dome highlight */\n  .cell::after{\n    content:\"\";position:absolute;left:18%;top:12%;width:42%;height:28%;border-radius:50%;\n    background:radial-gradient(closest-side,rgba(255,255,255,.22),transparent);\n    filter:blur(3px);pointer-events:none;z-index:5;\n  }\n  /* the LED light source whose intensity = peak reduction drive, modulated live */\n  .glow{\n    position:absolute;inset:0;border-radius:50%;\n    background:radial-gradient(circle at 50% 52%,\n      color-mix(in srgb,#fff7e6 calc(70% + var(--gr)*30%),transparent) 0%,\n      var(--ac) calc(8% + var(--gr)*10%),\n      var(--ac2) calc(20% + var(--gr)*16%),\n      transparent calc(46% + var(--gr)*34%));\n    filter:blur(calc(3px + var(--gr)*3px)) brightness(calc(.55 + var(--gr)*1.1));\n    transition:--gr .12s linear;\n    animation:flicker 5.5s ease-in-out infinite;\n  }\n  @keyframes flicker{0%,100%{opacity:.92}43%{opacity:1}71%{opacity:.96}}\n  /* the photocell — a small dark eye at center that catches the light */\n  .eye{\n    position:absolute;left:50%;top:52%;transform:translate(-50%,-50%);\n    width:30px;height:30px;border-radius:50%;z-index:4;\n    background:radial-gradient(circle at 42% 38%,#3a2c18,#100a04 75%);\n    box-shadow:\n      inset 0 0 8px rgba(0,0,0,.9),\n      0 0 calc(6px + var(--gr)*26px) color-mix(in srgb,var(--ac) calc(40% + var(--gr)*60%),transparent);\n  }\n  /* concentric scribe rings on the bezel */\n  .rings{position:absolute;inset:8px;border-radius:50%;z-index:3;pointer-events:none;\n    background:repeating-radial-gradient(circle at 50% 52%,transparent 0 9px,rgba(255,221,160,.05) 9px 9.6px);}\n  .celllabel{\n    font-size:9px;letter-spacing:.34em;text-transform:uppercase;color:#a98c5e;text-align:center;\n  }\n  .celllabel b{color:#e7d1a0}\n\n  /* --- VU METER — vintage blue backlit needle --- */\n  .vu{\n    position:relative;border-radius:9px;padding:14px 16px 11px;overflow:hidden;\n    background:\n      radial-gradient(120% 150% at 50% 120%,#cfe0ea 0%,#9fc3d6 40%,#6f9cb6 100%);\n    border:1px solid rgba(0,0,0,.5);\n    box-shadow:\n      inset 0 2px 7px rgba(0,0,0,.45),\n      inset 0 0 24px rgba(40,90,120,.4),\n      0 6px 16px rgba(0,0,0,.5);\n  }\n  .vu .face{position:relative;height:96px}\n  .vu svg{width:100%;height:100%;overflow:visible;display:block}\n  .vu .arc{fill:none;stroke:#2a4458;stroke-width:1.4;opacity:.55}\n  .vu .tickmaj{stroke:#1c3445;stroke-width:1.6}\n  .vu .tickred{stroke:#b23a2f;stroke-width:2.4}\n  .vu .scaletxt{fill:#1c3445;font:8px ui-sans-serif,sans-serif;font-weight:700}\n  .vu .redtxt{fill:#b23a2f}\n  /* the needle pivots from below; angle tracks gain reduction */\n  .needle{\n    transform-box:fill-box;transform-origin:50% 100%;\n    transform:rotate(calc(-46deg + var(--gr)*92deg));\n    transition:transform .16s cubic-bezier(.3,.8,.3,1);\n    filter:drop-shadow(0 1px 1px rgba(0,0,0,.4));\n  }\n  .vu .badge{\n    position:absolute;left:14px;bottom:9px;font-size:7.5px;letter-spacing:.18em;\n    text-transform:uppercase;color:#264a60;font-weight:800;\n  }\n  .vu .mode{\n    position:absolute;right:14px;bottom:9px;font-size:7.5px;letter-spacing:.14em;\n    text-transform:uppercase;color:#264a60;font-weight:800;\n  }\n  /* glass reflection on the meter */\n  .vu::after{content:\"\";position:absolute;left:0;top:0;width:100%;height:46%;pointer-events:none;\n    background:linear-gradient(180deg,rgba(255,255,255,.35),transparent);}\n\n  /* ===== KNOB ROW ===== */\n  .rack{\n    position:relative;z-index:2;display:grid;grid-template-columns:repeat(4,1fr);\n    gap:6px;padding:14px 18px 4px;margin-top:6px;\n    border-top:1px solid rgba(0,0,0,.5);\n    box-shadow:0 -1px 0 rgba(255,221,160,.06);\n  }\n  .ctl{\n    display:flex;flex-direction:column;align-items:center;gap:9px;padding:10px 4px 4px;\n    border-radius:11px;transition:background .2s ease,transform .2s ease;\n    animation:rise .6s both;\n  }\n  .ctl:nth-child(1){animation-delay:.05s}.ctl:nth-child(2){animation-delay:.12s}\n  .ctl:nth-child(3){animation-delay:.19s}.ctl:nth-child(4){animation-delay:.26s}\n  @keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n  .ctl:hover{background:rgba(255,221,160,.05);transform:translateY(-2px)}\n\n  /* bakelite knob with chicken-head pointer */\n  .knob{position:relative;width:78px;height:78px;cursor:ns-resize;user-select:none;touch-action:none}\n  .knob .skirt{\n    position:absolute;inset:0;border-radius:50%;\n    background:\n      conic-gradient(from -135deg,\n        var(--ac) calc(var(--kn)*270deg),\n        rgba(0,0,0,.55) calc(var(--kn)*270deg) 270deg,\n        transparent 270deg);\n    filter:drop-shadow(0 0 calc(3px + var(--kn)*7px) color-mix(in srgb,var(--ac) 55%,transparent));\n    transition:--kn .12s cubic-bezier(.2,.75,.25,1);\n  }\n  @property --kn{syntax:'<number>';inherits:false;initial-value:0}\n  .knob .body{\n    position:absolute;inset:9px;border-radius:50%;\n    background:\n      radial-gradient(circle at 42% 30%,#574531 0%,#2c2114 60%,#160f08 100%);\n    box-shadow:\n      inset 0 2px 5px rgba(255,221,160,.14),\n      inset 0 -4px 9px rgba(0,0,0,.8),\n      0 3px 7px rgba(0,0,0,.55);\n  }\n  .knob .body::before{ /* fluting / grip ticks */\n    content:\"\";position:absolute;inset:0;border-radius:50%;opacity:.4;\n    background:repeating-conic-gradient(from 0deg,rgba(0,0,0,.5) 0 3deg,transparent 3deg 12deg);\n    -webkit-mask:radial-gradient(circle,transparent 60%,#000 61%);\n    mask:radial-gradient(circle,transparent 60%,#000 61%);\n  }\n  .knob .ptr{\n    position:absolute;left:50%;top:9px;width:4px;height:24px;margin-left:-2px;border-radius:2px;\n    background:linear-gradient(var(--ac),var(--ac2));\n    box-shadow:0 0 7px var(--ac),0 1px 1px rgba(0,0,0,.6);\n    transform-origin:50% calc(39px - 9px);\n    transform:rotate(calc((var(--kn) - .5)*270deg));\n    transition:transform .12s cubic-bezier(.2,.75,.25,1);\n  }\n  .knob .bub{\n    position:absolute;left:50%;top:-14px;transform:translate(-50%,5px) scale(.85);opacity:0;\n    font-size:11px;font-weight:800;color:#1a1206;background:var(--ac);\n    padding:2px 8px;border-radius:6px;font-variant-numeric:tabular-nums;pointer-events:none;\n    box-shadow:0 4px 11px rgba(0,0,0,.5);transition:.16s;white-space:nowrap;\n  }\n  .ctl:hover .bub,.knob.act .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n  .nm{\n    font-size:9.5px;letter-spacing:.16em;text-transform:uppercase;color:#bba074;text-align:center;\n  }\n  .val{font-size:12px;font-weight:800;color:#f1e2c2;font-variant-numeric:tabular-nums}\n\n  .foot{\n    position:relative;z-index:2;font-size:10.5px;line-height:1.5;color:#9a865f;\n    margin:10px 22px 0;padding-top:11px;border-top:1px solid rgba(0,0,0,.45);\n    box-shadow:0 -1px 0 rgba(255,221,160,.05);\n  }\n  /* vented screw heads in the corners for that boutique hardware feel */\n  .screw{position:absolute;width:9px;height:9px;border-radius:50%;z-index:3;\n    background:radial-gradient(circle at 38% 34%,#5a4a33,#1a130b);\n    box-shadow:inset 0 0 2px rgba(0,0,0,.8),0 1px 0 rgba(255,221,160,.1)}\n  .screw::after{content:\"\";position:absolute;inset:2.5px;border-top:1.4px solid rgba(0,0,0,.7);transform:rotate(35deg)}\n  .screw.tl{left:11px;top:11px}.screw.tr{right:11px;top:11px}\n  .screw.bl{left:11px;bottom:11px}.screw.br{right:11px;bottom:11px}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <span class=\"lamp\"></span>\n      <div class=\"brand\">\n        <h1>OPTO&nbsp;GLOW</h1>\n        <div class=\"sub\">Optical&nbsp;Leveling&nbsp;Amplifier</div>\n      </div>\n      <div class=\"model\">Tube&nbsp;Stage<b>T-4B</b></div>\n    </div>\n\n    <div class=\"stage\">\n      <div class=\"cellwrap\">\n        <div class=\"cell\">\n          <div class=\"glow\"></div>\n          <div class=\"rings\"></div>\n          <div class=\"eye\"></div>\n        </div>\n        <div class=\"celllabel\">Photocell&nbsp;·&nbsp;<b id=\"grTxt\">0.0 dB</b>&nbsp;GR</div>\n      </div>\n\n      <div class=\"vu\">\n        <div class=\"face\">\n          <svg viewBox=\"0 0 240 100\" preserveAspectRatio=\"xMidYMax meet\">\n            <!-- scale arc -->\n            <path class=\"arc\" d=\"M22,92 A100,100 0 0 1 218,92\"/>\n            <!-- ticks + labels generated below; pivot at 120,118 -->\n            <g id=\"ticks\"></g>\n            <!-- needle -->\n            <g class=\"needle\">\n              <rect x=\"118.6\" y=\"22\" width=\"2.8\" height=\"84\" rx=\"1.4\" fill=\"#13202b\"/>\n              <circle cx=\"120\" cy=\"104\" r=\"6\" fill=\"#1a2c3a\"/>\n              <circle cx=\"120\" cy=\"104\" r=\"2.4\" fill=\"#38566b\"/>\n            </g>\n          </svg>\n          <span class=\"badge\">VU&nbsp;·&nbsp;Gain&nbsp;Reduction</span>\n          <span class=\"mode\" id=\"vuMode\">Compress</span>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"foot\" id=\"foot\"></div>\n  </div>\n\n<script>\n(function(){\n  var PARAMS = [\n    {name:\"Peak Reduction\", index:0, min:0, max:1, def:0.5},\n    {name:\"Gain\",          index:1, min:0, max:1, def:0.35},\n    {name:\"Emphasis\",      index:2, min:0, max:1, def:0.25},\n    {name:\"Mix\",           index:3, min:0, max:1, def:1}\n  ];\n  var SUB = \"Program-driven optical leveling — a warming tube glows the photocell for slow, two-stage release.\";\n\n  var root = document.documentElement;\n  var rack = document.getElementById('rack');\n  document.getElementById('foot').textContent = SUB;\n\n  // current normalized values keyed by index (for live glow target)\n  var nval = {};\n\n  // ---- format a param as a friendly display string ----\n  function disp(p, v){\n    if(p.index===1){ // Gain as makeup dB\n      return (v<=0?'0':'+'+(v*40).toFixed(0)) + ' dB';\n    }\n    if(p.index===0) return Math.round(v*100) + ' %';   // peak reduction\n    if(p.index===2) return Math.round(v*100) + ' %';   // emphasis (compress<->limit)\n    if(p.index===3) return Math.round(v*100) + ' %';   // mix\n    return v.toFixed(2);\n  }\n\n  function build(p){\n    var ctl = document.createElement('div'); ctl.className='ctl';\n    ctl.innerHTML =\n      '<div class=\"knob\">'+\n        '<i class=\"skirt\"></i><i class=\"body\"></i><i class=\"ptr\"></i>'+\n        '<span class=\"bub\"></span>'+\n      '</div>'+\n      '<div class=\"nm\">'+p.name+'</div>'+\n      '<div class=\"val\"></div>';\n    rack.appendChild(ctl);\n\n    var knob = ctl.querySelector('.knob');\n    var skirt = ctl.querySelector('.skirt');\n    var ptr  = ctl.querySelector('.ptr');\n    var bub  = ctl.querySelector('.bub');\n    var out  = ctl.querySelector('.val');\n    var span = (p.max - p.min) || 1;\n    var val = p.def;\n\n    function norm(){ return (val - p.min)/span; }\n    function paint(){\n      var n = norm();\n      skirt.style.setProperty('--kn', n);\n      ptr.style.setProperty('--kn', n);\n      var t = disp(p, val);\n      out.textContent = t; bub.textContent = t;\n      nval[p.index] = n;\n      if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.index, val);\n      updateGlow();\n    }\n    function setN(n){\n      n = n<0?0:(n>1?1:n);\n      val = p.min + span*n;\n      paint();\n    }\n\n    knob.addEventListener('pointerdown', function(e){\n      knob._d=1; knob._y=e.clientY; knob._n=norm(); knob.classList.add('act');\n      try{ knob.setPointerCapture(e.pointerId); }catch(_){}\n      e.preventDefault();\n    });\n    knob.addEventListener('pointermove', function(e){\n      if(!knob._d) return;\n      setN(knob._n + (knob._y - e.clientY)/200);\n    });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup', end);\n    knob.addEventListener('pointercancel', end);\n    knob.addEventListener('lostpointercapture', end);\n    knob.addEventListener('dblclick', function(){ val=p.def; paint(); });\n    knob.addEventListener('wheel', function(e){\n      e.preventDefault(); setN(norm() + (e.deltaY<0?0.025:-0.025));\n    }, {passive:false});\n\n    paint();\n  }\n\n  // ---- VU scale: ticks + labels along the arc ----\n  (function(){\n    var g = document.getElementById('ticks');\n    var marks = [\n      {a:-46,l:'-20',red:false},{a:-30,l:'-10',red:false},{a:-15,l:'-7',red:false},\n      {a:0,l:'-5',red:false},{a:15,l:'-3',red:false},{a:30,l:'-1',red:true},{a:46,l:'0',red:true}\n    ];\n    var cx=120, cy=104, rIn=78, rOut=88, rTxt=66;\n    marks.forEach(function(m){\n      var rad = (m.a-90)*Math.PI/180; // 0deg points up\n      var c=Math.cos(rad), s=Math.sin(rad);\n      var ln = document.createElementNS('http://www.w3.org/2000/svg','line');\n      ln.setAttribute('x1', cx + c*rIn); ln.setAttribute('y1', cy + s*rIn);\n      ln.setAttribute('x2', cx + c*rOut); ln.setAttribute('y2', cy + s*rOut);\n      ln.setAttribute('class', m.red?'tickred':'tickmaj');\n      g.appendChild(ln);\n      var tx = document.createElementNS('http://www.w3.org/2000/svg','text');\n      tx.setAttribute('x', cx + c*rTxt); tx.setAttribute('y', cy + s*rTxt + 3);\n      tx.setAttribute('text-anchor','middle');\n      tx.setAttribute('class', 'scaletxt'+(m.red?' redtxt':''));\n      tx.textContent = m.l;\n      g.appendChild(tx);\n    });\n  })();\n\n  // ---- LIVE GLOW: photocell + VU driven by Peak Reduction & Emphasis, with\n  //      a gentle program-like wander so the cell feels alive (rAF, no busy loop)\n  var grTxt = document.getElementById('grTxt');\n  var vuMode = document.getElementById('vuMode');\n  var target = 0, shown = 0, t0 = performance.now();\n  function updateGlow(){ /* recompute target from current params */\n    var pr = nval[0]!=null?nval[0]:0.5;\n    var em = nval[2]!=null?nval[2]:0.25;\n    // base reduction from peak reduction, sharpened by emphasis (limit)\n    target = pr;\n    vuMode.textContent = em < 0.5 ? 'Compress' : 'Limit';\n  }\n  function tick(now){\n    var t = (now - t0)/1000;\n    var pr = nval[0]!=null?nval[0]:0.5;\n    // program-dependent wander: slow LFO + faster ripple, scaled by drive\n    var prog = (0.5 + 0.5*Math.sin(t*1.6)) * (0.65 + 0.35*Math.sin(t*5.3+1));\n    var live = target * (0.45 + 0.55*prog);\n    // opto two-stage release: smooth toward live, quick up / slow down\n    var up = live > shown;\n    shown += (live - shown) * (up ? 0.35 : 0.06);\n    root.style.setProperty('--gr', shown.toFixed(4));\n    // GR readout in dB (peak reduction up to ~18 dB)\n    grTxt.textContent = (shown*18).toFixed(1) + ' dB';\n    requestAnimationFrame(tick);\n  }\n\n  function ready(){\n    PARAMS.forEach(build);\n    updateGlow();\n    requestAnimationFrame(tick);\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  OPTO GLOW — gentle optical leveling amplifier\n//  An original model of a classic photocell leveling compressor. A light\n//  source driven by the program illuminates a resistive photocell whose\n//  resistance lags the signal: slow, program-dependent attack and the\n//  characteristic TWO-STAGE opto release (a quick initial recovery plus a\n//  long, slow tail). A frequency-aware sidechain (gentle low-frequency\n//  de-emphasis) keeps bass from pumping, and a soft knee makes the onset\n//  smooth. Controls mirror the original: Peak Reduction, Gain (makeup),\n//  and a Compress/Limit emphasis blend. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- opto cell state: two release time-constants summed (fast + slow tail) ---\nlet cellFast: f32 = 0.0;   // quick-recovery photocell component (linear gain-reduction units)\nlet cellSlow: f32 = 0.0;   // long memory tail component\nlet attackEnv: f32 = 0.0;  // smoothed sidechain drive into the cell\n\n// --- sidechain detector state ---\nconst scHpL: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low-freq de-emphasis (high-pass) state\nconst scRect: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // smoothed rectified level per channel (unused tail, kept stable)\n\nconst PI: f32 = 3.14159265358979;\n\nconst P_PEAK: i32 = 0;   // 0..1  Peak Reduction (compression amount)\nconst P_GAIN: i32 = 1;   // 0..1  Makeup gain   -> 0..+24 dB\nconst P_EMPH: i32 = 2;   // 0..1  Compress(0) .. Limit(1) emphasis\nconst P_MIX: i32 = 3;    // 0..1  dry/wet (parallel)\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  cellFast = 0.0; cellSlow = 0.0; attackEnv = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) { scHpL[c] = 0.0; scRect[c] = 0.0; }\n  params[P_PEAK] = 0.5;\n  params[P_GAIN] = 0.35;\n  params[P_EMPH] = 0.25;\n  params[P_MIX]  = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// one-pole smoothing coefficient for a given time constant (seconds)\n@inline function tcCoeff(seconds: f32, sr: f32): f32 {\n  const t: f32 = seconds > 0.00001 ? seconds : f32(0.00001);\n  return f32(1.0 - Mathf.exp(f32(-1.0) / (t * sr)));\n}\n\nexport function process(n: i32): void {\n  const peak: f32 = clampf(params[P_PEAK], 0.0, 1.0);\n  const makeupDb: f32 = clampf(params[P_GAIN], 0.0, 1.0) * 24.0;\n  const makeup: f32 = f32(Mathf.pow(10.0, makeupDb / 20.0));\n  const emph: f32 = clampf(params[P_EMPH], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // --- threshold drops as Peak Reduction rises (more of the signal squeezed) ---\n  // peak=0 -> ~ -6 dBFS (almost nothing), peak=1 -> ~ -34 dBFS (heavy leveling)\n  const threshDb: f32 = f32(-6.0) - peak * 28.0;\n  const thresh: f32 = f32(Mathf.pow(10.0, threshDb / 20.0));\n  // soft-knee width in dB (wider knee -> smoother, more \"optical\")\n  const kneeDb: f32 = 6.0;\n\n  // --- compression ratio: Compress emphasis ~ gentle (≈3:1); Limit ~ firm (≈10:1) ---\n  const ratio: f32 = f32(3.0) + emph * 7.0;\n  const slope: f32 = f32(1.0) - f32(1.0) / ratio; // gain-reduction slope in dB/dB above knee\n\n  // --- opto timing. Attack is slow + program dependent; Limit emphasis quickens it. ---\n  const atkSec: f32 = f32(0.012) - emph * 0.008;           // ~12 ms .. ~4 ms\n  const aAtk: f32 = tcCoeff(atkSec, sampleRate);\n  // two-stage release: fast component recovers quickly, slow tail lingers\n  const relFastSec: f32 = f32(0.08) + (1.0 - emph) * 0.04;  // ~80..120 ms\n  const relSlowSec: f32 = f32(1.4) + (1.0 - emph) * 1.1;    // ~1.4..2.5 s long tail\n  const rFast: f32 = tcCoeff(relFastSec, sampleRate);\n  const rSlow: f32 = tcCoeff(relSlowSec, sampleRate);\n\n  // sidechain low-frequency de-emphasis (high-pass ~90 Hz) so bass doesn't pump\n  const cHp: f32 = f32(1.0 - Mathf.exp(f32(-2.0) * PI * 90.0 / sampleRate));\n\n  // gentle output trim to keep broadband peaks under control\n  const outTrim: f32 = 0.92;\n\n  let cf: f32 = cellFast;\n  let cs: f32 = cellSlow;\n  let ae: f32 = attackEnv;\n\n  for (let f = 0; f < n; f++) {\n    // ---- build a mono-ish, frequency-aware sidechain detector ----\n    let sc: f32 = 0.0;\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      const x: f32 = inBuf[base + f];\n      // de-emphasise lows in the detector only\n      let lo: f32 = scHpL[c];\n      lo = lo + cHp * (x - lo);\n      scHpL[c] = lo;\n      const hp: f32 = x - lo * 0.85; // partial low cut (keep some body)\n      const a: f32 = hp < 0.0 ? -hp : hp;\n      if (a > sc) sc = a;            // peak across channels\n    }\n\n    // smooth the detector a touch (removes sample-to-sample jitter)\n    const detTc: f32 = tcCoeff(0.002, sampleRate);\n    ae = ae + detTc * (sc - ae);\n    const det: f32 = ae > 0.0000001 ? ae : f32(0.0000001);\n\n    // ---- soft-knee static gain-reduction TARGET (in dB, positive = reduction) ----\n    const detDb: f32 = f32(20.0) * f32(Mathf.log10(det));\n    const over: f32 = detDb - threshDb; // dB above threshold\n    let grDb: f32 = 0.0;\n    if (over <= -kneeDb * 0.5) {\n      grDb = 0.0;\n    } else if (over >= kneeDb * 0.5) {\n      grDb = slope * over;\n    } else {\n      // quadratic soft knee\n      const t: f32 = over + kneeDb * 0.5; // 0..kneeDb\n      grDb = slope * (t * t) / (2.0 * kneeDb);\n    }\n    // linear target reduction (>=1 means \"no reduction\" multiplier of 1)\n    const targetGain: f32 = f32(Mathf.pow(10.0, -grDb / 20.0)); // 0..1, 1 = no reduction\n\n    // ---- opto cell: track target with slow attack, two-stage release ----\n    // The cell stores REDUCTION amount = (1 - gain). More reduction => darker cell.\n    const targetRed: f32 = f32(1.0) - targetGain; // 0..1\n    // fast component\n    if (targetRed > cf) cf = cf + aAtk * (targetRed - cf);\n    else                cf = cf + rFast * (targetRed - cf);\n    // slow tail follows the fast component but with a long memory\n    if (cf > cs) cs = cs + aAtk * (cf - cs);\n    else         cs = cs + rSlow * (cf - cs);\n\n    // combined cell reduction: mostly fast, with the slow tail adding sustain\n    let red: f32 = 0.65 * cf + 0.35 * cs;\n    if (red < 0.0) red = 0.0;\n    if (red > 0.97) red = 0.97; // never fully close the cell\n    const gr: f32 = f32(1.0) - red; // final smooth gain multiplier (0.03..1)\n\n    // ---- apply to both channels ----\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      const x: f32 = inBuf[base + f];\n      const comp: f32 = x * gr * makeup;\n      const y: f32 = x * (1.0 - mix) + comp * mix;\n      outBuf[base + f] = f32(y * outTrim);\n    }\n  }\n\n  cellFast = cf;\n  cellSlow = cs;\n  attackEnv = ae;\n}\n",
  "publishedAt": 1751000005000
}