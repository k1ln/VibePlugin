{
  "format": 1,
  "name": "Twin Filter",
  "isInstrument": true,
  "explanation": "A dual series-filter monophonic synth: two detuned sawtooth oscillators feed a resonant HIGH-PASS filter in series with a resonant LOW-PASS filter. Because the high-pass comes first you can carve hollow, nasal, band-pass tones that single-filter monos cannot reach — the HP Cutoff thins and hollows the body, the LP Cutoff darkens the top, and where the two corners pinch together you get a reedy vocal band. Both filters are resonant and a punchy filter envelope (Env Amount + Decay) sweeps both cutoffs upward for the signature 'wow' attack. Detune thickens the two oscillators; pitch tracks the played note exactly. Up to two voices, last-note priority.",
  "params": [
    {
      "name": "LP Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.62
    },
    {
      "name": "HP Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.32
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Env Amount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.42
    },
    {
      "name": "Detune",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Twin Filter</title>\n<style>\n  :root{\n    --teal:#4ad0c8;\n    --orange:#ff8a5a;\n    --teal-dim:#1f5a56;\n    --orange-dim:#7a3f29;\n    --panel0:#0c1012;\n    --panel1:#161c1f;\n    --panel2:#212a2e;\n    --ink:#070a0b;\n    --txt:#cfe2e0;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}\n  html,body{height:100%}\n  body{\n    background:radial-gradient(130% 100% at 50% -15%,#1a2226 0%,#0c1113 50%,#05080a 100%);\n    color:var(--txt);\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    letter-spacing:.02em;\n  }\n\n  /* ===== slim charcoal chassis ===== */\n  .unit{\n    position:relative;\n    width:720px;height:404px;\n    border-radius:14px;\n    padding:16px 20px 18px;\n    background:\n      linear-gradient(180deg,#2b3438 0%,#222b2f 7%,#1a2125 12%,#141a1d 55%,#10161a 92%,#0a0f12 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.12) inset,\n      0 -2px 8px rgba(0,0,0,.6) inset,\n      0 26px 60px rgba(0,0,0,.7),\n      0 2px 0 #05090b;\n    overflow:hidden;\n  }\n  /* fine vertical brushed grain */\n  .unit::before{\n    content:\"\";position:absolute;inset:0;border-radius:14px;pointer-events:none;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.022) 0 1px,rgba(0,0,0,.05) 1px 3px);\n    mix-blend-mode:overlay;opacity:.6;\n  }\n  /* slow drifting sheen */\n  .unit::after{\n    content:\"\";position:absolute;top:0;left:-40%;width:30%;height:100%;\n    background:linear-gradient(105deg,transparent,rgba(255,255,255,.06),transparent);\n    transform:skewX(-16deg);pointer-events:none;\n    animation:sheen 11s ease-in-out infinite;\n  }\n  @keyframes sheen{0%,78%{left:-45%}94%{left:135%}100%{left:135%}}\n\n  .screw{position:absolute;width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#5a656a,#2b3236 55%,#13191c 100%);\n    box-shadow:0 1px 1px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.4) inset;}\n  .screw::after{content:\"\";position:absolute;inset:2.5px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#0a0f11 44% 56%,transparent 56%);transform:rotate(-22deg)}\n  .screw.tl{top:8px;left:8px}.screw.tr{top:8px;right:8px}\n  .screw.bl{bottom:8px;left:8px}.screw.br{bottom:8px;right:8px}\n\n  /* ===== header ===== */\n  .head{display:flex;align-items:flex-end;justify-content:space-between;margin:1px 4px 11px}\n  .brand{display:flex;flex-direction:column;line-height:1}\n  .brand .sub{font-size:8.5px;letter-spacing:.46em;color:#6f8582;font-weight:700;margin-bottom:6px;text-transform:uppercase}\n  .brand .name{font-size:25px;font-weight:800;letter-spacing:.01em;color:#e8f3f1;\n    text-shadow:0 1px 0 rgba(0,0,0,.6)}\n  .brand .name b{color:var(--teal);text-shadow:0 0 10px rgba(74,208,200,.6)}\n  .brand .name i{font-style:normal;color:var(--orange);text-shadow:0 0 10px rgba(255,138,90,.55)}\n  .tag{display:flex;flex-direction:column;align-items:flex-end;gap:3px}\n  .tag .mono{font-size:8px;letter-spacing:.34em;color:#5a6e6b;font-weight:700}\n  .tag .voice{display:flex;gap:5px;align-items:center}\n  .vled{width:7px;height:7px;border-radius:50%;background:#16201f;\n    box-shadow:0 0 0 1px rgba(0,0,0,.5) inset}\n  .vled.on{background:var(--teal);box-shadow:0 0 7px var(--teal),0 0 0 1px rgba(0,0,0,.4) inset}\n\n  /* ===== response scope ===== */\n  .scope{\n    position:relative;width:100%;height:150px;border-radius:10px;\n    background:linear-gradient(180deg,#05100f 0%,#040b0c 60%,#030708 100%);\n    border:1.5px solid #1b2528;\n    box-shadow:0 3px 7px rgba(0,0,0,.7) inset,0 1px 0 rgba(255,255,255,.08);\n    overflow:hidden;margin-bottom:14px;\n  }\n  .scope svg{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .grid{position:absolute;inset:0;pointer-events:none;\n    background:\n      repeating-linear-gradient(0deg,rgba(74,208,200,.05) 0 1px,transparent 1px 19px),\n      repeating-linear-gradient(90deg,rgba(74,208,200,.05) 0 1px,transparent 1px 30px);}\n  .glass{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(130% 80% at 50% -10%,rgba(120,220,210,.10),transparent 60%)}\n  .scan{position:absolute;left:0;right:0;height:34px;pointer-events:none;\n    background:linear-gradient(180deg,transparent,rgba(74,208,200,.06),transparent);\n    animation:scan 5.5s linear infinite}\n  @keyframes scan{0%{top:-34px}100%{top:150px}}\n  .lbl{position:absolute;font-size:8px;font-weight:700;letter-spacing:.16em;pointer-events:none}\n  .lbl.hp{left:9px;top:8px;color:var(--orange);text-shadow:0 0 6px rgba(255,138,90,.7)}\n  .lbl.lp{right:9px;top:8px;color:var(--teal);text-shadow:0 0 6px rgba(74,208,200,.7)}\n  .lbl.band{bottom:7px;left:50%;transform:translateX(-50%);color:#9fdfd9;opacity:.7;letter-spacing:.3em}\n\n  /* ===== controls row ===== */\n  .controls{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;align-items:start}\n  .cell{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .knob{\n    position:relative;width:62px;height:62px;border-radius:50%;cursor:ns-resize;\n    background:\n      radial-gradient(circle at 50% 38%,#2a3438 0%,#1b2327 55%,#11171a 100%);\n    box-shadow:\n      0 2px 5px rgba(0,0,0,.6),\n      0 1px 0 rgba(255,255,255,.08) inset,\n      0 -3px 6px rgba(0,0,0,.5) inset;\n    touch-action:none;\n  }\n  .knob::before{ /* outer ring tick gauge */\n    content:\"\";position:absolute;inset:-5px;border-radius:50%;\n    background:conic-gradient(from 220deg,\n      rgba(255,255,255,.04) 0deg,\n      rgba(255,255,255,.04) 280deg,\n      transparent 280deg);\n    -webkit-mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33px,transparent 34px);\n            mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33px,transparent 34px);\n  }\n  .knob .arc{position:absolute;inset:-5px;border-radius:50%;pointer-events:none}\n  .knob .cap{position:absolute;inset:9px;border-radius:50%;\n    background:radial-gradient(circle at 50% 34%,#323d41,#1d2529 60%,#141a1d 100%);\n    box-shadow:0 1px 2px rgba(0,0,0,.6),0 1px 0 rgba(255,255,255,.07) inset}\n  .knob .ptr{position:absolute;left:50%;top:9px;width:2.4px;height:21px;border-radius:2px;\n    background:linear-gradient(180deg,var(--teal),#bff3ef);\n    transform-origin:50% 22px;transform:translateX(-50%) rotate(0deg);\n    box-shadow:0 0 7px var(--teal)}\n  .knob.orange .ptr{background:linear-gradient(180deg,var(--orange),#ffd2bf);box-shadow:0 0 7px var(--orange)}\n  .knob .dot{position:absolute;left:50%;top:50%;width:5px;height:5px;border-radius:50%;\n    transform:translate(-50%,-50%);background:#0a0f11;box-shadow:0 0 0 1px rgba(255,255,255,.06) inset}\n  .cell .nm{font-size:8.5px;letter-spacing:.13em;font-weight:700;color:#9fb2af;text-transform:uppercase}\n  .cell .val{font-size:9.5px;font-weight:700;color:var(--teal);font-variant-numeric:tabular-nums;\n    text-shadow:0 0 6px rgba(74,208,200,.4)}\n  .cell.orange .val{color:var(--orange);text-shadow:0 0 6px rgba(255,138,90,.4)}\n  .knob:hover .cap{filter:brightness(1.12)}\n  .knob:active{cursor:grabbing}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <span class=\"sub\">Dual Series Filter · Mono Synth</span>\n        <span class=\"name\"><b>TWIN</b> <i>FILTER</i></span>\n      </div>\n      <div class=\"tag\">\n        <span class=\"mono\">HP → LP · 2-VOICE</span>\n        <span class=\"voice\"><span class=\"vled\" id=\"v0\"></span><span class=\"vled\" id=\"v1\"></span></span>\n      </div>\n    </div>\n\n    <div class=\"scope\">\n      <svg viewBox=\"0 0 600 150\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"hpFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ff8a5a\" stop-opacity=\".30\"/>\n            <stop offset=\"1\" stop-color=\"#ff8a5a\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <linearGradient id=\"lpFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#4ad0c8\" stop-opacity=\".30\"/>\n            <stop offset=\"1\" stop-color=\"#4ad0c8\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <filter id=\"glow\"><feGaussianBlur stdDeviation=\"2.2\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n        </defs>\n        <path id=\"hpArea\" fill=\"url(#hpFill)\"></path>\n        <path id=\"lpArea\" fill=\"url(#lpFill)\"></path>\n        <path id=\"bandArea\" fill=\"#bff3ef\" fill-opacity=\".10\"></path>\n        <path id=\"hpCurve\" fill=\"none\" stroke=\"var(--orange)\" stroke-width=\"2.2\" filter=\"url(#glow)\"></path>\n        <path id=\"lpCurve\" fill=\"none\" stroke=\"var(--teal)\" stroke-width=\"2.2\" filter=\"url(#glow)\"></path>\n        <circle id=\"hpKnee\" r=\"3.4\" fill=\"#fff\" stroke=\"var(--orange)\" stroke-width=\"1.6\"></circle>\n        <circle id=\"lpKnee\" r=\"3.4\" fill=\"#fff\" stroke=\"var(--teal)\" stroke-width=\"1.6\"></circle>\n      </svg>\n      <div class=\"grid\"></div>\n      <div class=\"glass\"></div>\n      <div class=\"scan\"></div>\n      <span class=\"lbl hp\">HIGH-PASS</span>\n      <span class=\"lbl lp\">LOW-PASS</span>\n      <span class=\"lbl band\">BAND</span>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n  </div>\n\n<script>\n(function(){\n  var host = window.vstai || null;\n  function send(i,v){ if(host && host.setParam) host.setParam(i,v); }\n\n  // param defs: index matches assembly.ts / spec.json\n  var PARAMS = [\n    {i:0, nm:\"LP Cutoff\",  def:0.62, accent:\"teal\"},\n    {i:1, nm:\"HP Cutoff\",  def:0.32, accent:\"orange\"},\n    {i:2, nm:\"Resonance\",  def:0.55, accent:\"teal\"},\n    {i:3, nm:\"Env Amount\", def:0.60, accent:\"orange\"},\n    {i:4, nm:\"Decay\",      def:0.42, accent:\"teal\"},\n    {i:5, nm:\"Detune\",     def:0.30, accent:\"orange\"},\n    {i:6, nm:\"Level\",      def:0.80, accent:\"teal\"}\n  ];\n  var state = {};\n  PARAMS.forEach(function(p){ state[p.i] = p.def; });\n\n  var controls = document.getElementById(\"controls\");\n  var els = {};\n\n  function fmt(p){\n    var v = state[p.i];\n    if(p.i===5) return (v*3.5).toFixed(1)+\"%\";       // detune percent-ish\n    return Math.round(v*100)+\"\";\n  }\n\n  PARAMS.forEach(function(p){\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\" + (p.accent===\"orange\" ? \" orange\" : \"\");\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\" + (p.accent===\"orange\" ? \" orange\" : \"\");\n    knob.setAttribute(\"title\",\"drag · double-click resets\");\n    knob.innerHTML =\n      '<svg class=\"arc\" viewBox=\"0 0 72 72\"><path class=\"arcpath\" fill=\"none\" '+\n      'stroke=\"'+(p.accent===\"orange\"?\"#ff8a5a\":\"#4ad0c8\")+'\" stroke-width=\"2.4\" '+\n      'stroke-linecap=\"round\" stroke-opacity=\".85\"></path></svg>'+\n      '<div class=\"cap\"></div><div class=\"ptr\"></div><div class=\"dot\"></div>';\n    var nm = document.createElement(\"div\"); nm.className=\"nm\"; nm.textContent=p.nm;\n    var val = document.createElement(\"div\"); val.className=\"val\";\n    cell.appendChild(knob); cell.appendChild(nm); cell.appendChild(val);\n    controls.appendChild(cell);\n    els[p.i] = { knob:knob, ptr:knob.querySelector(\".ptr\"), arc:knob.querySelector(\".arcpath\"), val:val };\n\n    // ---- interaction: vertical drag ----\n    var dragging=false, startY=0, startV=0;\n    function setV(nv, doSend){\n      nv = Math.max(0, Math.min(1, nv));\n      state[p.i]=nv;\n      paint(p);\n      if(doSend!==false) send(p.i, nv);\n    }\n    knob.addEventListener(\"pointerdown\", function(e){\n      dragging=true; startY=e.clientY; startV=state[p.i];\n      knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener(\"pointermove\", function(e){\n      if(!dragging) return;\n      var dy = startY - e.clientY;\n      setV(startV + dy/180);\n    });\n    knob.addEventListener(\"pointerup\", function(e){ dragging=false; });\n    knob.addEventListener(\"pointercancel\", function(e){ dragging=false; });\n    knob.addEventListener(\"dblclick\", function(e){ setV(p.def); e.preventDefault(); });\n    knob.addEventListener(\"wheel\", function(e){\n      setV(state[p.i] - e.deltaY/2400); e.preventDefault();\n    }, {passive:false});\n  });\n\n  var ARC_LEN = 0; // computed lazily per knob via path\n  function paint(p){\n    var e = els[p.i];\n    var v = state[p.i];\n    // pointer: -135deg .. +135deg (270 deg sweep)\n    var ang = -135 + v*270;\n    e.ptr.style.transform = \"translateX(-50%) rotate(\"+ang+\"deg)\";\n    // arc gauge (start at 220deg sweeping 280deg of the ring, mapped to value)\n    var R=33, cx=36, cy=36;\n    var a0 = (220)*Math.PI/180;\n    var a1 = (220 + v*280)*Math.PI/180;\n    var x0 = cx + R*Math.cos(a0), y0 = cy + R*Math.sin(a0);\n    var x1 = cx + R*Math.cos(a1), y1 = cy + R*Math.sin(a1);\n    var large = (v*280) > 180 ? 1 : 0;\n    e.arc.setAttribute(\"d\",\"M \"+x0.toFixed(2)+\" \"+y0.toFixed(2)+\n      \" A \"+R+\" \"+R+\" 0 \"+large+\" 1 \"+x1.toFixed(2)+\" \"+y1.toFixed(2));\n    e.val.textContent = fmt(p);\n    drawScope();\n  }\n\n  // ===== response-curve scope =====\n  var W=600, H=150;\n  var hpCurve=document.getElementById(\"hpCurve\"),\n      lpCurve=document.getElementById(\"lpCurve\"),\n      hpArea=document.getElementById(\"hpArea\"),\n      lpArea=document.getElementById(\"lpArea\"),\n      bandArea=document.getElementById(\"bandArea\"),\n      hpKnee=document.getElementById(\"hpKnee\"),\n      lpKnee=document.getElementById(\"lpKnee\");\n\n  function xForCut(norm){ return 30 + norm*540; }   // map 0..1 -> 30..570 px\n\n  function drawScope(){\n    var lp = state[0], hp = state[1], reso = state[2];\n    // knee x positions on the log-ish axis\n    var hpX = xForCut(hp*0.78 + 0.04);   // HP corner travels right as HP rises\n    var lpX = xForCut(lp*0.82 + 0.12);   // LP corner travels right as LP rises\n    var peak = 10 + reso*26;             // resonance bump height\n\n    // HIGH-PASS: low freq attenuated (rises from bottom-left up to flat top),\n    // with a resonant peak at its knee.\n    var hp_d = \"M 0 \"+H+\" \";\n    var hp_top = 34;\n    for(var x=0;x<=W;x+=6){\n      var t=(x-hpX)/55;\n      var s=1/(1+Math.exp(-t));          // sigmoid rise\n      var y = H-10 - s*(H-44);\n      // resonant bump near knee\n      var bump = peak*Math.exp(-Math.pow((x-hpX)/22,2));\n      y -= bump;\n      if(y<hp_top) y=hp_top;\n      hp_d += \"L \"+x+\" \"+y.toFixed(1)+\" \";\n    }\n    hpCurve.setAttribute(\"d\", hp_d);\n    hpArea.setAttribute(\"d\", hp_d + \"L \"+W+\" \"+H+\" L 0 \"+H+\" Z\");\n\n    // LOW-PASS: high freq attenuated (flat top then falls), resonant peak at knee.\n    var lp_d = \"M 0 34 \";\n    for(var x2=0;x2<=W;x2+=6){\n      var t2=(x2-lpX)/55;\n      var s2=1/(1+Math.exp(t2));          // sigmoid fall\n      var y2 = H-10 - s2*(H-44);\n      var bump2 = peak*Math.exp(-Math.pow((x2-lpX)/22,2));\n      y2 -= bump2;\n      if(y2<34) y2=34;\n      lp_d += \"L \"+x2+\" \"+y2.toFixed(1)+\" \";\n    }\n    lpCurve.setAttribute(\"d\", lp_d);\n    lpArea.setAttribute(\"d\", lp_d + \"L \"+W+\" \"+H+\" L 0 \"+H+\" Z\");\n\n    // BAND region between the two knees\n    var lo = Math.min(hpX,lpX), hi=Math.max(hpX,lpX);\n    bandArea.setAttribute(\"d\",\"M \"+lo+\" 34 L \"+hi+\" 34 L \"+hi+\" \"+H+\" L \"+lo+\" \"+H+\" Z\");\n\n    // knee markers\n    hpKnee.setAttribute(\"cx\",hpX); hpKnee.setAttribute(\"cy\", (H-10)-0.5*(H-44)-peak);\n    lpKnee.setAttribute(\"cx\",lpX); lpKnee.setAttribute(\"cy\", (H-10)-0.5*(H-44)-peak);\n  }\n\n  // voice LED shimmer (purely decorative — alternates with the scan)\n  var t=0;\n  function tick(){\n    t+=0.016;\n    var a=document.getElementById(\"v0\"), b=document.getElementById(\"v1\");\n    if(a) a.classList.toggle(\"on\", (Math.sin(t*2.1)>0.4));\n    if(b) b.classList.toggle(\"on\", (Math.sin(t*2.1+1.7)>0.6));\n    requestAnimationFrame(tick);\n  }\n  requestAnimationFrame(tick);\n\n  function ready(){\n    PARAMS.forEach(function(p){\n      send(p.i, state[p.i]);   // push defaults to host\n      paint(p);\n    });\n    drawScope();\n  }\n  if(host && host.onReady) host.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  TWIN FILTER — dual series HP+LP resonant mono synth (CS-lineage voice)\n//\n//  An original take on the classic Japanese dual-filter monophonic voice:\n//  two detuned sawtooth oscillators are summed, then driven through a\n//  resonant HIGH-PASS filter IN SERIES with a resonant LOW-PASS filter.\n//  Because the HP comes first, you can carve a hollow / nasal / band-pass\n//  character that single-filter monos cannot reach — the HP thins the body\n//  out, the LP darkens the top, and where the two corners pinch together\n//  you get a reedy, vocal band. A snappy filter envelope sweeps BOTH\n//  cutoffs upward for the signature punchy \"wow\" attack.\n//\n//  Signal path per voice (2 voices, last-note priority + note stack):\n//    osc1 + osc2 (detuned saws) -> resonant HP (2-pole SVF, HP tap)\n//                               -> resonant LP (2-pole SVF, LP tap)\n//                               -> amp env -> soft sat -> level\n//    cutoffs = base * 2^(env * EnvAmount)  (envelope opens both filters)\n//\n//  Pure algorithm, no samples. All math in f32 (Mathf.*).\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 2;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32  = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_LPCUT:  i32 = 0; // low-pass cutoff 0..1  (darkens)\nconst P_HPCUT:  i32 = 1; // high-pass cutoff 0..1 (thins/hollows)\nconst P_RESO:   i32 = 2; // shared resonance 0..1 (both filters)\nconst P_ENVAMT: i32 = 3; // filter envelope amount 0..1 (sweeps both cutoffs)\nconst P_DECAY:  i32 = 4; // filter+amp decay 0..1\nconst P_DETUNE: i32 = 5; // osc2 detune 0..1\nconst P_LEVEL:  i32 = 6; // output level 0..1\n\n// ---- per-voice state (StaticArrays, indexed by voice) ----\nconst vPhase1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc1 phase 0..1\nconst vPhase2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc2 phase 0..1\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // base freq Hz\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // note id (-1 = free)\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for voice stealing\nconst vFenv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // filter env 1->0\nconst vAenv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // amp env\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // note velocity\n\n// HP state-variable filter (per voice): two integrators\nconst vHpLp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // hp svf low integrator\nconst vHpBp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // hp svf band integrator\n// LP state-variable filter (per voice)\nconst vLpLp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // lp svf low integrator\nconst vLpBp: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // lp svf band integrator\n\nlet ageCounter: i32 = 0;\n\n// global output DC blocker\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vPhase1[v] = 0.0; vPhase2[v] = 0.0; vFreq[v] = 0.0;\n    vNote[v] = -1; vGate[v] = 0; vAge[v] = 0;\n    vFenv[v] = 0.0; vAenv[v] = 0.0; vVel[v] = 0.0;\n    vHpLp[v] = 0.0; vHpBp[v] = 0.0; vLpLp[v] = 0.0; vLpBp[v] = 0.0;\n  }\n  ageCounter = 0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_LPCUT]  = 0.62;\n  params[P_HPCUT]  = 0.32;\n  params[P_RESO]   = 0.55;\n  params[P_ENVAMT] = 0.6;\n  params[P_DECAY]  = 0.42;\n  params[P_DETUNE] = 0.3;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// fast bounded tanh-ish saturator (keeps resonance + output safe)\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// ---- voice allocation: pick a free voice, else steal the oldest ----\nfunction pickVoice(): i32 {\n  for (let v = 0; v < NUM_VOICES; v++) {\n    if (vGate[v] == 0 && vAenv[v] < 0.001) return v;\n  }\n  // steal the oldest-started voice\n  let oldest: i32 = 0;\n  let bestAge: i32 = 0x7fffffff;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    if (vAge[v] < bestAge) { bestAge = vAge[v]; oldest = v; }\n  }\n  return oldest;\n}\n\n// Host passes frequency in Hz. Each new note grabs a voice and retriggers\n// its envelopes (punchy attack).\nexport function noteOn(id: i32, f: f32, vel: f32): void {\n  const fr: f32 = f > 0.0 ? f : 0.0001;\n  const v: i32 = pickVoice();\n  vNote[v]  = id;\n  vFreq[v]  = fr;\n  vGate[v]  = 1;\n  vVel[v]   = clampf(vel, 0.0, 1.0);\n  vPhase1[v] = 0.0;\n  vPhase2[v] = 0.37;            // offset so the two saws don't start in phase\n  vFenv[v]  = 1.0;             // retrigger filter sweep\n  vAenv[v]  = 1.0;             // retrigger amp\n  vAge[v]   = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let v = 0; v < NUM_VOICES; v++) {\n    if (vNote[v] == id && vGate[v] == 1) { vGate[v] = 0; }\n  }\n}\n\nexport function process(n: i32): void {\n  const lpN:    f32 = clampf(params[P_LPCUT],  0.0, 1.0);\n  const hpN:    f32 = clampf(params[P_HPCUT],  0.0, 1.0);\n  const resoN:  f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envAmtN: f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  // ---- base cutoffs (exponential, musical) ----\n  //   LP:  ~120 Hz .. ~12 kHz   (darkens when low)\n  //   HP:  ~20 Hz  .. ~1.8 kHz  (thins / hollows when high)\n  const lpBase: f32 = f32(120.0 * Mathf.exp(lpN * 4.61));   // 120 * e^4.61 ~ 12000\n  const hpBase: f32 = f32(20.0  * Mathf.exp(hpN * 4.50));   // 20 * e^4.50  ~ 1800\n\n  // ---- envelope sweep: opens BOTH cutoffs by up to ~3 octaves ----\n  const sweepOct: f32 = envAmtN * 3.0;\n\n  // ---- resonance: shared by both filters. SVF damping q = 1/Q ----\n  //   resoN 0 -> q ~2.0 (gentle), resoN 1 -> q ~0.06 (near self-osc, bounded)\n  const q: f32 = 2.0 - resoN * 1.94;\n\n  // ---- envelope decay coefficients ----\n  const fdecaySec: f32 = 0.04 + decayN * decayN * 1.4;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n  // amp env: short attack handled by retrigger; decay-to-sustain while held,\n  // full release when gate drops. Made decay-dependent so Decay is audible.\n  const adecaySec: f32 = 0.05 + decayN * decayN * 1.8;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n  // release a touch faster than sustain decay\n  const relSec: f32 = 0.04 + decayN * 0.5;\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relSec * sampleRate)));\n\n  // ---- detune: osc2 up to ~+/- ~30 cents-ish spread for thick mono ----\n  const detRatio: f32 = 1.0 + detuneN * 0.035;   // up to +3.5% (osc2 sharp)\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      // skip fully silent free voices\n      if (vGate[v] == 0 && vAenv[v] < 0.0002) continue;\n\n      // ---- envelopes ----\n      vFenv[v] *= fenvCoef;\n      if (vGate[v] != 0) {\n        // decay toward a sustain floor while held\n        const sustain: f32 = 0.32;\n        vAenv[v] = sustain + (vAenv[v] - sustain) * aenvCoef;\n      } else {\n        vAenv[v] *= relCoef;\n      }\n      const aenv: f32 = vAenv[v];\n\n      // ---- oscillators: two detuned naive saws ----\n      const f0: f32 = vFreq[v];\n      let inc1: f32 = f0 / sampleRate;\n      let inc2: f32 = (f0 * detRatio) / sampleRate;\n      if (inc1 > 0.5) inc1 = 0.5; if (inc1 < 0.0) inc1 = 0.0;\n      if (inc2 > 0.5) inc2 = 0.5; if (inc2 < 0.0) inc2 = 0.0;\n\n      let ph1: f32 = vPhase1[v] + inc1; if (ph1 >= 1.0) ph1 -= 1.0;\n      let ph2: f32 = vPhase2[v] + inc2; if (ph2 >= 1.0) ph2 -= 1.0;\n      vPhase1[v] = ph1;\n      vPhase2[v] = ph2;\n\n      const saw1: f32 = ph1 * 2.0 - 1.0;\n      const saw2: f32 = ph2 * 2.0 - 1.0;\n      let osc: f32 = (saw1 + saw2) * 0.5;\n\n      // ---- envelope-swept cutoffs (Hz) ----\n      const sweep: f32 = f32(Mathf.exp(0.6931472 * sweepOct * vFenv[v])); // 2^(oct*env)\n      let hpHz: f32 = hpBase * sweep;\n      let lpHz: f32 = lpBase * sweep;\n      if (hpHz < 20.0)  hpHz = 20.0;\n      if (hpHz > nyq * 0.45) hpHz = nyq * 0.45;\n      if (lpHz < 30.0)  lpHz = 30.0;\n      if (lpHz > nyq * 0.45) lpHz = nyq * 0.45;\n\n      // ---- SERIES resonant HIGH-PASS then resonant LOW-PASS (2-pole SVF) ----\n      // HP stage\n      let gH: f32 = f32(Mathf.tan(PI * hpHz / sampleRate));\n      if (gH > 1.2) gH = 1.2;\n      const denH: f32 = 1.0 + gH * (gH + q);\n      let lpH: f32 = vHpLp[v];\n      let bpH: f32 = vHpBp[v];\n      const hpHpf: f32 = (osc - (gH + q) * bpH - lpH) / denH; // high-pass tap\n      const bp1: f32 = gH * hpHpf + bpH;\n      const lp1: f32 = gH * bp1 + lpH;\n      vHpBp[v] = bp1;\n      vHpLp[v] = lp1;\n      let afterHP: f32 = hpHpf;        // hollowed signal\n      afterHP = satf(afterHP * 1.1);   // gentle drive into LP\n\n      // LP stage\n      let gL: f32 = f32(Mathf.tan(PI * lpHz / sampleRate));\n      if (gL > 1.2) gL = 1.2;\n      const denL: f32 = 1.0 + gL * (gL + q);\n      let lpL: f32 = vLpLp[v];\n      let bpL: f32 = vLpBp[v];\n      const hpL: f32 = (afterHP - (gL + q) * bpL - lpL) / denL;\n      const bp2: f32 = gL * hpL + bpL;\n      const lp2: f32 = gL * bp2 + lpL;\n      vLpBp[v] = bp2;\n      vLpLp[v] = lp2;\n      let voiceOut: f32 = lp2;         // low-pass tap (darkened)\n\n      // amp + per-note velocity\n      voiceOut *= aenv * (0.55 + 0.45 * vVel[v]);\n      mix += voiceOut;\n\n      // free the voice once fully released and silent\n      if (vGate[v] == 0 && vAenv[v] < 0.0002) {\n        vNote[v] = -1;\n        vHpLp[v] = 0.0; vHpBp[v] = 0.0; vLpLp[v] = 0.0; vLpBp[v] = 0.0;\n      }\n    }\n\n    // ---- output stage: saturate, DC block, level ----\n    let s: f32 = satf(mix * 1.2);\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n    s = satf(s * level * 1.25) * 0.82;   // peak guard, stays < ~1.0\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000110000
}