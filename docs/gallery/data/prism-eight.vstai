  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Prism Eight</title>\n<style>\n  :root{ --acc:#5ad0ff; --acc2:#ff7ad0; --bg0:#070a12; --bg1:#0e1428; --ink:#e9f1fb; --dim:#6f7da0; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#162043 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#121a36,#070a12); border:1px solid rgba(90,208,255,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(225,240,255,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0c1226,#070a14); border:1px solid rgba(90,208,255,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(210,225,245,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(90,208,255,.6)); }\n  .pcap{ fill:#0b1124; stroke:rgba(90,208,255,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(90,208,255,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(90,208,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">PRISM&nbsp;EIGHT</span><span class=\"sub\">ring-mod hybrid poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">SPECTRUM</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.55},{name:\"Reso\",idx:1,def:0.3},{name:\"Env\",idx:2,def:0.5},{name:\"Ring\",idx:3,def:0.0},{name:\"Detune\",idx:4,def:0.3},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#5ad0ff\"/><stop offset=\"1\" stop-color=\"#ff7ad0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  // spectrum: harmonics (clustered) + ring-mod sidebands (spread, inharmonic). Cutoff rolls off the top.\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], reso=vals[1], ring=vals[3], det=vals[4]; var baseY=H-12;\n    var N=28;\n    for(var i=0;i<N;i++){ var hpos=i/(N-1);\n      // harmonic position vs ring-spread inharmonic position\n      var f=hpos; if(ring>0.01){ f = hpos*(1-ring*0.4) + ring*0.4*Math.abs(Math.sin(i*1.7+1.3)); }\n      var x=12+f*(W-24);\n      // rolloff: bars above cutoff shrink\n      var roll=Math.max(0.04,1-Math.max(0,hpos-cut)*2.2);\n      var harm=1/(1+i*0.5);                       // harmonic amplitude decay\n      var sb=ring*(0.3+0.5*Math.abs(Math.sin(i*2.3+ts/600)));   // ring sidebands shimmer\n      var amp=(harm*(1-ring*0.6)+sb)*roll*(0.7+reso*0.5*(hpos>cut-0.05&&hpos<cut+0.05?1:0));\n      var bh=Math.max(1,amp*(H-26));\n      var col=i/(N-1);\n      ctx.strokeStyle=\"rgba(\"+Math.round(90+col*165)+\",\"+Math.round(208-col*86)+\",\"+Math.round(255-col*47)+\",\"+(0.45+amp*0.5)+\")\";\n      ctx.lineWidth=Math.max(2,(W-24)/N-2.5); ctx.shadowColor=ctx.strokeStyle; ctx.shadowBlur=ring>0.3?6:2;\n      ctx.beginPath(); ctx.moveTo(x,baseY); ctx.lineTo(x,baseY-bh); ctx.stroke();\n    }\n    ctx.shadowBlur=0;\n    // cutoff marker\n    var cx=12+cut*(W-24); ctx.strokeStyle=\"rgba(255,122,208,0.5)\"; ctx.lineWidth=1; ctx.setLineDash([3,3]); ctx.beginPath(); ctx.moveTo(cx,10); ctx.lineTo(cx,baseY); ctx.stroke(); ctx.setLineDash([]);\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  PRISM EIGHT — a flexible, slightly metallic analog/hybrid poly\n//  (Rhodes Chroma lineage). Its signature is RING modulation between the\n//  two oscillators: dial Ring up and the saws cross into clangorous,\n//  bell-like, inharmonic territory the way the Chroma's patchable voice\n//  could. Each of 8 voices runs two detuned saws through a resonant\n//  two-pole low-pass with its own envelope.\n//  Controls: Cutoff, Resonance, Env Amount, Ring, Detune, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vA: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vB: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_RING: i32 = 3; const P_DETUNE: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vA[i] = 0.0; vB[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.55; params[P_RESO] = 0.3; params[P_ENV] = 0.5; params[P_RING] = 0.0; params[P_DETUNE] = 0.3; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vA[slot] = 0.0; vB[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const ringN: f32 = clampf(params[P_RING], 0.0, 1.0);\n  const detN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.007 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.42 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.55 * sampleRate)));\n  const baseCut: f32 = 55.0 * f32(Mathf.exp(cutoffN * 5.3));\n  const envSpan: f32 = envN * 8000.0;\n  const k: f32 = 2.0 - 1.9 * resoN;\n  // detune climbs with Detune; ring uses a wider ratio so the product is clangorous\n  const det: f32 = 1.0 + detN * 0.04 + ringN * 0.9;       // osc2 ratio (ring pushes it up ~2x)\n  const dryGain: f32 = 1.0 - ringN * 0.85;\n  const ringGain: f32 = ringN * 1.7;\n  const out: f32 = level * 0.9;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let a: f32 = vA[s] + fr / sampleRate; if (a >= 1.0) a -= 1.0; vA[s] = a;\n      let b: f32 = vB[s] + (fr * det) / sampleRate; if (b >= 1.0) b -= 1.0; vB[s] = b;\n      const saw1: f32 = a * 2.0 - 1.0;\n      const saw2: f32 = b * 2.0 - 1.0;\n      const ringp: f32 = saw1 * saw2;                       // ring modulation product\n      let osc: f32 = ((saw1 + saw2) * 0.5 * dryGain + ringp * ringGain) * 0.5;\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      mix += lpN * vAmp[s] * vVel[s];\n    }\n    let o: f32 = f32(Mathf.tanh(mix * out));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751302400000
}