    {
      "name": "Ring",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
