{"format":1,"name":"Saw Lead","isInstrument":true,"explanation":"A monophonic sawtooth lead with a soft AR envelope. Play it with the on-screen keyboard, your computer keys (a–k), or a MIDI controller.","params":[{"name":"Level","index":0,"min":0,"max":1,"default":0.5}],"wasmBase64":"","html":"<!doctype html><html><head><meta charset=\"utf-8\"><style>\n    body{margin:0;font:14px ui-sans-serif,system-ui,sans-serif;background:#0b0e14;color:#e7eef6;\n      display:flex;flex-direction:column;gap:18px;padding:26px 28px}\n    h1{font-size:16px;margin:0 0 6px;letter-spacing:.04em;color:#4fe3c1}\n    label{display:flex;flex-direction:column;gap:6px;font-size:13px;color:#aeb9cc}\n    label span{color:#e7eef6;font-variant-numeric:tabular-nums}\n    input[type=range]{width:100%;accent-color:#4fe3c1}\n  </style></head><body>\n    <h1>Saw Lead</h1>\n    <label>Level<span id=\"v0\"></span>\n      <input type=\"range\" data-i=\"0\" min=\"0\" max=\"1\" step=\"0.001\" value=\"0.5\">\n    </label>\n    <script>\n      function ready(){\n        document.querySelectorAll('input[type=range]').forEach(function(r){\n          var i=+r.dataset.i, out=document.getElementById('v'+i);\n          function send(){ out.textContent=(+r.value).toFixed(2); window.vstai.setParam(i,+r.value); }\n          r.addEventListener('input',send); send();\n        });\n      }\n      if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n    </script>\n  </body></html>","publishedAt":1750000000000,"assembly":"// =====================================================================\n//  Reference INSTRUMENT module (monophonic saw + AR envelope).\n//  Implements the VibePlugin WASM ABI plus the synth note exports. The host\n//  converts MIDI note numbers to frequency (Hz) and calls noteOn/noteOff.\n//  Compiled to WASM in-process by asc.wasm (see wasm-toolchain/).\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 44100;\nlet phase: f32 = 0;\nlet freq:  f32 = 0;\nlet env:   f32 = 0;   // current envelope level\nlet vel:   f32 = 0;   // gate target while held\nlet gate:  i32 = 0;   // 1 while a note is held\nlet note:  i32 = -1;  // currently sounding note id\n\nconst P_LEVEL: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr;\n  phase = 0; env = 0; gate = 0; note = -1;\n  params[P_LEVEL] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 1; }\n\n// Host passes frequency in Hz (no note->Hz math needed in the module).\nexport function noteOn(id: i32, f: f32, v: f32): void { note = id; freq = f; vel = v; gate = 1; }\nexport function noteOff(id: i32): void { if (id == note) gate = 0; }\n\nexport function process(n: i32): void {\n  const gain: f32 = params[P_LEVEL];\n  const inc:  f32 = freq / sampleRate;\n  const tgt:  f32 = gate ? vel : 0.0;\n\n  for (let f = 0; f < n; f++) {\n    env = env + 0.001 * (tgt - env);        // ~20 ms attack/release\n    phase += inc; if (phase >= 1.0) phase -= 1.0;\n    const saw: f32 = phase * 2.0 - 1.0;       // naive saw (no transcendentals)\n    const s: f32 = saw * env * gain;\n    outBuf[f] = s;                            // left\n    outBuf[MAX_FRAMES + f] = s;               // right\n  }\n}\n"}