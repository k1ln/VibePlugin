{
  "format": 1,
  "name": "Choral Bank",
  "isInstrument": true,
  "explanation": "A fully-polyphonic organ / string-ensemble synthesizer in the lineage of the big paraphonic-string machines. Every key sounds a divide-down full-keyboard source — a stack of octave and fifth partials voiced like an organ's footages — and each note gets its OWN gentle resonant low-pass with a slow attack/release swell, so dense chords each breathe independently. The whole bank pours into a rich four-tap ensemble chorus whose slow quadrature LFOs widen the sound into a vast, shimmering, angelic choir. Controls: Cutoff, Resonance, Attack, Release, Ensemble, Brightness and Level.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.22
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Ensemble",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Brightness",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.55
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Choral Bank</title>\n<style>\n  :root {\n    --accent:  #7ab0ff;\n    --accent2: #d0b0ff;\n    --sky0: #0b1226;\n    --sky1: #101c3a;\n    --sky2: #1b2c52;\n    --haze: rgba(208,176,255,0.16);\n    --ink:  #eaf2ff;\n    --ink-dim: #9fb4d6;\n    --panel: rgba(18,30,58,0.66);\n    --stroke: rgba(160,190,255,0.18);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    height: 100%;\n    background: var(--sky0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  /* ---- cathedral sky backdrop ---------------------------------- */\n  .app {\n    position: relative;\n    min-height: 100%;\n    padding: 22px 22px 18px;\n    background:\n      radial-gradient(120% 80% at 50% -10%, rgba(122,176,255,0.28), transparent 60%),\n      radial-gradient(90% 70% at 18% 8%, rgba(208,176,255,0.18), transparent 55%),\n      radial-gradient(90% 70% at 84% 6%, rgba(122,176,255,0.16), transparent 55%),\n      linear-gradient(180deg, var(--sky1) 0%, var(--sky0) 70%);\n    overflow: hidden;\n  }\n\n  /* slow-drifting ensemble haze layers */\n  .haze {\n    position: absolute;\n    inset: -40% -20%;\n    pointer-events: none;\n    background:\n      radial-gradient(40% 30% at 30% 40%, var(--haze), transparent 70%),\n      radial-gradient(36% 28% at 70% 55%, rgba(122,176,255,0.14), transparent 70%),\n      radial-gradient(30% 24% at 50% 30%, rgba(255,255,255,0.06), transparent 70%);\n    filter: blur(14px);\n    animation: drift 26s ease-in-out infinite alternate;\n    z-index: 0;\n  }\n  @keyframes drift {\n    0%   { transform: translate3d(-3%, -2%, 0) scale(1.02); opacity: 0.85; }\n    50%  { transform: translate3d(3%, 2%, 0)   scale(1.08); opacity: 1; }\n    100% { transform: translate3d(-2%, 3%, 0)  scale(1.04); opacity: 0.9; }\n  }\n\n  /* faint cathedral arch columns */\n  .arches {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.5;\n    z-index: 0;\n  }\n\n  .wrap { position: relative; z-index: 2; max-width: 880px; margin: 0 auto; }\n\n  header {\n    display: flex;\n    align-items: baseline;\n    justify-content: space-between;\n    gap: 12px;\n    margin-bottom: 14px;\n  }\n  .title {\n    font-size: clamp(20px, 4.4vw, 30px);\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    background: linear-gradient(92deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 28px rgba(122,176,255,0.25);\n  }\n  .subtitle {\n    font-size: 10px;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* ---- shimmering choral wavefield ----------------------------- */\n  .field {\n    position: relative;\n    height: 96px;\n    border-radius: 14px;\n    border: 1px solid var(--stroke);\n    background: linear-gradient(180deg, rgba(11,18,38,0.7), rgba(27,44,82,0.5));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -16px 30px rgba(0,0,0,0.4);\n    overflow: hidden;\n    margin-bottom: 16px;\n  }\n  .field svg { display: block; width: 100%; height: 100%; }\n\n  /* ---- control sections ---------------------------------------- */\n  .sections {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));\n    gap: 12px;\n    margin-bottom: 16px;\n  }\n  .panel {\n    background: var(--panel);\n    border: 1px solid var(--stroke);\n    border-radius: 14px;\n    padding: 14px 10px 10px;\n    backdrop-filter: blur(6px);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 8px 24px rgba(0,0,0,0.3);\n  }\n  .panel .legend {\n    font-size: 9px;\n    letter-spacing: 0.26em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n    margin-bottom: 10px;\n  }\n  .knobrow {\n    display: flex;\n    flex-wrap: wrap;\n    justify-content: center;\n    gap: 10px;\n  }\n\n  .knob {\n    width: 96px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n    user-select: none;\n    cursor: ns-resize;\n  }\n  .knob svg { overflow: visible; touch-action: none; }\n  .knob .name {\n    font-size: 9.5px;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .knob .val {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    font-weight: 600;\n  }\n  .knob:hover .ring { stroke: var(--accent); }\n  .knob:hover .glow { opacity: 0.85; }\n\n  /* ---- keyboard ------------------------------------------------ */\n  .kb {\n    position: relative;\n    height: 88px;\n    border-radius: 12px;\n    border: 1px solid var(--stroke);\n    background: linear-gradient(180deg, rgba(20,32,60,0.8), rgba(10,16,34,0.9));\n    box-shadow: inset 0 2px 8px rgba(0,0,0,0.5);\n    padding: 8px;\n    display: flex;\n    gap: 0;\n    overflow: hidden;\n  }\n  .keys { position: relative; flex: 1; height: 100%; }\n  .wkey {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #eaf1ff, #b9c8e6);\n    border: 1px solid rgba(20,30,55,0.4);\n    box-shadow: inset 0 -8px 10px rgba(120,150,210,0.25);\n    cursor: pointer;\n    transition: background 0.08s, box-shadow 0.08s;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent), #9fc3ff);\n    box-shadow: inset 0 -6px 14px rgba(122,176,255,0.6), 0 0 16px rgba(122,176,255,0.5);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    height: 58%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #1a2440, #0a1124);\n    border: 1px solid rgba(0,0,0,0.6);\n    box-shadow: inset 0 -4px 8px rgba(0,0,0,0.7);\n    cursor: pointer;\n    z-index: 3;\n    transition: background 0.08s, box-shadow 0.08s;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2), #7a5fb0);\n    box-shadow: 0 0 16px rgba(208,176,255,0.6);\n  }\n\n  .hint {\n    text-align: center;\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 8px;\n  }\n</style>\n</head>\n<body>\n<div class=\"app\">\n  <div class=\"haze\"></div>\n  <svg class=\"arches\" preserveAspectRatio=\"none\" viewBox=\"0 0 880 600\">\n    <g fill=\"none\" stroke=\"rgba(160,190,255,0.10)\" stroke-width=\"1.5\">\n      <path d=\"M120 600 L120 220 Q120 120 220 120 Q320 120 320 220 L320 600\"/>\n      <path d=\"M340 600 L340 180 Q340 70 440 70 Q540 70 540 180 L540 600\"/>\n      <path d=\"M560 600 L560 220 Q560 120 660 120 Q760 120 760 220 L760 600\"/>\n    </g>\n  </svg>\n\n  <div class=\"wrap\">\n    <header>\n      <div class=\"title\">Choral Bank</div>\n      <div class=\"subtitle\">Fully-Poly Ensemble Organ</div>\n    </header>\n\n    <div class=\"field\">\n      <svg id=\"field\" preserveAspectRatio=\"none\" viewBox=\"0 0 880 96\">\n        <defs>\n          <linearGradient id=\"gw\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#d0b0ff\" stop-opacity=\"0.9\"/>\n            <stop offset=\"1\" stop-color=\"#7ab0ff\" stop-opacity=\"0.5\"/>\n          </linearGradient>\n        </defs>\n        <path id=\"w1\" fill=\"none\" stroke=\"url(#gw)\" stroke-width=\"2\"   opacity=\"0.9\"/>\n        <path id=\"w2\" fill=\"none\" stroke=\"#7ab0ff\"  stroke-width=\"1.4\" opacity=\"0.5\"/>\n        <path id=\"w3\" fill=\"none\" stroke=\"#d0b0ff\"  stroke-width=\"1.2\" opacity=\"0.4\"/>\n      </svg>\n    </div>\n\n    <div class=\"sections\" id=\"sections\"></div>\n\n    <div class=\"kb\">\n      <div class=\"keys\" id=\"keys\"></div>\n    </div>\n    <div class=\"hint\">Drag knobs vertically &middot; double-click to reset &middot; play the keys</div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices match assembly.ts) --------------\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.55, group: \"Voice\" },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.22, group: \"Voice\" },\n    { name: \"Brightness\", index: 5, min: 0, max: 1, def: 0.50, group: \"Voice\" },\n    { name: \"Attack\",     index: 2, min: 0, max: 1, def: 0.30, group: \"Swell\" },\n    { name: \"Release\",    index: 3, min: 0, max: 1, def: 0.45, group: \"Swell\" },\n    { name: \"Ensemble\",   index: 4, min: 0, max: 1, def: 0.70, group: \"Ensemble\" },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.55, group: \"Ensemble\" }\n  ];\n\n  var state = {};       // index -> current value\n  var ready = false;\n\n  function pushParam(index, value) {\n    state[index] = value;\n    if (window.vstai && window.vstai.setParam) {\n      try { window.vstai.setParam(index, value); } catch (e) {}\n    }\n  }\n\n  // ---- knob factory --------------------------------------------\n  function makeKnob(p) {\n    var R = 30, CX = 38, CY = 38;\n    var START = 135, SWEEP = 270; // degrees\n\n    var el = document.createElement(\"div\");\n    el.className = \"knob\";\n    el.innerHTML =\n      '<svg width=\"76\" height=\"76\" viewBox=\"0 0 76 76\">' +\n        '<circle class=\"glow\" cx=\"38\" cy=\"38\" r=\"33\" fill=\"none\" stroke=\"' + accentFor(p) + '\" stroke-width=\"6\" opacity=\"0\" filter=\"blur(4px)\"/>' +\n        '<circle cx=\"38\" cy=\"38\" r=\"33\" fill=\"#0c1430\" stroke=\"rgba(160,190,255,0.18)\" stroke-width=\"1\"/>' +\n        '<path class=\"track\" fill=\"none\" stroke=\"rgba(160,190,255,0.16)\" stroke-width=\"4\" stroke-linecap=\"round\"/>' +\n        '<path class=\"ring\" fill=\"none\" stroke=\"' + accentFor(p) + '\" stroke-width=\"4\" stroke-linecap=\"round\"/>' +\n        '<circle cx=\"38\" cy=\"38\" r=\"22\" fill=\"url(#body' + p.index + ')\"/>' +\n        '<defs><radialGradient id=\"body' + p.index + '\" cx=\"0.4\" cy=\"0.3\" r=\"0.8\">' +\n          '<stop offset=\"0\" stop-color=\"#2a3a64\"/><stop offset=\"1\" stop-color=\"#0b1430\"/>' +\n        '</radialGradient></defs>' +\n        '<line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"20\" stroke=\"#eaf2ff\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>' +\n      '</svg>' +\n      '<div class=\"name\">' + p.name + '</div>' +\n      '<div class=\"val\">0</div>';\n\n    var svg = el.querySelector(\"svg\");\n    var ringEl = el.querySelector(\".ring\");\n    var trackEl = el.querySelector(\".track\");\n    var ptrEl = el.querySelector(\".ptr\");\n    var valEl = el.querySelector(\".val\");\n\n    function polar(deg, r) {\n      var a = (deg - 90) * Math.PI / 180;\n      return [CX + r * Math.cos(a), CY + r * Math.sin(a)];\n    }\n    function arc(fromDeg, toDeg, r) {\n      var s = polar(fromDeg, r), e = polar(toDeg, r);\n      var large = (toDeg - fromDeg) > 180 ? 1 : 0;\n      return \"M\" + s[0].toFixed(2) + \" \" + s[1].toFixed(2) +\n             \" A\" + r + \" \" + r + \" 0 \" + large + \" 1 \" + e[0].toFixed(2) + \" \" + e[1].toFixed(2);\n    }\n    trackEl.setAttribute(\"d\", arc(START, START + SWEEP, R));\n\n    function norm(v) { return (v - p.min) / (p.max - p.min); }\n\n    function render(v) {\n      var t = norm(v);\n      var end = START + SWEEP * t;\n      ringEl.setAttribute(\"d\", arc(START, Math.max(START + 0.01, end), R));\n      var pe = polar(end, 16);\n      ptrEl.setAttribute(\"x2\", pe[0].toFixed(2));\n      ptrEl.setAttribute(\"y2\", pe[1].toFixed(2));\n      valEl.textContent = formatVal(p, v);\n    }\n\n    function setVal(v, push) {\n      v = Math.max(p.min, Math.min(p.max, v));\n      render(v);\n      if (push) pushParam(p.index, v);\n      el._value = v;\n    }\n\n    // ---- drag interaction --------------------------------------\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      var g = el.querySelector(\".glow\"); if (g) g.setAttribute(\"opacity\", \"0.9\");\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var range = p.max - p.min;\n      var fine = (e.shiftKey ? 0.25 : 1);\n      setVal(el._value + dy * 0.005 * range * fine, true);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      var g = el.querySelector(\".glow\"); if (g) g.setAttribute(\"opacity\", \"0\");\n    }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"mouseup\", onUp);\n    window.addEventListener(\"touchend\", onUp);\n\n    svg.addEventListener(\"wheel\", function (e) {\n      var range = p.max - p.min;\n      setVal(el._value - Math.sign(e.deltaY) * 0.02 * range, true);\n      e.preventDefault();\n    }, { passive: false });\n\n    svg.addEventListener(\"dblclick\", function () { setVal(p.def, true); });\n\n    el._setVal = setVal;\n    el._param = p;\n    return el;\n  }\n\n  function accentFor(p) {\n    return (p.group === \"Ensemble\") ? \"#d0b0ff\" : \"#7ab0ff\";\n  }\n\n  function formatVal(p, v) {\n    var t = (v - p.min) / (p.max - p.min);\n    return Math.round(t * 100) + \"%\";\n  }\n\n  // ---- build sections ------------------------------------------\n  var knobEls = [];\n  function buildUI() {\n    var sections = document.getElementById(\"sections\");\n    var groups = [\"Voice\", \"Swell\", \"Ensemble\"];\n    groups.forEach(function (gname) {\n      var panel = document.createElement(\"div\");\n      panel.className = \"panel\";\n      var legend = document.createElement(\"div\");\n      legend.className = \"legend\";\n      legend.textContent = gname;\n      panel.appendChild(legend);\n      var row = document.createElement(\"div\");\n      row.className = \"knobrow\";\n      PARAMS.filter(function (p) { return p.group === gname; }).forEach(function (p) {\n        var k = makeKnob(p);\n        row.appendChild(k);\n        knobEls.push(k);\n      });\n      panel.appendChild(row);\n      sections.appendChild(panel);\n    });\n  }\n\n  // ---- on-screen keyboard --------------------------------------\n  function buildKeyboard() {\n    var keys = document.getElementById(\"keys\");\n    var startMidi = 48; // C3\n    var numWhite = 17;  // ~2.5 octaves of white keys\n    var whitePattern = [0, 2, 4, 5, 7, 9, 11];\n    var blackAfter = { 0: 1, 2: 1, 5: 1, 7: 1, 9: 1 }; // semitone offsets that have a black key after\n\n    var whiteW = 100 / numWhite; // percent\n    var wIndex = 0;\n    var midi = startMidi;\n    var whiteMidis = [];\n\n    // figure out white-key midis\n    var m = startMidi;\n    while (whiteMidis.length < numWhite) {\n      var pc = m % 12;\n      if (whitePattern.indexOf(pc) >= 0) whiteMidis.push(m);\n      m++;\n    }\n\n    whiteMidis.forEach(function (mm, i) {\n      var k = document.createElement(\"div\");\n      k.className = \"wkey\";\n      k.style.left = (i * whiteW) + \"%\";\n      k.style.width = whiteW + \"%\";\n      bindKey(k, mm);\n      keys.appendChild(k);\n    });\n\n    // black keys sit between whites that have a sharp\n    whiteMidis.forEach(function (mm, i) {\n      var pc = mm % 12;\n      if (blackAfter[pc] && i < numWhite - 1) {\n        var k = document.createElement(\"div\");\n        k.className = \"bkey\";\n        k.style.left = ((i + 1) * whiteW - whiteW * 0.3) + \"%\";\n        k.style.width = (whiteW * 0.6) + \"%\";\n        bindKey(k, mm + 1);\n        keys.appendChild(k);\n      }\n    });\n  }\n\n  function bindKey(el, midi) {\n    var held = false;\n    function on(e) {\n      if (held) return;\n      held = true;\n      el.classList.add(\"down\");\n      if (window.vstai && window.vstai.noteOn) {\n        try { window.vstai.noteOn(midi, 0.85); } catch (err) {}\n      }\n      e.preventDefault();\n    }\n    function off() {\n      if (!held) return;\n      held = false;\n      el.classList.remove(\"down\");\n      if (window.vstai && window.vstai.noteOff) {\n        try { window.vstai.noteOff(midi); } catch (err) {}\n      }\n    }\n    el.addEventListener(\"mousedown\", on);\n    el.addEventListener(\"mouseenter\", function (e) { if (e.buttons === 1) on(e); });\n    el.addEventListener(\"mouseleave\", off);\n    el.addEventListener(\"mouseup\", off);\n    el.addEventListener(\"touchstart\", on, { passive: false });\n    el.addEventListener(\"touchend\", off);\n    window.addEventListener(\"mouseup\", off);\n  }\n\n  // ---- shimmering wavefield animation --------------------------\n  var raf = 0;\n  function startField() {\n    var w1 = document.getElementById(\"w1\");\n    var w2 = document.getElementById(\"w2\");\n    var w3 = document.getElementById(\"w3\");\n    var W = 880, H = 96, MID = 48, N = 64;\n\n    function wave(el, t, amp, freq, phase, drift) {\n      var d = \"M0 \" + MID;\n      for (var i = 0; i <= N; i++) {\n        var x = (i / N) * W;\n        var ens = (state[4] != null ? state[4] : 0.7);\n        var br = (state[5] != null ? state[5] : 0.5);\n        var a = amp * (0.4 + ens * 0.9);\n        var y = MID\n          + Math.sin(i * freq + t * drift + phase) * a\n          + Math.sin(i * freq * 2.3 + t * drift * 1.4) * a * 0.3 * (0.3 + br);\n        d += \" L\" + x.toFixed(1) + \" \" + y.toFixed(2);\n      }\n      el.setAttribute(\"d\", d);\n    }\n\n    function loop(ts) {\n      var t = ts * 0.001;\n      wave(w1, t, 16, 0.28, 0.0, 0.7);\n      wave(w2, t, 12, 0.36, 1.6, -0.9);\n      wave(w3, t, 9,  0.22, 3.1, 0.5);\n      raf = requestAnimationFrame(loop);\n    }\n    raf = requestAnimationFrame(loop);\n  }\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (document.hidden) {\n      if (raf) cancelAnimationFrame(raf);\n      raf = 0;\n    } else if (!raf) {\n      startField();\n    }\n  });\n\n  // ---- init -----------------------------------------------------\n  function init() {\n    buildUI();\n    buildKeyboard();\n    // set every knob to default and push to engine\n    knobEls.forEach(function (k) { k._setVal(k._param.def, true); });\n    startField();\n    ready = true;\n  }\n\n  function boot() {\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(init);\n    } else {\n      init();\n    }\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CHORAL BANK — a fully-polyphonic organ / string-ensemble synth.\n//  Lineage of the big paraphonic-string / fully-poly organ machines: a\n//  divide-down-style FULL-KEYBOARD source (every note is a stack of\n//  harmonically related partials, like an organ's drawbar/footage mix)\n//  runs through its OWN gentle resonant low-pass with a SLOW ADSR — one\n//  filter per note, so dense chords each breathe independently. The whole\n//  bank is then poured into a rich 4-tap ENSEMBLE chorus (slow quadrature\n//  LFOs modulating short delay lines, hard-panned) that widens the sound\n//  into a huge, shimmering, angelic choir. Pure algorithm, no samples,\n//  no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 16;        // fully-polyphonic — play big stacked chords\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:     i32 = 0;  // 0..1 -> base filter cutoff\nconst P_RESO:       i32 = 1;  // 0..1 -> filter resonance\nconst P_ATTACK:     i32 = 2;  // 0..1 -> seconds (slow swell)\nconst P_RELEASE:    i32 = 3;  // 0..1 -> seconds (slow fade)\nconst P_ENSEMBLE:   i32 = 4;  // 0..1 -> chorus depth / width\nconst P_BRIGHTNESS: i32 = 5;  // 0..1 -> upper-partial / drawbar balance\nconst P_LEVEL:      i32 = 6;  // 0..1 -> output\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice steal\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// four divide-down partial phases per voice (footages 16'/8'/4'/2-2/3')\nconst vPh0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// amplitude ADSR-ish (slow attack / release, full sustain)\nconst vEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\n\n// per-voice 2-pole resonant low-pass state (one filter per note)\nconst vLp0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vLp1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// ---- ensemble (chorus) state: 4 modulated delay lines, stereo -------\nconst ENS_LEN: i32 = 2048;  // ~42 ms @ 48k — plenty for slow ensemble sweep\nconst ensL: StaticArray<f32> = new StaticArray<f32>(ENS_LEN);\nconst ensR: StaticArray<f32> = new StaticArray<f32>(ENS_LEN);\nlet ensWrite: i32 = 0;\nlet ensLfo0: f32 = 0.0;\nlet ensLfo1: f32 = 0.0;\nlet ensLfo2: f32 = 0.0;\nlet ensLfo3: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPh0[v] = 0.0; vPh1[v] = 0.0; vPh2[v] = 0.0; vPh3[v] = 0.0;\n    vEnv[v] = 0.0; vStage[v] = 0;\n    vLp0[v] = 0.0; vLp1[v] = 0.0;\n  }\n  ageCounter = 0;\n  for (let i = 0; i < ENS_LEN; i++) { ensL[i] = 0.0; ensR[i] = 0.0; }\n  ensWrite = 0;\n  ensLfo0 = 0.0; ensLfo1 = 0.25; ensLfo2 = 0.5; ensLfo3 = 0.75;\n\n  params[P_CUTOFF]     = 0.55;\n  params[P_RESO]       = 0.22;\n  params[P_ATTACK]     = 0.30;\n  params[P_RELEASE]    = 0.45;\n  params[P_ENSEMBLE]   = 0.7;\n  params[P_BRIGHTNESS] = 0.5;\n  params[P_LEVEL]      = 0.55;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vStage[slot]  = 1;   // attack\n  // staggered phases so the divide-down stack starts coherent but not pin-sharp\n  vPh0[slot] = 0.0; vPh1[slot] = 0.13; vPh2[slot] = 0.37; vPh3[slot] = 0.61;\n  vLp0[slot] = 0.0; vLp1[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3;  // release\n    }\n  }\n}\n\n// linear-interpolated read from an ensemble delay line, `d` samples back\n@inline function tapL(d: f32): f32 {\n  let rp: f32 = f32(ensWrite) - d;\n  while (rp < 0.0) rp += f32(ENS_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= ENS_LEN) i1 -= ENS_LEN;\n  const fr: f32 = rp - f32(i0);\n  return f32(ensL[i0] + (ensL[i1] - ensL[i0]) * fr);\n}\n@inline function tapR(d: f32): f32 {\n  let rp: f32 = f32(ensWrite) - d;\n  while (rp < 0.0) rp += f32(ENS_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= ENS_LEN) i1 -= ENS_LEN;\n  const fr: f32 = rp - f32(i0);\n  return f32(ensR[i0] + (ensR[i1] - ensR[i0]) * fr);\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const atkS: f32    = 0.005 + clampf(params[P_ATTACK], 0.0, 1.0)  * 3.5;   // up to ~3.5 s slow swell\n  const relS: f32    = 0.02  + clampf(params[P_RELEASE], 0.0, 1.0) * 4.0;   // up to ~4 s fade\n  const ensN: f32    = clampf(params[P_ENSEMBLE], 0.0, 1.0);\n  const brightN: f32 = clampf(params[P_BRIGHTNESS], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // base cutoff in Hz, exponential 120 Hz .. ~12 kHz\n  const baseHz: f32 = 120.0 * f32(Mathf.pow(100.0, cutoffN));\n  // resonance 0..~1.6 (gentle — never screaming; this is a choir, not a synth lead)\n  const reso: f32 = resoN * 1.6;\n\n  // divide-down \"drawbar\" footage gains. Brightness tilts energy from the\n  // fundamental toward the upper partials (2', 1') for an airy choir top.\n  const g0: f32 = 0.95;                         // 16'/fundamental — always present\n  const g1: f32 = 0.85;                          // 8' octave\n  const g2: f32 = 0.30 + brightN * 0.55;         // 4' two-octave\n  const g3: f32 = 0.08 + brightN * 0.60;         // ~2-2/3' fifth/airy top\n  const gNorm: f32 = 1.0 / (g0 + g1 + g2 + g3);  // keep stack peak bounded\n\n  // ensemble LFO rates (slow, slightly incommensurate -> living, never static)\n  const lfoInc0: f32 = 0.082 / sr * TWO_PI;\n  const lfoInc1: f32 = 0.114 / sr * TWO_PI;\n  const lfoInc2: f32 = 0.151 / sr * TWO_PI;\n  const lfoInc3: f32 = 0.197 / sr * TWO_PI;\n\n  // ensemble depth/center in samples (msec * sr) — widens with Ensemble\n  const baseDelay: f32 = 0.012 * sr;             // ~12 ms center\n  const depth: f32 = (0.001 + ensN * 0.006) * sr; // ±1..7 ms sweep\n  const wet: f32 = 0.25 + ensN * 0.55;           // dry/wet of ensemble\n  const dry: f32 = 1.0 - 0.5 * ensN;             // keep some center as it widens\n\n  // headroom: many voices summed -> scale so big chords stay < 1\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let mono: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope (slow attack / sustain / release) ----\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {            // attack\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {     // sustain (organ holds full)\n        env = 1.0;\n      } else if (stg == 3) {     // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- divide-down organ source: stacked octave/fifth partials --\n      const baseInc: f32 = vFreq[v] / sr;\n\n      let p0: f32 = vPh0[v]; p0 += baseInc;        if (p0 >= 1.0) p0 -= 1.0;\n      let p1: f32 = vPh1[v]; p1 += baseInc * 2.0;  if (p1 >= 1.0) p1 -= 1.0;\n      let p2: f32 = vPh2[v]; p2 += baseInc * 4.0;  if (p2 >= 1.0) p2 -= 1.0;\n      let p3: f32 = vPh3[v]; p3 += baseInc * 6.0;  if (p3 >= 1.0) p3 -= 1.0;\n      vPh0[v] = p0; vPh1[v] = p1; vPh2[v] = p2; vPh3[v] = p3;\n\n      // sine partials (smooth, organ-like, no aliasing) summed as a drawbar mix\n      const s0: f32 = f32(Mathf.sin(p0 * TWO_PI));\n      const s1: f32 = f32(Mathf.sin(p1 * TWO_PI));\n      const s2: f32 = f32(Mathf.sin(p2 * TWO_PI));\n      const s3: f32 = f32(Mathf.sin(p3 * TWO_PI));\n      let osc: f32 = (s0 * g0 + s1 * g1 + s2 * g2 + s3 * g3) * gNorm;\n\n      // ---- per-note resonant 2-pole low-pass with slow ADSR --------\n      let fc: f32 = baseHz;\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let lp0: f32 = vLp0[v];\n      let lp1: f32 = vLp1[v];\n      const inp: f32 = osc - reso * lp1;       // resonance feedback from 2nd stage\n      lp0 += g * (inp - lp0);\n      lp1 += g * (lp0 - lp1);\n      vLp0[v] = lp0;\n      vLp1[v] = lp1;\n\n      mono += lp1 * env * vVel[v];\n    }\n\n    let sig: f32 = mono * voiceScale;\n\n    // ---- write into ensemble delay lines (same mono source both sides)\n    ensL[ensWrite] = sig;\n    ensR[ensWrite] = sig;\n\n    // ---- 4 quadrature-ish modulated taps, hard-spread for width -----\n    const m0: f32 = f32(Mathf.sin(ensLfo0));\n    const m1: f32 = f32(Mathf.sin(ensLfo1));\n    const m2: f32 = f32(Mathf.sin(ensLfo2));\n    const m3: f32 = f32(Mathf.sin(ensLfo3));\n\n    const d0: f32 = baseDelay + depth * m0;\n    const d1: f32 = baseDelay + depth * m1;\n    const d2: f32 = baseDelay + depth * m2;\n    const d3: f32 = baseDelay + depth * m3;\n\n    // left favours taps 0/2, right favours 1/3 -> wide shimmering choir\n    const wetL: f32 = (tapL(d0) * 0.8 + tapL(d2) * 0.6 + tapR(d1) * 0.3);\n    const wetR: f32 = (tapR(d1) * 0.8 + tapR(d3) * 0.6 + tapL(d2) * 0.3);\n\n    let outL: f32 = sig * dry + wetL * wet * 0.7;\n    let outR: f32 = sig * dry + wetR * wet * 0.7;\n\n    // gentle soft saturation for choral glue, then output level\n    outL = f32(Mathf.tanh(outL * 3.6)) * level;\n    outR = f32(Mathf.tanh(outR * 3.6)) * level;\n\n    outBuf[f] = outL;\n    outBuf[MAX_FRAMES + f] = outR;\n\n    // advance ensemble write head + LFOs\n    ensWrite++; if (ensWrite >= ENS_LEN) ensWrite = 0;\n    ensLfo0 += lfoInc0; if (ensLfo0 >= TWO_PI) ensLfo0 -= TWO_PI;\n    ensLfo1 += lfoInc1; if (ensLfo1 >= TWO_PI) ensLfo1 -= TWO_PI;\n    ensLfo2 += lfoInc2; if (ensLfo2 >= TWO_PI) ensLfo2 -= TWO_PI;\n    ensLfo3 += lfoInc3; if (ensLfo3 >= TWO_PI) ensLfo3 -= TWO_PI;\n  }\n}\n",
  "publishedAt": 1751000117000
}