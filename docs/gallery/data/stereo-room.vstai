{
  "format": 1,
  "name": "Stereo Room",
  "isInstrument": false,
  "explanation": "An early-digital stereo room reverb. A panned multitap network throws out tight, defined early reflections off the room walls, feeding a Schroeder allpass diffuser into a short-to-medium feedback delay network for a controlled diffuse tail. Gentle damping plus subtle feedback quantisation give the slightly grainy vintage-digital character. Controls: Mix, Size, Decay, Diffusion and Pre-Delay. Mix at 0 is the dry signal.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Size",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Diffusion",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Pre-Delay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Stereo Room</title>\n<style>\n  :root {\n    --accent: #7ad0c0;\n    --accent2: #a0e0d0;\n    --bg0: #0a1413;\n    --bg1: #0f1f1d;\n    --panel: #14201f;\n    --panel-hi: #1c2c2a;\n    --ink: #cfe9e3;\n    --ink-dim: #6f8a85;\n    --line: #233834;\n    --display-bg: #05100d;\n    --display-glow: #7ad0c0;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background:\n      radial-gradient(120% 80% at 50% -10%, #16302c 0%, var(--bg0) 55%, #060d0c 100%);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    -webkit-font-smoothing: antialiased;\n    min-height: 100%;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 18px 14px 26px;\n  }\n\n  .unit {\n    width: 100%;\n    max-width: 720px;\n    background:\n      linear-gradient(180deg, #1a2b29 0%, var(--panel) 18%, #101b1a 100%);\n    border: 1px solid #2a423e;\n    border-radius: 14px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.05) inset,\n      0 -2px 0 rgba(0,0,0,0.45) inset,\n      0 22px 50px rgba(0,0,0,0.6);\n    padding: 16px 18px 20px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* brushed-metal sheen */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      repeating-linear-gradient(90deg,\n        rgba(255,255,255,0.018) 0 2px,\n        rgba(0,0,0,0.02) 2px 4px);\n    pointer-events: none;\n    opacity: 0.5;\n  }\n\n  /* ---------------- header / rack ears ---------------- */\n  .head {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .screw {\n    width: 14px; height: 14px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #3a524d, #0c1413 70%);\n    box-shadow: 0 1px 1px rgba(0,0,0,0.6), 0 0 0 1px #243733 inset;\n    position: relative;\n    flex: 0 0 auto;\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute;\n    inset: 4px;\n    border-top: 1.5px solid rgba(0,0,0,0.55);\n    transform: rotate(35deg);\n  }\n\n  .title-block { flex: 1 1 auto; }\n  .brand {\n    font-size: 10px;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-bottom: 3px;\n  }\n  .model {\n    font-size: 22px;\n    font-weight: 700;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: var(--ink);\n    text-shadow: 0 0 14px rgba(122,208,192,0.25);\n  }\n  .model b { color: var(--accent); font-weight: 700; }\n\n  .power {\n    display: flex;\n    align-items: center;\n    gap: 7px;\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    color: var(--ink-dim);\n    text-transform: uppercase;\n  }\n  .led {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 9px 2px rgba(122,208,192,0.8);\n    animation: pulse 3.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 0.85; }\n    50% { opacity: 0.35; }\n  }\n\n  /* ---------------- display (room view) ---------------- */\n  .display {\n    position: relative;\n    z-index: 2;\n    background:\n      radial-gradient(130% 120% at 50% 0%, #0a1f1a 0%, var(--display-bg) 70%);\n    border: 1px solid #06231c;\n    border-radius: 9px;\n    box-shadow:\n      0 0 0 1px rgba(0,0,0,0.6),\n      0 6px 18px rgba(0,0,0,0.55) inset,\n      0 0 26px rgba(122,208,192,0.06) inset;\n    padding: 12px;\n    margin-bottom: 16px;\n    overflow: hidden;\n  }\n\n  /* scanline / vintage CRT texture */\n  .display::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: repeating-linear-gradient(\n      0deg,\n      rgba(0,0,0,0) 0 2px,\n      rgba(0,0,0,0.16) 2px 3px);\n    pointer-events: none;\n    mix-blend-mode: multiply;\n  }\n\n  .display-top {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n    margin-bottom: 8px;\n    font-size: 9px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--accent);\n    text-shadow: 0 0 7px rgba(122,208,192,0.6);\n  }\n  .display-top .rt {\n    font-variant-numeric: tabular-nums;\n    color: var(--accent2);\n  }\n\n  .room-wrap {\n    position: relative;\n    width: 100%;\n    aspect-ratio: 16 / 7;\n    border-radius: 4px;\n    overflow: hidden;\n    background: linear-gradient(180deg, #06140f, #04100c);\n  }\n  .room-svg { display: block; width: 100%; height: 100%; }\n\n  /* ---------------- controls ---------------- */\n  .panel {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 10px;\n  }\n  @media (max-width: 560px) {\n    .panel { grid-template-columns: repeat(3, 1fr); }\n  }\n\n  .cell {\n    background: linear-gradient(180deg, var(--panel-hi), #0f1817);\n    border: 1px solid var(--line);\n    border-radius: 11px;\n    padding: 12px 8px 11px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.04) inset,\n      0 -3px 6px rgba(0,0,0,0.3) inset;\n  }\n\n  .knob {\n    position: relative;\n    width: 76px; height: 76px;\n    cursor: ns-resize;\n    touch-action: none;\n    -webkit-user-select: none;\n    user-select: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; overflow: visible; }\n  .knob .body-grad { transition: filter 0.18s ease; }\n  .knob.active .body-grad,\n  .knob:hover .body-grad { filter: drop-shadow(0 0 8px rgba(122,208,192,0.5)); }\n\n  .label {\n    font-size: 9.5px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .value {\n    font-size: 12px;\n    font-weight: 600;\n    letter-spacing: 0.04em;\n    color: var(--accent2);\n    font-variant-numeric: tabular-nums;\n    text-shadow: 0 0 8px rgba(122,208,192,0.3);\n  }\n\n  .foot {\n    position: relative;\n    z-index: 2;\n    margin-top: 14px;\n    display: flex;\n    justify-content: space-between;\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .foot .digital {\n    color: var(--accent);\n    text-shadow: 0 0 6px rgba(122,208,192,0.4);\n  }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"head\">\n      <div class=\"screw\"></div>\n      <div class=\"title-block\">\n        <div class=\"brand\">Vibe&nbsp;&middot;&nbsp;Digital&nbsp;Reverb&nbsp;Processor</div>\n        <div class=\"model\"><b>Stereo</b> Room</div>\n      </div>\n      <div class=\"power\">\n        <span>On</span>\n        <span class=\"led\"></span>\n      </div>\n      <div class=\"screw\"></div>\n    </div>\n\n    <div class=\"display\">\n      <div class=\"display-top\">\n        <span>Room&nbsp;&middot;&nbsp;Top&nbsp;View</span>\n        <span class=\"rt\" id=\"rt\">RT 1.20 s</span>\n      </div>\n      <div class=\"room-wrap\">\n        <svg class=\"room-svg\" id=\"roomSvg\" viewBox=\"0 0 320 140\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"floor\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#0a221b\"/>\n              <stop offset=\"1\" stop-color=\"#040f0c\"/>\n            </linearGradient>\n            <radialGradient id=\"src\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n              <stop offset=\"0\" stop-color=\"#dffff6\"/>\n              <stop offset=\"0.5\" stop-color=\"#7ad0c0\"/>\n              <stop offset=\"1\" stop-color=\"#7ad0c0\" stop-opacity=\"0\"/>\n            </radialGradient>\n          </defs>\n\n          <!-- floor -->\n          <rect x=\"0\" y=\"0\" width=\"320\" height=\"140\" fill=\"url(#floor)\"/>\n\n          <!-- floor grid -->\n          <g stroke=\"#16352c\" stroke-width=\"0.5\" id=\"grid\"></g>\n\n          <!-- room walls (the box). inset rect, scales with Size -->\n          <rect id=\"walls\" x=\"26\" y=\"16\" width=\"268\" height=\"108\" rx=\"2\"\n                fill=\"none\" stroke=\"#3f7d70\" stroke-width=\"1.4\"\n                style=\"filter: drop-shadow(0 0 4px rgba(122,208,192,0.35));\"/>\n\n          <!-- early-reflection rays -->\n          <g id=\"rays\" stroke-linecap=\"round\"></g>\n\n          <!-- wall impact sparks -->\n          <g id=\"sparks\"></g>\n\n          <!-- source + two mic dots -->\n          <circle id=\"srcGlow\" cx=\"160\" cy=\"70\" r=\"13\" fill=\"url(#src)\"/>\n          <circle id=\"srcDot\" cx=\"160\" cy=\"70\" r=\"3.2\" fill=\"#eafff9\"/>\n\n          <circle class=\"mic\" cx=\"120\" cy=\"70\" r=\"2.6\" fill=\"#a0e0d0\" opacity=\"0.9\"/>\n          <circle class=\"mic\" cx=\"200\" cy=\"70\" r=\"2.6\" fill=\"#a0e0d0\" opacity=\"0.9\"/>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"panel\" id=\"panel\"></div>\n\n    <div class=\"foot\">\n      <span>Multitap&nbsp;ER&nbsp;+&nbsp;Diffuse&nbsp;Tail</span>\n      <span class=\"digital\">16&nbsp;Bit&nbsp;&middot;&nbsp;Stereo</span>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model -------------------------------------------------\n  var PARAMS = [\n    { name: \"Mix\",       index: 0, min: 0, max: 1, def: 0.35, unit: \"%\",  fmt: pct },\n    { name: \"Size\",      index: 1, min: 0, max: 1, def: 0.50, unit: \"\",   fmt: sizeFmt },\n    { name: \"Decay\",     index: 2, min: 0, max: 1, def: 0.50, unit: \"s\",  fmt: decayFmt },\n    { name: \"Diffusion\", index: 3, min: 0, max: 1, def: 0.70, unit: \"%\",  fmt: pct },\n    { name: \"Pre-Delay\", index: 4, min: 0, max: 1, def: 0.10, unit: \"ms\", fmt: preFmt }\n  ];\n\n  var values = {};   // index -> normalized 0..1\n\n  function pct(v)      { return Math.round(v * 100) + \" %\"; }\n  function sizeFmt(v)  {\n    var labels = [\"Booth\", \"Small\", \"Medium\", \"Large\", \"Hall\"];\n    return labels[Math.min(4, Math.floor(v * 4.999))];\n  }\n  function decayFmt(v) { return (0.25 + v * 2.55).toFixed(2) + \" s\"; }\n  function preFmt(v)   { return Math.round(v * 120) + \" ms\"; }\n\n  // ---- host wiring -----------------------------------------------------\n  function pushParam(p) {\n    var v = values[p.index];\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(p.index, p.min + v * (p.max - p.min));\n    }\n  }\n\n  // ---- build knobs -----------------------------------------------------\n  var panel = document.getElementById(\"panel\");\n  var knobEls = {};\n\n  function buildKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n\n    var ns = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(ns, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // defs (gradient body)\n    var defs = document.createElementNS(ns, \"defs\");\n    var gid = \"kbody\" + p.index;\n    var lg = document.createElementNS(ns, \"radialGradient\");\n    lg.setAttribute(\"id\", gid);\n    lg.setAttribute(\"cx\", \"38%\"); lg.setAttribute(\"cy\", \"32%\"); lg.setAttribute(\"r\", \"75%\");\n    [[\"0\", \"#2b3f3c\"], [\"0.55\", \"#1a2725\"], [\"1\", \"#0c1413\"]].forEach(function (s) {\n      var st = document.createElementNS(ns, \"stop\");\n      st.setAttribute(\"offset\", s[0]); st.setAttribute(\"stop-color\", s[1]);\n      lg.appendChild(st);\n    });\n    defs.appendChild(lg);\n    svg.appendChild(defs);\n\n    // track arc (background)\n    var track = document.createElementNS(ns, \"path\");\n    track.setAttribute(\"d\", arcPath(50, 52, 38, -135, 135));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"#16302b\");\n    track.setAttribute(\"stroke-width\", \"5\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(track);\n\n    // value arc\n    var arc = document.createElementNS(ns, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"var(--accent)\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    arc.style.filter = \"drop-shadow(0 0 4px rgba(122,208,192,0.7))\";\n    svg.appendChild(arc);\n\n    // body\n    var body = document.createElementNS(ns, \"circle\");\n    body.setAttribute(\"class\", \"body-grad\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"52\");\n    body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"url(#\" + gid + \")\");\n    body.setAttribute(\"stroke\", \"#33514b\");\n    body.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(body);\n\n    // pointer notch\n    var notch = document.createElementNS(ns, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"52\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"30\");\n    notch.setAttribute(\"stroke\", \"var(--accent2)\");\n    notch.setAttribute(\"stroke-width\", \"2.6\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    knob.appendChild(svg);\n    cell.appendChild(knob);\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n    cell.appendChild(label);\n\n    var val = document.createElement(\"div\");\n    val.className = \"value\";\n    cell.appendChild(val);\n\n    panel.appendChild(cell);\n\n    knobEls[p.index] = { knob: knob, arc: arc, notch: notch, val: val };\n    attachDrag(knob, p);\n    render(p);\n  }\n\n  function arcPath(cx, cy, r, a0deg, a1deg) {\n    var a0 = (a0deg - 90) * Math.PI / 180;\n    var a1 = (a1deg - 90) * Math.PI / 180;\n    var x0 = cx + r * Math.cos(a0), y0 = cy + r * Math.sin(a0);\n    var x1 = cx + r * Math.cos(a1), y1 = cy + r * Math.sin(a1);\n    var large = (a1deg - a0deg) > 180 ? 1 : 0;\n    return \"M \" + x0.toFixed(2) + \" \" + y0.toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n           x1.toFixed(2) + \" \" + y1.toFixed(2);\n  }\n\n  function render(p) {\n    var v = values[p.index];\n    var el = knobEls[p.index];\n    var ang = -135 + v * 270;\n    // value arc\n    if (v <= 0.0001) {\n      el.arc.setAttribute(\"d\", \"\");\n    } else {\n      el.arc.setAttribute(\"d\", arcPath(50, 52, 38, -135, ang));\n    }\n    // notch rotation\n    el.notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 52)\");\n    el.val.textContent = p.fmt(v);\n  }\n\n  // ---- drag interaction ------------------------------------------------\n  function attachDrag(knob, p) {\n    var dragging = false, startY = 0, startV = 0;\n\n    function onDown(e) {\n      dragging = true;\n      knob.classList.add(\"active\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = values[p.index];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = startY - y;\n      var fine = e.shiftKey ? 0.25 : 1;\n      var nv = startV + (dy / 180) * fine;\n      values[p.index] = clamp01(nv);\n      render(p); pushParam(p); updateRoom();\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      knob.classList.remove(\"active\");\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    knob.addEventListener(\"dblclick\", function () {\n      values[p.index] = (p.def - p.min) / (p.max - p.min);\n      render(p); pushParam(p); updateRoom();\n    });\n    knob.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var step = (e.deltaY < 0 ? 1 : -1) * (e.shiftKey ? 0.005 : 0.02);\n      values[p.index] = clamp01(values[p.index] + step);\n      render(p); pushParam(p); updateRoom();\n    }, { passive: false });\n  }\n\n  function clamp01(x) { return x < 0 ? 0 : (x > 1 ? 1 : x); }\n\n  // ---- room visualization ----------------------------------------------\n  var SVG_NS = \"http://www.w3.org/2000/svg\";\n  var raysG = document.getElementById(\"rays\");\n  var sparksG = document.getElementById(\"sparks\");\n  var walls = document.getElementById(\"walls\");\n  var gridG = document.getElementById(\"grid\");\n  var rtEl = document.getElementById(\"rt\");\n\n  // floor grid lines (static)\n  (function makeGrid() {\n    for (var x = 0; x <= 320; x += 32) {\n      var l = document.createElementNS(SVG_NS, \"line\");\n      l.setAttribute(\"x1\", x); l.setAttribute(\"y1\", 0);\n      l.setAttribute(\"x2\", x); l.setAttribute(\"y2\", 140);\n      gridG.appendChild(l);\n    }\n    for (var y = 0; y <= 140; y += 28) {\n      var h = document.createElementNS(SVG_NS, \"line\");\n      h.setAttribute(\"x1\", 0); h.setAttribute(\"y1\", y);\n      h.setAttribute(\"x2\", 320); h.setAttribute(\"y2\", y);\n      gridG.appendChild(h);\n    }\n  })();\n\n  // 7 reflection rays (one per \"wall bounce direction\")\n  var RAY_DIRS = [];\n  var NUM_RAYS = 9;\n  for (var i = 0; i < NUM_RAYS; i++) {\n    RAY_DIRS.push((i / NUM_RAYS) * Math.PI * 2 + 0.18);\n  }\n  var rays = [];\n  RAY_DIRS.forEach(function () {\n    var ln = document.createElementNS(SVG_NS, \"line\");\n    ln.setAttribute(\"stroke\", \"var(--accent)\");\n    ln.setAttribute(\"stroke-width\", \"1\");\n    raysG.appendChild(ln);\n    rays.push(ln);\n  });\n\n  // current room rect (animated toward target by Size)\n  var room = { x: 26, y: 16, w: 268, h: 108 };\n\n  function updateRoom() {\n    var size = values[1];      // 0..1\n    var pad = 70 - size * 55;  // smaller pad => bigger room\n    room.tx = pad;\n    room.ty = pad * 0.42 + 8;\n    room.tw = 320 - 2 * (room.tx);\n    room.th = 140 - 2 * (room.ty);\n\n    // RT readout from Decay (mirrors decayFmt)\n    rtEl.textContent = \"RT \" + (0.25 + values[2] * 2.55).toFixed(2) + \" s\";\n  }\n  updateRoom();\n  // initialise current to target\n  room.x = room.tx; room.y = room.ty; room.w = room.tw; room.h = room.th;\n\n  var t0 = performance.now();\n  var sparkPool = [];\n\n  function frame(now) {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    var t = (now - t0) / 1000;\n\n    // ease room geometry toward target\n    room.x += (room.tx - room.x) * 0.12;\n    room.y += (room.ty - room.y) * 0.12;\n    room.w += (room.tw - room.w) * 0.12;\n    room.h += (room.th - room.h) * 0.12;\n    walls.setAttribute(\"x\", room.x.toFixed(1));\n    walls.setAttribute(\"y\", room.y.toFixed(1));\n    walls.setAttribute(\"width\", room.w.toFixed(1));\n    walls.setAttribute(\"height\", room.h.toFixed(1));\n\n    var cx = 160, cy = 70;\n    var mix = values[0];\n    var decay = values[2];\n    var diff = values[3];\n    var pre = values[4];\n\n    // speed of rays depends inversely on Size (bigger room = slower bounce);\n    // length/brightness on Mix + Decay; spread on Diffusion.\n    var speed = 26 + (1 - values[1]) * 34;\n    var maxReach = Math.min(room.w, room.h) * 0.5;\n\n    for (var k = 0; k < rays.length; k++) {\n      var phase = (t * speed * (0.6 + (k % 3) * 0.2) + k * 17) % 100 / 100;\n      // pre-delay shifts the start outward (rays appear later)\n      var startR = pre * 18;\n      var reach = startR + phase * maxReach;\n      var jitter = (diff * 0.5) * Math.sin(t * 3 + k * 2.1);\n      var dir = RAY_DIRS[k] + jitter;\n\n      var x1 = cx + Math.cos(dir) * startR;\n      var y1 = cy + Math.sin(dir) * startR * 0.6;\n      var x2 = cx + Math.cos(dir) * reach;\n      var y2 = cy + Math.sin(dir) * reach * 0.6;\n\n      // clamp endpoint to inside the walls\n      var halfW = room.w / 2 - 4, halfH = room.h / 2 - 4;\n      var dx = x2 - cx, dy = y2 - cy;\n      if (Math.abs(dx) > halfW) { var s = halfW / Math.abs(dx); dx *= s; dy *= s; }\n      if (Math.abs(dy) > halfH) { var s2 = halfH / Math.abs(dy); dx *= s2; dy *= s2; }\n      x2 = cx + dx; y2 = cy + dy;\n\n      rays[k].setAttribute(\"x1\", x1.toFixed(1));\n      rays[k].setAttribute(\"y1\", y1.toFixed(1));\n      rays[k].setAttribute(\"x2\", x2.toFixed(1));\n      rays[k].setAttribute(\"y2\", y2.toFixed(1));\n      // fade with travel; brighter at higher Mix, longer trail at higher Decay\n      var alpha = (1 - phase) * (0.25 + mix * 0.7) * (0.5 + decay * 0.5);\n      rays[k].setAttribute(\"stroke-opacity\", alpha.toFixed(3));\n      rays[k].setAttribute(\"stroke-width\", (0.6 + diff * 1.4).toFixed(2));\n    }\n\n    // source glow breathes with Mix\n    var glow = document.getElementById(\"srcGlow\");\n    glow.setAttribute(\"r\", (8 + mix * 8 + Math.sin(t * 4) * 1.5).toFixed(1));\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- init ------------------------------------------------------------\n  function init() {\n    PARAMS.forEach(function (p) {\n      values[p.index] = (p.def - p.min) / (p.max - p.min);\n      buildKnob(p);\n      pushParam(p);\n    });\n    updateRoom();\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STEREO ROOM — early-digital stereo room reverb (effect)\n//  Models the tight, defined character of an early-1980s digital room\n//  box: a stereo MULTITAP early-reflection network (discrete, panned\n//  reflections off the room walls) feeding a short-to-medium DIFFUSE\n//  tail built from a Schroeder allpass diffuser into a small feedback\n//  delay network. A gentle damping low-pass plus subtle quantisation\n//  on the feedback path give the slightly grainy vintage-digital grain.\n//\n//  Params: Mix, Size, Decay, Diffusion, Pre-Delay.\n//  Mix = 0 is bit-exact dry. Output is bounded well under full scale.\n//  Pure algorithm, no samples, no imports, no alloc in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\n\n// --- parameter indices ---\nconst P_MIX:  i32 = 0;  // 0..1 dry/wet  (0 = bit-exact dry)\nconst P_SIZE: i32 = 1;  // 0..1 small room -> large room (scales all delays)\nconst P_DECAY:i32 = 2;  // 0..1 tail decay time (feedback amount)\nconst P_DIFF: i32 = 3;  // 0..1 diffusion (allpass coefficient + ER density)\nconst P_PRE:  i32 = 4;  // 0..1 pre-delay 0..120 ms\n\n// --------------------------------------------------------------------\n//  Buffer sizes. Everything is sized for the LARGEST room and longest\n//  pre-delay at 48k-ish rates, then read with a scaled tap so Size can\n//  shrink the geometry without reallocating. All pow-of-two for cheap\n//  masking where convenient, but plain modulo is fine and clearer.\n// --------------------------------------------------------------------\n\n// pre-delay line: up to ~150 ms @ 48k\nconst PRE_LEN: i32 = 8192;            // 8192 / 48000 ~= 170 ms\nconst preL: StaticArray<f32> = new StaticArray<f32>(PRE_LEN);\nconst preR: StaticArray<f32> = new StaticArray<f32>(PRE_LEN);\nlet preW: i32 = 0;\n\n// early-reflection multitap line (post pre-delay). ~80 ms max geometry.\nconst ER_LEN: i32 = 4096;             // 4096 / 48000 ~= 85 ms\nconst erL: StaticArray<f32> = new StaticArray<f32>(ER_LEN);\nconst erR: StaticArray<f32> = new StaticArray<f32>(ER_LEN);\nlet erW: i32 = 0;\n\n// 8 multitap reflections per channel. Base tap times (samples @ 48k) and\n// gains form an asymmetric stereo pattern off the room walls.\nconst ER_TAPS: i32 = 8;\nconst tapL:  StaticArray<f32> = new StaticArray<f32>(ER_TAPS); // base delay (samples)\nconst tapR:  StaticArray<f32> = new StaticArray<f32>(ER_TAPS);\nconst tapGL: StaticArray<f32> = new StaticArray<f32>(ER_TAPS);\nconst tapGR: StaticArray<f32> = new StaticArray<f32>(ER_TAPS);\n\n// --- diffuser: 2 series allpasses per channel ---\nconst AP1_LEN: i32 = 1024;\nconst AP2_LEN: i32 = 1024;\nconst ap1L: StaticArray<f32> = new StaticArray<f32>(AP1_LEN);\nconst ap1R: StaticArray<f32> = new StaticArray<f32>(AP1_LEN);\nconst ap2L: StaticArray<f32> = new StaticArray<f32>(AP2_LEN);\nconst ap2R: StaticArray<f32> = new StaticArray<f32>(AP2_LEN);\nlet ap1W: i32 = 0;\nlet ap2W: i32 = 0;\nconst AP1_BASE: i32 = 142;            // samples @ 48k\nconst AP2_BASE: i32 = 379;\nconst AP1_OFF:  i32 = 23;             // small L/R offset for width\nconst AP2_OFF:  i32 = 41;\n\n// --- feedback delay network: 4 comb-style delay lines ---\nconst FDN_LEN: i32 = 4096;\nconst d0: StaticArray<f32> = new StaticArray<f32>(FDN_LEN);\nconst d1: StaticArray<f32> = new StaticArray<f32>(FDN_LEN);\nconst d2: StaticArray<f32> = new StaticArray<f32>(FDN_LEN);\nconst d3: StaticArray<f32> = new StaticArray<f32>(FDN_LEN);\nlet dW0: i32 = 0;\nlet dW1: i32 = 0;\nlet dW2: i32 = 0;\nlet dW3: i32 = 0;\n// base delay lengths (samples @ 48k) — mutually prime-ish for density\nconst FDN_B0: i32 = 1116;\nconst FDN_B1: i32 = 1356;\nconst FDN_B2: i32 = 1722;\nconst FDN_B3: i32 = 1991;\n\n// per-line damping low-pass state\nlet damp0: f32 = 0.0;\nlet damp1: f32 = 0.0;\nlet damp2: f32 = 0.0;\nlet damp3: f32 = 0.0;\n\n// --------------------------------------------------------------------\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  // clear all state\n  for (let i = 0; i < PRE_LEN; i++) { preL[i] = 0.0; preR[i] = 0.0; }\n  for (let i = 0; i < ER_LEN;  i++) { erL[i] = 0.0;  erR[i] = 0.0;  }\n  for (let i = 0; i < AP1_LEN; i++) { ap1L[i] = 0.0; ap1R[i] = 0.0; }\n  for (let i = 0; i < AP2_LEN; i++) { ap2L[i] = 0.0; ap2R[i] = 0.0; }\n  for (let i = 0; i < FDN_LEN; i++) { d0[i] = 0.0; d1[i] = 0.0; d2[i] = 0.0; d3[i] = 0.0; }\n  preW = 0; erW = 0; ap1W = 0; ap2W = 0;\n  dW0 = 0; dW1 = 0; dW2 = 0; dW3 = 0;\n  damp0 = 0.0; damp1 = 0.0; damp2 = 0.0; damp3 = 0.0;\n\n  // multitap reflection pattern (asymmetric L/R for a real stereo image)\n  // delays in samples @ 48k, gains decaying with arrival time\n  tapL[0] = 71.0;   tapGL[0] = 0.84;\n  tapL[1] = 197.0;  tapGL[1] = 0.72;\n  tapL[2] = 421.0;  tapGL[2] = 0.61;\n  tapL[3] = 683.0;  tapGL[3] = 0.52;\n  tapL[4] = 1009.0; tapGL[4] = 0.43;\n  tapL[5] = 1453.0; tapGL[5] = 0.35;\n  tapL[6] = 1979.0; tapGL[6] = 0.28;\n  tapL[7] = 2557.0; tapGL[7] = 0.22;\n\n  tapR[0] = 113.0;  tapGR[0] = 0.80;\n  tapR[1] = 251.0;  tapGR[1] = 0.69;\n  tapR[2] = 487.0;  tapGR[2] = 0.58;\n  tapR[3] = 769.0;  tapGR[3] = 0.49;\n  tapR[4] = 1129.0; tapGR[4] = 0.41;\n  tapR[5] = 1567.0; tapGR[5] = 0.33;\n  tapR[6] = 2113.0; tapGR[6] = 0.26;\n  tapR[7] = 2729.0; tapGR[7] = 0.20;\n\n  params[P_MIX]   = 0.35;\n  params[P_SIZE]  = 0.5;\n  params[P_DECAY] = 0.5;\n  params[P_DIFF]  = 0.7;\n  params[P_PRE]   = 0.1;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// read a delay line at an integer sample offset behind the write head\n@inline function tap(buf: StaticArray<f32>, len: i32, w: i32, d: i32): f32 {\n  let r: i32 = w - d;\n  while (r < 0) r += len;\n  return buf[r];\n}\n\nexport function process(n: i32): void {\n  const mix: f32  = clampf(params[P_MIX],  0.0, 1.0);\n  const size: f32 = clampf(params[P_SIZE], 0.0, 1.0);\n  const decay: f32= clampf(params[P_DECAY],0.0, 1.0);\n  const diff: f32 = clampf(params[P_DIFF], 0.0, 1.0);\n  const preN: f32 = clampf(params[P_PRE],  0.0, 1.0);\n\n  // sample-rate scale relative to the 48k design\n  const srScale: f32 = sampleRate / 48000.0;\n\n  // pre-delay 0..120 ms\n  let preSamp: i32 = i32(preN * 0.120 * sampleRate);\n  if (preSamp < 0) preSamp = 0;\n  if (preSamp > PRE_LEN - 1) preSamp = PRE_LEN - 1;\n\n  // Size scales the room geometry: 0.45x (small) .. 1.25x (large)\n  const geo: f32 = (0.45 + size * 0.80) * srScale;\n\n  // FDN feedback from Decay: short-to-medium room (never a long hall)\n  // 0.0 -> ~0.45 (very short), 1.0 -> ~0.86 (medium tail)\n  const fb: f32 = 0.45 + decay * 0.41;\n\n  // diffusion controls allpass coefficient and ER tail blend\n  const apC: f32 = 0.45 + diff * 0.30;        // 0.45 .. 0.75\n\n  // damping: a touch more high-cut on bigger / longer settings for realism\n  const dampC: f32 = clampf(0.18 + (1.0 - decay) * 0.25, 0.0, 0.9);\n\n  // scaled FDN line lengths (clamped into buffer)\n  let l0: i32 = i32(f32(FDN_B0) * geo); if (l0 < 1) l0 = 1; if (l0 > FDN_LEN - 1) l0 = FDN_LEN - 1;\n  let l1: i32 = i32(f32(FDN_B1) * geo); if (l1 < 1) l1 = 1; if (l1 > FDN_LEN - 1) l1 = FDN_LEN - 1;\n  let l2: i32 = i32(f32(FDN_B2) * geo); if (l2 < 1) l2 = 1; if (l2 > FDN_LEN - 1) l2 = FDN_LEN - 1;\n  let l3: i32 = i32(f32(FDN_B3) * geo); if (l3 < 1) l3 = 1; if (l3 > FDN_LEN - 1) l3 = FDN_LEN - 1;\n\n  // scaled allpass lengths\n  let a1l: i32 = i32(f32(AP1_BASE) * geo);            if (a1l < 1) a1l = 1; if (a1l > AP1_LEN - 1) a1l = AP1_LEN - 1;\n  let a1r: i32 = i32(f32(AP1_BASE + AP1_OFF) * geo);  if (a1r < 1) a1r = 1; if (a1r > AP1_LEN - 1) a1r = AP1_LEN - 1;\n  let a2l: i32 = i32(f32(AP2_BASE) * geo);            if (a2l < 1) a2l = 1; if (a2l > AP2_LEN - 1) a2l = AP2_LEN - 1;\n  let a2r: i32 = i32(f32(AP2_BASE + AP2_OFF) * geo);  if (a2r < 1) a2r = 1; if (a2r > AP2_LEN - 1) a2r = AP2_LEN - 1;\n\n  // wet output trim so the tail sits well under full scale\n  const wetTrim: f32 = 0.32;\n\n  const baseR: i32 = MAX_FRAMES;\n\n  for (let f = 0; f < n; f++) {\n    const dryL: f32 = inBuf[f];\n    const dryR: f32 = channels > 1 ? inBuf[baseR + f] : dryL;\n\n    // --- pre-delay ---\n    preL[preW] = dryL;\n    preR[preW] = dryR;\n    const pL: f32 = tap(preL, PRE_LEN, preW, preSamp);\n    const pR: f32 = tap(preR, PRE_LEN, preW, preSamp);\n    preW++; if (preW >= PRE_LEN) preW = 0;\n\n    // --- write into ER line, gather multitap early reflections ---\n    erL[erW] = pL;\n    erR[erW] = pR;\n    let eL: f32 = 0.0;\n    let eR: f32 = 0.0;\n    for (let t = 0; t < ER_TAPS; t++) {\n      let dl: i32 = i32(tapL[t] * geo); if (dl > ER_LEN - 1) dl = ER_LEN - 1;\n      let dr: i32 = i32(tapR[t] * geo); if (dr > ER_LEN - 1) dr = ER_LEN - 1;\n      // diffusion thins/cross-feeds the later taps for density control\n      const g: f32 = 0.4 + diff * 0.6;\n      eL += tap(erL, ER_LEN, erW, dl) * tapGL[t] * g;\n      eR += tap(erR, ER_LEN, erW, dr) * tapGR[t] * g;\n    }\n    erW++; if (erW >= ER_LEN) erW = 0;\n    eL *= 0.5;\n    eR *= 0.5;\n\n    // --- diffuser: 2 series allpasses per channel (feeds the tail) ---\n    const inDiffL: f32 = pL + eL * 0.6;\n    const inDiffR: f32 = pR + eR * 0.6;\n\n    // allpass 1\n    const a1xL: f32 = tap(ap1L, AP1_LEN, ap1W, a1l);\n    const a1xR: f32 = tap(ap1R, AP1_LEN, ap1W, a1r);\n    const a1yL: f32 = f32(-apC * inDiffL + a1xL);\n    const a1yR: f32 = f32(-apC * inDiffR + a1xR);\n    ap1L[ap1W] = f32(inDiffL + apC * a1yL);\n    ap1R[ap1W] = f32(inDiffR + apC * a1yR);\n    ap1W++; if (ap1W >= AP1_LEN) ap1W = 0;\n\n    // allpass 2\n    const a2xL: f32 = tap(ap2L, AP2_LEN, ap2W, a2l);\n    const a2xR: f32 = tap(ap2R, AP2_LEN, ap2W, a2r);\n    const a2yL: f32 = f32(-apC * a1yL + a2xL);\n    const a2yR: f32 = f32(-apC * a1yR + a2xR);\n    ap2L[ap2W] = f32(a1yL + apC * a2yL);\n    ap2R[ap2W] = f32(a1yR + apC * a2yR);\n    ap2W++; if (ap2W >= AP2_LEN) ap2W = 0;\n\n    const diffL: f32 = a2yL;\n    const diffR: f32 = a2yR;\n\n    // --- feedback delay network (4 lines, lattice mix for stereo tail) ---\n    const t0: f32 = tap(d0, FDN_LEN, dW0, l0);\n    const t1: f32 = tap(d1, FDN_LEN, dW1, l1);\n    const t2: f32 = tap(d2, FDN_LEN, dW2, l2);\n    const t3: f32 = tap(d3, FDN_LEN, dW3, l3);\n\n    // damping low-pass on each line (one-pole)\n    damp0 = f32(damp0 + (1.0 - dampC) * (t0 - damp0));\n    damp1 = f32(damp1 + (1.0 - dampC) * (t1 - damp1));\n    damp2 = f32(damp2 + (1.0 - dampC) * (t2 - damp2));\n    damp3 = f32(damp3 + (1.0 - dampC) * (t3 - damp3));\n\n    // Householder-style feedback matrix mixing\n    const s: f32 = f32((damp0 + damp1 + damp2 + damp3) * 0.5);\n    const f0: f32 = f32(s - damp0);\n    const f1: f32 = f32(s - damp1);\n    const f2: f32 = f32(s - damp2);\n    const f3: f32 = f32(s - damp3);\n\n    // inject the diffused signal, apply decay feedback, write lines.\n    // subtle vintage-digital grain: quantise the feedback to ~13-bit.\n    const qScale: f32 = 4096.0;\n    let w0: f32 = f32(diffL + f0 * fb);\n    let w1: f32 = f32(diffR + f1 * fb);\n    let w2: f32 = f32(diffL * 0.7 + f2 * fb);\n    let w3: f32 = f32(diffR * 0.7 + f3 * fb);\n    w0 = f32(Mathf.floor(w0 * qScale) / qScale);\n    w1 = f32(Mathf.floor(w1 * qScale) / qScale);\n    w2 = f32(Mathf.floor(w2 * qScale) / qScale);\n    w3 = f32(Mathf.floor(w3 * qScale) / qScale);\n    // soft safety clamp on the feedback storage\n    d0[dW0] = clampf(w0, -1.2, 1.2);\n    d1[dW1] = clampf(w1, -1.2, 1.2);\n    d2[dW2] = clampf(w2, -1.2, 1.2);\n    d3[dW3] = clampf(w3, -1.2, 1.2);\n    dW0++; if (dW0 >= FDN_LEN) dW0 = 0;\n    dW1++; if (dW1 >= FDN_LEN) dW1 = 0;\n    dW2++; if (dW2 >= FDN_LEN) dW2 = 0;\n    dW3++; if (dW3 >= FDN_LEN) dW3 = 0;\n\n    // stereo tap of the tail\n    const tailL: f32 = f32((damp0 + damp2) * 0.5);\n    const tailR: f32 = f32((damp1 + damp3) * 0.5);\n\n    // wet = early reflections + diffuse tail\n    let wetL: f32 = f32((eL + tailL) * wetTrim);\n    let wetR: f32 = f32((eR + tailR) * wetTrim);\n\n    // equal-power-ish dry/wet (Mix = 0 -> bit-exact dry)\n    const outL: f32 = f32(dryL * (1.0 - mix) + wetL * mix);\n    const outR: f32 = f32(dryR * (1.0 - mix) + wetR * mix);\n\n    outBuf[f] = clampf(outL, -1.0, 1.0);\n    outBuf[baseR + f] = clampf(outR, -1.0, 1.0);\n  }\n}\n",
  "publishedAt": 1751000086000
}