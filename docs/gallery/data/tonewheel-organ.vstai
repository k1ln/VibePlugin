  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Tonewheel Organ</title>\n<style>\n  :root {\n    --accent:   #caa15a;\n    --accent2:  #8a5a2a;\n    --wood-1:   #3a2415;\n    --wood-2:   #57361f;\n    --wood-3:   #79492a;\n    --panel:    #1c1611;\n    --chrome-1: #f4efe6;\n    --ink:      #f3e7d2;\n    --ink-dim:  #b69a72;\n    --felt:     #15100b;\n    font-size: 15px;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background: radial-gradient(140% 120% at 50% -10%, #2a1d12 0%, #150d07 60%, #0c0805 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    min-height: 100vh;\n  }\n\n  .shell {\n    max-width: 940px;\n    margin: 0 auto;\n    padding: 22px 18px 30px;\n  }\n\n  /* ---- console body : warm lacquered wood ---- */\n  .console {\n    position: relative;\n    border-radius: 18px;\n    padding: 20px 22px 24px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,0.06), rgba(0,0,0,0.35)),\n      repeating-linear-gradient(92deg,\n        var(--wood-2) 0px, var(--wood-3) 6px, var(--wood-1) 11px, var(--wood-2) 17px),\n      linear-gradient(180deg, var(--wood-3), var(--wood-1));\n    box-shadow:\n      0 30px 60px -20px rgba(0,0,0,0.8),\n      inset 0 2px 0 rgba(255,236,200,0.18),\n      inset 0 -3px 14px rgba(0,0,0,0.6);\n    border: 1px solid #2c1c10;\n  }\n\n  /* ---- header ---- */\n  .header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    margin-bottom: 18px;\n  }\n  .brand { display: flex; align-items: center; gap: 14px; }\n\n  .rotor {\n    width: 46px; height: 46px;\n    border-radius: 50%;\n    background:\n      radial-gradient(circle at 50% 50%, #2a2118 0 30%, #0c0905 31% 100%);\n    border: 2px solid var(--accent2);\n    box-shadow: inset 0 0 10px rgba(0,0,0,0.8), 0 0 14px rgba(202,161,90,0.25);\n    position: relative;\n    overflow: hidden;\n    flex: 0 0 auto;\n  }\n  .rotor::before, .rotor::after {\n    content: \"\";\n    position: absolute;\n    inset: 5px;\n    border-radius: 50%;\n    background: conic-gradient(from 0deg,\n      var(--accent) 0deg, transparent 40deg, transparent 180deg,\n      var(--accent) 200deg, transparent 240deg, transparent 360deg);\n    opacity: 0.85;\n    animation: spin var(--rot-dur, 1.6s) linear infinite;\n  }\n  .rotor::after {\n    inset: 13px;\n    animation-direction: reverse;\n    animation-duration: calc(var(--rot-dur, 1.6s) * 1.4);\n    opacity: 0.55;\n  }\n  @keyframes spin { to { transform: rotate(360deg); } }\n\n  .title h1 {\n    margin: 0;\n    font-size: 1.45rem;\n    letter-spacing: 0.04em;\n    font-weight: 700;\n    color: var(--ink);\n    text-shadow: 0 1px 0 rgba(0,0,0,0.5), 0 0 18px rgba(202,161,90,0.25);\n  }\n  .title .sub {\n    font-size: 0.62rem;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--accent);\n    margin-top: 3px;\n  }\n\n  .badge {\n    font-size: 0.6rem;\n    letter-spacing: 0.3em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    border: 1px solid rgba(202,161,90,0.4);\n    border-radius: 20px;\n    padding: 6px 12px;\n    background: rgba(0,0,0,0.25);\n  }\n\n  /* ---- main grid ---- */\n  .body {\n    display: grid;\n    grid-template-columns: minmax(0, 1.7fr) minmax(190px, 1fr);\n    gap: 18px;\n  }\n  @media (max-width: 720px) {\n    .body { grid-template-columns: 1fr; }\n  }\n\n  .bay {\n    background:\n      linear-gradient(180deg, rgba(0,0,0,0.45), rgba(0,0,0,0.65));\n    border-radius: 12px;\n    padding: 16px 16px 14px;\n    border: 1px solid rgba(0,0,0,0.6);\n    box-shadow: inset 0 2px 8px rgba(0,0,0,0.7), inset 0 -1px 0 rgba(255,255,255,0.05);\n  }\n  .bay-title {\n    font-size: 0.6rem;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--accent);\n    margin: 0 0 14px;\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .bay-title::after {\n    content: \"\";\n    flex: 1;\n    height: 1px;\n    background: linear-gradient(90deg, rgba(202,161,90,0.5), transparent);\n  }\n\n  /* ---- DRAWBARS ---- */\n  .drawbars {\n    display: flex;\n    gap: 12px;\n    align-items: flex-end;\n    justify-content: space-between;\n  }\n  .bar {\n    flex: 1 1 0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n  }\n  .bar .rail {\n    position: relative;\n    width: 30px;\n    height: 178px;\n    border-radius: 8px;\n    background:\n      linear-gradient(90deg, rgba(0,0,0,0.6), rgba(255,255,255,0.04), rgba(0,0,0,0.6)),\n      var(--felt);\n    box-shadow: inset 0 0 6px rgba(0,0,0,0.85);\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  /* the sliding drawbar knob — coloured caps like a real organ */\n  .bar .cap {\n    position: absolute;\n    left: 50%;\n    transform: translate(-50%, 0);\n    width: 38px;\n    height: 30px;\n    border-radius: 6px;\n    background:\n      linear-gradient(180deg, var(--cap-hi, #e9e2d4) 0%, var(--cap-lo, #9c9486) 55%, #4c463c 100%);\n    box-shadow:\n      0 4px 8px rgba(0,0,0,0.55),\n      inset 0 1px 0 rgba(255,255,255,0.7),\n      inset 0 -2px 3px rgba(0,0,0,0.4);\n    border: 1px solid rgba(0,0,0,0.5);\n    transition: box-shadow 0.12s ease;\n  }\n  .bar .cap::after {\n    content: \"\";\n    position: absolute;\n    left: 6px; right: 6px; top: 50%;\n    height: 3px;\n    transform: translateY(-50%);\n    border-radius: 2px;\n    background: rgba(0,0,0,0.35);\n    box-shadow: 0 4px 0 rgba(0,0,0,0.2), 0 -4px 0 rgba(0,0,0,0.2);\n  }\n  /* the metal shaft above the cap */\n  .bar .shaft {\n    position: absolute;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 6px;\n    top: 0;\n    border-radius: 3px;\n    background: linear-gradient(90deg, #5a5448, #d8d0c0, #5a5448);\n    box-shadow: 0 1px 2px rgba(0,0,0,0.5);\n  }\n  .bar .rail.drag .cap, .bar .rail:hover .cap {\n    box-shadow:\n      0 5px 12px rgba(0,0,0,0.6),\n      0 0 14px var(--cap-glow, rgba(202,161,90,0.5)),\n      inset 0 1px 0 rgba(255,255,255,0.8);\n  }\n  .bar .foot {\n    font-size: 0.78rem;\n    font-weight: 700;\n    color: var(--ink);\n    letter-spacing: 0.02em;\n    text-align: center;\n    line-height: 1.05;\n  }\n  .bar .lbl {\n    font-size: 0.5rem;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n  }\n  .bar .val {\n    font-size: 0.6rem;\n    color: var(--accent);\n    font-variant-numeric: tabular-nums;\n  }\n\n  /* ---- right column controls ---- */\n  .ctl-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 16px 12px;\n    justify-items: center;\n  }\n  .knobwrap {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n  .knob {\n    width: 70px; height: 70px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob .face { transition: filter 0.12s ease; }\n  .knob:hover .face, .knob.drag .face { filter: drop-shadow(0 0 7px rgba(202,161,90,0.6)); }\n  .knob-name {\n    font-size: 0.55rem;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .knob-val {\n    font-size: 0.62rem;\n    color: var(--accent);\n    font-variant-numeric: tabular-nums;\n  }\n\n  /* ---- rocker switch (perc mode / vibrato look) ---- */\n  .rocker {\n    grid-column: span 2;\n    width: 100%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n  }\n  .rocker-name {\n    font-size: 0.55rem;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .switch {\n    position: relative;\n    width: 132px;\n    height: 34px;\n    border-radius: 8px;\n    background: linear-gradient(180deg, #14100b, #241a11);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.8), 0 1px 0 rgba(255,255,255,0.06);\n    display: flex;\n    padding: 3px;\n    cursor: pointer;\n    border: 1px solid rgba(0,0,0,0.6);\n  }\n  .switch .opt {\n    flex: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-size: 0.6rem;\n    letter-spacing: 0.12em;\n    font-weight: 700;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    z-index: 2;\n    transition: color 0.18s ease;\n  }\n  .switch .opt.on { color: #1a120a; }\n  .switch .glide {\n    position: absolute;\n    top: 3px; bottom: 3px;\n    width: calc(50% - 3px);\n    border-radius: 6px;\n    background: linear-gradient(180deg, var(--accent) 0%, var(--accent2) 100%);\n    box-shadow: 0 2px 6px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.5);\n    transition: left 0.2s cubic-bezier(0.4, 1.4, 0.5, 1);\n    left: 3px;\n  }\n  .switch.right .glide { left: 50%; }\n\n  /* ---- keyboard ---- */\n  .keyboard {\n    margin-top: 18px;\n    background: linear-gradient(180deg, rgba(0,0,0,0.5), rgba(0,0,0,0.7));\n    border-radius: 10px;\n    padding: 12px 12px 14px;\n    box-shadow: inset 0 2px 8px rgba(0,0,0,0.7);\n    border: 1px solid rgba(0,0,0,0.6);\n  }\n  .keys {\n    position: relative;\n    height: 120px;\n    display: flex;\n    user-select: none;\n    touch-action: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #faf3e6 0%, #e6dcc8 88%, #cdbfa4 100%);\n    box-shadow: inset 0 -4px 6px rgba(0,0,0,0.12), 0 2px 3px rgba(0,0,0,0.4);\n    border: 1px solid #b6a888;\n    cursor: pointer;\n    transition: background 0.05s ease, transform 0.05s ease;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #d9b878 90%);\n    transform: translateY(2px);\n    box-shadow: inset 0 -3px 8px rgba(0,0,0,0.25);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 60%;\n    height: 62%;\n    transform: translateX(-50%);\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a221a 0%, #0d0a07 100%);\n    box-shadow: 0 3px 5px rgba(0,0,0,0.6), inset 0 -3px 4px rgba(255,255,255,0.06);\n    z-index: 3;\n    cursor: pointer;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2) 0%, #1a120a 100%);\n    transform: translateX(-50%) translateY(1px);\n  }\n\n  .hint {\n    text-align: center;\n    margin-top: 10px;\n    font-size: 0.55rem;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"console\">\n\n      <div class=\"header\">\n        <div class=\"brand\">\n          <div class=\"rotor\" id=\"rotor\"></div>\n          <div class=\"title\">\n            <h1>TONEWHEEL ORGAN</h1>\n            <div class=\"sub\">Drawbar &middot; Percussion &middot; Rotary</div>\n          </div>\n        </div>\n        <div class=\"badge\">Additive Console</div>\n      </div>\n\n      <div class=\"body\">\n        <div class=\"bay\">\n          <div class=\"bay-title\">Drawbars</div>\n          <div class=\"drawbars\" id=\"drawbars\"></div>\n        </div>\n\n        <div class=\"bay\">\n          <div class=\"bay-title\">Voicing</div>\n          <div class=\"ctl-grid\">\n            <div class=\"knobwrap\" id=\"knob-perc\"></div>\n            <div class=\"knobwrap\" id=\"knob-drive\"></div>\n            <div class=\"knobwrap\" id=\"knob-rotary\"></div>\n            <div class=\"knobwrap\" id=\"knob-spare\" style=\"visibility:hidden\"></div>\n            <div class=\"rocker\">\n              <div class=\"rocker-name\">Percussion Harmonic</div>\n              <div class=\"switch\" id=\"percSwitch\">\n                <div class=\"glide\"></div>\n                <div class=\"opt on\">2nd</div>\n                <div class=\"opt\">3rd</div>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"keyboard\">\n        <div class=\"keys\" id=\"keys\"></div>\n        <div class=\"hint\">Click &amp; drag the keys &middot; drag controls vertically &middot; double-click to reset</div>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host bridge (guard for late injection) -----------------------\n  var Q = [];\n  function setParam(i, v) {\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n    else Q.push([i, v]);\n  }\n  function flush() {\n    if (!(window.vstai && window.vstai.setParam)) return;\n    for (var k = 0; k < Q.length; k++) window.vstai.setParam(Q[k][0], Q[k][1]);\n    Q = [];\n  }\n\n  // ---- parameter model (indices MUST match the DSP) -----------------\n  // Drawbars 0..3 map to the four drawbar params; Upper is one fader that\n  // blends the bright footages. We render seven physical bars but the\n  // upper four share param index 3 (a real organ groups them as \"brightness\").\n  var BARS = [\n    { idx: 0, foot: \"16'\", lbl: \"Sub\",   def: 0.6,  hi: \"#8b5a2b\", lo: \"#5a3a1c\", glow: \"rgba(139,90,43,0.6)\" },\n    { idx: 1, foot: \"8'\",  lbl: \"Fund\",  def: 0.85, hi: \"#f4efe6\", lo: \"#9c9486\", glow: \"rgba(244,239,230,0.6)\" },\n    { idx: 2, foot: \"5⅓'\", lbl: \"Third\", def: 0.35, hi: \"#caa15a\", lo: \"#8a5a2a\", glow: \"rgba(202,161,90,0.6)\" },\n    { idx: 3, foot: \"4'\",  lbl: \"Upper\", def: 0.45, hi: \"#caa15a\", lo: \"#8a5a2a\", glow: \"rgba(202,161,90,0.6)\", shared: true },\n    { idx: 3, foot: \"2⅔'\", lbl: \"Upper\", def: 0.45, hi: \"#9c5a8a\", lo: \"#5a2a4a\", glow: \"rgba(156,90,138,0.6)\", shared: true },\n    { idx: 3, foot: \"2'\",  lbl: \"Upper\", def: 0.45, hi: \"#f4efe6\", lo: \"#9c9486\", glow: \"rgba(244,239,230,0.5)\", shared: true },\n    { idx: 3, foot: \"1'\",  lbl: \"Upper\", def: 0.45, hi: \"#5a8aca\", lo: \"#2a4a7a\", glow: \"rgba(90,138,202,0.6)\", shared: true }\n  ];\n\n  var paramDefaults = { 0: 0.6, 1: 0.85, 2: 0.35, 3: 0.45, 4: 0.5, 5: 0, 6: 0.25, 7: 0.3 };\n  var paramValues = {};\n  for (var pk in paramDefaults) paramValues[pk] = paramDefaults[pk];\n\n  function pushParam(idx, val) {\n    paramValues[idx] = val;\n    setParam(idx, val);\n  }\n\n  // ===================================================================\n  //  DRAWBARS\n  // ===================================================================\n  var drawbarsEl = document.getElementById(\"drawbars\");\n  var RAIL_H = 178, CAP_H = 30, TRAVEL = RAIL_H - CAP_H;\n\n  function buildBar(spec) {\n    var bar = document.createElement(\"div\");\n    bar.className = \"bar\";\n\n    var foot = document.createElement(\"div\");\n    foot.className = \"foot\";\n    foot.textContent = spec.foot;\n\n    var rail = document.createElement(\"div\");\n    rail.className = \"rail\";\n    rail.style.setProperty(\"--cap-hi\", spec.hi);\n    rail.style.setProperty(\"--cap-lo\", spec.lo);\n    rail.style.setProperty(\"--cap-glow\", spec.glow);\n\n    var shaft = document.createElement(\"div\");\n    shaft.className = \"shaft\";\n\n    var cap = document.createElement(\"div\");\n    cap.className = \"cap\";\n\n    rail.appendChild(shaft);\n    rail.appendChild(cap);\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"lbl\";\n    lbl.textContent = spec.lbl;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    bar.appendChild(foot);\n    bar.appendChild(rail);\n    bar.appendChild(lbl);\n    bar.appendChild(val);\n    drawbarsEl.appendChild(bar);\n\n    // a \"pulled out\" drawbar = louder; visually it sits LOWER (towards player)\n    function render(v) {\n      var top = (1 - v) * TRAVEL;            // v=1 -> cap at bottom (pulled out)\n      cap.style.top = top + \"px\";\n      shaft.style.height = top + \"px\";\n      val.textContent = Math.round(v * 8) + \"/8\";\n    }\n\n    function setVal(v) {\n      v = Math.max(0, Math.min(1, v));\n      pushParam(spec.idx, v);\n      render(v);\n    }\n\n    render(paramValues[spec.idx]);\n\n    // drag interaction\n    var dragging = false, startY = 0, startV = 0;\n    function down(e) {\n      dragging = true;\n      rail.classList.add(\"drag\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = paramValues[spec.idx];\n      e.preventDefault();\n    }\n    function move(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dv = (y - startY) / TRAVEL;         // drag down = louder (matches pull)\n      setVal(startV + dv);\n      e.preventDefault();\n    }\n    function up() { dragging = false; rail.classList.remove(\"drag\"); }\n\n    rail.addEventListener(\"mousedown\", down);\n    window.addEventListener(\"mousemove\", move);\n    window.addEventListener(\"mouseup\", up);\n    rail.addEventListener(\"touchstart\", down, { passive: false });\n    window.addEventListener(\"touchmove\", move, { passive: false });\n    window.addEventListener(\"touchend\", up);\n    rail.addEventListener(\"dblclick\", function () { setVal(spec.def); });\n    rail.addEventListener(\"wheel\", function (e) {\n      setVal(paramValues[spec.idx] - e.deltaY * 0.0008);\n      e.preventDefault();\n    }, { passive: false });\n\n    return { render: render, idx: spec.idx };\n  }\n\n  var barCtrls = BARS.map(buildBar);\n\n  // when a shared (Upper) bar moves, mirror the other shared bars\n  function syncShared() {\n    var v = paramValues[3];\n    barCtrls.forEach(function (b) { if (b.idx === 3) b.render(v); });\n  }\n\n  // ===================================================================\n  //  KNOBS (SVG)\n  // ===================================================================\n  function buildKnob(mount, spec) {\n    var wrap = document.getElementById(mount);\n    var NS = \"http://www.w3.org/2000/svg\";\n\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n    svg.setAttribute(\"class\", \"knob\");\n\n    var g = document.createElementNS(NS, \"g\");\n    g.setAttribute(\"class\", \"face\");\n\n    var track = document.createElementNS(NS, \"circle\");\n    track.setAttribute(\"cx\", \"50\"); track.setAttribute(\"cy\", \"50\"); track.setAttribute(\"r\", \"40\");\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(0,0,0,0.55)\");\n    track.setAttribute(\"stroke-width\", \"7\");\n\n    var arc = document.createElementNS(NS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"var(--accent)\");\n    arc.setAttribute(\"stroke-width\", \"7\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n\n    var body = document.createElementNS(NS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"30\");\n    body.setAttribute(\"fill\", \"url(#kbody)\");\n    body.setAttribute(\"stroke\", \"#100b07\");\n    body.setAttribute(\"stroke-width\", \"1.5\");\n\n    var defs = document.createElementNS(NS, \"defs\");\n    defs.innerHTML =\n      '<radialGradient id=\"kbody\" cx=\"50%\" cy=\"34%\" r=\"70%\">' +\n      '<stop offset=\"0%\" stop-color=\"#403329\"/>' +\n      '<stop offset=\"60%\" stop-color=\"#241a11\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#0d0905\"/></radialGradient>';\n\n    var notch = document.createElementNS(NS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"26\");\n    notch.setAttribute(\"stroke\", \"var(--accent)\");\n    notch.setAttribute(\"stroke-width\", \"3.5\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n\n    g.appendChild(track); g.appendChild(arc); g.appendChild(body); g.appendChild(notch);\n    svg.appendChild(defs); svg.appendChild(g);\n\n    var name = document.createElement(\"div\");\n    name.className = \"knob-name\"; name.textContent = spec.name;\n    var val = document.createElement(\"div\");\n    val.className = \"knob-val\";\n\n    wrap.appendChild(svg);\n    wrap.appendChild(name);\n    wrap.appendChild(val);\n\n    var A0 = -135, A1 = 135; // sweep range in degrees\n    function render(v) {\n      var ang = A0 + (A1 - A0) * v;\n      var rad = ang * Math.PI / 180;\n      // notch\n      var nx = 50 + Math.sin(rad) * 24;\n      var ny = 50 - Math.cos(rad) * 24;\n      notch.setAttribute(\"x2\", nx.toFixed(2));\n      notch.setAttribute(\"y2\", ny.toFixed(2));\n      // arc from A0 to ang\n      var r = 40;\n      var sa = (A0 - 90) * Math.PI / 180;\n      var ea = (ang - 90) * Math.PI / 180;\n      var x0 = 50 + r * Math.cos(sa), y0 = 50 + r * Math.sin(sa);\n      var x1 = 50 + r * Math.cos(ea), y1 = 50 + r * Math.sin(ea);\n      var large = (ang - A0) > 180 ? 1 : 0;\n      arc.setAttribute(\"d\", \"M \" + x0.toFixed(2) + \" \" + y0.toFixed(2) +\n        \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + x1.toFixed(2) + \" \" + y1.toFixed(2));\n      val.textContent = spec.fmt ? spec.fmt(v) : Math.round(v * 100) + \"%\";\n    }\n\n    function setVal(v) {\n      v = Math.max(0, Math.min(1, v));\n      pushParam(spec.idx, v);\n      render(v);\n    }\n\n    render(paramValues[spec.idx]);\n\n    var dragging = false, startY = 0, startV = 0;\n    function down(e) {\n      dragging = true;\n      svg.classList.add(\"drag\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = paramValues[spec.idx];\n      e.preventDefault();\n    }\n    function move(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      setVal(startV - (y - startY) / 160);    // drag up = increase\n      e.preventDefault();\n    }\n    function up() { dragging = false; svg.classList.remove(\"drag\"); }\n\n    svg.addEventListener(\"mousedown\", down);\n    window.addEventListener(\"mousemove\", move);\n    window.addEventListener(\"mouseup\", up);\n    svg.addEventListener(\"touchstart\", down, { passive: false });\n    window.addEventListener(\"touchmove\", move, { passive: false });\n    window.addEventListener(\"touchend\", up);\n    svg.addEventListener(\"dblclick\", function () { setVal(spec.def); });\n    svg.addEventListener(\"wheel\", function (e) {\n      setVal(paramValues[spec.idx] - e.deltaY * 0.0008);\n      e.preventDefault();\n    }, { passive: false });\n\n    return { render: render, setVal: setVal };\n  }\n\n  buildKnob(\"knob-perc\",   { idx: 4, name: \"Perc\",   def: 0.5 });\n  buildKnob(\"knob-drive\",  { idx: 6, name: \"Drive\",  def: 0.25 });\n  var rotaryKnob = buildKnob(\"knob-rotary\", {\n    idx: 7, name: \"Rotary\", def: 0.3,\n    fmt: function (v) { return (0.8 + v * 6.2).toFixed(1) + \"Hz\"; }\n  });\n\n  // ===================================================================\n  //  PERCUSSION HARMONIC ROCKER (param 5, discrete {0,1})\n  // ===================================================================\n  var sw = document.getElementById(\"percSwitch\");\n  var opts = sw.querySelectorAll(\".opt\");\n  function setMode(m) {\n    pushParam(5, m);\n    if (m >= 0.5) { sw.classList.add(\"right\"); opts[0].classList.remove(\"on\"); opts[1].classList.add(\"on\"); }\n    else          { sw.classList.remove(\"right\"); opts[1].classList.remove(\"on\"); opts[0].classList.add(\"on\"); }\n  }\n  sw.addEventListener(\"click\", function () { setMode(paramValues[5] >= 0.5 ? 0 : 1); });\n  setMode(paramValues[5]);\n\n  // ===================================================================\n  //  ROTOR animation — speed tracks the Rotary param\n  // ===================================================================\n  var rotorEl = document.getElementById(\"rotor\");\n  function updateRotor() {\n    var hz = 0.8 + paramValues[7] * 6.2;\n    var dur = (1 / hz).toFixed(3) + \"s\";\n    rotorEl.style.setProperty(\"--rot-dur\", dur);\n  }\n  // hook rotary knob to update rotor live\n  var origRotorSet = rotaryKnob.setVal;\n  rotaryKnob.setVal = function (v) { origRotorSet(v); updateRotor(); };\n  // also patch pushParam so any rotary change refreshes the rotor\n  var basePush = pushParam;\n  pushParam = function (idx, val) {\n    basePush(idx, val);\n    if (idx === 3) syncShared();\n    if (idx === 7) updateRotor();\n  };\n  updateRotor();\n\n  // ===================================================================\n  //  KEYBOARD — two octaves, click & drag to play\n  // ===================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var BASE_NOTE = 48; // C3\n  var NUM_WHITE = 14; // two octaves of white keys\n  var whitePattern = [0, 2, 4, 5, 7, 9, 11]; // semitone offsets within an octave\n  var blackAfter   = [0, 1, 3, 4, 5];        // which white-key index has a black to its right\n\n  function noteOn(n, v) {\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, v == null ? 0.85 : v);\n  }\n  function noteOff(n) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  var whiteEls = [];\n  for (var w = 0; w < NUM_WHITE; w++) {\n    var oct = Math.floor(w / 7);\n    var deg = w % 7;\n    var note = BASE_NOTE + oct * 12 + whitePattern[deg];\n    var key = document.createElement(\"div\");\n    key.className = \"wkey\";\n    key.dataset.note = note;\n    keysEl.appendChild(key);\n    whiteEls.push(key);\n  }\n\n  // black keys positioned over the white-key boundaries\n  function placeBlacks() {\n    // remove old\n    var olds = keysEl.querySelectorAll(\".bkey\");\n    olds.forEach(function (b) { b.remove(); });\n    var whiteW = whiteEls[0].getBoundingClientRect().width + 2; // + margins\n    for (var o = 0; o < 2; o++) {\n      for (var i = 0; i < blackAfter.length; i++) {\n        var wi = o * 7 + blackAfter[i];\n        if (wi + 1 >= NUM_WHITE && o === 1 && blackAfter[i] === 5) { /* keep */ }\n        var note = parseInt(whiteEls[wi].dataset.note, 10) + 1;\n        var bk = document.createElement(\"div\");\n        bk.className = \"bkey\";\n        bk.dataset.note = note;\n        bk.style.left = ((wi + 1) * whiteW) + \"px\";\n        keysEl.appendChild(bk);\n      }\n    }\n  }\n\n  var heldKeys = {};\n  function pressEl(el) {\n    if (!el || el.dataset.note == null) return;\n    var n = parseInt(el.dataset.note, 10);\n    if (heldKeys[n]) return;\n    heldKeys[n] = el;\n    el.classList.add(\"down\");\n    noteOn(n, 0.85);\n  }\n  function releaseEl(el) {\n    if (!el || el.dataset.note == null) return;\n    var n = parseInt(el.dataset.note, 10);\n    if (!heldKeys[n]) return;\n    el.classList.remove(\"down\");\n    delete heldKeys[n];\n    noteOff(n);\n  }\n  function releaseAll() {\n    for (var n in heldKeys) {\n      heldKeys[n].classList.remove(\"down\");\n      noteOff(parseInt(n, 10));\n    }\n    heldKeys = {};\n  }\n\n  var mouseDown = false;\n  function keyAt(x, y) {\n    var el = document.elementFromPoint(x, y);\n    if (el && (el.classList.contains(\"wkey\") || el.classList.contains(\"bkey\"))) return el;\n    return null;\n  }\n\n  keysEl.addEventListener(\"mousedown\", function (e) {\n    mouseDown = true;\n    pressEl(keyAt(e.clientX, e.clientY));\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"mousemove\", function (e) {\n    if (!mouseDown) return;\n    var el = keyAt(e.clientX, e.clientY);\n    // release keys no longer under cursor (mono-ish drag glide)\n    for (var n in heldKeys) {\n      if (heldKeys[n] !== el) releaseEl(heldKeys[n]);\n    }\n    pressEl(el);\n  });\n  window.addEventListener(\"mouseup\", function () { mouseDown = false; releaseAll(); });\n\n  keysEl.addEventListener(\"touchstart\", function (e) {\n    for (var i = 0; i < e.changedTouches.length; i++) {\n      var t = e.changedTouches[i];\n      pressEl(keyAt(t.clientX, t.clientY));\n    }\n    e.preventDefault();\n  }, { passive: false });\n  keysEl.addEventListener(\"touchend\", function (e) { releaseAll(); e.preventDefault(); }, { passive: false });\n\n  // computer-keyboard row for convenience (a s d f ...)\n  var keyMap = { a: 0, w: 1, s: 2, e: 3, d: 4, f: 5, t: 6, g: 7, y: 8, h: 9, u: 10, j: 11, k: 12 };\n  var kbHeld = {};\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var off = keyMap[e.key];\n    if (off == null) return;\n    var n = BASE_NOTE + off;\n    if (kbHeld[n]) return;\n    kbHeld[n] = true;\n    var el = keysEl.querySelector('[data-note=\"' + n + '\"]');\n    if (el) el.classList.add(\"down\");\n    noteOn(n, 0.85);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var off = keyMap[e.key];\n    if (off == null) return;\n    var n = BASE_NOTE + off;\n    if (!kbHeld[n]) return;\n    delete kbHeld[n];\n    var el = keysEl.querySelector('[data-note=\"' + n + '\"]');\n    if (el) el.classList.remove(\"down\");\n    noteOff(n);\n  });\n\n  // ---- boot: place blacks once layout is known, init all params -----\n  function boot() {\n    flush();\n    // push every default into the engine\n    for (var pk in paramValues) setParam(parseInt(pk, 10), paramValues[pk]);\n    placeBlacks();\n    updateRotor();\n  }\n\n  window.addEventListener(\"resize\", placeBlacks);\n\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(boot);\n  else boot();\n\n  // also flush queued params once vstai appears (poll briefly)\n  var tries = 0;\n  var poll = setInterval(function () {\n    if (window.vstai && window.vstai.setParam) { flush(); clearInterval(poll); }\n    if (++tries > 40) clearInterval(poll);\n  }, 50);\n\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  TONEWHEEL ORGAN — a polyphonic additive drawbar organ instrument.\n//  Each held key is synthesised as a sum of sine partials at the classic\n//  drawbar footages (16', 8', 5 1/3', 4', 2 2/3', 2', 1'), mimicking the\n//  geared tonewheel generator of a vintage console organ. A short key-click\n//  transient, a decaying percussion tap (selectable 2nd/3rd harmonic) and a\n//  built-in rotary speaker (amplitude + pitch shimmer) round out the sound.\n//  Attack is instant and the tone sustains flat while a key is held — no\n//  amplitude decay — exactly like a real drawbar organ. Pure algorithm,\n//  no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 12;        // generous polyphony for big chords\nconst NUM_BARS: i32 = 7;           // 16,8,5 1/3,4,2 2/3,2,1\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_SUB:    i32 = 0;  // 0..1  -> 16' drawbar level\nconst P_FUND:   i32 = 1;  // 0..1  -> 8'  drawbar level\nconst P_THIRD:  i32 = 2;  // 0..1  -> 5 1/3' drawbar level\nconst P_UPPER:  i32 = 3;  // 0..1  -> blended 4'+2 2/3'+2'+1' brightness\nconst P_PERC:   i32 = 4;  // 0..1  -> percussion amount\nconst P_PMODE:  i32 = 5;  // {0,1} -> percussion harmonic (0=2nd, 1=3rd)\nconst P_DRIVE:  i32 = 6;  // 0..1  -> tube-amp overdrive\nconst P_ROTARY: i32 = 7;  // 0..1  -> rotary speaker speed (slow..fast)\n\n// ---- footage frequency ratios relative to the played pitch ----------\n// 16'=0.5, 8'=1, 5 1/3'=1.5, 4'=2, 2 2/3'=3, 2'=4, 1'=8\nconst barRatio: StaticArray<f32> = new StaticArray<f32>(NUM_BARS);\n\n// ---- per-voice state -------------------------------------------------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// one running phase per partial per voice (planar: voice*NUM_BARS + bar)\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES * NUM_BARS);\n\n// fast on/off amplitude envelope (instant attack, organ sustain, quick release)\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// percussion: a single-trigger decaying gain per voice (does NOT retrigger\n// while a chord is held — classic single-trigger percussion behaviour)\nconst vPerc:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// key-click transient envelope (very short noise burst at note onset)\nconst vClick:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// rotary speaker LFOs (global, shared by all voices for a coherent cabinet)\nlet rotPhase: f32 = 0.0;   // tremolo / doppler phase\nlet rotChorus: f32 = 0.0;  // a slightly detuned second LFO for stereo width\n\n// deterministic noise for key-click\nlet rng: u32 = 0x6d2b79f5;\n@inline function noise(): f32 {\n  rng ^= rng << 13; rng ^= rng >> 17; rng ^= rng << 5;\n  return f32(i32(rng) / 1073741824.0) * 0.5; // ~ -1..1\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n\n  barRatio[0] = 0.5;   // 16'\n  barRatio[1] = 1.0;   // 8'\n  barRatio[2] = 1.5;   // 5 1/3'\n  barRatio[3] = 2.0;   // 4'\n  barRatio[4] = 3.0;   // 2 2/3'\n  barRatio[5] = 4.0;   // 2'\n  barRatio[6] = 8.0;   // 1'\n\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vEnv[v] = 0.0; vPerc[v] = 0.0; vClick[v] = 0.0;\n    for (let b = 0; b < NUM_BARS; b++) vPhase[v * NUM_BARS + b] = 0.0;\n  }\n  ageCounter = 0;\n  rotPhase = 0.0; rotChorus = 0.0;\n\n  params[P_SUB]    = 0.6;\n  params[P_FUND]   = 0.85;\n  params[P_THIRD]  = 0.35;\n  params[P_UPPER]  = 0.45;\n  params[P_PERC]   = 0.5;\n  params[P_PMODE]  = 0.0;   // 2nd harmonic\n  params[P_DRIVE]  = 0.25;\n  params[P_ROTARY] = 0.3;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fast sine from phase 0..1 via a parabolic approximation (no Mathf in loop)\n@inline function sine01(p: f32): f32 {\n  // map 0..1 to -PI..PI then use the Bhaskara-style parabola, refined once\n  let x: f32 = p - f32(i32(p));    // wrap to 0..1\n  if (x < 0.0) x += 1.0;\n  const t: f32 = x * 2.0 - 1.0;    // -1..1\n  // 4th-order-ish sine approximation on -1..1 (zero at +-1, peak mid)\n  const a: f32 = t < 0.0 ? -t : t;\n  let s: f32 = t * (3.1 - 2.1 * a); // rough sine, smooth and bounded ~ +-1\n  // light shaping to tame the peak so partial sums stay bounded\n  return s;\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vEnv[slot]    = 0.0;   // ramps to 1 almost instantly\n  vPerc[slot]   = 1.0;   // trigger percussion tap\n  vClick[slot]  = 1.0;   // trigger key-click\n  // reset partial phases so the click attack is coherent\n  for (let b = 0; b < NUM_BARS; b++) vPhase[slot * NUM_BARS + b] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;   // enter release\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const sub: f32   = clampf(params[P_SUB], 0.0, 1.0);\n  const fund: f32  = clampf(params[P_FUND], 0.0, 1.0);\n  const third: f32 = clampf(params[P_THIRD], 0.0, 1.0);\n  const upper: f32 = clampf(params[P_UPPER], 0.0, 1.0);\n  const perc: f32  = clampf(params[P_PERC], 0.0, 1.0);\n  const pmode: i32 = params[P_PMODE] >= 0.5 ? 1 : 0;  // 0=2nd,1=3rd\n  const drive: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const rotN: f32  = clampf(params[P_ROTARY], 0.0, 1.0);\n\n  // per-bar levels. Upper knob fades in the bright footages 4',2 2/3',2',1'.\n  const lvl0: f32 = sub;            // 16'\n  const lvl1: f32 = fund;           // 8'\n  const lvl2: f32 = third;          // 5 1/3'\n  const lvl3: f32 = upper * 0.85;   // 4'\n  const lvl4: f32 = upper * 0.6;    // 2 2/3'\n  const lvl5: f32 = upper * 0.5;    // 2'\n  const lvl6: f32 = upper * 0.35;   // 1'\n\n  // normalise so a full chord of drawbars stays bounded\n  const barSum: f32 = lvl0 + lvl1 + lvl2 + lvl3 + lvl4 + lvl5 + lvl6 + 0.0001;\n  const barNorm: f32 = 0.85 / barSum;\n\n  // percussion harmonic ratio (2nd = 2x, 3rd = 3x the played pitch)\n  const percRatio: f32 = pmode == 1 ? 3.0 : 2.0;\n  const percDecay: f32 = f32(Mathf.exp(-1.0 / (0.18 * sr))); // ~180 ms tap\n  const percAmt: f32   = perc * 0.9;\n\n  // key-click: short ~3 ms noisy burst\n  const clickDecay: f32 = f32(Mathf.exp(-1.0 / (0.003 * sr)));\n\n  // on/off amp envelope rates (instant-ish attack, snappy release)\n  const atkRate: f32 = 1.0 / (0.002 * sr);   // ~2 ms attack\n  const relRate: f32 = 1.0 / (0.02 * sr);    // ~20 ms release\n\n  // rotary speaker: speed scales from slow (~0.8 Hz) to fast (~7 Hz)\n  const rotHz: f32 = 0.8 + rotN * 6.2;\n  const rotInc: f32 = rotHz / sr;\n  const chorusInc: f32 = (rotHz * 0.93) / sr; // slightly different -> stereo motion\n  // depth of the rotary effect: amplitude tremolo + a gentle pitch shimmer\n  const tremDepth: f32 = 0.12 + rotN * 0.28;       // 0.12..0.40\n  const pitchDepth: f32 = (0.0006 + rotN * 0.0020); // tiny vibrato (doppler hint)\n\n  // tube drive: maps to a pre-gain into a tanh-style soft clip\n  const driveGain: f32 = 1.0 + drive * 5.0;\n  const driveComp: f32 = 1.0 / (1.0 + drive * 1.6); // keep level musical\n\n  for (let f = 0; f < n; f++) {\n    // advance rotary LFOs once per frame\n    rotPhase += rotInc; if (rotPhase >= 1.0) rotPhase -= 1.0;\n    rotChorus += chorusInc; if (rotChorus >= 1.0) rotChorus -= 1.0;\n\n    const tremL: f32 = 1.0 - tremDepth * (0.5 - 0.5 * sine01(rotPhase));\n    const tremR: f32 = 1.0 - tremDepth * (0.5 - 0.5 * sine01(rotChorus + 0.25));\n    // pitch shimmer common to all voices (doppler suggestion)\n    const pitchMod: f32 = 1.0 + pitchDepth * sine01(rotPhase);\n\n    let mixL: f32 = 0.0;\n    let mixR: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- on/off envelope (organ: flat sustain while held) ---------\n      let env: f32 = vEnv[v];\n      if (vGate[v] == 1) {\n        env += atkRate;\n        if (env > 1.0) env = 1.0;\n      } else {\n        env -= relRate;\n        if (env <= 0.0) {\n          env = 0.0;\n          vActive[v] = 0; vNote[v] = -1; vEnv[v] = 0.0; vPerc[v] = 0.0; vClick[v] = 0.0;\n          continue;\n        }\n      }\n      vEnv[v] = env;\n\n      const baseInc: f32 = (vFreq[v] * pitchMod) / sr;\n      const pb: i32 = v * NUM_BARS;\n\n      // ---- sum the drawbar partials ---------------------------------\n      let s0: f32 = vPhase[pb + 0]; s0 += baseInc * barRatio[0]; if (s0 >= 1.0) s0 -= 1.0; vPhase[pb + 0] = s0;\n      let s1: f32 = vPhase[pb + 1]; s1 += baseInc * barRatio[1]; if (s1 >= 1.0) s1 -= 1.0; vPhase[pb + 1] = s1;\n      let s2: f32 = vPhase[pb + 2]; s2 += baseInc * barRatio[2]; if (s2 >= 1.0) s2 -= 1.0; vPhase[pb + 2] = s2;\n      let s3: f32 = vPhase[pb + 3]; s3 += baseInc * barRatio[3]; if (s3 >= 1.0) s3 -= 1.0; vPhase[pb + 3] = s3;\n      let s4: f32 = vPhase[pb + 4]; s4 += baseInc * barRatio[4]; if (s4 >= 1.0) s4 -= 1.0; vPhase[pb + 4] = s4;\n      let s5: f32 = vPhase[pb + 5]; s5 += baseInc * barRatio[5]; if (s5 >= 1.0) s5 -= 1.0; vPhase[pb + 5] = s5;\n      let s6: f32 = vPhase[pb + 6]; s6 += baseInc * barRatio[6]; if (s6 >= 1.0) s6 -= 1.0; vPhase[pb + 6] = s6;\n\n      let tone: f32 =\n          sine01(s0) * lvl0 +\n          sine01(s1) * lvl1 +\n          sine01(s2) * lvl2 +\n          sine01(s3) * lvl3 +\n          sine01(s4) * lvl4 +\n          sine01(s5) * lvl5 +\n          sine01(s6) * lvl6;\n      tone *= barNorm;\n\n      // ---- percussion tap (decaying harmonic, single-trigger) -------\n      let pc: f32 = vPerc[v];\n      if (pc > 0.0001) {\n        // reuse a phase that runs at percRatio of the fundamental\n        // (derive from the 8' phase scaled — cheap & coherent)\n        const pph: f32 = s1 * percRatio;\n        tone += sine01(pph) * pc * percAmt;\n        pc *= percDecay;\n      } else {\n        pc = 0.0;\n      }\n      vPerc[v] = pc;\n\n      // ---- key-click transient --------------------------------------\n      let ck: f32 = vClick[v];\n      if (ck > 0.001) {\n        tone += noise() * ck * 0.35;\n        ck *= clickDecay;\n      } else {\n        ck = 0.0;\n      }\n      vClick[v] = ck;\n\n      const voice: f32 = tone * env * (0.5 + 0.5 * vVel[v]);\n      mixL += voice;\n      mixR += voice;\n    }\n\n    // ---- tube overdrive (shared output stage) ---------------------\n    let dl: f32 = mixL * driveGain;\n    let dr: f32 = mixR * driveGain;\n    // cubic-ish soft clip\n    dl = clampf(dl, -1.5, 1.5); dl = dl - 0.18 * dl * dl * dl;\n    dr = clampf(dr, -1.5, 1.5); dr = dr - 0.18 * dr * dr * dr;\n    dl *= driveComp;\n    dr *= driveComp;\n\n    // ---- rotary speaker amplitude motion + output level -----------\n    let outL: f32 = dl * tremL * 0.7;\n    let outR: f32 = dr * tremR * 0.7;\n\n    outBuf[f] = clampf(outL, -1.0, 1.0);\n    outBuf[MAX_FRAMES + f] = clampf(outR, -1.0, 1.0);\n  }\n}\n",
