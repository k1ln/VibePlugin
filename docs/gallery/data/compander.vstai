  "name": "Compander",
  "isInstrument": false,
  "explanation": "A companding 'noise-reduction character' processor in the Dolby A/SR + HX lineage. Distinct from the factory's studio compressors: a level-dependent compress→expand with high-frequency pre-emphasis that imparts the characteristic tape-NR sheen and gentle breathing — used as a tone/dynamics colour. Controls: Squeeze (compand depth), HF (high-shelf emphasis), Tone (tilt), Output and Mix.",
  "params": [
    {
      "name": "Squeeze",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "HF",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Output",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Compander</title>\n<style>\n  :root{ --acc:#7aa0d0; --acc2:#c0c8d4; --bg0:#080a0d; --bg1:#12161c; --ink:#e7edf4; --dim:#71808f; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#1c232c 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(94vw,720px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#1e242c,#0a0d12); border:1px solid rgba(122,160,208,.2); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:14px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px; background:linear-gradient(90deg,var(--acc2),var(--acc)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .dd{ margin-left:auto; display:flex; gap:3px; } .dd b{ width:13px; height:13px; border:2px solid var(--acc); border-radius:3px 8px 8px 3px; display:block; opacity:.6; }\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0c1218,#0a0e13); border:1px solid rgba(122,160,208,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(190,205,225,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(122,160,208,.5)); }\n  .pcap{ fill:#0c1218; stroke:rgba(122,160,208,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(122,160,208,.1); padding:1px 8px; border-radius:7px; border:1px solid rgba(122,160,208,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">COMPANDER</span><span class=\"sub\">tape NR character</span><span class=\"dd\"><b></b><b></b></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">COMPAND CURVE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Squeeze\",idx:0,def:0.5},{name:\"HF\",idx:1,def:0.5},{name:\"Tone\",idx:2,def:0.5},{name:\"Output\",idx:3,def:0.6},{name:\"Mix\",idx:4,def:1.0}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#c0c8d4\"/><stop offset=\"1\" stop-color=\"#7aa0d0\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle><circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle><line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def); return {render:render};\n  });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var sq=vals[0], hf=vals[1]; var pad=14;\n    // diagonal reference + compand transfer curve (input->output)\n    ctx.strokeStyle=\"rgba(122,160,208,0.18)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(pad,H-pad); ctx.lineTo(W-pad,pad); ctx.stroke();\n    ctx.beginPath();\n    for(var i=0;i<=60;i++){ var x=i/60; var y=Math.pow(x,1-sq*0.6); // compand bend\n      var px=pad+x*(W-2*pad); var py=(H-pad)-y*(H-2*pad); if(i===0) ctx.moveTo(px,py); else ctx.lineTo(px,py); }\n    ctx.strokeStyle=\"rgba(122,160,208,0.95)\"; ctx.lineWidth=2.4; ctx.shadowColor=\"#7aa0d0\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    // HF sheen sparkles\n    ctx.globalAlpha=0.3+hf*0.5;\n    for(var s=0;s<5;s++){ var sx=pad+((ts/300+s*60)%(W-2*pad)); ctx.fillStyle=\"rgba(192,200,212,0.6)\"; ctx.fillRect(sx,pad+4,1.4,8); }\n    ctx.globalAlpha=1;\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  COMPANDER — a companding \"noise-reduction character\" processor (Dolby\n//  A/SR + HX lineage). Distinct from the factory's studio compressors: a\n//  level-dependent compress→expand with HF pre-emphasis that imparts the\n//  characteristic tape-NR sheen and gentle \"breathing\" — used here as a\n//  tone/dynamics colour. Controls: Squeeze (compand depth), HF (high-shelf\n//  emphasis), Tone (tilt), Output, Mix. No host imports, no alloc in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet envL: f32 = 0.0; let envR: f32 = 0.0;\nlet hsL: f32 = 0.0; let hsR: f32 = 0.0;   // high-shelf state (one-pole HP for emphasis)\nlet tiltL: f32 = 0.0; let tiltR: f32 = 0.0;\n\nconst P_SQUEEZE: i32 = 0; const P_HF: i32 = 1; const P_TONE: i32 = 2; const P_OUTPUT: i32 = 3; const P_MIX: i32 = 4;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  envL = 0.0; envR = 0.0; hsL = 0.0; hsR = 0.0; tiltL = 0.0; tiltR = 0.0;\n  params[P_SQUEEZE] = 0.5; params[P_HF] = 0.5; params[P_TONE] = 0.5; params[P_OUTPUT] = 0.6; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const sq: f32 = clampf(params[P_SQUEEZE], 0.0, 1.0);\n  const hfN: f32 = clampf(params[P_HF], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const outN: f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  const envCoef: f32 = f32(Mathf.exp(-1.0 / (0.01 * sampleRate)));  // ~10 ms detector\n  const hfco: f32 = 0.55;                       // high-shelf split point\n  const hfGain: f32 = hfN * 1.8;                // emphasis amount\n  const tilt: f32 = (toneN - 0.5) * 2.0;        // -1..1 dark..bright\n  const tiltco: f32 = 0.18;\n  const makeup: f32 = 0.7 + outN * 1.2;\n  const dry: f32 = 1.0 - mix;\n  const stereo: i32 = 1;\n\n  for (let i = 0; i < n; i++) {\n    let xl: f32 = inBuf[i];\n    let xr: f32 = stereo ? inBuf[MAX_FRAMES + i] : xl;\n\n    // --- channel L ---\n    // envelope\n    const al: f32 = xl < 0.0 ? -xl : xl;\n    envL = al > envL ? al : envL * envCoef + al * (1.0 - envCoef);\n    // companding gain: quiet boosted, loud tamed (level-dependent), depth = squeeze\n    let gl: f32 = 1.0 / (1.0 + sq * 2.5 * envL);     // compress\n    gl = 1.0 + (gl - 1.0);                            // (identity wrap, keeps f32)\n    let yl: f32 = xl * (1.0 + sq * (gl - 1.0) + sq * 0.3); // squeezed\n    // HF emphasis (one-pole high-pass -> add back as shelf)\n    hsL += (yl - hsL) * hfco; const hpl: f32 = yl - hsL;\n    yl = yl + hpl * hfGain;\n    // tilt tone\n    tiltL += (yl - tiltL) * tiltco; const lowl: f32 = tiltL; const highl: f32 = yl - tiltL;\n    yl = yl + (tilt > 0.0 ? highl * tilt : lowl * (-tilt));\n    yl *= makeup;\n\n    // --- channel R ---\n    const ar: f32 = xr < 0.0 ? -xr : xr;\n    envR = ar > envR ? ar : envR * envCoef + ar * (1.0 - envCoef);\n    let gr: f32 = 1.0 / (1.0 + sq * 2.5 * envR);\n    let yr: f32 = xr * (1.0 + sq * (gr - 1.0) + sq * 0.3);\n    hsR += (yr - hsR) * hfco; const hpr: f32 = yr - hsR;\n    yr = yr + hpr * hfGain;\n    tiltR += (yr - tiltR) * tiltco; const lowr: f32 = tiltR; const highr: f32 = yr - tiltR;\n    yr = yr + (tilt > 0.0 ? highr * tilt : lowr * (-tilt));\n    yr *= makeup;\n\n    let ol: f32 = xl * dry + yl * mix;\n    let orr: f32 = xr * dry + yr * mix;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[i] = ol;\n    outBuf[MAX_FRAMES + i] = orr;\n  }\n}\n",
  "publishedAt": 1751000169000
}