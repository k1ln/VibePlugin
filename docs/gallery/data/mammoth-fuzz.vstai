{
  "format": 1,
  "name": "Mammoth Fuzz",
  "isInstrument": false,
  "explanation": "A thick, sustaining fuzz. Two cascaded soft-clipping gain stages with inter-stage high-pass filtering deliver long sustain and rich harmonics, while a mid-scooped Tone control tilts the voice between dark/bassy and bright/cutting. Controls: Sustain, Tone, Volume and dry/wet Mix.",
  "params": [
    {
      "name": "Sustain",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Tone",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Volume",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Mammoth Fuzz</title>\n<style>\n:root{\n  --accent:#ff7a3c;\n  --accent2:#ffb454;\n  --enclosure:#2b6b5a;\n  --enclosure2:#1c4a3e;\n  --metal:#c9ccc7;\n  --bg:#0b0f0e;\n}\n*{box-sizing:border-box;margin:0;padding:0;}\nhtml,body{width:100%;height:100%;}\nbody{\n  background:\n    radial-gradient(120% 90% at 50% -10%, #14201d 0%, #060908 70%, #020403 100%);\n  font-family:\"Helvetica Neue\",Arial,sans-serif;\n  color:#e9e4d8;\n  display:flex;align-items:center;justify-content:center;\n  overflow:hidden;\n  -webkit-user-select:none;user-select:none;\n  touch-action:none;\n}\n\n/* ===== woolly fuzz texture backdrop ===== */\n.fuzz-bg{\n  position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden;\n  opacity:.5;\n}\n.fuzz-bg span{\n  position:absolute;border-radius:50%;\n  background:radial-gradient(circle at 35% 35%, rgba(255,180,84,.22), rgba(255,122,60,.05) 60%, transparent 72%);\n  filter:blur(6px);\n  animation:drift linear infinite;\n}\n@keyframes drift{\n  0%{transform:translate3d(0,0,0) scale(1);}\n  50%{transform:translate3d(var(--dx),var(--dy),0) scale(1.25);}\n  100%{transform:translate3d(0,0,0) scale(1);}\n}\n\n/* ===== pedal enclosure ===== */\n.pedal{\n  position:relative;z-index:2;\n  width:340px;\n  padding:26px 26px 30px;\n  border-radius:18px;\n  background:\n    linear-gradient(180deg, var(--enclosure) 0%, var(--enclosure2) 100%);\n  box-shadow:\n    inset 0 2px 0 rgba(255,255,255,.18),\n    inset 0 -8px 22px rgba(0,0,0,.55),\n    inset 0 0 60px rgba(0,0,0,.25),\n    0 28px 60px rgba(0,0,0,.7),\n    0 4px 0 #0d2620;\n  border:1px solid rgba(0,0,0,.4);\n}\n/* brushed-metal sheen overlay */\n.pedal::before{\n  content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n  background:\n    repeating-linear-gradient(115deg, rgba(255,255,255,.035) 0 2px, transparent 2px 5px);\n  mix-blend-mode:overlay;\n}\n/* moving specular highlight */\n.pedal::after{\n  content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n  background:linear-gradient(115deg, transparent 30%, rgba(255,255,255,.10) 48%, transparent 62%);\n  background-size:300% 100%;\n  animation:sheen 7s ease-in-out infinite;\n}\n@keyframes sheen{0%,100%{background-position:160% 0;}50%{background-position:-60% 0;}}\n\n/* corner screws */\n.screw{\n  position:absolute;width:16px;height:16px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%, #f2f2ee, #8a8d88 55%, #4c4f4a 100%);\n  box-shadow:0 1px 2px rgba(0,0,0,.6), inset 0 0 2px rgba(0,0,0,.5);\n}\n.screw::before{\n  content:\"\";position:absolute;inset:3px;border-radius:50%;\n  background:linear-gradient(0deg,#5b5e58,#9a9d97);\n}\n.screw::after{\n  content:\"\";position:absolute;left:50%;top:50%;width:11px;height:2px;\n  background:#2a2c28;border-radius:1px;\n  transform:translate(-50%,-50%) rotate(var(--rot,40deg));\n  box-shadow:0 1px 0 rgba(255,255,255,.2);\n}\n.screw.tl{top:9px;left:9px;--rot:35deg;}\n.screw.tr{top:9px;right:9px;--rot:-50deg;}\n.screw.bl{bottom:9px;left:9px;--rot:-25deg;}\n.screw.br{bottom:9px;right:9px;--rot:60deg;}\n\n/* ===== silkscreen nameplate ===== */\n.nameplate{position:relative;text-align:center;margin:4px 0 18px;}\n.brand{\n  font-size:10px;letter-spacing:.42em;text-transform:uppercase;\n  color:rgba(255,255,255,.55);margin-bottom:4px;text-indent:.42em;\n}\n.title{\n  font-family:\"Arial Black\",\"Helvetica Neue\",sans-serif;\n  font-weight:900;font-style:italic;\n  font-size:34px;line-height:.92;letter-spacing:-1px;\n  text-transform:uppercase;\n  background:linear-gradient(180deg,#fff,var(--accent2) 55%,var(--accent));\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  -webkit-text-stroke:.6px rgba(0,0,0,.25);\n  filter:drop-shadow(0 2px 1px rgba(0,0,0,.5));\n}\n.title .big{font-size:46px;}\n.tag{\n  margin-top:6px;font-size:8.5px;letter-spacing:.28em;text-transform:uppercase;\n  color:rgba(255,255,255,.45);\n}\n\n/* ===== knob row ===== */\n.knobs{display:grid;grid-template-columns:1fr 1fr;gap:22px 26px;margin:6px 6px 22px;}\n.knob-cell{display:flex;flex-direction:column;align-items:center;}\n.knob{\n  position:relative;width:78px;height:78px;cursor:grab;touch-action:none;\n}\n.knob:active{cursor:grabbing;}\n.knob .base{\n  position:absolute;inset:0;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 18%, #4a4d49 0%, #2a2c29 40%, #161817 100%);\n  box-shadow:0 6px 12px rgba(0,0,0,.6), inset 0 2px 3px rgba(255,255,255,.12);\n}\n/* rubber knob cap with ridges */\n.knob .cap{\n  position:absolute;inset:9px;border-radius:50%;\n  background:\n    radial-gradient(circle at 38% 30%, #3c3e3b, #1a1c1a 70%, #0c0d0c 100%);\n  box-shadow:inset 0 3px 6px rgba(255,255,255,.10), inset 0 -6px 10px rgba(0,0,0,.7), 0 2px 4px rgba(0,0,0,.5);\n}\n.knob .cap::before{\n  content:\"\";position:absolute;inset:0;border-radius:50%;\n  background:repeating-conic-gradient(from 0deg, rgba(255,255,255,.05) 0 4deg, transparent 4deg 12deg);\n}\n/* rotating pointer group */\n.knob .dial{position:absolute;inset:0;will-change:transform;}\n.knob .tick{\n  position:absolute;left:50%;top:7px;width:4px;height:24px;margin-left:-2px;\n  border-radius:2px;\n  background:linear-gradient(180deg,var(--accent2),var(--accent));\n  box-shadow:0 0 7px var(--accent), 0 0 2px #fff;\n}\n/* dotted tick scale */\n.scale{position:absolute;inset:-7px;border-radius:50%;pointer-events:none;}\n.scale i{\n  position:absolute;left:50%;top:0;width:2px;height:5px;margin-left:-1px;\n  background:rgba(255,255,255,.35);transform-origin:1px 46px;\n}\n.scale i.on{background:var(--accent2);box-shadow:0 0 4px var(--accent);}\n.k-name{margin-top:9px;font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:rgba(255,255,255,.72);}\n.k-val{margin-top:2px;font-size:13px;font-weight:700;color:var(--accent2);font-variant-numeric:tabular-nums;\n  text-shadow:0 0 6px rgba(255,180,84,.5);}\n\n/* ===== footswitch + LED bar ===== */\n.foot-row{display:flex;align-items:center;justify-content:space-between;padding:0 14px;}\n.led-wrap{display:flex;flex-direction:column;align-items:center;gap:6px;width:64px;}\n.led{\n  width:14px;height:14px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%, #5a1500, #2a0a00);\n  box-shadow:inset 0 0 3px rgba(0,0,0,.8);transition:background .15s;\n}\n.led.on{\n  background:radial-gradient(circle at 35% 30%, #fff, var(--accent2) 40%, var(--accent) 75%);\n  box-shadow:0 0 10px var(--accent), 0 0 22px rgba(255,122,60,.7), inset 0 0 4px #fff;\n  animation:ledpulse 1.6s ease-in-out infinite;\n}\n@keyframes ledpulse{0%,100%{filter:brightness(1);}50%{filter:brightness(1.35);}}\n.led-lbl{font-size:7.5px;letter-spacing:.2em;color:rgba(255,255,255,.45);text-transform:uppercase;}\n\n.footswitch{\n  position:relative;width:96px;height:96px;border-radius:50%;cursor:pointer;\n  background:radial-gradient(circle at 50% 28%, #d6d9d4, #9a9d98 45%, #5b5e59 100%);\n  box-shadow:0 8px 16px rgba(0,0,0,.6), inset 0 2px 3px rgba(255,255,255,.5), inset 0 -6px 10px rgba(0,0,0,.4);\n  display:flex;align-items:center;justify-content:center;\n  transition:transform .09s ease, box-shadow .09s ease;\n}\n.footswitch .stem{\n  width:46px;height:46px;border-radius:50%;\n  background:radial-gradient(circle at 45% 35%, #f4f5f2, #b9bcb7 50%, #6c6f6a 100%);\n  box-shadow:inset 0 2px 3px rgba(255,255,255,.7), inset 0 -4px 8px rgba(0,0,0,.45), 0 2px 4px rgba(0,0,0,.4);\n}\n.footswitch.pressed{transform:translateY(4px) scale(.97);box-shadow:0 3px 7px rgba(0,0,0,.6), inset 0 2px 4px rgba(0,0,0,.4);}\n.footswitch::after{\n  content:\"\";position:absolute;inset:-6px;border-radius:50%;\n  border:2px solid rgba(0,0,0,.25);\n}\n\n/* ribbed jack plates */\n.jacks{display:flex;flex-direction:column;align-items:center;gap:5px;width:64px;}\n.jack{width:24px;height:24px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%, #4a4d48, #161816 70%);\n  box-shadow:inset 0 0 4px rgba(0,0,0,.9), 0 1px 0 rgba(255,255,255,.1);}\n.jack i{display:block;width:8px;height:8px;border-radius:50%;margin:8px auto;background:#000;box-shadow:inset 0 0 3px rgba(255,255,255,.15);}\n.jacks .jlbl{font-size:7px;letter-spacing:.15em;color:rgba(255,255,255,.4);text-transform:uppercase;}\n\n.bypass-note{text-align:center;margin-top:14px;font-size:8px;letter-spacing:.25em;text-transform:uppercase;color:rgba(255,255,255,.35);}\n</style>\n</head>\n<body>\n<div class=\"fuzz-bg\" id=\"fuzzbg\"></div>\n\n<div class=\"pedal\" id=\"pedal\">\n  <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n  <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n  <div class=\"nameplate\">\n    <div class=\"brand\">Boutique &middot; Tone Co.</div>\n    <div class=\"title\"><span class=\"big\">M</span>ammoth <span class=\"big\">F</span>uzz</div>\n    <div class=\"tag\">Cascaded Sustaining Fuzz</div>\n  </div>\n\n  <div class=\"knobs\" id=\"knobs\"></div>\n\n  <div class=\"foot-row\">\n    <div class=\"jacks\">\n      <div class=\"jack\"><i></i></div><div class=\"jlbl\">In</div>\n    </div>\n    <div class=\"footswitch\" id=\"footswitch\"><div class=\"stem\"></div></div>\n    <div class=\"led-wrap\">\n      <div class=\"led on\" id=\"led\"></div><div class=\"led-lbl\">On</div>\n    </div>\n  </div>\n  <div class=\"bypass-note\">True&nbsp;Bypass &mdash; Tap&nbsp;Footswitch</div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n  var PARAMS=[\n    {name:\"Sustain\",index:0,min:0,max:1,def:0.7},\n    {name:\"Tone\",   index:1,min:0,max:1,def:0.5},\n    {name:\"Volume\", index:2,min:0,max:1,def:0.6},\n    {name:\"Mix\",    index:3,min:0,max:1,def:1}\n  ];\n  var MINA=-135, MAXA=135; // sweep degrees\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmt(p,v){ return Math.round((v-p.min)/(p.max-p.min)*100)+\"%\"; }\n\n  // build woolly background blobs\n  (function(){\n    var bg=document.getElementById('fuzzbg'),f=document.createDocumentFragment();\n    for(var i=0;i<14;i++){\n      var s=document.createElement('span');\n      var sz=60+Math.random()*160;\n      s.style.width=s.style.height=sz+'px';\n      s.style.left=(Math.random()*100)+'%';\n      s.style.top=(Math.random()*100)+'%';\n      s.style.setProperty('--dx',(Math.random()*60-30)+'px');\n      s.style.setProperty('--dy',(Math.random()*60-30)+'px');\n      s.style.animationDuration=(8+Math.random()*10)+'s';\n      s.style.animationDelay=(-Math.random()*10)+'s';\n      f.appendChild(s);\n    }\n    bg.appendChild(f);\n  })();\n\n  var knobsEl=document.getElementById('knobs');\n  var controls=[];\n\n  PARAMS.forEach(function(p){\n    var cell=document.createElement('div');cell.className='knob-cell';\n    var k=document.createElement('div');k.className='knob';k.tabIndex=-1;\n    k.innerHTML=\n      '<div class=\"base\"></div>'+\n      '<div class=\"scale\"></div>'+\n      '<div class=\"cap\"></div>'+\n      '<div class=\"dial\"><div class=\"tick\"></div></div>';\n    var name=document.createElement('div');name.className='k-name';name.textContent=p.name;\n    var val=document.createElement('div');val.className='k-val';\n    cell.appendChild(k);cell.appendChild(name);cell.appendChild(val);\n    knobsEl.appendChild(cell);\n\n    // build tick scale\n    var scale=k.querySelector('.scale');\n    var N=11;\n    for(var t=0;t<N;t++){\n      var i=document.createElement('i');\n      var ang=MINA+(MAXA-MINA)*(t/(N-1));\n      i.style.transform='rotate('+ang+'deg)';\n      i.dataset.ang=ang;\n      scale.appendChild(i);\n    }\n\n    var dial=k.querySelector('.dial');\n    var ctl={p:p,dial:dial,val:val,scale:scale,value:p.def};\n\n    function render(v){\n      ctl.value=v;\n      var norm=(v-p.min)/(p.max-p.min);\n      var deg=MINA+(MAXA-MINA)*norm;\n      dial.style.transform='rotate('+deg+'deg)';\n      val.textContent=fmt(p,v);\n      // light up scale ticks up to current\n      var lit=scale.querySelectorAll('i');\n      for(var j=0;j<lit.length;j++){\n        var a=+lit[j].dataset.ang;\n        if(a<=deg+0.5) lit[j].classList.add('on'); else lit[j].classList.remove('on');\n      }\n    }\n    function set(v,emit){\n      v=Math.max(p.min,Math.min(p.max,v));\n      render(v);\n      if(emit) send(p.index,v);\n    }\n    ctl.set=set;\n\n    // pointer drag (vertical)\n    var dragging=false,startY=0,startV=0;\n    k.addEventListener('pointerdown',function(e){\n      dragging=true;startY=e.clientY;startV=ctl.value;\n      k.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    k.addEventListener('pointermove',function(e){\n      if(!dragging)return;\n      var dy=startY-e.clientY;\n      var span=p.max-p.min;\n      var fine=e.shiftKey?0.25:1;\n      set(startV+(dy/180)*span*fine,true);\n    });\n    function endDrag(e){ if(dragging){dragging=false;try{k.releasePointerCapture(e.pointerId);}catch(_){}}}\n    k.addEventListener('pointerup',endDrag);\n    k.addEventListener('pointercancel',endDrag);\n    // wheel\n    k.addEventListener('wheel',function(e){\n      e.preventDefault();\n      var span=p.max-p.min;\n      set(ctl.value-(e.deltaY>0?1:-1)*span*0.04,true);\n    },{passive:false});\n    // double-click reset\n    k.addEventListener('dblclick',function(){ set(p.def,true); });\n\n    controls.push(ctl);\n  });\n\n  // footswitch / bypass (visual only — does not touch params)\n  var fs=document.getElementById('footswitch'),led=document.getElementById('led'),on=true;\n  fs.addEventListener('pointerdown',function(){fs.classList.add('pressed');});\n  function relFs(){fs.classList.remove('pressed');}\n  fs.addEventListener('pointerup',relFs);\n  fs.addEventListener('pointercancel',relFs);\n  fs.addEventListener('click',function(){\n    on=!on; led.classList.toggle('on',on);\n    document.getElementById('pedal').style.filter=on?'':'saturate(.4) brightness(.85)';\n  });\n\n  function ready(){ controls.forEach(function(c){ c.set(c.p.def,true); }); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MAMMOTH FUZZ — thick, sustaining fuzz\n//  Two cascaded soft-clipping gain stages with an inter-stage high-pass\n//  filter (the classic four-transistor sustaining-fuzz topology). The\n//  Sustain control drives both stages hard for long, singing sustain and\n//  rich harmonics; a mid-scooped Tone control tilts the voice between a\n//  bassy/dark and a bright/cutting setting. Output level and dry/wet Mix\n//  finish the chain. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst inHpState:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // input HP (LP for subtraction)\nconst mid1State:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // inter-stage HP after stage 1\nconst mid2State:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // inter-stage HP after stage 2\nconst dcState:      StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post DC-block (LP)\nconst toneLowState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone low-pass branch\nconst toneHiState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone high-pass branch (LP for subtraction)\n\nconst P_SUSTAIN: i32 = 0; // 0..1 -> input gain into the two stages\nconst P_TONE: i32 = 1;    // 0..1 -> scooped: 0 = bassy/dark, 1 = bright/trebly\nconst P_VOLUME: i32 = 2;  // 0..1 -> 0..1.2 output level\nconst P_MIX: i32 = 3;     // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    inHpState[c] = 0.0; mid1State[c] = 0.0; mid2State[c] = 0.0;\n    dcState[c] = 0.0; toneLowState[c] = 0.0; toneHiState[c] = 0.0;\n  }\n  params[P_SUSTAIN] = 0.7; params[P_TONE] = 0.5; params[P_VOLUME] = 0.6; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// one-pole low-pass coefficient for a given corner (Hz)\n@inline function lpCoef(hz: f32, sr: f32): f32 {\n  return f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * hz / sr));\n}\n\n// asymmetric soft clip — like a clamped diode pair, saturates smoothly to ~±1.\n// A touch of asymmetry adds even harmonics for a thicker, more vocal fuzz.\n@inline function fuzzClip(x: f32): f32 {\n  const c: f32 = clampf(x, -1.3, 1.3);\n  // tanh-style via rational approx, stays in f32 and is cheap\n  const y: f32 = f32(c / (1.0 + 0.28 * c * c));\n  // small even-harmonic bias\n  return f32(y + 0.06 * y * y);\n}\n\nexport function process(n: i32): void {\n  const sus: f32 = clampf(params[P_SUSTAIN], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const volume: f32 = clampf(params[P_VOLUME], 0.0, 1.0) * 1.2;\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Input gain into stage 1: musical 2..120x. High end gives sustain & buzz.\n  const drive1: f32 = 2.0 + sus * sus * 118.0;\n  // Stage 2 adds further squashing; scales gently with sustain.\n  const drive2: f32 = 3.0 + sus * 9.0;\n\n  // Filters\n  const cIn: f32 = lpCoef(80.0, sampleRate);    // input HP corner ~80 Hz (tighten before clip)\n  const cMid1: f32 = lpCoef(180.0, sampleRate); // inter-stage HP ~180 Hz\n  const cMid2: f32 = lpCoef(150.0, sampleRate); // second inter-stage HP ~150 Hz\n  const cDc: f32 = lpCoef(20.0, sampleRate);    // DC block\n\n  // Tone: scooped tilt. Low branch = LP at ~700 Hz, high branch = HP at ~1.5 kHz.\n  // toneN tilts the blend; the centre is scooped (both branches reduced).\n  const cToneLow: f32 = lpCoef(700.0, sampleRate);\n  const cToneHi: f32 = lpCoef(1500.0, sampleRate);\n  const lowGain: f32 = f32(1.0 - toneN) * 1.0;      // more low when toneN small\n  const hiGain: f32 = toneN * 1.0;                   // more high when toneN large\n  // scoop: subtract a little of the mid so the centre dips\n  const midScoop: f32 = 0.65;\n\n  // gain compensation so Sustain doesn't just get louder\n  const comp: f32 = f32(1.0 / Mathf.sqrt(drive1 * 0.5 + 1.0));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let inLp: f32 = inHpState[c];\n    let m1: f32 = mid1State[c];\n    let m2: f32 = mid2State[c];\n    let dc: f32 = dcState[c];\n    let tl: f32 = toneLowState[c];\n    let th: f32 = toneHiState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // input high-pass (tighten lows before first stage)\n      inLp = inLp + cIn * (x - inLp);\n      const hpIn: f32 = x - inLp;\n\n      // STAGE 1: drive + soft clip\n      const s1: f32 = fuzzClip(hpIn * drive1);\n\n      // inter-stage high-pass 1\n      m1 = m1 + cMid1 * (s1 - m1);\n      const hp1: f32 = s1 - m1;\n\n      // STAGE 2: drive + soft clip\n      const s2: f32 = fuzzClip(hp1 * drive2);\n\n      // inter-stage high-pass 2\n      m2 = m2 + cMid2 * (s2 - m2);\n      const hp2: f32 = s2 - m2;\n\n      // DC block\n      dc = dc + cDc * (hp2 - dc);\n      const clean: f32 = (hp2 - dc) * comp;\n\n      // TONE: scooped tilt between low and high branches\n      tl = tl + cToneLow * (clean - tl);     // low-passed (bassy) content\n      th = th + cToneHi * (clean - th);\n      const highContent: f32 = clean - th;   // high-passed (trebly) content\n      const lowContent: f32 = tl;\n      const midContent: f32 = th - tl;       // band between corners (the \"mid\")\n      const toned: f32 = lowContent * lowGain + highContent * hiGain - midContent * midScoop;\n\n      const wet: f32 = toned * volume * 5.5;\n      const outv: f32 = x * (1.0 - mix) + wet * mix;\n      outBuf[base + f] = clampf(outv, -1.2, 1.2);\n    }\n\n    inHpState[c] = inLp;\n    mid1State[c] = m1;\n    mid2State[c] = m2;\n    dcState[c] = dc;\n    toneLowState[c] = tl;\n    toneHiState[c] = th;\n  }\n}\n",
  "publishedAt": 1751000007000
}