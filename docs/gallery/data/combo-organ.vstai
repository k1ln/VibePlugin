  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Combo Organ</title>\n<style>\n  :root{\n    --accent:#ff5c6e;\n    --accent2:#ffd0d6;\n    --panel:#1d1116;\n    --panel2:#2a161c;\n    --cream:#f3e7d6;\n    --chrome1:#e9eef2;\n    --chrome2:#9aa6ad;\n    --chrome3:#5a6469;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none}\n  html,body{margin:0;height:100%}\n  body{\n    font-family:\"Futura\",\"Avenir Next\",Helvetica,Arial,sans-serif;\n    background:\n      radial-gradient(120% 80% at 50% -10%, #3a1f27 0%, #1a0d11 55%, #0c0608 100%);\n    color:var(--cream);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100%;padding:26px 18px 40px;\n    overflow:hidden;\n  }\n\n  /* ---- the organ cabinet ---- */\n  .organ{position:relative;width:660px;max-width:96vw;}\n  .cabinet{\n    position:relative;\n    border-radius:18px 18px 10px 10px;\n    padding:20px 22px 26px;\n    background:\n      linear-gradient(180deg,#36202a 0%, #2a161c 42%, #200f15 100%);\n    box-shadow:\n      0 28px 60px -18px rgba(0,0,0,.8),\n      0 2px 0 rgba(255,255,255,.06) inset,\n      0 -22px 40px -30px rgba(255,92,110,.5) inset;\n    border:1px solid #120a0d;\n  }\n  /* top brushed strip + logo */\n  .topbar{\n    display:flex;align-items:center;justify-content:space-between;\n    margin-bottom:16px;\n  }\n  .logo{\n    display:flex;align-items:baseline;gap:9px;\n    letter-spacing:.18em;\n  }\n  .logo .mark{\n    font-weight:800;font-size:22px;\n    color:var(--cream);\n    text-shadow:0 1px 0 #000, 0 0 14px rgba(255,92,110,.35);\n  }\n  .logo .mark b{color:var(--accent)}\n  .logo .sub{\n    font-size:9px;letter-spacing:.32em;color:#b79aa1;text-transform:uppercase;\n  }\n  .badge{\n    font-size:9px;letter-spacing:.28em;text-transform:uppercase;\n    color:#0c0608;background:linear-gradient(180deg,var(--accent2),#ffb7c0);\n    padding:5px 11px;border-radius:20px;font-weight:700;\n    box-shadow:0 2px 6px rgba(0,0,0,.4), 0 1px 0 rgba(255,255,255,.6) inset;\n  }\n\n  /* ---- tab console (the rocker bank) ---- */\n  .console{\n    background:\n      linear-gradient(180deg,#0e0709 0%, #160b0f 100%);\n    border-radius:10px;\n    padding:16px 16px 18px;\n    border:1px solid #0a0507;\n    box-shadow:0 10px 26px -10px rgba(0,0,0,.7) inset, 0 1px 0 rgba(255,255,255,.04);\n  }\n  .tabs{\n    display:grid;\n    grid-template-columns:repeat(7,1fr);\n    gap:12px;\n  }\n  @media (max-width:560px){ .tabs{grid-template-columns:repeat(4,1fr)} }\n\n  .tab{position:relative;display:flex;flex-direction:column;align-items:center;gap:8px;}\n  .tab .rock{\n    position:relative;width:100%;height:108px;border-radius:7px;\n    background:linear-gradient(180deg,#241318,#160c0f);\n    box-shadow:0 6px 14px -6px rgba(0,0,0,.7) inset;\n    padding:6px;cursor:grab;touch-action:none;\n    border:1px solid #0a0506;\n  }\n  .tab .rock:active{cursor:grabbing}\n  /* the cream lever face that tilts */\n  .cap{\n    position:absolute;left:6px;right:6px;\n    height:62px;border-radius:6px;\n    background:linear-gradient(180deg,var(--cream),#d8c6b0);\n    box-shadow:0 4px 8px rgba(0,0,0,.45), 0 1px 0 rgba(255,255,255,.8) inset;\n    transition:transform .12s cubic-bezier(.3,1.4,.5,1);\n    transform-origin:center bottom;\n    display:flex;align-items:center;justify-content:center;\n    overflow:hidden;\n  }\n  /* the lit colour band that grows with value */\n  .lit{\n    position:absolute;left:6px;right:6px;bottom:6px;\n    border-radius:6px;\n    background:linear-gradient(180deg,var(--accent),#c43448);\n    box-shadow:0 0 16px rgba(255,92,110,.55), 0 1px 0 rgba(255,255,255,.35) inset;\n    transition:height .04s linear, opacity .15s;\n    height:0;\n  }\n  .tab.color2 .lit{background:linear-gradient(180deg,#9aa6ff,#5566cc);box-shadow:0 0 16px rgba(120,140,255,.5)}\n  .tab.color3 .lit{background:linear-gradient(180deg,var(--accent2),#ff8da0);box-shadow:0 0 16px rgba(255,160,180,.5)}\n  .cap .ft{\n    font-size:14px;font-weight:800;color:#23121a;letter-spacing:.04em;\n  }\n  .tab .name{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:#caa9b1;font-weight:700}\n  .tab .val{font-size:10px;color:var(--accent2);font-variant-numeric:tabular-nums;min-height:12px}\n  .tab.color2 .val{color:#aeb6ff}\n  .tab.color3 .val{color:var(--accent2)}\n\n  /* ---- vibrato section with the wobbling toggle ---- */\n  .vibrato{\n    margin-top:16px;\n    display:grid;grid-template-columns:auto 1fr 1fr;gap:18px;align-items:center;\n    background:linear-gradient(180deg,#2a161c,#1c0f14);\n    border-radius:10px;padding:14px 18px;border:1px solid #0a0506;\n    box-shadow:0 1px 0 rgba(255,255,255,.04) inset;\n  }\n  .vibToggle{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .rocker{\n    width:74px;height:34px;border-radius:20px;cursor:pointer;\n    background:linear-gradient(180deg,#160b0f,#241318);\n    box-shadow:0 4px 9px -4px rgba(0,0,0,.7) inset;\n    position:relative;border:1px solid #0a0506;\n  }\n  .rocker .knob{\n    position:absolute;top:3px;left:3px;width:28px;height:28px;border-radius:50%;\n    background:linear-gradient(180deg,var(--chrome1),var(--chrome2) 60%,var(--chrome3));\n    box-shadow:0 2px 5px rgba(0,0,0,.5), 0 1px 0 rgba(255,255,255,.7) inset;\n    transition:left .18s cubic-bezier(.3,1.5,.5,1), background .2s;\n  }\n  .rocker.on{background:linear-gradient(180deg,#5a1b27,#7a2030)}\n  .rocker.on .knob{\n    left:43px;\n    background:linear-gradient(180deg,#fff,var(--accent));\n    box-shadow:0 0 14px rgba(255,92,110,.7), 0 1px 0 rgba(255,255,255,.8) inset;\n  }\n  .vibToggle.on{ animation:wobble 1.05s ease-in-out infinite }\n  @keyframes wobble{\n    0%,100%{transform:rotate(0deg) translateY(0)}\n    25%{transform:rotate(-2.2deg) translateY(-1px)}\n    50%{transform:rotate(0deg) translateY(0)}\n    75%{transform:rotate(2.2deg) translateY(-1px)}\n  }\n  .vibLabel{font-size:9px;letter-spacing:.22em;text-transform:uppercase;color:#caa9b1;font-weight:700}\n\n  /* round chrome knobs for depth/rate */\n  .knobctl{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .dial{\n    width:62px;height:62px;border-radius:50%;cursor:grab;touch-action:none;\n    background:\n      radial-gradient(circle at 50% 38%, #fff 0%, var(--chrome2) 55%, var(--chrome3) 100%);\n    box-shadow:0 5px 12px -3px rgba(0,0,0,.65), 0 1px 0 rgba(255,255,255,.7) inset;\n    position:relative;border:2px solid #1a1014;\n  }\n  .dial:active{cursor:grabbing}\n  .dial .ptr{\n    position:absolute;left:50%;top:7px;width:3px;height:20px;border-radius:2px;\n    background:var(--accent);transform-origin:50% 24px;\n    box-shadow:0 0 6px rgba(255,92,110,.8);\n  }\n  .dial .ring{\n    position:absolute;inset:-9px;border-radius:50%;pointer-events:none;\n  }\n  .knobctl .name{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#caa9b1;font-weight:700}\n  .knobctl .val{font-size:10px;color:var(--accent2);font-variant-numeric:tabular-nums}\n\n  /* ---- master row: tone + level ---- */\n  .master{\n    margin-top:16px;display:grid;grid-template-columns:1fr 1fr;gap:18px;\n  }\n  .slot{\n    background:linear-gradient(180deg,#2a161c,#1c0f14);border-radius:10px;\n    padding:14px 18px;border:1px solid #0a0506;display:flex;align-items:center;gap:16px;\n    box-shadow:0 1px 0 rgba(255,255,255,.04) inset;\n  }\n\n  /* ---- chrome legs hint ---- */\n  .legs{position:relative;height:34px;margin-top:-4px}\n  .leg{\n    position:absolute;top:0;width:9px;height:34px;border-radius:0 0 5px 5px;\n    background:linear-gradient(90deg,var(--chrome3),var(--chrome1) 50%,var(--chrome3));\n    box-shadow:0 8px 12px -6px rgba(0,0,0,.7);\n  }\n  .leg.l{left:46px;transform:skewX(8deg)} .leg.r{right:46px;transform:skewX(-8deg)}\n  .leg::after{content:\"\";position:absolute;bottom:-5px;left:-3px;width:15px;height:6px;border-radius:50%;\n    background:radial-gradient(circle,#000 0%,transparent 70%)}\n\n  .footer{margin-top:14px;text-align:center;font-size:8.5px;letter-spacing:.3em;\n    color:#7a5a62;text-transform:uppercase}\n</style>\n</head>\n<body>\n  <div class=\"organ\">\n    <div class=\"cabinet\">\n      <div class=\"topbar\">\n        <div class=\"logo\">\n          <span class=\"mark\">COMBO<b>·</b>ORGAN</span>\n          <span class=\"sub\">Transistor · Divide-Down</span>\n        </div>\n        <span class=\"badge\">Combo 60</span>\n      </div>\n\n      <div class=\"console\">\n        <div class=\"tabs\" id=\"tabs\"></div>\n\n        <div class=\"vibrato\">\n          <div class=\"vibToggle\" id=\"vibToggle\">\n            <div class=\"rocker\" id=\"vibRocker\"><div class=\"knob\"></div></div>\n            <span class=\"vibLabel\">Vibrato</span>\n          </div>\n          <div class=\"knobctl\" data-dial=\"3\">\n            <div class=\"dial\" id=\"dial3\"><div class=\"ptr\"></div><svg class=\"ring\" viewBox=\"0 0 80 80\"><circle id=\"ring3\" cx=\"40\" cy=\"40\" r=\"36\" fill=\"none\" stroke=\"#ff5c6e\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\".85\"/></svg></div>\n            <span class=\"name\">Depth</span><span class=\"val\" id=\"val3\"></span>\n          </div>\n          <div class=\"knobctl\" data-dial=\"4\">\n            <div class=\"dial\" id=\"dial4\"><div class=\"ptr\"></div><svg class=\"ring\" viewBox=\"0 0 80 80\"><circle id=\"ring4\" cx=\"40\" cy=\"40\" r=\"36\" fill=\"none\" stroke=\"#ffd0d6\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\".85\"/></svg></div>\n            <span class=\"name\">Rate</span><span class=\"val\" id=\"val4\"></span>\n          </div>\n        </div>\n\n        <div class=\"master\">\n          <div class=\"slot knobctl\" data-dial=\"5\" style=\"flex-direction:row;justify-content:center\">\n            <div class=\"dial\" id=\"dial5\"><div class=\"ptr\"></div><svg class=\"ring\" viewBox=\"0 0 80 80\"><circle id=\"ring5\" cx=\"40\" cy=\"40\" r=\"36\" fill=\"none\" stroke=\"#ff5c6e\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\".85\"/></svg></div>\n            <div><div class=\"name\">Tone</div><div class=\"val\" id=\"val5\"></div></div>\n          </div>\n          <div class=\"slot knobctl\" data-dial=\"6\" style=\"flex-direction:row;justify-content:center\">\n            <div class=\"dial\" id=\"dial6\"><div class=\"ptr\"></div><svg class=\"ring\" viewBox=\"0 0 80 80\"><circle id=\"ring6\" cx=\"40\" cy=\"40\" r=\"36\" fill=\"none\" stroke=\"#ffd0d6\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\".85\"/></svg></div>\n            <div><div class=\"name\">Level</div><div class=\"val\" id=\"val6\"></div></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"footer\">Polyphonic · Plays via host MIDI</div>\n    </div>\n    <div class=\"legs\"><div class=\"leg l\"></div><div class=\"leg r\"></div></div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n  // ---- host bridge ----\n  var HOST = (window.vstai && typeof window.vstai.setParam === \"function\") ? window.vstai : null;\n  function setParam(i,v){ if(HOST) HOST.setParam(i, v); }\n\n  // ---- param model ----\n  var P = [\n    {i:0, name:\"16′ Bass\",  ft:\"16′\", def:0.70, col:\"\"      , type:\"tab\"},\n    {i:1, name:\"8′ Mid\",    ft:\"8′\",  def:0.85, col:\"\"      , type:\"tab\"},\n    {i:2, name:\"4′ Bright\", ft:\"4′\",  def:0.60, col:\"color3\", type:\"tab\"},\n    {i:3, name:\"Depth\",     def:0.35, type:\"dial\"},\n    {i:4, name:\"Rate\",      def:0.45, type:\"dial\"},\n    {i:5, name:\"Tone\",      def:0.60, type:\"dial\"},\n    {i:6, name:\"Level\",     def:0.50, type:\"dial\"}\n  ];\n  var value = {};\n\n  function fmt(v){ return Math.round(v*100) + \"%\"; }\n\n  // ---- TABS ----\n  var tabHost = document.getElementById(\"tabs\");\n  P.forEach(function(p){\n    if(p.type!==\"tab\") return;\n    var el = document.createElement(\"div\");\n    el.className = \"tab \" + (p.col||\"\");\n    el.innerHTML =\n      '<div class=\"rock\" data-i=\"'+p.i+'\">'+\n        '<div class=\"lit\"></div>'+\n        '<div class=\"cap\"><span class=\"ft\">'+p.ft+'</span></div>'+\n      '</div>'+\n      '<div class=\"name\">'+p.name+'</div>'+\n      '<div class=\"val\" id=\"val'+p.i+'\"></div>';\n    tabHost.appendChild(el);\n  });\n\n  function paintTab(p){\n    var v = value[p.i];\n    var rock = tabHost.querySelector('.rock[data-i=\"'+p.i+'\"]');\n    if(!rock) return;\n    var lit = rock.querySelector('.lit');\n    var cap = rock.querySelector('.cap');\n    // available travel inside rock (108 - pads 12 - lit min)\n    var H = 96; // px region\n    lit.style.height = (8 + v*78) + \"px\";\n    lit.style.opacity = v>0.01 ? 1 : 0.25;\n    // cap tilts: high value = lever pressed up (rocked on), brighter\n    var tilt = (v-0.5)*-9; // degrees\n    cap.style.transform = \"translateY(\"+ (2 - v*4) +\"px) rotateX(\"+ tilt +\"deg)\";\n    document.getElementById(\"val\"+p.i).textContent = fmt(v);\n  }\n\n  // ---- DIALS ----\n  function paintDial(p){\n    var v = value[p.i];\n    var dial = document.getElementById(\"dial\"+p.i);\n    if(!dial) return;\n    var ptr = dial.querySelector(\".ptr\");\n    var deg = -135 + v*270;\n    ptr.style.transform = \"translateX(-50%) rotate(\"+deg+\"deg)\";\n    var ring = document.getElementById(\"ring\"+p.i);\n    if(ring){\n      var C = 2*Math.PI*36;\n      ring.style.strokeDasharray = C;\n      ring.style.strokeDashoffset = C*(1-v*0.75);\n      ring.setAttribute(\"transform\",\"rotate(135 40 40)\");\n    }\n    var vd = document.getElementById(\"val\"+p.i);\n    if(vd) vd.textContent = fmt(v);\n  }\n\n  function paint(p){ if(p.type===\"tab\") paintTab(p); else paintDial(p); }\n\n  function commit(p, v, send){\n    v = v<0?0:(v>1?1:v);\n    value[p.i] = v;\n    paint(p);\n    if(send!==false) setParam(p.i, v);\n  }\n\n  // ---- vibrato wobble toggle (depth>0 => on, animates) ----\n  var vibToggle = document.getElementById(\"vibToggle\");\n  var vibRocker = document.getElementById(\"vibRocker\");\n  var prevDepth = 0.35;\n  function syncVib(){\n    var on = value[3] > 0.01;\n    vibRocker.classList.toggle(\"on\", on);\n    vibToggle.classList.toggle(\"on\", on);\n    // sync animation speed to Rate\n    var hz = 4.5 + value[4]*3.0;\n    vibToggle.style.animationDuration = (1/hz*2).toFixed(3)+\"s\";\n  }\n  vibRocker.addEventListener(\"click\", function(){\n    var p = P[3];\n    if(value[3] > 0.01){ prevDepth = value[3]; commit(p, 0); }\n    else commit(p, prevDepth>0.01?prevDepth:0.35);\n    syncVib();\n  });\n\n  // ---- drag handling (shared) ----\n  function attachDrag(el, p, sens){\n    var startY, startV, dragging=false;\n    function down(e){\n      dragging=true; startY=(e.touches?e.touches[0].clientY:e.clientY); startV=value[p.i];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move); window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false}); window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      commit(p, startV + (startY-y)*sens);\n      if(p.i===3||p.i===4) syncVib();\n      e.preventDefault();\n    }\n    function up(){ dragging=false;\n      window.removeEventListener(\"mousemove\",move); window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move); window.removeEventListener(\"touchend\",up);\n    }\n    el.addEventListener(\"mousedown\",down);\n    el.addEventListener(\"touchstart\",down,{passive:false});\n    el.addEventListener(\"dblclick\",function(){ commit(p,p.def); if(p.i===3||p.i===4) syncVib(); });\n  }\n\n  // ---- init / wire ----\n  function start(){\n    P.forEach(function(p){ value[p.i]=p.def; });\n    P.forEach(function(p){\n      if(p.type===\"tab\"){\n        var rock = tabHost.querySelector('.rock[data-i=\"'+p.i+'\"]');\n        attachDrag(rock, p, 1/120);\n      } else {\n        attachDrag(document.getElementById(\"dial\"+p.i), p, 1/180);\n      }\n      commit(p, p.def);   // push default to host + paint\n    });\n    syncVib();\n  }\n\n  if(HOST && typeof HOST.onReady === \"function\") HOST.onReady(start);\n  else start();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  COMBO ORGAN — a 1960s transistor \"divide-down\" combo organ instrument.\n//  Each key fires a band-limited pulse oscillator whose octave taps are\n//  read off at three footages (16', 8', 4') plus a thin reedy upper-octave\n//  buzz, exactly like a divide-down organ where one master tone is divided\n//  into octaves and re-summed through bright drawbar/rocker tabs. A fast\n//  attack/release gate (no slow envelope — organs key instantly), a global\n//  scanner-style vibrato, and a one-pole tone tilt finish the voice.\n//  Polyphonic: voices are allocated per noteId so chords ring. The host\n//  passes frequency in Hz. Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 12;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----------------------\nconst P_BASS:    i32 = 0;  // 0..1  16' flute tab level\nconst P_MID:     i32 = 1;  // 0..1  8'  flute tab level\nconst P_BRIGHT:  i32 = 2;  // 0..1  4' + reed bright tab level\nconst P_VIBDEPTH:i32 = 3;  // 0..1  vibrato depth\nconst P_VIBRATE: i32 = 4;  // 0..1  vibrato rate\nconst P_TONE:    i32 = 5;  // 0..1  tone tilt (dark..bright)\nconst P_LEVEL:   i32 = 6;  // 0..1  output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) ------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // oldest-voice steal\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // fast gate env 0..1\n\n// four octave-tap phases per voice (16', 8', 4', 2' reed)\nconst vP16: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vP8:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vP4:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vP2:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// global vibrato scanner phase + tone-filter state (one per channel-free, mono sum)\nlet vibPhase: f32 = 0.0;\nlet toneState: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vEnv[v] = 0.0;\n    vP16[v] = 0.0; vP8[v] = 0.0; vP4[v] = 0.0; vP2[v] = 0.0;\n  }\n  ageCounter = 0;\n  vibPhase = 0.0;\n  toneState = 0.0;\n  params[P_BASS]     = 0.7;\n  params[P_MID]      = 0.85;\n  params[P_BRIGHT]   = 0.6;\n  params[P_VIBDEPTH] = 0.35;\n  params[P_VIBRATE]  = 0.45;\n  params[P_TONE]     = 0.6;\n  params[P_LEVEL]    = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// polyBLEP correction removes the worst aliasing on the pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\n// band-limited pulse of given duty cycle from the running phase\n@inline function blPulse(p: f32, inc: f32, pw: f32): f32 {\n  let sq: f32 = p < pw ? 1.0 : -1.0;\n  sq += polyBlep(p, inc);\n  let p2: f32 = p + (1.0 - pw);\n  if (p2 >= 1.0) p2 -= 1.0;\n  sq -= polyBlep(p2, inc);\n  return sq;\n}\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  // fresh phases, slightly offset so taps don't all phase-lock\n  vP16[slot] = 0.0; vP8[slot] = 0.12; vP4[slot] = 0.27; vP2[slot] = 0.41;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const bass:   f32 = clampf(params[P_BASS],   0.0, 1.0);\n  const mid:    f32 = clampf(params[P_MID],    0.0, 1.0);\n  const bright: f32 = clampf(params[P_BRIGHT], 0.0, 1.0);\n  const vibD:   f32 = clampf(params[P_VIBDEPTH],0.0, 1.0);\n  const vibR:   f32 = clampf(params[P_VIBRATE], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE],   0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // footage tab gains (the reed tab adds the buzzy 4'+2' upper octaves)\n  const g16: f32 = bass;\n  const g8:  f32 = mid;\n  const g4:  f32 = bright;            // 4' bright flute\n  const g2:  f32 = bright * 0.7;      // 2' reedy buzz, rides the bright tab\n\n  // vibrato: scanner 4.5 .. 7.5 Hz, depth up to ~+/-1.2% pitch\n  const vibHz:   f32 = 4.5 + vibR * 3.0;\n  const vibInc:  f32 = vibHz / sr;\n  const vibAmt:  f32 = vibD * 0.012;\n\n  // tone tilt: one-pole low-pass, 900 Hz (dark) .. 11 kHz (bright)\n  const toneHz:  f32 = 900.0 + toneN * toneN * 10100.0;\n  let toneG: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * toneHz / sr));\n  if (toneG > 0.99) toneG = 0.99;\n  // mix a little of the un-filtered signal back so very dark still has presence\n  const toneMix: f32 = 0.18 + 0.82 * toneN;\n\n  // fast organ gate: ~4 ms attack, ~12 ms release (instant, keyed)\n  const atkRate: f32 = 1.0 / (0.004 * sr);\n  const relRate: f32 = 1.0 / (0.012 * sr);\n\n  // sum-of-tabs normaliser so a full chord stays bounded\n  const tabSum: f32 = g16 + g8 + g4 + g2;\n  let tabNorm: f32 = 1.0 / (1.0 + tabSum);    // soft headroom per voice\n  const voiceScale: f32 = 0.42 * tabNorm;\n\n  let ts: f32 = toneState;\n  let vph: f32 = vibPhase;\n\n  for (let f = 0; f < n; f++) {\n    // advance global vibrato scanner\n    vph += vibInc; if (vph >= 1.0) vph -= 1.0;\n    const vib: f32 = 1.0 + vibAmt * f32(Mathf.sin(TWO_PI * vph));\n\n    let mixv: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- fast keyed gate (no slow ADSR; organs speak instantly) ----\n      let env: f32 = vEnv[v];\n      if (vGate[v] == 1) {\n        env += atkRate;\n        if (env > 1.0) env = 1.0;\n      } else {\n        env -= relRate;\n        if (env <= 0.0) {\n          env = 0.0;\n          vActive[v] = 0; vNote[v] = -1; vEnv[v] = 0.0;\n          continue;\n        }\n      }\n      vEnv[v] = env;\n\n      // ---- divide-down octave taps (one master pitch, octave divisions)\n      // 8' is the played pitch; 16' is an octave down, 4' / 2' octaves up.\n      const f8:  f32 = vFreq[v] * vib;\n      const inc8:  f32 = f8 / sr;\n      const inc16: f32 = inc8 * 0.5;\n      const inc4:  f32 = inc8 * 2.0;\n      const inc2:  f32 = inc8 * 4.0;\n\n      let p16: f32 = vP16[v]; p16 += inc16; if (p16 >= 1.0) p16 -= 1.0; vP16[v] = p16;\n      let p8:  f32 = vP8[v];  p8  += inc8;  if (p8  >= 1.0) p8  -= 1.0; vP8[v]  = p8;\n      let p4:  f32 = vP4[v];  p4  += inc4;  if (p4  >= 1.0) p4  -= 1.0; vP4[v]  = p4;\n      let p2:  f32 = vP2[v];  p2  += inc2;  if (p2  >= 1.0) p2  -= 1.0; vP2[v]  = p2;\n\n      // bright thin combo tone: narrow-ish pulses (flutey lower, reedy upper)\n      const t16: f32 = blPulse(p16, inc16, 0.5);   // hollow 16'\n      const t8:  f32 = blPulse(p8,  inc8,  0.42);  // 8' body\n      const t4:  f32 = blPulse(p4,  inc4,  0.30);  // 4' bright, thinner pulse\n      const t2:  f32 = blPulse(p2,  inc2,  0.22);  // 2' reedy buzz\n\n      const voice: f32 = (t16 * g16 + t8 * g8 + t4 * g4 + t2 * g2)\n                         * env * vVel[v];\n      mixv += voice;\n    }\n\n    // ---- global tone tilt + level -----------------------------------\n    let scaled: f32 = mixv * voiceScale;\n    ts += toneG * (scaled - ts);\n    let toned: f32 = ts * toneMix + scaled * (1.0 - toneMix);\n\n    // gentle soft clip for transistor-organ glue, keeps peak < 1\n    toned = f32(Mathf.tanh(toned * 1.15));\n    const outv: f32 = toned * level;\n\n    outBuf[f] = outv;\n    outBuf[MAX_FRAMES + f] = outv;\n  }\n\n  toneState = ts;\n  vibPhase = vph;\n}\n",
  "publishedAt": 1751000082000
}