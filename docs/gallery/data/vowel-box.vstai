{
  "format": 1,
  "name": "Vowel Box",
  "isInstrument": false,
  "explanation": "A talk-box-style formant filter that makes your input sing vowels. Three resonant band-pass formant filters track the F1/F2/F3 peaks of the vowels A-E-I-O-U; sweep the Vowel control and the peaks morph smoothly between vowel shapes. Drive adds harmonics for the formants to bite into, Resonance sharpens the peaks, and Mix blends against the dry signal. Best on rich, harmonic sources.",
  "params": [
    {
      "name": "Vowel",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Drive",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Level",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Vowel Box</title>\n  <style>\n    :root {\n      --accent: #ff7ac0;\n      --accent2: #ffd36a;\n      --bg0: #1a0d18;\n      --bg1: #2a1226;\n      --ink: #ffe9f6;\n      --ink-dim: #c79bb8;\n      --panel: #24101f;\n      --groove: #150812;\n    }\n\n    * { box-sizing: border-box; }\n\n    html, body {\n      margin: 0;\n      padding: 0;\n      background: var(--bg0);\n      color: var(--ink);\n      font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n      -webkit-font-smoothing: antialiased;\n    }\n\n    .shell {\n      min-height: 100vh;\n      display: flex;\n      align-items: flex-start;\n      justify-content: center;\n      padding: 18px;\n      background:\n        radial-gradient(120% 90% at 50% -10%, rgba(255,122,192,0.14), transparent 60%),\n        radial-gradient(100% 80% at 100% 120%, rgba(255,211,106,0.10), transparent 55%),\n        linear-gradient(160deg, var(--bg1), var(--bg0) 70%);\n    }\n\n    .panel {\n      width: 100%;\n      max-width: 640px;\n      background:\n        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.18)),\n        linear-gradient(160deg, var(--panel), #1b0c17);\n      border: 1px solid rgba(255,122,192,0.22);\n      border-radius: 20px;\n      box-shadow:\n        0 1px 0 rgba(255,255,255,0.08) inset,\n        0 24px 60px rgba(0,0,0,0.55),\n        0 0 0 1px rgba(0,0,0,0.5);\n      padding: 20px 22px 24px;\n      overflow: hidden;\n    }\n\n    /* ---------- header ---------- */\n    .head {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 16px;\n    }\n\n    .brand { display: flex; align-items: center; gap: 12px; }\n\n    .logo {\n      width: 38px; height: 38px;\n      border-radius: 11px;\n      background: linear-gradient(140deg, var(--accent), var(--accent2));\n      display: grid; place-items: center;\n      box-shadow: 0 6px 18px rgba(255,122,192,0.4), 0 0 0 1px rgba(255,255,255,0.18) inset;\n      animation: breathe 3.4s ease-in-out infinite;\n    }\n    @keyframes breathe {\n      0%,100% { box-shadow: 0 6px 18px rgba(255,122,192,0.35), 0 0 0 1px rgba(255,255,255,0.18) inset; }\n      50%     { box-shadow: 0 6px 26px rgba(255,211,106,0.55), 0 0 0 1px rgba(255,255,255,0.28) inset; }\n    }\n    .logo svg { width: 24px; height: 24px; display: block; }\n\n    .titles h1 {\n      margin: 0;\n      font-size: 19px;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n      font-weight: 800;\n      background: linear-gradient(90deg, var(--accent), var(--accent2));\n      -webkit-background-clip: text;\n      background-clip: text;\n      color: transparent;\n    }\n    .titles p {\n      margin: 2px 0 0;\n      font-size: 10px;\n      letter-spacing: 0.32em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n    }\n\n    .vowel-tag {\n      font-size: 30px;\n      font-weight: 800;\n      letter-spacing: 0.05em;\n      color: var(--accent2);\n      text-shadow: 0 0 18px rgba(255,211,106,0.5);\n      min-width: 44px;\n      text-align: center;\n      font-variant-numeric: tabular-nums;\n    }\n\n    /* ---------- stage (mouth + spectrum) ---------- */\n    .stage {\n      position: relative;\n      border-radius: 16px;\n      background:\n        radial-gradient(80% 120% at 50% 0%, rgba(255,122,192,0.10), transparent 60%),\n        linear-gradient(180deg, #120710, #1d0b18);\n      border: 1px solid rgba(255,122,192,0.16);\n      box-shadow: 0 10px 30px rgba(0,0,0,0.45) inset, 0 1px 0 rgba(255,255,255,0.04);\n      padding: 14px;\n      margin-bottom: 18px;\n    }\n    .stage svg { width: 100%; height: auto; display: block; }\n\n    /* ---------- controls ---------- */\n    .rack {\n      display: grid;\n      grid-template-columns: repeat(5, 1fr);\n      gap: 12px;\n    }\n    @media (max-width: 540px) {\n      .rack { grid-template-columns: repeat(3, 1fr); }\n    }\n\n    .cell {\n      background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(0,0,0,0.22));\n      border: 1px solid rgba(255,255,255,0.06);\n      border-radius: 14px;\n      padding: 12px 8px 10px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 7px;\n      box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 6px 16px rgba(0,0,0,0.3);\n      transition: border-color 0.2s, transform 0.12s;\n    }\n    .cell:hover { border-color: rgba(255,122,192,0.4); }\n    .cell.active { border-color: var(--accent); transform: translateY(-1px); }\n\n    .knob {\n      position: relative;\n      width: 72px; height: 72px;\n      cursor: ns-resize;\n      touch-action: none;\n      user-select: none;\n    }\n    .knob svg { width: 100%; height: 100%; display: block; overflow: visible; }\n\n    .cap-label {\n      font-size: 10px;\n      letter-spacing: 0.18em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n      font-weight: 600;\n    }\n    .cap-val {\n      font-size: 12px;\n      font-weight: 700;\n      color: var(--ink);\n      font-variant-numeric: tabular-nums;\n      letter-spacing: 0.02em;\n    }\n\n    .foot {\n      margin-top: 16px;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      font-size: 9px;\n      letter-spacing: 0.26em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n    }\n    .foot .dot {\n      display: inline-block; width: 7px; height: 7px; border-radius: 50%;\n      background: var(--accent); margin-right: 6px;\n      box-shadow: 0 0 8px var(--accent);\n      animation: pulse 1.6s ease-in-out infinite;\n      vertical-align: middle;\n    }\n    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }\n  </style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"panel\">\n\n      <div class=\"head\">\n        <div class=\"brand\">\n          <div class=\"logo\">\n            <svg viewBox=\"0 0 24 24\" fill=\"none\">\n              <path d=\"M3 12c3-6 15-6 18 0-3 6-15 6-18 0Z\" stroke=\"#2a0d20\" stroke-width=\"2\" fill=\"rgba(0,0,0,0.25)\"/>\n              <ellipse cx=\"12\" cy=\"12\" rx=\"4\" ry=\"5\" fill=\"#2a0d20\"/>\n            </svg>\n          </div>\n          <div class=\"titles\">\n            <h1>Vowel Box</h1>\n            <p>Formant Talker</p>\n          </div>\n        </div>\n        <div class=\"vowel-tag\" id=\"vowelTag\">A</div>\n      </div>\n\n      <!-- Stage: vocal-tract mouth + animated spectrum with 3 formant bumps -->\n      <div class=\"stage\">\n        <svg id=\"scene\" viewBox=\"0 0 600 230\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"gFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\"  stop-color=\"#ff7ac0\" stop-opacity=\"0.55\"/>\n              <stop offset=\"55%\" stop-color=\"#ff7ac0\" stop-opacity=\"0.10\"/>\n              <stop offset=\"100%\" stop-color=\"#ffd36a\" stop-opacity=\"0\"/>\n            </linearGradient>\n            <linearGradient id=\"gLine\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0%\"  stop-color=\"#ff7ac0\"/>\n              <stop offset=\"100%\" stop-color=\"#ffd36a\"/>\n            </linearGradient>\n            <radialGradient id=\"gBump\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n              <stop offset=\"0%\" stop-color=\"#ffd36a\" stop-opacity=\"0.95\"/>\n              <stop offset=\"100%\" stop-color=\"#ff7ac0\" stop-opacity=\"0\"/>\n            </radialGradient>\n            <linearGradient id=\"gLip\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#ff9bcf\"/>\n              <stop offset=\"100%\" stop-color=\"#d63a86\"/>\n            </linearGradient>\n            <filter id=\"soft\" x=\"-30%\" y=\"-30%\" width=\"160%\" height=\"160%\">\n              <feGaussianBlur stdDeviation=\"3\"/>\n            </filter>\n          </defs>\n\n          <!-- baseline grid -->\n          <g stroke=\"rgba(255,122,192,0.10)\" stroke-width=\"1\">\n            <line x1=\"0\" y1=\"170\" x2=\"600\" y2=\"170\"/>\n            <line x1=\"150\" y1=\"20\" x2=\"150\" y2=\"190\"/>\n            <line x1=\"300\" y1=\"20\" x2=\"300\" y2=\"190\"/>\n            <line x1=\"450\" y1=\"20\" x2=\"450\" y2=\"190\"/>\n          </g>\n\n          <!-- spectrum fill + line -->\n          <path id=\"specFill\" d=\"\" fill=\"url(#gFill)\"/>\n          <path id=\"specLine\" d=\"\" fill=\"none\" stroke=\"url(#gLine)\" stroke-width=\"2.5\"\n                stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n\n          <!-- glowing formant peak markers -->\n          <g id=\"bumps\">\n            <circle id=\"bumpGlow0\" r=\"22\" fill=\"url(#gBump)\" filter=\"url(#soft)\"/>\n            <circle id=\"bumpGlow1\" r=\"22\" fill=\"url(#gBump)\" filter=\"url(#soft)\"/>\n            <circle id=\"bumpGlow2\" r=\"22\" fill=\"url(#gBump)\" filter=\"url(#soft)\"/>\n            <circle id=\"bumpDot0\" r=\"3.5\" fill=\"#fff\"/>\n            <circle id=\"bumpDot1\" r=\"3.5\" fill=\"#fff\"/>\n            <circle id=\"bumpDot2\" r=\"3.5\" fill=\"#fff\"/>\n          </g>\n\n          <!-- the talking mouth (lips reshape with Vowel) -->\n          <g id=\"mouth\" transform=\"translate(300,205)\">\n            <ellipse id=\"mouthHole\" cx=\"0\" cy=\"0\" rx=\"40\" ry=\"14\" fill=\"#3a0c28\"/>\n            <ellipse id=\"tongue\" cx=\"0\" cy=\"6\" rx=\"26\" ry=\"7\" fill=\"#b8336e\" opacity=\"0.85\"/>\n            <path id=\"lipTop\" d=\"\" fill=\"url(#gLip)\"/>\n            <path id=\"lipBot\" d=\"\" fill=\"url(#gLip)\"/>\n          </g>\n        </svg>\n      </div>\n\n      <div class=\"rack\" id=\"rack\"></div>\n\n      <div class=\"foot\">\n        <span><span class=\"dot\"></span>Live</span>\n        <span>3-Band Formant · A E I O U</span>\n      </div>\n\n    </div>\n  </div>\n\n  <script>\n    \"use strict\";\n\n    // ---- parameter map (indices MUST match assembly.ts) ----\n    var PARAMS = [\n      { name: \"Vowel\",     index: 0, min: 0, max: 1, def: 0.0,  fmt: vowelFmt },\n      { name: \"Resonance\", index: 1, min: 0, max: 1, def: 0.6,  fmt: pctFmt },\n      { name: \"Drive\",     index: 2, min: 0, max: 1, def: 0.45, fmt: pctFmt },\n      { name: \"Mix\",       index: 3, min: 0, max: 1, def: 1.0,  fmt: pctFmt },\n      { name: \"Level\",     index: 4, min: 0, max: 1, def: 0.7,  fmt: pctFmt }\n    ];\n\n    var VOWELS = [\"A\", \"E\", \"I\", \"O\", \"U\"];\n    // normalized formant centre positions (0..1 across the spectrum view) per vowel\n    var VF = [\n      [0.16, 0.34, 0.62],  // A\n      [0.12, 0.52, 0.63],  // E\n      [0.07, 0.62, 0.74],  // I\n      [0.13, 0.27, 0.61],  // O\n      [0.07, 0.27, 0.58]   // U\n    ];\n\n    var values = PARAMS.map(function (p) { return p.def; });\n\n    function pctFmt(v) { return Math.round(v * 100) + \"%\"; }\n    function vowelFmt(v) {\n      var pos = v * 4;\n      var i = Math.min(4, Math.floor(pos));\n      var t = pos - i;\n      var j = Math.min(4, i + 1);\n      var name = t < 0.5 ? VOWELS[i] : VOWELS[j];\n      return name;\n    }\n\n    // ---- host bridge ----\n    function pushParam(idx, val) {\n      if (window.vstai && window.vstai.setParam) {\n        try { window.vstai.setParam(idx, val); } catch (e) {}\n      }\n    }\n\n    function setValue(slot, v, push) {\n      var p = PARAMS[slot];\n      v = Math.max(p.min, Math.min(p.max, v));\n      values[slot] = v;\n      var cell = cells[slot];\n      cell.valEl.textContent = p.fmt(v);\n      drawKnob(cell, slot);\n      if (push) pushParam(p.index, v);\n      if (slot === 0) document.getElementById(\"vowelTag\").textContent = vowelFmt(v);\n    }\n\n    // ---- knob construction ----\n    var cells = [];\n    var rack = document.getElementById(\"rack\");\n\n    function makeKnob(slot) {\n      var p = PARAMS[slot];\n      var cell = document.createElement(\"div\");\n      cell.className = \"cell\";\n\n      var knob = document.createElement(\"div\");\n      knob.className = \"knob\";\n      knob.innerHTML =\n        '<svg viewBox=\"0 0 100 100\">' +\n          '<circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"rgba(0,0,0,0.5)\" stroke-width=\"9\"/>' +\n          '<circle class=\"arc\" cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"url(#gArc' + slot + ')\" ' +\n            'stroke-width=\"9\" stroke-linecap=\"round\" ' +\n            'transform=\"rotate(135 50 50)\"/>' +\n          '<defs><linearGradient id=\"gArc' + slot + '\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n            '<stop offset=\"0%\" stop-color=\"#ff7ac0\"/><stop offset=\"100%\" stop-color=\"#ffd36a\"/>' +\n          '</linearGradient>' +\n          '<radialGradient id=\"gBody' + slot + '\" cx=\"50%\" cy=\"35%\" r=\"70%\">' +\n            '<stop offset=\"0%\" stop-color=\"#3a1730\"/><stop offset=\"100%\" stop-color=\"#1c0a16\"/>' +\n          '</radialGradient></defs>' +\n          '<circle cx=\"50\" cy=\"50\" r=\"32\" fill=\"url(#gBody' + slot + ')\" ' +\n            'stroke=\"rgba(255,255,255,0.08)\" stroke-width=\"1\"/>' +\n          '<line class=\"ptr\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"24\" ' +\n            'stroke=\"#ffd36a\" stroke-width=\"3\" stroke-linecap=\"round\"/>' +\n        '</svg>';\n\n      var label = document.createElement(\"div\");\n      label.className = \"cap-label\";\n      label.textContent = p.name;\n\n      var val = document.createElement(\"div\");\n      val.className = \"cap-val\";\n\n      cell.appendChild(knob);\n      cell.appendChild(label);\n      cell.appendChild(val);\n      rack.appendChild(cell);\n\n      var rec = {\n        el: cell,\n        knobEl: knob,\n        valEl: val,\n        arc: knob.querySelector(\".arc\"),\n        ptr: knob.querySelector(\".ptr\")\n      };\n      cells[slot] = rec;\n\n      // ---- interaction: vertical drag ----\n      var dragging = false, startY = 0, startV = 0;\n\n      function onDown(e) {\n        dragging = true;\n        cell.classList.add(\"active\");\n        startY = (e.touches ? e.touches[0].clientY : e.clientY);\n        startV = values[slot];\n        e.preventDefault();\n        window.addEventListener(\"mousemove\", onMove);\n        window.addEventListener(\"mouseup\", onUp);\n        window.addEventListener(\"touchmove\", onMove, { passive: false });\n        window.addEventListener(\"touchend\", onUp);\n      }\n      function onMove(e) {\n        if (!dragging) return;\n        var y = (e.touches ? e.touches[0].clientY : e.clientY);\n        var dy = startY - y;\n        var range = p.max - p.min;\n        var nv = startV + (dy / 200) * range;\n        setValue(slot, nv, true);\n        e.preventDefault();\n      }\n      function onUp() {\n        dragging = false;\n        cell.classList.remove(\"active\");\n        window.removeEventListener(\"mousemove\", onMove);\n        window.removeEventListener(\"mouseup\", onUp);\n        window.removeEventListener(\"touchmove\", onMove);\n        window.removeEventListener(\"touchend\", onUp);\n      }\n\n      knob.addEventListener(\"mousedown\", onDown);\n      knob.addEventListener(\"touchstart\", onDown, { passive: false });\n      knob.addEventListener(\"dblclick\", function () { setValue(slot, p.def, true); });\n      knob.addEventListener(\"wheel\", function (e) {\n        var range = p.max - p.min;\n        setValue(slot, values[slot] - Math.sign(e.deltaY) * range * 0.02, true);\n        e.preventDefault();\n      }, { passive: false });\n\n      return rec;\n    }\n\n    function drawKnob(rec, slot) {\n      var p = PARAMS[slot];\n      var norm = (values[slot] - p.min) / (p.max - p.min);\n      // arc sweeps 270deg; circumference of r=44 = 276.46\n      var C = 2 * Math.PI * 44;\n      var sweep = 0.75; // 270 / 360\n      rec.arc.setAttribute(\"stroke-dasharray\", (C * sweep * norm) + \" \" + C);\n      var ang = -135 + norm * 270; // degrees\n      var rad = ang * Math.PI / 180;\n      var x = 50 + Math.sin(rad) * 26;\n      var y = 50 - Math.cos(rad) * 26;\n      rec.ptr.setAttribute(\"x2\", x);\n      rec.ptr.setAttribute(\"y2\", y);\n    }\n\n    for (var i = 0; i < PARAMS.length; i++) makeKnob(i);\n\n    // =================================================================\n    //  Scene rendering: spectrum curve + 3 formant bumps + talking lips\n    // =================================================================\n    var W = 600, baseY = 170, topY = 24;\n    var specLine = document.getElementById(\"specLine\");\n    var specFill = document.getElementById(\"specFill\");\n    var bumpGlow = [0, 1, 2].map(function (k) { return document.getElementById(\"bumpGlow\" + k); });\n    var bumpDot  = [0, 1, 2].map(function (k) { return document.getElementById(\"bumpDot\" + k); });\n    var lipTop = document.getElementById(\"lipTop\");\n    var lipBot = document.getElementById(\"lipBot\");\n    var tongue = document.getElementById(\"tongue\");\n    var mouthHole = document.getElementById(\"mouthHole\");\n\n    // smoothed display state\n    var dCenters = [0.16, 0.34, 0.62];\n    var dOpen = 0.5;     // mouth openness 0..1\n    var dRound = 0.0;    // lip rounding 0..1\n\n    function morphFormants(vowel) {\n      var pos = vowel * 4;\n      var i = Math.min(4, Math.floor(pos));\n      var t = pos - i;\n      var j = Math.min(4, i + 1);\n      var out = [0, 0, 0];\n      for (var k = 0; k < 3; k++) out[k] = VF[i][k] + (VF[j][k] - VF[i][k]) * t;\n      return out;\n    }\n\n    // mouth shape per vowel: [openness, rounding]\n    var MOUTH = [\n      [1.0, 0.05],  // A  wide open\n      [0.6, 0.10],  // E  mid, spread\n      [0.35, 0.05], // I  narrow, spread\n      [0.7, 0.85],  // O  rounded\n      [0.4, 1.0]    // U  small, very rounded\n    ];\n\n    function mouthFor(vowel) {\n      var pos = vowel * 4;\n      var i = Math.min(4, Math.floor(pos));\n      var t = pos - i;\n      var j = Math.min(4, i + 1);\n      return [\n        MOUTH[i][0] + (MOUTH[j][0] - MOUTH[i][0]) * t,\n        MOUTH[i][1] + (MOUTH[j][1] - MOUTH[i][1]) * t\n      ];\n    }\n\n    var phase = 0;\n\n    function render() {\n      var vowel = values[0];\n      var res = values[1];\n      var drive = values[2];\n      var mix = values[3];\n\n      var targets = morphFormants(vowel);\n      var m = mouthFor(vowel);\n\n      // ease toward targets so motion feels alive\n      for (var k = 0; k < 3; k++) dCenters[k] += (targets[k] - dCenters[k]) * 0.18;\n      dOpen  += (m[0] - dOpen) * 0.18;\n      dRound += (m[1] - dRound) * 0.18;\n\n      phase += 0.045;\n\n      // --- build spectrum curve as sum of 3 gaussian formant bumps ---\n      var width = 0.085 - res * 0.05;   // sharper peaks at high resonance\n      width = Math.max(0.022, width);\n      var amps = [1.0, 0.78, 0.5];\n      var N = 80;\n      var lineD = \"\", fillD = \"\";\n      var wobble = 0.6 + drive * 1.2;   // a little life with drive\n\n      for (var s = 0; s <= N; s++) {\n        var fx = s / N;                 // 0..1 across spectrum\n        var v = 0;\n        for (var b = 0; b < 3; b++) {\n          var d = (fx - dCenters[b]) / width;\n          v += amps[b] * Math.exp(-0.5 * d * d);\n        }\n        // subtle animated shimmer\n        v *= 1 + 0.04 * Math.sin(phase + fx * 9);\n        v = Math.min(1.3, v) * (0.4 + 0.6 * mix);\n        var px = fx * W;\n        var py = baseY - v * (baseY - topY);\n        lineD += (s === 0 ? \"M\" : \"L\") + px.toFixed(1) + \" \" + py.toFixed(1) + \" \";\n      }\n      fillD = \"M0 \" + baseY + \" \" + lineD.replace(/^M/, \"L\") + \"L\" + W + \" \" + baseY + \" Z\";\n      specLine.setAttribute(\"d\", lineD);\n      specFill.setAttribute(\"d\", fillD);\n\n      // --- position the glowing bumps on the curve ---\n      for (var bb = 0; bb < 3; bb++) {\n        var cx = dCenters[bb] * W;\n        var peak = amps[bb] * (0.4 + 0.6 * mix);\n        var cy = baseY - Math.min(1.3, peak) * (baseY - topY);\n        var glowR = 14 + res * 16 + 3 * Math.sin(phase * 1.3 + bb);\n        bumpGlow[bb].setAttribute(\"cx\", cx);\n        bumpGlow[bb].setAttribute(\"cy\", cy);\n        bumpGlow[bb].setAttribute(\"r\", glowR);\n        bumpDot[bb].setAttribute(\"cx\", cx);\n        bumpDot[bb].setAttribute(\"cy\", cy);\n      }\n\n      // --- talking lips ---\n      var halfW = 38 + (1 - dRound) * 22;       // wide when spread, narrow when rounded\n      var gap = 4 + dOpen * 22;                  // vertical opening\n      var topThick = 8 + dRound * 6;\n      var botThick = 9 + dRound * 7;\n\n      // top lip\n      lipTop.setAttribute(\"d\",\n        \"M\" + (-halfW) + \" 0 \" +\n        \"Q0 \" + (-gap - topThick) + \" \" + halfW + \" 0 \" +\n        \"Q0 \" + (-gap + 2) + \" \" + (-halfW) + \" 0 Z\");\n      // bottom lip\n      lipBot.setAttribute(\"d\",\n        \"M\" + (-halfW) + \" 0 \" +\n        \"Q0 \" + (gap + botThick) + \" \" + halfW + \" 0 \" +\n        \"Q0 \" + (gap - 2) + \" \" + (-halfW) + \" 0 Z\");\n\n      mouthHole.setAttribute(\"rx\", halfW * 0.85);\n      mouthHole.setAttribute(\"ry\", Math.max(4, gap * 0.7));\n      tongue.setAttribute(\"rx\", halfW * 0.6);\n      tongue.setAttribute(\"cy\", gap * 0.4 + 4);\n\n      if (!document.hidden) requestAnimationFrame(render);\n    }\n\n    document.addEventListener(\"visibilitychange\", function () {\n      if (!document.hidden) requestAnimationFrame(render);\n    });\n\n    // ---- init ----\n    function boot() {\n      for (var s = 0; s < PARAMS.length; s++) setValue(s, values[s], true);\n      requestAnimationFrame(render);\n    }\n\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(boot);\n    } else {\n      boot();\n    }\n  </script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VOWEL BOX — talk-box / formant filter effect\n//  Makes the input \"talk\": three resonant band-pass FORMANT filters whose\n//  centre frequencies morph between the vowel sets A-E-I-O-U as the Vowel\n//  control sweeps. A pre-gain Drive adds harmonics for the formants to bite\n//  into, Resonance sharpens the formant peaks, and Mix blends against dry.\n//  Pure algorithm, no samples.\n//\n//  Each formant is a state-variable band-pass filter (TPT/Zavalishin style),\n//  stable and cheap, evaluated per sample. Formant tables are classic male\n//  vowel F1/F2/F3 centre frequencies; the Vowel control linearly morphs the\n//  centre frequencies (and relative gains) between adjacent vowels.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- formant state-variable band-pass state (per channel, per formant) ---\n// 3 formants * MAX_CHANNELS. Index = formant * MAX_CHANNELS + channel.\nconst svIc1: StaticArray<f32> = new StaticArray<f32>(3 * MAX_CHANNELS); // integrator 1\nconst svIc2: StaticArray<f32> = new StaticArray<f32>(3 * MAX_CHANNELS); // integrator 2\n\n// --- vowel formant tables (5 vowels: A E I O U) ---\n// classic male-voice formant centre frequencies (Hz) for F1, F2, F3\nconst VOWEL_F1: StaticArray<f32> = new StaticArray<f32>(5);\nconst VOWEL_F2: StaticArray<f32> = new StaticArray<f32>(5);\nconst VOWEL_F3: StaticArray<f32> = new StaticArray<f32>(5);\n// per-formant relative gain for each vowel (formant 3 is quieter)\nconst VOWEL_G1: StaticArray<f32> = new StaticArray<f32>(5);\nconst VOWEL_G2: StaticArray<f32> = new StaticArray<f32>(5);\nconst VOWEL_G3: StaticArray<f32> = new StaticArray<f32>(5);\n\nconst P_VOWEL: i32 = 0; // 0..1 -> morph A..U\nconst P_RES: i32 = 1;   // 0..1 -> formant sharpness (Q)\nconst P_DRIVE: i32 = 2; // 0..1 -> pre-gain 1..12 + harmonics\nconst P_MIX: i32 = 3;   // 0..1 dry/wet\nconst P_LEVEL: i32 = 4; // 0..1 -> 0..1.4 output\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < 3 * MAX_CHANNELS; i++) { svIc1[i] = 0.0; svIc2[i] = 0.0; }\n\n  // A   E    I    O    U\n  VOWEL_F1[0] = 730.0; VOWEL_F1[1] = 530.0; VOWEL_F1[2] = 270.0; VOWEL_F1[3] = 570.0; VOWEL_F1[4] = 300.0;\n  VOWEL_F2[0] = 1090.0; VOWEL_F2[1] = 1840.0; VOWEL_F2[2] = 2290.0; VOWEL_F2[3] = 840.0; VOWEL_F2[4] = 870.0;\n  VOWEL_F3[0] = 2440.0; VOWEL_F3[1] = 2480.0; VOWEL_F3[2] = 3010.0; VOWEL_F3[3] = 2410.0; VOWEL_F3[4] = 2240.0;\n\n  for (let v = 0; v < 5; v++) { VOWEL_G1[v] = 1.0; VOWEL_G2[v] = 0.75; VOWEL_G3[v] = 0.45; }\n\n  params[P_VOWEL] = 0.0;\n  params[P_RES]   = 0.6;\n  params[P_DRIVE] = 0.45;\n  params[P_MIX]   = 1.0;\n  params[P_LEVEL] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// soft saturation used by Drive so the formants have rich harmonics to filter\n@inline function softClip(x: f32): f32 {\n  const c: f32 = clampf(x, -1.5, 1.5);\n  return f32(c - 0.14814815 * c * c * c); // ~tanh-ish cubic, gentle\n}\n\n// module-scope morph scratch (computed per block, no alloc in process loop)\nlet mF1: f32 = 730.0; let mF2: f32 = 1090.0; let mF3: f32 = 2440.0;\nlet mG1: f32 = 1.0;   let mG2: f32 = 0.75;   let mG3: f32 = 0.45;\n\n@inline function lerpf(a: f32, b: f32, t: f32): f32 { return f32(a + (b - a) * t); }\n\n// resolve the morphed formant frequencies/gains for a Vowel position 0..1\nfunction computeMorph(vowel: f32): void {\n  const pos: f32 = clampf(vowel, 0.0, 1.0) * 4.0; // 0..4 across 5 vowels\n  let i0: i32 = i32(pos);\n  if (i0 > 3) i0 = 3;\n  const i1: i32 = i0 + 1;\n  const t: f32 = pos - f32(i0);\n\n  mF1 = lerpf(VOWEL_F1[i0], VOWEL_F1[i1], t);\n  mF2 = lerpf(VOWEL_F2[i0], VOWEL_F2[i1], t);\n  mF3 = lerpf(VOWEL_F3[i0], VOWEL_F3[i1], t);\n  mG1 = lerpf(VOWEL_G1[i0], VOWEL_G1[i1], t);\n  mG2 = lerpf(VOWEL_G2[i0], VOWEL_G2[i1], t);\n  mG3 = lerpf(VOWEL_G3[i0], VOWEL_G3[i1], t);\n}\n\n// TPT state-variable band-pass coefficients (shared per formant per block)\nlet g1: f32 = 0.0; let g2: f32 = 0.0; let g3: f32 = 0.0; // tan(pi*fc/sr)\nlet k: f32 = 0.5;                                         // damping = 1/Q\nlet a1c: f32 = 0.0;                                       // 1/(1+g*(g+k)) per formant\nlet a1c1: f32 = 0.0; let a1c2: f32 = 0.0; let a1c3: f32 = 0.0;\n\n@inline function tanApprox(x: f32): f32 {\n  // tan(pi*fc/sr); fc/sr small-ish, use Mathf.tan (f32) directly, bounded\n  return f32(Mathf.tan(x));\n}\n\nexport function process(n: i32): void {\n  const vowel: f32 = clampf(params[P_VOWEL], 0.0, 1.0);\n  const res: f32 = clampf(params[P_RES], 0.0, 1.0);\n  const driveN: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.4;\n\n  computeMorph(vowel);\n\n  // Q from resonance: 2 .. 28 (higher = sharper formant peaks)\n  const Q: f32 = 2.0 + res * res * 26.0;\n  k = f32(1.0 / Q);\n\n  const pi: f32 = 3.14159265;\n  const ny: f32 = sampleRate * 0.49;\n\n  // band-pass uses the bp output of the SVF, scaled by k so peak gain ~1\n  const f1c: f32 = clampf(mF1, 40.0, ny);\n  const f2c: f32 = clampf(mF2, 40.0, ny);\n  const f3c: f32 = clampf(mF3, 40.0, ny);\n  g1 = tanApprox(pi * f1c / sampleRate);\n  g2 = tanApprox(pi * f2c / sampleRate);\n  g3 = tanApprox(pi * f3c / sampleRate);\n  a1c1 = f32(1.0 / (1.0 + g1 * (g1 + k)));\n  a1c2 = f32(1.0 / (1.0 + g2 * (g2 + k)));\n  a1c3 = f32(1.0 / (1.0 + g3 * (g3 + k)));\n\n  const drive: f32 = 1.0 + driveN * 11.0;\n  // output makeup: band-pass gains scale with k; compensate so wet stays bounded\n  const formScale: f32 = f32(k * 2.2);\n  // overall wet trim to keep peak < ~1 after summing 3 formants + drive\n  const wetTrim: f32 = 0.7;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const idx0: i32 = 0 * MAX_CHANNELS + c;\n    const idx1: i32 = 1 * MAX_CHANNELS + c;\n    const idx2: i32 = 2 * MAX_CHANNELS + c;\n    let ic1a: f32 = svIc1[idx0]; let ic2a: f32 = svIc2[idx0];\n    let ic1b: f32 = svIc1[idx1]; let ic2b: f32 = svIc2[idx1];\n    let ic1d: f32 = svIc1[idx2]; let ic2d: f32 = svIc2[idx2];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n      // pre-gain + soft saturate -> harmonics for the formants to grab\n      const exc: f32 = softClip(dry * drive);\n\n      // --- formant 1 (SVF band-pass) ---\n      let v3: f32 = exc - ic2a;\n      let v1: f32 = f32(a1c1 * (ic1a + g1 * v3));\n      let v2: f32 = f32(ic2a + g1 * v1);\n      ic1a = f32(2.0 * v1 - ic1a);\n      ic2a = f32(2.0 * v2 - ic2a);\n      const bp1: f32 = v1; // band-pass output\n\n      // --- formant 2 ---\n      v3 = exc - ic2b;\n      v1 = f32(a1c2 * (ic1b + g2 * v3));\n      v2 = f32(ic2b + g2 * v1);\n      ic1b = f32(2.0 * v1 - ic1b);\n      ic2b = f32(2.0 * v2 - ic2b);\n      const bp2: f32 = v1;\n\n      // --- formant 3 ---\n      v3 = exc - ic2d;\n      v1 = f32(a1c3 * (ic1d + g3 * v3));\n      v2 = f32(ic2d + g3 * v1);\n      ic1d = f32(2.0 * v1 - ic1d);\n      ic2d = f32(2.0 * v2 - ic2d);\n      const bp3: f32 = v1;\n\n      let wet: f32 = f32((bp1 * mG1 + bp2 * mG2 + bp3 * mG3) * formScale * wetTrim);\n      // final gentle clip so peaks never explode at high Resonance\n      wet = softClip(wet);\n\n      const outv: f32 = f32((dry * (1.0 - mix) + wet * mix) * level);\n      outBuf[base + f] = outv;\n    }\n\n    svIc1[idx0] = ic1a; svIc2[idx0] = ic2a;\n    svIc1[idx1] = ic1b; svIc2[idx1] = ic2b;\n    svIc1[idx2] = ic1d; svIc2[idx2] = ic2d;\n  }\n}\n",
  "publishedAt": 1751000090000
}