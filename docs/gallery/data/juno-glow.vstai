  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Juno Glow</title>\n<style>\n  :root {\n    --bg0: #1a1714;\n    --bg1: #242019;\n    --panel: #2c2620;\n    --panel-hi: #3a332a;\n    --ink: #f3e9dd;\n    --ink-dim: #b6a892;\n    --accent: #ff8a3d;\n    --accent2: #ffd24a;\n    --slot: #100d0a;\n    --line: #443c31;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    height: 100%;\n    background:\n      radial-gradient(1200px 600px at 50% -10%, #322a22 0%, var(--bg0) 60%),\n      var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .shell {\n    max-width: 940px;\n    margin: 0 auto;\n    padding: 18px 18px 26px;\n    min-height: 100%;\n  }\n\n  /* ---- chassis ---- */\n  .chassis {\n    border-radius: 16px;\n    padding: 18px;\n    background:\n      linear-gradient(180deg, #322b23 0%, #25201a 38%, #211c16 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.06) inset,\n      0 -2px 0 rgba(0,0,0,.5) inset,\n      0 24px 60px rgba(0,0,0,.55);\n    border: 1px solid #0d0b08;\n    position: relative;\n  }\n\n  /* warm brushed-metal sheen on top edge */\n  .chassis::before {\n    content: \"\";\n    position: absolute;\n    inset: 0 0 auto 0;\n    height: 14px;\n    border-radius: 16px 16px 0 0;\n    background: linear-gradient(180deg, rgba(255,210,150,.16), transparent);\n    pointer-events: none;\n  }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    margin-bottom: 14px;\n  }\n\n  .brand {\n    display: flex;\n    align-items: baseline;\n    gap: 12px;\n  }\n\n  .logo {\n    font-weight: 800;\n    font-size: 26px;\n    letter-spacing: 1.5px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 18px rgba(255,138,61,.25);\n  }\n\n  .tagline {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .badge {\n    font-size: 9.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid var(--line);\n    border-radius: 999px;\n    padding: 5px 11px;\n    background: rgba(0,0,0,.25);\n  }\n\n  /* ---- waveform scope ---- */\n  .scope {\n    height: 86px;\n    border-radius: 11px;\n    background:\n      linear-gradient(180deg, #0c0a08, #14110d);\n    border: 1px solid #000;\n    box-shadow: 0 2px 0 rgba(255,255,255,.04) inset, 0 -8px 18px rgba(0,0,0,.5) inset;\n    margin-bottom: 16px;\n    position: relative;\n    overflow: hidden;\n  }\n  .scope svg { display: block; width: 100%; height: 100%; }\n\n  /* ---- slider panel ---- */\n  .panel {\n    background:\n      linear-gradient(180deg, var(--panel-hi), var(--panel) 30%, #241f19);\n    border: 1px solid #0e0c09;\n    border-radius: 13px;\n    padding: 16px 14px 14px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.05) inset, 0 14px 26px rgba(0,0,0,.4);\n  }\n\n  .faders {\n    display: grid;\n    grid-template-columns: repeat(8, 1fr);\n    gap: 10px;\n  }\n\n  .fader {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 9px;\n    user-select: none;\n  }\n\n  .slot {\n    position: relative;\n    width: 34px;\n    height: 168px;\n    border-radius: 8px;\n    background:\n      linear-gradient(90deg, #050403, #1c1712 18%, #1c1712 82%, #050403);\n    box-shadow:\n      0 0 0 1px #0a0805,\n      0 3px 7px rgba(0,0,0,.5) inset;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n\n  /* center groove */\n  .slot::before {\n    content: \"\";\n    position: absolute;\n    left: 50%;\n    top: 8px;\n    bottom: 8px;\n    width: 4px;\n    transform: translateX(-50%);\n    border-radius: 4px;\n    background: linear-gradient(180deg, #000, #221c16);\n    box-shadow: 0 0 3px #000 inset;\n  }\n\n  /* lit fill below the cap */\n  .fill {\n    position: absolute;\n    left: 50%;\n    bottom: 8px;\n    width: 4px;\n    transform: translateX(-50%);\n    border-radius: 4px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: 0 0 8px rgba(255,138,61,.7);\n    pointer-events: none;\n  }\n\n  /* tick marks */\n  .ticks {\n    position: absolute;\n    right: 3px;\n    top: 8px;\n    bottom: 8px;\n    width: 6px;\n    display: flex;\n    flex-direction: column;\n    justify-content: space-between;\n    opacity: .5;\n  }\n  .ticks i {\n    display: block;\n    height: 1px;\n    background: var(--line);\n  }\n\n  /* the cap */\n  .cap {\n    position: absolute;\n    left: 50%;\n    width: 30px;\n    height: 20px;\n    margin-left: -15px;\n    border-radius: 5px;\n    background: linear-gradient(180deg, #5a5046, #342d25 55%, #1f1a15);\n    box-shadow:\n      0 1px 0 rgba(255,235,200,.35) inset,\n      0 -2px 3px rgba(0,0,0,.6) inset,\n      0 5px 9px rgba(0,0,0,.55);\n    border: 1px solid #14100c;\n    transition: box-shadow .12s ease;\n  }\n  .cap::after {\n    content: \"\";\n    position: absolute;\n    left: 4px; right: 4px;\n    top: 50%;\n    height: 2px;\n    transform: translateY(-50%);\n    border-radius: 2px;\n    background: linear-gradient(90deg, transparent, var(--accent2), transparent);\n    box-shadow: 0 0 6px var(--accent);\n    opacity: .85;\n  }\n  .fader.active .cap,\n  .fader:hover .cap {\n    box-shadow:\n      0 1px 0 rgba(255,235,200,.45) inset,\n      0 -2px 3px rgba(0,0,0,.6) inset,\n      0 6px 12px rgba(0,0,0,.6),\n      0 0 14px rgba(255,138,61,.55);\n  }\n\n  .lbl {\n    font-size: 9.5px;\n    letter-spacing: 1.2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n    height: 12px;\n  }\n  .val {\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent2);\n    text-shadow: 0 0 8px rgba(255,210,74,.35);\n  }\n\n  /* ---- bottom row: chorus + keyboard ---- */\n  .row {\n    display: grid;\n    grid-template-columns: 168px 1fr;\n    gap: 16px;\n    margin-top: 16px;\n    align-items: stretch;\n  }\n\n  .chorus-bay {\n    background: linear-gradient(180deg, var(--panel-hi), #241f19);\n    border: 1px solid #0e0c09;\n    border-radius: 13px;\n    padding: 14px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    justify-content: center;\n    gap: 12px;\n    box-shadow: 0 1px 0 rgba(255,255,255,.05) inset;\n  }\n  .chorus-bay .lbl { font-size: 10px; letter-spacing: 2.5px; }\n\n  .chorus-btn {\n    position: relative;\n    width: 92px;\n    height: 50px;\n    border-radius: 9px;\n    border: 1px solid #0d0b08;\n    background: linear-gradient(180deg, #2c261f, #1c1813);\n    cursor: pointer;\n    color: var(--ink-dim);\n    font-size: 11px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    font-weight: 700;\n    transition: all .18s ease;\n    box-shadow: 0 3px 7px rgba(0,0,0,.45), 0 1px 0 rgba(255,255,255,.05) inset;\n  }\n  .chorus-btn .led {\n    position: absolute;\n    top: 7px;\n    left: 50%;\n    transform: translateX(-50%);\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    background: #3a2f22;\n    box-shadow: 0 0 0 1px #000 inset;\n    transition: all .18s ease;\n  }\n  .chorus-btn .txt { position: absolute; bottom: 9px; left: 0; right: 0; text-align: center; }\n  .chorus-btn.on {\n    color: var(--accent2);\n    border-color: var(--accent);\n    background: linear-gradient(180deg, #4a3318, #2a1d0e);\n    box-shadow:\n      0 3px 7px rgba(0,0,0,.45),\n      0 1px 0 rgba(255,235,200,.18) inset,\n      0 0 22px rgba(255,138,61,.5);\n  }\n  .chorus-btn.on .led {\n    background: var(--accent2);\n    box-shadow: 0 0 10px var(--accent2), 0 0 18px var(--accent);\n    animation: pulse 1.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { box-shadow: 0 0 8px var(--accent2), 0 0 14px var(--accent); }\n    50%      { box-shadow: 0 0 14px var(--accent2), 0 0 26px var(--accent); }\n  }\n\n  /* keyboard */\n  .keybay {\n    background: linear-gradient(180deg, #1d1813, #15110d);\n    border: 1px solid #0d0b08;\n    border-radius: 13px;\n    padding: 10px;\n    box-shadow: 0 2px 0 rgba(255,255,255,.04) inset;\n  }\n  .keys {\n    position: relative;\n    height: 116px;\n    display: flex;\n    gap: 3px;\n  }\n  .wkey {\n    flex: 1;\n    border-radius: 0 0 6px 6px;\n    background: linear-gradient(180deg, #efe7da, #c7bba8);\n    border: 1px solid #0d0b08;\n    box-shadow: 0 -3px 6px rgba(0,0,0,.25) inset, 0 3px 5px rgba(0,0,0,.4);\n    cursor: pointer;\n    position: relative;\n    transition: background .07s ease;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: 0 0 16px rgba(255,138,61,.6) inset;\n  }\n  .bkeys {\n    position: absolute;\n    inset: 0 0 auto 0;\n    height: 68px;\n    pointer-events: none;\n  }\n  .bkey {\n    position: absolute;\n    width: 5.4%;\n    height: 100%;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #2a241d, #0c0a07);\n    border: 1px solid #000;\n    box-shadow: 0 3px 5px rgba(0,0,0,.6);\n    cursor: pointer;\n    pointer-events: auto;\n    transition: background .07s ease;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #b3551f);\n    box-shadow: 0 0 14px rgba(255,138,61,.7) inset;\n  }\n\n  footer {\n    margin-top: 14px;\n    text-align: center;\n    font-size: 10px;\n    letter-spacing: 1.5px;\n    color: var(--ink-dim);\n    text-transform: uppercase;\n  }\n  footer b { color: var(--accent); }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"chassis\">\n      <header>\n        <div class=\"brand\">\n          <span class=\"logo\">JUNO GLOW</span>\n          <span class=\"tagline\">6-Voice DCO Poly</span>\n        </div>\n        <span class=\"badge\">Ensemble Chorus</span>\n      </header>\n\n      <div class=\"scope\">\n        <svg viewBox=\"0 0 600 86\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n          <path id=\"waveA\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"2\"></path>\n          <path id=\"waveB\" fill=\"none\" stroke=\"var(--accent2)\" stroke-width=\"1.6\" opacity=\"0.7\"></path>\n        </svg>\n      </div>\n\n      <div class=\"panel\">\n        <div class=\"faders\" id=\"faders\"></div>\n      </div>\n\n      <div class=\"row\">\n        <div class=\"chorus-bay\">\n          <span class=\"lbl\">Chorus</span>\n          <button class=\"chorus-btn\" id=\"chorusBtn\" title=\"Toggle ensemble chorus (double-click a fader to reset)\">\n            <span class=\"led\"></span>\n            <span class=\"txt\" id=\"chorusTxt\">Off</span>\n          </button>\n          <span class=\"val\" id=\"chorusVal\">0%</span>\n        </div>\n\n        <div class=\"keybay\">\n          <div class=\"keys\" id=\"keys\"></div>\n        </div>\n      </div>\n\n      <footer>Play with your <b>mouse</b> or computer keys <b>A&ndash;K</b> &middot; drag faders, double-click to reset</footer>\n    </div>\n  </div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter model (indices match assembly.ts / spec.json) ----\n  var PARAMS = [\n    { name: \"Cutoff\",  index: 0, min: 0, max: 1, def: 0.55 },\n    { name: \"Reso\",    index: 1, min: 0, max: 1, def: 0.30 },\n    { name: \"Env Amt\", index: 2, min: 0, max: 1, def: 0.55 },\n    { name: \"PWM\",     index: 3, min: 0, max: 1, def: 0.40 },\n    { name: \"Sub\",     index: 4, min: 0, max: 1, def: 0.45 },\n    { name: \"Chorus\",  index: 5, min: 0, max: 1, def: 0.60 },\n    { name: \"Release\", index: 6, min: 0, max: 1, def: 0.35 },\n    { name: \"Level\",   index: 7, min: 0, max: 1, def: 0.70 }\n  ];\n\n  var CHORUS_I = 5;\n  var values = {};\n\n  function clamp(v, lo, hi) { return v < lo ? lo : (v > hi ? hi : v); }\n\n  function pushParam(p, v) {\n    values[p.index] = v;\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(p.index, v);\n    }\n  }\n\n  // ---- build faders ----\n  var fadersEl = document.getElementById(\"faders\");\n  var fillEls = {};\n  var capEls = {};\n  var valEls = {};\n\n  PARAMS.forEach(function (p) {\n    var col = document.createElement(\"div\");\n    col.className = \"fader\";\n\n    var slot = document.createElement(\"div\");\n    slot.className = \"slot\";\n\n    var ticks = document.createElement(\"div\");\n    ticks.className = \"ticks\";\n    for (var t = 0; t < 9; t++) { ticks.appendChild(document.createElement(\"i\")); }\n    slot.appendChild(ticks);\n\n    var fill = document.createElement(\"div\");\n    fill.className = \"fill\";\n    slot.appendChild(fill);\n\n    var cap = document.createElement(\"div\");\n    cap.className = \"cap\";\n    slot.appendChild(cap);\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"lbl\";\n    lbl.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    col.appendChild(slot);\n    col.appendChild(lbl);\n    col.appendChild(val);\n    fadersEl.appendChild(col);\n\n    fillEls[p.index] = fill;\n    capEls[p.index] = cap;\n    valEls[p.index] = val;\n\n    function norm(v) { return (v - p.min) / (p.max - p.min); }\n\n    function paint(v) {\n      var n = clamp(norm(v), 0, 1);\n      var travel = 168 - 16 - 20;       // slot height - padding - cap\n      var y = (1 - n) * travel + 8;     // top offset of cap\n      cap.style.top = y + \"px\";\n      var fh = n * (168 - 16);\n      fill.style.height = fh + \"px\";\n      val.textContent = Math.round(n * 100) + \"%\";\n      if (p.index === CHORUS_I) { syncChorus(v); }\n    }\n\n    function setVal(v) {\n      v = clamp(v, p.min, p.max);\n      pushParam(p, v);\n      paint(v);\n    }\n\n    // drag\n    var dragging = false, startY = 0, startV = 0;\n    slot.addEventListener(\"pointerdown\", function (e) {\n      dragging = true;\n      startY = e.clientY;\n      startV = values[p.index];\n      col.classList.add(\"active\");\n      slot.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    slot.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var travel = 168;\n      var dv = (startY - e.clientY) / travel * (p.max - p.min);\n      setVal(startV + dv);\n    });\n    function endDrag(e) {\n      if (!dragging) return;\n      dragging = false;\n      col.classList.remove(\"active\");\n      try { slot.releasePointerCapture(e.pointerId); } catch (err) {}\n    }\n    slot.addEventListener(\"pointerup\", endDrag);\n    slot.addEventListener(\"pointercancel\", endDrag);\n\n    slot.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var step = (p.max - p.min) * 0.02;\n      setVal(values[p.index] - Math.sign(e.deltaY) * step);\n    }, { passive: false });\n\n    // double-click reset\n    slot.addEventListener(\"dblclick\", function () { setVal(p.def); });\n\n    p._setVal = setVal;\n    setVal(p.def);\n  });\n\n  // ---- chorus toggle ----\n  var chorusBtn = document.getElementById(\"chorusBtn\");\n  var chorusTxt = document.getElementById(\"chorusTxt\");\n  var chorusValEl = document.getElementById(\"chorusVal\");\n  var chorusParam = PARAMS[CHORUS_I];\n  var lastChorusOn = chorusParam.def;   // remembered amount when toggled back on\n\n  function syncChorus(v) {\n    var on = v > 0.001;\n    chorusBtn.classList.toggle(\"on\", on);\n    chorusTxt.textContent = on ? \"On\" : \"Off\";\n    chorusValEl.textContent = Math.round((v - chorusParam.min) / (chorusParam.max - chorusParam.min) * 100) + \"%\";\n    if (on) { lastChorusOn = v; }\n  }\n\n  chorusBtn.addEventListener(\"click\", function () {\n    var cur = values[CHORUS_I];\n    if (cur > 0.001) {\n      chorusParam._setVal(0);\n    } else {\n      chorusParam._setVal(lastChorusOn > 0.05 ? lastChorusOn : chorusParam.def);\n    }\n  });\n\n  // ---- on-screen keyboard ----\n  var keysEl = document.getElementById(\"keys\");\n  // one octave + a bit, starting at C4 (MIDI 60)\n  var WHITE = [60, 62, 64, 65, 67, 69, 71, 72, 74, 76];\n  var BLACK = [\n    { midi: 61, after: 0 }, { midi: 63, after: 1 },\n    { midi: 66, after: 3 }, { midi: 68, after: 4 }, { midi: 70, after: 5 },\n    { midi: 73, after: 7 }, { midi: 75, after: 8 }\n  ];\n  var keyEl = {};\n\n  WHITE.forEach(function (m) {\n    var k = document.createElement(\"div\");\n    k.className = \"wkey\";\n    k.dataset.midi = m;\n    keysEl.appendChild(k);\n    keyEl[m] = k;\n  });\n\n  var bwrap = document.createElement(\"div\");\n  bwrap.className = \"bkeys\";\n  keysEl.appendChild(bwrap);\n  var whiteCount = WHITE.length;\n  BLACK.forEach(function (b) {\n    var k = document.createElement(\"div\");\n    k.className = \"bkey\";\n    k.dataset.midi = b.midi;\n    // place between white keys: center at boundary\n    var leftPct = ((b.after + 1) / whiteCount) * 100;\n    k.style.left = \"calc(\" + leftPct + \"% - 2.7%)\";\n    bwrap.appendChild(k);\n    keyEl[b.midi] = k;\n  });\n\n  var down = {};\n\n  function noteOn(m) {\n    if (down[m]) return;\n    down[m] = true;\n    if (keyEl[m]) keyEl[m].classList.add(\"down\");\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(m, 0.9);\n    scopeKick();\n  }\n  function noteOff(m) {\n    if (!down[m]) return;\n    down[m] = false;\n    if (keyEl[m]) keyEl[m].classList.remove(\"down\");\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(m);\n  }\n\n  function bindKey(el) {\n    var m = parseInt(el.dataset.midi, 10);\n    el.addEventListener(\"pointerdown\", function (e) { e.preventDefault(); noteOn(m); el.setPointerCapture(e.pointerId); });\n    el.addEventListener(\"pointerup\", function () { noteOff(m); });\n    el.addEventListener(\"pointerleave\", function () { noteOff(m); });\n    el.addEventListener(\"pointercancel\", function () { noteOff(m); });\n  }\n  Object.keys(keyEl).forEach(function (m) { bindKey(keyEl[m]); });\n\n  // computer keyboard A..K row -> C major-ish\n  var KEYMAP = { a: 60, w: 61, s: 62, e: 63, d: 64, f: 65, t: 66, g: 67, y: 68, h: 69, u: 70, j: 71, k: 72 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m) noteOn(m);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m) noteOff(m);\n  });\n\n  // ---- animated doubled-waveform scope ----\n  var waveA = document.getElementById(\"waveA\");\n  var waveB = document.getElementById(\"waveB\");\n  var W = 600, H = 86, MID = H / 2;\n  var phase = 0;\n  var energy = 0.18;   // visual amplitude that swells when notes play\n\n  function scopeKick() { energy = 0.95; }\n\n  function buildPath(off, ampScale) {\n    var cutoff = values[0];          // brightness -> more harmonics\n    var pwm = values[3];             // pulse width adds a step\n    var chorus = values[5];          // width -> phase split between A/B\n    var amp = (0.22 + 0.55 * energy) * ampScale;\n    var harm = 1 + Math.round(cutoff * 5);\n    var pts = [];\n    for (var x = 0; x <= W; x += 6) {\n      var t = x / W * Math.PI * 2 * 2;           // 2 cycles across\n      var s = Math.sin(t + phase + off);\n      // add harmonics for brightness\n      for (var hN = 2; hN <= harm; hN++) {\n        s += Math.sin(t * hN + phase * hN + off) * (1 / hN) * 0.7;\n      }\n      // pulse-ish shaping from PWM\n      s += (Math.sin(t * 0.5 + off) > (pwm - 0.5) ? 0.18 : -0.18) * pwm;\n      var y = MID - s * amp * MID;\n      pts.push(x + \",\" + y.toFixed(1));\n    }\n    return \"M\" + pts.join(\" L\");\n  }\n\n  function frame() {\n    if (!document.hidden) {\n      phase += 0.06;\n      energy += (0.18 - energy) * 0.02;          // ease back to idle\n      var split = values[5] * 0.9;               // chorus widens the two traces\n      waveA.setAttribute(\"d\", buildPath(0, 1));\n      waveB.setAttribute(\"d\", buildPath(split + 0.4, 0.92));\n    }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- host handshake ----\n  function pushAll() {\n    PARAMS.forEach(function (p) { pushParam(p, values[p.index]); });\n  }\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(pushAll);\n  } else {\n    pushAll();\n  }\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  JUNO GLOW — a warm 6-voice DCO polyphonic synthesizer instrument.\n//  Inspired by the early-80s Japanese DCO poly workhorses: ONE rock-stable\n//  digitally-controlled oscillator per voice (a band-limited saw blended\n//  with a variable-width pulse driven by PWM), a square SUB an octave down\n//  and a sip of noise, into a resonant low-pass shaped by its own envelope\n//  (Cutoff + Env Amount + Resonance) and an amplitude AD/R contour. The\n//  whole bus then runs through the signature lush BBD-style stereo ENSEMBLE\n//  CHORUS that gives the shimmering width. Pure algorithm, no samples,\n//  no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// ---- chorus delay lines (BBD-style modulated stereo) ----------------\nconst CHORUS_LEN: i32 = 2048;   // ~42 ms at 48k — plenty for ensemble depth\nconst chL: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nconst chR: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF: i32 = 0;  // 0..1  -> base filter cutoff\nconst P_RESO:   i32 = 1;  // 0..1  -> filter resonance\nconst P_ENVAMT: i32 = 2;  // 0..1  -> filter envelope amount\nconst P_PWM:    i32 = 3;  // 0..1  -> pulse-width modulation depth\nconst P_SUB:    i32 = 4;  // 0..1  -> sub-oscillator level\nconst P_CHORUS: i32 = 5;  // 0..1  -> ensemble chorus depth/width\nconst P_REL:    i32 = 6;  // 0..1  -> amp + filter release time\nconst P_LEVEL:  i32 = 7;  // 0..1  -> master output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // DCO phase\nconst vSubPh:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // sub (half freq) phase\nconst vLfoPh:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // per-voice PWM LFO phase\nconst vNoise:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noise rng state\n\n// amplitude envelope (attack fixed-fast, sustain=1, then release)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\n// filter envelope (attack, decay to sustain, then release)\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// resonant 4-pole ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\nlet chWrite: i32 = 0;    // chorus delay-line write index\nlet chLfo: f32 = 0.0;    // chorus LFO phase\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhase[v] = 0.0; vSubPh[v] = 0.0; vLfoPh[v] = 0.0;\n    vNoise[v] = 0x1234 + v * 7919;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  for (let i = 0; i < CHORUS_LEN; i++) { chL[i] = 0.0; chR[i] = 0.0; }\n  ageCounter = 0;\n  chWrite = 0;\n  chLfo = 0.0;\n\n  params[P_CUTOFF] = 0.55;\n  params[P_RESO]   = 0.30;\n  params[P_ENVAMT] = 0.55;\n  params[P_PWM]    = 0.40;\n  params[P_SUB]    = 0.45;\n  params[P_CHORUS] = 0.60;\n  params[P_REL]    = 0.35;\n  params[P_LEVEL]  = 0.70;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vPhase[slot]  = 0.0;\n  vSubPh[slot]  = 0.0;\n  // stagger per-voice PWM LFO so a chord shimmers rather than pulsing in lockstep\n  vLfoPh[slot]  = f32(slot) * 0.17;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 3;  // release\n      vFStage[i] = 3;\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const pwmN: f32    = clampf(params[P_PWM], 0.0, 1.0);\n  const subN: f32    = clampf(params[P_SUB], 0.0, 1.0);\n  const chorusN: f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const relN: f32    = clampf(params[P_REL], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // envelope rates (fixed snappy attack, short filter decay; release knob-driven)\n  const atkS: f32 = 0.006;\n  const decS: f32 = 0.45;\n  const relS: f32 = 0.02 + relN * 2.4;\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n  const fSustain: f32 = 0.0;   // filter env decays fully toward base (classic pluck)\n\n  // base cutoff in Hz, exponential 60 Hz .. ~16 kHz\n  const baseHz: f32 = 60.0 * f32(Mathf.pow(256.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6 octaves\n  const envOct: f32 = envAmt * 6.0;\n  // resonance feedback 0..~3.6 (lush, just shy of self-oscillation)\n  const reso: f32 = resoN * 3.6;\n\n  // PWM: base duty 0.5, LFO swings it; depth from knob. Rate ~3 Hz slow drift.\n  const pwmDepth: f32 = pwmN * 0.42;\n  const pwmInc: f32 = 3.0 / sr;\n\n  // chorus: classic ensemble — single triangle-ish LFO, L/R in quadrature.\n  const chRate: f32 = 0.6;                 // ~0.6 Hz gentle wow\n  const chRateInc: f32 = chRate / sr;\n  const baseDelayMs: f32 = 11.0;           // ~11 ms center tap\n  const baseDelay: f32 = baseDelayMs * 0.001 * sr;\n  const chDepth: f32 = chorusN * 0.006 * sr; // up to ~6 ms swing\n  const chMix: f32 = chorusN;                // dry/wet blend toward wet\n\n  // headroom: 6 voices summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let dry: f32 = 0.0;\n\n    // advance the shared PWM modulator once per frame\n    // (each voice reads its own staggered phase below)\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope (A / sustain / R) -----------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {\n        aenv = 1.0;\n      } else if (astg == 3) {\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter envelope (A / D->sustain / R) -----------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate;\n        if (fenv <= fSustain) { fenv = fSustain; fstg = 0; }\n      } else if (fstg == 3) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- single DCO: saw + variable-width pulse ---------------\n      const inc: f32 = vFreq[v] / sr;\n\n      // per-voice PWM LFO\n      let lfo: f32 = vLfoPh[v];\n      lfo += pwmInc; if (lfo >= 1.0) lfo -= 1.0;\n      vLfoPh[v] = lfo;\n      const lfoTri: f32 = lfo < 0.5 ? (lfo * 4.0 - 1.0) : (3.0 - lfo * 4.0);\n      let pw: f32 = 0.5 + pwmDepth * lfoTri;\n      if (pw < 0.05) pw = 0.05;\n      if (pw > 0.95) pw = 0.95;\n\n      let ph: f32 = vPhase[v];\n      ph += inc; if (ph >= 1.0) ph -= 1.0;\n      vPhase[v] = ph;\n\n      // band-limited saw\n      let saw: f32 = 2.0 * ph - 1.0;\n      saw -= polyBlep(ph, inc);\n\n      // band-limited variable-width pulse (two saws)\n      let sq: f32 = ph < pw ? 1.0 : -1.0;\n      sq += polyBlep(ph, inc);\n      let ph2: f32 = ph + (1.0 - pw);\n      if (ph2 >= 1.0) ph2 -= 1.0;\n      sq -= polyBlep(ph2, inc);\n\n      // square SUB one octave down\n      const subInc: f32 = inc * 0.5;\n      let sph: f32 = vSubPh[v];\n      sph += subInc; if (sph >= 1.0) sph -= 1.0;\n      vSubPh[v] = sph;\n      let sub: f32 = sph < 0.5 ? 1.0 : -1.0;\n      sub += polyBlep(sph, subInc);\n      let sph2: f32 = sph + 0.5;\n      if (sph2 >= 1.0) sph2 -= 1.0;\n      sub -= polyBlep(sph2, subInc);\n\n      // a little noise for breath\n      let rs: i32 = vNoise[v];\n      rs ^= rs << 13; rs ^= rs >> 17; rs ^= rs << 5;\n      vNoise[v] = rs;\n      const noise: f32 = f32(rs) * (1.0 / 2147483648.0);\n\n      // DCO mix: saw + pulse as the core, plus sub + a touch of noise\n      let osc: f32 = saw * 0.55 + sq * 0.45 + sub * (subN * 0.9) + noise * 0.02;\n\n      // ---- resonant 4-pole low-pass -----------------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      dry += s3 * aenv * vVel[v];\n    }\n\n    // ---- bus sum + gentle analog glue ---------------------------\n    let mono: f32 = f32(Mathf.tanh(dry * voiceScale * 1.1));\n\n    // ---- ENSEMBLE CHORUS (stereo BBD-style) ---------------------\n    // write current mono signal into both delay lines\n    chL[chWrite] = mono;\n    chR[chWrite] = mono;\n\n    chLfo += chRateInc; if (chLfo >= 1.0) chLfo -= 1.0;\n    const aRad: f32 = chLfo * TWO_PI;\n    const modL: f32 = f32(Mathf.sin(aRad));\n    const modR: f32 = f32(Mathf.sin(aRad + 1.5707963)); // 90° apart for width\n\n    const dlL: f32 = baseDelay + chDepth * modL;\n    const dlR: f32 = baseDelay + chDepth * modR;\n\n    let rl: f32 = f32(chWrite) - dlL;\n    rl += f32(CHORUS_LEN);                 // bias positive (delay < CHORUS_LEN)\n    let rr: f32 = f32(chWrite) - dlR;\n    rr += f32(CHORUS_LEN);\n\n    let il0: i32 = i32(rl) % CHORUS_LEN;\n    if (il0 < 0) il0 += CHORUS_LEN;\n    let il1: i32 = il0 + 1; if (il1 >= CHORUS_LEN) il1 -= CHORUS_LEN;\n    const fl: f32 = rl - f32(i32(rl));\n    const wetL: f32 = chL[il0] + (chL[il1] - chL[il0]) * fl;\n\n    let ir0: i32 = i32(rr) % CHORUS_LEN;\n    if (ir0 < 0) ir0 += CHORUS_LEN;\n    let ir1: i32 = ir0 + 1; if (ir1 >= CHORUS_LEN) ir1 -= CHORUS_LEN;\n    const fr: f32 = rr - f32(i32(rr));\n    const wetR: f32 = chR[ir0] + (chR[ir1] - chR[ir0]) * fr;\n\n    chWrite++; if (chWrite >= CHORUS_LEN) chWrite = 0;\n\n    // blend: at chMix=0 pure mono dry; at chMix=1 wide wet ensemble\n    let outL: f32 = mono * (1.0 - chMix * 0.5) + wetL * chMix;\n    let outR: f32 = mono * (1.0 - chMix * 0.5) + wetR * chMix;\n\n    outL *= level;\n    outR *= level;\n\n    // final safety clamp\n    if (outL > 1.0) outL = 1.0; else if (outL < -1.0) outL = -1.0;\n    if (outR > 1.0) outR = 1.0; else if (outR < -1.0) outR = -1.0;\n\n    outBuf[f] = outL;\n    outBuf[MAX_FRAMES + f] = outR;\n  }\n}\n",
  "publishedAt": 1751000095000
}