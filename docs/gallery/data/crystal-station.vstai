  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Crystal Station</title>\n<style>\n  :root{ --acc:#5ad0ff; --acc2:#ffcf6a; --bg0:#05080d; --bg1:#0c141f; --ink:#e6f2fb; --dim:#5f7488; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#102032 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,780px); border-radius:16px; padding:16px 20px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#16263a,#070d15);\n    border:1px solid rgba(90,208,255,.18); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(190,235,255,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.15em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2);\n    box-shadow:0 0 10px var(--acc2),0 0 20px var(--acc2); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.45; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:12px; position:relative;\n    background:linear-gradient(180deg,#02201c,#04140f); border:1px solid rgba(90,255,200,.14); box-shadow:inset 0 2px 20px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:10px; letter-spacing:.22em; color:#6affce; z-index:2; text-shadow:0 0 6px rgba(80,255,180,.6); }\n\n  .vsel{ display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:12px; }\n  .vbtn{ text-align:center; padding:9px 4px; border-radius:9px; cursor:pointer; font-size:11px; letter-spacing:.12em; text-transform:uppercase;\n    background:linear-gradient(180deg,#13243600,#0c1a28); border:1px solid rgba(90,208,255,.2); color:var(--dim); transition:all .12s; }\n  .vbtn.sel{ color:#06121c; background:linear-gradient(180deg,var(--acc),#3ba8e0); box-shadow:0 0 16px rgba(90,208,255,.5); font-weight:700; }\n\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 2px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(150,210,240,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(90,208,255,.6)); }\n  .pcap{ fill:#0a1622; stroke:rgba(90,208,255,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(90,208,255,.08);\n    padding:1px 8px; border-radius:7px; border:1px solid rgba(90,208,255,.18); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">CRYSTAL&nbsp;STATION</span>\n      <span class=\"sub\">pcm workstation</span>\n      <span class=\"led\"></span>\n    </header>\n    <div class=\"screen\"><div class=\"scrlbl\" id=\"vname\">UNIVERSE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"vsel\" id=\"vsel\"></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var VOICES=[\"Piano\",\"Universe\",\"Bell\"];\n  var PARAMS=[\n    {name:\"Attack\",idx:1,def:0.04,ms:true},\n    {name:\"Decay\", idx:2,def:0.4,ms:true},\n    {name:\"Tone\",  idx:3,def:0.7},\n    {name:\"Chorus\",idx:4,def:0.45},\n    {name:\"Level\", idx:5,def:0.8}\n  ];\n  var vals={1:0.04,2:0.4,3:0.7,4:0.45,5:0.8};\n  var voiceV=0.5; // param 0\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function ms(v){ var m=Math.round(2+v*v*1500); return m>=1000?(m/1000).toFixed(1)+\"s\":m+\"ms\"; }\n  function fmt(p,v){ return p.ms?ms(v):Math.round(v*100)+\"%\"; }\n  function selFromV(v){ var s=Math.floor(v*2.999); return s<0?0:(s>2?2:s); }\n\n  // ---- voice selector ----\n  var vsel=document.getElementById(\"vsel\"), vname=document.getElementById(\"vname\");\n  var vbtns=VOICES.map(function(nm,i){\n    var b=document.createElement(\"div\"); b.className=\"vbtn\"; b.textContent=nm; vsel.appendChild(b);\n    b.addEventListener(\"click\",function(){ voiceV=(i+0.5)/3; setVoiceUI(); send(0,voiceV); });\n    return b;\n  });\n  function setVoiceUI(){ var s=selFromV(voiceV); for(var i=0;i<3;i++) vbtns[i].classList.toggle(\"sel\",i===s); vname.textContent=VOICES[s].toUpperCase(); }\n\n  // ---- knobs ----\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=PARAMS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#5ad0ff\"/><stop offset=\"1\" stop-color=\"#ffcf6a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle>'+\n      '<line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){\n      var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2));\n      ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=fmt(p,v);\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- evolving PCM waveform display (changes with voice + tone) ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H);\n    var s=selFromV(voiceV), tone=vals[3], ch=vals[4];\n    var mid=H*0.55;\n    ctx.strokeStyle=\"rgba(80,255,200,0.10)\"; ctx.lineWidth=1;\n    for(var gx=0;gx<=8;gx++){var X=W*gx/8;ctx.beginPath();ctx.moveTo(X,8);ctx.lineTo(X,H-8);ctx.stroke();}\n    function w(off,col,amp){\n      ctx.beginPath();\n      for(var x=0;x<=W;x+=2){\n        var t=x/W; var y=0;\n        if(s===0){ for(var h=1;h<=6;h++) y+=Math.sin(t*Math.PI*2*h*2+ts/300+off)/h; y*=Math.exp(-t*1.5); } // piano: decaying harmonics\n        else if(s===1){ y=Math.sin(t*Math.PI*4+ts/600+off)+0.4*Math.sin(t*Math.PI*8+ts/420); } // pad: smooth\n        else { var m=Math.sin(t*Math.PI*2*3.5+ts/200); y=Math.sin(t*Math.PI*2*4+m*2+off); } // bell: FM\n        ctx.lineTo(x, mid + y*amp*(0.5+tone*0.7));\n      }\n      ctx.strokeStyle=col; ctx.lineWidth=2; ctx.shadowColor=col; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    }\n    w(0,\"rgba(90,208,255,0.9)\",18);\n    if(ch>0.05) w(0.5+ch,\"rgba(255,207,106,\"+(0.25+ch*0.5)+\")\",16); // chorus ghost\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function boot(){ host=window.vstai||null; send(0,voiceV); setVoiceUI(); PARAMS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CRYSTAL STATION — a PCM-workstation synth (Korg M1 lineage).\n//  A polyphonic multisample player: three ORIGINAL, self-authored PCM\n//  voices (a bright percussive PIANO, an airy PAD/\"universe\", and an FM\n//  BELL) are baked in as base64 Int16 PCM @ 22050 Hz (recorded at C3 =\n//  130.81 Hz), decoded at init() and played back pitch-tracked across the\n//  keyboard with an ADSR amp envelope, a tone filter and a lush built-in\n//  CHORUS/space — the signature late-80s digital-workstation sound.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst SAMP_CAP: i32 = 80000;\nconst SAMP_SR: f32 = 22050.0;\nconst BASE_HZ: f32 = 130.81;       // sample recorded pitch (C3)\nconst NVOX: i32 = 8;               // polyphony\nconst NSAMP: i32 = 3;              // baked voices\nconst CH_LEN: i32 = 4096;          // chorus delay ring (power of two)\nconst CH_MASK: i32 = CH_LEN - 1;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst samp: StaticArray<f32> = new StaticArray<f32>(SAMP_CAP);\nlet sampLen: i32 = 0;\nconst sOff: StaticArray<i32> = new StaticArray<i32>(NSAMP);\nconst sLen: StaticArray<i32> = new StaticArray<i32>(NSAMP);\n\n// poly voice state\nconst vSamp:  StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vPos:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vRate:  StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vEnv:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vState: StaticArray<i32> = new StaticArray<i32>(NVOX); // 0 off,1 held,2 release\nconst vAmp:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote:  StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\n\nconst chL: StaticArray<f32> = new StaticArray<f32>(CH_LEN);\nlet chW: i32 = 0;\nlet chPh: f32 = 0.0;\nlet toneZ: f32 = 0.0;\n\nlet sampleRate: f32 = 48000.0;\n\nconst P_VOICE: i32 = 0;\nconst P_ATTACK: i32 = 1;\nconst P_RELEASE: i32 = 2;\nconst P_TONE: i32 = 3;\nconst P_CHORUS: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\n\nconst PCM_B64: string = \"\";\n\nfunction decodePCM(): void {\n  const s = PCM_B64; const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else { let val = (byte << 8) | lo; if (val >= 32768) val -= 65536; if (si < SAMP_CAP) { samp[si] = f32(val) / 32768.0; si++; } lo = -1; }\n    }\n  }\n  sampLen = si;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0; chW = 0; chPh = 0.0; toneZ = 0.0;\n  for (let i = 0; i < NVOX; i++) { vState[i] = 0; vPos[i] = 0.0; vEnv[i] = 0.0; vRate[i] = 1.0; vSamp[i] = 0; vAmp[i] = 0.0; vNote[i] = -1; }\n  for (let i = 0; i < CH_LEN; i++) chL[i] = 0.0;\n  sOff[0]=0; sLen[0]=20947; sOff[1]=20947; sLen[1]=30869; sOff[2]=51816; sLen[2]=22050;\n  params[P_VOICE] = 0.0;\n  params[P_ATTACK] = 0.04;\n  params[P_RELEASE] = 0.4;\n  params[P_TONE] = 0.7;\n  params[P_CHORUS] = 0.45;\n  params[P_LEVEL] = 0.8;\n  decodePCM();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let sel: i32 = i32(clampf(params[P_VOICE], 0.0, 1.0) * 2.999);\n  if (sel < 0) sel = 0; if (sel >= NSAMP) sel = NSAMP - 1;\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vSamp[slot] = sel;\n  vPos[slot] = 0.0;\n  vRate[slot] = (f > 0.0 ? f : BASE_HZ) / BASE_HZ * (SAMP_SR / sampleRate);\n  vEnv[slot] = 0.0;\n  vState[slot] = 1;\n  vAmp[slot] = clampf(v, 0.05, 1.0);\n  vNote[slot] = id;\n}\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NVOX; i++) { if (vState[i] != 0 && vNote[i] == id) vState[i] = 3; }\n}\n\nexport function process(n: i32): void {\n  const attackN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const releaseN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const chorusN: f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.002 + attackN * attackN * 1.5) / sampleRate;\n  const decaySec: f32 = 0.08 + releaseN * releaseN * 4.0;   // held-note decay (Decay knob)\n  const decayCoef: f32 = f32(Mathf.exp(-1.0 / (decaySec * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.06 * sampleRate)));   // fixed quick release\n  const lpco: f32 = 0.05 + 0.94 * toneN;\n  const chDepth: f32 = chorusN * 0.011 * sampleRate;   // up to ~11 ms\n  const chBase: f32 = 0.008 * sampleRate;\n  const chRate: f32 = 0.8;\n  const chPhInc: f32 = chRate / sampleRate * 6.2831853;\n  const chMix: f32 = chorusN * 0.6;\n  const out: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let dry: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vState[s] == 0) continue;\n      const so: i32 = sOff[vSamp[s]];\n      const sl: i32 = sLen[vSamp[s]];\n      const pos: f32 = vPos[s];\n      const ip: i32 = i32(pos);\n      if (ip >= sl - 1) { vState[s] = 0; continue; }\n      const fr: f32 = pos - f32(ip);\n      const a: f32 = samp[so + ip];\n      const b: f32 = samp[so + ip + 1];\n      let smp: f32 = a + (b - a) * fr;\n      // amp env: attack ramp, hold at 1 while held, exp release\n      if (vState[s] == 1) { vEnv[s] += atkInc; if (vEnv[s] >= 1.0) { vEnv[s] = 1.0; vState[s] = 2; } }\n      else if (vState[s] == 2) { vEnv[s] *= decayCoef; if (vEnv[s] < 0.0004) vState[s] = 0; }\n      else { vEnv[s] *= relCoef; if (vEnv[s] < 0.0004) vState[s] = 0; }\n      dry += smp * vEnv[s] * vAmp[s];\n      vPos[s] = pos + vRate[s];\n    }\n    // tone low-pass\n    toneZ += (dry - toneZ) * lpco;\n    let mono: f32 = toneZ;\n    // chorus: modulated delay tap, anti-phase L/R for width\n    chL[chW] = mono;\n    chPh += chPhInc; if (chPh > 6.2831853) chPh -= 6.2831853;\n    const d1: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh)));\n    const d2: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh + 2.094)));\n    const rp1: f32 = f32(chW) - d1; let i1: i32 = i32(rp1); const f1: f32 = rp1 - f32(i1);\n    const rp2: f32 = f32(chW) - d2; let i2: i32 = i32(rp2); const f2: f32 = rp2 - f32(i2);\n    const c1: f32 = chL[i1 & CH_MASK] + (chL[(i1 + 1) & CH_MASK] - chL[i1 & CH_MASK]) * f1;\n    const c2: f32 = chL[i2 & CH_MASK] + (chL[(i2 + 1) & CH_MASK] - chL[i2 & CH_MASK]) * f2;\n    chW = (chW + 1) & CH_MASK;\n\n    let l: f32 = (mono + c1 * chMix) * out;\n    let r: f32 = (mono + c2 * chMix) * out;\n    if (l > 1.4) l = 1.4; else if (l < -1.4) l = -1.4;\n    if (r > 1.4) r = 1.4; else if (r < -1.4) r = -1.4;\n    outBuf[i] = l;\n    outBuf[MAX_FRAMES + i] = r;\n  }\n}\n",
  "publishedAt": 1751000154000
}