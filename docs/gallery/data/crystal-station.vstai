      "name": "Voice",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Attack",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Chorus",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 5,
