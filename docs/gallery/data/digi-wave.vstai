{
  "format": 1,
  "name": "Digi Wave",
  "isInstrument": true,
  "explanation": "A hybrid digital/analog polyphonic synthesizer with up to eight voices. Each voice plays a selectable single-cycle digital waveform from a bank of eight harmonically-distinct tables (organ, reed, hollow square, piano-ish, buzzy saw, pulse, bell and sync-buzz) built at startup, then runs it through a warm resonant analog-style 4-pole low-pass with its own attack/release contour. A built-in stereo delay/chorus adds the signature shimmer. Controls: Wave select, Cutoff, Resonance, Env Amount, Attack, Release, Delay mix and Level. Digital edge meets analog warmth.",
  "params": [
    {
      "name": "Wave",
      "index": 0,
      "min": 0,
      "max": 7,
      "default": 0
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "EnvAmount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Delay",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\n<title>Digi Wave</title>\n<style>\n  :root {\n    --ac: #43e0c4;     /* teal */\n    --ac2: #7a86ff;    /* indigo */\n    --panel: #232529;\n    --panel2: #1a1c20;\n    --ink: #cdd6dd;\n    --lcd: #0a1f17;\n    --lcdink: #57f6b8;\n    --metal: #3a3d43;\n  }\n  * { box-sizing: border-box; -webkit-user-select: none; user-select: none; }\n  html, body { margin: 0; height: 100%; }\n  body {\n    font: 12px ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", sans-serif;\n    color: var(--ink);\n    background:\n      radial-gradient(120% 80% at 50% -10%, #2c2f35 0%, #15161a 60%, #0c0d10 100%);\n    display: flex; align-items: center; justify-content: center;\n    overflow: hidden;\n  }\n\n  .unit {\n    width: 720px;\n    border-radius: 14px;\n    padding: 18px 20px 22px;\n    background:\n      linear-gradient(180deg, #2b2e33 0%, #212327 8%, #1d1f23 100%);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(255,255,255,.05),\n      inset 0 -2px 6px rgba(0,0,0,.5);\n    border: 1px solid #0c0d10;\n    position: relative;\n  }\n  /* brushed-metal hairlines */\n  .unit::before {\n    content: \"\"; position: absolute; inset: 0; border-radius: 14px; pointer-events: none;\n    background: repeating-linear-gradient(90deg, rgba(255,255,255,.012) 0 2px, transparent 2px 4px);\n    opacity: .6;\n  }\n\n  .top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }\n  .brand { display: flex; align-items: baseline; gap: 10px; }\n  .brand .logo {\n    font-weight: 800; letter-spacing: 2px; font-size: 19px;\n    color: #eef3f6; text-shadow: 0 1px 0 #000;\n  }\n  .brand .logo b { color: var(--ac); }\n  .brand .sub {\n    font-size: 9px; letter-spacing: 3px; color: #7d848c; text-transform: uppercase;\n  }\n  .poly-leds { display: flex; gap: 5px; }\n  .pled {\n    width: 8px; height: 8px; border-radius: 50%;\n    background: #16181b; box-shadow: inset 0 0 2px #000;\n    transition: background .08s, box-shadow .08s;\n  }\n  .pled.on { background: var(--ac); box-shadow: 0 0 7px var(--ac), inset 0 0 2px #073; }\n\n  .grid { display: grid; grid-template-columns: 300px 1fr; gap: 18px; }\n\n  /* ---------- LCD + wave readout ---------- */\n  .lcd {\n    background:\n      linear-gradient(180deg, #0c2a1f 0%, #08201700 30%),\n      repeating-linear-gradient(0deg, rgba(0,0,0,.18) 0 2px, transparent 2px 4px),\n      var(--lcd);\n    border-radius: 7px;\n    border: 2px solid #05130d;\n    box-shadow: inset 0 0 18px rgba(0,0,0,.85), inset 0 0 0 1px #143b2c, 0 0 18px rgba(67,224,196,.08);\n    padding: 12px 14px;\n    position: relative;\n    overflow: hidden;\n  }\n  .lcd::after { /* scan glow sweep */\n    content:\"\"; position:absolute; left:-30%; top:0; width:30%; height:100%;\n    background: linear-gradient(90deg, transparent, rgba(87,246,184,.07), transparent);\n    animation: scan 5.5s linear infinite;\n  }\n  @keyframes scan { 0% { left:-30%; } 100% { left:120%; } }\n\n  .lcd-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:6px; }\n  .lcd-title { color: var(--lcdink); font: 700 11px ui-monospace, monospace; letter-spacing:2px; text-shadow:0 0 6px rgba(87,246,184,.6); }\n  .lcd-wn { color: var(--lcdink); font: 700 11px ui-monospace, monospace; opacity:.85; text-shadow:0 0 6px rgba(87,246,184,.5); }\n\n  svg.scope { display:block; width:100%; height:96px; }\n  .scope .grid-line { stroke: rgba(87,246,184,.10); stroke-width:1; }\n  .scope .wave { fill:none; stroke: var(--lcdink); stroke-width:2.2;\n    filter: drop-shadow(0 0 4px rgba(87,246,184,.75));\n    stroke-linejoin:round; stroke-linecap:round; }\n  .scope .ghost { fill:none; stroke: rgba(87,246,184,.18); stroke-width:6; }\n\n  .lcd-foot { margin-top:6px; display:flex; justify-content:space-between;\n    color: rgba(87,246,184,.6); font: 700 9px ui-monospace, monospace; letter-spacing:1px; }\n  .blink { animation: blink 1.1s steps(2,start) infinite; }\n  @keyframes blink { 50% { opacity:.25; } }\n\n  /* ---------- membrane wave buttons ---------- */\n  .waves { margin-top:14px; }\n  .waves .lbl { font-size:9px; letter-spacing:2px; color:#8a929a; text-transform:uppercase; margin-bottom:6px; }\n  .wgrid { display:grid; grid-template-columns: repeat(4, 1fr); gap:7px; }\n  .wbtn {\n    height:38px; border-radius:5px; cursor:pointer; position:relative;\n    background: linear-gradient(180deg, #34373d, #232529);\n    border: 1px solid #0e0f12;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,.06), 0 2px 3px rgba(0,0,0,.4);\n    display:flex; flex-direction:column; align-items:center; justify-content:center; gap:2px;\n    transition: transform .05s, box-shadow .12s, background .12s;\n    color:#9aa2aa;\n  }\n  .wbtn .num { font:700 8px ui-monospace,monospace; opacity:.6; }\n  .wbtn .nm { font:700 9px ui-sans-serif,system-ui,sans-serif; letter-spacing:.5px; }\n  .wbtn:hover { background: linear-gradient(180deg, #3b3f46, #26282d); color:#c6ced5; }\n  .wbtn:active { transform: translateY(1px); }\n  .wbtn.sel {\n    color:#04130d;\n    background: linear-gradient(180deg, var(--ac), #28b79c);\n    border-color: #0c5a4c;\n    box-shadow: 0 0 14px rgba(67,224,196,.5), inset 0 1px 0 rgba(255,255,255,.4);\n  }\n  .wbtn.sel .num { opacity:.55; }\n\n  /* ---------- right: dials ---------- */\n  .dials {\n    display:grid; grid-template-columns: repeat(4, 1fr); gap: 10px 6px;\n    align-content:start;\n  }\n  .dial { display:flex; flex-direction:column; align-items:center; gap:4px; }\n  .knob {\n    --ang: -135deg;\n    width:62px; height:62px; border-radius:50%; position:relative; cursor:ns-resize;\n    background:\n      radial-gradient(60% 60% at 38% 32%, #4a4e55 0%, #2c2f34 55%, #202226 100%);\n    box-shadow:\n      0 4px 8px rgba(0,0,0,.55),\n      inset 0 1px 0 rgba(255,255,255,.10),\n      inset 0 -3px 6px rgba(0,0,0,.5);\n    border: 1px solid #0d0e11;\n    touch-action:none;\n  }\n  /* teal glow ring driven by --p (0..1) via conic-gradient */\n  .knob .ring {\n    position:absolute; inset:-5px; border-radius:50%; pointer-events:none;\n    background: conic-gradient(from 225deg,\n      var(--ac) calc(var(--p, .5) * 270deg), rgba(255,255,255,.05) 0 270deg, transparent 270deg);\n    -webkit-mask: radial-gradient(closest-side, transparent 78%, #000 80%);\n    mask: radial-gradient(closest-side, transparent 78%, #000 80%);\n    filter: drop-shadow(0 0 5px rgba(67,224,196,.45));\n    transition: filter .15s;\n  }\n  .knob.big { width:88px; height:88px; }\n  .knob.big .ring { background: conic-gradient(from 225deg,\n      var(--ac) calc(var(--p,.5)*270deg), var(--ac2) calc(var(--p,.5)*270deg) calc(var(--p,.5)*270deg + 1deg), rgba(255,255,255,.05) 0 270deg, transparent 270deg);\n      filter: drop-shadow(0 0 9px rgba(67,224,196,.55)); }\n  .knob .pointer {\n    position:absolute; left:50%; top:50%; width:3px; height:42%;\n    background: linear-gradient(180deg, var(--ac), #1c8f7c);\n    border-radius:2px; transform-origin:50% 100%;\n    transform: translate(-50%,-100%) rotate(var(--ang));\n    box-shadow:0 0 6px rgba(67,224,196,.7);\n  }\n  .knob.big .pointer { height:44%; }\n  .knob:active { cursor:grabbing; }\n  .knob .cap { position:absolute; inset:30%; border-radius:50%;\n    background: radial-gradient(50% 50% at 40% 35%, #41454c, #25282d);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,.08); }\n\n  .dial .nm { font-size:9px; letter-spacing:1px; color:#9aa2aa; text-transform:uppercase; }\n  .dial .val { font:700 10px ui-monospace,monospace; color:var(--ac); text-shadow:0 0 6px rgba(67,224,196,.35); }\n  .dial.big { grid-column: span 2; }\n\n  .filt-head { grid-column:1/-1; display:flex; align-items:center; gap:8px; margin:2px 0 -2px; }\n  .filt-head .t { font-size:9px; letter-spacing:3px; color:#7d848c; text-transform:uppercase; }\n  .filt-head .ln { flex:1; height:1px; background:linear-gradient(90deg, #3a3d43, transparent); }\n\n  .hint { margin-top:14px; text-align:center; font-size:9px; color:#5f666d; letter-spacing:.5px; }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"top\">\n      <div class=\"brand\">\n        <div class=\"logo\">DIGI <b>WAVE</b></div>\n        <div class=\"sub\">Digital&nbsp;Wave&nbsp;·&nbsp;Analog&nbsp;Filter</div>\n      </div>\n      <div class=\"poly-leds\" id=\"leds\"></div>\n    </div>\n\n    <div class=\"grid\">\n      <!-- LEFT: LCD + membrane wave bank -->\n      <div class=\"left\">\n        <div class=\"lcd\">\n          <div class=\"lcd-head\">\n            <div class=\"lcd-title\">DWGS</div>\n            <div class=\"lcd-wn\" id=\"lcdWn\">W0</div>\n          </div>\n          <svg class=\"scope\" viewBox=\"0 0 260 96\" preserveAspectRatio=\"none\">\n            <line class=\"grid-line\" x1=\"0\" y1=\"48\" x2=\"260\" y2=\"48\"/>\n            <line class=\"grid-line\" x1=\"65\" y1=\"0\" x2=\"65\" y2=\"96\"/>\n            <line class=\"grid-line\" x1=\"130\" y1=\"0\" x2=\"130\" y2=\"96\"/>\n            <line class=\"grid-line\" x1=\"195\" y1=\"0\" x2=\"195\" y2=\"96\"/>\n            <path class=\"ghost\" id=\"ghost\" d=\"\"/>\n            <path class=\"wave\" id=\"wave\" d=\"\"/>\n          </svg>\n          <div class=\"lcd-foot\">\n            <span id=\"lcdName\">ORGAN</span>\n            <span class=\"blink\">▮ READY</span>\n          </div>\n        </div>\n\n        <div class=\"waves\">\n          <div class=\"lbl\">Digital Waveform</div>\n          <div class=\"wgrid\" id=\"wgrid\"></div>\n        </div>\n      </div>\n\n      <!-- RIGHT: dials -->\n      <div class=\"dials\" id=\"dials\"></div>\n    </div>\n\n    <div class=\"hint\">drag dials vertically · double-click to reset · click pads to select wave</div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host bridge -------------------------------------------------\n  function send(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- param model -------------------------------------------------\n  // indices must match spec.json / assembly.ts\n  var DIALS = [\n    { i:1, nm:\"Cutoff\",    def:0.55, big:true,  fmt:hzFmt },\n    { i:2, nm:\"Reso\",      def:0.30, fmt:pctFmt },\n    { i:3, nm:\"Env Amt\",   def:0.55, fmt:pctFmt },\n    { i:4, nm:\"Attack\",    def:0.04, fmt:msFmt(1.8) },\n    { i:5, nm:\"Release\",   def:0.35, fmt:msFmt(2.5) },\n    { i:6, nm:\"Delay\",     def:0.30, fmt:pctFmt },\n    { i:7, nm:\"Level\",     def:0.60, fmt:pctFmt }\n  ];\n\n  var WAVES = [\n    { nm:\"ORGAN\",  spec:[1,.5,.35,.25,0,.18,0,.12] },\n    { nm:\"REED\",   spec:[1,0,.33,0,.85,0,.45,0] },\n    { nm:\"SQUARE\", spec:[1,0,.33,0,.2,0,.14,0] },\n    { nm:\"PIANO\",  spec:[1,.83,.9,.78,.45,.3,.21,.14] },\n    { nm:\"SAW\",    spec:[1,.5,.33,.25,.2,.16,.14,.12] },\n    { nm:\"PULSE\",  spec:[1,0,.33,0,0,0,.14,0] },\n    { nm:\"BELL\",   spec:[.7,0,0,.5,0,0,.6,0] },\n    { nm:\"BUZZ\",   spec:[.2,.5,.8,1,.8,.5,.2,.08] }\n  ];\n\n  function pctFmt(v){ return Math.round(v*100) + \"%\"; }\n  function hzFmt(v){ var hz = 60*Math.pow(256, v); return hz>=1000 ? (hz/1000).toFixed(1)+\"k\" : Math.round(hz)+\"Hz\"; }\n  function msFmt(max){ return function(v){ var s=0.005+v*max; return s<1 ? Math.round(s*1000)+\"ms\" : s.toFixed(2)+\"s\"; }; }\n\n  var state = {}; // index -> value\n  var waveIdx = 0;\n\n  // ---- build dials -------------------------------------------------\n  var dialsEl = document.getElementById(\"dials\");\n  var filtHead = document.createElement(\"div\");\n  filtHead.className = \"filt-head\";\n  filtHead.innerHTML = '<span class=\"t\">Analog Filter</span><span class=\"ln\"></span>';\n  dialsEl.appendChild(filtHead);\n\n  var dialNodes = {};\n  DIALS.forEach(function (d, idx) {\n    if (idx === 5) {\n      var h2 = document.createElement(\"div\");\n      h2.className = \"filt-head\";\n      h2.innerHTML = '<span class=\"t\">Output</span><span class=\"ln\"></span>';\n      dialsEl.appendChild(h2);\n    }\n    var cell = document.createElement(\"div\");\n    cell.className = \"dial\" + (d.big ? \" big\" : \"\");\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\" + (d.big ? \" big\" : \"\");\n    knob.innerHTML = '<div class=\"ring\"></div><div class=\"cap\"></div><div class=\"pointer\"></div>';\n    var nm = document.createElement(\"div\"); nm.className = \"nm\"; nm.textContent = d.nm;\n    var val = document.createElement(\"div\"); val.className = \"val\";\n    cell.appendChild(knob); cell.appendChild(nm); cell.appendChild(val);\n    dialsEl.appendChild(cell);\n    dialNodes[d.i] = { knob: knob, val: val, d: d };\n    attachKnob(knob, d, val);\n    setDial(d.i, d.def, false);\n  });\n\n  function setDial(index, v, push) {\n    v = Math.max(0, Math.min(1, v));\n    state[index] = v;\n    var node = dialNodes[index];\n    var ang = -135 + v * 270;\n    node.knob.style.setProperty(\"--p\", v);\n    node.knob.style.setProperty(\"--ang\", ang + \"deg\");\n    node.val.textContent = node.d.fmt(v);\n    if (push) send(index, v);\n  }\n\n  function attachKnob(knob, d, val) {\n    var dragging = false, startY = 0, startV = 0;\n    function down(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = state[d.i];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", move);\n      window.addEventListener(\"mouseup\", up);\n      window.addEventListener(\"touchmove\", move, { passive:false });\n      window.addEventListener(\"touchend\", up);\n    }\n    function move(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dv = (startY - y) / 200;            // 200px = full travel\n      if (e.shiftKey) dv *= 0.25;             // fine\n      setDial(d.i, startV + dv, true);\n      e.preventDefault();\n    }\n    function up() {\n      dragging = false;\n      window.removeEventListener(\"mousemove\", move);\n      window.removeEventListener(\"mouseup\", up);\n      window.removeEventListener(\"touchmove\", move);\n      window.removeEventListener(\"touchend\", up);\n    }\n    knob.addEventListener(\"mousedown\", down);\n    knob.addEventListener(\"touchstart\", down, { passive:false });\n    knob.addEventListener(\"dblclick\", function () { setDial(d.i, d.def, true); });\n    knob.addEventListener(\"wheel\", function (e) {\n      setDial(d.i, state[d.i] - e.deltaY / 1500, true);\n      e.preventDefault();\n    }, { passive:false });\n  }\n\n  // ---- wave bank buttons ------------------------------------------\n  var wgrid = document.getElementById(\"wgrid\");\n  var wbtns = [];\n  WAVES.forEach(function (w, i) {\n    var b = document.createElement(\"div\");\n    b.className = \"wbtn\";\n    b.innerHTML = '<span class=\"num\">'+i+'</span><span class=\"nm\">'+w.nm+'</span>';\n    b.addEventListener(\"click\", function () { selectWave(i, true); });\n    wgrid.appendChild(b);\n    wbtns.push(b);\n  });\n\n  function selectWave(i, push) {\n    waveIdx = i;\n    for (var k = 0; k < wbtns.length; k++) wbtns[k].classList.toggle(\"sel\", k === i);\n    document.getElementById(\"lcdWn\").textContent = \"W\" + i;\n    document.getElementById(\"lcdName\").textContent = WAVES[i].nm;\n    drawWave(i);\n    if (push) send(0, i); // P_WAVE\n  }\n\n  // ---- LCD waveform render (additive from harmonic spec) ----------\n  var wavePath = document.getElementById(\"wave\");\n  var ghostPath = document.getElementById(\"ghost\");\n  function buildWaveSamples(i) {\n    var spec = WAVES[i].spec, N = 130, out = new Array(N), peak = 1e-4;\n    for (var x = 0; x < N; x++) {\n      var ph = 2 * Math.PI * x / N, s = 0;\n      for (var h = 0; h < spec.length; h++) {\n        if (spec[h]) s += spec[h] * Math.sin(ph * (h + 1));\n      }\n      out[x] = s; var a = Math.abs(s); if (a > peak) peak = a;\n    }\n    for (var x2 = 0; x2 < N; x2++) out[x2] /= peak;\n    return out;\n  }\n  function pathFor(samples) {\n    // draw two cycles across width 260, centered at y=48, amp 38\n    var N = samples.length, W = 260, cyc = 2, d = \"\";\n    for (var x = 0; x <= W; x++) {\n      var t = (x / W) * cyc * N;\n      var i0 = Math.floor(t) % N, i1 = (i0 + 1) % N, fr = t - Math.floor(t);\n      var s = samples[i0] + (samples[i1] - samples[i0]) * fr;\n      var y = 48 - s * 38;\n      d += (x === 0 ? \"M\" : \"L\") + x + \" \" + y.toFixed(1) + \" \";\n    }\n    return d;\n  }\n  function drawWave(i) {\n    var d = pathFor(buildWaveSamples(i));\n    wavePath.setAttribute(\"d\", d);\n    ghostPath.setAttribute(\"d\", d);\n  }\n\n  // ---- poly LEDs (decorative + reactive to noteOn if host calls) ---\n  var ledsEl = document.getElementById(\"leds\");\n  var leds = [];\n  for (var L = 0; L < 8; L++) {\n    var el = document.createElement(\"div\"); el.className = \"pled\";\n    ledsEl.appendChild(el); leds.push(el);\n  }\n  var ledI = 0;\n  // gentle idle chase so the panel feels alive\n  setInterval(function () {\n    for (var k = 0; k < 8; k++) leds[k].classList.remove(\"on\");\n    leds[ledI % 8].classList.add(\"on\");\n    leds[(ledI + 4) % 8].classList.add(\"on\");\n    ledI++;\n  }, 420);\n\n  // ---- push everything to host on ready ---------------------------\n  function pushAll() {\n    selectWave(0, true);\n    DIALS.forEach(function (d) { setDial(d.i, state[d.i], true); });\n  }\n\n  // init visuals immediately (no host)\n  selectWave(0, false);\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(pushAll);\n  } else {\n    pushAll();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DIGI WAVE — a hybrid DIGITAL/ANALOG polyphonic synthesizer instrument.\n//  Lineage of the early-80s \"digital wave generator + analog filter\" poly:\n//  each voice reads a SELECTABLE single-cycle DIGITAL waveform from a small\n//  bank of harmonically-distinct DWGS-style tables (organ, reed, square-ish,\n//  piano-ish, buzzy/saw, hollow, bell, sync-buzz) built once at init, then\n//  runs it through a warm resonant ANALOG-style 4-pole low-pass with its own\n//  Attack/Release amplitude+filter contour. A built-in stereo delay/chorus\n//  adds the signature shimmer. >=6 voices; pure algorithm, no host imports.\n//\n//  Digital edge (quantised wavetable harmonics) + analog warmth (tanh ladder\n//  filter and saturated summing bus).\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\n// digital-wave bank: 8 single-cycle tables, power-of-two length for cheap wrap\nconst NUM_WAVES: i32 = 8;\nconst TBL_LEN: i32 = 1024;\nconst TBL_MASK: i32 = 1023;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// the wave bank, laid out flat: wave w, sample i -> waveBank[w*TBL_LEN + i]\nconst waveBank: StaticArray<f32> = new StaticArray<f32>(NUM_WAVES * TBL_LEN);\n\n// stereo delay / chorus lines (signature shimmer)\nconst DLY_LEN: i32 = 65536;      // ~1.36 s @ 48k, power of two\nconst DLY_MASK: i32 = 65535;\nconst dlyL: StaticArray<f32> = new StaticArray<f32>(DLY_LEN);\nconst dlyR: StaticArray<f32> = new StaticArray<f32>(DLY_LEN);\nlet dlyPos: i32 = 0;\nlet chorusPhase: f32 = 0.0;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_WAVE:   i32 = 0;  // 0..7  -> stepped digital waveform select\nconst P_CUTOFF: i32 = 1;  // 0..1  -> analog low-pass base cutoff\nconst P_RESO:   i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT: i32 = 3;  // 0..1  -> filter envelope amount\nconst P_ATTACK: i32 = 4;  // 0..1  -> attack seconds\nconst P_RELEASE:i32 = 5;  // 0..1  -> release seconds\nconst P_DELAY:  i32 = 6;  // 0..1  -> onboard delay/chorus mix\nconst P_LEVEL:  i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // 0..1 table phase\n\n// amplitude AR envelope\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 hold/sus 3 rel\n// filter AR envelope\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// analog ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- build the DWGS-style digital wave bank -------------------------\n//  Each table is an additive sum of harmonics with a hand-picked spectral\n//  recipe, so the 8 waves are clearly distinct timbres. Normalised to ~1.\nfunction buildWaves(): void {\n  for (let w = 0; w < NUM_WAVES; w++) {\n    const base: i32 = w * TBL_LEN;\n    let peak: f32 = 0.0001;\n    for (let i = 0; i < TBL_LEN; i++) {\n      const ph: f32 = TWO_PI * f32(i) / f32(TBL_LEN);\n      let s: f32 = 0.0;\n      // up to 32 harmonics; amplitude recipe depends on wave index\n      for (let h = 1; h <= 32; h++) {\n        const hf: f32 = f32(h);\n        let amp: f32 = 0.0;\n        if (w == 0) {\n          // 0 ORGAN: a few strong low harmonics (drawbar-ish)\n          if (h == 1) amp = 1.0;\n          else if (h == 2) amp = 0.5;\n          else if (h == 3) amp = 0.35;\n          else if (h == 4) amp = 0.25;\n          else if (h == 6) amp = 0.18;\n          else if (h == 8) amp = 0.12;\n        } else if (w == 1) {\n          // 1 REED: odd-weighted with a formant bump around 5th\n          if ((h & 1) == 1) amp = 1.0 / hf;\n          if (h == 5) amp += 0.6;\n          if (h == 7) amp += 0.3;\n        } else if (w == 2) {\n          // 2 SQUARE-ish hollow: odd harmonics 1/h\n          if ((h & 1) == 1) amp = 1.0 / hf;\n        } else if (w == 3) {\n          // 3 PIANO-ish: gentle rolloff, slight inharmonic emphasis mid\n          amp = f32(Mathf.exp(-0.18 * (hf - 1.0)));\n          if (h == 3 || h == 4) amp *= 1.3;\n        } else if (w == 4) {\n          // 4 BUZZY SAW: full 1/h spectrum, bright\n          amp = 1.0 / hf;\n        } else if (w == 5) {\n          // 5 HOLLOW (pulse ~25%): harmonics weighted by sin(h*pi*0.25)\n          amp = f32(Mathf.abs(Mathf.sin(hf * PI * 0.25))) / hf;\n        } else if (w == 6) {\n          // 6 BELL/METALLIC: sparse high partials, slightly stretched\n          if (h == 1) amp = 0.7;\n          else if (h == 4) amp = 0.5;\n          else if (h == 7) amp = 0.6;\n          else if (h == 11) amp = 0.45;\n          else if (h == 16) amp = 0.3;\n        } else {\n          // 7 SYNC-BUZZ: rising then falling band — aggressive digital edge\n          amp = f32(Mathf.exp(-0.5 * (f32(h) - 8.0) * (f32(h) - 8.0) * 0.06));\n        }\n        if (amp != 0.0) s += amp * f32(Mathf.sin(ph * hf));\n      }\n      waveBank[base + i] = s;\n      const a: f32 = s < 0.0 ? -s : s;\n      if (a > peak) peak = a;\n    }\n    // normalise this table to +/-0.95\n    const norm: f32 = 0.95 / peak;\n    for (let i = 0; i < TBL_LEN; i++) waveBank[base + i] *= norm;\n  }\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vPhase[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  for (let i = 0; i < DLY_LEN; i++) { dlyL[i] = 0.0; dlyR[i] = 0.0; }\n  dlyPos = 0; chorusPhase = 0.0;\n\n  buildWaves();\n\n  params[P_WAVE]    = 0.0;\n  params[P_CUTOFF]  = 0.55;\n  params[P_RESO]    = 0.30;\n  params[P_ENVAMT]  = 0.55;\n  params[P_ATTACK]  = 0.04;\n  params[P_RELEASE] = 0.35;\n  params[P_DELAY]   = 0.30;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n  vPhase[slot]  = 0.0;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 3;  // release\n      vFStage[i] = 3;\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  // Wave: stepped 0..7 -> integer table index\n  let waveIdx: i32 = i32(clampf(params[P_WAVE], 0.0, f32(NUM_WAVES - 1)) + 0.5);\n  if (waveIdx < 0) waveIdx = 0;\n  if (waveIdx > NUM_WAVES - 1) waveIdx = NUM_WAVES - 1;\n  const waveBase: i32 = waveIdx * TBL_LEN;\n\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n\n  const atkS: f32 = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.8;\n  const relS: f32 = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 2.5;\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // base cutoff in Hz, exponential 60 Hz .. ~16 kHz\n  const baseHz: f32 = 60.0 * f32(Mathf.pow(256.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6 octaves\n  const envOct: f32 = envAmt * 6.0;\n  // resonance feedback 0..~4 (warm, just shy of self-oscillation)\n  const reso: f32 = resoN * 3.8;\n\n  // delay / chorus controls\n  const dlyMix: f32 = clampf(params[P_DELAY], 0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL], 0.0, 1.0) * 1.1;\n\n  // chorus/delay times: short modulated delay -> ensemble shimmer\n  const baseDelaySamp: f32 = 0.013 * sr;   // ~13 ms base\n  const chorusDepth: f32   = 0.004 * sr;   // +/- 4 ms sweep\n  const chorusInc: f32     = TWO_PI * 0.45 / sr; // ~0.45 Hz LFO\n  const feedback: f32      = 0.32;          // gentle repeats\n\n  // headroom: up to 8 voices summed -> scale so big chords stay < 1\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let dry: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR ----------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // sustain (held)\n        aenv = 1.0;\n      } else if (astg == 3) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter AR -------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv = 1.0;\n      } else if (fstg == 3) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- digital wavetable oscillator (linear-interp read) ----\n      let ph: f32 = vPhase[v];\n      const inc: f32 = vFreq[v] / sr;   // cycles per sample (0..1)\n      ph += inc; if (ph >= 1.0) ph -= 1.0;\n      vPhase[v] = ph;\n\n      const fp: f32 = ph * f32(TBL_LEN);\n      const i0: i32 = i32(fp) & TBL_MASK;\n      const i1: i32 = (i0 + 1) & TBL_MASK;\n      const frac: f32 = fp - f32(i32(fp));\n      const a0: f32 = waveBank[waveBase + i0];\n      const a1: f32 = waveBank[waveBase + i1];\n      const osc: f32 = a0 + (a1 - a0) * frac;\n\n      // ---- analog resonant 4-pole low-pass ----------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));     // analog warmth on the feedback path\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      dry += s3 * aenv * vVel[v];\n    }\n\n    // ---- analog summing bus: scale + soft saturate ----------------\n    let mono: f32 = f32(Mathf.tanh(dry * voiceScale * 1.15));\n\n    // ---- stereo delay / chorus (the DW shimmer) -------------------\n    chorusPhase += chorusInc; if (chorusPhase >= TWO_PI) chorusPhase -= TWO_PI;\n    const modL: f32 = f32(Mathf.sin(chorusPhase));\n    const modR: f32 = f32(Mathf.sin(chorusPhase + PI * 0.5)); // 90° apart -> width\n\n    const dL: f32 = baseDelaySamp + chorusDepth * modL;\n    const dR: f32 = baseDelaySamp + chorusDepth * modR + 0.003 * sr; // slight R offset\n\n    const rdL: f32 = readDelay(dlyL, f32(dlyPos) - dL);\n    const rdR: f32 = readDelay(dlyR, f32(dlyPos) - dR);\n\n    // write input + feedback into the lines\n    dlyL[dlyPos] = mono + rdL * feedback;\n    dlyR[dlyPos] = mono + rdR * feedback;\n    dlyPos = (dlyPos + 1) & DLY_MASK;\n\n    const wetL: f32 = rdL;\n    const wetR: f32 = rdR;\n\n    let outL: f32 = (mono * (1.0 - dlyMix * 0.6) + wetL * dlyMix) * level;\n    let outR: f32 = (mono * (1.0 - dlyMix * 0.6) + wetR * dlyMix) * level;\n\n    // final safety limit\n    outL = clampf(outL, -1.0, 1.0);\n    outR = clampf(outR, -1.0, 1.0);\n\n    outBuf[f] = outL;\n    outBuf[MAX_FRAMES + f] = outR;\n  }\n}\n\n// fractional-delay read with linear interpolation; wraps the ring buffer\n@inline function readDelay(line: StaticArray<f32>, fpos: f32): f32 {\n  let p: f32 = fpos;\n  // bring into [0, DLY_LEN)\n  while (p < 0.0) p += f32(DLY_LEN);\n  const ip: i32 = i32(p) & DLY_MASK;\n  const ip1: i32 = (ip + 1) & DLY_MASK;\n  const fr: f32 = p - f32(i32(p));\n  const a: f32 = line[ip];\n  const b: f32 = line[ip1];\n  return a + (b - a) * fr;\n}\n",
  "publishedAt": 1751000135000
}