{
  "format": 1,
  "name": "Hold Echo",
  "isInstrument": false,
  "explanation": "A studio digital delay with modulation and infinite hold. A clean delay line feeds linear-interpolated repeats whose read tap is gently swept by a quadrature LFO for chorus / pitch-wobble echoes; a tilt tone filter darkens or brightens the feedback path, and a Hold control lifts feedback toward unity while fading the input out so the captured buffer loops and freezes without runaway. A soft limiter keeps the loop bounded. Controls: Time, Feedback, Modulation, Tone, Hold and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Modulation",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Hold",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Hold Echo</title>\n<style>\n  :root {\n    --accent: #3de0c4;\n    --accent2: #7a86ff;\n    --bg0: #0a1413;\n    --bg1: #0f1d1c;\n    --panel: #122625;\n    --panel-hi: #18302e;\n    --ink: #cdeee6;\n    --ink-dim: #6f928c;\n    --well: #08100f;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background: var(--bg0);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 18px;\n    min-height: 100vh;\n  }\n\n  .unit {\n    width: 100%;\n    max-width: 640px;\n    border-radius: 16px;\n    background:\n      radial-gradient(120% 80% at 50% -10%, #1a3633 0%, transparent 60%),\n      linear-gradient(180deg, #14302d 0%, var(--bg1) 55%, var(--bg0) 100%);\n    border: 1px solid #1f3e3a;\n    box-shadow:\n      0 24px 60px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(120,220,200,0.12),\n      inset 0 -2px 8px rgba(0,0,0,0.5);\n    padding: 18px 20px 22px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* faint brushed-metal sheen sweeping across the top */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    inset: 0 0 auto 0;\n    height: 70px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.05), transparent);\n    pointer-events: none;\n  }\n\n  /* rack screws */\n  .screw {\n    position: absolute;\n    width: 11px; height: 11px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #2c4b47, #0c1817 70%);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,0.15), 0 1px 2px rgba(0,0,0,0.6);\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute; inset: 3px;\n    border-top: 1px solid rgba(0,0,0,0.55);\n    transform: rotate(35deg);\n  }\n  .screw.tl { top: 10px; left: 10px; }\n  .screw.tr { top: 10px; right: 10px; }\n  .screw.bl { bottom: 10px; left: 10px; }\n  .screw.br { bottom: 10px; right: 10px; }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 2px 14px 14px;\n  }\n\n  .brand { display: flex; align-items: baseline; gap: 10px; }\n  .brand .mark {\n    font-size: 11px;\n    letter-spacing: 3px;\n    color: var(--ink-dim);\n    text-transform: uppercase;\n  }\n  .brand h1 {\n    font-size: 21px;\n    letter-spacing: 4px;\n    font-weight: 700;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, #eafff9, var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 18px rgba(61,224,196,0.25);\n  }\n  .sub {\n    font-size: 9.5px;\n    letter-spacing: 2px;\n    color: var(--ink-dim);\n    text-transform: uppercase;\n  }\n\n  /* ---- the glowing time / status display ---- */\n  .display {\n    position: relative;\n    border-radius: 10px;\n    background:\n      linear-gradient(180deg, #06100f, #040a09);\n    border: 1px solid #1c3b37;\n    box-shadow: inset 0 2px 12px rgba(0,0,0,0.8), 0 0 0 1px rgba(0,0,0,0.4);\n    padding: 14px 16px 10px;\n    margin: 0 0 18px;\n    overflow: hidden;\n  }\n  /* scanline texture on the display */\n  .display::after {\n    content: \"\";\n    position: absolute; inset: 0;\n    background: repeating-linear-gradient(0deg, rgba(0,0,0,0.0) 0 2px, rgba(0,0,0,0.18) 2px 3px);\n    pointer-events: none;\n    mix-blend-mode: multiply;\n  }\n\n  .readout {\n    display: flex;\n    align-items: baseline;\n    justify-content: space-between;\n    margin-bottom: 8px;\n    position: relative;\n    z-index: 2;\n  }\n  .readout .time {\n    font-variant-numeric: tabular-nums;\n    font-feature-settings: \"tnum\";\n    font-size: 32px;\n    font-weight: 700;\n    letter-spacing: 1px;\n    color: var(--accent);\n    text-shadow: 0 0 14px rgba(61,224,196,0.55);\n  }\n  .readout .time .u { font-size: 14px; color: var(--ink-dim); margin-left: 4px; text-shadow: none; }\n  .readout .lbl { font-size: 10px; letter-spacing: 2px; color: var(--ink-dim); text-transform: uppercase; }\n\n  .hold-led {\n    display: inline-flex; align-items: center; gap: 7px;\n    font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--ink-dim);\n  }\n  .hold-led .dot {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: #213c39;\n    box-shadow: inset 0 0 3px rgba(0,0,0,0.7);\n    transition: background 0.18s, box-shadow 0.18s;\n  }\n  .hold-led.on .dot {\n    background: var(--accent2);\n    box-shadow: 0 0 10px var(--accent2), 0 0 4px #fff;\n    animation: pulse 1.1s ease-in-out infinite;\n  }\n  .hold-led.on { color: var(--accent2); }\n  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.45; } }\n\n  .scope {\n    position: relative;\n    z-index: 2;\n    width: 100%;\n    height: 92px;\n    display: block;\n    border-radius: 6px;\n  }\n\n  /* ---- controls ---- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px 10px;\n    padding: 0 4px;\n  }\n  @media (max-width: 460px) { .rack { grid-template-columns: repeat(2, 1fr); } }\n\n  .cell {\n    background: linear-gradient(180deg, var(--panel-hi), var(--panel));\n    border: 1px solid #1d3a36;\n    border-radius: 12px;\n    padding: 12px 8px 10px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    box-shadow: inset 0 1px 0 rgba(120,220,200,0.08), 0 6px 14px rgba(0,0,0,0.35);\n  }\n  .cell .name {\n    font-size: 10px; letter-spacing: 2px; text-transform: uppercase;\n    color: var(--ink-dim); margin-bottom: 9px;\n  }\n  .knob {\n    position: relative;\n    width: 78px; height: 78px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; overflow: visible; }\n  .knob .val {\n    margin-top: 7px;\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    font-feature-settings: \"tnum\";\n    color: var(--ink);\n    letter-spacing: 0.5px;\n  }\n  .cell.hold-cell { box-shadow: inset 0 1px 0 rgba(122,134,255,0.12), 0 6px 14px rgba(0,0,0,0.35); }\n  .footnote {\n    margin-top: 14px;\n    text-align: center;\n    font-size: 9px;\n    letter-spacing: 2px;\n    color: var(--ink-dim);\n    text-transform: uppercase;\n  }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <header>\n      <div class=\"brand\">\n        <span class=\"mark\">VIBE</span>\n        <h1>Hold Echo</h1>\n      </div>\n      <div class=\"sub\">Digital Delay · Modulation · Hold</div>\n    </header>\n\n    <div class=\"display\">\n      <div class=\"readout\">\n        <div>\n          <div class=\"lbl\">Delay Time</div>\n          <div class=\"time\"><span id=\"timeVal\">315</span><span class=\"u\">ms</span></div>\n        </div>\n        <div class=\"hold-led\" id=\"holdLed\"><span class=\"dot\"></span><span>Hold</span></div>\n      </div>\n      <canvas class=\"scope\" id=\"scope\"></canvas>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n    <div class=\"footnote\">Drag knobs vertically · double-click to reset</div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (must match assembly.ts indices) ----\n  var PARAMS = [\n    { name: \"Time\",       index: 0, min: 0, max: 1, def: 0.35 },\n    { name: \"Feedback\",   index: 1, min: 0, max: 1, def: 0.45 },\n    { name: \"Modulation\", index: 2, min: 0, max: 1, def: 0.30 },\n    { name: \"Tone\",       index: 3, min: 0, max: 1, def: 0.50 },\n    { name: \"Hold\",       index: 4, min: 0, max: 1, def: 0.00, hold: true },\n    { name: \"Mix\",        index: 5, min: 0, max: 1, def: 0.50 }\n  ];\n\n  var state = {}; // index -> normalized value\n  PARAMS.forEach(function (p) { state[p.index] = p.def; });\n\n  function pushParam(index, norm) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(index, norm);\n    }\n  }\n\n  // ---- formatting helpers ----\n  function fmtTime(norm) { return Math.round(30 + norm * 870); }      // ms\n  function fmtPct(norm) { return Math.round(norm * 100) + \"%\"; }\n\n  function knobValueText(p, norm) {\n    if (p.name === \"Time\") return fmtTime(norm) + \" ms\";\n    return fmtPct(norm);\n  }\n\n  // ---- build knobs ----\n  var rack = document.getElementById(\"rack\");\n  var knobs = {}; // index -> { setArc, valEl }\n\n  PARAMS.forEach(function (p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\" + (p.hold ? \" hold-cell\" : \"\");\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\";\n    name.textContent = p.name;\n    cell.appendChild(name);\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.setAttribute(\"role\", \"slider\");\n    knob.setAttribute(\"tabindex\", \"0\");\n    knob.setAttribute(\"aria-label\", p.name);\n\n    var stroke = p.hold ? \"var(--accent2)\" : \"var(--accent)\";\n    var R = 32, CX = 39, CY = 39;\n    // arc spans 270deg from 135deg to 405deg\n    var START = 135, SWEEP = 270;\n    var circ = 2 * Math.PI * R;\n\n    knob.innerHTML =\n      '<svg viewBox=\"0 0 78 78\">' +\n        '<defs>' +\n          '<radialGradient id=\"body' + p.index + '\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n            '<stop offset=\"0%\" stop-color=\"#20413d\"/>' +\n            '<stop offset=\"60%\" stop-color=\"#152e2b\"/>' +\n            '<stop offset=\"100%\" stop-color=\"#0c1c1a\"/>' +\n          '</radialGradient>' +\n          '<filter id=\"gl' + p.index + '\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\">' +\n            '<feGaussianBlur stdDeviation=\"2.4\" result=\"b\"/>' +\n            '<feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>' +\n          '</filter>' +\n        '</defs>' +\n        // track\n        '<circle cx=\"' + CX + '\" cy=\"' + CY + '\" r=\"' + R + '\" fill=\"none\" ' +\n          'stroke=\"#0a1817\" stroke-width=\"6\" stroke-linecap=\"round\" ' +\n          'transform=\"rotate(' + START + ' ' + CX + ' ' + CY + ')\" ' +\n          'stroke-dasharray=\"' + (circ * SWEEP / 360) + ' ' + circ + '\"/>' +\n        // value arc\n        '<circle class=\"arc\" cx=\"' + CX + '\" cy=\"' + CY + '\" r=\"' + R + '\" fill=\"none\" ' +\n          'stroke=\"' + stroke + '\" stroke-width=\"6\" stroke-linecap=\"round\" ' +\n          'transform=\"rotate(' + START + ' ' + CX + ' ' + CY + ')\" ' +\n          'filter=\"url(#gl' + p.index + ')\" ' +\n          'stroke-dasharray=\"0 ' + circ + '\"/>' +\n        // knob body\n        '<circle cx=\"' + CX + '\" cy=\"' + CY + '\" r=\"23\" fill=\"url(#body' + p.index + ')\" ' +\n          'stroke=\"#2a4d48\" stroke-width=\"1\"/>' +\n        '<circle cx=\"' + CX + '\" cy=\"' + CY + '\" r=\"23\" fill=\"none\" ' +\n          'stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"/>' +\n        // pointer\n        '<line class=\"ptr\" x1=\"' + CX + '\" y1=\"' + CY + '\" x2=\"' + CX + '\" y2=\"' + (CY - 18) + '\" ' +\n          'stroke=\"' + stroke + '\" stroke-width=\"3\" stroke-linecap=\"round\" ' +\n          'filter=\"url(#gl' + p.index + ')\"/>' +\n      '</svg>';\n\n    var valEl = document.createElement(\"div\");\n    valEl.className = \"val\";\n    cell.appendChild(knob);\n    cell.appendChild(valEl);\n    rack.appendChild(cell);\n\n    var arc = knob.querySelector(\".arc\");\n    var ptr = knob.querySelector(\".ptr\");\n\n    function render(norm) {\n      var len = circ * SWEEP / 360 * norm;\n      arc.setAttribute(\"stroke-dasharray\", len + \" \" + circ);\n      var ang = START + SWEEP * norm; // degrees\n      ptr.setAttribute(\"transform\", \"rotate(\" + ang + \" \" + CX + \" \" + CY + \")\");\n      valEl.textContent = knobValueText(p, norm);\n    }\n\n    knobs[p.index] = { render: render, knob: knob };\n\n    // ---- interaction ----\n    function setNorm(norm, push) {\n      norm = Math.max(0, Math.min(1, norm));\n      state[p.index] = norm;\n      render(norm);\n      if (push !== false) pushParam(p.index, norm);\n      if (p.name === \"Time\") document.getElementById(\"timeVal\").textContent = fmtTime(norm);\n      if (p.hold) updateHoldLed(norm);\n    }\n\n    var dragging = false, lastY = 0;\n\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      knob.style.cursor = \"ns-resize\";\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var speed = (e.shiftKey ? 0.0008 : 0.004);\n      setNorm(state[p.index] + dy * speed, true);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    knob.addEventListener(\"touchmove\", onMove, { passive: false });\n    knob.addEventListener(\"touchend\", onUp);\n\n    knob.addEventListener(\"wheel\", function (e) {\n      setNorm(state[p.index] - e.deltaY * 0.0006, true);\n      e.preventDefault();\n    }, { passive: false });\n\n    knob.addEventListener(\"dblclick\", function () { setNorm(p.def, true); });\n\n    knob.addEventListener(\"keydown\", function (e) {\n      if (e.key === \"ArrowUp\" || e.key === \"ArrowRight\") { setNorm(state[p.index] + 0.02, true); e.preventDefault(); }\n      else if (e.key === \"ArrowDown\" || e.key === \"ArrowLeft\") { setNorm(state[p.index] - 0.02, true); e.preventDefault(); }\n    });\n\n    p._setNorm = setNorm;\n  });\n\n  // ---- hold LED ----\n  var holdLed = document.getElementById(\"holdLed\");\n  function updateHoldLed(norm) {\n    if (norm > 0.55) holdLed.classList.add(\"on\");\n    else holdLed.classList.remove(\"on\");\n  }\n\n  // =========================================================\n  //  Scope — a looping delay-repeats waveform that ripples\n  //  with modulation and FREEZES when HOLD engages.\n  // =========================================================\n  var canvas = document.getElementById(\"scope\");\n  var ctx = canvas.getContext(\"2d\");\n  var dpr = Math.max(1, Math.min(2, window.devicePixelRatio || 1));\n\n  function resize() {\n    var r = canvas.getBoundingClientRect();\n    canvas.width = Math.max(2, Math.floor(r.width * dpr));\n    canvas.height = Math.max(2, Math.floor(r.height * dpr));\n  }\n  resize();\n  window.addEventListener(\"resize\", resize);\n\n  // a short captured \"buffer\" of impulse positions; we draw decaying echoes\n  var t = 0;\n  var rafId = null;\n\n  function draw() {\n    rafId = requestAnimationFrame(draw);\n    if (document.hidden) return;\n\n    var W = canvas.width, H = canvas.height;\n    ctx.clearRect(0, 0, W, H);\n\n    var fb = state[1];        // feedback -> echo count / decay\n    var mod = state[2];       // modulation -> ripple amplitude\n    var tone = state[3];      // tone -> brightness / line color\n    var hold = state[4];      // hold -> freeze\n    var mix = state[5];       // mix -> overall amplitude\n    var timeN = state[0];\n\n    var frozen = hold > 0.55;\n    if (!frozen) t += 0.016 * (0.4 + timeN * 1.4);\n\n    var mid = H * 0.5;\n    var baseAmp = H * 0.32 * (0.35 + mix * 0.65);\n\n    // grid baseline\n    ctx.strokeStyle = \"rgba(61,224,196,0.10)\";\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    ctx.moveTo(0, mid);\n    ctx.lineTo(W, mid);\n    ctx.stroke();\n\n    // number of visible repeats grows with feedback\n    var taps = frozen ? 7 : Math.max(2, Math.round(2 + fb * 6));\n    var spacing = W / (taps + 0.5);\n\n    // color blends accent -> accent2 with tone\n    function lerpColor(a, b, x) {\n      return [\n        Math.round(a[0] + (b[0] - a[0]) * x),\n        Math.round(a[1] + (b[1] - a[1]) * x),\n        Math.round(a[2] + (b[2] - a[2]) * x)\n      ];\n    }\n    var teal = [61, 224, 196], indigo = [122, 134, 255];\n\n    for (var k = 0; k < taps; k++) {\n      var decay = frozen ? 1.0 : Math.pow(fb * 0.92 + 0.05, k);\n      var amp = baseAmp * decay;\n      if (amp < 0.5) continue;\n\n      var cx = spacing * (k + 0.6);\n      // pulse phase: when frozen the whole pattern holds still\n      var phase = frozen ? 0.0 : (t - k * 0.5);\n\n      // each repeat is a damped sine burst; modulation wobbles its frequency\n      var wob = mod * Math.sin((t * 0.9) + k * 0.7) * 0.6;\n      var freq = 0.14 + 0.05 * k + wob * 0.05;\n\n      var c = lerpColor(teal, indigo, Math.min(1, hold * 0.8 + tone * 0.2));\n      var alpha = frozen ? 0.95 : (0.85 * decay + 0.1);\n\n      ctx.beginPath();\n      var span = spacing * 0.9;\n      for (var i = -span; i <= span; i += 2 * dpr) {\n        var env = Math.exp(-Math.abs(i) / (span * 0.42));\n        // modulation ripple: a slow vertical shimmer along the burst\n        var ripple = 1 + mod * 0.5 * Math.sin(i * 0.05 + phase * 2.0);\n        var y = mid - Math.sin((i / dpr) * freq + phase) * amp * env * ripple;\n        if (i === -span) ctx.moveTo(cx + i, y);\n        else ctx.lineTo(cx + i, y);\n      }\n      ctx.strokeStyle = \"rgba(\" + c[0] + \",\" + c[1] + \",\" + c[2] + \",\" + alpha + \")\";\n      ctx.lineWidth = (frozen ? 2.4 : 2.0) * dpr;\n      ctx.shadowColor = \"rgba(\" + c[0] + \",\" + c[1] + \",\" + c[2] + \",\" + (0.5 * alpha) + \")\";\n      ctx.shadowBlur = (frozen ? 12 : 7) * dpr;\n      ctx.stroke();\n      ctx.shadowBlur = 0;\n    }\n\n    // frozen overlay: a steady scan bar to signal the loop is held\n    if (frozen) {\n      var bx = ((Math.sin(t * 0.6) * 0.5 + 0.5)) * W;\n      var grad = ctx.createLinearGradient(bx - 30 * dpr, 0, bx + 30 * dpr, 0);\n      grad.addColorStop(0, \"rgba(122,134,255,0)\");\n      grad.addColorStop(0.5, \"rgba(122,134,255,0.18)\");\n      grad.addColorStop(1, \"rgba(122,134,255,0)\");\n      ctx.fillStyle = grad;\n      ctx.fillRect(0, 0, W, H);\n    }\n  }\n\n  // ---- init & host wiring ----\n  function initAll() {\n    PARAMS.forEach(function (p) {\n      knobs[p.index].render(state[p.index]);\n      p._setNorm(state[p.index], true); // push default to engine\n    });\n    document.getElementById(\"timeVal\").textContent = fmtTime(state[0]);\n    updateHoldLed(state[4]);\n    draw();\n  }\n\n  function boot() {\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(initAll);\n    } else {\n      initAll();\n    }\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  HOLD ECHO — studio digital delay with modulation and infinite hold\n//  (PCM42 lineage). A clean digital delay line whose read tap is gently\n//  wobbled by an LFO (chorus / pitch-warble repeats), the feedback path\n//  is band-shaped by a tilt tone filter (darken or brighten the repeats),\n//  and a HOLD control pushes feedback toward ~1.0 so the buffer loops /\n//  freezes without runaway. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: up to ~1.2 s per channel at 48k gives plenty of headroom and\n// a generous hold-loop length. Sized fixed so process() never allocates.\nconst DELAY_LEN: i32 = 65536; // ~1.36 s @ 48k per channel\nconst dline: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel state\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst lpState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone low-pass in fb path\nconst hpState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone high-pass (tilt)\nconst dcState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // dc blocker\n\n// smoothed delay time (in samples) so Time moves without zipper / clicks\nlet smoothDelay: f32 = 12000.0;\n\n// LFO phase for the modulation wobble (quadrature per channel for stereo width)\nlet lfoPhase: f32 = 0.0;\n\nconst P_TIME: i32 = 0;  // 0..1 -> delay 30..900 ms\nconst P_FB:   i32 = 1;  // 0..1 -> feedback 0..0.95\nconst P_MOD:  i32 = 2;  // 0..1 -> delay-time wobble depth\nconst P_TONE: i32 = 3;  // 0..1 -> tilt filter on repeats (0 dark, 1 bright)\nconst P_HOLD: i32 = 4;  // 0..1 -> push feedback toward ~1.0, mute input into line\nconst P_MIX:  i32 = 5;  // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DELAY_LEN * MAX_CHANNELS; i++) dline[i] = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0; lpState[c] = 0.0; hpState[c] = 0.0; dcState[c] = 0.0;\n  }\n  smoothDelay = 12000.0;\n  lfoPhase = 0.0;\n  params[P_TIME] = 0.35;\n  params[P_FB]   = 0.45;\n  params[P_MOD]  = 0.30;\n  params[P_TONE] = 0.5;\n  params[P_HOLD] = 0.0;\n  params[P_MIX]  = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// soft saturator keeps the hold loop / high-feedback bounded (no runaway clip)\n@inline function softLimit(x: f32): f32 {\n  const c: f32 = clampf(x, -2.0, 2.0);\n  return f32(c - 0.1481481 * c * c * c); // ~tanh-ish, unity slope at 0, bounded\n}\n\n// linear-interpolated read from a channel's delay line at fractional sample\n// distance `delaySamp` behind the write head\n@inline function readDelay(base: i32, wp: i32, delaySamp: f32): f32 {\n  let d: f32 = delaySamp;\n  if (d < 1.0) d = 1.0;\n  if (d > f32(DELAY_LEN - 2)) d = f32(DELAY_LEN - 2);\n  const id: i32 = i32(d);\n  const frac: f32 = d - f32(id);\n  let i0: i32 = wp - id;\n  while (i0 < 0) i0 += DELAY_LEN;\n  let i1: i32 = i0 - 1;\n  while (i1 < 0) i1 += DELAY_LEN;\n  const a: f32 = dline[base + i0];\n  const b: f32 = dline[base + i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN:   f32 = clampf(params[P_FB],   0.0, 1.0);\n  const modN:  f32 = clampf(params[P_MOD],  0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const holdN: f32 = clampf(params[P_HOLD], 0.0, 1.0);\n  const mix:   f32 = clampf(params[P_MIX],  0.0, 1.0);\n\n  // target delay in samples: 30..900 ms\n  const ms: f32 = 30.0 + timeN * 870.0;\n  const targetDelay: f32 = clampf(ms * 0.001 * sampleRate, 2.0, f32(DELAY_LEN - 600));\n\n  // base feedback 0..0.95; HOLD lifts it toward ~1.0 and fades the input feed\n  // into the line so the captured buffer loops/freezes (bounded by softLimit)\n  const baseFb: f32 = fbN * 0.95;\n  const fb: f32 = baseFb + holdN * (0.9995 - baseFb);\n  const inGain: f32 = 1.0 - holdN; // at full hold, no new audio enters the loop\n\n  // tone = tilt: low tone darkens (low-pass), high tone brightens (high-pass mix)\n  // low-pass corner 700..9000 Hz, plus a fixed gentle high-pass to avoid build-up\n  const lpHz: f32 = 700.0 + toneN * toneN * 8300.0;\n  const cLp: f32 = f32(1.0 - Mathf.exp(-PI2 * lpHz / sampleRate));\n  const cHp: f32 = f32(1.0 - Mathf.exp(-PI2 * 35.0 / sampleRate)); // dc/rumble blocker\n\n  // modulation: LFO ~0.35 Hz, depth up to ~12 ms of delay-time wobble\n  const lfoHz: f32 = 0.15 + modN * 1.2;\n  const lfoInc: f32 = PI2 * lfoHz / sampleRate;\n  const modDepth: f32 = modN * 0.012 * sampleRate; // samples of swing\n\n  // delay-time smoothing coefficient (~30 ms glide)\n  const smoothC: f32 = f32(1.0 - Mathf.exp(-PI2 * 6.0 / sampleRate));\n\n  let lph: f32 = lfoPhase;\n\n  for (let f = 0; f < n; f++) {\n    // advance smoothed delay and LFO once per frame (shared across channels)\n    smoothDelay += smoothC * (targetDelay - smoothDelay);\n    lph += lfoInc; if (lph >= PI2) lph -= PI2;\n    const modL: f32 = Mathf.sin(lph) * modDepth;\n    const modR: f32 = Mathf.sin(lph + 1.5707963) * modDepth; // quadrature for width\n\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * DELAY_LEN;\n      const wp: i32 = writePos[c];\n\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // modulated read distance (wobbles the pitch of the repeats)\n      const md: f32 = c == 0 ? modL : modR;\n      let dd: f32 = smoothDelay + md;\n      if (dd < 2.0) dd = 2.0;\n      const wet: f32 = readDelay(base, wp, dd);\n\n      // tone-shape the feedback signal: low-pass then dc/rumble high-pass\n      let lp: f32 = lpState[c];\n      lp = lp + cLp * (wet - lp);\n      lpState[c] = lp;\n      let dc: f32 = dcState[c];\n      dc = dc + cHp * (lp - dc);\n      dcState[c] = dc;\n      const shaped: f32 = lp - dc; // band-limited repeat\n\n      // write input + bounded feedback back into the line\n      const toLine: f32 = softLimit(x * inGain + shaped * fb);\n      dline[base + wp] = toLine;\n\n      // advance write head\n      let nwp: i32 = wp + 1; if (nwp >= DELAY_LEN) nwp = 0;\n      writePos[c] = nwp;\n\n      // mix: equal-ish, wet uses the shaped repeat\n      const o: f32 = x * (1.0 - mix) + shaped * mix;\n      outBuf[c * MAX_FRAMES + f] = clampf(o, -1.5, 1.5);\n    }\n  }\n\n  lfoPhase = lph;\n}\n",
  "publishedAt": 1751000121000
}