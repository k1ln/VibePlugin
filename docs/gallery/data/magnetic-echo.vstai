{
  "format": 1,
  "name": "Magnetic Echo",
  "isInstrument": false,
  "explanation": "An original multi-head magnetic-drum echo. A single circulating loop is read by four fixed playback heads, and a Head Mode selects which head combination sounds for distinct rhythmic multi-tap patterns. Recirculating Swell feedback stacks warm, bandwidth-limited repeats with subtle mechanical flutter. Controls: Time, Swell, Heads, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Swell",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Heads",
      "index": 2,
      "min": 0,
      "max": 3,
      "default": 1
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.45
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Magnetic Echo</title>\n  <style>\n    :root {\n      --accent: #e0a85a;\n      --accent2: #ffd089;\n      --bg0: #1a140d;\n      --bg1: #241a10;\n      --panel: #2c2014;\n      --panel-hi: #3a2a18;\n      --brass: #c9933f;\n      --ink: #f3e4cb;\n      --ink-dim: #b59a6f;\n      --line: #4a3621;\n      --shadow: rgba(0,0,0,0.55);\n    }\n\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n\n    html, body {\n      background:\n        radial-gradient(120% 90% at 50% -10%, #3a2a18 0%, var(--bg1) 45%, var(--bg0) 100%);\n      color: var(--ink);\n      font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n      min-height: 100%;\n      -webkit-font-smoothing: antialiased;\n    }\n\n    body {\n      display: flex;\n      justify-content: center;\n      padding: 18px 12px 28px;\n    }\n\n    .unit {\n      width: 100%;\n      max-width: 640px;\n      background:\n        linear-gradient(180deg, var(--panel-hi) 0%, var(--panel) 14%, var(--bg1) 100%);\n      border: 1px solid var(--line);\n      border-radius: 16px;\n      box-shadow:\n        0 1px 0 rgba(255,220,170,0.10) inset,\n        0 24px 60px -20px var(--shadow),\n        0 2px 0 rgba(0,0,0,0.4);\n      padding: 20px 22px 24px;\n      position: relative;\n      overflow: hidden;\n    }\n\n    /* faint brushed-metal texture */\n    .unit::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background:\n        repeating-linear-gradient(90deg,\n          rgba(255,255,255,0.012) 0 2px,\n          rgba(0,0,0,0.012) 2px 4px);\n      pointer-events: none;\n      mix-blend-mode: overlay;\n    }\n\n    /* ---- header ---- */\n    .head {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      margin-bottom: 16px;\n      position: relative;\n      z-index: 2;\n    }\n    .brand { display: flex; flex-direction: column; gap: 3px; }\n    .brand .name {\n      font-size: 20px;\n      font-weight: 700;\n      letter-spacing: 0.18em;\n      text-transform: uppercase;\n      background: linear-gradient(180deg, var(--accent2), var(--accent));\n      -webkit-background-clip: text;\n      background-clip: text;\n      color: transparent;\n      text-shadow: 0 1px 0 rgba(0,0,0,0.3);\n    }\n    .brand .sub {\n      font-size: 9.5px;\n      letter-spacing: 0.34em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n    }\n    .badge {\n      font-size: 9px;\n      letter-spacing: 0.2em;\n      text-transform: uppercase;\n      color: var(--bg0);\n      background: linear-gradient(180deg, var(--accent2), var(--brass));\n      padding: 5px 10px;\n      border-radius: 999px;\n      border: 1px solid rgba(0,0,0,0.3);\n      box-shadow: 0 1px 0 rgba(255,255,255,0.3) inset;\n      font-weight: 700;\n    }\n\n    /* ---- drum stage ---- */\n    .stage {\n      display: flex;\n      justify-content: center;\n      padding: 6px 0 14px;\n      position: relative;\n      z-index: 2;\n    }\n    .drum-wrap {\n      position: relative;\n      width: 230px;\n      height: 230px;\n      filter: drop-shadow(0 12px 18px rgba(0,0,0,0.5));\n    }\n    svg { display: block; width: 100%; height: 100%; }\n\n    .spin { transform-origin: 115px 115px; animation: spin 5.2s linear infinite; }\n    @keyframes spin { to { transform: rotate(360deg); } }\n\n    /* the rotating tape sheen pulse */\n    .sheen { animation: sheenpulse 5.2s linear infinite; }\n    @keyframes sheenpulse {\n      0%, 100% { opacity: 0.18; }\n      50% { opacity: 0.42; }\n    }\n\n    .head-dot { transition: filter 0.25s, opacity 0.25s; }\n    .head-on  { filter: drop-shadow(0 0 6px var(--accent2)); }\n\n    .pulse-ring {\n      transform-origin: 115px 115px;\n      animation: echoPulse 2.6s ease-out infinite;\n      opacity: 0;\n    }\n    @keyframes echoPulse {\n      0% { transform: scale(0.34); opacity: 0.5; }\n      80% { opacity: 0; }\n      100% { transform: scale(1.0); opacity: 0; }\n    }\n\n    /* ---- controls ---- */\n    .controls {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 14px 10px;\n      position: relative;\n      z-index: 2;\n    }\n    @media (max-width: 520px) {\n      .controls { grid-template-columns: repeat(2, 1fr); }\n    }\n\n    .knob-cell {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 7px;\n      padding: 10px 6px 12px;\n      border-radius: 12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.18));\n      border: 1px solid var(--line);\n      box-shadow: 0 1px 0 rgba(255,220,170,0.06) inset;\n    }\n    .knob {\n      width: 78px;\n      height: 78px;\n      cursor: ns-resize;\n      touch-action: none;\n      user-select: none;\n    }\n    .label {\n      font-size: 10px;\n      letter-spacing: 0.22em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n      font-weight: 600;\n    }\n    .value {\n      font-size: 12px;\n      color: var(--accent2);\n      font-variant-numeric: tabular-nums;\n      letter-spacing: 0.04em;\n      min-height: 14px;\n    }\n\n    /* heads selector */\n    .heads-cell {\n      grid-column: span 4;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 12px;\n      padding: 12px 14px;\n      border-radius: 12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.2));\n      border: 1px solid var(--line);\n    }\n    @media (max-width: 520px) {\n      .heads-cell { grid-column: span 2; }\n    }\n    .heads-left { display: flex; flex-direction: column; gap: 3px; }\n    .heads-left .vlab { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--ink-dim); font-weight: 600; }\n    .heads-left .vname { font-size: 13px; color: var(--accent2); font-weight: 600; letter-spacing: 0.05em; }\n    .heads-btns { display: flex; gap: 8px; }\n    .hbtn {\n      min-width: 54px;\n      padding: 9px 8px 8px;\n      border-radius: 9px;\n      border: 1px solid var(--line);\n      background: linear-gradient(180deg, var(--panel-hi), var(--panel));\n      color: var(--ink-dim);\n      font-size: 10px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      font-weight: 700;\n      cursor: pointer;\n      transition: all 0.18s ease;\n      box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 2px 4px rgba(0,0,0,0.3);\n      text-align: center;\n      line-height: 1.5;\n    }\n    .hbtn small { display: block; font-size: 8px; letter-spacing: 0.05em; opacity: 0.7; font-weight: 500; }\n    .hbtn:hover { color: var(--ink); border-color: var(--brass); }\n    .hbtn.active {\n      color: var(--bg0);\n      background: linear-gradient(180deg, var(--accent2), var(--accent));\n      border-color: var(--accent2);\n      box-shadow: 0 0 12px -1px var(--accent), 0 1px 0 rgba(255,255,255,0.4) inset;\n    }\n\n    .foot {\n      margin-top: 14px;\n      text-align: center;\n      font-size: 9px;\n      letter-spacing: 0.28em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n      opacity: 0.7;\n      position: relative;\n      z-index: 2;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"name\">Magnetic Echo</div>\n        <div class=\"sub\">Multi-Head Drum Delay</div>\n      </div>\n      <div class=\"badge\">Vintage</div>\n    </div>\n\n    <div class=\"stage\">\n      <div class=\"drum-wrap\">\n        <svg viewBox=\"0 0 230 230\" aria-hidden=\"true\">\n          <defs>\n            <radialGradient id=\"drumBody\" cx=\"42%\" cy=\"36%\" r=\"75%\">\n              <stop offset=\"0%\" stop-color=\"#6b5230\"/>\n              <stop offset=\"45%\" stop-color=\"#4a3720\"/>\n              <stop offset=\"100%\" stop-color=\"#1c140b\"/>\n            </radialGradient>\n            <radialGradient id=\"hub\" cx=\"40%\" cy=\"38%\" r=\"70%\">\n              <stop offset=\"0%\" stop-color=\"#ffe6b8\"/>\n              <stop offset=\"40%\" stop-color=\"#c9933f\"/>\n              <stop offset=\"100%\" stop-color=\"#6b4d22\"/>\n            </radialGradient>\n            <linearGradient id=\"ring\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0%\" stop-color=\"#7a5e34\"/>\n              <stop offset=\"50%\" stop-color=\"#3a2c19\"/>\n              <stop offset=\"100%\" stop-color=\"#5a4426\"/>\n            </linearGradient>\n            <radialGradient id=\"sheenGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n              <stop offset=\"60%\" stop-color=\"rgba(255,224,170,0)\"/>\n              <stop offset=\"100%\" stop-color=\"rgba(255,224,170,0.5)\"/>\n            </radialGradient>\n          </defs>\n\n          <!-- outer casing ring -->\n          <circle cx=\"115\" cy=\"115\" r=\"112\" fill=\"url(#ring)\" stroke=\"#1a120a\" stroke-width=\"2\"/>\n          <circle cx=\"115\" cy=\"115\" r=\"104\" fill=\"#160f08\"/>\n\n          <!-- echo pulse rings rippling out from the drum -->\n          <circle class=\"pulse-ring\" cx=\"115\" cy=\"115\" r=\"92\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"2\"/>\n          <circle class=\"pulse-ring\" cx=\"115\" cy=\"115\" r=\"92\" fill=\"none\" stroke=\"var(--accent2)\" stroke-width=\"1.5\" style=\"animation-delay:1.3s\"/>\n\n          <!-- the spinning magnetic drum -->\n          <g class=\"spin\">\n            <circle cx=\"115\" cy=\"115\" r=\"92\" fill=\"url(#drumBody)\" stroke=\"#2a1d10\" stroke-width=\"2\"/>\n            <!-- magnetic tape grooves -->\n            <circle cx=\"115\" cy=\"115\" r=\"80\" fill=\"none\" stroke=\"rgba(0,0,0,0.35)\" stroke-width=\"1\"/>\n            <circle cx=\"115\" cy=\"115\" r=\"68\" fill=\"none\" stroke=\"rgba(0,0,0,0.3)\" stroke-width=\"1\"/>\n            <circle cx=\"115\" cy=\"115\" r=\"56\" fill=\"none\" stroke=\"rgba(0,0,0,0.28)\" stroke-width=\"1\"/>\n            <circle cx=\"115\" cy=\"115\" r=\"44\" fill=\"none\" stroke=\"rgba(0,0,0,0.25)\" stroke-width=\"1\"/>\n            <!-- rotation index marks so the spin reads clearly -->\n            <rect x=\"113.5\" y=\"26\" width=\"3\" height=\"22\" rx=\"1.5\" fill=\"var(--accent2)\" opacity=\"0.85\"/>\n            <rect x=\"113.5\" y=\"182\" width=\"3\" height=\"22\" rx=\"1.5\" fill=\"rgba(255,224,170,0.25)\"/>\n            <!-- moving sheen highlight -->\n            <circle class=\"sheen\" cx=\"115\" cy=\"115\" r=\"92\" fill=\"url(#sheenGrad)\"/>\n            <!-- brass hub -->\n            <circle cx=\"115\" cy=\"115\" r=\"26\" fill=\"url(#hub)\" stroke=\"#3a2912\" stroke-width=\"2\"/>\n            <circle cx=\"115\" cy=\"115\" r=\"7\" fill=\"#2a1d0e\"/>\n            <circle cx=\"108\" cy=\"108\" r=\"3\" fill=\"rgba(255,255,255,0.5)\"/>\n          </g>\n\n          <!-- four fixed playback heads around the drum (static, not spinning) -->\n          <!-- top (head 4) -->\n          <g id=\"hd4\" class=\"head-dot\">\n            <rect x=\"108\" y=\"6\" width=\"14\" height=\"20\" rx=\"3\" fill=\"#2a1d10\" stroke=\"#5a4426\" stroke-width=\"1\"/>\n            <circle cx=\"115\" cy=\"24\" r=\"4.5\" fill=\"var(--accent)\"/>\n          </g>\n          <!-- right (head 1) -->\n          <g id=\"hd1\" class=\"head-dot\">\n            <rect x=\"204\" y=\"108\" width=\"20\" height=\"14\" rx=\"3\" fill=\"#2a1d10\" stroke=\"#5a4426\" stroke-width=\"1\"/>\n            <circle cx=\"206\" cy=\"115\" r=\"4.5\" fill=\"var(--accent)\"/>\n          </g>\n          <!-- bottom (head 3) -->\n          <g id=\"hd3\" class=\"head-dot\">\n            <rect x=\"108\" y=\"204\" width=\"14\" height=\"20\" rx=\"3\" fill=\"#2a1d10\" stroke=\"#5a4426\" stroke-width=\"1\"/>\n            <circle cx=\"115\" cy=\"206\" r=\"4.5\" fill=\"var(--accent)\"/>\n          </g>\n          <!-- left (head 2) -->\n          <g id=\"hd2\" class=\"head-dot\">\n            <rect x=\"6\" y=\"108\" width=\"20\" height=\"14\" rx=\"3\" fill=\"#2a1d10\" stroke=\"#5a4426\" stroke-width=\"1\"/>\n            <circle cx=\"24\" cy=\"115\" r=\"4.5\" fill=\"var(--accent)\"/>\n          </g>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <div class=\"knob-cell\">\n        <canvas class=\"knob\" id=\"k_time\" width=\"156\" height=\"156\"></canvas>\n        <div class=\"label\">Time</div>\n        <div class=\"value\" id=\"v_time\">—</div>\n      </div>\n      <div class=\"knob-cell\">\n        <canvas class=\"knob\" id=\"k_swell\" width=\"156\" height=\"156\"></canvas>\n        <div class=\"label\">Swell</div>\n        <div class=\"value\" id=\"v_swell\">—</div>\n      </div>\n      <div class=\"knob-cell\">\n        <canvas class=\"knob\" id=\"k_tone\" width=\"156\" height=\"156\"></canvas>\n        <div class=\"label\">Tone</div>\n        <div class=\"value\" id=\"v_tone\">—</div>\n      </div>\n      <div class=\"knob-cell\">\n        <canvas class=\"knob\" id=\"k_mix\" width=\"156\" height=\"156\"></canvas>\n        <div class=\"label\">Mix</div>\n        <div class=\"value\" id=\"v_mix\">—</div>\n      </div>\n\n      <div class=\"heads-cell\">\n        <div class=\"heads-left\">\n          <div class=\"vlab\">Head Mode</div>\n          <div class=\"vname\" id=\"v_heads\">—</div>\n        </div>\n        <div class=\"heads-btns\" id=\"headsBtns\">\n          <button class=\"hbtn\" data-mode=\"0\">I<small>Slap</small></button>\n          <button class=\"hbtn\" data-mode=\"1\">II<small>Eighths</small></button>\n          <button class=\"hbtn\" data-mode=\"2\">III<small>Gallop</small></button>\n          <button class=\"hbtn\" data-mode=\"3\">IV<small>Swell</small></button>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"foot\">Original model · No trademark affiliation</div>\n  </div>\n\n  <script>\n    \"use strict\";\n\n    // ---- parameter map (must match spec.json indices) ----\n    var P_TIME = 0, P_SWELL = 1, P_HEADS = 2, P_TONE = 3, P_MIX = 4;\n\n    var defaults = {};\n    defaults[P_TIME] = 0.4;\n    defaults[P_SWELL] = 0.45;\n    defaults[P_HEADS] = 1;\n    defaults[P_TONE] = 0.55;\n    defaults[P_MIX] = 0.45;\n\n    var values = {};\n\n    function pushParam(index, value) {\n      values[index] = value;\n      if (window.vstai && window.vstai.setParam) {\n        window.vstai.setParam(index, value);\n      }\n    }\n\n    // ---- knob factory ----\n    function makeKnob(canvasId, valId, index, opts) {\n      var canvas = document.getElementById(canvasId);\n      var valEl = document.getElementById(valId);\n      var ctx = canvas.getContext(\"2d\");\n      var min = opts.min, max = opts.max, fmt = opts.fmt;\n      var def = defaults[index];\n\n      function norm() { return (values[index] - min) / (max - min); }\n\n      function draw() {\n        var w = canvas.width, h = canvas.height, cx = w / 2, cy = h / 2;\n        var r = w * 0.36;\n        ctx.clearRect(0, 0, w, h);\n        var a0 = Math.PI * 0.75, a1 = Math.PI * 2.25;\n        var t = Math.max(0, Math.min(1, norm()));\n        var ang = a0 + (a1 - a0) * t;\n\n        // outer inset well\n        ctx.beginPath();\n        ctx.arc(cx, cy, r + 16, 0, Math.PI * 2);\n        ctx.fillStyle = \"rgba(0,0,0,0.35)\";\n        ctx.fill();\n\n        // track\n        ctx.beginPath();\n        ctx.lineWidth = 8;\n        ctx.lineCap = \"round\";\n        ctx.strokeStyle = \"rgba(0,0,0,0.5)\";\n        ctx.arc(cx, cy, r + 9, a0, a1);\n        ctx.stroke();\n\n        // value arc (accent gradient)\n        var grad = ctx.createLinearGradient(0, 0, w, h);\n        grad.addColorStop(0, \"#e0a85a\");\n        grad.addColorStop(1, \"#ffd089\");\n        ctx.beginPath();\n        ctx.lineWidth = 8;\n        ctx.strokeStyle = grad;\n        ctx.shadowColor = \"rgba(224,168,90,0.7)\";\n        ctx.shadowBlur = 10;\n        ctx.arc(cx, cy, r + 9, a0, ang);\n        ctx.stroke();\n        ctx.shadowBlur = 0;\n\n        // knob body\n        var bg = ctx.createRadialGradient(cx - r * 0.35, cy - r * 0.4, r * 0.2, cx, cy, r);\n        bg.addColorStop(0, \"#4a3a24\");\n        bg.addColorStop(0.6, \"#33271a\");\n        bg.addColorStop(1, \"#1d150d\");\n        ctx.beginPath();\n        ctx.arc(cx, cy, r, 0, Math.PI * 2);\n        ctx.fillStyle = bg;\n        ctx.fill();\n        ctx.lineWidth = 1.5;\n        ctx.strokeStyle = \"rgba(255,220,170,0.15)\";\n        ctx.stroke();\n\n        // top highlight\n        ctx.beginPath();\n        ctx.arc(cx, cy - r * 0.15, r * 0.7, Math.PI * 1.1, Math.PI * 1.9);\n        ctx.strokeStyle = \"rgba(255,255,255,0.07)\";\n        ctx.lineWidth = 2;\n        ctx.stroke();\n\n        // pointer\n        var px = cx + Math.cos(ang) * (r - 8);\n        var py = cy + Math.sin(ang) * (r - 8);\n        ctx.beginPath();\n        ctx.moveTo(cx + Math.cos(ang) * (r * 0.32), cy + Math.sin(ang) * (r * 0.32));\n        ctx.lineTo(px, py);\n        ctx.lineWidth = 4;\n        ctx.lineCap = \"round\";\n        ctx.strokeStyle = \"#ffe6b8\";\n        ctx.shadowColor = \"rgba(255,224,170,0.9)\";\n        ctx.shadowBlur = 6;\n        ctx.stroke();\n        ctx.shadowBlur = 0;\n\n        // center cap\n        ctx.beginPath();\n        ctx.arc(cx, cy, r * 0.22, 0, Math.PI * 2);\n        var cap = ctx.createRadialGradient(cx - 3, cy - 3, 1, cx, cy, r * 0.22);\n        cap.addColorStop(0, \"#c9933f\");\n        cap.addColorStop(1, \"#5a4022\");\n        ctx.fillStyle = cap;\n        ctx.fill();\n      }\n\n      function update(v, silent) {\n        v = Math.max(min, Math.min(max, v));\n        values[index] = v;\n        valEl.textContent = fmt(v);\n        if (!silent) pushParam(index, v);\n        draw();\n      }\n\n      // drag handling\n      var dragging = false, lastY = 0;\n      function onDown(e) {\n        dragging = true;\n        lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n        e.preventDefault();\n      }\n      function onMove(e) {\n        if (!dragging) return;\n        var y = (e.touches ? e.touches[0].clientY : e.clientY);\n        var dy = lastY - y;\n        lastY = y;\n        var range = max - min;\n        update(values[index] + dy * range / 180);\n        e.preventDefault();\n      }\n      function onUp() { dragging = false; }\n\n      canvas.addEventListener(\"mousedown\", onDown);\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      canvas.addEventListener(\"touchstart\", onDown, { passive: false });\n      canvas.addEventListener(\"touchmove\", onMove, { passive: false });\n      canvas.addEventListener(\"touchend\", onUp);\n      canvas.addEventListener(\"dblclick\", function () { update(def); });\n      canvas.addEventListener(\"wheel\", function (e) {\n        var range = max - min;\n        update(values[index] - Math.sign(e.deltaY) * range * 0.03);\n        e.preventDefault();\n      }, { passive: false });\n\n      return { update: update, draw: draw };\n    }\n\n    function pct(v) { return Math.round(v * 100) + \"%\"; }\n    function timeFmt(v) { return Math.round((0.09 + v * 0.66) * 1000) + \" ms\"; }\n\n    var knobTime, knobSwell, knobTone, knobMix;\n\n    // ---- heads selector ----\n    var headIds = { 1: \"hd1\", 2: \"hd2\", 3: \"hd3\", 4: \"hd4\" };\n    var modeHeads = {\n      0: [4],\n      1: [2, 4],\n      2: [1, 3, 4],\n      3: [1, 2, 3, 4]\n    };\n    var modeNames = { 0: \"I · Single Head\", 1: \"II · Even Eighths\", 2: \"III · Triplet Gallop\", 3: \"IV · Full Swell\" };\n\n    function setHeads(mode, silent) {\n      mode = Math.max(0, Math.min(3, Math.round(mode)));\n      values[P_HEADS] = mode;\n      document.getElementById(\"v_heads\").textContent = modeNames[mode];\n      // buttons\n      var btns = document.querySelectorAll(\"#headsBtns .hbtn\");\n      btns.forEach(function (b) {\n        b.classList.toggle(\"active\", parseInt(b.getAttribute(\"data-mode\"), 10) === mode);\n      });\n      // light the active heads on the drum\n      var active = modeHeads[mode];\n      for (var k in headIds) {\n        var g = document.getElementById(headIds[k]);\n        var on = active.indexOf(parseInt(k, 10)) >= 0;\n        g.classList.toggle(\"head-on\", on);\n        g.style.opacity = on ? \"1\" : \"0.32\";\n      }\n      if (!silent) pushParam(P_HEADS, mode);\n    }\n\n    function wireHeads() {\n      var btns = document.querySelectorAll(\"#headsBtns .hbtn\");\n      btns.forEach(function (b) {\n        b.addEventListener(\"click\", function () {\n          setHeads(parseInt(b.getAttribute(\"data-mode\"), 10));\n        });\n        b.addEventListener(\"dblclick\", function () { setHeads(defaults[P_HEADS]); });\n      });\n    }\n\n    // ---- init ----\n    function start() {\n      knobTime = makeKnob(\"k_time\", \"v_time\", P_TIME, { min: 0, max: 1, fmt: timeFmt });\n      knobSwell = makeKnob(\"k_swell\", \"v_swell\", P_SWELL, { min: 0, max: 1, fmt: pct });\n      knobTone = makeKnob(\"k_tone\", \"v_tone\", P_TONE, { min: 0, max: 1, fmt: pct });\n      knobMix = makeKnob(\"k_mix\", \"v_mix\", P_MIX, { min: 0, max: 1, fmt: pct });\n      wireHeads();\n\n      // initialise everything to defaults and push once\n      knobTime.update(defaults[P_TIME]);\n      knobSwell.update(defaults[P_SWELL]);\n      knobTone.update(defaults[P_TONE]);\n      knobMix.update(defaults[P_MIX]);\n      setHeads(defaults[P_HEADS]);\n    }\n\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(start);\n    } else {\n      start();\n    }\n  </script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MAGNETIC ECHO — multi-head magnetic-drum echo\n//  An original model of the vintage Italian magnetic-drum echo: a single\n//  circulating loop (the rotating drum) is read by FOUR fixed playback\n//  heads at 1/4, 2/4, 3/4 and 4/4 of the loop. A Head Mode (0..3) selects\n//  which heads sound, giving distinct rhythmic multi-tap patterns. The\n//  recirculating \"Swell\" feedback builds repeats; each pass is bandwidth-\n//  limited (warm drum + record/playback head loss) and carries subtle\n//  flutter from the drum's mechanical wobble. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay drum: a circular buffer per channel. ~1.2 s max loop at 48k headroom.\nconst DRUM_LEN: i32 = 96000; // per channel, ~2 s @ 48k — full drum circumference\nconst drum: StaticArray<f32> = new StaticArray<f32>(DRUM_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\n\n// per-channel filter / saturation state for the recirculating path\nconst lpState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // HF loss in loop\nconst hpState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC / rumble block\nconst toneState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone LP\n\n// flutter LFOs (slow wow + faster flutter) — one shared phase, stereo offset\nlet wowPhase: f32 = 0.0;\nlet flutPhase: f32 = 0.0;\n\nconst P_TIME: i32 = 0;  // 0..1 -> loop length (drum speed)\nconst P_SWELL: i32 = 1; // 0..1 -> feedback amount\nconst P_HEADS: i32 = 2; // 0..3 step 1 -> head-combination mode\nconst P_TONE: i32 = 3;  // 0..1 -> post tone low-pass\nconst P_MIX: i32 = 4;   // 0..1 dry/wet\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// gentle tape/drum saturation, bounded to ±1\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -1.6, 1.6);\n  return f32(c - 0.16666667 * c * c * c);\n}\n\n// read the drum at a fractional sample offset behind the write head (per channel)\n@inline function readDrum(c: i32, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(DRUM_LEN);\n  while (rp >= f32(DRUM_LEN)) rp -= f32(DRUM_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= DRUM_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const base: i32 = c * DRUM_LEN;\n  const a: f32 = drum[base + i0];\n  const b: f32 = drum[base + i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  wowPhase = 0.0;\n  flutPhase = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lpState[c] = 0.0; hpState[c] = 0.0; toneState[c] = 0.0;\n  }\n  for (let i = 0; i < DRUM_LEN * MAX_CHANNELS; i++) drum[i] = 0.0;\n  params[P_TIME] = 0.4;\n  params[P_SWELL] = 0.45;\n  params[P_HEADS] = 1.0;\n  params[P_TONE] = 0.55;\n  params[P_MIX] = 0.45;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const swell: f32 = clampf(params[P_SWELL], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // head mode 0..3 (selector). Each mode lights a different head combination.\n  let mode: i32 = i32(params[P_HEADS] + 0.5);\n  if (mode < 0) mode = 0; if (mode > 3) mode = 3;\n\n  // base loop length (the longest head = full drum). 90 ms .. 750 ms.\n  const baseDelay: f32 = (0.09 + timeN * 0.66) * sampleRate;\n\n  // The four heads sit at 1/4, 2/4, 3/4, 4/4 of the loop. Gains per mode.\n  // Mode 0: single head (head 4 only) — simple slap.\n  // Mode 1: heads 2 + 4 — even eighths.\n  // Mode 2: heads 1 + 3 + 4 — galloping triplet feel.\n  // Mode 3: all four heads — dense swell.\n  let g1: f32 = 0.0; let g2: f32 = 0.0; let g3: f32 = 0.0; let g4: f32 = 0.0;\n  if (mode == 0) { g4 = 1.0; }\n  else if (mode == 1) { g2 = 0.85; g4 = 1.0; }\n  else if (mode == 2) { g1 = 0.7; g3 = 0.85; g4 = 1.0; }\n  else { g1 = 0.7; g2 = 0.8; g3 = 0.9; g4 = 1.0; }\n\n  const d1: f32 = baseDelay * 0.25;\n  const d2: f32 = baseDelay * 0.50;\n  const d3: f32 = baseDelay * 0.75;\n  const d4: f32 = baseDelay;\n\n  // feedback taken from the last head; bounded so the drum never runs away.\n  const fb: f32 = swell * 0.92;\n\n  // loop HF loss: warmer as repeats stack (fixed musical corner ~3.8 kHz)\n  const loopHz: f32 = 3800.0;\n  const cLoop: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * loopHz / sampleRate));\n  // loop DC / rumble blocker corner ~45 Hz\n  const cHp: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 45.0 / sampleRate));\n  // post tone low-pass 700 .. 7500 Hz\n  const toneHz: f32 = 700.0 + toneN * toneN * 6800.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * toneHz / sampleRate));\n\n  // flutter: slow wow ~0.7 Hz + faster flutter ~6.3 Hz, depth in samples\n  const wowInc: f32 = f32(0.7 / sampleRate);\n  const flutInc: f32 = f32(6.3 / sampleRate);\n  const flutDepth: f32 = 0.0016 * baseDelay; // proportional wobble\n\n  for (let f = 0; f < n; f++) {\n    // advance flutter phases once per frame (shared across channels)\n    wowPhase += wowInc; if (wowPhase >= 1.0) wowPhase -= 1.0;\n    flutPhase += flutInc; if (flutPhase >= 1.0) flutPhase -= 1.0;\n    const wob: f32 = flutDepth * (Mathf.sin(wowPhase * 6.2831853) * 0.7\n                                + Mathf.sin(flutPhase * 6.2831853) * 0.3);\n\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * DRUM_LEN;\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // stereo flutter offset so the channels shimmer apart slightly\n      const chOff: f32 = c == 0 ? wob : -wob;\n\n      // read the four heads (longest carries the feedback)\n      const h1: f32 = g1 != 0.0 ? readDrum(c, d1 + chOff) : 0.0;\n      const h2: f32 = g2 != 0.0 ? readDrum(c, d2 + chOff) : 0.0;\n      const h3: f32 = g3 != 0.0 ? readDrum(c, d3 + chOff) : 0.0;\n      const h4: f32 = readDrum(c, d4 + chOff);\n\n      const echoes: f32 = h1 * g1 + h2 * g2 + h3 * g3 + h4 * g4;\n\n      // what we record onto the drum: input + recirculated last head,\n      // through the warm loop band-limiting + saturation.\n      let into: f32 = x + h4 * fb;\n\n      // loop HF loss (one-pole LP toward lpState)\n      let lp: f32 = lpState[c];\n      lp = lp + cLoop * (into - lp);\n      lpState[c] = lp;\n\n      // rumble / DC blocker (subtract a slow LP)\n      let hp: f32 = hpState[c];\n      hp = hp + cHp * (lp - hp);\n      hpState[c] = hp;\n      let rec: f32 = lp - hp;\n\n      rec = satf(rec);\n      drum[base + writePos] = rec;\n\n      // wet sum of selected heads, then post tone shaping\n      let tn: f32 = toneState[c];\n      tn = tn + cTone * (echoes - tn);\n      toneState[c] = tn;\n\n      const wet: f32 = tn;\n      const y: f32 = x * (1.0 - mix) + wet * mix;\n      outBuf[c * MAX_FRAMES + f] = clampf(y, -1.0, 1.0);\n    }\n\n    // advance the single shared write head AFTER both channels recorded\n    writePos++;\n    if (writePos >= DRUM_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000041000
}