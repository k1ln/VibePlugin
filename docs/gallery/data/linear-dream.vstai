  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Linear Dream</title>\n<style>\n  :root{ --acc:#5ad0c4; --acc2:#b08cff; --bg0:#05100f; --bg1:#0b1a20; --ink:#dff3f0; --dim:#5f8086; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#10282c 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:16px; padding:16px 20px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#123034,#06140f);\n    border:1px solid rgba(90,208,196,.18); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(200,255,245,.06); }\n  .unit::before{ content:\"\"; position:absolute; inset:-40% -10%; pointer-events:none;\n    background:radial-gradient(40% 50% at 18% 0%,rgba(90,208,196,.10),transparent 60%),radial-gradient(40% 60% at 100% 20%,rgba(176,140,255,.12),transparent 60%);\n    animation:drift 16s ease-in-out infinite alternate; }\n  @keyframes drift{ from{ transform:translate(-2%,-1%);} to{ transform:translate(3%,2%);} }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.15em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2);\n    box-shadow:0 0 10px var(--acc2),0 0 20px var(--acc2); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.45; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:12px; position:relative;\n    background:linear-gradient(180deg,#08201d,#06140f); border:1px solid rgba(90,208,196,.15); box-shadow:inset 0 2px 20px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .leg{ position:absolute; right:12px; top:8px; font-size:9px; letter-spacing:.06em; z-index:2; }\n  .leg b{ color:var(--acc); } .leg i{ color:var(--acc2); font-style:normal; }\n\n  .asel{ display:grid; grid-template-columns:repeat(3,1fr); gap:8px; margin-bottom:12px; }\n  .abtn{ text-align:center; padding:8px 4px; border-radius:9px; cursor:pointer; font-size:10.5px; letter-spacing:.12em; text-transform:uppercase;\n    background:#0c1c1f; border:1px solid rgba(90,208,196,.2); color:var(--dim); transition:all .12s; }\n  .abtn.sel{ color:#04140f; background:linear-gradient(180deg,var(--acc),#39b0a4); box-shadow:0 0 16px rgba(90,208,196,.5); font-weight:700; }\n\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(180,230,225,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(90,208,196,.6)); }\n  .pcap{ fill:#0a1a18; stroke:rgba(90,208,196,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(90,208,196,.1);\n    padding:1px 7px; border-radius:7px; border:1px solid rgba(90,208,196,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">LINEAR&nbsp;DREAM</span>\n      <span class=\"sub\">LA synthesis</span>\n      <span class=\"led\"></span>\n    </header>\n    <div class=\"screen\"><div class=\"scrlbl\">ATTACK + BODY</div><div class=\"leg\"><b>■ attack</b> &nbsp; <i>■ body</i></div><canvas id=\"cv\"></canvas></div>\n    <div class=\"asel\" id=\"asel\"></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var ATKS=[\"Mallet\",\"Blown\",\"Pluck\"];\n  var PARAMS=[\n    {name:\"Cutoff\",idx:1,def:0.55},\n    {name:\"Reso\",  idx:2,def:0.35},\n    {name:\"Env\",   idx:3,def:0.6},\n    {name:\"Chorus\",idx:4,def:0.5},\n    {name:\"Level\", idx:5,def:0.8}\n  ];\n  var vals={1:0.55,2:0.35,3:0.6,4:0.5,5:0.8};\n  var atkV=0.0; // param 0\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function selFromV(v){ var s=Math.floor(v*2.999); return s<0?0:(s>2?2:s); }\n\n  var asel=document.getElementById(\"asel\");\n  var abtns=ATKS.map(function(nm,i){\n    var b=document.createElement(\"div\"); b.className=\"abtn\"; b.textContent=nm; asel.appendChild(b);\n    b.addEventListener(\"click\",function(){ atkV=(i+0.5)/3; setAtkUI(); send(0,atkV); });\n    return b;\n  });\n  function setAtkUI(){ var s=selFromV(atkV); for(var i=0;i<3;i++) abtns[i].classList.toggle(\"sel\",i===s); }\n\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=PARAMS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#5ad0c4\"/><stop offset=\"1\" stop-color=\"#b08cff\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle>'+\n      '<circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle>'+\n      '<line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){\n      var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2));\n      ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2));\n      val.textContent=Math.round(v*100)+\"%\";\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- LA layering visualization: a sharp attack spike + a sustained body envelope ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H);\n    var atkType=selFromV(atkV), env=vals[3], cut=vals[1];\n    var base=H-14, pulse=0.5+0.5*Math.sin(ts/700);\n    ctx.strokeStyle=\"rgba(90,208,196,0.10)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(0,base); ctx.lineTo(W,base); ctx.stroke();\n    // BODY envelope (purple): rises then sustains, filter env affects the curve\n    ctx.beginPath();\n    for(var x=0;x<=W;x++){ var t=x/W; var a=Math.min(1,t/0.08); var dec=0.5+0.5*Math.exp(-t*(1+env*3)); var y=base-(a*dec)*(H*0.6)*(0.5+cut*0.5); ctx.lineTo(x,y); }\n    ctx.strokeStyle=\"rgba(176,140,255,0.85)\"; ctx.lineWidth=2; ctx.shadowColor=\"#b08cff\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    // ATTACK transient (teal): a sharp spike whose shape depends on type\n    ctx.beginPath();\n    for(var x2=0;x2<=W;x2++){ var t2=x2/W; var spike;\n      if(atkType===0) spike=Math.exp(-t2*40)*Math.abs(Math.sin(t2*120));        // mallet: ringy\n      else if(atkType===1) spike=Math.exp(-t2*16)*(0.4+0.6*Math.abs(Math.sin(t2*60)));  // blown: softer chiff\n      else spike=Math.exp(-t2*55);                                            // pluck: sharp\n      var y2=base - spike*(H*0.66)*pulse;\n      if(x2===0) ctx.moveTo(x2,y2); else ctx.lineTo(x2,y2); }\n    ctx.strokeStyle=\"rgba(90,208,196,0.95)\"; ctx.lineWidth=2; ctx.shadowColor=\"#5ad0c4\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function boot(){ host=window.vstai||null; send(0,atkV); setAtkUI(); PARAMS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  LINEAR DREAM — an LA-synthesis voice (Roland D-50 lineage).\n//  \"Linear Arithmetic\": each note layers a short PCM ATTACK transient over\n//  a synthesised SUSTAIN body. Three original attack samples (mallet,\n//  blown, pluck — self-authored CC0) are baked in as base64 Int16 PCM @\n//  22050 Hz (C3) and played once at note onset; a sawtooth body runs\n//  through a per-voice resonant low-pass with a decaying filter envelope\n//  and an amp envelope. 8-voice poly + a lush built-in chorus.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst SAMP_CAP: i32 = 12000;\nconst SAMP_SR: f32 = 22050.0;\nconst BASE_HZ: f32 = 130.81;\nconst NVOX: i32 = 8;\nconst NATK: i32 = 3;\nconst CH_LEN: i32 = 4096;\nconst CH_MASK: i32 = CH_LEN - 1;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst samp: StaticArray<f32> = new StaticArray<f32>(SAMP_CAP);\nlet sampLen: i32 = 0;\nconst aOff: StaticArray<i32> = new StaticArray<i32>(NATK);\nconst aLen: StaticArray<i32> = new StaticArray<i32>(NATK);\n\nconst vAPos: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vASmp: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vOsc:  StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp:  StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt:   StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vVel:  StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\n\nconst chL: StaticArray<f32> = new StaticArray<f32>(CH_LEN);\nlet chW: i32 = 0;\nlet chPh: f32 = 0.0;\n\nlet sampleRate: f32 = 48000.0;\n\nconst P_ATTACK: i32 = 0;  // attack-transient select 0..2\nconst P_CUTOFF: i32 = 1;\nconst P_RESO: i32 = 2;\nconst P_ENV: i32 = 3;     // filter envelope amount\nconst P_CHORUS: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62; if (c == 47) return 63; return -1;\n}\n\nconst PCM_B64: string = \"\";\n\nfunction decodePCM(): void {\n  const s = PCM_B64; const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i)); if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) { bits -= 8; const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; } else { let val = (byte << 8) | lo; if (val >= 32768) val -= 65536; if (si < SAMP_CAP) { samp[si] = f32(val) / 32768.0; si++; } lo = -1; } }\n  }\n  sampLen = si;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0; chW = 0; chPh = 0.0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vAPos[i] = 0.0; vOsc[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vVel[i] = 0.0; vFreq[i] = BASE_HZ; vLp[i] = 0.0; vBp[i] = 0.0; vASmp[i] = 0; vNote[i] = -1; }\n  for (let i = 0; i < CH_LEN; i++) chL[i] = 0.0;\n  aOff[0]=0; aLen[0]=2866; aOff[1]=2866; aLen[1]=2866; aOff[2]=5732; aLen[2]=2866;\n  params[P_ATTACK] = 0.0;\n  params[P_CUTOFF] = 0.55;\n  params[P_RESO] = 0.35;\n  params[P_ENV] = 0.6;\n  params[P_CHORUS] = 0.5;\n  params[P_LEVEL] = 0.8;\n  decodePCM();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let sel: i32 = i32(clampf(params[P_ATTACK], 0.0, 1.0) * 2.999); if (sel < 0) sel = 0; if (sel >= NATK) sel = NATK - 1;\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vASmp[slot] = sel; vAPos[slot] = 0.0; vOsc[slot] = 0.0;\n  vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vVel[slot] = clampf(v, 0.05, 1.0); vFreq[slot] = f > 0.0 ? f : BASE_HZ;\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const chorusN: f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.005 * sampleRate);            // ~5 ms amp attack\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.25 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate))); // filter env decay\n  const baseCut: f32 = 60.0;\n  const cutSpan: f32 = f32(Mathf.exp(cutoffN * 5.0));        // cutoff scaler\n  const envSpan: f32 = envN * 6000.0;\n  const k: f32 = 2.0 - 1.9 * resoN;\n  const aRate0: f32 = SAMP_SR / sampleRate;\n  const chDepth: f32 = chorusN * 0.009 * sampleRate;\n  const chBase: f32 = 0.007 * sampleRate;\n  const chPhInc: f32 = 0.7 / sampleRate * 6.2831853;\n  const chMix: f32 = chorusN * 0.6;\n  const out: f32 = level * 0.42;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr0: f32 = vFreq[s];\n      // amp env\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      // PCM attack transient (plays once, pitched)\n      let atk: f32 = 0.0;\n      const al: i32 = aLen[vASmp[s]];\n      const apos: f32 = vAPos[s];\n      const aip: i32 = i32(apos);\n      if (aip < al - 1) {\n        const ao: i32 = aOff[vASmp[s]];\n        const af: f32 = apos - f32(aip);\n        atk = samp[ao + aip] + (samp[ao + aip + 1] - samp[ao + aip]) * af;\n        vAPos[s] = apos + (fr0 / BASE_HZ) * aRate0;\n      }\n      // synth saw body\n      let ph: f32 = vOsc[s] + fr0 / sampleRate;\n      if (ph >= 1.0) ph -= 1.0;\n      vOsc[s] = ph;\n      const saw: f32 = ph * 2.0 - 1.0;\n      // per-voice resonant SVF low-pass with filter env\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut * cutSpan + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (saw - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s];\n      const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const body: f32 = lpN;\n      mix += (atk * 0.9 + body * 0.8) * vAmp[s] * vVel[s];\n    }\n    // chorus\n    chL[chW] = mix;\n    chPh += chPhInc; if (chPh > 6.2831853) chPh -= 6.2831853;\n    const d1: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh)));\n    const d2: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh + 2.6)));\n    const r1: f32 = f32(chW) - d1; let i1: i32 = i32(r1); const fa: f32 = r1 - f32(i1);\n    const r2: f32 = f32(chW) - d2; let i2: i32 = i32(r2); const fb2: f32 = r2 - f32(i2);\n    const c1: f32 = chL[i1 & CH_MASK] + (chL[(i1 + 1) & CH_MASK] - chL[i1 & CH_MASK]) * fa;\n    const c2: f32 = chL[i2 & CH_MASK] + (chL[(i2 + 1) & CH_MASK] - chL[i2 & CH_MASK]) * fb2;\n    chW = (chW + 1) & CH_MASK;\n    let l: f32 = (mix + c1 * chMix) * out;\n    let r: f32 = (mix + c2 * chMix) * out;\n    if (l > 1.4) l = 1.4; else if (l < -1.4) l = -1.4;\n    if (r > 1.4) r = 1.4; else if (r < -1.4) r = -1.4;\n    outBuf[i] = l;\n    outBuf[MAX_FRAMES + i] = r;\n  }\n}\n",
  "publishedAt": 1751000156000
}