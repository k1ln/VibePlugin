{
  "format": 1,
  "name": "Sweet Drive",
  "isInstrument": false,
  "explanation": "A warm asymmetric soft-clip overdrive. The signal is band-limited to clean the low end, then pushed into an asymmetric waveshaper that clips one half harder than the other — generating even harmonics for a sweeter, slightly fatter break-up over a gentle mid-hump. Touch-sensitive, amp-like dynamics; a post tone low-pass shapes brightness, with output Level and dry/wet Mix. Controls: Drive, Tone, Level, Mix.",
  "params": [
    {
      "name": "Drive",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Level",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Sweet Drive</title>\n<style>\n  :root{\n    --accent:#ffd23d;      /* lemon */\n    --accent2:#ff8a2a;     /* honey orange */\n    --face1:#ffe27a;\n    --face2:#f4b62e;\n    --ink:#5a3a08;\n    --chrome1:#fbfbff;\n    --chrome2:#9aa0ad;\n    --chrome3:#3a3e48;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:\"Avenir Next\",\"Segoe UI\",system-ui,sans-serif;\n    background:radial-gradient(120% 120% at 50% -10%,#2a2118 0%,#15110b 60%,#0a0806 100%);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100vh;overflow:hidden;color:var(--ink);\n  }\n\n  /* ---------- ambient honey glow ---------- */\n  .glow{\n    position:fixed;inset:0;pointer-events:none;\n    background:radial-gradient(40% 50% at 50% 42%,rgba(255,170,40,.20),transparent 70%);\n    animation:breathe 6s ease-in-out infinite;\n  }\n  @keyframes breathe{0%,100%{opacity:.55}50%{opacity:1}}\n\n  /* ---------- the pedal ---------- */\n  .pedal{\n    position:relative;width:340px;border-radius:26px;padding:26px 26px 30px;\n    background:\n      linear-gradient(155deg,var(--face1) 0%,var(--face2) 55%,#e09b20 100%);\n    box-shadow:\n      0 2px 0 rgba(255,255,255,.55) inset,\n      0 -22px 50px rgba(120,70,0,.35) inset,\n      0 28px 60px rgba(0,0,0,.6),\n      0 4px 14px rgba(0,0,0,.5);\n    border:1px solid rgba(120,70,0,.4);\n  }\n  /* glossy top sheen */\n  .pedal::before{\n    content:\"\";position:absolute;left:14px;right:14px;top:12px;height:34%;\n    border-radius:20px 20px 60% 60%;\n    background:linear-gradient(180deg,rgba(255,255,255,.55),rgba(255,255,255,0));\n    pointer-events:none;mix-blend-mode:screen;\n  }\n  /* corner screws */\n  .screw{position:absolute;width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff,#c9a23a 55%,#7a5a10);\n    box-shadow:0 1px 2px rgba(0,0,0,.5),0 0 0 1px rgba(120,70,0,.3) inset}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(45deg,transparent 44%,#6b4d10 44%,#6b4d10 56%,transparent 56%)}\n  .screw.tl{top:10px;left:10px}.screw.tr{top:10px;right:10px}\n  .screw.bl{bottom:10px;left:10px}.screw.br{bottom:10px;right:10px}\n\n  .brand{text-align:center;margin-bottom:4px}\n  .brand h1{\n    font-size:30px;letter-spacing:1px;font-weight:800;font-style:italic;\n    color:#fff;text-shadow:0 1px 0 #fff6,0 2px 3px rgba(120,60,0,.55);\n  }\n  .brand .sub{font-size:10px;letter-spacing:4px;font-weight:700;color:#7a4f0c;opacity:.8;text-transform:uppercase}\n\n  /* ---------- scope: asymmetric clipping waves ---------- */\n  .scope-wrap{\n    margin:12px auto 6px;width:100%;height:96px;border-radius:14px;\n    background:linear-gradient(180deg,#2a1c08,#120c04);\n    box-shadow:0 2px 6px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.3);\n    overflow:hidden;position:relative;border:1px solid rgba(0,0,0,.4);\n  }\n  .scope-wrap::after{ /* glass reflection */\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(120deg,rgba(255,255,255,.12),transparent 40%);\n  }\n  svg{display:block;width:100%;height:100%}\n\n  /* ---------- big chrome drive knob ---------- */\n  .knob-stage{display:flex;justify-content:center;margin:14px 0 6px}\n  .bigknob{position:relative;width:130px;height:130px;cursor:grab}\n  .bigknob.drag{cursor:grabbing}\n  .halo{position:absolute;inset:-10px;border-radius:50%;\n    background:radial-gradient(circle,rgba(255,180,50,.0),rgba(255,180,50,.0));\n    transition:background .25s}\n  .bigknob:hover .halo{background:radial-gradient(circle,rgba(255,180,50,.35),transparent 65%)}\n  .dial{position:absolute;inset:0;border-radius:50%;\n    background:\n      radial-gradient(circle at 38% 30%,#ffffff 0%,#dfe3ec 22%,#aab0bd 48%,#6e7480 70%,#42464f 100%);\n    box-shadow:\n      0 6px 16px rgba(0,0,0,.55),\n      0 1px 0 rgba(255,255,255,.8) inset,\n      0 -8px 14px rgba(0,0,0,.45) inset;\n    border:1px solid #2a2d34;\n  }\n  .dial::before{content:\"\";position:absolute;inset:14px;border-radius:50%;\n    background:repeating-conic-gradient(#c7ccd6 0deg 4deg,#9aa0ad 4deg 8deg);\n    box-shadow:0 1px 3px rgba(0,0,0,.4) inset}\n  .cap{position:absolute;inset:30px;border-radius:50%;\n    background:radial-gradient(circle at 40% 32%,#fff,#cdd2dc 40%,#7a808c 100%);\n    box-shadow:0 2px 6px rgba(0,0,0,.5),0 1px 0 rgba(255,255,255,.9) inset}\n  .pointer{position:absolute;left:50%;top:8px;width:5px;height:34px;margin-left:-2.5px;\n    border-radius:3px;background:linear-gradient(#fff,var(--accent2));\n    box-shadow:0 0 6px var(--accent),0 1px 2px rgba(0,0,0,.6);transform-origin:50% 57px}\n  .ticks{position:absolute;inset:-2px;pointer-events:none}\n  .knob-label{position:absolute;left:0;right:0;bottom:-22px;text-align:center;\n    font-size:11px;letter-spacing:3px;font-weight:800;color:#6b4310;text-transform:uppercase}\n  .knob-val{position:absolute;left:0;right:0;top:50px;text-align:center;\n    font-size:18px;font-weight:800;color:#3a2606;text-shadow:0 1px 0 #fff8}\n\n  /* ---------- small knobs row ---------- */\n  .row{display:flex;justify-content:space-around;margin-top:30px}\n  .mini{position:relative;width:74px;text-align:center;cursor:grab}\n  .mini.drag{cursor:grabbing}\n  .mdial{position:relative;width:62px;height:62px;margin:0 auto;border-radius:50%;\n    background:radial-gradient(circle at 38% 30%,#fff 0%,#e7ebf2 24%,#aeb4c1 52%,#5d626d 100%);\n    box-shadow:0 4px 10px rgba(0,0,0,.5),0 1px 0 rgba(255,255,255,.8) inset,0 -6px 10px rgba(0,0,0,.35) inset;\n    border:1px solid #2a2d34}\n  .mcap{position:absolute;inset:14px;border-radius:50%;\n    background:radial-gradient(circle at 40% 32%,#fff,#c7ccd6 45%,#7a808c)}\n  .mpointer{position:absolute;left:50%;top:4px;width:4px;height:18px;margin-left:-2px;border-radius:2px;\n    background:linear-gradient(#fff,var(--accent2));box-shadow:0 0 5px var(--accent);transform-origin:50% 27px}\n  .mlabel{font-size:10px;letter-spacing:2px;font-weight:800;color:#6b4310;margin-top:7px;text-transform:uppercase}\n  .mval{font-size:11px;font-weight:700;color:#4a3208;opacity:.85}\n\n  /* ---------- LED ---------- */\n  .led{position:absolute;top:54px;right:30px;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff,#ffcf3b 40%,#ff7a18 90%);\n    box-shadow:0 0 12px 3px rgba(255,150,30,.85),0 1px 2px rgba(0,0,0,.5);\n    animation:pulse 2.4s ease-in-out infinite}\n  @keyframes pulse{0%,100%{box-shadow:0 0 8px 2px rgba(255,150,30,.6)}50%{box-shadow:0 0 16px 5px rgba(255,170,40,1)}}\n\n  .footnote{text-align:center;font-size:9px;color:#7a4f0c;opacity:.7;margin-top:18px;letter-spacing:2px}\n</style>\n</head>\n<body>\n  <div class=\"glow\"></div>\n  <div class=\"pedal\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n    <span class=\"led\"></span>\n\n    <div class=\"brand\">\n      <h1>Sweet&nbsp;Drive</h1>\n      <div class=\"sub\">Asymmetric Overdrive</div>\n    </div>\n\n    <div class=\"scope-wrap\">\n      <svg id=\"scope\" viewBox=\"0 0 340 96\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"g-wave\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#fff2a8\"/>\n            <stop offset=\"1\" stop-color=\"#ff8a2a\"/>\n          </linearGradient>\n          <linearGradient id=\"g-fill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"rgba(255,210,61,.45)\"/>\n            <stop offset=\"1\" stop-color=\"rgba(255,138,42,.02)\"/>\n          </linearGradient>\n        </defs>\n        <line x1=\"0\" y1=\"48\" x2=\"340\" y2=\"48\" stroke=\"rgba(255,200,80,.18)\" stroke-width=\"1\"/>\n        <path id=\"wfill\" fill=\"url(#g-fill)\" d=\"\"/>\n        <path id=\"wave\" fill=\"none\" stroke=\"url(#g-wave)\" stroke-width=\"2.4\"\n              stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n      </svg>\n    </div>\n\n    <div class=\"knob-stage\">\n      <div class=\"bigknob\" id=\"k-drive\" tabindex=\"0\">\n        <div class=\"halo\"></div>\n        <svg class=\"ticks\" viewBox=\"0 0 130 130\">\n          <g id=\"bigticks\" stroke=\"#7a4f0c\" stroke-width=\"2\" stroke-linecap=\"round\"></g>\n        </svg>\n        <div class=\"dial\"></div>\n        <div class=\"cap\"></div>\n        <div class=\"pointer\" id=\"p-drive\"></div>\n        <div class=\"knob-val\" id=\"v-drive\">50</div>\n        <div class=\"knob-label\">Drive</div>\n      </div>\n    </div>\n\n    <div class=\"row\">\n      <div class=\"mini\" id=\"k-tone\" tabindex=\"0\">\n        <div class=\"mdial\"><div class=\"mcap\"></div><div class=\"mpointer\" id=\"p-tone\"></div></div>\n        <div class=\"mlabel\">Tone</div><div class=\"mval\" id=\"v-tone\">50</div>\n      </div>\n      <div class=\"mini\" id=\"k-level\" tabindex=\"0\">\n        <div class=\"mdial\"><div class=\"mcap\"></div><div class=\"mpointer\" id=\"p-level\"></div></div>\n        <div class=\"mlabel\">Level</div><div class=\"mval\" id=\"v-level\">60</div>\n      </div>\n      <div class=\"mini\" id=\"k-mix\" tabindex=\"0\">\n        <div class=\"mdial\"><div class=\"mcap\"></div><div class=\"mpointer\" id=\"p-mix\"></div></div>\n        <div class=\"mlabel\">Mix</div><div class=\"mval\" id=\"v-mix\">100</div>\n      </div>\n    </div>\n\n    <div class=\"footnote\">EVEN-HARMONIC SOFT CLIP · BOUTIQUE TONE</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- host bridge ----\n  function setParam(i,v){\n    try{ if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v); }catch(e){}\n  }\n\n  // ---- param model (all 0..1 normalized) ----\n  var P = {\n    drive:{idx:0, def:0.5, val:0.5, big:true,  pEl:\"p-drive\", vEl:\"v-drive\"},\n    tone: {idx:1, def:0.5, val:0.5, big:false, pEl:\"p-tone\",  vEl:\"v-tone\"},\n    level:{idx:2, def:0.6, val:0.6, big:false, pEl:\"p-level\", vEl:\"v-level\"},\n    mix:  {idx:3, def:1.0, val:1.0, big:false, pEl:\"p-mix\",   vEl:\"v-mix\"}\n  };\n\n  var MIN=-135, MAX=135; // pointer sweep degrees\n\n  function angle(v){ return MIN + v*(MAX-MIN); }\n\n  function render(name){\n    var p=P[name];\n    var ptr=document.getElementById(p.pEl);\n    if(ptr) ptr.style.transform = \"rotate(\"+angle(p.val).toFixed(1)+\"deg)\";\n    var val=document.getElementById(p.vEl);\n    if(val) val.textContent = Math.round(p.val*100);\n  }\n\n  function commit(name){\n    var p=P[name];\n    setParam(p.idx, p.val);\n    render(name);\n  }\n\n  // ---- big knob tick marks ----\n  (function(){\n    var g=document.getElementById(\"bigticks\");\n    if(!g) return;\n    var cx=65, cy=65;\n    for(var i=0;i<=10;i++){\n      var a=(MIN + i/10*(MAX-MIN))*Math.PI/180;\n      var r1=58, r2=(i%5===0)?49:53;\n      var x1=cx+r1*Math.sin(a), y1=cy-r1*Math.cos(a);\n      var x2=cx+r2*Math.sin(a), y2=cy-r2*Math.cos(a);\n      var ln=document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      ln.setAttribute(\"x1\",x1.toFixed(1));ln.setAttribute(\"y1\",y1.toFixed(1));\n      ln.setAttribute(\"x2\",x2.toFixed(1));ln.setAttribute(\"y2\",y2.toFixed(1));\n      ln.setAttribute(\"opacity\", i%5===0 ? \"0.9\":\"0.45\");\n      g.appendChild(ln);\n    }\n  })();\n\n  // ---- drag interaction (vertical drag = value) ----\n  function attach(name, elId){\n    var el=document.getElementById(elId);\n    if(!el) return;\n    var dragging=false, startY=0, startVal=0;\n\n    function down(e){\n      dragging=true; el.classList.add(\"drag\");\n      startY = (e.touches?e.touches[0].clientY:e.clientY);\n      startVal = P[name].val;\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move);\n      window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false});\n      window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=startY-y;\n      var span = e.shiftKey ? 600 : 220; // shift = fine\n      var v=startVal + dy/span;\n      v = v<0?0:(v>1?1:v);\n      P[name].val=v; commit(name);\n      e.preventDefault();\n    }\n    function up(){\n      dragging=false; el.classList.remove(\"drag\");\n      window.removeEventListener(\"mousemove\",move);\n      window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move);\n      window.removeEventListener(\"touchend\",up);\n    }\n    el.addEventListener(\"mousedown\",down);\n    el.addEventListener(\"touchstart\",down,{passive:false});\n    // double-click = reset to default\n    el.addEventListener(\"dblclick\",function(){ P[name].val=P[name].def; commit(name); });\n    // wheel = fine adjust\n    el.addEventListener(\"wheel\",function(e){\n      var v=P[name].val - (e.deltaY>0?0.02:-0.02);\n      v=v<0?0:(v>1?1:v); P[name].val=v; commit(name); e.preventDefault();\n    },{passive:false});\n    // keyboard\n    el.addEventListener(\"keydown\",function(e){\n      var step=(e.shiftKey?0.01:0.05),d=0;\n      if(e.key===\"ArrowUp\"||e.key===\"ArrowRight\")d=step;\n      else if(e.key===\"ArrowDown\"||e.key===\"ArrowLeft\")d=-step;\n      else return;\n      var v=P[name].val+d; v=v<0?0:(v>1?1:v); P[name].val=v; commit(name); e.preventDefault();\n    });\n  }\n\n  // ---- animated scope: asymmetric soft-clip waveform ----\n  var wave=document.getElementById(\"wave\");\n  var wfill=document.getElementById(\"wfill\");\n  var W=340,H=96,MID=48,phase=0;\n\n  function tanh(x){ var e=Math.exp(2*x); return (e-1)/(e+1); }\n\n  function drawScope(){\n    var drive=P.drive.val, tone=P.tone.val, level=P.level.val, mix=P.mix.val;\n    var gain=1 + drive*drive*9;          // visual gain\n    var bias=0.18 + drive*0.4;           // asymmetry grows with drive\n    var amp=(0.30 + level*0.55)*36;      // vertical amplitude\n    var bright=0.4 + tone*0.6;           // tone -> harmonic sharpness\n    var d=\"M0 \"+MID, fill=\"M0 \"+MID;\n    var N=68;\n    for(var i=0;i<=N;i++){\n      var x=i/N*W;\n      var t=i/N*Math.PI*2*2 + phase;     // two cycles\n      var s=Math.sin(t) + 0.18*bright*Math.sin(3*t);\n      // asymmetric clip: bias pushes one half harder\n      var y=tanh(s*gain + bias) - tanh(bias); // remove DC offset\n      // blend dry (clean sine) by mix\n      var dry=Math.sin(t)*0.6;\n      y = y*mix + dry*(1-mix);\n      var py=MID - y*amp;\n      d += \" L\"+x.toFixed(1)+\" \"+py.toFixed(1);\n      fill += \" L\"+x.toFixed(1)+\" \"+py.toFixed(1);\n    }\n    fill += \" L\"+W+\" \"+MID+\" Z\";\n    wave.setAttribute(\"d\",d);\n    wfill.setAttribute(\"d\",fill);\n    phase += 0.045 + drive*0.06;\n    requestAnimationFrame(drawScope);\n  }\n\n  // ---- boot ----\n  function boot(){\n    attach(\"drive\",\"k-drive\");\n    attach(\"tone\",\"k-tone\");\n    attach(\"level\",\"k-level\");\n    attach(\"mix\",\"k-mix\");\n    for(var k in P){ if(P.hasOwnProperty(k)){ P[k].val=P[k].def; commit(k); } }\n    requestAnimationFrame(drawScope);\n  }\n\n  if(window.vstai && typeof window.vstai.onReady===\"function\"){\n    window.vstai.onReady(boot);\n  }else{\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SWEET DRIVE — warm ASYMMETRIC soft-clip overdrive (SD-1 lineage)\n//  A boutique-pedal break-up: the input is band-limited to clean the low\n//  end, then driven into an ASYMMETRIC soft-clipper. A small DC bias is\n//  added before the waveshaper so the positive and negative halves clip\n//  by different amounts — one half stays rounder than the other. That\n//  asymmetry generates EVEN harmonics for a sweeter, slightly fatter\n//  break-up, sitting over a gentle mid-hump. A post tone low-pass shapes\n//  brightness; output level and dry/wet mix finish the chain.\n//  Pure algorithm, no samples, no imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst hpState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-clip LP (for HP)\nconst midState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-clip band-pass-ish state (mid-hump)\nconst toneState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone LP\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post-clip DC blocker LP\nconst envState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // touch-sensitivity envelope\n\nconst P_DRIVE: i32 = 0;  // 0..1 -> gain 1..36\nconst P_TONE:  i32 = 1;  // 0..1 -> post LP 700..6500 Hz\nconst P_LEVEL: i32 = 2;  // 0..1 -> 0..1.2 output\nconst P_MIX:   i32 = 3;  // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    hpState[c] = 0.0; midState[c] = 0.0; toneState[c] = 0.0; dcState[c] = 0.0; envState[c] = 0.0;\n  }\n  params[P_DRIVE] = 0.5; params[P_TONE] = 0.5; params[P_LEVEL] = 0.6; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Asymmetric soft clip via tanh on a biased signal. The bias shifts the\n// waveshaper's operating point so the positive lobe saturates harder than\n// the negative one (or vice-versa), producing even harmonics. We subtract\n// the shaped bias (DC) afterwards so static offset is removed but the\n// dynamic asymmetry stays.\n@inline function asymClip(x: f32, bias: f32): f32 {\n  return f32(Mathf.tanh(x + bias));\n}\n\nexport function process(n: i32): void {\n  const driveN: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.2;\n  const mix:    f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Drive: clean -> singing overdrive. Squared curve for musical taper.\n  const drive: f32 = 1.0 + driveN * driveN * 35.0;\n\n  // Pre-clip high-pass corner ~110 Hz (clean low end -> tighter mid-hump).\n  const cHp: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 110.0 / sampleRate));\n  // Mild mid-hump: a gentle resonant emphasis around ~720 Hz applied to the\n  // high-passed signal before clipping (extra weight in the mids).\n  const cMid: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 720.0 / sampleRate));\n  // Post tone low-pass 700..6500 Hz.\n  const toneHz: f32 = 700.0 + toneN * toneN * 5800.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * toneHz / sampleRate));\n  // Slow DC blocker (~12 Hz) to strip the static bias offset after clipping.\n  const cDc: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 12.0 / sampleRate));\n  // Touch envelope follower coefficient (~30 ms).\n  const cEnv: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 5.3 / sampleRate));\n\n  // Asymmetry bias grows a little with drive: harder you push, sweeter the\n  // even-harmonic break-up. Bounded so it never collapses the waveform.\n  const bias: f32 = 0.18 + driveN * 0.22;\n\n  // Output compensation so Drive sings rather than just getting louder.\n  const comp: f32 = 1.7 / f32(Mathf.sqrt(drive));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let hp: f32  = hpState[c];\n    let md: f32  = midState[c];\n    let tn: f32  = toneState[c];\n    let dc: f32  = dcState[c];\n    let env: f32 = envState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // high-pass: remove sub-bass before clipping\n      hp = hp + cHp * (x - hp);\n      const hpd: f32 = x - hp;\n\n      // mild mid emphasis: blend the band toward 720 Hz back in\n      md = md + cMid * (hpd - md);\n      const shaped: f32 = hpd + (md * 0.45);\n\n      // touch sensitivity: envelope scales effective drive a touch so the\n      // break-up responds to playing dynamics (amp-like).\n      const rect: f32 = shaped < 0.0 ? -shaped : shaped;\n      env = env + cEnv * (rect - env);\n      const touch: f32 = 0.85 + env * 0.6; // louder input pushes harder\n\n      // asymmetric soft clip\n      const pre: f32 = shaped * drive * touch;\n      const clipped: f32 = asymClip(pre, bias);\n\n      // DC blocker: remove static offset from the bias, keep dynamic asym\n      dc = dc + cDc * (clipped - dc);\n      const noDc: f32 = clipped - dc;\n\n      const driven: f32 = noDc * comp;\n\n      // post tone low-pass\n      tn = tn + cTone * (driven - tn);\n\n      const wet: f32 = tn * level;\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    hpState[c] = hp; midState[c] = md; toneState[c] = tn; dcState[c] = dc; envState[c] = env;\n  }\n}\n",
  "publishedAt": 1751000119000
}