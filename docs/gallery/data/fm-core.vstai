  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>FM Core</title>\n<style>\n  :root{ --acc:#a07cff; --acc2:#c8ff5a; --bg0:#0a0713; --bg1:#150f26; --ink:#efeafb; --dim:#8478a4; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#241a44 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#181130,#0a0713); border:1px solid rgba(160,124,255,.24); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(235,225,255,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:112px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#120c24,#0a0713); border:1px solid rgba(160,124,255,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(222,214,245,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(160,124,255,.6)); }\n  .pcap{ fill:#100a20; stroke:rgba(160,124,255,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(160,124,255,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(160,124,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">FM&nbsp;CORE</span><span class=\"sub\">two-operator fm</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">OPERATORS</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Ratio\",idx:0,def:0.28},{name:\"Index\",idx:1,def:0.4},{name:\"Idx Env\",idx:2,def:0.6},{name:\"Feedbk\",idx:3,def:0.15},{name:\"Decay\",idx:4,def:0.55},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#a07cff\"/><stop offset=\"1\" stop-color=\"#c8ff5a\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=(p.idx===0)?(Math.round((0.5+v*6.5)*2)/2).toFixed(1)+\":1\":Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function box(x,y,w,h,label,glow,col){ ctx.strokeStyle=col; ctx.lineWidth=1.5; ctx.globalAlpha=0.5+glow*0.5;\n    ctx.shadowColor=col; ctx.shadowBlur=glow*10; ctx.strokeRect(x,y,w,h); ctx.shadowBlur=0;\n    ctx.fillStyle=col; ctx.font=\"bold 10px Inter,sans-serif\"; ctx.textAlign=\"center\"; ctx.textBaseline=\"middle\"; ctx.fillText(label,x+w/2,y+h/2); ctx.globalAlpha=1; ctx.textAlign=\"left\"; ctx.textBaseline=\"alphabetic\"; }\n  function frame(ts){ ctx.clearRect(0,0,W,H); var ratio=vals[0], index=vals[1], ienv=vals[2], fb=vals[3];\n    // decaying index env cycle (loops every ~1.6s) for the animation\n    var cyc=(ts/1600)%1; var idxEnv=Math.exp(-cyc*(1+ienv*4)); var effIdx=index*(1-ienv+ienv*idxEnv)*6;\n    // left: operator diagram\n    var bx=20, bw=68, bh=28;\n    box(bx, 16, bw, bh, \"MOD\", 0.3+effIdx/6*0.7, \"#a07cff\");\n    box(bx, 66, bw, bh, \"CAR\", 0.6, \"#c8ff5a\");\n    // MOD -> CAR arrow\n    ctx.strokeStyle=\"rgba(200,255,90,0.6)\"; ctx.lineWidth=1.5; ctx.beginPath(); ctx.moveTo(bx+bw/2,16+bh); ctx.lineTo(bx+bw/2,66); ctx.stroke();\n    ctx.beginPath(); ctx.moveTo(bx+bw/2-3,60); ctx.lineTo(bx+bw/2+3,60); ctx.lineTo(bx+bw/2,66); ctx.closePath(); ctx.fillStyle=\"rgba(200,255,90,0.7)\"; ctx.fill();\n    // feedback arc on MOD\n    if(fb>0.02){ ctx.strokeStyle=\"rgba(160,124,255,\"+(0.3+fb*0.6)+\")\"; ctx.lineWidth=1.4; ctx.beginPath(); ctx.arc(bx+bw+6,30,10,-Math.PI*0.6,Math.PI*0.6); ctx.stroke(); }\n    // right: live FM waveform\n    var sx=120, sw=W-12-sx, mid=H*0.5;\n    ctx.fillStyle=\"rgba(160,124,255,0.4)\"; ctx.font=\"8px Inter,sans-serif\"; ctx.fillText(\"FM OUTPUT\",sx,14);\n    var rq=Math.round((0.5+ratio*6.5)*2)/2;\n    ctx.beginPath();\n    for(var x=0;x<=sw;x+=1.5){ var t=x/sw; var ph=t*4+ts/500; var m=Math.sin((ph*rq+fb*0.0)*6.2831853+fb*1.2*Math.sin(ph*rq*6.2831853));\n      var c=Math.sin(ph*6.2831853+effIdx*m); ctx.lineTo(sx+x, mid - c*(H*0.34)); }\n    var grd=ctx.createLinearGradient(sx,0,sx+sw,0); grd.addColorStop(0,\"#a07cff\"); grd.addColorStop(1,\"#c8ff5a\");\n    ctx.strokeStyle=grd; ctx.lineWidth=1.8; ctx.shadowColor=\"#a07cff\"; ctx.shadowBlur=6; ctx.stroke(); ctx.shadowBlur=0;\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  FM CORE — a clean two-operator FM voice (the textbook Chowning\n//  algorithm). One modulator phase-modulates one carrier; a RATIO sets\n//  the modulator:carrier frequency relationship, INDEX sets the FM depth,\n//  and the signature INDEX ENV makes that depth decay over each note so\n//  the tone starts bright and bell-like then settles — the classic FM\n//  movement on a single held key. Operator FEEDBACK adds extra harmonics.\n//  8-voice poly. Controls: Ratio, Index, Index Env, Feedback, Decay, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\nconst TAU: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vCar: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vMod: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFb:  StaticArray<f32> = new StaticArray<f32>(NVOX);   // last modulator output (feedback)\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vIEnv:StaticArray<f32> = new StaticArray<f32>(NVOX);   // index env (1 -> 0)\nconst vSt:  StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq:StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote:StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_RATIO: i32 = 0; const P_INDEX: i32 = 1; const P_IENV: i32 = 2; const P_FB: i32 = 3; const P_DECAY: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vCar[i] = 0.0; vMod[i] = 0.0; vFb[i] = 0.0; vAmp[i] = 0.0; vIEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vNote[i] = -1; }\n  params[P_RATIO] = 0.28; params[P_INDEX] = 0.4; params[P_IENV] = 0.6; params[P_FB] = 0.15; params[P_DECAY] = 0.55; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vCar[slot] = 0.0; vMod[slot] = 0.0; vFb[slot] = 0.0; vAmp[slot] = 0.0; vIEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0); vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const ratioN: f32 = clampf(params[P_RATIO], 0.0, 1.0);\n  const indexN: f32 = clampf(params[P_INDEX], 0.0, 1.0);\n  const ienvN: f32  = clampf(params[P_IENV], 0.0, 1.0);\n  const fbN: f32    = clampf(params[P_FB], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // quantise ratio to musical half-integer steps (0.5 .. 7.0)\n  const ratio: f32 = f32(i32((0.5 + ratioN * 6.5) * 2.0 + 0.5)) * 0.5;\n  const index: f32 = indexN * 6.0;                       // max FM index\n  const fb: f32 = fbN * 1.2;\n  const atkInc: f32 = 1.0 / (0.004 * sampleRate);\n  const decT: f32 = 0.08 + decayN * 2.4;\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / (decT * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.3 * sampleRate)));\n  const ienvCoef: f32 = f32(Mathf.exp(-1.0 / ((0.06 + (1.0 - ienvN) * 1.5) * sampleRate)));  // env speed\n  const out: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] >= 1.0) { vAmp[s] = 1.0; vSt[s] = 3; } }\n      else if (vSt[s] == 3) { vAmp[s] *= decCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      vIEnv[s] *= ienvCoef;\n      const effIndex: f32 = index * (1.0 - ienvN + ienvN * vIEnv[s]);\n      // modulator with feedback\n      let mp: f32 = vMod[s] + (fr * ratio) / sampleRate; if (mp >= 1.0) mp -= 1.0; vMod[s] = mp;\n      const modOut: f32 = f32(Mathf.sin(mp * TAU + fb * vFb[s]));\n      vFb[s] = modOut;\n      // carrier phase-modulated by modulator\n      let cp: f32 = vCar[s] + fr / sampleRate; if (cp >= 1.0) cp -= 1.0; vCar[s] = cp;\n      const car: f32 = f32(Mathf.sin(cp * TAU + effIndex * modOut));\n      mix += car * vAmp[s] * vVel[s];\n    }\n    let o: f32 = mix * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751304200000
}