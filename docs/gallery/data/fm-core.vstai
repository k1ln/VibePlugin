      "name": "Ratio",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.28
    },
    {
      "name": "Index",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Index Env",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
