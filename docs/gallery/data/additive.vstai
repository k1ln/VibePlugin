{
  "format": 1,
  "name": "Additive",
  "isInstrument": true,
  "explanation": "A polyphonic additive (Fourier) synthesizer with eight independent voices. Each voice sums up to 32 sine harmonics whose amplitudes follow a sculptable spectral shape: an Odd/Even partial balance (square-hollow vs. full saw-like timbres), a Brightness spectral tilt, and a Spectral Decay that lets higher harmonics fade faster than the fundamental over the life of the note. An amplitude Attack/Release contour gates each voice and chords ring with independent decays. Controls: Odd, Even, Brightness, Spectral Decay, Attack, Release and Level.",
  "params": [
    {
      "name": "Odd",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.85
    },
    {
      "name": "Even",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Brightness",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Spectral Decay",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Additive</title>\n<style>\n  :root{\n    --accent:#54d1ff;\n    --accent2:#b0e0ff;\n    --bg:#04080d;\n    --panel:#0a131c;\n    --grid:#0e2230;\n    --ink:#dff3ff;\n    --dim:#5b7b8c;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    background:\n      radial-gradient(1200px 600px at 70% -10%, rgba(84,209,255,.10), transparent 60%),\n      radial-gradient(900px 500px at -10% 120%, rgba(176,224,255,.07), transparent 55%),\n      var(--bg);\n    color:var(--ink);\n    font-family:\"SF Mono\",ui-monospace,\"Roboto Mono\",Menlo,Consolas,monospace;\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    height:100%;\n  }\n  .unit{\n    width:760px;max-width:96vw;\n    border:1px solid #11303f;\n    border-radius:18px;\n    background:linear-gradient(180deg,#08121b,#050b12);\n    box-shadow:0 30px 80px rgba(0,0,0,.7), inset 0 1px 0 rgba(176,224,255,.06);\n    padding:20px 22px 22px;\n    position:relative;\n    overflow:hidden;\n  }\n  /* faint moving scan sheen */\n  .unit::before{\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(115deg,transparent 40%,rgba(84,209,255,.05) 50%,transparent 60%);\n    background-size:300% 300%;\n    animation:sheen 9s linear infinite;\n  }\n  @keyframes sheen{0%{background-position:120% 0}100%{background-position:-120% 0}}\n\n  header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;position:relative;z-index:2;}\n  .brand{display:flex;align-items:center;gap:11px;}\n  .logo{\n    width:30px;height:30px;border-radius:8px;\n    border:1px solid rgba(84,209,255,.5);\n    display:grid;place-items:center;\n    background:radial-gradient(circle at 50% 30%,rgba(84,209,255,.25),transparent 70%);\n  }\n  .logo span{width:3px;height:16px;background:var(--accent);border-radius:2px;box-shadow:0 0 8px var(--accent);animation:pulse 1.6s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{transform:scaleY(.5);opacity:.6}50%{transform:scaleY(1);opacity:1}}\n  .title h1{font-size:17px;letter-spacing:3px;font-weight:600;}\n  .title small{font-size:9.5px;letter-spacing:2.5px;color:var(--dim);text-transform:uppercase;}\n  .badge{font-size:9px;letter-spacing:2px;color:var(--accent2);border:1px solid #163a4c;border-radius:20px;padding:5px 11px;text-transform:uppercase;}\n\n  .scope-wrap{\n    position:relative;z-index:2;\n    border:1px solid var(--grid);border-radius:12px;\n    background:linear-gradient(180deg,#061018,#040a10);\n    padding:8px 10px 4px;margin-bottom:14px;\n    overflow:hidden;\n  }\n  .scope-wrap .tag{position:absolute;top:7px;left:11px;font-size:8.5px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;z-index:3;}\n  svg{display:block;width:100%;}\n\n  .row{display:grid;grid-template-columns:1fr 300px;gap:16px;position:relative;z-index:2;}\n  .card{border:1px solid var(--grid);border-radius:12px;background:linear-gradient(180deg,#08121a,#050c13);padding:11px 12px;}\n  .card h2{font-size:9px;letter-spacing:2.5px;color:var(--dim);text-transform:uppercase;margin-bottom:9px;display:flex;justify-content:space-between;}\n\n  /* harmonic bars */\n  .bars{display:flex;align-items:flex-end;gap:4px;height:118px;}\n  .bar{\n    flex:1;position:relative;display:flex;flex-direction:column;justify-content:flex-end;\n    height:100%;border-radius:3px 3px 0 0;cursor:default;\n  }\n  .bar i{\n    display:block;width:100%;border-radius:3px 3px 0 0;\n    background:linear-gradient(180deg,var(--accent),#1d7aa8);\n    box-shadow:0 0 7px rgba(84,209,255,.45);\n    transition:height .12s cubic-bezier(.2,.8,.2,1),background .2s;\n  }\n  .bar.even i{background:linear-gradient(180deg,var(--accent2),#3a6f93);}\n  .bar:hover i{filter:brightness(1.35);}\n  .bar b{position:absolute;bottom:-13px;left:0;right:0;text-align:center;font-size:7px;color:var(--dim);}\n\n  /* knobs */\n  .knobs{display:grid;grid-template-columns:repeat(4,1fr);gap:10px 6px;}\n  .knob{display:flex;flex-direction:column;align-items:center;gap:5px;}\n  .dial{\n    width:52px;height:52px;border-radius:50%;position:relative;cursor:ns-resize;\n    background:radial-gradient(circle at 50% 35%,#15303f,#091820);\n    border:1px solid #1c4256;\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.6), 0 0 0 1px rgba(84,209,255,.06);\n    touch-action:none;\n  }\n  .dial::after{\n    content:\"\";position:absolute;inset:6px;border-radius:50%;\n    background:conic-gradient(from -135deg,var(--accent) var(--deg,0deg),#0c1c26 0);\n    -webkit-mask:radial-gradient(circle,transparent 56%,#000 57%);\n    mask:radial-gradient(circle,transparent 56%,#000 57%);\n    opacity:.9;\n  }\n  .dial .ptr{\n    position:absolute;left:50%;top:50%;width:2px;height:18px;\n    background:var(--accent2);border-radius:2px;transform-origin:50% 100%;\n    transform:translate(-50%,-100%) rotate(var(--rot,0deg));\n    box-shadow:0 0 6px var(--accent);\n  }\n  .dial:hover{border-color:var(--accent);}\n  .knob label{font-size:8.5px;letter-spacing:1.5px;color:var(--dim);text-transform:uppercase;text-align:center;}\n  .knob .val{font-size:10px;color:var(--accent2);letter-spacing:.5px;font-variant-numeric:tabular-nums;}\n\n  .foot{margin-top:13px;display:flex;justify-content:space-between;align-items:center;font-size:8px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;position:relative;z-index:2;}\n  .dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);box-shadow:0 0 7px var(--accent);animation:blink 2s ease-in-out infinite;margin-right:6px;vertical-align:middle;}\n  @keyframes blink{0%,100%{opacity:.35}50%{opacity:1}}\n</style>\n</head>\n<body>\n<div class=\"unit\">\n  <header>\n    <div class=\"brand\">\n      <div class=\"logo\"><span></span></div>\n      <div class=\"title\"><h1>ADDITIVE</h1><small>Fourier Voice Engine</small></div>\n    </div>\n    <div class=\"badge\">32 partials · 8 voices</div>\n  </header>\n\n  <div class=\"scope-wrap\">\n    <div class=\"tag\">Summed Waveform</div>\n    <svg id=\"scope\" viewBox=\"0 0 720 120\" preserveAspectRatio=\"none\">\n      <defs>\n        <linearGradient id=\"wf\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0\" stop-color=\"#b0e0ff\"/>\n          <stop offset=\"1\" stop-color=\"#54d1ff\"/>\n        </linearGradient>\n        <linearGradient id=\"fill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0\" stop-color=\"rgba(84,209,255,.28)\"/>\n          <stop offset=\"1\" stop-color=\"rgba(84,209,255,0)\"/>\n        </linearGradient>\n      </defs>\n      <line x1=\"0\" y1=\"60\" x2=\"720\" y2=\"60\" stroke=\"#0e2230\" stroke-width=\"1\"/>\n      <path id=\"wfFill\" fill=\"url(#fill)\" d=\"\"/>\n      <path id=\"wfLine\" fill=\"none\" stroke=\"url(#wf)\" stroke-width=\"2\" d=\"\"/>\n    </svg>\n  </div>\n\n  <div class=\"row\">\n    <div class=\"card\">\n      <h2><span>Harmonic Spectrum</span><span id=\"specInfo\">live</span></h2>\n      <div class=\"bars\" id=\"bars\"></div>\n      <div style=\"height:14px\"></div>\n    </div>\n    <div class=\"card\">\n      <h2><span>Voice</span><span>drag · dbl-click reset</span></h2>\n      <div class=\"knobs\" id=\"knobs\"></div>\n    </div>\n  </div>\n\n  <div class=\"foot\">\n    <div><span class=\"dot\"></span>Additive Synthesis</div>\n    <div>cyan lab · #54d1ff</div>\n  </div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n  var NHARM = 16;\n\n  // ---- param model (index must match assembly.ts / spec.json) -------\n  var PARAMS = [\n    { name:\"Odd\",      idx:0, def:0.85 },\n    { name:\"Even\",     idx:1, def:0.45 },\n    { name:\"Bright\",   idx:2, def:0.55 },\n    { name:\"S.Decay\",  idx:3, def:0.40 },\n    { name:\"Attack\",   idx:4, def:0.04 },\n    { name:\"Release\",  idx:5, def:0.45 },\n    { name:\"Level\",    idx:6, def:0.60 }\n  ];\n  var val = PARAMS.map(function(p){ return p.def; });\n\n  function send(i,v){\n    if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n  function pushAll(){ for(var i=0;i<PARAMS.length;i++) send(PARAMS[i].idx, val[i]); }\n\n  // ---- harmonic bars (visual model of the spectral shape) ----------\n  var barsEl = document.getElementById(\"bars\");\n  var barInner = [];\n  for(var h=0; h<NHARM; h++){\n    var b = document.createElement(\"div\");\n    b.className = \"bar\" + (((h+1)&1)===0 ? \" even\" : \"\");\n    var inn = document.createElement(\"i\");\n    var lbl = document.createElement(\"b\");\n    lbl.textContent = (h+1);\n    b.appendChild(inn); b.appendChild(lbl);\n    barsEl.appendChild(b);\n    barInner.push(inn);\n  }\n\n  // compute the static harmonic amplitude profile exactly like the DSP\n  function harmAmps(){\n    var odd=val[0], even=val[1], bright=val[2];\n    var tilt = 0.35 + bright*1.35;\n    var a = new Array(NHARM), norm=0;\n    for(var h=0; h<NHARM; h++){\n      var hn=h+1, isOdd=(hn&1)===1;\n      var oe = isOdd?odd:even;\n      var roll = Math.pow(hn, -tilt);\n      var v = oe*roll;\n      a[h]=v; norm+=v;\n    }\n    var inv = norm>1e-4 ? 1/norm : 1;\n    for(var k=0;k<NHARM;k++) a[k]*=inv;\n    return a;\n  }\n\n  function drawBars(){\n    var a = harmAmps();\n    var mx = 0; for(var i=0;i<a.length;i++) mx=Math.max(mx,a[i]);\n    mx = mx>1e-4?mx:1;\n    for(var h=0;h<NHARM;h++){\n      var pct = Math.max(2, (a[h]/mx)*100);\n      barInner[h].style.height = pct + \"%\";\n    }\n    return a;\n  }\n\n  // ---- summed-waveform scope (animated) ----------------------------\n  var line = document.getElementById(\"wfLine\");\n  var fill = document.getElementById(\"wfFill\");\n  var W=720, H=120, MID=60, N=240;\n  var t=0;\n  function drawScope(amps){\n    var sdecay = val[3];\n    var d = \"M0 \"+MID, fd = \"M0 \"+H;\n    for(var x=0; x<=N; x++){\n      var ph = x/N; // one fundamental cycle across the view\n      var s=0;\n      for(var h=0;h<NHARM;h++){\n        var hn=h+1;\n        // animated spectral fade: highs shimmer with S.Decay\n        var fade = 1 - (hn/NHARM)*(1-sdecay)*0.5*(0.5+0.5*Math.sin(t*0.9 + hn*0.4));\n        s += amps[h]*fade*Math.sin(2*Math.PI*hn*ph);\n      }\n      var px = (x/N)*W;\n      var py = MID - s*48;\n      d  += \" L\"+px.toFixed(1)+\" \"+py.toFixed(1);\n      fd += \" L\"+px.toFixed(1)+\" \"+py.toFixed(1);\n    }\n    fd += \" L\"+W+\" \"+H+\" Z\";\n    line.setAttribute(\"d\", d);\n    fill.setAttribute(\"d\", fd);\n  }\n\n  var cachedAmps = null;\n  function refreshVisual(){ cachedAmps = drawBars(); }\n  function loop(){ t+=0.05; if(cachedAmps) drawScope(cachedAmps); requestAnimationFrame(loop); }\n\n  // ---- knobs --------------------------------------------------------\n  var knobsEl = document.getElementById(\"knobs\");\n  var dials = [];\n  PARAMS.forEach(function(p, i){\n    var wrap = document.createElement(\"div\"); wrap.className=\"knob\";\n    var dial = document.createElement(\"div\"); dial.className=\"dial\";\n    var ptr  = document.createElement(\"div\"); ptr.className=\"ptr\";\n    dial.appendChild(ptr);\n    var label= document.createElement(\"label\"); label.textContent=p.name;\n    var vEl  = document.createElement(\"div\"); vEl.className=\"val\";\n    wrap.appendChild(dial); wrap.appendChild(label); wrap.appendChild(vEl);\n    knobsEl.appendChild(wrap);\n\n    function paint(){\n      var v = val[i];\n      var deg = v*270;             // arc fill\n      var rot = -135 + v*270;      // pointer\n      dial.style.setProperty(\"--deg\", deg+\"deg\");\n      dial.style.setProperty(\"--rot\", rot+\"deg\");\n      vEl.textContent = v.toFixed(2);\n    }\n    function set(v, push){\n      v = v<0?0:(v>1?1:v);\n      val[i]=v; paint();\n      refreshVisual();\n      if(push!==false) send(p.idx, v);\n    }\n    dials.push({ paint:paint, set:set });\n\n    // vertical drag\n    var dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true;\n      startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startV=val[i];\n      e.preventDefault();\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      set(startV + (startY-y)/180);\n      e.preventDefault();\n    }\n    function up(){ dragging=false; }\n    dial.addEventListener(\"mousedown\", down);\n    dial.addEventListener(\"touchstart\", down, {passive:false});\n    window.addEventListener(\"mousemove\", move);\n    window.addEventListener(\"touchmove\", move, {passive:false});\n    window.addEventListener(\"mouseup\", up);\n    window.addEventListener(\"touchend\", up);\n    dial.addEventListener(\"dblclick\", function(){ set(p.def); });\n    dial.addEventListener(\"wheel\", function(e){ set(val[i] - e.deltaY*0.0008); e.preventDefault(); }, {passive:false});\n\n    paint();\n  });\n\n  // ---- boot ---------------------------------------------------------\n  function ready(){\n    for(var i=0;i<PARAMS.length;i++){ dials[i].paint(); }\n    refreshVisual();\n    pushAll();\n    loop();\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  ADDITIVE — a polyphonic additive (Fourier) synthesizer instrument.\n//  Each of eight independent voices sums up to 32 sine harmonics whose\n//  amplitudes are shaped by a reduced spectral-control set: an Odd/Even\n//  partial balance, a Brightness spectral tilt, and per-sample Spectral\n//  Decay so higher harmonics fade faster than the fundamental over the\n//  life of the note. An amplitude AR contour gates each voice; voices are\n//  allocated per noteId so chords ring independently. The harmonic basis\n//  is built once at init with a sine table (Mathf). No samples, no host\n//  imports, no allocation in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\nconst NUM_HARM: i32 = 32;          // partials summed per voice\nconst TABLE_SIZE: i32 = 4096;      // sine wavetable length\nconst TABLE_MASK: i32 = 4095;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// sine table built once at init with Mathf\nconst sineTab: StaticArray<f32> = new StaticArray<f32>(TABLE_SIZE);\n\n// per-block computed harmonic amplitude profile (shared by all voices)\nconst harmAmp: StaticArray<f32> = new StaticArray<f32>(NUM_HARM);\n// per-harmonic spectral-decay coefficient (higher harmonics decay faster)\nconst harmDecay: StaticArray<f32> = new StaticArray<f32>(NUM_HARM);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_ODD:    i32 = 0;  // 0..1  -> level of odd harmonics\nconst P_EVEN:   i32 = 1;  // 0..1  -> level of even harmonics\nconst P_BRIGHT: i32 = 2;  // 0..1  -> spectral tilt (rolloff vs flat)\nconst P_SDECAY: i32 = 3;  // 0..1  -> how fast harmonics fade over time\nconst P_ATTACK: i32 = 4;  // 0..1  -> seconds\nconst P_RELEASE:i32 = 5;  // 0..1  -> seconds\nconst P_LEVEL:  i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // fundamental Hz\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // fundamental phase 0..1\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // amplitude AR\nconst vStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\nconst vSpec:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // 1->0 spectral fade since noteOn\n\nlet ageCounter: i32 = 0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n\n  // build sine wavetable once\n  for (let i = 0; i < TABLE_SIZE; i++) {\n    const ph: f32 = f32(i) / f32(TABLE_SIZE);\n    sineTab[i] = f32(Mathf.sin(TWO_PI * ph));\n  }\n\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vPhase[v] = 0.0;\n    vEnv[v] = 0.0; vStage[v] = 0; vSpec[v] = 1.0;\n  }\n  ageCounter = 0;\n\n  params[P_ODD]     = 0.85;\n  params[P_EVEN]    = 0.45;\n  params[P_BRIGHT]  = 0.55;\n  params[P_SDECAY]  = 0.4;\n  params[P_ATTACK]  = 0.04;\n  params[P_RELEASE] = 0.45;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function sineLookup(phase01: f32): f32 {\n  // phase01 in [0,1)\n  let p: f32 = phase01 - f32(i32(phase01)); // wrap to fractional\n  if (p < 0.0) p += 1.0;\n  const fidx: f32 = p * f32(TABLE_SIZE);\n  const i0: i32 = i32(fidx) & TABLE_MASK;\n  const i1: i32 = (i0 + 1) & TABLE_MASK;\n  const frac: f32 = fidx - f32(i32(fidx));\n  const a: f32 = sineTab[i0];\n  const b: f32 = sineTab[i1];\n  return a + (b - a) * frac;\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vStage[slot]  = 1;     // attack\n  vPhase[slot]  = 0.0;\n  vSpec[slot]   = 1.0;   // full spectrum at onset, decays over time\n  vAge[slot]    = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3;     // release\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const oddN: f32    = clampf(params[P_ODD], 0.0, 1.0);\n  const evenN: f32   = clampf(params[P_EVEN], 0.0, 1.0);\n  const brightN: f32 = clampf(params[P_BRIGHT], 0.0, 1.0);\n  const sdecayN: f32 = clampf(params[P_SDECAY], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.5;\n  const relS: f32 = 0.01  + clampf(params[P_RELEASE], 0.0, 1.0) * 2.5;\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // Brightness as a spectral tilt: tilt<1 rolls off highs (warm),\n  // tilt>1 boosts highs (bright/buzzy). Centred so 0.5 ~= natural.\n  const tilt: f32 = 0.35 + brightN * 1.35;     // ~0.35 .. 1.7 exponent\n\n  // ---- build the static harmonic amplitude profile (shape) ----------\n  // h = 1 is the fundamental (treated as odd). Odd/Even sculpt timbre:\n  // square-ish (odd only) vs full (saw-ish) vs hollow.\n  let norm: f32 = 0.0;\n  for (let h = 0; h < NUM_HARM; h++) {\n    const hn: i32 = h + 1;                      // harmonic number 1..NUM_HARM\n    const isOdd: bool = (hn & 1) == 1;\n    const oe: f32 = isOdd ? oddN : evenN;\n    // 1/h falloff scaled by brightness tilt (smaller tilt -> faster rolloff)\n    const rolloff: f32 = f32(Mathf.pow(f32(hn), -tilt));\n    let a: f32 = oe * rolloff;\n    if (hn == 1) a = a * 1.0 + (1.0 - oddN) * 0.0; // fundamental always present via odd\n    harmAmp[h] = a;\n    norm += a;\n    // per-harmonic spectral-decay rate (per sample). Higher harmonics fade\n    // faster; SDecay scales the overall speed. h=0 (fundamental) is steady.\n    const baseRate: f32 = (sdecayN * sdecayN) * 12.0;  // 0..12 1/sec at top harmonic\n    const hRate: f32 = baseRate * (f32(hn) / f32(NUM_HARM));\n    harmDecay[h] = f32(Mathf.exp(-hRate / sr));        // per-sample multiplier\n  }\n  // normalize the static profile so total summed amplitude is bounded\n  const invNorm: f32 = norm > 0.0001 ? (1.0 / norm) : 1.0;\n  for (let h = 0; h < NUM_HARM; h++) harmAmp[h] = harmAmp[h] * invNorm;\n\n  // 8 voices summed -> headroom scaling. The normalized harmonic profile\n  // keeps a single voice modest, so lift the summed level into a usable\n  // range; the tanh below keeps big chords bounded < 1.\n  const voiceScale: f32 = 3.6;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR -----------------------------------------\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {                 // attack\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {          // sustain (held)\n        env = 1.0;\n      } else if (stg == 3) {          // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- spectral fade state (per voice, 1 -> ~0 over note) ----\n      // we advance one shared scalar and apply each harmonic's own coeff;\n      // implemented by storing a running fade per voice that we raise to\n      // the per-harmonic ratio. To stay alloc-free + cheap we track a\n      // single phase and recompute each harmonic's contribution below.\n      const specFade: f32 = vSpec[v];   // 0..1 master fade clock\n\n      // ---- additive oscillator: sum harmonics -------------------\n      const base: f32 = vFreq[v] / sr;          // fundamental increment (cyc/sample)\n      let ph: f32 = vPhase[v];\n\n      // advance fundamental phase\n      ph += base;\n      if (ph >= 1.0) ph -= f32(i32(ph));\n      vPhase[v] = ph;\n\n      let sample: f32 = 0.0;\n      // nyquist guard: skip harmonics above ~ sr/2\n      const maxHarmF: f32 = sr * 0.45;\n      for (let h = 0; h < NUM_HARM; h++) {\n        const hn: i32 = h + 1;\n        const hf: f32 = vFreq[v] * f32(hn);\n        if (hf >= maxHarmF) break;\n        let amp: f32 = harmAmp[h];\n        if (amp <= 0.0) continue;\n        // time-varying spectral decay: blend a per-harmonic fade so highs\n        // die faster. specFade is the master clock; weight by harmonic idx.\n        const hWeight: f32 = f32(hn) / f32(NUM_HARM);\n        const fade: f32 = 1.0 - hWeight * (1.0 - specFade);\n        amp *= (fade > 0.0 ? fade : 0.0);\n        sample += amp * sineLookup(ph * f32(hn));\n      }\n\n      // advance the master spectral-decay clock toward 0 (uses h=NUM_HARM rate)\n      let sf: f32 = specFade * harmDecay[NUM_HARM - 1];\n      vSpec[v] = sf;\n\n      outL += sample * env * vVel[v];\n    }\n\n    // sum + gentle soft-saturate to keep peaks bounded < 1\n    let mix: f32 = outL * voiceScale * level;\n    mix = f32(Mathf.tanh(mix * 1.1)) * 0.92;\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000084000
}