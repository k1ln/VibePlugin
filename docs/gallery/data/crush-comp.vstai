{
  "format": 1,
  "name": "Crush Comp",
  "isInstrument": false,
  "explanation": "An aggressive FET-style compressor with built-in distortion. A fast, stereo-linked peak detector drives a soft-knee, dB-domain gain computer whose ratio steps from a gentle 2:1 up to a slamming NUKE all-in extreme; attack and a program-dependent release shape the punch. A DIST stage layers asymmetric 2nd/3rd-harmonic FET grit that grows as the compressor works, then a dry/wet Mix blends it back. Controls: Threshold, Ratio (gentle to NUKE), Attack, Release, Dist and Mix.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 5,
      "default": 3
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Dist",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Crush Comp</title>\n<style>\n  :root {\n    --accent: #ff7a2a;\n    --accent2: #ffd23d;\n    --bg0: #14100d;\n    --bg1: #1d1712;\n    --panel: #241b14;\n    --panel2: #2c211a;\n    --ink: #f3e6d6;\n    --dim: #9a8674;\n    --line: #3a2c20;\n    --red: #ff3b30;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .rack {\n    width: 100%;\n    max-width: 640px;\n    border-radius: 16px;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a2018 0%, var(--bg1) 55%, var(--bg0) 100%);\n    border: 1px solid #4a382a;\n    box-shadow:\n      0 30px 70px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(255,210,160,.08),\n      inset 0 -2px 8px rgba(0,0,0,.5);\n    padding: 20px 22px 24px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* brushed-metal texture overlay */\n  .rack::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    background:\n      repeating-linear-gradient(90deg, rgba(255,255,255,.018) 0 2px, rgba(0,0,0,.02) 2px 4px);\n    mix-blend-mode: overlay;\n  }\n\n  /* rack ears / screws */\n  .screw {\n    position: absolute;\n    width: 12px;\n    height: 12px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #6a543f, #2a1f16 70%);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,.2), 0 1px 2px rgba(0,0,0,.6);\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute;\n    inset: 3px;\n    border-top: 1.5px solid rgba(0,0,0,.5);\n    transform: rotate(35deg);\n  }\n  .screw.tl { top: 10px; left: 10px; }\n  .screw.tr { top: 10px; right: 10px; }\n  .screw.bl { bottom: 10px; left: 10px; }\n  .screw.br { bottom: 10px; right: 10px; }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 0 14px 14px;\n    border-bottom: 1px solid var(--line);\n    position: relative;\n    z-index: 1;\n  }\n\n  .brand {\n    display: flex;\n    align-items: baseline;\n    gap: 10px;\n  }\n  .brand h1 {\n    margin: 0;\n    font-size: 22px;\n    font-weight: 800;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,.3);\n  }\n  .brand .sub {\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n\n  .power {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: 9px;\n    letter-spacing: 2px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n  .led {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 8px var(--accent), 0 0 16px rgba(255,122,42,.6);\n    animation: pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 1; box-shadow: 0 0 8px var(--accent), 0 0 16px rgba(255,122,42,.6); }\n    50% { opacity: .55; box-shadow: 0 0 4px var(--accent); }\n  }\n\n  /* ---- gain reduction meter ---- */\n  .meter-wrap {\n    position: relative;\n    z-index: 1;\n    margin: 18px 14px 10px;\n    padding: 12px 14px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, #0d0a07, #161009);\n    border: 1px solid #000;\n    box-shadow: inset 0 2px 10px rgba(0,0,0,.7), inset 0 0 0 1px rgba(255,150,60,.05);\n  }\n  .meter-top {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 8px;\n  }\n  .meter-label {\n    font-size: 9px;\n    letter-spacing: 2.5px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n  .gr-val {\n    font-variant-numeric: tabular-nums;\n    font-size: 13px;\n    font-weight: 700;\n    color: var(--accent2);\n    letter-spacing: .5px;\n  }\n  .bar {\n    position: relative;\n    height: 16px;\n    border-radius: 4px;\n    background: #060403;\n    overflow: hidden;\n    box-shadow: inset 0 1px 3px rgba(0,0,0,.9);\n  }\n  /* the GR fill grows from the RIGHT (gain pulled down) */\n  .bar-fill {\n    position: absolute;\n    top: 0; right: 0; bottom: 0;\n    width: 0%;\n    background: linear-gradient(90deg, var(--accent2), var(--accent) 60%, var(--red));\n    box-shadow: 0 0 12px rgba(255,122,42,.7);\n    transition: width .04s linear;\n  }\n  .bar-ticks {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    pointer-events: none;\n  }\n  .bar-ticks span {\n    flex: 1;\n    border-right: 1px solid rgba(255,255,255,.06);\n  }\n\n  /* ---- controls grid ---- */\n  .controls {\n    position: relative;\n    z-index: 1;\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 16px 10px;\n    margin: 18px 8px 4px;\n  }\n\n  .cell {\n    background: linear-gradient(180deg, var(--panel2), var(--panel));\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 14px 8px 12px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    box-shadow: inset 0 1px 0 rgba(255,210,160,.06), 0 4px 10px rgba(0,0,0,.35);\n    transition: border-color .15s, box-shadow .15s;\n  }\n  .cell:hover {\n    border-color: #5a4330;\n  }\n  .cell.active {\n    border-color: var(--accent);\n    box-shadow: inset 0 1px 0 rgba(255,210,160,.06), 0 0 18px rgba(255,122,42,.25);\n  }\n\n  .knob {\n    position: relative;\n    width: 84px;\n    height: 84px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; }\n\n  .clabel {\n    font-size: 9.5px;\n    letter-spacing: 2px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n  .cval {\n    font-variant-numeric: tabular-nums;\n    font-size: 12px;\n    font-weight: 700;\n    color: var(--ink);\n    letter-spacing: .3px;\n    min-height: 14px;\n  }\n\n  /* ---- stepped ratio selector ---- */\n  .ratio-cell {\n    grid-column: span 1;\n    align-items: stretch;\n  }\n  .ratio-dial {\n    position: relative;\n    width: 100%;\n    cursor: ns-resize;\n    touch-action: none;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n    padding: 2px;\n  }\n  .rstep {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 1px;\n    padding: 3px 8px;\n    border-radius: 5px;\n    color: var(--dim);\n    background: rgba(0,0,0,.25);\n    border: 1px solid transparent;\n    transition: all .12s;\n  }\n  .rstep .dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: #4a382a;\n    box-shadow: inset 0 1px 1px rgba(0,0,0,.6);\n  }\n  .rstep.on {\n    color: #1a120a;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    border-color: var(--accent2);\n    box-shadow: 0 0 12px rgba(255,122,42,.6);\n  }\n  .rstep.on .dot {\n    background: #1a120a;\n    box-shadow: none;\n  }\n  .rstep.nuke.on {\n    background: linear-gradient(180deg, #ff6a3a, var(--red));\n    border-color: #ff5a4a;\n    box-shadow: 0 0 18px rgba(255,59,48,.8);\n    animation: nukeflash .5s steps(2) infinite;\n  }\n  @keyframes nukeflash {\n    0% { filter: brightness(1); }\n    50% { filter: brightness(1.35); }\n    100% { filter: brightness(1); }\n  }\n\n  /* ---- DIST harmonic readout ---- */\n  .dist-cell {\n    grid-column: span 2;\n    flex-direction: row;\n    align-items: center;\n    gap: 14px;\n    padding: 12px 16px;\n  }\n  .dist-knob-wrap {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n  .harm {\n    flex: 1;\n    height: 64px;\n    border-radius: 8px;\n    background: linear-gradient(180deg, #0d0a07, #161009);\n    border: 1px solid #000;\n    box-shadow: inset 0 2px 8px rgba(0,0,0,.7);\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-around;\n    padding: 6px 10px;\n    gap: 6px;\n  }\n  .harm .h {\n    flex: 1;\n    max-width: 22px;\n    border-radius: 3px 3px 0 0;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: 0 0 10px rgba(255,122,42,.5);\n    height: 6%;\n    transition: height .08s ease-out, opacity .08s;\n    align-self: flex-end;\n  }\n  .harm-label {\n    font-size: 8px;\n    letter-spacing: 2px;\n    color: var(--dim);\n    text-transform: uppercase;\n    writing-mode: vertical-rl;\n    text-orientation: mixed;\n  }\n\n  footer {\n    position: relative;\n    z-index: 1;\n    text-align: center;\n    margin-top: 16px;\n    font-size: 8.5px;\n    letter-spacing: 3px;\n    color: #6b574402;\n    color: var(--dim);\n    text-transform: uppercase;\n    opacity: .6;\n  }\n</style>\n</head>\n<body>\n  <div class=\"rack\">\n    <div class=\"screw tl\"></div><div class=\"screw tr\"></div>\n    <div class=\"screw bl\"></div><div class=\"screw br\"></div>\n\n    <header>\n      <div class=\"brand\">\n        <h1>Crush Comp</h1>\n        <span class=\"sub\">FET Slam &middot; Drive</span>\n      </div>\n      <div class=\"power\"><span class=\"led\"></span> On Air</div>\n    </header>\n\n    <div class=\"meter-wrap\">\n      <div class=\"meter-top\">\n        <span class=\"meter-label\">Gain Reduction</span>\n        <span class=\"gr-val\" id=\"grVal\">0.0 dB</span>\n      </div>\n      <div class=\"bar\">\n        <div class=\"bar-fill\" id=\"grFill\"></div>\n        <div class=\"bar-ticks\" id=\"grTicks\"></div>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <!-- Threshold -->\n      <div class=\"cell\" data-cell=\"0\">\n        <div class=\"knob\" data-param=\"0\"></div>\n        <div class=\"clabel\">Threshold</div>\n        <div class=\"cval\" id=\"v0\">—</div>\n      </div>\n\n      <!-- Ratio stepped selector -->\n      <div class=\"cell ratio-cell\" data-cell=\"1\">\n        <div class=\"clabel\">Ratio</div>\n        <div class=\"ratio-dial\" data-param=\"1\" id=\"ratioDial\"></div>\n        <div class=\"cval\" id=\"v1\">—</div>\n      </div>\n\n      <!-- Attack -->\n      <div class=\"cell\" data-cell=\"2\">\n        <div class=\"knob\" data-param=\"2\"></div>\n        <div class=\"clabel\">Attack</div>\n        <div class=\"cval\" id=\"v2\">—</div>\n      </div>\n\n      <!-- Release -->\n      <div class=\"cell\" data-cell=\"3\">\n        <div class=\"knob\" data-param=\"3\"></div>\n        <div class=\"clabel\">Release</div>\n        <div class=\"cval\" id=\"v3\">—</div>\n      </div>\n\n      <!-- Dist + harmonic readout -->\n      <div class=\"cell dist-cell active\" data-cell=\"4\">\n        <div class=\"dist-knob-wrap\">\n          <div class=\"knob\" data-param=\"4\"></div>\n          <div class=\"clabel\">Dist</div>\n          <div class=\"cval\" id=\"v4\">—</div>\n        </div>\n        <span class=\"harm-label\">Harmonics</span>\n        <div class=\"harm\" id=\"harm\">\n          <div class=\"h\"></div><div class=\"h\"></div><div class=\"h\"></div>\n          <div class=\"h\"></div><div class=\"h\"></div><div class=\"h\"></div>\n        </div>\n      </div>\n\n      <!-- Mix -->\n      <div class=\"cell\" data-cell=\"5\">\n        <div class=\"knob\" data-param=\"5\"></div>\n        <div class=\"clabel\">Mix</div>\n        <div class=\"cval\" id=\"v5\">—</div>\n      </div>\n    </div>\n\n    <footer>Crush Comp &middot; Aggressive Dynamics</footer>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  var ACCENT = \"#ff7a2a\";\n  var ACCENT2 = \"#ffd23d\";\n\n  // param definitions (index, default, formatter)\n  var RATIO_LABELS = [\"2:1\", \"4:1\", \"6:1\", \"10:1\", \"20:1\", \"NUKE\"];\n\n  var PARAMS = {\n    0: { def: 0.30, min: 0, max: 1, fmt: function (v) { return (-40 + v * 40).toFixed(1) + \" dB\"; } },\n    1: { def: 3,    min: 0, max: 5, step: 1, fmt: function (v) { return RATIO_LABELS[Math.round(v)]; } },\n    2: { def: 0.15, min: 0, max: 1, fmt: function (v) { return (0.05 + v * v * 29.95).toFixed(2) + \" ms\"; } },\n    3: { def: 0.30, min: 0, max: 1, fmt: function (v) { return Math.round(30 + v * v * 770) + \" ms\"; } },\n    4: { def: 0.35, min: 0, max: 1, fmt: function (v) { return Math.round(v * 100) + \" %\"; } },\n    5: { def: 1.0,  min: 0, max: 1, fmt: function (v) { return Math.round(v * 100) + \" %\"; } }\n  };\n\n  var state = {};\n  for (var k in PARAMS) { state[k] = PARAMS[k].def; }\n\n  function push(index, value) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  function setVal(index, value, fromUser) {\n    var p = PARAMS[index];\n    var v = Math.max(p.min, Math.min(p.max, value));\n    if (p.step) { v = Math.round(v); }\n    state[index] = v;\n    push(index, v);\n    var el = document.getElementById(\"v\" + index);\n    if (el) { el.textContent = p.fmt(v); }\n    if (index === 1) { renderRatio(); }\n    renderKnob(index);\n  }\n\n  // ===== KNOB rendering (SVG arc) =====\n  var SWEEP = 270;       // total degrees\n  var START = 135;       // start angle (deg), clockwise from +x\n\n  function knobSvg() {\n    return ''\n      + '<svg viewBox=\"0 0 100 100\">'\n      + '  <defs>'\n      + '    <linearGradient id=\"kbody\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">'\n      + '      <stop offset=\"0\" stop-color=\"#3a2c20\"/>'\n      + '      <stop offset=\"1\" stop-color=\"#1a120c\"/>'\n      + '    </linearGradient>'\n      + '    <radialGradient id=\"ktop\" cx=\"0.4\" cy=\"0.32\" r=\"0.8\">'\n      + '      <stop offset=\"0\" stop-color=\"#46342500\"/>'\n      + '      <stop offset=\"0\" stop-color=\"#4a3727\"/>'\n      + '      <stop offset=\"1\" stop-color=\"#241a12\"/>'\n      + '    </radialGradient>'\n      + '  </defs>'\n      + '  <circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"none\" stroke=\"#0a0705\" stroke-width=\"7\"/>'\n      + '  <path class=\"arc-bg\" d=\"\" fill=\"none\" stroke=\"#3a2c20\" stroke-width=\"6\" stroke-linecap=\"round\"/>'\n      + '  <path class=\"arc-fg\" d=\"\" fill=\"none\" stroke=\"' + ACCENT + '\" stroke-width=\"6\" stroke-linecap=\"round\"/>'\n      + '  <circle cx=\"50\" cy=\"50\" r=\"33\" fill=\"url(#kbody)\" stroke=\"#000\" stroke-width=\"1\"/>'\n      + '  <circle cx=\"50\" cy=\"50\" r=\"30\" fill=\"url(#ktop)\"/>'\n      + '  <line class=\"pointer\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"22\" stroke=\"' + ACCENT2 + '\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>'\n      + '  <circle cx=\"50\" cy=\"50\" r=\"3\" fill=\"#1a120c\" stroke=\"#000\"/>'\n      + '</svg>';\n  }\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(cx, cy, r, a0, a1) {\n    var p0 = polar(cx, cy, r, a0);\n    var p1 = polar(cx, cy, r, a1);\n    var large = (a1 - a0) % 360 > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2)\n      + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \"\n      + p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function renderKnob(index) {\n    var knob = document.querySelector('.knob[data-param=\"' + index + '\"]');\n    if (!knob) { return; }\n    var p = PARAMS[index];\n    var norm = (state[index] - p.min) / (p.max - p.min);\n    var a0 = START;\n    var aFull = START + SWEEP;\n    var aVal = START + SWEEP * norm;\n\n    var bg = knob.querySelector(\".arc-bg\");\n    var fg = knob.querySelector(\".arc-fg\");\n    var ptr = knob.querySelector(\".pointer\");\n    if (bg) { bg.setAttribute(\"d\", arcPath(50, 50, 40, a0, aFull)); }\n    if (fg) { fg.setAttribute(\"d\", norm > 0.001 ? arcPath(50, 50, 40, a0, aVal) : \"\"); }\n    if (ptr) {\n      var rot = -135 + 270 * norm;\n      ptr.setAttribute(\"transform\", \"rotate(\" + rot + \" 50 50)\");\n    }\n  }\n\n  function attachKnob(knob) {\n    var index = +knob.getAttribute(\"data-param\");\n    knob.innerHTML = knobSvg();\n    var cell = knob.closest(\".cell\");\n\n    var dragging = false;\n    var lastY = 0;\n\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      if (cell) { cell.classList.add(\"active\"); }\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) { return; }\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var p = PARAMS[index];\n      var range = p.max - p.min;\n      var sensitivity = e.shiftKey ? 600 : 180;\n      setVal(index, state[index] + (dy / sensitivity) * range, true);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      if (cell && index !== 4) { cell.classList.remove(\"active\"); }\n    }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    knob.addEventListener(\"dblclick\", function () {\n      setVal(index, PARAMS[index].def, true);\n    });\n    knob.addEventListener(\"wheel\", function (e) {\n      var p = PARAMS[index];\n      var range = p.max - p.min;\n      setVal(index, state[index] - (e.deltaY > 0 ? 1 : -1) * range * 0.02, true);\n      e.preventDefault();\n    }, { passive: false });\n  }\n\n  // ===== RATIO stepped selector =====\n  function buildRatio() {\n    var dial = document.getElementById(\"ratioDial\");\n    var html = \"\";\n    for (var i = RATIO_LABELS.length - 1; i >= 0; i--) {\n      var nuke = (i === 5) ? \" nuke\" : \"\";\n      html += '<div class=\"rstep' + nuke + '\" data-step=\"' + i + '\">'\n        + '<span>' + RATIO_LABELS[i] + '</span><span class=\"dot\"></span></div>';\n    }\n    dial.innerHTML = html;\n\n    Array.prototype.forEach.call(dial.querySelectorAll(\".rstep\"), function (el) {\n      el.addEventListener(\"click\", function () {\n        setVal(1, +el.getAttribute(\"data-step\"), true);\n      });\n    });\n\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      var cell = dial.closest(\".cell\");\n      if (cell) { cell.classList.add(\"active\"); }\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) { return; }\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      if (Math.abs(lastY - y) >= 22) {\n        var dir = lastY - y > 0 ? 1 : -1;\n        setVal(1, state[1] + dir, true);\n        lastY = y;\n      }\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      var cell = dial.closest(\".cell\");\n      if (cell) { cell.classList.remove(\"active\"); }\n    }\n    dial.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    dial.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n    dial.addEventListener(\"dblclick\", function () { setVal(1, PARAMS[1].def, true); });\n    dial.addEventListener(\"wheel\", function (e) {\n      setVal(1, state[1] + (e.deltaY > 0 ? -1 : 1), true);\n      e.preventDefault();\n    }, { passive: false });\n  }\n\n  function renderRatio() {\n    var sel = Math.round(state[1]);\n    Array.prototype.forEach.call(document.querySelectorAll(\".rstep\"), function (el) {\n      var s = +el.getAttribute(\"data-step\");\n      el.classList.toggle(\"on\", s === sel);\n    });\n  }\n\n  // ===== animated meter + harmonic readout =====\n  var grFill = document.getElementById(\"grFill\");\n  var grVal = document.getElementById(\"grVal\");\n  var harmBars = document.querySelectorAll(\"#harm .h\");\n\n  // simulated, eased gain-reduction display (driven by Threshold+Ratio)\n  var grDisp = 0;\n  var grTarget = 0;\n  var pumpPhase = 0;\n\n  function buildTicks() {\n    var t = document.getElementById(\"grTicks\");\n    var h = \"\";\n    for (var i = 0; i < 10; i++) { h += \"<span></span>\"; }\n    t.innerHTML = h;\n  }\n\n  function frame() {\n    if (!document.hidden) {\n      // estimate how hard the comp slams from Threshold + Ratio steps\n      var thr = state[0];               // 0=low thresh (more GR), 1=high\n      var ratioStep = Math.round(state[1]);\n      var ratioK = [0.35, 0.55, 0.7, 0.85, 0.95, 1.0][ratioStep];\n      var depth = (1 - thr) * ratioK;   // 0..1\n\n      // a pumping motion so the bar feels alive (fast slam, slower recover)\n      pumpPhase += 0.045 + state[2] * 0.04;\n      var pump = 0.5 + 0.5 * Math.sin(pumpPhase) * Math.sin(pumpPhase * 0.5);\n      grTarget = depth * (0.45 + 0.55 * pump) * 20; // up to ~20 dB\n\n      // fast attack toward target, slower release away (program feel)\n      var rate = grTarget > grDisp ? 0.6 : 0.06 + (1 - state[3]) * 0.12;\n      grDisp += (grTarget - grDisp) * rate;\n\n      var pct = Math.min(100, (grDisp / 20) * 100);\n      grFill.style.width = pct.toFixed(1) + \"%\";\n      grVal.textContent = \"-\" + grDisp.toFixed(1) + \" dB\";\n\n      // harmonic bars: DIST + current GR feed a decaying harmonic series\n      var dist = state[4];\n      var work = dist * (0.4 + grDisp / 20 * 0.6);\n      for (var i = 0; i < harmBars.length; i++) {\n        var decay = Math.pow(0.72, i);\n        var jitter = 0.85 + 0.15 * Math.sin(pumpPhase * (1.3 + i * 0.4));\n        var hh = Math.min(1, work * decay * jitter * 1.6);\n        harmBars[i].style.height = (6 + hh * 90).toFixed(0) + \"%\";\n        harmBars[i].style.opacity = (0.35 + hh * 0.65).toFixed(2);\n      }\n    }\n    requestAnimationFrame(frame);\n  }\n\n  // ===== init =====\n  function init() {\n    buildTicks();\n    buildRatio();\n    Array.prototype.forEach.call(document.querySelectorAll(\".knob\"), attachKnob);\n    for (var i = 0; i <= 5; i++) {\n      setVal(i, PARAMS[i].def, false);\n    }\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CRUSH COMP — an aggressive FET-style compressor with built-in\n//  distortion. A fast, stereo-linked peak detector drives a dB-domain\n//  gain computer with a soft knee and ratios stepping from a gentle 2:1\n//  up to a slamming \"NUKE\" all-buttons-in extreme. Attack/Release shape\n//  punch with a program-dependent release that lets go faster on busy\n//  material. A DIST stage adds asymmetric 2nd/3rd-harmonic FET grit that\n//  grows as the compressor works (more reduction -> more colour), then a\n//  dry/wet Mix blends it back. Punchy, gritty, in-your-face.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (shared across the stereo pair = stereo-linked)\nlet peakState: f32 = 0.0;  // smoothed peak detector level (linear)\nlet fastState: f32 = 0.0;  // very-fast follower, for program-dependent release\nlet grDb: f32 = 0.0;       // current gain reduction in dB (>= 0), smoothed\nlet dcL: f32 = 0.0;        // DC blocker state (asymmetric clip adds DC)\nlet dcR: f32 = 0.0;\nlet dcXL: f32 = 0.0;\nlet dcXR: f32 = 0.0;\n\nconst P_THRESH:  i32 = 0;  // 0..1 -> threshold  -40..0 dBFS  (low = more comp)\nconst P_RATIO:   i32 = 1;  // 0..5 discrete -> 2,4,6,10,20:1, NUKE\nconst P_ATTACK:  i32 = 2;  // 0..1 -> attack     0.05..30 ms\nconst P_RELEASE: i32 = 3;  // 0..1 -> release    30..800 ms (program-dependent)\nconst P_DIST:    i32 = 4;  // 0..1 -> harmonic drive amount\nconst P_MIX:     i32 = 5;  // 0..1 -> dry/wet\n\nconst KNEE_DB: f32 = 8.0;        // soft knee width (dB)\nconst LN10_20: f32 = 0.11512925; // ln(10)/20, for dB<->linear\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// linear amplitude -> dBFS (guarded), and back\n@inline function lin2db(x: f32): f32 {\n  const a: f32 = x < 1e-9 ? 1e-9 : x;\n  return f32(8.6858896 * Mathf.log(a)); // 20/ln(10) * ln(a)\n}\n@inline function db2lin(db: f32): f32 {\n  return f32(Mathf.exp(db * LN10_20));\n}\n\n// asymmetric tanh-ish saturator: stronger on the positive swing for a\n// dominant 2nd harmonic, with 3rd-harmonic odd grit underneath.\n@inline function fetSat(x: f32, drive: f32): f32 {\n  const d: f32 = 1.0 + drive * 9.0;            // 1..10\n  const bias: f32 = drive * 0.18;              // asymmetry -> 2nd harmonic\n  const a: f32 = (x + bias) * d;\n  // fast tanh approx (rational), bounded to ~[-1,1]\n  const a2: f32 = a * a;\n  const t: f32 = a * (27.0 + a2) / (27.0 + 9.0 * a2);\n  const tb2: f32 = bias * d;\n  const tb: f32 = tb2 * (27.0 + tb2 * tb2) / (27.0 + 9.0 * tb2 * tb2);\n  return f32((t - tb) / d);                    // remove bias DC, normalise gain\n}\n\n// ratio lookup for the stepped selector (last step = NUKE)\n@inline function ratioForStep(step: i32): f32 {\n  if (step <= 0) return 2.0;\n  if (step == 1) return 4.0;\n  if (step == 2) return 6.0;\n  if (step == 3) return 10.0;\n  if (step == 4) return 20.0;\n  return 60.0;                                  // NUKE — brutal limiting\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  peakState = 0.0;\n  fastState = 0.0;\n  grDb = 0.0;\n  dcL = 0.0; dcR = 0.0; dcXL = 0.0; dcXR = 0.0;\n  params[P_THRESH]  = 0.30; // ~ -28 dBFS — bites on the test bed\n  params[P_RATIO]   = 3.0;  // 10:1\n  params[P_ATTACK]  = 0.15; // fast\n  params[P_RELEASE] = 0.30; // medium\n  params[P_DIST]    = 0.35; // some grit\n  params[P_MIX]     = 1.0;  // fully wet\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function process(n: i32): void {\n  // ---- map params to engineering units ----\n  const tN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const threshDb: f32 = -40.0 + tN * 40.0;               // -40..0 dBFS\n\n  let step: i32 = i32(params[P_RATIO] + 0.5);\n  if (step < 0) step = 0;\n  if (step > 5) step = 5;\n  const ratio: f32 = ratioForStep(step);\n  const slope: f32 = 1.0 - 1.0 / ratio;                  // 0.5..~0.98\n\n  const aN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const atkMs: f32 = 0.05 + aN * aN * 29.95;             // 0.05..30 ms (curved)\n  const relN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const relMs: f32 = 30.0 + relN * relN * 770.0;         // 30..800 ms (curved)\n\n  // one-pole time-constant coefficients (per-sample) for the dB envelope\n  const atkCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (atkMs * 0.001 * sampleRate)));\n  const relCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (relMs * 0.001 * sampleRate)));\n\n  // peak detector smoothing (fast attack, short hold via release)\n  const detCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.001 * sampleRate)));     // ~1 ms\n  const fastCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.0001 * sampleRate)));   // ~0.1 ms\n\n  const distN: f32 = clampf(params[P_DIST], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // makeup compensates for the average reduction so NUKE/low-thresh stays usable\n  const makeup: f32 = db2lin(slope * 6.0 + distN * 3.0);\n\n  // DC blocker coefficient (~20 Hz)\n  const dcCoef: f32 = f32(1.0 - 2.0 * 3.14159265 * 20.0 / sampleRate);\n\n  const halfKnee: f32 = KNEE_DB * 0.5;\n\n  let pk: f32 = peakState;\n  let fast: f32 = fastState;\n  let gr: f32 = grDb;\n\n  const baseL: i32 = 0;\n  const baseR: i32 = MAX_FRAMES;\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    const xL: f32 = inBuf[baseL + f];\n    const xR: f32 = stereo ? inBuf[baseR + f] : xL;\n\n    // ---- stereo-linked peak detector ----\n    const aL: f32 = xL < 0.0 ? -xL : xL;\n    const aR: f32 = xR < 0.0 ? -xR : xR;\n    const inLevel: f32 = aL > aR ? aL : aR;\n\n    // smoothed peak (release-ish) and an ultra-fast follower\n    pk = pk + (inLevel > pk ? 1.0 : detCoef) * (inLevel - pk);\n    fast = fast + (inLevel > fast ? 1.0 : fastCoef) * (inLevel - fast);\n\n    // program dependence: when the fast follower sits well above the slow\n    // peak (busy/transient material) speed the release up.\n    const busy: f32 = fast > pk ? (fast - pk) : 0.0;\n    const progRel: f32 = relCoef + busy * relCoef * 6.0;\n\n    const detDb: f32 = lin2db(pk);\n\n    // ---- gain computer: soft-knee static curve -> target GR (dB) ----\n    const over: f32 = detDb - threshDb;\n    let targetGr: f32;\n    if (over <= -halfKnee) {\n      targetGr = 0.0;\n    } else if (over >= halfKnee) {\n      targetGr = slope * over;\n    } else {\n      const kt: f32 = over + halfKnee;          // 0..KNEE_DB\n      targetGr = slope * (kt * kt) / (2.0 * KNEE_DB);\n    }\n    if (targetGr < 0.0) targetGr = 0.0;\n\n    // ---- ballistics: attack down, program-dependent release up ----\n    const coef: f32 = targetGr > gr ? atkCoef : progRel;\n    gr = gr + coef * (targetGr - gr);\n    if (gr < 0.0) gr = 0.0;\n\n    const g: f32 = db2lin(-gr);\n\n    // FET grit scales with both the DIST control and how hard we're working\n    const driveAmt: f32 = clampf(distN * (0.35 + gr * 0.06), 0.0, 1.0);\n\n    // ---- left ----\n    let yL: f32 = xL * g;\n    yL = fetSat(yL, driveAmt);\n    // DC block\n    const dL: f32 = yL - dcXL + dcCoef * dcL;\n    dcXL = yL; dcL = dL;\n    yL = dL * makeup;\n    let wetL: f32 = clampf(yL, -1.2, 1.2);\n    outBuf[baseL + f] = xL * (1.0 - mix) + wetL * mix;\n\n    // ---- right ----\n    if (stereo) {\n      let yR: f32 = xR * g;\n      yR = fetSat(yR, driveAmt);\n      const dR: f32 = yR - dcXR + dcCoef * dcR;\n      dcXR = yR; dcR = dR;\n      yR = dR * makeup;\n      let wetR: f32 = clampf(yR, -1.2, 1.2);\n      outBuf[baseR + f] = xR * (1.0 - mix) + wetR * mix;\n    }\n  }\n\n  peakState = pk;\n  fastState = fast;\n  grDb = gr;\n}\n",
  "publishedAt": 1751000118000
}