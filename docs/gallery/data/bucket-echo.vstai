{
  "format": 1,
  "name": "Bucket Echo",
  "isInstrument": false,
  "explanation": "A warm analog bucket-brigade-style delay. A modulated, interpolated delay line feeds a bounded feedback path whose repeats grow progressively darker through an in-loop low-pass, while a slow wow/flutter LFO adds vintage pitch wander. Controls: Time, Feedback, Tone, Modulation and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.22
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Modulation",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --n0{syntax:'<number>';inherits:false;initial-value:0}\n@property --n1{syntax:'<number>';inherits:false;initial-value:0}\n@property --n2{syntax:'<number>';inherits:false;initial-value:0}\n@property --n3{syntax:'<number>';inherits:false;initial-value:0}\n@property --n4{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --ac:#ffa94d;        /* amber LED / warm accent */\n  --ac2:#ffd166;       /* hotter LED highlight   */\n  --teal:#0e3b3a;      /* enclosure teal         */\n  --teal-lo:#06201f;\n  --teal-hi:#1b5856;\n  --metal:#cdb27a;     /* brushed brass screws   */\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{margin:0;font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace;color:#dfeae6;\n  background:\n    radial-gradient(120% 90% at 50% -10%,#13343a 0%,#081417 60%,#03090b 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;overflow:hidden}\n\n/* ===================== ENCLOSURE ===================== */\n.pedal{position:relative;width:100%;max-width:560px;border-radius:20px;padding:0 0 18px;overflow:hidden;\n  background:\n    linear-gradient(155deg,var(--teal-hi) 0%,var(--teal) 30%,var(--teal-lo) 100%);\n  border:1px solid rgba(0,0,0,.55);\n  box-shadow:\n    0 36px 80px rgba(0,0,0,.65),\n    inset 0 2px 0 rgba(255,255,255,.12),\n    inset 0 -3px 12px rgba(0,0,0,.6),\n    inset 0 0 0 2px rgba(0,0,0,.35);\n  /* powder-coat micro-speckle */\n  background-image:\n    linear-gradient(155deg,var(--teal-hi) 0%,var(--teal) 30%,var(--teal-lo) 100%),\n    repeating-radial-gradient(circle at 20% 30%,rgba(255,255,255,.018) 0 1px,transparent 1px 3px);\n  background-blend-mode:overlay}\n/* brushed-metal sweep + faint sheen that drifts */\n.pedal::before{content:\"\";position:absolute;inset:0;z-index:0;pointer-events:none;border-radius:20px;\n  background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.07) 48%,transparent 62%);\n  background-size:300% 100%;animation:sheen 9s ease-in-out infinite}\n@keyframes sheen{0%{background-position:120% 0}55%,100%{background-position:-60% 0}}\n\n/* corner mounting screws */\n.screw{position:absolute;width:16px;height:16px;border-radius:50%;z-index:5;\n  background:radial-gradient(circle at 35% 30%,#f3e2b0,var(--metal) 55%,#5f4f2c 100%);\n  box-shadow:0 1px 2px rgba(0,0,0,.7),inset 0 0 0 1px rgba(0,0,0,.4)}\n.screw::after{content:\"\";position:absolute;inset:5px;border-radius:1px;background:rgba(0,0,0,.45);\n  transform:rotate(var(--r,40deg))}\n.screw.tl{top:10px;left:10px;--r:25deg}.screw.tr{top:10px;right:10px;--r:-15deg}\n.screw.bl{bottom:10px;left:10px;--r:65deg}.screw.br{bottom:10px;right:10px;--r:-40deg}\n\n/* ===================== HEADER PLATE ===================== */\n.plate{position:relative;z-index:2;margin:18px 22px 8px;padding:13px 16px;border-radius:12px;\n  background:linear-gradient(180deg,#04181a,#020c0d);\n  border:1px solid rgba(255,255,255,.06);\n  box-shadow:inset 0 2px 8px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.08);\n  display:flex;align-items:center;gap:12px}\n.pwr{position:relative;width:13px;height:13px;border-radius:50%;flex:none;\n  background:radial-gradient(circle at 40% 35%,#fff 0%,var(--ac2) 22%,var(--ac) 55%,#7a3d09 100%);\n  box-shadow:0 0 14px 2px var(--ac),0 0 3px #fff inset;animation:blink 1.7s steps(1,end) infinite}\n@keyframes blink{0%,62%{opacity:1;box-shadow:0 0 16px 3px var(--ac),0 0 3px #fff inset}\n  64%,70%{opacity:.35;box-shadow:0 0 4px var(--ac)}72%,100%{opacity:1;box-shadow:0 0 16px 3px var(--ac),0 0 3px #fff inset}}\n.tt{flex:1;min-width:0}\n.tt h1{margin:0;font-size:19px;font-weight:800;letter-spacing:.16em;line-height:1;\n  color:#f4ead2;text-shadow:0 1px 0 #000,0 0 16px rgba(255,169,77,.25)}\n.tt .sub{margin-top:3px;font-size:9px;letter-spacing:.42em;color:#7fae9f;text-transform:uppercase}\n.model{font-size:8.5px;letter-spacing:.18em;color:#9bd0c2;text-transform:uppercase;text-align:right;line-height:1.5;opacity:.8}\n\n/* ===================== BBD CHIP / ECHO TRACK ===================== */\n.track{position:relative;z-index:2;margin:6px 22px 4px;height:78px;border-radius:11px;overflow:hidden;\n  background:linear-gradient(180deg,#030f10,#01080a);\n  border:1px solid rgba(255,255,255,.05);\n  box-shadow:inset 0 3px 10px rgba(0,0,0,.8),inset 0 0 0 1px rgba(0,0,0,.5)}\n/* the chip body sits on the left */\n.chip{position:absolute;left:12px;top:50%;transform:translateY(-50%);width:74px;height:46px;border-radius:5px;z-index:3;\n  background:linear-gradient(160deg,#26282b,#0c0d0f);\n  border:1px solid #000;box-shadow:0 2px 5px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.06)}\n.chip .notch{position:absolute;top:50%;left:5px;width:8px;height:8px;border-radius:50%;transform:translateY(-50%);\n  background:radial-gradient(circle,#000,#1a1c1f);box-shadow:inset 0 0 3px #000}\n.chip .lbl{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\n  font-size:7.5px;letter-spacing:.12em;color:#6f7a7d;text-align:center;line-height:1.3}\n/* chip legs */\n.chip i{position:absolute;width:5px;height:5px;background:linear-gradient(#d8d2c0,#7c7565);border-radius:0 0 2px 2px}\n.chip i.t{top:-4px}.chip i.b{bottom:-4px;border-radius:2px 2px 0 0}\n.chip i:nth-child(odd){}\n/* the 8 BBD \"stage\" LEDs that the signal walks through */\n.stages{position:absolute;left:98px;right:14px;top:0;bottom:0;display:flex;align-items:center;gap:0;z-index:2}\n.stage{flex:1;height:100%;display:flex;align-items:center;justify-content:center;position:relative}\n.stage b{width:8px;height:8px;border-radius:50%;background:#0a2422;\n  box-shadow:inset 0 0 3px #000;transition:none}\n.stage.on b{background:radial-gradient(circle at 40% 35%,#fff,var(--ac2) 35%,var(--ac) 70%);\n  box-shadow:0 0 10px 2px var(--ac),0 0 16px var(--ac)}\n/* dashed signal path under the LEDs */\n.stages::before{content:\"\";position:absolute;left:0;right:0;top:50%;height:1px;transform:translateY(8px);\n  background:repeating-linear-gradient(90deg,rgba(127,174,159,.35) 0 4px,transparent 4px 9px)}\n/* the visual \"repeats\" — echo blips that drift right and fade */\n.echoes{position:absolute;left:96px;right:8px;top:0;bottom:0;z-index:1;pointer-events:none}\n.blip{position:absolute;top:50%;width:14px;height:14px;margin-top:-7px;border-radius:50%;\n  background:radial-gradient(circle,var(--ac) 0%,transparent 70%);opacity:0}\n\n/* ===================== KNOB DECK ===================== */\n.deck{position:relative;z-index:2;display:grid;grid-template-columns:repeat(5,1fr);gap:4px;\n  padding:16px 16px 4px;margin:0 6px}\n.cell{display:flex;flex-direction:column;align-items:center;gap:9px;padding:8px 2px 6px;border-radius:12px;\n  animation:rise .55s both;animation-delay:var(--d)}\n@keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}\n.cell:hover{background:rgba(255,255,255,.025)}\n\n/* the knob: chicken-head boutique pointer cap */\n.knob{position:relative;width:78px;height:78px;cursor:ns-resize;touch-action:none;user-select:none}\n/* outer chrome bezel + value arc */\n.knob .arc{position:absolute;inset:2px;border-radius:50%;\n  background:conic-gradient(from 220deg,\n    var(--ac) calc(var(--v)*280deg),\n    rgba(0,0,0,.45) calc(var(--v)*280deg) 280deg,\n    transparent 280deg);\n  filter:drop-shadow(0 0 calc(3px + var(--v)*8px) color-mix(in srgb,var(--ac) 70%,transparent));\n  -webkit-mask:radial-gradient(circle,transparent 32px,#000 33px);\n  mask:radial-gradient(circle,transparent 32px,#000 33px)}\n/* faint tick ring */\n.knob .ticks{position:absolute;inset:-3px;border-radius:50%;\n  background:repeating-conic-gradient(from 216deg,rgba(180,220,205,.32) 0 1deg,transparent 1deg 13.7deg);\n  -webkit-mask:radial-gradient(circle,transparent 39px,#000 40px,#000 42px,transparent 43px);\n  mask:radial-gradient(circle,transparent 39px,#000 40px,#000 42px,transparent 43px)}\n/* the rotating cap */\n.knob .cap{position:absolute;left:50%;top:50%;width:58px;height:58px;margin:-29px 0 0 -29px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 32%,#3a4a47 0%,#14201e 70%,#091211 100%);\n  box-shadow:\n    inset 0 3px 7px rgba(0,0,0,.7),\n    inset 0 -2px 0 rgba(255,255,255,.05),\n    0 2px 4px rgba(0,0,0,.6);\n  transform:rotate(calc((var(--v) - 0.5) * 280deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.knob .cap::before{content:\"\";position:absolute;left:50%;top:6px;width:4px;height:20px;margin-left:-2px;border-radius:2px;\n  background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 7px var(--ac);}\n/* tiny indicator LED at top of each knob mirrors value */\n.knob .dot{position:absolute;left:50%;top:-1px;width:6px;height:6px;margin-left:-3px;border-radius:50%;\n  background:radial-gradient(circle,#fff,var(--ac));opacity:calc(.25 + var(--v)*.75);\n  box-shadow:0 0 calc(2px + var(--v)*7px) var(--ac);transition:.12s}\n.knob.act .cap{transition:none}\n\n.nm{font-size:9.5px;letter-spacing:.2em;color:#bfe0d4;text-transform:uppercase}\n.val{font-size:13px;font-weight:800;color:#fff;font-variant-numeric:tabular-nums;\n  text-shadow:0 0 10px rgba(255,169,77,.35)}\n.unit{font-size:8px;letter-spacing:.1em;color:#6f9b8d;margin-left:1px}\n\n/* value bubble while dragging */\n.bub{position:absolute;left:50%;top:-22px;transform:translate(-50%,5px) scale(.85);opacity:0;\n  padding:2px 7px;border-radius:6px;font-size:11px;font-weight:800;color:#0a1413;\n  background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 4px 12px rgba(0,0,0,.5);\n  pointer-events:none;font-variant-numeric:tabular-nums;transition:.14s;white-space:nowrap}\n.knob.act .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n\n/* footer label strip */\n.foot{position:relative;z-index:2;margin:8px 22px 0;padding-top:10px;display:flex;align-items:center;gap:10px;\n  border-top:1px dashed rgba(127,174,159,.22);font-size:8.5px;letter-spacing:.14em;color:#6f9b8d;text-transform:uppercase}\n.foot .bbd{color:#9bd0c2}\n.stomp{margin-left:auto;width:20px;height:20px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#e7dcc0,var(--metal) 60%,#4a3c20);\n  box-shadow:0 2px 4px rgba(0,0,0,.6),inset 0 0 0 1px rgba(0,0,0,.4)}\n</style></head><body>\n<div class=\"pedal\">\n  <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n  <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n  <div class=\"plate\">\n    <span class=\"pwr\" id=\"pwr\"></span>\n    <div class=\"tt\"><h1>BUCKET ECHO</h1><div class=\"sub\">Bucket&nbsp;Brigade&nbsp;Delay</div></div>\n    <div class=\"model\">BBD-3208<br>Analog Echo</div>\n  </div>\n\n  <div class=\"track\">\n    <div class=\"chip\">\n      <i class=\"t\" style=\"left:8px\"></i><i class=\"t\" style=\"left:20px\"></i><i class=\"t\" style=\"left:32px\"></i>\n      <i class=\"t\" style=\"left:44px\"></i><i class=\"t\" style=\"left:56px\"></i>\n      <i class=\"b\" style=\"left:8px\"></i><i class=\"b\" style=\"left:20px\"></i><i class=\"b\" style=\"left:32px\"></i>\n      <i class=\"b\" style=\"left:44px\"></i><i class=\"b\" style=\"left:56px\"></i>\n      <span class=\"notch\"></span>\n      <span class=\"lbl\">MN<br>3208</span>\n    </div>\n    <div class=\"stages\" id=\"stages\"></div>\n    <div class=\"echoes\" id=\"echoes\"></div>\n  </div>\n\n  <div class=\"deck\" id=\"deck\"></div>\n\n  <div class=\"foot\">\n    <span class=\"bbd\">●</span><span id=\"footTxt\">512-stage analog delay line · in-loop low-pass · wow&amp;flutter</span>\n    <span class=\"stomp\"></span>\n  </div>\n</div>\n\n<script>\n(function(){\n  // ---- spec params (re-read from spec.json) ----\n  var PARAMS=[\n    {name:\"Time\",      index:0,min:0,max:1,def:0.22,fmt:function(v){return Math.round(40+v*860)+\"<span class='unit'>ms</span>\";}},\n    {name:\"Feedback\",  index:1,min:0,max:1,def:0.45,fmt:function(v){return Math.round(v*100)+\"<span class='unit'>%</span>\";}},\n    {name:\"Tone\",      index:2,min:0,max:1,def:0.5, fmt:function(v){return (v<.5?\"dark \":v>.5?\"brite \":\"\")+Math.round(v*100);}},\n    {name:\"Modulation\",index:3,min:0,max:1,def:0.35,fmt:function(v){return Math.round(v*100)+\"<span class='unit'>%</span>\";}},\n    {name:\"Mix\",       index:4,min:0,max:1,def:0.5, fmt:function(v){return Math.round(v*100)+\"<span class='unit'>%</span>\";}}\n  ];\n  var STEP=0.001;\n  var deck=document.getElementById('deck');\n  var ctrls=[]; // {p,val,setN,norm,el}\n\n  PARAMS.forEach(function(p,idx){\n    var cell=document.createElement('div');\n    cell.className='cell'; cell.style.setProperty('--d',(idx*70)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\"><span class=\"bub\"></span><i class=\"ticks\"></i><i class=\"arc\"></i>'\n      +'<i class=\"cap\"></i><i class=\"dot\"></i></div>'\n      +'<div class=\"nm\">'+p.name+'</div><div class=\"val\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var val=cell.querySelector('.val');\n    var bub=cell.querySelector('.bub');\n    var v=p.def;\n    function norm(){return (v-p.min)/((p.max-p.min)||1);}\n    function paint(){\n      var n=norm();\n      knob.style.setProperty('--v',n);\n      var t=p.fmt(v);\n      val.innerHTML=t; bub.textContent=val.textContent;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n    }\n    function setN(n){\n      n=n<0?0:(n>1?1:n);\n      var nv=p.min+(p.max-p.min)*n;\n      nv=Math.round(nv/STEP)*STEP;\n      v=nv; paint();\n    }\n    // pointer drag (vertical)\n    knob.addEventListener('pointerdown',function(e){\n      knob._d=1; knob._y=e.clientY; knob._n=norm(); knob.classList.add('act');\n      knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!knob._d)return;\n      var sp=e.shiftKey?600:200; // fine with Shift\n      setN(knob._n+(knob._y-e.clientY)/sp);\n    });\n    function endDrag(){knob._d=0;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',endDrag);\n    knob.addEventListener('pointercancel',endDrag);\n    knob.addEventListener('lostpointercapture',endDrag);\n    // double-click resets to default\n    knob.addEventListener('dblclick',function(){v=p.def;paint();});\n    // wheel\n    knob.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?0.025:-0.025));},{passive:false});\n\n    // setV: apply an absolute (raw) value WITHOUT echoing back to the host\n    // (used for host->UI read-back so we don't fight the DAW with setParam).\n    function setV(raw,silent){\n      var nv=raw<p.min?p.min:(raw>p.max?p.max:raw);\n      v=nv;\n      var n=norm();\n      knob.style.setProperty('--v',n);\n      var t=p.fmt(v); val.innerHTML=t; bub.textContent=val.textContent;\n      if(!silent && window.vstai && window.vstai.setParam) window.vstai.setParam(p.index,v);\n    }\n\n    ctrls.push({p:p,get val(){return v;},norm:norm,setV:setV});\n    paint();\n  });\n\n  // ---- host -> UI read-back: if the host exposes getParam, pull the\n  //      authoritative value for every index on load so the knobs reflect\n  //      the saved/automation state instead of our defaults. Silent so we\n  //      don't immediately write the same value straight back to the host.\n  function syncFromHost(){\n    if(!(window.vstai && typeof window.vstai.getParam==='function')) return;\n    ctrls.forEach(function(c){\n      try{\n        var hv=window.vstai.getParam(c.p.index);\n        if(hv!=null && isFinite(hv)) c.setV(+hv,true);\n      }catch(e){}\n    });\n  }\n\n  // =========================================================\n  //  ANALOG ECHO ANIMATION — signal walks the BBD stages and\n  //  spawns fading \"repeats\". Driven by Time/Feedback/Mod/Mix.\n  // =========================================================\n  var NSTAGE=12, stagesEl=document.getElementById('stages'), echoesEl=document.getElementById('echoes');\n  var stages=[];\n  for(var s=0;s<NSTAGE;s++){var d=document.createElement('div');d.className='stage';d.innerHTML='<b></b>';stagesEl.appendChild(d);stages.push(d);}\n  function P(i){return ctrls[i].norm();} // normalized 0..1 of param i\n  var rootStyle=document.documentElement.style; // live accent-hue target (Tone)\n\n  var last=0, headPos=0;\n  function loop(ts){\n    requestAnimationFrame(loop);\n    if(!last)last=ts; var dt=(ts-last)/1000; last=ts;\n\n    var time=P(0), fb=P(1), tone=P(2), mod=P(3), mix=P(4);\n    // Tone = in-loop low-pass colour: dark (low) => deep amber/red & dimmer\n    //        repeats; bright (high) => hot golden, crisper repeats. Drives the\n    //        --ac / --ac2 accent hues live so the whole echo path responds.\n    var hue=18+tone*30;                 // 18deg(red-amber)..48deg(gold)\n    var sat=92-tone*14;                 // brighter tone slightly less saturated\n    var litA=42+tone*16;                // lightness of accent\n    rootStyle.setProperty('--ac','hsl('+hue.toFixed(0)+','+sat.toFixed(0)+'%,'+litA.toFixed(0)+'%)');\n    rootStyle.setProperty('--ac2','hsl('+(hue+12).toFixed(0)+',100%,'+(litA+18).toFixed(0)+'%)');\n    // brightness ceiling for stage LEDs scales with Tone (low-pass darkens)\n    var toneGlow=0.45+tone*0.55;\n    // clock speed: shorter Time => faster walk through the bucket brigade\n    var speed=(2.2 - time*1.7); // stages per second-ish factor\n    headPos=(headPos+dt*speed*3) % NSTAGE;\n\n    // wow/flutter: modulation jitters the lit position slightly\n    var wobble=Math.sin(ts/170)*mod*1.4 + Math.sin(ts/61)*mod*0.6;\n    var lit=Math.round(headPos+wobble);\n\n    for(var k=0;k<NSTAGE;k++){\n      var on=(((k%NSTAGE)+NSTAGE)%NSTAGE)===(((lit%NSTAGE)+NSTAGE)%NSTAGE);\n      // brightness trails off down the line by feedback (repeats fade)\n      var bb=stages[k].firstChild;\n      if(on){\n        stages[k].classList.add('on');\n        // later stages dimmer unless feedback high; Tone caps the ceiling\n        // (a dark low-pass tone literally dims the bucket-brigade glow)\n        var fade=Math.max(0,Math.min(1, (1 - k/NSTAGE)*(0.4+fb*0.9) ));\n        bb.style.opacity=((0.35+0.65*fade)*toneGlow).toFixed(2);\n      } else {\n        stages[k].classList.remove('on');\n      }\n    }\n\n    // spawn a drifting echo blip when the head crosses stage 0 (a new repeat)\n    if(headPos<lastHead) spawnEcho(fb,mix,time,tone);\n    lastHead=headPos;\n  }\n  var lastHead=0;\n\n  function spawnEcho(fb,mix,time,tone){\n    var b=document.createElement('div'); b.className='blip'; echoesEl.appendChild(b);\n    var startMix=(0.4+mix*0.6);\n    var life=900+ (1-time)*0 + 700; // ms total travel\n    // Tone tints each repeat: dark tone => deep amber, bright tone => gold,\n    // matching the in-loop low-pass colour of the BBD feedback path.\n    var hue=18+tone*30;\n    b.style.background='radial-gradient(circle,hsl('+hue.toFixed(0)+',95%,'+(48+tone*16).toFixed(0)+'%) 0%,transparent 70%)';\n    var t0=performance.now();\n    function step(now){\n      var e=(now-t0)/life;\n      if(e>=1){ b.remove(); return; }\n      // travels left->right, fading; feedback => slower fade / more visible\n      // tail; a darker Tone also fades the repeat faster (high-freq loss).\n      var x=e*100;\n      var op=startMix*Math.pow(1-e, 1.6 - fb*1.0)*(0.55+tone*0.45);\n      b.style.left=x.toFixed(1)+'%';\n      b.style.opacity=op.toFixed(3);\n      b.style.transform='scale('+(1+e*0.6)+')';\n      requestAnimationFrame(step);\n    }\n    requestAnimationFrame(step);\n  }\n\n  function ready(){ syncFromHost(); requestAnimationFrame(loop); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  BUCKET ECHO — analog bucket-brigade-style delay\n//  A modulated, interpolated delay line with a feedback path. Each repeat\n//  is progressively darker: a one-pole low-pass sits inside the feedback\n//  loop to mimic the bandwidth loss of a bucket-brigade device. A slow\n//  wow/flutter LFO modulates the delay time for the unstable, vintage\n//  pitch wander. Feedback is clamped so near-max self-oscillation stays\n//  bounded. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: up to ~1.0 s per channel at 96 kHz keeps headroom for the\n// 800 ms max time plus modulation depth.\nconst DELAY_LEN: i32 = 96000 + 8192;\nconst delayL: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\n\n// per-channel feedback low-pass state (BBD darkening)\nlet fbLpL: f32 = 0.0;\nlet fbLpR: f32 = 0.0;\n\n// smoothed delay time (samples) to avoid zipper noise on Time changes\nlet smoothDelay: f32 = 9600.0;\n\n// wow/flutter LFOs (two slightly detuned phases per channel for organic drift)\nlet lfoPhase: f32 = 0.0;\nlet flutPhase: f32 = 0.0;\n\nconst P_TIME: i32 = 0;   // 0..1 -> 20..800 ms\nconst P_FEEDBACK: i32 = 1; // 0..1 -> 0..0.95 (clamped)\nconst P_TONE: i32 = 2;   // 0..1 -> repeat darkness (LP cutoff in feedback)\nconst P_MOD: i32 = 3;    // 0..1 -> wow depth\nconst P_MIX: i32 = 4;    // 0..1 dry/wet\n\nconst TWO_PI: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  fbLpL = 0.0;\n  fbLpR = 0.0;\n  lfoPhase = 0.0;\n  flutPhase = 0.0;\n  for (let i = 0; i < DELAY_LEN; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  smoothDelay = 0.18 * sampleRate; // ~180 ms default\n  params[P_TIME] = 0.22;     // ~190 ms\n  params[P_FEEDBACK] = 0.45;\n  params[P_TONE] = 0.5;\n  params[P_MOD] = 0.35;\n  params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// read a delay line at a fractional sample distance behind the write head,\n// linear interpolation, wrap-safe.\n@inline function readDelay(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(DELAY_LEN);\n  while (rp >= f32(DELAY_LEN)) rp -= f32(DELAY_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const modN: f32 = clampf(params[P_MOD], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Time: 20..800 ms (perceptual-ish curve), in samples.\n  const timeMs: f32 = 20.0 + timeN * timeN * 780.0;\n  let targetDelay: f32 = timeMs * 0.001 * sampleRate;\n  const maxDelay: f32 = f32(DELAY_LEN - 4);\n  if (targetDelay > maxDelay) targetDelay = maxDelay;\n  if (targetDelay < 4.0) targetDelay = 4.0;\n\n  // Feedback gain — strictly clamped to 0.95 so self-oscillation can ring\n  // but never diverge.\n  const fbGain: f32 = clampf(fbN * 0.95, 0.0, 0.95);\n\n  // Feedback low-pass: brighter when Tone high, darker when low.\n  // Cutoff ~700 Hz (dark) .. ~7000 Hz (bright).\n  const toneHz: f32 = 700.0 + toneN * toneN * 6300.0;\n  let cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  cTone = clampf(cTone, 0.0, 1.0);\n\n  // Wow/flutter: depth scales with Mod. Keep modulation in samples small\n  // relative to delay so it stays musical and never reads out of range.\n  // depth up to ~6 ms wow + a faster, shallower flutter.\n  const wowDepth: f32 = modN * 0.006 * sampleRate;     // samples\n  const flutDepth: f32 = modN * 0.0012 * sampleRate;   // samples\n  const wowRate: f32 = 0.7;   // Hz\n  const flutRate: f32 = 6.3;  // Hz\n  const wowInc: f32 = TWO_PI * wowRate / sampleRate;\n  const flutInc: f32 = TWO_PI * flutRate / sampleRate;\n\n  // one-pole smoothing coeff for delay time (~30 ms)\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 8.0 / sampleRate));\n\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    // advance LFOs\n    lfoPhase += wowInc; if (lfoPhase >= TWO_PI) lfoPhase -= TWO_PI;\n    flutPhase += flutInc; if (flutPhase >= TWO_PI) flutPhase -= TWO_PI;\n    const wow: f32 = Mathf.sin(lfoPhase);\n    const flut: f32 = Mathf.sin(flutPhase);\n\n    // smooth the base delay toward target\n    smoothDelay += smoothCoeff * (targetDelay - smoothDelay);\n\n    // modulated read distance (channels offset slightly for width)\n    const modOffset: f32 = wow * wowDepth + flut * flutDepth;\n    let dL: f32 = smoothDelay + modOffset;\n    let dR: f32 = smoothDelay - modOffset * 0.85;\n    if (dL < 2.0) dL = 2.0; if (dL > maxDelay) dL = maxDelay;\n    if (dR < 2.0) dR = 2.0; if (dR > maxDelay) dR = maxDelay;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n\n    // read the delayed (echo) signal\n    const echoL: f32 = readDelay(delayL, dL);\n    const echoR: f32 = readDelay(delayR, dR);\n\n    // darken the feedback signal (progressive bandwidth loss per repeat)\n    fbLpL += cTone * (echoL - fbLpL);\n    fbLpR += cTone * (echoR - fbLpR);\n\n    // soft-saturate the feedback so runaway oscillation stays bounded and\n    // gets the warm BBD compression character.\n    let fbInL: f32 = xL + fbLpL * fbGain;\n    let fbInR: f32 = xR + fbLpR * fbGain;\n    fbInL = f32(Mathf.tanh(fbInL));\n    fbInR = f32(Mathf.tanh(fbInR));\n\n    // write into the delay line at the head\n    delayL[writePos] = fbInL;\n    delayR[writePos] = fbInR;\n\n    // wet = the delayed signal (already tone-shaped reads come from line)\n    const wetL: f32 = echoL;\n    const wetR: f32 = echoR;\n\n    outBuf[f] = f32(xL * (1.0 - mix) + wetL * mix);\n    if (stereo) outBuf[MAX_FRAMES + f] = f32(xR * (1.0 - mix) + wetR * mix);\n    else outBuf[MAX_FRAMES + f] = outBuf[f];\n\n    writePos++;\n    if (writePos >= DELAY_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000012000
}