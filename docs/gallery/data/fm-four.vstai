{
  "format": 1,
  "name": "FM Four",
  "isInstrument": true,
  "explanation": "A programmable 4-operator FM synth. Four sine operators are wired by a selectable algorithm — a serial stack, two parallel FM pairs, or three modulators in parallel into one carrier — for everything from clangy basses to glassy bells and evolving pads. An exposed modulator ratio and FM depth set the timbre, operator feedback adds gritty 80s-digital edge, and an attack/release envelope shapes both the amplitude and the modulation index so the brightness evolves over each note. Controls: Ratio, FM Depth, Feedback, Algorithm, Attack, Release and Level.",
  "params": [
    {
      "name": "Ratio",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.32
    },
    {
      "name": "FM Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Feedback",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Algorithm",
      "index": 3,
      "min": 0,
      "max": 2,
      "default": 0
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.02
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>FM Four</title>\n<style>\n  :root{\n    --accent:#7a86ff;\n    --accent2:#42e6c4;\n    --bg0:#070912;\n    --bg1:#0d1226;\n    --panel:#10162e;\n    --line:#202a4d;\n    --txt:#cfe0ff;\n    --dim:#5e6a93;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:\"SF Mono\",ui-monospace,Menlo,Consolas,monospace;\n    color:var(--txt);\n    background:\n      radial-gradient(1200px 500px at 20% -10%, rgba(122,134,255,.12), transparent 60%),\n      radial-gradient(900px 500px at 110% 120%, rgba(66,230,196,.10), transparent 55%),\n      linear-gradient(160deg,var(--bg1),var(--bg0));\n    overflow:hidden;\n    padding:14px;\n  }\n  .shell{\n    position:relative;\n    height:100%;\n    border:1px solid var(--line);\n    border-radius:16px;\n    background:linear-gradient(180deg,rgba(20,28,56,.55),rgba(8,11,22,.65));\n    box-shadow:0 0 0 1px rgba(122,134,255,.06) inset, 0 18px 60px rgba(0,0,0,.6);\n    overflow:hidden;\n    display:flex;\n    flex-direction:column;\n  }\n  /* subtle moving scanline texture */\n  .shell::before{\n    content:\"\";position:absolute;inset:0;pointer-events:none;z-index:5;\n    background:repeating-linear-gradient(0deg,rgba(255,255,255,.018) 0 1px,transparent 1px 3px);\n    animation:scan 6s linear infinite;opacity:.5;\n  }\n  @keyframes scan{from{background-position:0 0}to{background-position:0 3px}}\n\n  header{\n    display:flex;align-items:center;justify-content:space-between;\n    padding:14px 20px 10px;border-bottom:1px solid var(--line);\n    position:relative;z-index:6;\n  }\n  .brand{display:flex;align-items:baseline;gap:10px;}\n  .logo{\n    font-weight:700;font-size:22px;letter-spacing:3px;\n    background:linear-gradient(90deg,var(--accent),var(--accent2));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 0 18px rgba(122,134,255,.35);\n  }\n  .logo .four{font-style:italic;}\n  .sub{font-size:10px;letter-spacing:2px;color:var(--dim);text-transform:uppercase;}\n  .badge{\n    font-size:9px;letter-spacing:2px;color:var(--accent2);\n    border:1px solid rgba(66,230,196,.4);border-radius:20px;padding:4px 10px;\n    text-transform:uppercase;\n    box-shadow:0 0 12px rgba(66,230,196,.15) inset;\n  }\n\n  .main{flex:1;display:grid;grid-template-columns:1.1fr 1fr;gap:14px;padding:14px 18px;min-height:0;position:relative;z-index:6;}\n\n  .viz{display:flex;flex-direction:column;gap:12px;min-height:0;}\n  .card{\n    border:1px solid var(--line);border-radius:12px;\n    background:linear-gradient(180deg,rgba(13,18,38,.7),rgba(8,11,22,.5));\n    padding:12px 14px;position:relative;overflow:hidden;\n  }\n  .card h3{font-size:9px;letter-spacing:2.5px;color:var(--dim);text-transform:uppercase;margin-bottom:8px;}\n\n  .algoCard{flex:0 0 auto;}\n  .graph{height:160px;width:100%;display:block;}\n  .opbox{transition:all .25s ease;}\n  .opLabel{font:600 11px \"SF Mono\",monospace;fill:var(--txt);}\n  .opSub{font:9px \"SF Mono\",monospace;fill:var(--dim);}\n\n  .specCard{flex:1;min-height:0;display:flex;flex-direction:column;}\n  .spectrum{flex:1;width:100%;display:block;}\n\n  .controls{display:flex;flex-direction:column;gap:12px;min-height:0;overflow:auto;}\n  .algoPick{display:flex;gap:8px;}\n  .algoBtn{\n    flex:1;font:600 10px \"SF Mono\",monospace;letter-spacing:1.5px;\n    color:var(--dim);background:rgba(16,22,46,.6);\n    border:1px solid var(--line);border-radius:9px;padding:10px 4px;cursor:pointer;\n    text-transform:uppercase;transition:all .18s ease;position:relative;\n  }\n  .algoBtn small{display:block;font-size:8px;letter-spacing:1px;margin-top:3px;color:var(--dim);font-weight:400;}\n  .algoBtn:hover{border-color:rgba(122,134,255,.5);color:var(--txt);}\n  .algoBtn.on{\n    color:#fff;border-color:var(--accent);\n    background:linear-gradient(180deg,rgba(122,134,255,.28),rgba(122,134,255,.08));\n    box-shadow:0 0 16px rgba(122,134,255,.3),0 0 0 1px rgba(122,134,255,.4) inset;\n  }\n  .algoBtn.on small{color:var(--accent2);}\n\n  .knobs{display:grid;grid-template-columns:repeat(3,1fr);gap:10px 6px;}\n  .knob{display:flex;flex-direction:column;align-items:center;gap:5px;}\n  .dial{\n    width:74px;height:74px;cursor:ns-resize;position:relative;touch-action:none;\n  }\n  .dial svg{display:block;overflow:visible;}\n  .kName{font-size:9px;letter-spacing:1.5px;color:var(--dim);text-transform:uppercase;}\n  .kVal{font-size:11px;color:var(--accent2);min-height:13px;font-variant-numeric:tabular-nums;}\n  .dial .needle{transition:transform .04s linear;transform-origin:50% 50%;}\n  .dial:hover .ring{filter:drop-shadow(0 0 6px rgba(122,134,255,.7));}\n\n  footer{\n    padding:8px 20px;border-top:1px solid var(--line);\n    display:flex;justify-content:space-between;align-items:center;\n    font-size:9px;letter-spacing:1.5px;color:var(--dim);position:relative;z-index:6;\n  }\n  .dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--accent2);\n    box-shadow:0 0 8px var(--accent2);animation:pulse 1.6s ease-in-out infinite;margin-right:6px;}\n  @keyframes pulse{0%,100%{opacity:.35;}50%{opacity:1;}}\n</style>\n</head>\n<body>\n<div class=\"shell\">\n  <header>\n    <div class=\"brand\">\n      <span class=\"logo\">FM<span class=\"four\"> FOUR</span></span>\n      <span class=\"sub\">4-operator digital fm</span>\n    </div>\n    <span class=\"badge\">phase modulation engine</span>\n  </header>\n\n  <div class=\"main\">\n    <div class=\"viz\">\n      <div class=\"card algoCard\">\n        <h3>Operator Algorithm</h3>\n        <svg class=\"graph\" viewBox=\"0 0 320 160\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"opg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#1a2247\"/>\n              <stop offset=\"1\" stop-color=\"#0d1430\"/>\n            </linearGradient>\n            <linearGradient id=\"wire\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#7a86ff\"/>\n              <stop offset=\"1\" stop-color=\"#42e6c4\"/>\n            </linearGradient>\n            <filter id=\"glow\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">\n              <feGaussianBlur stdDeviation=\"2.4\" result=\"b\"/>\n              <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n            </filter>\n          </defs>\n          <g id=\"wires\" filter=\"url(#glow)\"></g>\n          <g id=\"ops\"></g>\n        </svg>\n      </div>\n      <div class=\"card specCard\">\n        <h3>FM Spectrum</h3>\n        <canvas class=\"spectrum\" id=\"spec\"></canvas>\n      </div>\n    </div>\n\n    <div class=\"controls\">\n      <div class=\"card\">\n        <h3>Algorithm Select</h3>\n        <div class=\"algoPick\" id=\"algoPick\">\n          <button class=\"algoBtn\" data-a=\"0\">Stack<small>4→3→2→1</small></button>\n          <button class=\"algoBtn\" data-a=\"1\">Pair<small>2 fm pairs</small></button>\n          <button class=\"algoBtn\" data-a=\"2\">Parallel<small>3→1 carrier</small></button>\n        </div>\n      </div>\n      <div class=\"card\" style=\"flex:1;\">\n        <h3>Voice</h3>\n        <div class=\"knobs\" id=\"knobs\"></div>\n      </div>\n    </div>\n  </div>\n\n  <footer>\n    <span><span class=\"dot\"></span>FM FOUR · 12-VOICE POLY</span>\n    <span id=\"status\">READY</span>\n  </footer>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- host bridge -------------------------------------------------\n  var host = window.vstai || null;\n  function sendParam(i,v){ try{ if(host && host.setParam) host.setParam(i, v); }catch(e){} }\n\n  // ---- param model (must match spec.json indices) -----------------\n  // continuous knobs use 0..1; algorithm is its own stepped control\n  var KNOBS = [\n    {idx:0, name:\"Ratio\",    def:0.32, fmt:function(v){return (0.5+v*11.5).toFixed(2)+\"×\";}},\n    {idx:1, name:\"FM Depth\", def:0.55, fmt:function(v){return Math.round(v*100)+\"%\";}},\n    {idx:2, name:\"Feedback\", def:0.25, fmt:function(v){return Math.round(v*100)+\"%\";}},\n    {idx:4, name:\"Attack\",   def:0.02, fmt:function(v){var s=0.001+v*v*0.399;return s<1?Math.round(s*1000)+\"ms\":s.toFixed(2)+\"s\";}},\n    {idx:5, name:\"Release\",  def:0.45, fmt:function(v){var s=0.04+v*v*3.96;return s<1?Math.round(s*1000)+\"ms\":s.toFixed(2)+\"s\";}},\n    {idx:6, name:\"Level\",    def:0.7,  fmt:function(v){return Math.round(v*100)+\"%\";}}\n  ];\n  var ALGO_IDX = 3;\n  var state = {};           // idx -> 0..1 value\n  var algo = 0;             // 0,1,2\n\n  KNOBS.forEach(function(k){ state[k.idx] = k.def; });\n\n  // =================================================================\n  //  KNOBS\n  // =================================================================\n  var knobWrap = document.getElementById(\"knobs\");\n  var dials = {};\n\n  function makeDial(k){\n    var wrap = document.createElement(\"div\"); wrap.className=\"knob\";\n    var dial = document.createElement(\"div\"); dial.className=\"dial\";\n    dial.innerHTML =\n      '<svg viewBox=\"0 0 74 74\">'+\n      '<circle cx=\"37\" cy=\"37\" r=\"30\" fill=\"none\" stroke=\"#202a4d\" stroke-width=\"5\"/>'+\n      '<circle class=\"ring\" cx=\"37\" cy=\"37\" r=\"30\" fill=\"none\" stroke=\"url(#kg)\" stroke-width=\"5\" stroke-linecap=\"round\" '+\n        'stroke-dasharray=\"0 999\" transform=\"rotate(135 37 37)\"/>'+\n      '<defs><linearGradient id=\"kg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n        '<stop offset=\"0\" stop-color=\"#7a86ff\"/><stop offset=\"1\" stop-color=\"#42e6c4\"/></linearGradient></defs>'+\n      '<g class=\"needle\"><line class=\"ndl\" x1=\"37\" y1=\"37\" x2=\"37\" y2=\"14\" stroke=\"#cfe0ff\" stroke-width=\"2.5\" stroke-linecap=\"round\"/></g>'+\n      '<circle cx=\"37\" cy=\"37\" r=\"4.5\" fill=\"#0d1226\" stroke=\"#42e6c4\" stroke-width=\"1.4\"/>'+\n      '</svg>';\n    var name = document.createElement(\"div\"); name.className=\"kName\"; name.textContent=k.name;\n    var val  = document.createElement(\"div\"); val.className=\"kVal\";\n    wrap.appendChild(dial); wrap.appendChild(name); wrap.appendChild(val);\n    knobWrap.appendChild(wrap);\n\n    var ring = dial.querySelector(\".ring\");\n    var ndl = dial.querySelector(\".ndl\");\n    var C = 2*Math.PI*30;              // circumference\n    var SWEEP = 270/360;               // 270deg arc\n\n    function render(){\n      var v = state[k.idx];\n      var len = C*SWEEP*v;\n      ring.setAttribute(\"stroke-dasharray\", len+\" 999\");\n      // compute the needle tip directly (avoids CSS transform-origin conflict\n      // that was flinging the pointer off-centre)\n      var th = (-135 + v*270) * Math.PI/180;\n      ndl.setAttribute(\"x2\", (37 + 23*Math.sin(th)).toFixed(2));\n      ndl.setAttribute(\"y2\", (37 - 23*Math.cos(th)).toFixed(2));\n      val.textContent = k.fmt(v);\n    }\n    function set(v){\n      v = Math.max(0,Math.min(1,v));\n      state[k.idx]=v; render(); sendParam(k.idx, v);\n    }\n\n    // drag (vertical)\n    var dragging=false, startY=0, startV=0;\n    function down(e){ dragging=true; startY=(e.touches?e.touches[0].clientY:e.clientY); startV=state[k.idx];\n      document.body.style.cursor=\"ns-resize\"; e.preventDefault(); }\n    function move(e){ if(!dragging)return; var y=(e.touches?e.touches[0].clientY:e.clientY);\n      set(startV + (startY-y)/180); e.preventDefault(); }\n    function up(){ dragging=false; document.body.style.cursor=\"\"; }\n    dial.addEventListener(\"mousedown\",down);\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"mouseup\",up);\n    dial.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"touchend\",up);\n    dial.addEventListener(\"wheel\",function(e){ set(state[k.idx]-e.deltaY*0.0011); e.preventDefault(); },{passive:false});\n    dial.addEventListener(\"dblclick\",function(){ set(k.def); });\n\n    dials[k.idx]={set:set,render:render};\n    render();\n  }\n  KNOBS.forEach(makeDial);\n\n  // =================================================================\n  //  ALGORITHM SELECT\n  // =================================================================\n  var algoBtns = Array.prototype.slice.call(document.querySelectorAll(\".algoBtn\"));\n  function setAlgo(a){\n    algo = a|0;\n    algoBtns.forEach(function(b){ b.classList.toggle(\"on\", (+b.dataset.a)===algo); });\n    sendParam(ALGO_IDX, algo);     // real value 0/1/2 (stepped)\n    drawGraph();\n  }\n  algoBtns.forEach(function(b){\n    b.addEventListener(\"click\",function(){ setAlgo(+b.dataset.a); });\n    b.addEventListener(\"dblclick\",function(){ setAlgo(0); });\n  });\n\n  // =================================================================\n  //  ALGORITHM NODE GRAPH (animated)\n  // =================================================================\n  var opsG = document.getElementById(\"ops\");\n  var wiresG = document.getElementById(\"wires\");\n  // operator box positions (4 ops)\n  var POS = { 1:{x:130,y:118}, 2:{x:130,y:42}, 3:{x:230,y:80}, 4:{x:230,y:30} };\n  // algorithm wiring: list of [from,to]; \"to\" of 0 means audio out\n  var ALGOS = [\n    // STACK 4->3->2->1->out\n    {carriers:[1], wires:[[4,3],[3,2],[2,1]], pos:{1:{x:120,y:120},2:{x:120,y:84},3:{x:120,y:48},4:{x:120,y:12}}},\n    // PAIR (4->3)+(2->1)\n    {carriers:[1,3], wires:[[4,3],[2,1]], pos:{3:{x:80,y:30},4:{x:80,y:90},1:{x:200,y:30},2:{x:200,y:90}}},\n    // PARALLEL 4,3,2 -> 1\n    {carriers:[1], wires:[[4,1],[3,1],[2,1]], pos:{4:{x:60,y:30},3:{x:130,y:30},2:{x:200,y:30},1:{x:130,y:115}}}\n  ];\n\n  function boxSVG(id,p,isCarrier,phase){\n    var w=46,h=30,x=p.x-w/2,y=p.y-h/2;\n    var col = isCarrier ? \"#42e6c4\" : \"#7a86ff\";\n    return '<g class=\"opbox\" style=\"animation:pulse 2.2s ease-in-out infinite;animation-delay:'+phase+'s\">'+\n      '<rect x=\"'+x+'\" y=\"'+y+'\" width=\"'+w+'\" height=\"'+h+'\" rx=\"7\" fill=\"url(#opg)\" '+\n        'stroke=\"'+col+'\" stroke-width=\"1.6\"/>'+\n      '<text class=\"opLabel\" x=\"'+p.x+'\" y=\"'+(p.y-1)+'\" text-anchor=\"middle\">OP'+id+'</text>'+\n      '<text class=\"opSub\" x=\"'+p.x+'\" y=\"'+(p.y+11)+'\" text-anchor=\"middle\">'+(isCarrier?'CARR':'MOD')+'</text>'+\n      '</g>';\n  }\n  function curve(a,b){\n    var mx=(a.x+b.x)/2;\n    return 'M'+a.x+','+a.y+' C'+mx+','+a.y+' '+mx+','+b.y+' '+b.x+','+b.y;\n  }\n\n  function drawGraph(){\n    var A = ALGOS[algo];\n    // wires\n    var wh=\"\";\n    A.wires.forEach(function(w,i){\n      var from=A.pos[w[0]], to=A.pos[w[1]];\n      var d=curve(from,to);\n      wh += '<path d=\"'+d+'\" fill=\"none\" stroke=\"url(#wire)\" stroke-width=\"2\" '+\n            'stroke-dasharray=\"5 6\" opacity=\".9\">'+\n            '<animate attributeName=\"stroke-dashoffset\" from=\"0\" to=\"-22\" dur=\"0.7s\" repeatCount=\"indefinite\"/></path>';\n    });\n    // carriers -> output line\n    A.carriers.forEach(function(c){\n      var p=A.pos[c];\n      wh += '<path d=\"M'+p.x+','+(p.y+15)+' L'+p.x+','+150+'\" stroke=\"#42e6c4\" stroke-width=\"2\" opacity=\".55\" '+\n            'stroke-dasharray=\"4 5\"><animate attributeName=\"stroke-dashoffset\" from=\"0\" to=\"-18\" dur=\"0.8s\" repeatCount=\"indefinite\"/></path>';\n    });\n    wiresG.innerHTML = wh;\n    // boxes\n    var oh=\"\";\n    [4,3,2,1].forEach(function(id,i){\n      var isC = A.carriers.indexOf(id)>=0;\n      oh += boxSVG(id, A.pos[id], isC, i*0.3);\n    });\n    opsG.innerHTML = oh;\n  }\n\n  // =================================================================\n  //  FM SPECTRUM (fast evolving readout, driven by params)\n  // =================================================================\n  var canvas = document.getElementById(\"spec\");\n  var ctx = canvas.getContext(\"2d\");\n  function fitCanvas(){\n    var r=canvas.getBoundingClientRect();\n    canvas.width = Math.max(80,r.width)*devicePixelRatio;\n    canvas.height = Math.max(40,r.height)*devicePixelRatio;\n  }\n  window.addEventListener(\"resize\", function(){ fitCanvas(); drawGraph(); });\n\n  var NB = 64;                 // spectral bins\n  var bins = new Float32Array(NB);\n  var t0 = performance.now();\n\n  // approximate FM partial energy: carrier + sidebands at k*ratio spacing,\n  // bessel-ish falloff by modulation index. Just for a lively visual.\n  function targetSpectrum(arr){\n    for(var i=0;i<NB;i++) arr[i]=0;\n    var ratio = 0.5 + state[0]*11.5;\n    var idx = state[1]*10*(0.6+state[2]*0.6);   // depth + feedback widen\n    var fb = state[2];\n    var carrierBin = 5;\n    // number of significant sidebands ~ idx+1\n    var N = Math.min(28, Math.floor(idx)+2);\n    for(var k=-N;k<=N;k++){\n      // bin position: carrier ± k*ratio\n      var bpos = carrierBin + k*ratio*(algo===2?1.3:1.0);\n      if(bpos<0||bpos>=NB) continue;\n      // bessel-ish magnitude\n      var mag = Math.exp(-Math.abs(k)*Math.abs(k)/(2*(idx+0.5))) ;\n      mag *= (1 - 0.25*((k%2+2)%2));        // alternate sideband dip\n      if(algo===1 && k!==0) mag*=0.8;       // pair: a touch softer\n      var bi = Math.round(bpos);\n      arr[bi] = Math.max(arr[bi], mag);\n    }\n    // feedback adds noisy high partials\n    if(fb>0.05){\n      for(var j=carrierBin;j<NB;j++){ arr[j]=Math.max(arr[j], fb*0.5*Math.exp(-(j-carrierBin)/(NB*0.6))); }\n    }\n  }\n\n  var tgt = new Float32Array(NB);\n  function frame(){\n    var now=performance.now();\n    var t=(now-t0)/1000;\n    targetSpectrum(tgt);\n    var W=canvas.width, H=canvas.height;\n    ctx.clearRect(0,0,W,H);\n    // baseline grid\n    ctx.strokeStyle=\"rgba(122,134,255,.08)\"; ctx.lineWidth=1;\n    for(var g=1;g<4;g++){ var y=H*g/4; ctx.beginPath();ctx.moveTo(0,y);ctx.lineTo(W,y);ctx.stroke(); }\n    var bw=W/NB;\n    for(var i=0;i<NB;i++){\n      // shimmer animation per bin\n      var sh = 1 + 0.10*Math.sin(t*5 + i*0.5);\n      bins[i] += (tgt[i]*sh - bins[i])*0.18;     // fast evolving\n      var h = bins[i]*H*0.92;\n      if(h<1) continue;\n      var x=i*bw;\n      var grad=ctx.createLinearGradient(0,H,0,H-h);\n      grad.addColorStop(0,\"rgba(122,134,255,.25)\");\n      grad.addColorStop(1,\"rgba(66,230,196,.95)\");\n      ctx.fillStyle=grad;\n      ctx.fillRect(x+bw*0.18, H-h, bw*0.64, h);\n      // cap\n      ctx.fillStyle=\"rgba(207,224,255,.9)\";\n      ctx.fillRect(x+bw*0.18, H-h-2*devicePixelRatio, bw*0.64, 2*devicePixelRatio);\n    }\n    requestAnimationFrame(frame);\n  }\n\n  // =================================================================\n  //  INIT\n  // =================================================================\n  function init(){\n    fitCanvas();\n    drawGraph();\n    setAlgo(0);\n    // push all knob defaults to host + render\n    KNOBS.forEach(function(k){ sendParam(k.idx, state[k.idx]); dials[k.idx].render(); });\n    requestAnimationFrame(frame);\n    var st=document.getElementById(\"status\");\n    st.textContent = host ? \"HOST LINKED\" : \"STANDALONE\";\n  }\n\n  if(host && host.onReady){ host.onReady(init); }\n  else { init(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  FM FOUR — programmable 4-operator FM synth (DX-lineage)\n//  A general 4-operator phase-modulation engine, NOT a fixed tine EP.\n//  Four sine operators (OP1..OP4) are wired by a selectable ALGORITHM:\n//\n//    0 STACK    : OP4 -> OP3 -> OP2 -> OP1(carrier)   (deep, clangy bass)\n//    1 PAIR     : OP4 -> OP3(carrier) + OP2 -> OP1(carrier)  (two FM pairs)\n//    2 PARALLEL : OP4,OP3,OP2 all -> OP1(carrier)     (rich additive-ish)\n//\n//  The top modulator(s) run at a selectable RATIO; FM DEPTH sets the\n//  modulation index; OP-FEEDBACK self-modulates the top operator for the\n//  gritty 80s edge. A single ADSR-ish env (Attack + Release, with a fast\n//  body decay) shapes BOTH the amplitude AND the modulation index, so the\n//  brightness evolves over the note like a real DX patch.\n//  Pure algorithm: all f32, no allocation in process(), no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_VOICES: i32 = 12;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831853071795864769;\n\n// ---- per-voice state (parallel StaticArrays, no allocation in process) ----\nconst vActive: StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = in use\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = key held\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // note id\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // carrier Hz\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // 0..1\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // amp-env level\nconst vAge:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // LRU voice-steal\n// four operator phases per voice (radians)\nconst vP1: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vP2: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vP3: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vP4: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vFb: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // feedback memory (top op output)\n\nlet ageCounter: f32 = 0.0;\n\n// ---- parameter indices (MUST match spec.json) ----\nconst P_RATIO: i32 = 0; // modulator ratio        0..1 -> 0.5 .. 12\nconst P_DEPTH: i32 = 1; // FM depth / mod index   0..1 -> 0 .. ~10\nconst P_FB:    i32 = 2; // operator feedback       0..1\nconst P_ALGO:  i32 = 3; // algorithm select (stepped 0..2)\nconst P_ATK:   i32 = 4; // attack                  0..1\nconst P_REL:   i32 = 5; // release                 0..1\nconst P_LEVEL: i32 = 6; // output level            0..1\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vAmp[v] = 0.0; vAge[v] = 0.0;\n    vP1[v] = 0.0; vP2[v] = 0.0; vP3[v] = 0.0; vP4[v] = 0.0; vFb[v] = 0.0;\n  }\n  ageCounter = 0.0;\n  params[P_RATIO] = 0.32;  // ~ ratio 3.0  (clangy)\n  params[P_DEPTH] = 0.55;\n  params[P_FB]    = 0.25;\n  params[P_ALGO]  = 0.0;   // STACK\n  params[P_ATK]   = 0.02;\n  params[P_REL]   = 0.45;\n  params[P_LEVEL] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function noteOn(id: i32, freq: f32, velocity: f32): void {\n  if (freq <= 0.0) freq = 1.0;\n  let slot: i32 = -1;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) { slot = v; break; }\n  }\n  if (slot < 0) {\n    for (let v = 0; v < MAX_VOICES; v++) {\n      if (vActive[v] == 0) { slot = v; break; }\n    }\n  }\n  if (slot < 0) {\n    let oldest: f32 = vAge[0]; slot = 0;\n    for (let v = 1; v < MAX_VOICES; v++) {\n      if (vAge[v] < oldest) { oldest = vAge[v]; slot = v; }\n    }\n  }\n  ageCounter += 1.0;\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vNote[slot]   = id;\n  vFreq[slot]   = freq;\n  vVel[slot]    = clampf(velocity, 0.0, 1.0);\n  vAmp[slot]    = 0.0;\n  vP1[slot] = 0.0; vP2[slot] = 0.0; vP3[slot] = 0.0; vP4[slot] = 0.0; vFb[slot] = 0.0;\n  vAge[slot]    = ageCounter;\n}\n\nexport function noteOff(id: i32): void {\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) vGate[v] = 0;\n  }\n}\n\nexport function process(n: i32): void {\n  // ---- resolve params once per block ----\n  const ratio: f32  = 0.5 + clampf(params[P_RATIO], 0.0, 1.0) * 11.5;   // 0.5 .. 12\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const fbN: f32    = clampf(params[P_FB], 0.0, 1.0);\n  const atkN: f32   = clampf(params[P_ATK], 0.0, 1.0);\n  const relN: f32   = clampf(params[P_REL], 0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL], 0.0, 1.0) * 0.8;\n  // algorithm: stepped 0..2 (round, clamp)\n  let algo: i32 = i32(clampf(params[P_ALGO], 0.0, 2.0) + 0.5);\n  if (algo < 0) algo = 0; if (algo > 2) algo = 2;\n\n  // peak modulation index — strong enough to clearly move bell<->bass<->pad\n  const peakIndex: f32 = depthN * 10.0;\n  // feedback amount (radians of self-PM on the top operator)\n  const fbAmt: f32 = fbN * fbN * 3.0;\n\n  // amp attack: 1 ms .. 400 ms\n  const atkSec: f32 = 0.001 + atkN * atkN * 0.399;\n  const atkCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (atkSec * sampleRate)));\n  // release: 40 ms .. ~4 s\n  const relSec: f32 = 0.04 + relN * relN * 3.96;\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relSec * sampleRate)));\n  // body decay while held (so brightness/level evolves; longer than release)\n  const decSec: f32 = relSec * 2.5 + 0.5;\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / (decSec * sampleRate)));\n\n  // modulation-index envelope follows the amp env shape but with a faster\n  // settle, so the patch starts bright and mellows — the DX \"evolving\" feel.\n  const idxDecCoef: f32 = f32(Mathf.exp(-1.0 / ((relSec * 0.6 + 0.05) * sampleRate)));\n\n  const invSr: f32 = 1.0 / sampleRate;\n\n  // ---- clear output block ----\n  for (let f = 0; f < n; f++) {\n    outBuf[f] = 0.0;\n    outBuf[MAX_FRAMES + f] = 0.0;\n  }\n\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] == 0) continue;\n\n    const f0: f32 = vFreq[v];\n    const vel: f32 = vVel[v];\n    const gate: i32 = vGate[v];\n\n    // operator increments. carrier(s) at f0, modulators at f0*ratio.\n    const incCar: f32 = TWO_PI * f0 * invSr;\n    const incMod: f32 = TWO_PI * f0 * ratio * invSr;\n\n    let p1: f32 = vP1[v]; // OP1 carrier\n    let p2: f32 = vP2[v]; // OP2\n    let p3: f32 = vP3[v]; // OP3\n    let p4: f32 = vP4[v]; // OP4 top modulator (carries feedback)\n    let fb: f32 = vFb[v];\n    let amp: f32 = vAmp[v];\n\n    // per-voice mod-index env: starts at velocity-scaled peak, decays\n    // We track it implicitly off a separate running multiplier per sample.\n    // Use vFb? no — reuse a local that decays each sample from 1.\n    // Re-derive its current value from amp would be wrong; keep simple: a\n    // local decaying scalar restarted each block is not persistent, so we\n    // fold the index env into amp shape: index = peak * (idxEnvFloor + ...).\n    // Simpler + persistent: drive index by a normalized amp (amp/vel).\n\n    const ampTarget: f32 = vel;\n    let reachedAtk: bool = amp >= ampTarget * 0.999 || ampTarget <= 0.0001;\n\n    for (let f = 0; f < n; f++) {\n      // amp envelope\n      if (gate != 0 && !reachedAtk) {\n        amp += atkCoef * (ampTarget - amp);\n        if (amp >= ampTarget * 0.999) { amp = ampTarget; reachedAtk = true; }\n      } else if (gate != 0) {\n        amp *= decCoef;\n      } else {\n        amp *= relCoef;\n      }\n\n      // modulation index evolves: brighter at the start of the note, then\n      // mellows. Normalized envelope (amp/vel) ^ shaping gives the evolution;\n      // velocity also opens the index (harder hits = brighter).\n      const normAmp: f32 = vel > 0.0001 ? amp / vel : amp;\n      const idxEnv: f32 = 0.25 + 0.75 * normAmp;        // 1.0 at peak -> 0.25 tail\n      const index: f32 = peakIndex * idxEnv * (0.5 + 0.5 * vel);\n\n      // ---- operator outputs (sine) ----\n      // top operator OP4 with self-feedback\n      const op4: f32 = Mathf.sin(p4 + fb * fbAmt);\n      fb = op4; // store for next-sample feedback\n\n      let s: f32;\n      if (algo == 0) {\n        // STACK: OP4 -> OP3 -> OP2 -> OP1\n        const op3: f32 = Mathf.sin(p3 + op4 * index);\n        const op2: f32 = Mathf.sin(p2 + op3 * index);\n        s = Mathf.sin(p1 + op2 * index);\n      } else if (algo == 1) {\n        // PAIR: (OP4->OP3) + (OP2->OP1), two carriers summed\n        const op3: f32 = Mathf.sin(p3 + op4 * index);   // carrier A\n        const op1: f32 = Mathf.sin(p1 + Mathf.sin(p2) * index); // OP2->OP1 carrier B\n        s = (op3 + op1) * 0.5;\n      } else {\n        // PARALLEL: OP4 + OP3 + OP2 all modulate OP1 carrier\n        const m: f32 = (op4 + Mathf.sin(p3) + Mathf.sin(p2)) * 0.5;\n        s = Mathf.sin(p1 + m * index);\n      }\n\n      s *= amp;\n      outBuf[f] += s;\n\n      // advance phases. carriers at incCar; modulators (p2,p3,p4) at incMod.\n      // In PAIR, p3 is a carrier so it runs at incCar; p1 always carrier.\n      p1 += incCar; if (p1 >= TWO_PI) p1 -= TWO_PI;\n      if (algo == 1) {\n        p3 += incCar; if (p3 >= TWO_PI) p3 -= TWO_PI;   // carrier A\n        p4 += incMod; if (p4 >= TWO_PI) p4 -= TWO_PI;   // modulates A\n        p2 += incMod; if (p2 >= TWO_PI) p2 -= TWO_PI;   // modulates B\n      } else {\n        p2 += incMod; if (p2 >= TWO_PI) p2 -= TWO_PI;\n        p3 += incMod; if (p3 >= TWO_PI) p3 -= TWO_PI;\n        p4 += incMod; if (p4 >= TWO_PI) p4 -= TWO_PI;\n      }\n    }\n\n    vP1[v] = p1; vP2[v] = p2; vP3[v] = p3; vP4[v] = p4; vFb[v] = fb;\n    vAmp[v] = amp;\n\n    if (gate == 0 && amp < 0.00008) {\n      vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    }\n  }\n\n  // ---- output level + soft safety limit, copy mono to stereo ----\n  for (let f = 0; f < n; f++) {\n    let s: f32 = outBuf[f] * level;\n    if (s > 1.2) s = 1.2; else if (s < -1.2) s = -1.2;\n    s = f32(s - 0.16666667 * s * s * s);   // gentle soft clip, peak < 1.0\n    outBuf[f] = s;\n    outBuf[MAX_FRAMES + f] = s;\n  }\n}\n",
  "publishedAt": 1751000098000
}