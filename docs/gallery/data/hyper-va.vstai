  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Hyper VA</title>\n<style>\n  :root {\n    --accent:  #ff3d7a;\n    --accent2: #3d8cff;\n    --bg0: #05060a;\n    --bg1: #0b0e16;\n    --panel: #0d1018;\n    --line: rgba(255,255,255,0.06);\n    --ink: #eef2ff;\n    --dim: #7d86a0;\n    --glass-hi: rgba(255,255,255,0.07);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    padding: 18px;\n  }\n\n  .machine {\n    width: 100%;\n    max-width: 720px;\n    border-radius: 20px;\n    background:\n      radial-gradient(120% 90% at 12% -10%, rgba(255,61,122,0.14), transparent 55%),\n      radial-gradient(120% 90% at 92% 0%, rgba(61,140,255,0.16), transparent 55%),\n      linear-gradient(160deg, #11141f 0%, #080a11 60%, #05060a 100%);\n    border: 1px solid rgba(255,255,255,0.08);\n    box-shadow:\n      0 40px 80px -30px rgba(0,0,0,0.9),\n      inset 0 1px 0 rgba(255,255,255,0.08),\n      inset 0 -1px 0 rgba(0,0,0,0.6);\n    padding: 20px 22px 18px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .machine::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      repeating-linear-gradient(0deg, rgba(255,255,255,0.012) 0 1px, transparent 1px 3px);\n    pointer-events: none;\n    mix-blend-mode: screen;\n  }\n\n  /* ---- header ---- */\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .logo {\n    width: 38px; height: 38px;\n    border-radius: 11px;\n    background: linear-gradient(145deg, var(--accent), var(--accent2));\n    box-shadow: 0 0 18px rgba(255,61,122,0.5), inset 0 1px 0 rgba(255,255,255,0.5);\n    display: grid; place-items: center;\n    position: relative;\n  }\n  .logo svg { width: 24px; height: 24px; display: block; }\n\n  .titles h1 {\n    font-size: 20px;\n    font-weight: 800;\n    letter-spacing: 1.5px;\n    background: linear-gradient(90deg, #fff, #cfe0ff);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles .sub {\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--dim);\n    margin-top: 2px;\n  }\n\n  /* ---- LED meter cluster ---- */\n  .meters { display: flex; gap: 5px; align-items: flex-end; height: 34px; }\n  .led-col { display: flex; flex-direction: column-reverse; gap: 2px; }\n  .led {\n    width: 5px; height: 3px;\n    border-radius: 1px;\n    background: rgba(255,255,255,0.08);\n    transition: background 60ms linear, box-shadow 60ms linear;\n  }\n  .led.on  { background: var(--accent2); box-shadow: 0 0 5px var(--accent2); }\n  .led.mid { background: #ffd23d; box-shadow: 0 0 5px #ffd23d; }\n  .led.hot { background: var(--accent); box-shadow: 0 0 7px var(--accent); }\n\n  /* ---- saw fan visualiser ---- */\n  .viz {\n    position: relative;\n    z-index: 2;\n    height: 132px;\n    border-radius: 14px;\n    background:\n      linear-gradient(180deg, rgba(61,140,255,0.05), rgba(0,0,0,0.4)),\n      #06080e;\n    border: 1px solid var(--line);\n    box-shadow: inset 0 2px 18px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(255,255,255,0.02);\n    overflow: hidden;\n    margin-bottom: 16px;\n  }\n  .viz canvas { display: block; width: 100%; height: 100%; }\n  .viz .tag {\n    position: absolute;\n    top: 8px; left: 12px;\n    font-size: 9px; letter-spacing: 2.5px;\n    color: var(--dim); text-transform: uppercase;\n  }\n\n  /* ---- knob grid ---- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px 10px;\n    position: relative;\n    z-index: 2;\n    margin-bottom: 16px;\n  }\n\n  .knob {\n    background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0.25));\n    border: 1px solid var(--line);\n    border-radius: 13px;\n    padding: 10px 6px 8px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n    user-select: none;\n    transition: border-color 160ms, box-shadow 160ms, transform 120ms;\n  }\n  .knob:hover { border-color: rgba(255,61,122,0.4); }\n  .knob.active {\n    border-color: rgba(255,61,122,0.7);\n    box-shadow: 0 0 22px -4px rgba(255,61,122,0.45);\n  }\n\n  .knob .dial { width: 64px; height: 64px; cursor: ns-resize; touch-action: none; }\n\n  .knob .name {\n    font-size: 9px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n  .knob .val {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    font-weight: 700;\n    color: var(--ink);\n    letter-spacing: 0.5px;\n  }\n  .knob.active .val { color: var(--accent); }\n\n  /* ---- keyboard ---- */\n  .kbd {\n    position: relative;\n    z-index: 2;\n    height: 92px;\n    border-radius: 12px;\n    background: #04050a;\n    border: 1px solid var(--line);\n    box-shadow: inset 0 3px 14px rgba(0,0,0,0.8);\n    padding: 8px;\n    display: flex;\n    gap: 0;\n  }\n  .keys { position: relative; flex: 1; height: 100%; }\n\n  .wkey {\n    position: absolute;\n    top: 0; bottom: 0;\n    border-radius: 0 0 6px 6px;\n    background: linear-gradient(180deg, #e9edf6, #b9c1d4);\n    border: 1px solid #2a2f3d;\n    box-shadow: inset 0 -6px 8px rgba(0,0,0,0.18);\n    cursor: pointer;\n    transition: background 70ms, box-shadow 70ms;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), #2a6bff);\n    box-shadow: inset 0 -4px 10px rgba(0,0,0,0.4), 0 0 16px rgba(61,140,255,0.6);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    height: 58%;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #20242f, #05060a);\n    border: 1px solid #000;\n    box-shadow: inset 0 -3px 4px rgba(255,255,255,0.06), 0 3px 6px rgba(0,0,0,0.6);\n    cursor: pointer;\n    z-index: 3;\n    transition: background 70ms, box-shadow 70ms;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #c01f54);\n    box-shadow: 0 0 16px rgba(255,61,122,0.7);\n  }\n\n  footer {\n    margin-top: 12px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n    position: relative;\n    z-index: 2;\n  }\n  .hint { font-size: 8.5px; letter-spacing: 1px; text-transform: none; color: #4d566e; }\n</style>\n</head>\n<body>\n  <div class=\"machine\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\" fill=\"none\">\n            <path d=\"M2 18 L7 6 L7 18 L12 6 L12 18 L17 6 L17 18 L22 6\"\n                  stroke=\"#fff\" stroke-width=\"1.6\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"titles\">\n          <h1>HYPER VA</h1>\n          <div class=\"sub\">Hypersaw Virtual Analog</div>\n        </div>\n      </div>\n      <div class=\"meters\" id=\"meters\"></div>\n    </header>\n\n    <div class=\"viz\">\n      <span class=\"tag\">Saw Stack</span>\n      <canvas id=\"viz\"></canvas>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"kbd\">\n      <div class=\"keys\" id=\"keys\"></div>\n    </div>\n\n    <footer>\n      <span>POLY · 8 VOICES</span>\n      <span class=\"hint\">drag knobs · double-click to reset · play the keys</span>\n      <span>48k</span>\n    </footer>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match assembly.ts / spec.json) ----\n  var PARAMS = [\n    { name: \"Detune\",   index: 0, min: 0, max: 1, def: 0.45 },\n    { name: \"Cutoff\",   index: 1, min: 0, max: 1, def: 0.60 },\n    { name: \"Reso\",     index: 2, min: 0, max: 1, def: 0.30 },\n    { name: \"Env Amt\",  index: 3, min: 0, max: 1, def: 0.55 },\n    { name: \"Spread\",   index: 4, min: 0, max: 1, def: 0.70 },\n    { name: \"Attack\",   index: 5, min: 0, max: 1, def: 0.05 },\n    { name: \"Release\",  index: 6, min: 0, max: 1, def: 0.40 },\n    { name: \"Level\",    index: 7, min: 0, max: 1, def: 0.70 }\n  ];\n\n  var values = {};\n\n  function vstaiReady(fn) {\n    if (window.vstai && typeof window.vstai.onReady === \"function\") {\n      window.vstai.onReady(fn);\n    } else {\n      fn();\n    }\n  }\n\n  function pushParam(p) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(p.index, values[p.index]);\n    }\n  }\n\n  // ---- knob factory ----\n  var rack = document.getElementById(\"rack\");\n\n  function fmt(p) {\n    var v = values[p.index];\n    if (p.name === \"Cutoff\") {\n      var hz = 80 * Math.pow(225, v);\n      return hz >= 1000 ? (hz / 1000).toFixed(1) + \"k\" : Math.round(hz) + \"\";\n    }\n    if (p.name === \"Attack\")  return (2.0 * v * 1000 + 2).toFixed(0) + \"ms\";\n    if (p.name === \"Release\") return (3.0 * v + 0.01).toFixed(2) + \"s\";\n    return Math.round(v * 100) + \"%\";\n  }\n\n  function buildKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob\";\n\n    var dial = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\");\n    dial.setAttribute(\"viewBox\", \"0 0 100 100\");\n    dial.className = \"dial\";\n\n    // static rim\n    var rim = arc(50, 50, 38, -135, 135);\n    var track = path(rim, \"rgba(255,255,255,0.08)\", 7);\n    dial.appendChild(track);\n\n    // value arc (gradient stroke via id)\n    var gradId = \"g\" + p.index;\n    var defs = document.createElementNS(\"http://www.w3.org/2000/svg\", \"defs\");\n    var lg = document.createElementNS(\"http://www.w3.org/2000/svg\", \"linearGradient\");\n    lg.id = gradId;\n    lg.setAttribute(\"x1\", \"0\"); lg.setAttribute(\"y1\", \"0\");\n    lg.setAttribute(\"x2\", \"1\"); lg.setAttribute(\"y2\", \"1\");\n    var st1 = document.createElementNS(\"http://www.w3.org/2000/svg\", \"stop\");\n    st1.setAttribute(\"offset\", \"0%\"); st1.setAttribute(\"stop-color\", \"#ff3d7a\");\n    var st2 = document.createElementNS(\"http://www.w3.org/2000/svg\", \"stop\");\n    st2.setAttribute(\"offset\", \"100%\"); st2.setAttribute(\"stop-color\", \"#3d8cff\");\n    lg.appendChild(st1); lg.appendChild(st2); defs.appendChild(lg);\n    dial.appendChild(defs);\n\n    var fill = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n    fill.setAttribute(\"fill\", \"none\");\n    fill.setAttribute(\"stroke\", \"url(#\" + gradId + \")\");\n    fill.setAttribute(\"stroke-width\", \"7\");\n    fill.setAttribute(\"stroke-linecap\", \"round\");\n    dial.appendChild(fill);\n\n    // body\n    var body = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"#0c0f17\");\n    body.setAttribute(\"stroke\", \"rgba(255,255,255,0.1)\");\n    dial.appendChild(body);\n\n    // pointer\n    var ptr = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n    ptr.setAttribute(\"stroke\", \"#fff\");\n    ptr.setAttribute(\"stroke-width\", \"3\");\n    ptr.setAttribute(\"stroke-linecap\", \"round\");\n    dial.appendChild(ptr);\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\"; name.textContent = p.name;\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(dial);\n    cell.appendChild(val);\n    cell.appendChild(name);\n    rack.appendChild(cell);\n\n    function render() {\n      var v = values[p.index];\n      var t = (v - p.min) / (p.max - p.min);\n      var a = -135 + t * 270;\n      fill.setAttribute(\"d\", arc(50, 50, 38, -135, a));\n      var rad = (a - 90) * Math.PI / 180;\n      ptr.setAttribute(\"x1\", 50 + Math.cos(rad) * 11);\n      ptr.setAttribute(\"y1\", 50 + Math.sin(rad) * 11);\n      ptr.setAttribute(\"x2\", 50 + Math.cos(rad) * 24);\n      ptr.setAttribute(\"y2\", 50 + Math.sin(rad) * 24);\n      val.textContent = fmt(p);\n    }\n\n    function setNorm(t) {\n      t = Math.max(0, Math.min(1, t));\n      values[p.index] = p.min + t * (p.max - p.min);\n      render();\n      pushParam(p);\n    }\n\n    // drag\n    var dragging = false, startY = 0, startV = 0;\n    dial.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; startY = e.clientY;\n      startV = (values[p.index] - p.min) / (p.max - p.min);\n      cell.classList.add(\"active\");\n      dial.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    dial.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = (startY - e.clientY) / 180;\n      setNorm(startV + dy);\n    });\n    dial.addEventListener(\"pointerup\", function (e) {\n      dragging = false; cell.classList.remove(\"active\");\n    });\n    dial.addEventListener(\"pointercancel\", function () {\n      dragging = false; cell.classList.remove(\"active\");\n    });\n    dial.addEventListener(\"dblclick\", function () {\n      values[p.index] = p.def; render(); pushParam(p);\n    });\n    dial.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var t = (values[p.index] - p.min) / (p.max - p.min);\n      setNorm(t - e.deltaY * 0.0006);\n    }, { passive: false });\n\n    values[p.index] = p.def;\n    render();\n  }\n\n  // polar arc path helper\n  function arc(cx, cy, r, a0, a1) {\n    var p0 = pol(cx, cy, r, a0);\n    var p1 = pol(cx, cy, r, a1);\n    var large = (a1 - a0) <= 180 ? 0 : 1;\n    return \"M \" + p0.x + \" \" + p0.y + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + p1.x + \" \" + p1.y;\n  }\n  function pol(cx, cy, r, deg) {\n    var rad = (deg - 90) * Math.PI / 180;\n    return { x: cx + r * Math.cos(rad), y: cy + r * Math.sin(rad) };\n  }\n  function path(d, stroke, w) {\n    var pe = document.createElementNS(\"http://www.w3.org/2000/svg\", \"path\");\n    pe.setAttribute(\"d\", d); pe.setAttribute(\"fill\", \"none\");\n    pe.setAttribute(\"stroke\", stroke); pe.setAttribute(\"stroke-width\", w);\n    pe.setAttribute(\"stroke-linecap\", \"round\");\n    return pe;\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  // ---- LED meters ----\n  var meters = document.getElementById(\"meters\");\n  var ledRows = [];\n  for (var c = 0; c < 8; c++) {\n    var col = document.createElement(\"div\");\n    col.className = \"led-col\";\n    var leds = [];\n    for (var i = 0; i < 9; i++) {\n      var led = document.createElement(\"div\");\n      led.className = \"led\";\n      col.appendChild(led);\n      leds.push(led);\n    }\n    meters.appendChild(col);\n    ledRows.push(leds);\n  }\n\n  // ---- saw fan visualiser ----\n  var canvas = document.getElementById(\"viz\");\n  var ctx = canvas.getContext(\"2d\");\n  var DPR = window.devicePixelRatio || 1;\n\n  function resize() {\n    var r = canvas.getBoundingClientRect();\n    canvas.width = r.width * DPR;\n    canvas.height = r.height * DPR;\n  }\n  window.addEventListener(\"resize\", resize);\n  resize();\n\n  var activity = 0;   // 0..1 envelope follower for playing intensity\n  var t0 = performance.now();\n\n  function draw(now) {\n    var w = canvas.width, h = canvas.height;\n    ctx.clearRect(0, 0, w, h);\n\n    var time = (now - t0) / 1000;\n    var detune = values[0], cutoff = values[1], spread = values[4];\n\n    // background glow\n    var g = ctx.createRadialGradient(w * 0.5, h * 1.1, 0, w * 0.5, h * 1.1, w * 0.7);\n    g.addColorStop(0, \"rgba(61,140,255,\" + (0.05 + activity * 0.12).toFixed(3) + \")\");\n    g.addColorStop(1, \"rgba(0,0,0,0)\");\n    ctx.fillStyle = g;\n    ctx.fillRect(0, 0, w, h);\n\n    var mid = h * 0.5;\n    var saws = 7;\n    for (var s = 0; s < saws; s++) {\n      var off = (s - 3) / 3;                 // -1..1\n      var detAmt = off * detune;             // detune fans them apart\n      var freq = 3.0 + detAmt * 2.4;         // visual cycles across width\n      var panX = off * spread;               // horizontal shift = stereo spread\n      var amp = (h * 0.22) * (0.55 + cutoff * 0.55) * (0.4 + activity * 0.9);\n      var phase = time * (1.4 + detAmt * 1.1) + s * 0.5;\n\n      var hue = s / (saws - 1);\n      var col = mixColor(\"#ff3d7a\", \"#3d8cff\", hue);\n      var glow = 0.22 + activity * 0.55;\n      ctx.strokeStyle = \"rgba(\" + col + \",\" + glow.toFixed(3) + \")\";\n      ctx.lineWidth = (s === 3 ? 2.2 : 1.3) * DPR;\n      ctx.beginPath();\n      var step = Math.max(2, Math.floor(w / 220));\n      for (var x = 0; x <= w; x += step) {\n        var u = x / w;\n        // sawtooth shape\n        var ph = (u * freq + phase) % 1;\n        var saw = (ph * 2 - 1);\n        var yy = mid + saw * amp + panX * w * 0.04 * 0 + Math.sin(u * 6.28 + phase) * 0 ;\n        // horizontal pan offset shifts the whole wave left/right visually\n        var xx = x + panX * w * 0.06;\n        if (x === 0) ctx.moveTo(xx, yy); else ctx.lineTo(xx, yy);\n      }\n      ctx.stroke();\n    }\n\n    // decay activity\n    activity *= 0.94;\n\n    // update LED meters from activity + level\n    var level = values[7];\n    var lit = Math.round(activity * level * 9);\n    for (var ci = 0; ci < ledRows.length; ci++) {\n      var jitter = Math.round(Math.sin(time * 9 + ci) * 1.5);\n      var n = Math.max(0, Math.min(9, lit + jitter));\n      for (var li = 0; li < 9; li++) {\n        var on = li < n;\n        var cls = \"led\";\n        if (on) cls += li >= 7 ? \" hot\" : (li >= 5 ? \" mid\" : \" on\");\n        ledRows[ci][li].className = cls;\n      }\n    }\n\n    requestAnimationFrame(loop);\n  }\n\n  function loop(now) {\n    if (document.hidden) { return; }\n    draw(now);\n  }\n\n  function mixColor(a, b, t) {\n    var pa = hex(a), pb = hex(b);\n    var r = Math.round(pa[0] + (pb[0] - pa[0]) * t);\n    var g = Math.round(pa[1] + (pb[1] - pa[1]) * t);\n    var bl = Math.round(pa[2] + (pb[2] - pa[2]) * t);\n    return r + \",\" + g + \",\" + bl;\n  }\n  function hex(h) {\n    return [parseInt(h.slice(1, 3), 16), parseInt(h.slice(3, 5), 16), parseInt(h.slice(5, 7), 16)];\n  }\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden) requestAnimationFrame(loop);\n  });\n  requestAnimationFrame(loop);\n\n  // ---- on-screen keyboard ----\n  var keysEl = document.getElementById(\"keys\");\n  var START = 48;   // C3\n  var OCTAVES = 2;\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 1: 0, 3: 1, 6: 3, 8: 4, 10: 5 };\n  var whiteCount = WHITE.length * OCTAVES + 1;\n  var down = {};\n\n  function buildKeys() {\n    var wW = 100 / whiteCount;\n    var idx = 0;\n    var notes = [];\n    for (var o = 0; o < OCTAVES; o++) {\n      for (var i = 0; i < 12; i++) notes.push(START + o * 12 + i);\n    }\n    notes.push(START + OCTAVES * 12); // top C\n\n    // whites first\n    var whiteOrder = [];\n    notes.forEach(function (n) {\n      var pc = n % 12;\n      if (WHITE.indexOf(pc) >= 0) whiteOrder.push(n);\n    });\n    whiteOrder.forEach(function (n, w) {\n      var k = document.createElement(\"div\");\n      k.className = \"wkey\";\n      k.style.left = (w * wW) + \"%\";\n      k.style.width = wW + \"%\";\n      k.dataset.note = n;\n      keysEl.appendChild(k);\n      bindKey(k, n);\n    });\n\n    // blacks positioned relative to preceding white\n    var wpos = 0;\n    notes.forEach(function (n) {\n      var pc = n % 12;\n      if (WHITE.indexOf(pc) >= 0) { wpos++; return; }\n      if (pc in BLACK) {\n        var k = document.createElement(\"div\");\n        k.className = \"bkey\";\n        var left = (wpos * wW) - (wW * 0.3);\n        k.style.left = left + \"%\";\n        k.style.width = (wW * 0.6) + \"%\";\n        k.dataset.note = n;\n        keysEl.appendChild(k);\n        bindKey(k, n);\n      }\n    });\n  }\n\n  function noteOn(n) {\n    if (down[n]) return;\n    down[n] = true;\n    activity = Math.min(1, activity + 0.6);\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, 0.9);\n  }\n  function noteOff(n) {\n    if (!down[n]) return;\n    down[n] = false;\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  function bindKey(el, n) {\n    el.addEventListener(\"pointerdown\", function (e) {\n      el.classList.add(\"down\"); noteOn(n);\n      el.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    el.addEventListener(\"pointerup\", function () {\n      el.classList.remove(\"down\"); noteOff(n);\n    });\n    el.addEventListener(\"pointerleave\", function (e) {\n      if (e.buttons) { el.classList.remove(\"down\"); noteOff(n); }\n    });\n    el.addEventListener(\"pointerenter\", function (e) {\n      if (e.buttons) { el.classList.add(\"down\"); noteOn(n); }\n    });\n    el.addEventListener(\"pointercancel\", function () {\n      el.classList.remove(\"down\"); noteOff(n);\n    });\n  }\n\n  // computer keyboard mapping (A W S E D ...)\n  var KEYMAP = { a: 0, w: 1, s: 2, e: 3, d: 4, f: 5, t: 6, g: 7, y: 8, h: 9, u: 10, j: 11, k: 12 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m === undefined) return;\n    var n = START + m;\n    noteOn(n);\n    var el = keysEl.querySelector('[data-note=\"' + n + '\"]');\n    if (el) el.classList.add(\"down\");\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m === undefined) return;\n    var n = START + m;\n    noteOff(n);\n    var el = keysEl.querySelector('[data-note=\"' + n + '\"]');\n    if (el) el.classList.remove(\"down\");\n  });\n\n  buildKeys();\n\n  // ---- push all defaults to the engine on load ----\n  vstaiReady(function () {\n    PARAMS.forEach(function (p) { pushParam(p); });\n  });\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  HYPER VA — a modern hypersaw virtual-analog polyphonic synthesizer.\n//  Lineage of the big digital VA leads/pads: each of 8 voices runs a\n//  SUPERSAW oscillator — 7 detuned band-limited saws stacked around the\n//  played pitch — plus a square sub an octave down. The stack feeds a\n//  bright resonant 4-pole low-pass driven by its own envelope, then an\n//  amplitude AR envelope. The 7 saws are panned across the stereo field\n//  by Spread to bloom into a huge, shimmering trance lead/pad. Bright\n//  DIGITAL character (no vintage warmth/drift). Pure algorithm, no\n//  samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\nconst NUM_SAWS: i32 = 7;          // detuned saws per supersaw stack\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_DETUNE:  i32 = 0;  // 0..1  -> supersaw detune spread\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount\nconst P_SPREAD:  i32 = 4;  // 0..1  -> stereo width of the saw stack\nconst P_ATTACK:  i32 = 5;  // 0..1  -> seconds\nconst P_RELEASE: i32 = 6;  // 0..1  -> seconds\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- relative detune offsets of the 7 saws (centre = 0) --------------\n// JP-style asymmetric spread; scaled by the Detune param at run time.\nconst sawOffset: StaticArray<f32> = new StaticArray<f32>(NUM_SAWS);\n// fixed stereo pan position for each saw (-1..+1), scaled by Spread.\nconst sawPanBase: StaticArray<f32> = new StaticArray<f32>(NUM_SAWS);\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// supersaw phases: NUM_VOICES * NUM_SAWS, plus a sub phase per voice\nconst vSawPhase: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES * NUM_SAWS);\nconst vSubPhase: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// amplitude AR envelope\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\n// filter AR envelope\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// 4-pole low-pass state per voice, run on the LEFT and RIGHT sums.\nconst vFL0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFL1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFL2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFL3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFR0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFR1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFR2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFR3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n\n  // symmetric, slightly irregular detune offsets so beating is rich.\n  sawOffset[0] = -1.00;\n  sawOffset[1] = -0.62;\n  sawOffset[2] = -0.27;\n  sawOffset[3] =  0.00;   // centre saw, no detune\n  sawOffset[4] =  0.31;\n  sawOffset[5] =  0.66;\n  sawOffset[6] =  1.00;\n\n  // alternating L/R pan layout; centre saw stays centred.\n  sawPanBase[0] = -1.00;\n  sawPanBase[1] =  0.66;\n  sawPanBase[2] = -0.40;\n  sawPanBase[3] =  0.00;\n  sawPanBase[4] =  0.40;\n  sawPanBase[5] = -0.66;\n  sawPanBase[6] =  1.00;\n\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vSubPhase[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vFL0[v] = 0.0; vFL1[v] = 0.0; vFL2[v] = 0.0; vFL3[v] = 0.0;\n    vFR0[v] = 0.0; vFR1[v] = 0.0; vFR2[v] = 0.0; vFR3[v] = 0.0;\n    for (let s = 0; s < NUM_SAWS; s++) {\n      // spread starting phases so the stack does not start phase-locked\n      vSawPhase[v * NUM_SAWS + s] = f32(s) * 0.137;\n    }\n  }\n  ageCounter = 0;\n\n  params[P_DETUNE]  = 0.45;\n  params[P_CUTOFF]  = 0.6;\n  params[P_RESO]    = 0.3;\n  params[P_ENVAMT]  = 0.55;\n  params[P_SPREAD]  = 0.7;\n  params[P_ATTACK]  = 0.05;\n  params[P_RELEASE] = 0.4;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n  vSubPhase[slot] = 0.0;\n  vFL0[slot] = 0.0; vFL1[slot] = 0.0; vFL2[slot] = 0.0; vFL3[slot] = 0.0;\n  vFR0[slot] = 0.0; vFR1[slot] = 0.0; vFR2[slot] = 0.0; vFR3[slot] = 0.0;\n  for (let s = 0; s < NUM_SAWS; s++) {\n    vSawPhase[slot * NUM_SAWS + s] = f32(s) * 0.137;\n  }\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 3;  // release\n      vFStage[i] = 3;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const spreadN: f32 = clampf(params[P_SPREAD], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 2.0;\n  const relS: f32 = 0.010 + clampf(params[P_RELEASE], 0.0, 1.0) * 3.0;\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune amount: up to ~ +/- 0.55 semitone at the extreme saws -> huge\n  const detSemi: f32 = detuneN * 0.55;\n\n  // base cutoff in Hz, exponential 80 Hz .. ~18 kHz (bright digital top)\n  const baseHz: f32 = 80.0 * f32(Mathf.pow(225.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6.5 octaves\n  const envOct: f32 = envAmt * 6.5;\n  // resonance feedback 0..~3.8\n  const reso: f32 = resoN * 3.8;\n\n  // per-saw equal-power pan gains depend only on params -> compute once.\n  // (kept in locals; NUM_SAWS is small and fixed.)\n  const sp: f32 = spreadN;\n\n  // headroom: 8 voices * (supersaw+sub) summed -> normalise.\n  // supersaw normalised internally to ~unit; voice gain modest.\n  const voiceScale: f32 = 0.34;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n    let outR: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR envelope --------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // sustain (held at 1)\n        aenv = 1.0;\n      } else if (astg == 3) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter AR envelope -----------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv = 1.0;\n      } else if (fstg == 3) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- supersaw: 7 detuned saws, panned across the field ----\n      const baseInc: f32 = vFreq[v] / sr;\n      const phBase: i32 = v * NUM_SAWS;\n\n      let sawL: f32 = 0.0;\n      let sawR: f32 = 0.0;\n\n      for (let s = 0; s < NUM_SAWS; s++) {\n        // detune ratio for this saw\n        const semi: f32 = sawOffset[s] * detSemi;\n        const ratio: f32 = f32(Mathf.pow(2.0, semi / 12.0));\n        const inc: f32 = baseInc * ratio;\n\n        let p: f32 = vSawPhase[phBase + s];\n        p += inc; if (p >= 1.0) p -= 1.0;\n        let saw: f32 = 2.0 * p - 1.0;\n        saw -= polyBlep(p, inc);\n        vSawPhase[phBase + s] = p;\n\n        // the centre saw is a touch louder for a defined pitch core\n        const sg: f32 = s == 3 ? 0.85 : 0.6;\n\n        // pan: equal-power, position = base pan * spread\n        const pan: f32 = sawPanBase[s] * sp;            // -1..+1\n        const ang: f32 = (pan * 0.5 + 0.5) * (PI * 0.5); // 0..pi/2\n        const gl: f32 = f32(Mathf.cos(ang));\n        const gr: f32 = f32(Mathf.sin(ang));\n\n        const sv: f32 = saw * sg;\n        sawL += sv * gl;\n        sawR += sv * gr;\n      }\n\n      // normalise the stack (sum of ~7 weighted saws)\n      const norm: f32 = 0.32;\n      sawL *= norm;\n      sawR *= norm;\n\n      // ---- square sub one octave down (mono, centred) -----------\n      let subp: f32 = vSubPhase[v];\n      const subInc: f32 = baseInc * 0.5;\n      subp += subInc; if (subp >= 1.0) subp -= 1.0;\n      vSubPhase[v] = subp;\n      const sub: f32 = subp < 0.5 ? 0.28 : -0.28;\n\n      let inL: f32 = sawL + sub;\n      let inR: f32 = sawR + sub;\n\n      // ---- bright resonant 4-pole low-pass (per channel) --------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      // LEFT ladder\n      let l0: f32 = vFL0[v];\n      let l1: f32 = vFL1[v];\n      let l2: f32 = vFL2[v];\n      let l3: f32 = vFL3[v];\n      let il: f32 = inL - reso * l3;\n      il = f32(Mathf.tanh(il));\n      l0 += g * (il - l0);\n      l1 += g * (l0 - l1);\n      l2 += g * (l1 - l2);\n      l3 += g * (l2 - l3);\n      vFL0[v] = l0; vFL1[v] = l1; vFL2[v] = l2; vFL3[v] = l3;\n\n      // RIGHT ladder\n      let r0: f32 = vFR0[v];\n      let r1: f32 = vFR1[v];\n      let r2: f32 = vFR2[v];\n      let r3: f32 = vFR3[v];\n      let ir: f32 = inR - reso * r3;\n      ir = f32(Mathf.tanh(ir));\n      r0 += g * (ir - r0);\n      r1 += g * (r0 - r1);\n      r2 += g * (r1 - r2);\n      r3 += g * (r2 - r3);\n      vFR0[v] = r0; vFR1[v] = r1; vFR2[v] = r2; vFR3[v] = r3;\n\n      const amp: f32 = aenv * vVel[v];\n      outL += l3 * amp;\n      outR += r3 * amp;\n    }\n\n    // ---- sum + gentle soft clip + output level ------------------\n    let mixL: f32 = outL * voiceScale;\n    let mixR: f32 = outR * voiceScale;\n    mixL = f32(Mathf.tanh(mixL * 1.1)) * level;\n    mixR = f32(Mathf.tanh(mixR * 1.1)) * level;\n\n    outBuf[f] = mixL;\n    outBuf[MAX_FRAMES + f] = mixR;\n  }\n}\n",
  "publishedAt": 1751000103000
}