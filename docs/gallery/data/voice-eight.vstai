  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Voice Eight</title>\n<style>\n  :root{ --acc:#8ab0d0; --acc2:#ffcf6a; --bg0:#0a0c0f; --bg1:#161b22; --ink:#eef2f7; --dim:#7a8694; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#222a34 0%,var(--bg1) 44%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#222a34,#0b0e13); border:1px solid rgba(138,176,208,.2); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.4s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:92px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0c1016,#0a0e13); border:1px solid rgba(138,176,208,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; } .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(200,215,230,.14); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(138,176,208,.6)); }\n  .pcap{ fill:#0c1016; stroke:rgba(138,176,208,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(138,176,208,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(138,176,208,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">VOICE&nbsp;EIGHT</span><span class=\"sub\">unison analog poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">UNISON</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.6},{name:\"Reso\",idx:1,def:0.3},{name:\"Env\",idx:2,def:0.5},{name:\"Spread\",idx:3,def:0.35},{name:\"Sub\",idx:4,def:0.4},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#8ab0d0\"/><stop offset=\"1\" stop-color=\"#ffcf6a\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], spread=vals[3], sub=vals[4]; var mid=H*0.55;\n    function saw(off,col,amp){ ctx.beginPath(); for(var x=0;x<=W;x+=2){ var t=x/W; var v=(2*((t*3+ts/700+off)%1)-1)*(0.4+cut*0.5); ctx.lineTo(x, mid+v*amp); } ctx.strokeStyle=col; ctx.lineWidth=1.6; ctx.shadowColor=col; ctx.shadowBlur=5; ctx.stroke(); ctx.shadowBlur=0; }\n    saw(0,\"rgba(138,176,208,0.85)\",13); saw(spread*0.4,\"rgba(138,176,208,0.6)\",12); saw(-spread*0.4,\"rgba(255,207,106,\"+(0.3+spread*0.5)+\")\",11);\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  VOICE EIGHT — a fat unison analog poly (Oberheim Four/Eight Voice\n//  lineage): each voice stacks two detuned saws + a sub through a smooth\n//  resonant low-pass with its own envelope, with a wide unison Spread for\n//  the huge stacked-SEM choir/brass. 8-voice poly. No host imports, no\n//  allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vA: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vB: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSubp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vDrift: StaticArray<f32> = new StaticArray<f32>(NVOX);   // slow analog pitch drift per voice\nconst vGL: StaticArray<f32> = new StaticArray<f32>(NVOX);      // per-voice equal-power pan gain L\nconst vGR: StaticArray<f32> = new StaticArray<f32>(NVOX);      // per-voice equal-power pan gain R\nconst PANTAB: StaticArray<f32> = new StaticArray<f32>(NVOX);   // interleaved pan spread (any chord fans wide)\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\nlet rngState: i32 = 0x51f7a3;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_SPREAD: i32 = 3; const P_SUB: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0; rngState = 0x51f7a3;\n  // interleaved so slots fill center -> wide, keeping any voice count spread\n  PANTAB[0] = 0.0; PANTAB[1] = -0.78; PANTAB[2] = 0.78; PANTAB[3] = -0.4; PANTAB[4] = 0.4; PANTAB[5] = -1.0; PANTAB[6] = 1.0; PANTAB[7] = 0.16;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vA[i] = 0.0; vB[i] = 0.0; vSubp[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; vDrift[i] = 0.0; vGL[i] = 0.707; vGR[i] = 0.707; }\n  params[P_CUTOFF] = 0.6; params[P_RESO] = 0.3; params[P_ENV] = 0.5; params[P_SPREAD] = 0.35; params[P_SUB] = 0.4; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vA[slot] = 0.0; vB[slot] = 0.0; vSubp[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0); vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const spreadN: f32 = clampf(params[P_SPREAD], 0.0, 1.0);\n  const subN: f32 = clampf(params[P_SUB], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.008 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.45 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.6 * sampleRate)));\n  const baseCut: f32 = 50.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const envSpan: f32 = envN * 7000.0;\n  const k: f32 = 2.0 - 1.9 * resoN;\n  const det: f32 = 1.0 + spreadN * 0.05;\n  const out: f32 = level * 0.4;\n  // Spread also fans the voices across the stereo field (equal-power pan)\n  const width: f32 = spreadN * 0.92;\n  for (let s = 0; s < NVOX; s++) {\n    const pan: f32 = PANTAB[s] * width;   // interleaved spread\n    vGL[s] = f32(Mathf.sqrt(0.5 * (1.0 - pan)));\n    vGR[s] = f32(Mathf.sqrt(0.5 * (1.0 + pan)));\n  }\n  const driftLeak: f32 = 0.9998;\n  const driftStep: f32 = 0.00006;   // ~+/-5 cents slow analog tuning drift\n\n  for (let i = 0; i < n; i++) {\n    let mixL: f32 = 0.0; let mixR: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      // slow bounded random-walk drift so each voice breathes like real analog\n      vDrift[s] = vDrift[s] * driftLeak + rnd() * driftStep;\n      const fr: f32 = vFreq[s] * (1.0 + vDrift[s]);\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let a: f32 = vA[s] + fr / sampleRate; if (a >= 1.0) a -= 1.0; vA[s] = a;\n      let b: f32 = vB[s] + (fr * det) / sampleRate; if (b >= 1.0) b -= 1.0; vB[s] = b;\n      let sp: f32 = vSubp[s] + (fr * 0.5) / sampleRate; if (sp >= 1.0) sp -= 1.0; vSubp[s] = sp;\n      const saw1: f32 = a * 2.0 - 1.0;\n      const saw2: f32 = b * 2.0 - 1.0;\n      const sub: f32 = sp < 0.5 ? 0.7 : -0.7;\n      let osc: f32 = (saw1 + saw2 + sub * subN) * 0.4;\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const val: f32 = lpN * vAmp[s] * vVel[s];\n      mixL += val * vGL[s]; mixR += val * vGR[s];\n    }\n    let oL: f32 = mixL * out; let oR: f32 = mixR * out;\n    if (oL > 1.4) oL = 1.4; else if (oL < -1.4) oL = -1.4;\n    if (oR > 1.4) oR = 1.4; else if (oR < -1.4) oR = -1.4;\n    outBuf[i] = oL; outBuf[MAX_FRAMES + i] = oR;\n  }\n}\n",
  "publishedAt": 1751000177000
}