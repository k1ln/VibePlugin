{
  "format": 1,
  "name": "Ladder Filter",
  "isInstrument": false,
  "explanation": "A 4-pole (24 dB/oct) resonant transistor-ladder low-pass filter. Four cascaded one-pole stages share a resonance feedback path that can climb all the way to self-oscillation, while gentle tanh saturation in the loop tames the peak and adds warm analog growl. Controls: Cutoff, Resonance, Drive and dry/wet Mix.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Drive",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Ladder Filter</title>\n<style>\n  :root{\n    --ac:#66e0c0; --ac2:#54d1ff;\n    --panel:#161b22; --panel2:#0c0f15;\n    --screw:#2a3340;\n    --ink:#cdd9e6; --ink2:#7f8ea3;\n  }\n  *{box-sizing:border-box}\n  html,body{margin:0;height:100%}\n  body{\n    font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace;color:var(--ink);\n    background:\n      radial-gradient(120% 90% at 50% -10%, #1b2330 0%, #0a0d12 60%, #05070a 100%);\n    display:flex;align-items:center;justify-content:center;padding:16px;overflow:hidden;\n    -webkit-user-select:none;user-select:none;\n  }\n\n  /* ---- the eurorack-style module faceplate ---- */\n  .module{\n    position:relative;width:100%;max-width:560px;\n    border-radius:10px;padding:0;overflow:hidden;\n    background:\n      linear-gradient(180deg,#20262f 0%,#171c24 4%,#13171e 96%,#0d1016 100%);\n    border:1px solid rgba(255,255,255,.07);\n    box-shadow:\n      0 36px 80px rgba(0,0,0,.66),\n      inset 0 1px 0 rgba(255,255,255,.10),\n      inset 0 0 0 1px rgba(0,0,0,.5);\n    animation:rackIn .6s cubic-bezier(.2,.8,.25,1) both;\n  }\n  @keyframes rackIn{from{opacity:0;transform:translateY(14px) rotateX(8deg)}to{opacity:1;transform:none}}\n  /* brushed-metal vertical streaks */\n  .module::before{\n    content:\"\";position:absolute;inset:0;pointer-events:none;opacity:.35;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.02) 0 1px,transparent 1px 3px);\n    mix-blend-mode:overlay;\n  }\n  /* corner mounting screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;z-index:6;\n    background:radial-gradient(circle at 35% 30%,#465264,#1a1f28 70%,#0c0f14);\n    box-shadow:inset 0 1px 1px rgba(255,255,255,.25),0 1px 2px rgba(0,0,0,.6)}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#0a0d12 44% 56%,transparent 56%);\n    transform:rotate(35deg)}\n  .screw.tl{top:8px;left:8px}.screw.tr{top:8px;right:8px}\n  .screw.bl{bottom:8px;left:8px}.screw.br{bottom:8px;right:8px}\n\n  /* ---- header / name plate ---- */\n  .head{position:relative;z-index:2;display:flex;align-items:center;gap:11px;\n    padding:14px 22px 10px;border-bottom:1px solid rgba(0,0,0,.5);\n    box-shadow:0 1px 0 rgba(255,255,255,.05)}\n  .pwr{position:relative;width:10px;height:10px;border-radius:50%;flex:none;\n    background:var(--ac);box-shadow:0 0 10px var(--ac);animation:beat 2.6s ease-in-out infinite}\n  @keyframes beat{0%,100%{opacity:.5;box-shadow:0 0 5px var(--ac)}50%{opacity:1;box-shadow:0 0 14px var(--ac)}}\n  .title{flex:1;min-width:0}\n  .title b{display:block;font:700 16px ui-monospace,monospace;letter-spacing:.26em;\n    color:#eaf2f8;text-shadow:0 1px 0 rgba(0,0,0,.6)}\n  .title .mod{display:block;font-size:9px;letter-spacing:.42em;color:var(--ink2);margin-top:3px}\n  .hp{font-size:9px;letter-spacing:.2em;color:var(--ink2);text-align:right;line-height:1.5}\n  .hp span{color:var(--ac2)}\n\n  /* ---- layout: scope on top, controls + ladder below ---- */\n  .body{position:relative;z-index:2;padding:14px 18px 16px;display:grid;\n    grid-template-columns:1fr 86px;gap:14px}\n\n  /* ===== frequency-response scope ===== */\n  .scope{position:relative;border-radius:8px;overflow:hidden;\n    background:\n      radial-gradient(120% 140% at 50% 0%,#0a1f1c 0%,#060a0d 70%);\n    border:1px solid rgba(255,255,255,.06);\n    box-shadow:inset 0 2px 16px rgba(0,0,0,.7),inset 0 0 0 1px rgba(0,0,0,.5);\n    height:150px}\n  .scope svg{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .grid line{stroke:rgba(102,224,192,.10);stroke-width:1}\n  .curve{fill:none;stroke:var(--ac);stroke-width:2.2;\n    filter:drop-shadow(0 0 5px var(--ac));stroke-linejoin:round;stroke-linecap:round}\n  .fill{fill:url(#fillg);opacity:.5}\n  .ch{fill:none;stroke:rgba(255,255,255,.04);stroke-width:1}\n  .scan{position:absolute;inset:0;pointer-events:none;opacity:.5;\n    background:repeating-linear-gradient(0deg,transparent 0 3px,rgba(0,0,0,.25) 3px 4px)}\n  .cutline{stroke:var(--ac2);stroke-width:1;stroke-dasharray:3 4;opacity:.55}\n  .cutdot{fill:var(--ac2);filter:drop-shadow(0 0 6px var(--ac2))}\n  .scopelbl{position:absolute;left:8px;top:6px;font-size:8px;letter-spacing:.18em;\n    color:var(--ink2);z-index:3}\n  .scopelbl b{color:var(--ac)}\n  .scopehz{position:absolute;right:8px;bottom:5px;font-size:8px;letter-spacing:.1em;\n    color:var(--ink2);z-index:3;font-variant-numeric:tabular-nums}\n  .scopehz b{color:var(--ac2)}\n\n  /* ===== resonance ladder (right column) ===== */\n  .ladder{display:flex;flex-direction:column;align-items:center;gap:5px;\n    padding:8px 6px;border-radius:8px;\n    background:linear-gradient(180deg,rgba(0,0,0,.35),rgba(0,0,0,.15));\n    border:1px solid rgba(255,255,255,.05);box-shadow:inset 0 2px 10px rgba(0,0,0,.6)}\n  .ladder .lbl{font-size:8px;letter-spacing:.18em;color:var(--ink2);margin-bottom:2px}\n  .rails{position:relative;flex:1;display:flex;flex-direction:column;justify-content:space-between;\n    gap:4px;padding:6px 9px;width:100%}\n  .rails::before,.rails::after{content:\"\";position:absolute;top:4px;bottom:4px;width:3px;border-radius:2px;\n    background:linear-gradient(180deg,#2c3644,#11161d)}\n  .rails::before{left:7px}.rails::after{right:7px}\n  .rung{position:relative;height:9px;border-radius:3px;z-index:1;\n    background:linear-gradient(90deg,#1b222c,#252e3a 50%,#1b222c);\n    box-shadow:inset 0 1px 1px rgba(255,255,255,.05),inset 0 -1px 2px rgba(0,0,0,.6);\n    transition:background .18s,box-shadow .18s,transform .12s}\n  .rung.lit{\n    background:linear-gradient(90deg,\n      color-mix(in srgb,var(--ac) 30%,#1b222c),\n      var(--ac) 50%,\n      color-mix(in srgb,var(--ac) 30%,#1b222c));\n    box-shadow:0 0 10px color-mix(in srgb,var(--ac) 70%,transparent),\n      inset 0 0 4px rgba(255,255,255,.4)}\n  .rung.peak{animation:rungPulse .55s ease-in-out infinite}\n  @keyframes rungPulse{0%,100%{transform:scaleX(1);filter:brightness(1)}50%{transform:scaleX(1.06);filter:brightness(1.5)}}\n  .selfosc{margin-top:4px;font-size:7.5px;letter-spacing:.12em;text-align:center;\n    color:var(--ink2);transition:color .2s,text-shadow .2s}\n  .selfosc.hot{color:var(--ac);text-shadow:0 0 8px var(--ac);animation:beat 1s ease-in-out infinite}\n\n  /* ===== patch-panel of jacks (the four params) ===== */\n  .patch{grid-column:1/3;display:grid;grid-template-columns:repeat(4,1fr);gap:10px;\n    padding:14px 10px 6px;margin-top:2px;border-top:1px solid rgba(255,255,255,.05);\n    box-shadow:0 -1px 0 rgba(0,0,0,.5)}\n  .jack{position:relative;display:flex;flex-direction:column;align-items:center;gap:8px;\n    padding:8px 4px 6px;border-radius:10px;\n    animation:jackIn .5s both;animation-delay:var(--d);\n    transition:background .2s}\n  @keyframes jackIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}\n  .jack:hover{background:rgba(255,255,255,.025)}\n\n  /* the physical jack: an outer collar + glowing inner socket that doubles as the dial */\n  .socket{position:relative;width:70px;height:70px;cursor:ns-resize;touch-action:none}\n  .collar{position:absolute;inset:0;border-radius:50%;\n    background:\n      radial-gradient(circle at 50% 35%,#3a4452,#1a1f28 62%,#0b0e13);\n    box-shadow:\n      0 3px 6px rgba(0,0,0,.6),\n      inset 0 2px 3px rgba(255,255,255,.16),\n      inset 0 -3px 6px rgba(0,0,0,.7)}\n  /* hex nut ring around the collar */\n  .collar::before{content:\"\";position:absolute;inset:-3px;border-radius:50%;z-index:-1;\n    background:conic-gradient(#252d39,#171c24,#252d39,#171c24,#252d39,#171c24,#252d39);\n    -webkit-mask:radial-gradient(circle,transparent 33px,#000 34px);\n    mask:radial-gradient(circle,transparent 33px,#000 34px)}\n  /* value arc */\n  .arc{position:absolute;inset:2px;border-radius:50%;\n    background:conic-gradient(from 220deg,\n      var(--ac) calc(var(--n,0)*280deg),\n      rgba(255,255,255,.06) calc(var(--n,0)*280deg) 280deg,\n      transparent 280deg);\n    filter:drop-shadow(0 0 calc(2px + var(--n,0)*8px) color-mix(in srgb,var(--ac) 70%,transparent));\n    -webkit-mask:radial-gradient(circle,transparent 27px,#000 28px,#000 33px,transparent 34px);\n    mask:radial-gradient(circle,transparent 27px,#000 28px,#000 33px,transparent 34px);\n    transition:--n .12s linear}\n  /* the dark socket hole with a center contact pin */\n  .hole{position:absolute;top:12px;left:12px;width:46px;height:46px;border-radius:50%;\n    background:radial-gradient(circle at 50% 38%,#10161d 0%,#04070a 70%);\n    box-shadow:inset 0 4px 9px rgba(0,0,0,.9),inset 0 -1px 0 rgba(255,255,255,.05)}\n  .pin{position:absolute;top:50%;left:50%;width:11px;height:11px;border-radius:50%;\n    transform:translate(-50%,-50%);\n    background:radial-gradient(circle,var(--ac) 0%,color-mix(in srgb,var(--ac) 40%,#04070a) 70%);\n    box-shadow:0 0 calc(4px + var(--n,0)*14px) var(--ac),0 0 3px #fff;\n    transition:box-shadow .12s}\n  /* the indicator notch riding the rim (shows position like a knob pointer) */\n  .notch{position:absolute;top:50%;left:50%;width:4px;height:34px;margin-left:-2px;\n    border-radius:2px;transform-origin:50% 100%;\n    transform:translate(-2px,-34px) rotate(calc((var(--n,0) - 0.5) * 280deg));\n    background:linear-gradient(var(--ac),var(--ac2));box-shadow:0 0 7px var(--ac);\n    transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n  .socket.act .collar{box-shadow:0 3px 6px rgba(0,0,0,.6),inset 0 2px 3px rgba(255,255,255,.16),inset 0 -3px 6px rgba(0,0,0,.7),0 0 0 2px color-mix(in srgb,var(--ac) 50%,transparent)}\n\n  .jname{font-size:9.5px;letter-spacing:.16em;color:var(--ink);text-transform:uppercase}\n  .jval{font-size:11px;font-weight:700;color:var(--ac);font-variant-numeric:tabular-nums;\n    letter-spacing:.04em;min-height:13px}\n  /* tiny \"patched\" cable hint that glows on hover/drag */\n  .cable{position:absolute;top:-4px;right:8px;width:7px;height:7px;border-radius:50%;\n    background:var(--ac2);opacity:0;box-shadow:0 0 8px var(--ac2);transition:opacity .2s}\n  .jack:hover .cable,.socket.act ~ .cable{opacity:.9}\n\n  .foot{grid-column:1/3;font-size:9px;line-height:1.55;color:var(--ink2);\n    letter-spacing:.04em;padding:8px 6px 2px;border-top:1px solid rgba(255,255,255,.04)}\n  .foot b{color:var(--ac)}\n</style>\n</head>\n<body>\n  <div class=\"module\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <span class=\"pwr\"></span>\n      <span class=\"title\"><b>LADDER&nbsp;FILTER</b><span class=\"mod\">VCF · 24 dB/OCT · TRANSISTOR LADDER</span></span>\n      <span class=\"hp\">MODULE <span>VF-24</span><br>4 HP</span>\n    </div>\n\n    <div class=\"body\">\n      <!-- frequency response scope -->\n      <div class=\"scope\">\n        <div class=\"scopelbl\"><b>RESPONSE</b> · LP</div>\n        <div class=\"scopehz\">f<sub>c</sub> <b id=\"hz\">—</b></div>\n        <svg viewBox=\"0 0 300 150\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"fillg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"var(--ac)\" stop-opacity=\"0.45\"/>\n              <stop offset=\"1\" stop-color=\"var(--ac)\" stop-opacity=\"0\"/>\n            </linearGradient>\n          </defs>\n          <g class=\"grid\">\n            <line x1=\"0\" y1=\"37.5\" x2=\"300\" y2=\"37.5\"/>\n            <line x1=\"0\" y1=\"75\" x2=\"300\" y2=\"75\"/>\n            <line x1=\"0\" y1=\"112.5\" x2=\"300\" y2=\"112.5\"/>\n            <line x1=\"75\" y1=\"0\" x2=\"75\" y2=\"150\"/>\n            <line x1=\"150\" y1=\"0\" x2=\"150\" y2=\"150\"/>\n            <line x1=\"225\" y1=\"0\" x2=\"225\" y2=\"150\"/>\n          </g>\n          <path class=\"ch\" id=\"ghost\" d=\"\"/>\n          <line class=\"cutline\" id=\"cutline\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"150\"/>\n          <path class=\"fill\" id=\"fill\" d=\"\"/>\n          <path class=\"curve\" id=\"curve\" d=\"\"/>\n          <circle class=\"cutdot\" id=\"cutdot\" cx=\"0\" cy=\"0\" r=\"3.4\"/>\n        </svg>\n        <div class=\"scan\"></div>\n      </div>\n\n      <!-- resonance ladder -->\n      <div class=\"ladder\">\n        <div class=\"lbl\">RES</div>\n        <div class=\"rails\" id=\"rails\"></div>\n        <div class=\"selfosc\" id=\"selfosc\">FEEDBACK</div>\n      </div>\n\n      <!-- patch-panel: the four params as jacks -->\n      <div class=\"patch\" id=\"patch\"></div>\n\n      <div class=\"foot\">\n        <b>4&nbsp;cascaded&nbsp;one-pole&nbsp;stages</b> share a resonance feedback path that climbs to self-oscillation; tanh saturation in the loop adds warm analog growl.\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- params straight from spec.json (index-exact) ----\n  var PARAMS = [\n    {name:\"Cutoff\",    index:0, min:0, max:1, def:0.6},\n    {name:\"Resonance\", index:1, min:0, max:1, def:0.3},\n    {name:\"Drive\",     index:2, min:0, max:1, def:0.25},\n    {name:\"Mix\",       index:3, min:0, max:1, def:1}\n  ];\n\n  var state = {0:0.6, 1:0.3, 2:0.25, 3:1};\n\n  function send(i,v){\n    if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n\n  // ---- build the resonance ladder rungs ----\n  var RUNGS = 12, rungEls = [];\n  var rails = document.getElementById('rails');\n  for(var r=0;r<RUNGS;r++){\n    var el = document.createElement('div');\n    el.className = 'rung';\n    rails.appendChild(el);\n    rungEls.push(el);\n  }\n  var selfoscEl = document.getElementById('selfosc');\n\n  function paintLadder(){\n    var res = state[1]; // 0..1\n    // light rungs from the BOTTOM up as resonance climbs\n    var litCount = res * RUNGS;\n    for(var k=0;k<RUNGS;k++){\n      var fromBottom = RUNGS - 1 - k; // index k=0 is top, light bottom-first\n      var lit = (RUNGS - fromBottom) <= litCount;\n      var el = rungEls[k];\n      el.classList.toggle('lit', lit);\n      // top-most lit rung pulses as the \"resonance peak\"\n      el.classList.remove('peak');\n    }\n    // mark the highest lit rung as the pulsing peak\n    var topLit = RUNGS - Math.ceil(litCount); // index of highest lit\n    if(litCount>0 && topLit>=0 && topLit<RUNGS) rungEls[topLit].classList.add('peak');\n    // self-oscillation indicator near the top of resonance\n    selfoscEl.classList.toggle('hot', res > 0.85);\n    selfoscEl.textContent = res > 0.85 ? 'SELF-OSC' : 'FEEDBACK';\n  }\n\n  // ---- frequency-response curve maths ----\n  var curve = document.getElementById('curve');\n  var fill  = document.getElementById('fill');\n  var ghost = document.getElementById('ghost');\n  var cutline = document.getElementById('cutline');\n  var cutdot = document.getElementById('cutdot');\n  var hzLbl = document.getElementById('hz');\n  var W=300, H=150, N=80;\n\n  function respPath(closed){\n    var cut = state[0], res = state[1], drv = state[2];\n    // map cutoff 0..1 to a log-ish x position of the corner\n    var fcX = 0.06 + cut*0.86;          // normalised x of corner (0..1)\n    var peak = res*res;                 // resonance bump amount\n    var dpts = [];\n    for(var i=0;i<=N;i++){\n      var x = i/N;                       // 0..1 across freq axis\n      // distance from corner in \"octave\" space\n      var d = (x - fcX) / 0.16;\n      var mag;\n      if(x <= fcX){\n        // passband flat ~0 dB, with a resonant bump just below corner\n        var bump = peak * Math.exp(-Math.pow((x-fcX)/0.05,2)) * 1.4;\n        mag = bump;\n      }else{\n        // 24 dB/oct rolloff after the corner; drive lifts the floor slightly\n        mag = -d*1.05 + peak*Math.exp(-Math.pow((x-fcX)/0.05,2))*1.4;\n      }\n      // convert magnitude (in ~dB-ish units) to y; 0 ≈ upper third\n      var y = H*0.42 - mag*16 + (1-drv)*0; // drive subtly thickens but keep level\n      if(y<6) y=6; if(y>H-4) y=H-4;\n      dpts.push([x*W, y]);\n    }\n    var dstr = \"M\"+dpts.map(function(p){return p[0].toFixed(1)+\",\"+p[1].toFixed(1);}).join(\" L\");\n    if(closed){\n      dstr += \" L\"+W+\",\"+H+\" L0,\"+H+\" Z\";\n    }\n    return {d:dstr, fcX:fcX, pts:dpts};\n  }\n\n  function paintScope(){\n    var info = respPath(false);\n    var fc = respPath(true);\n    curve.setAttribute('d', info.d);\n    fill.setAttribute('d', fc.d);\n    // ghost = the \"dry\" reference curve at mix<1 (faint full-range flat-ish)\n    // corner marker on the curve\n    var cx = info.fcX*W;\n    // find y at corner\n    var idx = Math.round(info.fcX*N);\n    var cyArr = info.pts[Math.min(idx,info.pts.length-1)];\n    cutline.setAttribute('x1', cx); cutline.setAttribute('x2', cx);\n    cutdot.setAttribute('cx', cyArr[0]); cutdot.setAttribute('cy', cyArr[1]);\n\n    // ghost dry line fades in as Mix drops\n    var mix = state[3];\n    ghost.style.opacity = (1-mix)*0.9;\n    if(mix<0.999){\n      ghost.setAttribute('d', \"M0,\"+(H*0.42).toFixed(1)+\" L\"+W+\",\"+(H*0.42).toFixed(1));\n    }\n    // Hz readout — map cutoff to a musical 20Hz..20kHz log range\n    var hz = Math.round(20 * Math.pow(1000, state[0]));\n    hzLbl.textContent = hz>=1000 ? (hz/1000).toFixed(1).replace(/\\.0$/,'')+'k' : hz;\n    // tint the whole thing by drive (warmer accent when driven)\n    document.documentElement.style.setProperty('--ac',\n      mixHex('#66e0c0', '#ffb454', state[2]*0.55));\n  }\n\n  // simple hex lerp for drive warmth\n  function mixHex(a,b,t){\n    function h(x){return [parseInt(x.slice(1,3),16),parseInt(x.slice(3,5),16),parseInt(x.slice(5,7),16)];}\n    var A=h(a),B=h(b),o='#';\n    for(var i=0;i<3;i++){var v=Math.round(A[i]+(B[i]-A[i])*t).toString(16);o+=v.length<2?'0'+v:v;}\n    return o;\n  }\n\n  // ---- build the four jacks ----\n  var patch = document.getElementById('patch');\n  var jacks = [];\n\n  function fmt(v){\n    // show as percent for these normalised 0..1 params\n    return Math.round(v*100) + '%';\n  }\n\n  PARAMS.forEach(function(p, k){\n    var jack = document.createElement('div');\n    jack.className = 'jack';\n    jack.style.setProperty('--d', (k*70)+'ms');\n    jack.innerHTML =\n      '<div class=\"socket\" tabindex=\"0\">'+\n        '<div class=\"collar\"></div>'+\n        '<div class=\"arc\"></div>'+\n        '<div class=\"hole\"></div>'+\n        '<div class=\"pin\"></div>'+\n        '<div class=\"notch\"></div>'+\n      '</div>'+\n      '<span class=\"cable\"></span>'+\n      '<div class=\"jname\">'+p.name+'</div>'+\n      '<div class=\"jval\"></div>';\n    patch.appendChild(jack);\n\n    var socket = jack.querySelector('.socket');\n    var arc    = jack.querySelector('.arc');\n    var notch  = jack.querySelector('.notch');\n    var pin    = jack.querySelector('.pin');\n    var valEl  = jack.querySelector('.jval');\n\n    var span = (p.max - p.min) || 1;\n\n    function norm(){ return (state[p.index]-p.min)/span; }\n\n    function paint(){\n      var n = norm();\n      arc.style.setProperty('--n', n.toFixed(4));\n      notch.style.setProperty('--n', n.toFixed(4));\n      pin.style.setProperty('--n', n.toFixed(4));\n      valEl.textContent = fmt(state[p.index]);\n    }\n\n    function commit(){\n      send(p.index, state[p.index]);\n      paint();\n      // these two params drive the shared graphics\n      paintScope();\n      paintLadder();\n    }\n\n    function setNorm(n){\n      n = n<0?0:(n>1?1:n);\n      var v = p.min + span*n;\n      // continuous, round to 0.001\n      v = Math.round(v/0.001)*0.001;\n      state[p.index] = v;\n      commit();\n    }\n\n    // pointer drag (vertical) = change\n    var dragY=0, dragN=0, dragging=false;\n    socket.addEventListener('pointerdown', function(e){\n      dragging=true; dragY=e.clientY; dragN=norm();\n      socket.classList.add('act');\n      socket.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    socket.addEventListener('pointermove', function(e){\n      if(!dragging) return;\n      setNorm(dragN + (dragY - e.clientY)/180);\n    });\n    function end(){ dragging=false; socket.classList.remove('act'); }\n    socket.addEventListener('pointerup', end);\n    socket.addEventListener('pointercancel', end);\n    // double-click = reset to default\n    socket.addEventListener('dblclick', function(){\n      state[p.index] = p.def; commit();\n    });\n    // wheel = fine adjust\n    socket.addEventListener('wheel', function(e){\n      e.preventDefault();\n      setNorm(norm() + (e.deltaY<0?0.03:-0.03));\n    }, {passive:false});\n\n    jacks.push({paint:paint, p:p});\n    paint();\n  });\n\n  // ---- initialise everything to defaults & push to host ----\n  function init(){\n    PARAMS.forEach(function(p){\n      state[p.index] = p.def;\n      send(p.index, p.def);\n    });\n    jacks.forEach(function(j){ j.paint(); });\n    paintScope();\n    paintLadder();\n\n    // a gentle one-time \"boot sweep\" of the ladder for life on load\n    var boot=0;\n    var id=setInterval(function(){\n      boot++;\n      for(var i=0;i<RUNGS;i++){\n        rungEls[i].style.opacity = (i===RUNGS-boot)?'1':'';\n      }\n      if(boot>RUNGS){ clearInterval(id); for(var j=0;j<RUNGS;j++) rungEls[j].style.opacity=''; paintLadder(); }\n    },40);\n  }\n\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(init);\n  else init();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  LADDER FILTER — 4-pole (24 dB/oct) resonant transistor-ladder low-pass\n//  A cascade of four one-pole sections with a global resonance feedback\n//  path that can reach self-oscillation. A gentle tanh-style saturation\n//  in the feedback loop tames the resonance and gives the warm growl that\n//  the classic transistor ladder is known for. Pure algorithm, no samples.\n//\n//  Controls: Cutoff, Resonance (musical up to self-oscillation), Drive, Mix.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// Per-channel ladder state: the four one-pole stage outputs, plus the\n// previous overall output (for the half-sample feedback delay smoothing).\nconst s0: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst s1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst s2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst s3: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst fbState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_CUTOFF: i32 = 0;  // 0..1 -> ~30 Hz .. ~18 kHz (exponential)\nconst P_RESO:   i32 = 1;  // 0..1 -> feedback 0 .. ~4.2 (self-oscillation near 1)\nconst P_DRIVE:  i32 = 2;  // 0..1 -> input drive 1 .. ~8\nconst P_MIX:    i32 = 3;  // 0..1 dry/wet\n\nconst PI: f32 = 3.14159265358979;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    s0[c] = 0.0; s1[c] = 0.0; s2[c] = 0.0; s3[c] = 0.0; fbState[c] = 0.0;\n  }\n  params[P_CUTOFF] = 0.6;\n  params[P_RESO]   = 0.3;\n  params[P_DRIVE]  = 0.25;\n  params[P_MIX]    = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// Cheap, stable tanh approximation (rational). Saturates to ±1, monotone.\n@inline function tanhf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.5, 3.5);\n  const x2: f32 = c * c;\n  const num: f32 = c * (f32(27.0) + x2);\n  const den: f32 = f32(27.0) + f32(9.0) * x2;\n  return num / den;\n}\n\nexport function process(n: i32): void {\n  const cutN:  f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resN:  f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const drvN:  f32 = clampf(params[P_DRIVE],  0.0, 1.0);\n  const mix:   f32 = clampf(params[P_MIX],    0.0, 1.0);\n\n  // Exponential cutoff map: ~30 Hz .. ~18 kHz.\n  const fc: f32 = f32(30.0) * f32(Mathf.exp(cutN * f32(6.4)));   // 30 .. ~18k\n  let fcCl: f32 = clampf(fc, 20.0, sampleRate * f32(0.45));\n\n  // One-pole coefficient via the standard ladder tuning. g is the per-stage\n  // gain; the cascade of 4 of these gives the 24 dB/oct slope.\n  const wc: f32 = f32(2.0) * PI * fcCl / sampleRate;\n  // Bilinear-ish frequency warp so the cutoff tracks well up high.\n  const g: f32 = clampf(f32(Mathf.tan(clampf(wc * f32(0.5), 0.0, 1.45))), 0.0001, 10.0);\n  const G: f32 = g / (f32(1.0) + g);   // one-pole TPT coefficient (0..1)\n\n  // Resonance: feedback amount up to ~4.2 (self-oscillation a touch above 4).\n  const res: f32 = resN * f32(4.2);\n\n  // Input drive 1..8; compensate level a bit so high drive doesn't blow up.\n  const drive: f32 = f32(1.0) + drvN * f32(7.0);\n  const driveComp: f32 = f32(1.0) / f32(Mathf.sqrt(drive));\n\n  // Mild make-up: resonance steals low-end energy; nudge level a touch.\n  const makeup: f32 = f32(1.0) + resN * f32(0.4);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let z0: f32 = s0[c];\n    let z1: f32 = s1[c];\n    let z2: f32 = s2[c];\n    let z3: f32 = s3[c];\n    let fb: f32 = fbState[c];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n\n      // Drive the input and saturate it going in (transistor input pair).\n      const xin: f32 = tanhf(dry * drive) * driveComp;\n\n      // Feedback: subtract the resonance-scaled, saturated previous output.\n      // Saturating the feedback is what keeps self-oscillation bounded.\n      const u: f32 = xin - res * tanhf(fb);\n\n      // Four cascaded one-pole TPT low-pass stages (transistor ladder).\n      const v0: f32 = (u  - z0) * G;\n      const y0: f32 = v0 + z0;  z0 = y0 + v0;\n\n      const v1: f32 = (y0 - z1) * G;\n      const y1: f32 = v1 + z1;  z1 = y1 + v1;\n\n      const v2: f32 = (y1 - z2) * G;\n      const y2: f32 = v2 + z2;  z2 = y2 + v2;\n\n      const v3: f32 = (y2 - z3) * G;\n      const y3: f32 = v3 + z3;  z3 = y3 + v3;\n\n      // y3 is the 4-pole low-pass output; feed it back next sample.\n      fb = y3;\n\n      const wet: f32 = clampf(y3 * makeup, -1.5, 1.5);\n      outBuf[base + f] = f32(dry * (f32(1.0) - mix) + wet * mix);\n    }\n\n    s0[c] = z0; s1[c] = z1; s2[c] = z2; s3[c] = z3; fbState[c] = fb;\n  }\n}\n",
  "publishedAt": 1751000010000
}