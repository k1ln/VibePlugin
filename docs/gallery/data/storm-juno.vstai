  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Storm Juno</title>\n<style>\n  :root {\n    --accent: #9a7bff;\n    --accent2: #3de0ff;\n    --bg0: #0a0716;\n    --bg1: #160d2e;\n    --bg2: #1d1142;\n    --ink: #e7e3ff;\n    --dim: #8a82b8;\n    --panel: #120a26;\n    --line: rgba(154,123,255,0.16);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .wrap {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 16px;\n  }\n\n  /* ---- stormy shell ------------------------------------------------ */\n  .shell {\n    position: relative;\n    border-radius: 18px;\n    padding: 18px 20px 20px;\n    overflow: hidden;\n    background:\n      radial-gradient(120% 90% at 20% -10%, rgba(154,123,255,0.22), transparent 55%),\n      radial-gradient(120% 120% at 110% 120%, rgba(61,224,255,0.18), transparent 55%),\n      linear-gradient(160deg, var(--bg2), var(--bg0) 70%);\n    border: 1px solid rgba(154,123,255,0.28);\n    box-shadow:\n      0 20px 60px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.06);\n  }\n\n  /* drifting storm clouds */\n  .shell::before {\n    content: \"\";\n    position: absolute;\n    inset: -40%;\n    background:\n      radial-gradient(40% 30% at 30% 40%, rgba(80,40,160,0.30), transparent 60%),\n      radial-gradient(35% 28% at 70% 60%, rgba(20,120,170,0.26), transparent 60%),\n      radial-gradient(30% 24% at 50% 20%, rgba(120,80,220,0.22), transparent 60%);\n    filter: blur(8px);\n    animation: drift 26s ease-in-out infinite alternate;\n    pointer-events: none;\n  }\n  @keyframes drift {\n    0%   { transform: translate(0,0) scale(1); }\n    100% { transform: translate(-6%, 4%) scale(1.08); }\n  }\n\n  /* ---- header ------------------------------------------------------ */\n  header {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 14px;\n  }\n  .brand { display: flex; align-items: baseline; gap: 10px; }\n  .logo {\n    font-weight: 800;\n    font-size: 26px;\n    letter-spacing: 0.5px;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 24px rgba(154,123,255,0.35);\n  }\n  .sub {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  /* rave LED strip */\n  .leds { display: flex; gap: 6px; }\n  .led {\n    width: 9px; height: 9px;\n    border-radius: 50%;\n    background: rgba(154,123,255,0.25);\n    box-shadow: inset 0 0 3px rgba(0,0,0,0.6);\n  }\n  .led.on {\n    background: var(--accent2);\n    box-shadow: 0 0 10px var(--accent2), 0 0 18px rgba(61,224,255,0.6);\n  }\n\n  /* ---- visualiser -------------------------------------------------- */\n  .viz {\n    position: relative;\n    height: 132px;\n    border-radius: 12px;\n    background:\n      linear-gradient(180deg, rgba(8,4,20,0.9), rgba(20,10,44,0.55));\n    border: 1px solid var(--line);\n    overflow: hidden;\n    margin-bottom: 16px;\n  }\n  .viz canvas { display: block; width: 100%; height: 100%; }\n  .viz .tag {\n    position: absolute; top: 8px; left: 10px;\n    font-size: 9px; letter-spacing: 2px; text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  /* ---- control grid ------------------------------------------------ */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px 8px;\n    background: rgba(8,4,20,0.4);\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 16px 12px 14px;\n    margin-bottom: 16px;\n  }\n\n  .cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n    user-select: none;\n  }\n  .knob {\n    width: 74px; height: 74px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob .glow { transition: opacity 0.18s; opacity: 0; }\n  .cell.active .knob .glow,\n  .knob:hover .glow { opacity: 1; }\n\n  .lbl {\n    font-size: 10px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n  .val {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    font-weight: 600;\n  }\n\n  /* ---- keyboard ---------------------------------------------------- */\n  .kbd {\n    position: relative;\n    height: 96px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, #07040f, #120a26);\n    border: 1px solid var(--line);\n    padding: 8px 10px;\n    display: flex;\n    justify-content: center;\n  }\n  .keys { position: relative; height: 100%; width: 100%; max-width: 660px; }\n  .wkey, .bkey {\n    position: absolute;\n    bottom: 0;\n    border-radius: 0 0 5px 5px;\n    cursor: pointer;\n    transition: background 0.08s, box-shadow 0.08s, transform 0.05s;\n  }\n  .wkey {\n    top: 0;\n    background: linear-gradient(180deg, #efeaff, #cdc4ee);\n    border: 1px solid #1a1030;\n    box-shadow: inset 0 -6px 10px rgba(120,90,200,0.18);\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), #7ce8ff);\n    box-shadow: 0 0 16px rgba(61,224,255,0.7);\n    transform: translateY(1px);\n  }\n  .bkey {\n    top: 0;\n    height: 60%;\n    background: linear-gradient(180deg, #2a1a52, #0c0620);\n    border: 1px solid #000;\n    box-shadow: 0 3px 6px rgba(0,0,0,0.6);\n    z-index: 2;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #6b4fd6);\n    box-shadow: 0 0 16px rgba(154,123,255,0.8);\n  }\n\n  .hint {\n    margin-top: 10px;\n    text-align: center;\n    font-size: 10px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"shell\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"logo\">STORM JUNO</div>\n        <div class=\"sub\">6-Voice DCO Hoover</div>\n      </div>\n      <div class=\"leds\" id=\"leds\"></div>\n    </header>\n\n    <div class=\"viz\">\n      <div class=\"tag\">Detuned Pulse Stack</div>\n      <canvas id=\"scope\"></canvas>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"kbd\">\n      <div class=\"keys\" id=\"keys\"></div>\n    </div>\n    <div class=\"hint\">Drag knobs vertically · double-click to reset · play the keys</div>\n  </div>\n</div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter model (indices must match the DSP module) ----------\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.45 },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.55 },\n    { name: \"Env Amount\", index: 2, min: 0, max: 1, def: 0.70 },\n    { name: \"PWM Depth\",  index: 3, min: 0, max: 1, def: 0.70 },\n    { name: \"PWM Rate\",   index: 4, min: 0, max: 1, def: 0.35 },\n    { name: \"Chorus\",     index: 5, min: 0, max: 1, def: 0.60 },\n    { name: \"Release\",    index: 6, min: 0, max: 1, def: 0.35 },\n    { name: \"Level\",      index: 7, min: 0, max: 1, def: 0.70 }\n  ];\n\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  function pushParam(i) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(PARAMS[i].index, values[i]);\n    }\n  }\n\n  // ---- build knobs --------------------------------------------------\n  var NS = \"http://www.w3.org/2000/svg\";\n\n  function makeKnob(i) {\n    var p = PARAMS[i];\n\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"class\", \"knob\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // glow halo (shown when active/hover)\n    var glow = document.createElementNS(NS, \"circle\");\n    glow.setAttribute(\"class\", \"glow\");\n    glow.setAttribute(\"cx\", \"50\");\n    glow.setAttribute(\"cy\", \"50\");\n    glow.setAttribute(\"r\", \"44\");\n    glow.setAttribute(\"fill\", \"none\");\n    glow.setAttribute(\"stroke\", \"var(--accent2)\");\n    glow.setAttribute(\"stroke-width\", \"2\");\n    glow.setAttribute(\"opacity\", \"0\");\n    glow.style.filter = \"drop-shadow(0 0 6px var(--accent2))\";\n    svg.appendChild(glow);\n\n    // track arc\n    var track = document.createElementNS(NS, \"path\");\n    track.setAttribute(\"d\", arcPath(50, 50, 36, -135, 135));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(154,123,255,0.18)\");\n    track.setAttribute(\"stroke-width\", \"6\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(track);\n\n    // value arc\n    var arc = document.createElementNS(NS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#grad\" + i + \")\");\n    arc.setAttribute(\"stroke-width\", \"6\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(arc);\n\n    // gradient def\n    var defs = document.createElementNS(NS, \"defs\");\n    var grad = document.createElementNS(NS, \"linearGradient\");\n    grad.setAttribute(\"id\", \"grad\" + i);\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"0\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"1\");\n    var st1 = document.createElementNS(NS, \"stop\");\n    st1.setAttribute(\"offset\", \"0\"); st1.setAttribute(\"stop-color\", \"var(--accent)\");\n    var st2 = document.createElementNS(NS, \"stop\");\n    st2.setAttribute(\"offset\", \"1\"); st2.setAttribute(\"stop-color\", \"var(--accent2)\");\n    grad.appendChild(st1); grad.appendChild(st2);\n    defs.appendChild(grad);\n    svg.appendChild(defs);\n\n    // body\n    var body = document.createElementNS(NS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\");\n    body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"#160d2e\");\n    body.setAttribute(\"stroke\", \"rgba(255,255,255,0.07)\");\n    svg.appendChild(body);\n\n    // pointer\n    var ptr = document.createElementNS(NS, \"line\");\n    ptr.setAttribute(\"stroke\", \"var(--accent2)\");\n    ptr.setAttribute(\"stroke-width\", \"3\");\n    ptr.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(ptr);\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"lbl\";\n    lbl.textContent = p.name;\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(svg);\n    cell.appendChild(lbl);\n    cell.appendChild(val);\n\n    function redraw() {\n      var t = (values[i] - p.min) / (p.max - p.min);\n      var ang = -135 + t * 270;\n      arc.setAttribute(\"d\", arcPath(50, 50, 36, -135, ang));\n      var rad = (ang - 90) * Math.PI / 180;\n      ptr.setAttribute(\"x1\", 50 + 12 * Math.cos(rad));\n      ptr.setAttribute(\"y1\", 50 + 12 * Math.sin(rad));\n      ptr.setAttribute(\"x2\", 50 + 24 * Math.cos(rad));\n      ptr.setAttribute(\"y2\", 50 + 24 * Math.sin(rad));\n      val.textContent = Math.round(t * 100) + \"%\";\n    }\n\n    // ---- drag interaction ----\n    var dragging = false, lastY = 0;\n    function start(y) { dragging = true; lastY = y; cell.classList.add(\"active\"); }\n    function move(y) {\n      if (!dragging) return;\n      var dy = lastY - y;\n      lastY = y;\n      var t = (values[i] - p.min) / (p.max - p.min);\n      t = Math.max(0, Math.min(1, t + dy / 180));\n      values[i] = p.min + t * (p.max - p.min);\n      redraw();\n      pushParam(i);\n    }\n    function end() { dragging = false; cell.classList.remove(\"active\"); }\n\n    svg.addEventListener(\"mousedown\", function (e) { e.preventDefault(); start(e.clientY); });\n    window.addEventListener(\"mousemove\", function (e) { move(e.clientY); });\n    window.addEventListener(\"mouseup\", end);\n    svg.addEventListener(\"touchstart\", function (e) { start(e.touches[0].clientY); }, { passive: true });\n    svg.addEventListener(\"touchmove\", function (e) { move(e.touches[0].clientY); }, { passive: true });\n    svg.addEventListener(\"touchend\", end);\n    svg.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var t = (values[i] - p.min) / (p.max - p.min);\n      t = Math.max(0, Math.min(1, t - Math.sign(e.deltaY) * 0.02));\n      values[i] = p.min + t * (p.max - p.min);\n      redraw();\n      pushParam(i);\n    }, { passive: false });\n    svg.addEventListener(\"dblclick\", function () {\n      values[i] = p.def;\n      redraw();\n      pushParam(i);\n    });\n\n    redraw();\n    return cell;\n  }\n\n  function arcPath(cx, cy, r, a0, a1) {\n    var r0 = (a0 - 90) * Math.PI / 180;\n    var r1 = (a1 - 90) * Math.PI / 180;\n    var x0 = cx + r * Math.cos(r0), y0 = cy + r * Math.sin(r0);\n    var x1 = cx + r * Math.cos(r1), y1 = cy + r * Math.sin(r1);\n    var large = (a1 - a0) > 180 ? 1 : 0;\n    return \"M \" + x0 + \" \" + y0 + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + x1 + \" \" + y1;\n  }\n\n  var rack = document.getElementById(\"rack\");\n  for (var i = 0; i < PARAMS.length; i++) rack.appendChild(makeKnob(i));\n\n  // ---- rave LEDs ----------------------------------------------------\n  var leds = [];\n  var ledHost = document.getElementById(\"leds\");\n  for (var l = 0; l < 7; l++) {\n    var d = document.createElement(\"div\");\n    d.className = \"led\";\n    ledHost.appendChild(d);\n    leds.push(d);\n  }\n\n  // ---- on-screen keyboard ------------------------------------------\n  var keysHost = document.getElementById(\"keys\");\n  var FIRST = 48;        // C3\n  var OCTAVES = 2;\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 1: 0, 3: 1, 6: 3, 8: 4, 10: 5 };\n  var heldKeys = {};\n\n  function buildKeys() {\n    var whiteCount = OCTAVES * 7 + 1;\n    var wW = 100 / whiteCount;\n    var whiteIdx = 0;\n    for (var oct = 0; oct <= OCTAVES; oct++) {\n      for (var s = 0; s < 7; s++) {\n        if (oct === OCTAVES && s > 0) break;\n        var note = FIRST + oct * 12 + WHITE[s];\n        var el = document.createElement(\"div\");\n        el.className = \"wkey\";\n        el.style.left = (whiteIdx * wW) + \"%\";\n        el.style.width = (wW - 0.4) + \"%\";\n        bindKey(el, note);\n        keysHost.appendChild(el);\n        whiteIdx++;\n      }\n    }\n    whiteIdx = 0;\n    for (var oct2 = 0; oct2 <= OCTAVES; oct2++) {\n      for (var s2 = 0; s2 < 7; s2++) {\n        if (oct2 === OCTAVES) break;\n        var semi = WHITE[s2];\n        whiteIdx++;\n        if (semi === 0 || semi === 2 || semi === 5 || semi === 7 || semi === 9) {\n          var note2 = FIRST + oct2 * 12 + semi + 1;\n          var bk = document.createElement(\"div\");\n          bk.className = \"bkey\";\n          bk.style.left = (whiteIdx * wW - wW * 0.3) + \"%\";\n          bk.style.width = (wW * 0.6) + \"%\";\n          bindKey(bk, note2);\n          keysHost.appendChild(bk);\n        }\n      }\n    }\n  }\n\n  function bindKey(el, note) {\n    function on(e) {\n      e.preventDefault();\n      if (heldKeys[note]) return;\n      heldKeys[note] = true;\n      el.classList.add(\"down\");\n      if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(note, 0.9);\n    }\n    function off() {\n      if (!heldKeys[note]) return;\n      heldKeys[note] = false;\n      el.classList.remove(\"down\");\n      if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(note);\n    }\n    el.addEventListener(\"mousedown\", on);\n    el.addEventListener(\"mouseup\", off);\n    el.addEventListener(\"mouseleave\", off);\n    el.addEventListener(\"touchstart\", on, { passive: false });\n    el.addEventListener(\"touchend\", off);\n  }\n  buildKeys();\n\n  // ---- storm + waveform visualiser ---------------------------------\n  var scope = document.getElementById(\"scope\");\n  var ctx = scope.getContext(\"2d\");\n\n  function fit() {\n    var r = scope.getBoundingClientRect();\n    var dpr = window.devicePixelRatio || 1;\n    scope.width = r.width * dpr;\n    scope.height = r.height * dpr;\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n  window.addEventListener(\"resize\", fit);\n  fit();\n\n  // lightning bolt path generator\n  function bolt(x0, y0, x1, y1, jag) {\n    var pts = [[x0, y0]];\n    var steps = 6;\n    for (var k = 1; k < steps; k++) {\n      var t = k / steps;\n      var x = x0 + (x1 - x0) * t + (Math.random() - 0.5) * jag;\n      var y = y0 + (y1 - y0) * t + (Math.random() - 0.5) * jag * 0.5;\n      pts.push([x, y]);\n    }\n    pts.push([x1, y1]);\n    return pts;\n  }\n\n  var t0 = performance.now();\n  var nextStrike = 0;\n  var strikes = [];\n\n  function frame(now) {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    var w = scope.clientWidth, h = scope.clientHeight;\n    var time = (now - t0) / 1000;\n\n    ctx.clearRect(0, 0, w, h);\n\n    // background haze\n    var grd = ctx.createLinearGradient(0, 0, w, h);\n    grd.addColorStop(0, \"rgba(40,20,90,0.25)\");\n    grd.addColorStop(1, \"rgba(20,80,120,0.18)\");\n    ctx.fillStyle = grd;\n    ctx.fillRect(0, 0, w, h);\n\n    // ---- morphing detuned-pulse waveform ----\n    var depth = values[3];      // PWM depth\n    var rate = values[4];       // PWM rate\n    var cutoff = values[0];\n    var pwmHz = 0.05 + rate * rate * 7.0;\n    var lfo = Math.sin(2 * Math.PI * pwmHz * time);\n    var pw = 0.5 + depth * 0.42 * lfo;\n\n    ctx.lineWidth = 2;\n    ctx.strokeStyle = \"rgba(61,224,255,0.85)\";\n    ctx.shadowColor = \"var(--accent2)\";\n    ctx.shadowBlur = 10;\n    ctx.beginPath();\n    var mid = h * 0.55;\n    var amp = h * 0.30 * (0.5 + cutoff * 0.5);\n    var cycles = 3;\n    for (var px = 0; px <= w; px++) {\n      var ph = (px / w) * cycles;\n      // sum of three slightly detuned pulses -> hollow stacked shape\n      var s = 0;\n      for (var d = 0; d < 3; d++) {\n        var dp = ph * (1 + (d - 1) * 0.012) + d * 0.18;\n        var fr = dp - Math.floor(dp);\n        var pwd = Math.min(0.92, Math.max(0.08, pw + (d - 1) * 0.06 * depth));\n        s += (fr < pwd ? 1 : -1);\n      }\n      s /= 3;\n      var y = mid - s * amp;\n      if (px === 0) ctx.moveTo(px, y); else ctx.lineTo(px, y);\n    }\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    // accent overlay line (the saw body), faint purple\n    ctx.lineWidth = 1;\n    ctx.strokeStyle = \"rgba(154,123,255,0.35)\";\n    ctx.beginPath();\n    for (var px2 = 0; px2 <= w; px2 += 2) {\n      var ph2 = (px2 / w) * cycles;\n      var fr2 = ph2 - Math.floor(ph2);\n      var y2 = mid - (fr2 * 2 - 1) * amp * 0.5;\n      if (px2 === 0) ctx.moveTo(px2, y2); else ctx.lineTo(px2, y2);\n    }\n    ctx.stroke();\n\n    // ---- charging lightning arcs ----\n    var charge = (depth + rate) * 0.5;\n    if (now > nextStrike && Math.random() < 0.04 + charge * 0.18) {\n      strikes.push({ pts: bolt(Math.random() * w, 0, Math.random() * w, h * 0.5, 22 + charge * 24), life: 1 });\n      nextStrike = now + 40;\n    }\n    for (var si = strikes.length - 1; si >= 0; si--) {\n      var st = strikes[si];\n      ctx.globalAlpha = st.life;\n      ctx.strokeStyle = \"rgba(180,200,255,0.9)\";\n      ctx.lineWidth = 1.6;\n      ctx.shadowColor = \"var(--accent)\";\n      ctx.shadowBlur = 14;\n      ctx.beginPath();\n      for (var pi = 0; pi < st.pts.length; pi++) {\n        if (pi === 0) ctx.moveTo(st.pts[pi][0], st.pts[pi][1]);\n        else ctx.lineTo(st.pts[pi][0], st.pts[pi][1]);\n      }\n      ctx.stroke();\n      ctx.shadowBlur = 0;\n      ctx.globalAlpha = 1;\n      st.life -= 0.12;\n      if (st.life <= 0) strikes.splice(si, 1);\n    }\n\n    // ---- pulsing rave LEDs (run pattern keyed to PWM rate) ----\n    var pos = Math.floor(time * (1 + rate * 8)) % leds.length;\n    for (var li = 0; li < leds.length; li++) {\n      var anyHeld = Object.keys(heldKeys).some(function (k) { return heldKeys[k]; });\n      var lit = (li === pos) || (anyHeld && ((li + Math.floor(time * 6)) % 2 === 0));\n      leds[li].className = lit ? \"led on\" : \"led\";\n    }\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- init params to defaults -------------------------------------\n  function initParams() {\n    for (var i = 0; i < PARAMS.length; i++) pushParam(i);\n  }\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(initParams);\n  } else {\n    initParams();\n  }\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STORM JUNO — a 6-voice DCO polyphonic instrument (Alpha-Juno lineage).\n//  The signature \"hoover / storm\" lead: each voice stacks THREE detuned\n//  pulse oscillators under deep pulse-width modulation, plus a saw and a\n//  sub-octave square, into a resonant low-pass shaped by its own punchy\n//  filter envelope. A global PWM Rate/Depth LFO sweeps the hollow\n//  detuned-pulse motion; a stereo chorus widens the result.\n//  Pure algorithm — no samples, no host imports, allocation-free process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:  i32 = 0;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 1;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 2;  // 0..1  -> filter envelope amount\nconst P_PWMDEP:  i32 = 3;  // 0..1  -> pulse-width modulation depth\nconst P_PWMRATE: i32 = 4;  // 0..1  -> PWM / hoover sweep rate\nconst P_CHORUS:  i32 = 5;  // 0..1  -> chorus width / mix\nconst P_RELEASE: i32 = 6;  // 0..1  -> amp + filter release time\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// three stacked detuned pulse phases + saw + sub-square\nconst vPh0:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh1:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh2:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhSaw:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhSub:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// amplitude envelope (fast attack + decay-to-sustain, release on note-off)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec/sus 4 rel\n// filter envelope (its own punchy contour)\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// global PWM / hoover LFO\nlet pwmPhase: f32 = 0.0;\n\n// stereo chorus delay lines (modulated)\nconst CHORUS_LEN: i32 = 2048;          // ~42 ms at 48k, plenty for chorus\nconst chL: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nconst chR: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nlet chWrite: i32 = 0;\nlet chPhase: f32 = 0.0;\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPh0[v] = 0.0; vPh1[v] = 0.0; vPh2[v] = 0.0; vPhSaw[v] = 0.0; vPhSub[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  for (let i = 0; i < CHORUS_LEN; i++) { chL[i] = 0.0; chR[i] = 0.0; }\n  chWrite = 0; chPhase = 0.0; pwmPhase = 0.0;\n  ageCounter = 0;\n\n  params[P_CUTOFF]  = 0.45;\n  params[P_RESO]    = 0.55;\n  params[P_ENVAMT]  = 0.7;\n  params[P_PWMDEP]  = 0.7;\n  params[P_PWMRATE] = 0.35;\n  params[P_CHORUS]  = 0.6;\n  params[P_RELEASE] = 0.35;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n  // offset the three pulse phases so the stack starts hollow & wide\n  vPh0[slot] = 0.0;\n  vPh1[slot] = 0.33;\n  vPh2[slot] = 0.66;\n  vPhSaw[slot] = 0.5;\n  vPhSub[slot] = 0.0;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\n// band-limited pulse of arbitrary width via two phase-shifted saws\n@inline function blPulse(ph: f32, inc: f32, pw: f32): f32 {\n  let sq: f32 = ph < pw ? 1.0 : -1.0;\n  sq += polyBlep(ph, inc);\n  let ph2: f32 = ph - pw;\n  if (ph2 < 0.0) ph2 += 1.0;\n  sq -= polyBlep(ph2, inc);\n  return sq;\n}\n\n// linear read from a chorus delay line at fractional sample distance back\n@inline function readDelay(line: StaticArray<f32>, write: i32, delay: f32): f32 {\n  let rp: f32 = f32(write) - delay;\n  while (rp < 0.0) rp += f32(CHORUS_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= CHORUS_LEN) i1 -= CHORUS_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const pwmDep: f32  = clampf(params[P_PWMDEP], 0.0, 1.0);\n  const pwmRateN: f32 = clampf(params[P_PWMRATE], 0.0, 1.0);\n  const chorusN: f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const relN: f32    = clampf(params[P_RELEASE], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // amp envelope timing: punchy fixed attack/decay, knob-controlled release\n  const atkS: f32 = 0.006;\n  const decS: f32 = 0.6;\n  const susL: f32 = 0.72;\n  const relS: f32 = 0.03 + relN * 2.5;\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // filter envelope is punchier: faster decay, release tracks the amp release\n  const fAtkRate: f32 = 1.0 / (0.004 * sr);\n  const fDecRate: f32 = 1.0 / (0.35 * sr);\n  const fSus: f32 = 0.25;\n  const fRelRate: f32 = 1.0 / ((0.03 + relN * 2.0) * sr);\n\n  // base cutoff in Hz, exponential 80 Hz .. ~14 kHz\n  const baseHz: f32 = 80.0 * f32(Mathf.pow(180.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6 octaves\n  const envOct: f32 = envAmt * 6.0;\n  // resonance feedback 0..~3.8\n  const reso: f32 = resoN * 3.8;\n\n  // hoover detune spread: the three pulses sit at small fixed offsets so the\n  // stack always sounds wide; PWM motion does the rest.\n  const detUp: f32   = f32(Mathf.pow(2.0, 0.07 / 12.0));   // ~+7 cents\n  const detDown: f32 = f32(Mathf.pow(2.0, -0.07 / 12.0));  // ~-7 cents\n\n  // PWM LFO: 0.05 .. ~7 Hz (the hoover sweep)\n  const pwmHz: f32 = 0.05 + pwmRateN * pwmRateN * 7.0;\n  const pwmInc: f32 = pwmHz / sr;\n  // pulse width swings around 0.5 by up to ~0.42\n  const pwSwing: f32 = pwmDep * 0.42;\n\n  // chorus: ~6 ms base delay, ~4 ms modulation, 0.7 Hz\n  const chBase: f32 = 0.006 * sr;\n  const chMod: f32  = 0.004 * sr;\n  const chInc: f32  = 0.7 / sr;\n  const chMix: f32  = chorusN;            // 0 dry .. 1 lush\n\n  // 6 voices summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.34;\n\n  for (let f = 0; f < n; f++) {\n    // advance the global PWM LFO + per-stack phase offsets for the three pulses\n    pwmPhase += pwmInc; if (pwmPhase >= 1.0) pwmPhase -= 1.0;\n    const lfo0: f32 = Mathf.sin(TWO_PI * pwmPhase);\n    const lfo1: f32 = Mathf.sin(TWO_PI * pwmPhase + 2.094);   // +120 deg\n    const lfo2: f32 = Mathf.sin(TWO_PI * pwmPhase + 4.188);   // +240 deg\n    const pw0: f32 = clampf(0.5 + pwSwing * lfo0, 0.05, 0.95);\n    const pw1: f32 = clampf(0.5 + pwSwing * lfo1, 0.05, 0.95);\n    const pw2: f32 = clampf(0.5 + pwSwing * lfo2, 0.05, 0.95);\n\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope -----------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {                 // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {          // decay -> sustain\n        if (aenv > susL) {\n          aenv -= decRate * (1.0 - susL);\n          if (aenv <= susL) aenv = susL;\n        } else {\n          aenv = susL;\n        }\n      } else if (astg == 4) {          // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter envelope --------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += fAtkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        if (fenv > fSus) {\n          fenv -= fDecRate * (1.0 - fSus);\n          if (fenv <= fSus) fenv = fSus;\n        } else {\n          fenv = fSus;\n        }\n      } else if (fstg == 4) {\n        fenv -= fRelRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- DCO: three detuned PWM pulses + saw + sub ------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const inc0: f32 = baseInc * detDown;\n      const inc1: f32 = baseInc;\n      const inc2: f32 = baseInc * detUp;\n\n      let p0: f32 = vPh0[v]; p0 += inc0; if (p0 >= 1.0) p0 -= 1.0; vPh0[v] = p0;\n      let p1: f32 = vPh1[v]; p1 += inc1; if (p1 >= 1.0) p1 -= 1.0; vPh1[v] = p1;\n      let p2: f32 = vPh2[v]; p2 += inc2; if (p2 >= 1.0) p2 -= 1.0; vPh2[v] = p2;\n\n      const pulse0: f32 = blPulse(p0, inc0, pw0);\n      const pulse1: f32 = blPulse(p1, inc1, pw1);\n      const pulse2: f32 = blPulse(p2, inc2, pw2);\n      const pulseStack: f32 = (pulse0 + pulse1 + pulse2) * 0.33;\n\n      // band-limited saw on the centre frequency for body\n      let psaw: f32 = vPhSaw[v]; psaw += inc1; if (psaw >= 1.0) psaw -= 1.0; vPhSaw[v] = psaw;\n      let saw: f32 = 2.0 * psaw - 1.0;\n      saw -= polyBlep(psaw, inc1);\n\n      // sub-octave square one octave down\n      let psub: f32 = vPhSub[v]; psub += inc1 * 0.5; if (psub >= 1.0) psub -= 1.0; vPhSub[v] = psub;\n      const sub: f32 = psub < 0.5 ? 0.7 : -0.7;\n\n      // hoover voicing: pulse stack dominates, saw + sub fill it out\n      let osc: f32 = pulseStack * 0.9 + saw * 0.32 + sub * 0.28;\n\n      // ---- resonant 4-pole low-pass -----------------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      outL += s3 * aenv * vVel[v];\n    }\n\n    let mono: f32 = outL * voiceScale;\n    mono = f32(Mathf.tanh(mono * 1.1));\n\n    // ---- stereo chorus for width -------------------------------\n    chPhase += chInc; if (chPhase >= 1.0) chPhase -= 1.0;\n    const cm: f32 = Mathf.sin(TWO_PI * chPhase);\n    const dL: f32 = chBase + chMod * (0.5 + 0.5 * cm);\n    const dR: f32 = chBase + chMod * (0.5 - 0.5 * cm);\n\n    chL[chWrite] = mono;\n    chR[chWrite] = mono;\n    const wetL: f32 = readDelay(chL, chWrite, dL);\n    const wetR: f32 = readDelay(chR, chWrite, dR);\n    chWrite++; if (chWrite >= CHORUS_LEN) chWrite = 0;\n\n    let yL: f32 = mono * (1.0 - 0.5 * chMix) + wetL * chMix;\n    let yR: f32 = mono * (1.0 - 0.5 * chMix) + wetR * chMix;\n\n    yL *= level;\n    yR *= level;\n\n    outBuf[f] = clampf(yL, -1.0, 1.0);\n    outBuf[MAX_FRAMES + f] = clampf(yR, -1.0, 1.0);\n  }\n}\n",
  "publishedAt": 1751000101000
}