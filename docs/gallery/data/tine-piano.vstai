{
  "format": 1,
  "name": "Tine Piano",
  "isInstrument": true,
  "explanation": "A polyphonic electric tine-piano instrument. Each voice is a struck metal tine modelled with two-operator FM — a sine carrier at pitch plus a higher-ratio modulator whose index decays fast for the bright bell/bark attack that melts into a mellow sine body. Velocity drives the bark amount and brightness, a natural two-stage decay keeps notes singing, and a gentle opposed-phase stereo tremolo adds the classic suitcase sway. Controls: Bell (attack FM amount), Decay, Tone, Tremolo Depth, Tremolo Rate and Level.",
  "params": [
    {
      "name": "Bell",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Decay",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tremolo Depth",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Tremolo Rate",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Tine Piano</title>\n<style>\n  :root {\n    --accent: #e0a060;\n    --accent2: #ffcf8a;\n    --wood: #3a2417;\n    --wood-hi: #4e3220;\n    --panel: #1c1410;\n    --panel-2: #251a13;\n    --ink: #f3e6d2;\n    --ink-dim: #b79b7e;\n    --line: rgba(255, 207, 138, 0.14);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a1d14 0%, #150f0b 60%, #0c0805 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    min-height: 100vh;\n  }\n\n  .shell {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 18px 16px 26px;\n  }\n\n  /* ---- the suitcase-piano cabinet ---- */\n  .cabinet {\n    position: relative;\n    border-radius: 18px;\n    padding: 0;\n    background:\n      linear-gradient(180deg, var(--wood-hi), var(--wood) 14%, #2c1b11 100%);\n    box-shadow:\n      0 26px 60px rgba(0, 0, 0, 0.6),\n      inset 0 1px 0 rgba(255, 220, 170, 0.18),\n      inset 0 -2px 14px rgba(0, 0, 0, 0.5);\n    border: 1px solid rgba(0, 0, 0, 0.5);\n    overflow: hidden;\n  }\n\n  /* wood grain texture overlay */\n  .cabinet::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    opacity: 0.35;\n    background:\n      repeating-linear-gradient(91deg,\n        rgba(0,0,0,0.0) 0px,\n        rgba(0,0,0,0.10) 2px,\n        rgba(255,200,150,0.04) 4px,\n        rgba(0,0,0,0.0) 7px);\n    mix-blend-mode: overlay;\n  }\n\n  /* ---- header / nameplate ---- */\n  .header {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 16px 22px 12px;\n    background: linear-gradient(180deg, rgba(0,0,0,0.18), rgba(0,0,0,0) 70%);\n    border-bottom: 1px solid rgba(0,0,0,0.45);\n  }\n\n  .brand { display: flex; align-items: center; gap: 14px; }\n\n  .nameplate {\n    display: flex;\n    flex-direction: column;\n    line-height: 1;\n  }\n  .nameplate .title {\n    font-size: 25px;\n    font-weight: 800;\n    letter-spacing: 0.5px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.4);\n  }\n  .nameplate .sub {\n    margin-top: 5px;\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* glowing power lamp that pulses with tremolo */\n  .lamp-wrap { display: flex; align-items: center; gap: 9px; }\n  .lamp-label {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .lamp {\n    width: 14px; height: 14px; border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, var(--accent2), var(--accent) 55%, #6b3d12 100%);\n    box-shadow: 0 0 10px 2px rgba(224,160,96,0.7), inset 0 -1px 2px rgba(0,0,0,0.4);\n  }\n\n  /* ---- the tine harp (animated) ---- */\n  .harp-frame {\n    position: relative;\n    margin: 14px 16px 6px;\n    border-radius: 12px;\n    padding: 10px 12px 6px;\n    background:\n      linear-gradient(180deg, #120c08, #1c130c);\n    box-shadow:\n      inset 0 2px 10px rgba(0,0,0,0.7),\n      inset 0 -1px 0 rgba(255,200,150,0.06);\n    border: 1px solid rgba(0,0,0,0.55);\n  }\n  .harp-glow {\n    position: absolute;\n    inset: 0;\n    border-radius: 12px;\n    pointer-events: none;\n    background: radial-gradient(60% 120% at 50% 0%, rgba(224,160,96,0.16), transparent 70%);\n  }\n  svg.harp { display: block; width: 100%; height: 116px; }\n\n  /* ---- controls ---- */\n  .controls {\n    display: grid;\n    grid-template-columns: repeat(6, 1fr);\n    gap: 6px;\n    padding: 14px 18px 18px;\n  }\n  @media (max-width: 620px) {\n    .controls { grid-template-columns: repeat(3, 1fr); gap: 14px 6px; }\n  }\n\n  .knob-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n    padding: 6px 2px 4px;\n    border-radius: 12px;\n  }\n  .knob-cell .label {\n    font-size: 9.5px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n    white-space: nowrap;\n  }\n  .knob {\n    position: relative;\n    width: 70px; height: 70px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; }\n  .knob .readout {\n    margin-top: 2px;\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    text-align: center;\n    letter-spacing: 0.5px;\n  }\n  .knob:focus { outline: none; }\n  .knob:focus-visible .ring,\n  .knob:hover .ring { filter: drop-shadow(0 0 5px rgba(224,160,96,0.55)); }\n\n  /* ---- keyboard ---- */\n  .kbd-wrap {\n    margin: 0 16px 16px;\n    padding: 10px 12px 12px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, #0f0a07, #181009);\n    box-shadow: inset 0 2px 9px rgba(0,0,0,0.7);\n    border: 1px solid rgba(0,0,0,0.5);\n  }\n  .kbd-title {\n    font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--ink-dim); margin: 0 2px 8px;\n  }\n  .keys {\n    position: relative;\n    display: flex;\n    height: 92px;\n    border-radius: 6px;\n    overflow: hidden;\n    box-shadow: 0 3px 10px rgba(0,0,0,0.5);\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    background: linear-gradient(180deg, #f6ecdb, #d9c8ab 92%, #b9a585 100%);\n    border-right: 1px solid #b09a78;\n    border-radius: 0 0 4px 4px;\n    cursor: pointer;\n    transition: background 0.06s, transform 0.05s;\n  }\n  .wkey:last-child { border-right: none; }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), var(--accent) 95%);\n    transform: translateY(1px);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 9%;\n    height: 58%;\n    background: linear-gradient(180deg, #2a1d14, #110b07 90%);\n    border: 1px solid #000;\n    border-radius: 0 0 4px 4px;\n    box-shadow: 0 3px 5px rgba(0,0,0,0.6), inset 0 -3px 4px rgba(255,200,150,0.05);\n    cursor: pointer;\n    z-index: 2;\n    transition: background 0.06s, transform 0.05s;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #8a5520 95%);\n    transform: translateY(1px);\n  }\n  .hint {\n    margin: 9px 2px 0;\n    font-size: 9px;\n    letter-spacing: 1px;\n    color: var(--ink-dim);\n    opacity: 0.7;\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"cabinet\">\n\n      <div class=\"header\">\n        <div class=\"brand\">\n          <div class=\"nameplate\">\n            <span class=\"title\">Tine&nbsp;Piano</span>\n            <span class=\"sub\">Electric &middot; Suitcase &middot; FM Tine</span>\n          </div>\n        </div>\n        <div class=\"lamp-wrap\">\n          <span class=\"lamp-label\">Tremolo</span>\n          <div class=\"lamp\" id=\"lamp\"></div>\n        </div>\n      </div>\n\n      <!-- animated tine harp -->\n      <div class=\"harp-frame\">\n        <div class=\"harp-glow\"></div>\n        <svg class=\"harp\" id=\"harp\" viewBox=\"0 0 640 116\" preserveAspectRatio=\"none\"></svg>\n      </div>\n\n      <!-- knobs -->\n      <div class=\"controls\" id=\"controls\"></div>\n\n      <!-- keyboard -->\n      <div class=\"kbd-wrap\">\n        <div class=\"kbd-title\">Keyboard</div>\n        <div class=\"keys\" id=\"keys\"></div>\n        <div class=\"hint\">Drag a knob (double-click to reset) &middot; click or press A&ndash;K to play</div>\n      </div>\n\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- param model (indices match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Bell\",     index: 0, min: 0, max: 1, def: 0.55, fmt: pct },\n    { name: \"Decay\",    index: 1, min: 0, max: 1, def: 0.55, fmt: pct },\n    { name: \"Tone\",     index: 2, min: 0, max: 1, def: 0.5,  fmt: pct },\n    { name: \"Trem Dep\", index: 3, min: 0, max: 1, def: 0.35, fmt: pct },\n    { name: \"Trem Rate\",index: 4, min: 0, max: 1, def: 0.3,  fmt: rateFmt },\n    { name: \"Level\",    index: 5, min: 0, max: 1, def: 0.7,  fmt: pct }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function rateFmt(v) { return (0.5 + v * 6.5).toFixed(1) + \" Hz\"; }\n\n  var values = {};\n  var SVGNS = \"http://www.w3.org/2000/svg\";\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n  function noteOn(n, vel) {\n    if (window.vstai && typeof window.vstai.noteOn === \"function\") window.vstai.noteOn(n, vel);\n  }\n  function noteOff(n) {\n    if (window.vstai && typeof window.vstai.noteOff === \"function\") window.vstai.noteOff(n);\n  }\n\n  // ===========================================================\n  //  KNOBS — hand-drawn SVG, drag vertically, double-click reset\n  // ===========================================================\n  var ARC_START = 135;     // degrees, sweep 270\n  var ARC_SWEEP = 270;\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(cx, cy, r, a0, a1) {\n    var p0 = polar(cx, cy, r, a0);\n    var p1 = polar(cx, cy, r, a1);\n    var large = (a1 - a0) % 360 > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function buildKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob-cell\";\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.setAttribute(\"tabindex\", \"0\");\n    knob.setAttribute(\"role\", \"slider\");\n    knob.setAttribute(\"aria-label\", p.name);\n\n    var svg = document.createElementNS(SVGNS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    var cx = 50, cy = 50, rTrack = 38, rBody = 30;\n\n    // track (full)\n    var track = document.createElementNS(SVGNS, \"path\");\n    track.setAttribute(\"d\", arcPath(cx, cy, rTrack, ARC_START, ARC_START + ARC_SWEEP));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(0,0,0,0.55)\");\n    track.setAttribute(\"stroke-width\", \"6\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n\n    // value arc (accent)\n    var ring = document.createElementNS(SVGNS, \"path\");\n    ring.setAttribute(\"class\", \"ring\");\n    ring.setAttribute(\"fill\", \"none\");\n    ring.setAttribute(\"stroke\", \"url(#kgrad)\");\n    ring.setAttribute(\"stroke-width\", \"6\");\n    ring.setAttribute(\"stroke-linecap\", \"round\");\n\n    // body\n    var bodyOuter = document.createElementNS(SVGNS, \"circle\");\n    bodyOuter.setAttribute(\"cx\", cx); bodyOuter.setAttribute(\"cy\", cy);\n    bodyOuter.setAttribute(\"r\", rBody);\n    bodyOuter.setAttribute(\"fill\", \"url(#kbody)\");\n    bodyOuter.setAttribute(\"stroke\", \"rgba(0,0,0,0.6)\");\n    bodyOuter.setAttribute(\"stroke-width\", \"1\");\n\n    var bodyHi = document.createElementNS(SVGNS, \"circle\");\n    bodyHi.setAttribute(\"cx\", cx); bodyHi.setAttribute(\"cy\", cy - 1);\n    bodyHi.setAttribute(\"r\", rBody - 3);\n    bodyHi.setAttribute(\"fill\", \"none\");\n    bodyHi.setAttribute(\"stroke\", \"rgba(255,220,170,0.12)\");\n    bodyHi.setAttribute(\"stroke-width\", \"1\");\n\n    // pointer notch\n    var notch = document.createElementNS(SVGNS, \"line\");\n    notch.setAttribute(\"stroke\", \"var(--accent2)\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n\n    svg.appendChild(track);\n    svg.appendChild(ring);\n    svg.appendChild(bodyOuter);\n    svg.appendChild(bodyHi);\n    svg.appendChild(notch);\n\n    var readout = document.createElement(\"div\");\n    readout.className = \"readout\";\n\n    knob.appendChild(svg);\n    cell.appendChild(label);\n    cell.appendChild(knob);\n    cell.appendChild(readout);\n\n    function render() {\n      var v = values[p.index];\n      var norm = (v - p.min) / (p.max - p.min);\n      var a1 = ARC_START + ARC_SWEEP * norm;\n      ring.setAttribute(\"d\", arcPath(cx, cy, rTrack, ARC_START, a1 + 0.001));\n      var np = polar(cx, cy, rBody - 6, a1);\n      var ni = polar(cx, cy, 9, a1);\n      notch.setAttribute(\"x1\", ni[0]); notch.setAttribute(\"y1\", ni[1]);\n      notch.setAttribute(\"x2\", np[0]); notch.setAttribute(\"y2\", np[1]);\n      readout.textContent = p.fmt(v);\n      knob.setAttribute(\"aria-valuenow\", v.toFixed(3));\n    }\n\n    function setNorm(norm) {\n      norm = Math.max(0, Math.min(1, norm));\n      var v = p.min + (p.max - p.min) * norm;\n      values[p.index] = v;\n      pushParam(p.index, v);\n      render();\n    }\n\n    // drag\n    var dragging = false, startY = 0, startNorm = 0;\n    function curNorm() { return (values[p.index] - p.min) / (p.max - p.min); }\n\n    function onDown(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startNorm = curNorm();\n      knob.focus();\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = startY - y;\n      var fine = e.shiftKey ? 0.25 : 1;\n      setNorm(startNorm + dy / 200 * fine);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    knob.addEventListener(\"touchmove\", onMove, { passive: false });\n    knob.addEventListener(\"touchend\", onUp);\n\n    knob.addEventListener(\"wheel\", function (e) {\n      setNorm(curNorm() - e.deltaY / 1500);\n      e.preventDefault();\n    }, { passive: false });\n\n    knob.addEventListener(\"dblclick\", function () {\n      setNorm((p.def - p.min) / (p.max - p.min));\n    });\n\n    knob.addEventListener(\"keydown\", function (e) {\n      var step = e.shiftKey ? 0.01 : 0.05;\n      if (e.key === \"ArrowUp\" || e.key === \"ArrowRight\") { setNorm(curNorm() + step); e.preventDefault(); }\n      else if (e.key === \"ArrowDown\" || e.key === \"ArrowLeft\") { setNorm(curNorm() - step); e.preventDefault(); }\n    });\n\n    values[p.index] = p.def;\n    render();\n    return cell;\n  }\n\n  // shared gradient defs (added to the first knob svg via a hidden defs svg)\n  function injectDefs() {\n    var defsSvg = document.createElementNS(SVGNS, \"svg\");\n    defsSvg.setAttribute(\"width\", \"0\");\n    defsSvg.setAttribute(\"height\", \"0\");\n    defsSvg.style.position = \"absolute\";\n    defsSvg.innerHTML =\n      '<defs>' +\n        '<linearGradient id=\"kgrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">' +\n          '<stop offset=\"0\" stop-color=\"#ffcf8a\"/>' +\n          '<stop offset=\"1\" stop-color=\"#e0a060\"/>' +\n        '</linearGradient>' +\n        '<radialGradient id=\"kbody\" cx=\"0.4\" cy=\"0.32\" r=\"0.85\">' +\n          '<stop offset=\"0\" stop-color=\"#3a2a1d\"/>' +\n          '<stop offset=\"0.6\" stop-color=\"#251a12\"/>' +\n          '<stop offset=\"1\" stop-color=\"#120c08\"/>' +\n        '</radialGradient>' +\n      '</defs>';\n    document.body.appendChild(defsSvg);\n  }\n\n  // ===========================================================\n  //  TINE HARP — vibrating metal tines struck by little hammers\n  // ===========================================================\n  var TINES = 13;\n  var harp = document.getElementById(\"harp\");\n  var tineEls = [];   // { line, hammer, base, vib (0..1), gloss }\n\n  function buildHarp() {\n    var W = 640, H = 116;\n    var pad = 24;\n    var span = (W - pad * 2) / (TINES - 1);\n\n    // resonator bar at the bottom\n    var bar = document.createElementNS(SVGNS, \"rect\");\n    bar.setAttribute(\"x\", \"10\"); bar.setAttribute(\"y\", H - 16);\n    bar.setAttribute(\"width\", W - 20); bar.setAttribute(\"height\", \"10\");\n    bar.setAttribute(\"rx\", \"3\");\n    bar.setAttribute(\"fill\", \"url(#barGrad)\");\n    harp.appendChild(bar);\n\n    for (var i = 0; i < TINES; i++) {\n      var x = pad + span * i;\n      var len = 64 + (TINES - 1 - i) * 1.6;   // longer (lower) on the left\n      var topY = H - 22 - len;\n\n      // tine: vertical metal rod with a tip\n      var line = document.createElementNS(SVGNS, \"path\");\n      line.setAttribute(\"stroke\", \"url(#tineGrad)\");\n      line.setAttribute(\"stroke-width\", \"3\");\n      line.setAttribute(\"stroke-linecap\", \"round\");\n      line.setAttribute(\"fill\", \"none\");\n\n      // glossy tip\n      var tip = document.createElementNS(SVGNS, \"circle\");\n      tip.setAttribute(\"r\", \"3.2\");\n      tip.setAttribute(\"fill\", \"url(#tipGrad)\");\n\n      // little felt hammer below\n      var hammer = document.createElementNS(SVGNS, \"rect\");\n      hammer.setAttribute(\"x\", (x - 4).toFixed(1));\n      hammer.setAttribute(\"y\", (H - 22).toFixed(1));\n      hammer.setAttribute(\"width\", \"8\");\n      hammer.setAttribute(\"height\", \"7\");\n      hammer.setAttribute(\"rx\", \"2.5\");\n      hammer.setAttribute(\"fill\", \"#5a3a22\");\n\n      harp.appendChild(line);\n      harp.appendChild(tip);\n      harp.appendChild(hammer);\n\n      tineEls.push({ line: line, tip: tip, hammer: hammer, x: x, topY: topY, baseY: H - 22, vib: 0, hammerHit: 0 });\n    }\n\n    var defs = document.createElementNS(SVGNS, \"defs\");\n    defs.innerHTML =\n      '<linearGradient id=\"tineGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">' +\n        '<stop offset=\"0\" stop-color=\"#fff0d8\"/>' +\n        '<stop offset=\"0.5\" stop-color=\"#cdb38c\"/>' +\n        '<stop offset=\"1\" stop-color=\"#7a5e3e\"/>' +\n      '</linearGradient>' +\n      '<radialGradient id=\"tipGrad\" cx=\"0.35\" cy=\"0.3\" r=\"0.8\">' +\n        '<stop offset=\"0\" stop-color=\"#ffffff\"/>' +\n        '<stop offset=\"0.5\" stop-color=\"#ffcf8a\"/>' +\n        '<stop offset=\"1\" stop-color=\"#a06a2c\"/>' +\n      '</radialGradient>' +\n      '<linearGradient id=\"barGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">' +\n        '<stop offset=\"0\" stop-color=\"#4e3220\"/>' +\n        '<stop offset=\"1\" stop-color=\"#1c120b\"/>' +\n      '</linearGradient>';\n    harp.appendChild(defs);\n  }\n\n  // map a midi note to nearest tine for the strike animation\n  function tineForNote(note) {\n    var idx = ((note % 12) * TINES / 12) | 0;\n    if (idx >= TINES) idx = TINES - 1;\n    return idx;\n  }\n\n  function strikeTine(idx, vel) {\n    var t = tineEls[idx];\n    if (!t) return;\n    t.vib = Math.max(t.vib, 0.55 + vel * 0.45);\n    t.hammerHit = 1;\n  }\n\n  // ---- animation loop ----\n  var lamp = document.getElementById(\"lamp\");\n  var lastTime = performance.now();\n  var lfoPhase = 0;\n  var running = true;\n\n  function frame(now) {\n    var dt = Math.min(0.05, (now - lastTime) / 1000);\n    lastTime = now;\n\n    // tremolo LFO mirrors the DSP mapping (rate 0.5..7 Hz)\n    var rate = 0.5 + values[4] * 6.5;\n    var depth = values[3];\n    lfoPhase += dt * rate;\n    if (lfoPhase > 1e6) lfoPhase = 0;\n    var lfo = Math.sin(lfoPhase * 2 * Math.PI);\n\n    // lamp sways with tremolo\n    var glow = 0.5 + 0.5 * lfo;\n    var intensity = 0.35 + depth * 0.65 * glow + (1 - depth) * 0.3;\n    lamp.style.boxShadow =\n      \"0 0 \" + (6 + 14 * intensity).toFixed(1) + \"px \" +\n      (1 + 3 * intensity).toFixed(1) + \"px rgba(224,160,96,\" + (0.45 + 0.5 * intensity).toFixed(2) + \")\";\n    lamp.style.opacity = (0.55 + 0.45 * intensity).toFixed(2);\n\n    // update tines\n    var freq = 0.0;\n    for (var i = 0; i < tineEls.length; i++) {\n      var t = tineEls[i];\n      if (t.vib > 0.0005) {\n        t.vib *= Math.pow(0.12, dt);   // decay vibration\n        // each tine vibrates at its own visual rate; wobble amplitude scales w/ vib\n        var amp = t.vib * 7;\n        var ph = now / 1000 * (9 + i * 1.4);\n        var sway = Math.sin(ph * 2 * Math.PI) * amp;\n        // a curved tine: tip displaced sideways\n        var midX = t.x + sway * 0.4;\n        var tipX = t.x + sway;\n        var d = \"M \" + t.x.toFixed(1) + \" \" + t.baseY.toFixed(1) +\n                \" Q \" + midX.toFixed(1) + \" \" + ((t.topY + t.baseY) / 2).toFixed(1) +\n                \" \" + tipX.toFixed(1) + \" \" + t.topY.toFixed(1);\n        t.line.setAttribute(\"d\", d);\n        t.tip.setAttribute(\"cx\", tipX.toFixed(1));\n        t.tip.setAttribute(\"cy\", t.topY.toFixed(1));\n        t.tip.setAttribute(\"r\", (3.2 + t.vib * 2).toFixed(1));\n        t.line.setAttribute(\"stroke-width\", (3 + t.vib * 1.2).toFixed(1));\n      } else {\n        // resting tine (straight)\n        t.line.setAttribute(\"d\", \"M \" + t.x.toFixed(1) + \" \" + t.baseY.toFixed(1) +\n          \" L \" + t.x.toFixed(1) + \" \" + t.topY.toFixed(1));\n        t.tip.setAttribute(\"cx\", t.x.toFixed(1));\n        t.tip.setAttribute(\"cy\", t.topY.toFixed(1));\n        t.tip.setAttribute(\"r\", \"3.2\");\n        t.line.setAttribute(\"stroke-width\", \"3\");\n      }\n      // hammer recoil\n      if (t.hammerHit > 0.001) {\n        t.hammerHit *= Math.pow(0.02, dt);\n        t.hammer.setAttribute(\"y\", (t.baseY - t.hammerHit * 5).toFixed(1));\n      } else {\n        t.hammer.setAttribute(\"y\", t.baseY.toFixed(1));\n      }\n    }\n\n    if (running) requestAnimationFrame(frame);\n  }\n\n  document.addEventListener(\"visibilitychange\", function () {\n    if (document.hidden) { running = false; }\n    else if (!running) { running = true; lastTime = performance.now(); requestAnimationFrame(frame); }\n  });\n\n  // ===========================================================\n  //  KEYBOARD\n  // ===========================================================\n  var BASE_NOTE = 60;          // C4\n  var WHITE = [0, 2, 4, 5, 7, 9, 11, 12, 14, 16, 17, 19, 21, 23, 24];\n  var BLACK_AFTER = { 0:1, 2:3, 5:6, 7:8, 9:10, 12:13, 14:15, 17:18, 19:20, 21:22 };\n\n  var keysEl = document.getElementById(\"keys\");\n  var heldKeys = {};\n\n  function buildKeyboard() {\n    var whiteCount = WHITE.length;\n    var whiteEls = [];\n    for (var w = 0; w < whiteCount; w++) {\n      var note = BASE_NOTE + WHITE[w];\n      var key = document.createElement(\"div\");\n      key.className = \"wkey\";\n      key.dataset.note = note;\n      keysEl.appendChild(key);\n      whiteEls.push(key);\n      bindKey(key, note);\n    }\n    // black keys, positioned over white-key boundaries\n    for (var i = 0; i < whiteCount; i++) {\n      var semi = WHITE[i];\n      if (BLACK_AFTER.hasOwnProperty(semi)) {\n        var bnote = BASE_NOTE + BLACK_AFTER[semi];\n        var bk = document.createElement(\"div\");\n        bk.className = \"bkey\";\n        bk.dataset.note = bnote;\n        var leftPct = ((i + 1) / whiteCount) * 100;\n        bk.style.left = \"calc(\" + leftPct + \"% - 4.5%)\";\n        keysEl.appendChild(bk);\n        bindKey(bk, bnote);\n      }\n    }\n  }\n\n  function pressNote(el, note, vel) {\n    if (heldKeys[note]) return;\n    heldKeys[note] = true;\n    el.classList.add(\"down\");\n    noteOn(note, vel);\n    strikeTine(tineForNote(note), vel);\n  }\n  function releaseNote(el, note) {\n    if (!heldKeys[note]) return;\n    delete heldKeys[note];\n    el.classList.remove(\"down\");\n    noteOff(note);\n  }\n\n  function bindKey(el, note) {\n    el.addEventListener(\"mousedown\", function (e) { pressNote(el, note, 0.85); e.preventDefault(); });\n    el.addEventListener(\"mouseup\", function () { releaseNote(el, note); });\n    el.addEventListener(\"mouseleave\", function () { releaseNote(el, note); });\n    el.addEventListener(\"touchstart\", function (e) { pressNote(el, note, 0.85); e.preventDefault(); }, { passive: false });\n    el.addEventListener(\"touchend\", function (e) { releaseNote(el, note); e.preventDefault(); });\n  }\n\n  // computer keyboard A..K\n  var KEYMAP = { a:60, w:61, s:62, e:63, d:64, f:65, t:66, g:67, y:68, h:69, u:70, j:71, k:72 };\n  function elForNote(note) { return keysEl.querySelector('[data-note=\"' + note + '\"]'); }\n\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var note = KEYMAP[e.key.toLowerCase()];\n    if (note == null) return;\n    var el = elForNote(note);\n    if (el) pressNote(el, note, 0.9);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var note = KEYMAP[e.key.toLowerCase()];\n    if (note == null) return;\n    var el = elForNote(note);\n    if (el) releaseNote(el, note);\n  });\n\n  // ===========================================================\n  //  BOOT\n  // ===========================================================\n  function boot() {\n    injectDefs();\n    var controls = document.getElementById(\"controls\");\n    for (var i = 0; i < PARAMS.length; i++) {\n      controls.appendChild(buildKnob(PARAMS[i]));\n      // push default to engine on load\n      pushParam(PARAMS[i].index, PARAMS[i].def);\n    }\n    buildHarp();\n    buildKeyboard();\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  TINE PIANO — a polyphonic electric tine-piano instrument.\n//  Each voice models a struck metal tine with 2-operator FM: a sine\n//  CARRIER at the note pitch plus a higher-RATIO MODULATOR whose index\n//  decays fast, giving the bright bell/\"bark\" attack that melts into a\n//  mellow sine body. Velocity drives both the bark amount and brightness.\n//  A natural two-stage amplitude decay (fast initial, slow tail) plus a\n//  release tail keeps notes singing; a gentle stereo tremolo (opposed\n//  L/R amplitude wobble) adds the classic suitcase-piano sway. Up to\n//  twelve voices; chords ring with independent contours. No samples, no\n//  host imports — pure algorithm.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 12;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_BELL:   i32 = 0;  // 0..1  -> attack FM modulation depth (bark/bell)\nconst P_DECAY:  i32 = 1;  // 0..1  -> note decay time\nconst P_TONE:   i32 = 2;  // 0..1  -> overall brightness (body LP + mod ratio mix)\nconst P_TREMD:  i32 = 3;  // 0..1  -> tremolo depth\nconst P_TREMR:  i32 = 4;  // 0..1  -> tremolo rate (Hz)\nconst P_LEVEL:  i32 = 5;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhC:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // carrier phase (0..1)\nconst vPhM:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // modulator phase (0..1)\n\n// amplitude envelope (multiplicative decay + release)\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // current amp 0..1\nconst vAtk:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // attack ramp 0..1\nconst vGate2:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // release gate smoother 0..1\n\n// FM modulation index envelope (the bark: starts high, decays fast)\nconst vMEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// per-voice body low-pass state (one pole, mellows the sine body)\nconst vLP:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// global tremolo LFO phase (shared so the whole instrument sways together)\nlet tremPhase: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhC[v] = 0.0; vPhM[v] = 0.0;\n    vAmp[v] = 0.0; vAtk[v] = 0.0; vGate2[v] = 0.0;\n    vMEnv[v] = 0.0; vLP[v] = 0.0;\n  }\n  ageCounter = 0;\n  tremPhase = 0.0;\n  params[P_BELL]  = 0.55;\n  params[P_DECAY] = 0.55;\n  params[P_TONE]  = 0.5;\n  params[P_TREMD] = 0.35;\n  params[P_TREMR] = 0.3;\n  params[P_LEVEL] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fast sine from a normalized phase (0..1) using Mathf.sin\n@inline function sinp(phase: f32): f32 {\n  return f32(Mathf.sin(phase * TWO_PI));\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // prefer a free voice, else steal the oldest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vPhC[slot]    = 0.0;\n  vPhM[slot]    = 0.0;\n  vAmp[slot]    = 1.0;   // struck: full amplitude, then decays\n  vAtk[slot]    = 0.0;   // quick attack ramp removes the click\n  vGate2[slot]  = 1.0;\n  vMEnv[slot]   = 1.0;   // bark starts fully open\n  vLP[slot]     = 0.0;\n  vAge[slot]    = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;   // start release tail (gate smoother falls to 0)\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const bellN:  f32 = clampf(params[P_BELL],  0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE],  0.0, 1.0);\n  const tremD:  f32 = clampf(params[P_TREMD], 0.0, 1.0);\n  const tremRN: f32 = clampf(params[P_TREMR], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 0.9;\n\n  // bark depth: modulation index at the strike (peak FM amount)\n  const bellPeak: f32 = 1.2 + bellN * 7.0;        // ~1.2..8.2 radians\n\n  // bark decay: the bell/bark fades quickly (independent of body decay).\n  // time constant ~30..120 ms -> per-sample multiplier\n  const barkT: f32 = 0.03 + bellN * 0.09;\n  const barkDec: f32 = f32(Mathf.exp(-1.0 / (barkT * sr)));\n\n  // body decay time: short (~0.5 s) to long (~9 s) tail\n  const decT: f32 = 0.5 + decayN * decayN * 8.5;\n  const ampDec: f32 = f32(Mathf.exp(-1.0 / (decT * sr)));\n\n  // attack ramp speed (~3 ms) — soft enough to avoid clicks, fast enough to bark\n  const atkRate: f32 = 1.0 / (0.003 * sr);\n\n  // release smoother time constant (~0.18 s) after key up\n  const relCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.18 * sr)));\n\n  // modulator ratio: classic tine bell is a non-integer ratio (~ 2x..14x).\n  // Tone leans the spectrum brighter by raising the ratio a touch.\n  const modRatio: f32 = 3.0 + toneN * 11.0;\n\n  // body low-pass cutoff follows Tone (mellow to open) — softens the sine tail\n  const bodyHz: f32 = 700.0 + toneN * toneN * 6500.0;\n  const bodyG: f32 = clampf(f32(1.0 - Mathf.exp(-TWO_PI * bodyHz / sr)), 0.0, 0.999);\n\n  // tremolo: rate 0.5..7 Hz, opposed stereo wobble\n  const tremHz: f32 = 0.5 + tremRN * 6.5;\n  const tremInc: f32 = tremHz / sr;\n  const tremAmt: f32 = tremD * 0.5;   // up to +/-50% amplitude swing\n\n  // 12 voices summed -> scale so a full chord stays bounded\n  const voiceScale: f32 = 0.42;\n\n  let tp: f32 = tremPhase;\n\n  for (let f = 0; f < n; f++) {\n    // ---- stereo tremolo gains (opposed phase L/R) -------------------\n    tp += tremInc; if (tp >= 1.0) tp -= 1.0;\n    const lfo: f32 = sinp(tp);\n    const gL: f32 = 1.0 - tremAmt * (0.5 - 0.5 * lfo);\n    const gR: f32 = 1.0 - tremAmt * (0.5 + 0.5 * lfo);\n\n    let mono: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- attack ramp ------------------------------------------\n      let atk: f32 = vAtk[v];\n      if (atk < 1.0) { atk += atkRate; if (atk > 1.0) atk = 1.0; }\n      vAtk[v] = atk;\n\n      // ---- release gate smoother --------------------------------\n      let g2: f32 = vGate2[v];\n      if (vGate[v] == 0) {\n        g2 += relCoef * (0.0 - g2);\n      }\n      vGate2[v] = g2;\n\n      // ---- body amplitude decay ---------------------------------\n      let amp: f32 = vAmp[v];\n      amp *= ampDec;\n      vAmp[v] = amp;\n\n      const env: f32 = amp * atk * g2;\n\n      // voice finished? (decayed below threshold)\n      if (env <= 0.0002 && (vGate[v] == 0 || amp <= 0.0002)) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        vAmp[v] = 0.0; vMEnv[v] = 0.0; vLP[v] = 0.0;\n        continue;\n      }\n\n      // ---- FM bark envelope -------------------------------------\n      let menv: f32 = vMEnv[v];\n      menv *= barkDec;\n      vMEnv[v] = menv;\n\n      // ---- 2-operator FM ----------------------------------------\n      const incC: f32 = vFreq[v] / sr;\n      const incM: f32 = incC * modRatio;\n\n      let phM: f32 = vPhM[v];\n      phM += incM; if (phM >= 1.0) phM -= 1.0; if (phM < 0.0) phM += 1.0;\n      vPhM[v] = phM;\n\n      // modulation index: velocity makes harder strikes bark harder/brighter\n      const vel: f32 = vVel[v];\n      const velBark: f32 = 0.35 + vel * 0.85;\n      const modIndex: f32 = bellPeak * menv * velBark;\n      const modOut: f32 = sinp(phM) * modIndex;\n\n      let phC: f32 = vPhC[v];\n      phC += incC; if (phC >= 1.0) phC -= 1.0;\n      vPhC[v] = phC;\n\n      // carrier phase-modulated by the modulator\n      let car: f32 = f32(Mathf.sin(phC * TWO_PI + modOut));\n\n      // ---- per-voice body low-pass (mellow tail) ----------------\n      let lp: f32 = vLP[v];\n      lp += bodyG * (car - lp);\n      vLP[v] = lp;\n      // blend a little of the un-filtered carrier back so the bark stays present\n      const body: f32 = lp + (car - lp) * (0.25 + toneN * 0.5);\n\n      // velocity scales overall loudness too\n      const voiceAmp: f32 = env * (0.45 + vel * 0.55);\n      mono += body * voiceAmp;\n    }\n\n    let m: f32 = mono * voiceScale;\n    // gentle soft saturation for warmth + safety on big chords\n    m = f32(Mathf.tanh(m * 1.1)) * level;\n\n    outBuf[f] = m * gL;\n    outBuf[MAX_FRAMES + f] = m * gR;\n  }\n\n  tremPhase = tp;\n}\n",
  "publishedAt": 1751000080000
}