{
  "format": 1,
  "name": "Rotary Cabinet",
  "isInstrument": false,
  "explanation": "A twin-rotor rotating-speaker simulator. The signal is split into a low (woofer) and high (horn) band and each is spun through its own virtual driver, producing amplitude tremolo plus a short Doppler pitch vibrato; horn and drum turn at different rates and a Speed control morphs slow chorale to fast tremolo with inertia, so the rotors ramp rather than jump. Two virtual mics build the swirling stereo image.",
  "params": [
    {
      "name": "Speed",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.85
    },
    {
      "name": "Inertia",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Depth",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Width",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --n{syntax:'<number>';inherits:true;initial-value:0}\n:root{\n  --ac:#8d7bff;--ac2:#b08cff;\n  --wood1:#5a3b22;--wood2:#3d2716;--wood3:#2a1a0e;\n  --grille:#171008;\n  --spd:0.85;          /* normalised speed drives rotor rpm */\n  --rpm:14s;           /* horn rotation period, JS-updated */\n  --drumrpm:20s;\n  --depth:0.7;\n  --width:0.7;\n  --mix:1;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{margin:0;font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;color:#efe7da;\n  background:\n    radial-gradient(120% 80% at 50% -10%,#2a2236 0%,#140f1d 55%,#080610 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;overflow:hidden;user-select:none}\n\n/* ===== CABINET ===== */\n.cab{position:relative;width:100%;max-width:430px;border-radius:18px 18px 14px 14px;\n  padding:16px 16px 14px;\n  background:\n    /* corner blocks shading */\n    linear-gradient(160deg,rgba(255,220,170,.10),rgba(0,0,0,.34)),\n    /* vertical wood grain */\n    repeating-linear-gradient(91deg,var(--wood2) 0 6px,var(--wood1) 6px 11px,var(--wood3) 11px 13px),\n    linear-gradient(180deg,var(--wood1),var(--wood2) 60%,var(--wood3));\n  background-blend-mode:overlay,multiply,normal;\n  box-shadow:\n    0 38px 80px rgba(0,0,0,.7),\n    0 6px 0 #1a1009,            /* base plinth lip */\n    inset 0 2px 0 rgba(255,228,190,.22),\n    inset 0 -3px 8px rgba(0,0,0,.55),\n    inset 0 0 0 2px rgba(0,0,0,.45);\n  animation:cabIn .7s cubic-bezier(.2,.8,.2,1) both}\n@keyframes cabIn{from{opacity:0;transform:translateY(18px) scale(.97)}to{opacity:1;transform:none}}\n/* subtle cabinet vibration that intensifies with speed */\n.cab.shaking{animation:cabIn .7s cubic-bezier(.2,.8,.2,1) both, shake .18s linear infinite}\n@keyframes shake{0%{margin-left:0}25%{margin-left:.6px}50%{margin-left:0}75%{margin-left:-.6px}100%{margin-left:0}}\n\n/* nameplate */\n.plate{display:flex;align-items:center;gap:9px;margin:0 2px 12px;\n  padding:8px 12px;border-radius:9px;\n  background:linear-gradient(180deg,#161019,#0c0810);\n  box-shadow:inset 0 1px 0 rgba(255,255,255,.06),inset 0 -2px 6px rgba(0,0,0,.6),0 2px 3px rgba(0,0,0,.5);\n  border:1px solid rgba(0,0,0,.6)}\n.lamp{width:11px;height:11px;border-radius:50%;flex:none;\n  background:radial-gradient(circle at 35% 30%,#fff,var(--ac) 55%,#3a2d6e);\n  box-shadow:0 0 10px var(--ac),0 0 22px color-mix(in srgb,var(--ac) 60%,transparent);\n  animation:lamp calc(var(--rpm)/14*2.2s) ease-in-out infinite}\n@keyframes lamp{0%,100%{opacity:.6;transform:scale(.9)}50%{opacity:1;transform:scale(1.12)}}\n.plate h1{margin:0;font-size:15px;font-weight:800;letter-spacing:.18em;flex:1;\n  text-transform:uppercase;font-family:\"Times New Roman\",Georgia,serif;\n  background:linear-gradient(90deg,#d9cdb4,#fff 40%,var(--ac2) 75%,#d9cdb4);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 1px 0 rgba(0,0,0,.4)}\n.plate .mk{font-size:8.5px;letter-spacing:.22em;color:#8c7fae;text-transform:uppercase;\n  border:1px solid rgba(160,140,220,.35);border-radius:999px;padding:3px 8px}\n\n/* ===== SPEAKER WELL (grille + rotors) ===== */\n.well{position:relative;border-radius:11px;overflow:hidden;\n  height:268px;\n  background:radial-gradient(120% 100% at 50% 18%,#221a10,var(--grille) 70%,#0a0703);\n  box-shadow:inset 0 4px 14px rgba(0,0,0,.85),inset 0 0 0 3px #120c06,0 1px 0 rgba(255,228,190,.14);\n  border:1px solid #0a0703}\n/* horn chamber (top) and drum chamber (bottom) backlights */\n.glow{position:absolute;left:50%;transform:translateX(-50%);width:74%;border-radius:50%;\n  filter:blur(20px);pointer-events:none;opacity:calc(.30 + var(--depth)*.55);mix-blend-mode:screen}\n.glow.top{top:-8%;height:46%;background:radial-gradient(closest-side,var(--ac),transparent)}\n.glow.bot{bottom:-10%;height:50%;background:radial-gradient(closest-side,var(--ac2),transparent)}\n\n/* spinning rotors live BEHIND the grille slats */\n.rotorwrap{position:absolute;left:0;right:0;display:flex;align-items:center;justify-content:center}\n.rotorwrap.horn{top:6px;height:118px}\n.rotorwrap.drum{bottom:6px;height:118px}\n\n/* HORN: a two-throated rotor seen from the front, spins fast */\n.horn{position:relative;width:128px;height:104px;transform-style:preserve-3d;\n  animation:spin var(--rpm) linear infinite}\n.horn .hub{position:absolute;top:50%;left:50%;width:22px;height:22px;margin:-11px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#cfc4ff,#5a4ca8 60%,#241a4a);\n  box-shadow:0 0 10px var(--ac)}\n.horn .throat{position:absolute;top:50%;left:50%;width:60px;height:30px;margin:-15px 0 0 0;\n  transform-origin:0 50%}\n.horn .throat i{display:block;width:60px;height:30px;\n  /* a flared horn mouth, brighter at the bell */\n  background:linear-gradient(90deg,#2c2350 0%,#6c59c4 55%,var(--ac2) 100%);\n  clip-path:polygon(0 38%,40% 30%,100% 0,100% 100%,40% 70%);\n  box-shadow:0 0 14px color-mix(in srgb,var(--ac) 70%,transparent);border-radius:0 40% 40% 0/0 60% 60% 0}\n.horn .throat.b{transform:rotate(180deg)}\n.horn .throat.b i{filter:brightness(.62) saturate(.8)}  /* the receding (dummy) side dimmer */\n\n/* DRUM/BAFFLE: a scoop baffle that spins slower */\n.drum{position:relative;width:150px;height:96px;animation:spin var(--drumrpm) linear infinite}\n.drum .ring{position:absolute;inset:0;border-radius:50%/42%;\n  background:\n    conic-gradient(from 0deg,#1b1530,#3a2d66 18%,#1b1530 38%,#2a2150 60%,#140f24 80%,#1b1530);\n  box-shadow:inset 0 0 18px rgba(0,0,0,.8),0 0 16px color-mix(in srgb,var(--ac2) 40%,transparent)}\n.drum .scoop{position:absolute;top:50%;left:50%;width:84px;height:40px;margin:-20px 0 0 -42px;\n  border-radius:50% 50% 50% 50%/70% 70% 30% 30%;\n  background:linear-gradient(180deg,var(--ac2),#3a2d66 70%);\n  clip-path:polygon(0 100%,18% 0,82% 0,100% 100%);\n  box-shadow:0 0 16px color-mix(in srgb,var(--ac2) 60%,transparent)}\n.drum .mark{position:absolute;top:50%;left:50%;width:6px;height:46px;margin:-23px 0 0 -3px;border-radius:3px;\n  background:linear-gradient(var(--ac),transparent)}\n\n@keyframes spin{to{transform:rotate(360deg)}}\n\n/* GRILLE — horizontal wooden slats over the whole well (the thing you see through) */\n.grille{position:absolute;inset:0;pointer-events:none;\n  background:\n    repeating-linear-gradient(180deg,\n      rgba(0,0,0,0) 0 7px,\n      rgba(40,28,16,.0) 7px 9px,\n      #1c130a 9px 12px,\n      #2c1d10 12px 13px,\n      rgba(0,0,0,.55) 13px 16px);\n  box-shadow:inset 0 0 40px rgba(0,0,0,.7)}\n.grille::after{content:\"\";position:absolute;inset:0;\n  background:linear-gradient(105deg,rgba(255,235,200,.10) 0 18%,transparent 30%);mix-blend-mode:screen}\n/* vertical centre divider bar between horn and drum */\n.divider{position:absolute;left:8px;right:8px;top:50%;height:10px;transform:translateY(-50%);\n  background:linear-gradient(180deg,#3a260f,#160d05);border-radius:3px;\n  box-shadow:0 2px 4px rgba(0,0,0,.7),inset 0 1px 0 rgba(255,228,190,.18);pointer-events:none}\n\n/* stereo mic field indicator — two probes that spread with Width */\n.mics{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;z-index:3}\n.mic{position:absolute;top:0;width:4px;height:4px;border-radius:50%;background:#fff;\n  box-shadow:0 0 8px var(--ac),0 0 16px var(--ac);\n  transform:translate(calc(var(--side) * (32px + var(--width)*120px)),-2px)}\n.mic.l{--side:-1}.mic.r{--side:1}\n\n/* speed badge that morphs CHORALE <-> TREMOLO */\n.speedtag{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);z-index:4;\n  font-family:\"Times New Roman\",Georgia,serif;font-weight:700;letter-spacing:.3em;\n  font-size:11px;text-transform:uppercase;color:#efe7da;text-shadow:0 0 8px var(--ac),0 1px 2px #000;\n  padding:3px 10px;border-radius:6px;background:rgba(10,7,3,.5);\n  border:1px solid rgba(160,140,220,.3);opacity:.85;pointer-events:none}\n\n/* ===== CONTROL DECK ===== */\n.deck{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin:13px 2px 0;\n  padding:11px 8px 9px;border-radius:11px;\n  background:linear-gradient(180deg,#0f0a14,#070409);\n  box-shadow:inset 0 1px 0 rgba(255,255,255,.05),inset 0 -3px 7px rgba(0,0,0,.6),0 2px 4px rgba(0,0,0,.5);\n  border:1px solid rgba(0,0,0,.6)}\n.cell{display:flex;flex-direction:column;align-items:center;gap:5px;\n  animation:cellIn .55s both;animation-delay:var(--d)}\n@keyframes cellIn{from{opacity:0;transform:translateY(9px)}to{opacity:1;transform:none}}\n\n/* bakelite knob */\n.knob{position:relative;width:58px;height:58px;cursor:ns-resize;touch-action:none}\n.knob .ring{position:absolute;inset:-3px;border-radius:50%;\n  background:conic-gradient(from 225deg,var(--ac) calc(var(--n)*270deg),\n            rgba(255,255,255,.07) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(3px + var(--n)*7px) color-mix(in srgb,var(--ac) 65%,transparent));\n  transition:--n .12s cubic-bezier(.2,.8,.2,1)}\n.knob .ticks{position:absolute;inset:-7px;border-radius:50%;\n  background:repeating-conic-gradient(from 224deg,rgba(255,235,200,.30) 0 1deg,transparent 1deg 30deg);\n  -webkit-mask:radial-gradient(circle,transparent 31px,#000 32px,#000 34px,transparent 35px);\n  mask:radial-gradient(circle,transparent 31px,#000 32px,#000 34px,transparent 35px)}\n.knob .cap{position:absolute;inset:6px;border-radius:50%;\n  background:\n    radial-gradient(circle at 42% 30%,#4a4250,#241d2e 62%,#0c0810);\n  box-shadow:inset 0 2px 6px rgba(0,0,0,.7),inset 0 -1px 0 rgba(255,255,255,.07),0 2px 3px rgba(0,0,0,.6)}\n.knob .ptr{position:absolute;left:50%;top:7px;width:3px;height:20px;margin-left:-1.5px;border-radius:2px;\n  background:linear-gradient(var(--ac),var(--ac2));box-shadow:0 0 7px var(--ac);\n  transform-origin:50% 22px;transform:rotate(calc((var(--n) - .5)*270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.2,1)}\n.knob .bub{position:absolute;top:-15px;left:50%;transform:translate(-50%,4px) scale(.85);opacity:0;\n  font-size:10px;font-weight:800;color:#0c0810;background:var(--ac);padding:1px 6px;border-radius:5px;\n  font-variant-numeric:tabular-nums;box-shadow:0 4px 10px rgba(0,0,0,.5);transition:.14s;pointer-events:none;white-space:nowrap}\n.cell:hover .bub,.knob.act .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n\n/* the SPEED control is special: a chunky two-position-ish lever look */\n.cell.speed .knob .cap{background:radial-gradient(circle at 42% 30%,#5a4ca8,#2a2150 60%,#120c24)}\n\n.nm{font-size:9px;letter-spacing:.14em;text-transform:uppercase;color:#b6a9cf;font-weight:700}\n.val{font-size:11px;font-weight:800;color:#fff;font-variant-numeric:tabular-nums;\n  text-shadow:0 0 6px color-mix(in srgb,var(--ac) 50%,transparent)}\n\n.foot{margin:10px 4px 0;font-size:10px;line-height:1.5;color:#8c7fae;text-align:center;\n  font-family:\"Times New Roman\",Georgia,serif;font-style:italic;letter-spacing:.02em}\n</style></head><body>\n  <div class=\"cab\" id=\"cab\">\n    <div class=\"plate\">\n      <span class=\"lamp\"></span>\n      <h1>Rotary Cabinet</h1>\n      <span class=\"mk\">Twin&nbsp;Rotor</span>\n    </div>\n\n    <div class=\"well\">\n      <div class=\"glow top\"></div>\n      <div class=\"glow bot\"></div>\n\n      <div class=\"rotorwrap horn\">\n        <div class=\"horn\">\n          <div class=\"throat a\"><i></i></div>\n          <div class=\"throat b\"><i></i></div>\n          <div class=\"hub\"></div>\n        </div>\n      </div>\n\n      <div class=\"rotorwrap drum\">\n        <div class=\"drum\">\n          <div class=\"ring\"></div>\n          <div class=\"scoop\"></div>\n          <div class=\"mark\"></div>\n        </div>\n      </div>\n\n      <div class=\"grille\"></div>\n      <div class=\"divider\"></div>\n\n      <div class=\"mics\">\n        <div class=\"mic l\"></div>\n        <div class=\"mic r\"></div>\n      </div>\n      <div class=\"speedtag\" id=\"speedtag\">Tremolo</div>\n    </div>\n\n    <div class=\"deck\" id=\"deck\"></div>\n\n    <div class=\"foot\">Slow chorale &middot; fast tremolo &middot; ramped by inertia</div>\n  </div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Speed\",  i:0,min:0,max:1,def:0.85},\n    {name:\"Inertia\",i:1,min:0,max:1,def:0.45},\n    {name:\"Depth\",  i:2,min:0,max:1,def:0.7},\n    {name:\"Mix\",    i:3,min:0,max:1,def:1},\n    {name:\"Width\",  i:4,min:0,max:1,def:0.7}\n  ];\n  var root=document.documentElement, cab=document.getElementById('cab'),\n      deck=document.getElementById('deck'), speedtag=document.getElementById('speedtag');\n  var state={0:0.85,1:0.45,2:0.7,3:1,4:0.7};\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmt(v){ return Math.round(v*100)+'%'; }\n\n  // ---- motion engine: Speed sets target rpm, Inertia ramps toward it ----\n  // visual \"rpm\" expressed as rotation PERIOD (seconds); smaller = faster.\n  var targetSpd=state[0], curSpd=state[0];\n  function hornPeriod(s){ return (14 - s*12.4).toFixed(2)+'s'; }   // ~14s slow -> ~1.6s fast\n  function drumPeriod(s){ return (20 - s*16).toFixed(2)+'s'; }     // drum lags the horn\n  function applyMotion(){\n    root.style.setProperty('--rpm', hornPeriod(curSpd));\n    root.style.setProperty('--drumrpm', drumPeriod(curSpd));\n    root.style.setProperty('--spd', curSpd.toFixed(3));\n    speedtag.textContent = curSpd<0.33?'Chorale':(curSpd<0.7?'Brake':'Tremolo');\n    cab.classList.toggle('shaking', curSpd>0.62);\n  }\n  function tick(){\n    // inertia (param 1): 0 = snappy, 1 = very gradual ramp\n    var ease = 0.10 + (1-state[1])*0.85;     // higher inertia -> smaller step\n    if(Math.abs(targetSpd-curSpd)>0.0005){\n      curSpd += (targetSpd-curSpd)*ease*0.16;\n      applyMotion();\n    }\n    requestAnimationFrame(tick);\n  }\n\n  function buildKnob(p,idx){\n    var cell=document.createElement('div');\n    cell.className='cell'+(p.name==='Speed'?' speed':'');\n    cell.style.setProperty('--d',(idx*60)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"ticks\"></i><i class=\"ring\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n        '<span class=\"bub\"></span>'+\n      '</div>'+\n      '<div class=\"nm\">'+p.name+'</div><div class=\"val\"></div>';\n    var knob=cell.querySelector('.knob'),\n        ring=cell.querySelector('.ring'),\n        ptr=cell.querySelector('.ptr'),\n        out=cell.querySelector('.val'),\n        bub=cell.querySelector('.bub');\n    var val=p.def;\n    function norm(){ return (val-p.min)/(p.max-p.min||1); }\n    // paint(push): redraw the knob; only emit to the host when push===true,\n    // so the initial render doesn't spam default values before any interaction.\n    function paint(push){\n      var n=norm();\n      ring.style.setProperty('--n',n);\n      ptr.style.setProperty('--n',n);   /* ptr reads --n via inherit fallback */\n      knob.style.setProperty('--n',n);  /* drive both via the knob scope */\n      var t=fmt(val); out.textContent=t; bub.textContent=t;\n      state[p.i]=val; if(push) send(p.i,val);\n      reactGlobals();\n    }\n    function setN(n){ n=n<0?0:(n>1?1:n); val=p.min+(p.max-p.min)*n; paint(true); }\n    knob.addEventListener('pointerdown',function(e){\n      knob._d=1; knob._y=e.clientY; knob._n=norm(); knob.classList.add('act');\n      knob.setPointerCapture(e.pointerId); e.preventDefault(); });\n    knob.addEventListener('pointermove',function(e){\n      if(!knob._d)return; setN(knob._n+(knob._y-e.clientY)/180); });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ val=p.def; paint(true); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault();\n      setN(norm()+(e.deltaY<0?0.02:-0.02)); },{passive:false});\n    paint(false);   /* initial render: do NOT push defaults to the host */\n    deck.appendChild(cell);\n  }\n\n  // knob --n needs to reach .ring and .ptr; set it on the knob and let CSS read it\n  // (ring/ptr use var(--n) which inherits from .knob)\n  function reactGlobals(){\n    // map params onto the cabinet visuals\n    root.style.setProperty('--depth', state[2].toFixed(3));\n    root.style.setProperty('--width', state[4].toFixed(3));\n    root.style.setProperty('--mix', state[3].toFixed(3));\n    // Mix fades the rotor visibility (dry = quieter swirl)\n    var well=document.querySelector('.well');\n    if(well) well.style.filter='saturate('+(0.35+state[3]*0.9).toFixed(2)+') brightness('+(0.75+state[3]*0.35).toFixed(2)+')';\n    targetSpd=state[0];\n  }\n\n  function ready(){\n    PARAMS.forEach(buildKnob);\n    applyMotion();\n    reactGlobals();\n    requestAnimationFrame(tick);\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  ROTARY CABINET — rotating-speaker (twin-rotor) simulator\n//  Splits the signal into a low (woofer/drum) band and a high (horn) band\n//  with a Linkwitz-Riley-style crossover, then rotates each through its own\n//  virtual driver. Rotation gives BOTH amplitude tremolo (the driver swings\n//  toward and away from the mics) AND a small pitch/Doppler vibrato via a\n//  short modulated delay line. Horn and drum spin at slightly different\n//  rates and opposite phase. A Speed control morphs slow (chorale) <-> fast\n//  (tremolo) with INERTIA — the rotor rates RAMP up and down, they never\n//  jump. Two virtual mics, panned apart, build the stereo image.\n//  Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\n// ---- parameter map (indices MUST match spec.json) --------------------\nconst P_SPEED:   i32 = 0;  // 0..1  -> slow (chorale) .. fast (tremolo)\nconst P_INERTIA: i32 = 1;  // 0..1  -> rotor acceleration ramp time (short..long)\nconst P_DEPTH:   i32 = 2;  // 0..1  -> amount of AM + Doppler vibrato\nconst P_MIX:     i32 = 3;  // 0..1  -> dry/wet\nconst P_WIDTH:   i32 = 4;  // 0..1  -> stereo spread of the two mics\n\n// ---- target rotor rates (Hz) -----------------------------------------\n// Authentic twin-rotor speeds. Horn (treble) spins faster than the drum\n// (bass). Chorale ~ slow, tremolo ~ fast.\nconst HORN_SLOW: f32 = 0.80;\nconst HORN_FAST: f32 = 6.80;\nconst DRUM_SLOW: f32 = 0.70;\nconst DRUM_FAST: f32 = 6.00;\n\n// ---- modulated delay line for the Doppler vibrato --------------------\n// ~12 ms max per channel-band is plenty for a few semitones of pitch wobble.\nconst DELAY_LEN: i32 = 2048;            // ring buffer, > 12ms @ 48k\nconst hornDelay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst drumDelay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nlet dWrite: i32 = 0;\n\n// ---- crossover state (2x one-pole per band = ~12 dB/oct) -------------\nconst lpA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lpB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hpA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hpB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// ---- rotor phase + smoothed (inertial) rate state --------------------\nlet hornPhase: f32 = 0.0;\nlet drumPhase: f32 = 0.0;\nlet hornRate:  f32 = HORN_SLOW;   // current (smoothed) Hz\nlet drumRate:  f32 = DRUM_SLOW;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lpA[c] = 0.0; lpB[c] = 0.0; hpA[c] = 0.0; hpB[c] = 0.0;\n  }\n  for (let i = 0; i < DELAY_LEN; i++) {\n    hornDelay[i] = 0.0; drumDelay[i] = 0.0;\n  }\n  dWrite = 0;\n  hornPhase = 0.0;\n  drumPhase = 0.25;                 // start the rotors out of phase\n  // Start at rest (slow) so INERTIA audibly governs the spin-up ramp.\n  hornRate = HORN_SLOW;\n  drumRate = DRUM_SLOW;\n\n  params[P_SPEED]   = 0.85;  // start near fast so the spin-up is obvious\n  params[P_INERTIA] = 0.45;\n  params[P_DEPTH]   = 0.7;\n  params[P_MIX]     = 1.0;\n  params[P_WIDTH]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// read a delay line at a fractional sample distance `back` (in samples)\n// from the current write head, linearly interpolated.\n@inline function tapDelay(line: StaticArray<f32>, back: f32): f32 {\n  let bk: f32 = back;\n  if (bk < 1.0) bk = 1.0;\n  if (bk > f32(DELAY_LEN - 2)) bk = f32(DELAY_LEN - 2);\n  let rp: f32 = f32(dWrite) - bk;\n  if (rp < 0.0) rp += f32(DELAY_LEN);\n  if (rp < 0.0) rp = 0.0;\n  let i0: i32 = i32(rp);\n  if (i0 < 0) i0 = 0;\n  if (i0 >= DELAY_LEN) i0 = DELAY_LEN - 1;\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 -= DELAY_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const speed:   f32 = clampf(params[P_SPEED],   0.0, 1.0);\n  const inertia: f32 = clampf(params[P_INERTIA], 0.0, 1.0);\n  const depth:   f32 = clampf(params[P_DEPTH],   0.0, 1.0);\n  const mix:     f32 = clampf(params[P_MIX],     0.0, 1.0);\n  const width:   f32 = clampf(params[P_WIDTH],   0.0, 1.0);\n\n  // --- target rotor rates from Speed (linear morph slow<->fast) -------\n  const hornTarget: f32 = HORN_SLOW + (HORN_FAST - HORN_SLOW) * speed;\n  const drumTarget: f32 = DRUM_SLOW + (DRUM_FAST - DRUM_SLOW) * speed;\n\n  // --- inertia: one-pole smoothing of the rate toward the target ------\n  // Short ramp ~0.15 s, long ramp ~3.0 s. The drum is heavier than the horn.\n  const rampSec: f32 = 0.15 + inertia * 2.85;\n  const hornGlide: f32 = f32(1.0 - Mathf.exp(-1.0 / (rampSec * sampleRate)));\n  const drumGlide: f32 = f32(1.0 - Mathf.exp(-1.0 / (rampSec * 1.6 * sampleRate)));\n\n  // --- crossover coefficient (~800 Hz split) --------------------------\n  const xHz: f32 = 800.0;\n  const xc: f32 = f32(1.0 - Mathf.exp(-TWO_PI * xHz / sampleRate));\n\n  // --- Doppler delay swing (samples). Depth scales the excursion. -----\n  // Horn throws further than the drum (longer effective radius / higher band).\n  const hornSwing: f32 = depth * 0.0019 * sampleRate; // ~ up to 1.9 ms each way\n  const drumSwing: f32 = depth * 0.0011 * sampleRate; // ~ up to 1.1 ms each way\n  const baseDelay: f32 = 0.004 * sampleRate;          // 4 ms standing delay\n\n  // --- amplitude tremolo depth ---------------------------------------\n  const amDepth: f32 = depth * 0.55;\n\n  // --- stereo: two mics. width spreads horn/drum pan opposingly -------\n  const w: f32 = width;\n\n  const hornInc: f32 = TWO_PI / sampleRate;\n  const drumInc: f32 = TWO_PI / sampleRate;\n\n  // Mono-sum the input front-end (a rotary cab is fed one driver chain),\n  // but keep per-channel crossover state coherent by processing L/R.\n  let hp: f32 = hornPhase;\n  let dp: f32 = drumPhase;\n  let hr: f32 = hornRate;\n  let dr: f32 = drumRate;\n\n  for (let f = 0; f < n; f++) {\n    // glide the rotor rates toward their targets (inertia)\n    hr += hornGlide * (hornTarget - hr);\n    dr += drumGlide * (drumTarget - dr);\n\n    // advance rotor phases\n    hp += hornInc * hr; if (hp >= TWO_PI) hp -= TWO_PI;\n    dp += drumInc * dr; if (dp >= TWO_PI) dp -= TWO_PI;\n\n    // mono input feed (sum L+R)\n    const xl: f32 = inBuf[f];\n    const xr: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : xl;\n    const mono: f32 = (xl + xr) * 0.5;\n\n    // ---- 2-pole crossover (use channel-0 state for the mono feed) ----\n    let la: f32 = lpA[0]; let lb: f32 = lpB[0];\n    la = la + xc * (mono - la);\n    lb = lb + xc * (la - lb);\n    lpA[0] = la; lpB[0] = lb;\n    const low: f32 = lb;             // drum band\n    const high: f32 = mono - lb;     // horn band\n\n    // ---- write the bands into their delay lines ----------------------\n    hornDelay[dWrite] = high;\n    drumDelay[dWrite] = low;\n\n    // ---- Doppler taps: delay swings with rotor phase (sin) -----------\n    const hSin: f32 = Mathf.sin(hp);\n    const hCos: f32 = Mathf.cos(hp);\n    const dSin: f32 = Mathf.sin(dp);\n    const dCos: f32 = Mathf.cos(dp);\n\n    const hornBack: f32 = baseDelay + hornSwing * (1.0 + hSin);\n    const drumBack: f32 = baseDelay + drumSwing * (1.0 + dSin);\n\n    const hornWet: f32 = tapDelay(hornDelay, hornBack);\n    const drumWet: f32 = tapDelay(drumDelay, drumBack);\n\n    // ---- amplitude tremolo (driver facing the mic = louder) ----------\n    const hornAM: f32 = 1.0 - amDepth * (0.5 - 0.5 * hCos);\n    const drumAM: f32 = 1.0 - (amDepth * 0.7) * (0.5 - 0.5 * dCos);\n\n    const hornS: f32 = hornWet * hornAM;\n    const drumS: f32 = drumWet * drumAM;\n\n    // ---- two virtual mics: pan horn & drum by rotor phase ------------\n    // mic separation grows with Width. Horn and drum pan in opposition so\n    // the image swirls. Use cos of phase for the L/R balance.\n    const hornPan: f32 = w * 0.9 * hCos;   // -w..+w\n    const drumPan: f32 = -w * 0.7 * dCos;\n\n    const hornL: f32 = hornS * (0.5 - 0.5 * hornPan);\n    const hornR: f32 = hornS * (0.5 + 0.5 * hornPan);\n    const drumL: f32 = drumS * (0.5 - 0.5 * drumPan);\n    const drumR: f32 = drumS * (0.5 + 0.5 * drumPan);\n\n    // sum bands per channel; *2 compensates the 0.5/0.5 mic split gain\n    let wetL: f32 = (hornL + drumL) * 1.6;\n    let wetR: f32 = (hornR + drumR) * 1.6;\n\n    // ---- dry/wet ----------------------------------------------------\n    const outL: f32 = xl * (1.0 - mix) + wetL * mix;\n    const outR: f32 = xr * (1.0 - mix) + wetR * mix;\n\n    outBuf[f] = clampf(outL, -1.2, 1.2);\n    outBuf[MAX_FRAMES + f] = clampf(outR, -1.2, 1.2);\n\n    // advance the shared delay write head\n    dWrite++; if (dWrite >= DELAY_LEN) dWrite = 0;\n  }\n\n  hornPhase = hp;\n  drumPhase = dp;\n  hornRate = hr;\n  drumRate = dr;\n}\n",
  "publishedAt": 1751000013000
}