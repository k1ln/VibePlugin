{
  "format": 1,
  "name": "Drip Tank",
  "isInstrument": false,
  "explanation": "A drippy outboard spring-reverb tank — the long, boingy surf-amp spring sound, not a tight studio plate. Three parallel spring lines, each a chain of dispersive allpass filters (high frequencies arrive before low ones, giving the signature chirpy 'drip' and flutter) feeding a short damped delay loop. A built-in transient detector fires an excitation burst into the tank, so hard hits audibly boing. Controls: Mix, Dwell (send/level into the tank), Boing (excitation/drip intensity), Tone (dark to bright) and Decay (tail length). Bounded feedback — it never runs away.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Dwell",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Boing",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Drip Tank</title>\n<style>\n  :root{\n    --accent:#d98a4a;\n    --accent2:#ffd86a;\n    --tweed1:#c9a96a;\n    --tweed2:#8a6d3f;\n    --steel:#cdd2d8;\n    --steel-dk:#7e858d;\n    --panel:#1a1410;\n    --ink:#f6e9cf;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{height:100%}\n  body{\n    font-family:\"Futura\",\"Avenir Next\",-apple-system,Segoe UI,Roboto,sans-serif;\n    background:\n      radial-gradient(120% 120% at 50% -20%, #2a2017 0%, #140f0a 60%, #0a0705 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    padding:18px;user-select:none;overflow:hidden;\n  }\n  .amp{\n    width:min(560px,96vw);\n    border-radius:18px;\n    position:relative;\n    /* worn tweed cabinet */\n    background:\n      repeating-linear-gradient(48deg, rgba(0,0,0,.10) 0 3px, rgba(255,255,255,.04) 3px 6px),\n      repeating-linear-gradient(-48deg, rgba(0,0,0,.10) 0 3px, rgba(255,255,255,.03) 3px 6px),\n      linear-gradient(160deg, var(--tweed1), var(--tweed2));\n    box-shadow:\n      0 28px 60px rgba(0,0,0,.6),\n      inset 0 0 0 6px #2c2014,\n      inset 0 0 0 9px #463318,\n      inset 0 0 40px rgba(0,0,0,.45);\n    padding:16px;\n  }\n  /* leather handle */\n  .handle{\n    position:absolute;top:-13px;left:50%;transform:translateX(-50%);\n    width:120px;height:22px;border-radius:12px;\n    background:linear-gradient(#3a2a16,#241809);\n    box-shadow:0 3px 6px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.12);\n  }\n  .handle:before,.handle:after{\n    content:\"\";position:absolute;top:8px;width:8px;height:8px;border-radius:50%;\n    background:radial-gradient(circle at 30% 30%,#e9d7a6,#7a5c2c);\n  }\n  .handle:before{left:8px}.handle:after{right:8px}\n\n  /* faceplate */\n  .face{\n    border-radius:12px;\n    background:\n      linear-gradient(180deg, #e8923f 0%, #d98a4a 35%, #b96d33 100%);\n    box-shadow:\n      inset 0 2px 0 rgba(255,255,255,.35),\n      inset 0 -3px 8px rgba(0,0,0,.35),\n      0 2px 6px rgba(0,0,0,.4);\n    padding:14px 16px 18px;\n    position:relative;\n    overflow:hidden;\n  }\n  .face:before{ /* grime / wear */\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:\n      radial-gradient(60% 40% at 80% 110%, rgba(0,0,0,.28), transparent 70%),\n      radial-gradient(40% 30% at 10% -10%, rgba(255,255,255,.18), transparent 70%);\n    mix-blend-mode:multiply;opacity:.7;\n  }\n  .brand{\n    display:flex;align-items:center;justify-content:space-between;\n    margin-bottom:10px;position:relative;z-index:2;\n  }\n  .logo{\n    font-weight:800;letter-spacing:.18em;font-size:20px;\n    color:#2a1708;\n    text-shadow:0 1px 0 rgba(255,255,255,.35);\n  }\n  .logo b{color:#3a200a}\n  .sub{font-size:9px;letter-spacing:.34em;color:#5a3414;opacity:.85;margin-top:2px}\n\n  /* DRIP lamp */\n  .lamp-wrap{display:flex;align-items:center;gap:7px}\n  .lamp-label{font-size:9px;letter-spacing:.28em;color:#3a200a;font-weight:700}\n  .lamp{\n    width:15px;height:15px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #7a2a12, #2a0c04);\n    box-shadow:inset 0 0 4px #000, 0 0 0 2px #1c0d05;\n    transition:none;\n  }\n  .lamp.on{\n    background:radial-gradient(circle at 35% 30%, #fff2c4, var(--accent2) 40%, #e07a2a 100%);\n    box-shadow:0 0 14px 4px rgba(255,216,106,.85), inset 0 0 4px #fff, 0 0 0 2px #1c0d05;\n  }\n\n  /* ===== spring tank window (top-down view) ===== */\n  .tank{\n    position:relative;border-radius:9px;height:178px;margin:6px 0 16px;\n    background:\n      linear-gradient(180deg,#11171c,#070b0e 60%,#04070a);\n    box-shadow:\n      inset 0 0 0 2px #05080b,\n      inset 0 0 24px rgba(0,0,0,.8),\n      inset 0 2px 10px rgba(0,0,0,.7);\n    overflow:hidden;\n  }\n  .tank:before{ /* glass reflection */\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(115deg, rgba(255,255,255,.10) 0%, transparent 22%, transparent 80%, rgba(255,255,255,.05) 100%);\n  }\n  /* transducer end blocks */\n  .end{position:absolute;top:8px;bottom:8px;width:16px;border-radius:4px;\n    background:linear-gradient(90deg,#3a3f45,#1d2126);\n    box-shadow:inset 0 0 0 1px #0b0d10, 0 0 6px rgba(0,0,0,.6);z-index:4}\n  .end.l{left:8px}.end.r{right:8px}\n  .springs{position:absolute;left:24px;right:24px;top:0;bottom:0}\n  .springs svg{width:100%;height:100%;display:block}\n  .spring-path{\n    fill:none;stroke-linecap:round;\n    filter:drop-shadow(0 1px 1px rgba(0,0,0,.6));\n  }\n\n  /* ===== knob row ===== */\n  .knobs{\n    display:grid;grid-template-columns:repeat(5,1fr);gap:6px;\n    position:relative;z-index:2;\n  }\n  .cell{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .knob{\n    --ang:-135deg;\n    width:62px;height:62px;border-radius:50%;\n    position:relative;cursor:grab;touch-action:none;\n    background:\n      radial-gradient(circle at 38% 30%, #4a4f55 0%, #2b2f34 55%, #15181b 100%);\n    box-shadow:\n      0 5px 10px rgba(0,0,0,.55),\n      inset 0 2px 3px rgba(255,255,255,.18),\n      inset 0 -4px 8px rgba(0,0,0,.6),\n      0 0 0 3px #0c0e10, 0 0 0 4px rgba(255,216,106,.12);\n    transition:box-shadow .15s ease;\n  }\n  .knob:active{cursor:grabbing}\n  .knob.drag{\n    box-shadow:\n      0 5px 14px rgba(0,0,0,.6),\n      inset 0 2px 3px rgba(255,255,255,.2),\n      inset 0 -4px 8px rgba(0,0,0,.6),\n      0 0 0 3px #0c0e10, 0 0 0 5px rgba(255,216,106,.55);\n  }\n  .knob .skirt{ /* tick ring */\n    position:absolute;inset:-9px;border-radius:50%;\n    background:conic-gradient(from -135deg,\n      var(--accent) 0deg, var(--accent2) var(--fill,0deg), transparent var(--fill,0deg) 270deg, transparent 360deg);\n    -webkit-mask:radial-gradient(circle, transparent 0 31px, #000 32px 34px, transparent 35px);\n            mask:radial-gradient(circle, transparent 0 31px, #000 32px 34px, transparent 35px);\n    opacity:.95;\n  }\n  .knob .ptr{\n    position:absolute;left:50%;top:50%;width:3px;height:24px;border-radius:2px;\n    background:linear-gradient(#fff,#ffd86a);\n    transform-origin:50% 100%;\n    transform:translate(-50%,-100%) rotate(var(--ang));\n    box-shadow:0 0 5px rgba(255,216,106,.8);\n  }\n  .knob .cap{\n    position:absolute;inset:18px;border-radius:50%;\n    background:radial-gradient(circle at 38% 32%, #3b4046, #1c1f23);\n    box-shadow:inset 0 1px 2px rgba(255,255,255,.15);\n  }\n  .lbl{font-size:10px;letter-spacing:.16em;font-weight:700;color:#2a1708;text-shadow:0 1px 0 rgba(255,255,255,.3)}\n  .val{font-size:10px;font-variant-numeric:tabular-nums;color:#fff;\n    background:rgba(0,0,0,.32);padding:1px 7px;border-radius:8px;min-width:42px;text-align:center}\n\n  .hint{\n    text-align:center;font-size:8px;letter-spacing:.22em;color:#4a2c12;\n    margin-top:10px;opacity:.75;position:relative;z-index:2;\n  }\n\n  /* shimmer when struck */\n  @keyframes flutter{\n    0%{filter:none}\n    50%{filter:drop-shadow(0 0 4px var(--accent2)) brightness(1.4)}\n    100%{filter:none}\n  }\n</style>\n</head>\n<body>\n  <div class=\"amp\">\n    <div class=\"handle\"></div>\n    <div class=\"face\">\n      <div class=\"brand\">\n        <div>\n          <div class=\"logo\">DRIP <b>TANK</b></div>\n          <div class=\"sub\">OUTBOARD SPRING REVERB</div>\n        </div>\n        <div class=\"lamp-wrap\">\n          <span class=\"lamp-label\">DRIP</span>\n          <span class=\"lamp\" id=\"lamp\"></span>\n        </div>\n      </div>\n\n      <div class=\"tank\">\n        <div class=\"end l\"></div>\n        <div class=\"end r\"></div>\n        <div class=\"springs\">\n          <svg id=\"svg\" viewBox=\"0 0 500 170\" preserveAspectRatio=\"none\">\n            <path class=\"spring-path\" id=\"sp0\" stroke=\"#aeb6bf\" stroke-width=\"2.4\"/>\n            <path class=\"spring-path\" id=\"sp1\" stroke=\"#c7cdd4\" stroke-width=\"2.0\"/>\n            <path class=\"spring-path\" id=\"sp2\" stroke=\"#8f969e\" stroke-width=\"2.6\"/>\n          </svg>\n        </div>\n      </div>\n\n      <div class=\"knobs\" id=\"knobs\"></div>\n      <div class=\"hint\">DRAG VERTICALLY · DOUBLE-CLICK TO RESET</div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- param model (indices match assembly.ts) ----\n  var PARAMS = [\n    { name:\"Mix\",   index:0, min:0, max:1, def:0.35 },\n    { name:\"Dwell\", index:1, min:0, max:1, def:0.55 },\n    { name:\"Boing\", index:2, min:0, max:1, def:0.5 },\n    { name:\"Tone\",  index:3, min:0, max:1, def:0.45 },\n    { name:\"Decay\", index:4, min:0, max:1, def:0.5 }\n  ];\n  var values = PARAMS.map(function(p){ return p.def; });\n\n  function host(){ return (typeof window!==\"undefined\" && window.vstai) ? window.vstai : null; }\n  function send(i,v){ var h=host(); if(h && typeof h.setParam===\"function\"){ try{ h.setParam(i,v); }catch(e){} } }\n\n  // ---- build knobs ----\n  var knobsEl = document.getElementById(\"knobs\");\n  var widgets = [];\n  PARAMS.forEach(function(p,i){\n    var cell = document.createElement(\"div\"); cell.className=\"cell\";\n    var knob = document.createElement(\"div\"); knob.className=\"knob\"; knob.tabIndex=0;\n    var skirt=document.createElement(\"div\"); skirt.className=\"skirt\";\n    var cap=document.createElement(\"div\"); cap.className=\"cap\";\n    var ptr=document.createElement(\"div\"); ptr.className=\"ptr\";\n    knob.appendChild(skirt); knob.appendChild(cap); knob.appendChild(ptr);\n    var lbl=document.createElement(\"div\"); lbl.className=\"lbl\"; lbl.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    cell.appendChild(knob); cell.appendChild(lbl); cell.appendChild(val);\n    knobsEl.appendChild(cell);\n    widgets.push({knob:knob,ptr:ptr,skirt:skirt,val:val,p:p});\n\n    bindDrag(knob, i);\n  });\n\n  function norm(i){ var p=PARAMS[i]; return (values[i]-p.min)/(p.max-p.min); }\n  function render(i){\n    var w=widgets[i], t=norm(i);\n    var ang = -135 + t*270;\n    w.knob.style.setProperty(\"--ang\", ang+\"deg\");\n    w.skirt.style.setProperty(\"--fill\", (t*270)+\"deg\");\n    w.val.textContent = Math.round(t*100) + \"%\";\n  }\n  function setVal(i,v,push){\n    var p=PARAMS[i];\n    if(v<p.min)v=p.min; if(v>p.max)v=p.max;\n    values[i]=v; render(i);\n    if(push) send(i,v);\n  }\n\n  function bindDrag(knob,i){\n    var dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true; knob.classList.add(\"drag\");\n      startY = (e.touches?e.touches[0].clientY:e.clientY);\n      startV = norm(i);\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move);\n      window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false});\n      window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var fine = e.shiftKey?0.25:1;\n      var dt = (startY - y)/220 * fine;\n      var p=PARAMS[i];\n      setVal(i, p.min + (startV+dt)*(p.max-p.min), true);\n      e.preventDefault();\n    }\n    function up(){\n      dragging=false; knob.classList.remove(\"drag\");\n      window.removeEventListener(\"mousemove\",move);\n      window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move);\n      window.removeEventListener(\"touchend\",up);\n    }\n    knob.addEventListener(\"mousedown\",down);\n    knob.addEventListener(\"touchstart\",down,{passive:false});\n    knob.addEventListener(\"dblclick\",function(){ setVal(i,PARAMS[i].def,true); });\n    knob.addEventListener(\"wheel\",function(e){\n      var p=PARAMS[i];\n      setVal(i, values[i] - (e.deltaY>0?1:-1)*(p.max-p.min)*0.04, true);\n      e.preventDefault();\n    },{passive:false});\n    knob.addEventListener(\"keydown\",function(e){\n      var p=PARAMS[i], step=(p.max-p.min)*0.04;\n      if(e.key===\"ArrowUp\"||e.key===\"ArrowRight\"){ setVal(i,values[i]+step,true); e.preventDefault(); }\n      else if(e.key===\"ArrowDown\"||e.key===\"ArrowLeft\"){ setVal(i,values[i]-step,true); e.preventDefault(); }\n    });\n  }\n\n  // ---- animated spring tank ----\n  var lamp = document.getElementById(\"lamp\");\n  var paths = [document.getElementById(\"sp0\"),document.getElementById(\"sp1\"),document.getElementById(\"sp2\")];\n  var W=500,H=170;\n  var rows=[44,85,126];\n  // each spring: a coil drawn as a sine of small loops along x\n  var t0=performance.now();\n  var lastPeak=0, lampHold=0;\n\n  function readPeak(){\n    var h=host();\n    if(h && typeof h.getWetPeak===\"function\"){ try{ return h.getWetPeak()||0; }catch(e){} }\n    return null;\n  }\n  function readBoing(){\n    var h=host();\n    if(h && typeof h.getBoing===\"function\"){ try{ return h.getBoing()||0; }catch(e){} }\n    return null;\n  }\n\n  function buildSpring(yc, amp, coils, phase, sag){\n    // dispersive coil: loops get tighter chirp toward the right\n    var n=200, d=\"M\";\n    for(var k=0;k<=n;k++){\n      var x = 8 + (k/n)*(W-16);\n      var u = k/n;\n      // coil wobble + a traveling wave (the \"drip\" shimmer)\n      var coil = Math.sin(u*coils*6.2831853 + phase*3.0);\n      var wave = Math.sin(u*9.0 - phase*2.0) * (1-u*0.4);\n      var y = yc + sag*Math.sin(u*Math.PI) + amp*(coil*0.6 + wave*0.4);\n      d += (k===0?\"\":\"L\") + x.toFixed(1) + \" \" + y.toFixed(1) + \" \";\n    }\n    return d;\n  }\n\n  function frame(now){\n    var t=(now-t0)/1000;\n    var peak = readPeak();\n    // when no host telemetry, gently breathe so it's clearly alive\n    var energy;\n    if(peak===null){ energy = 0.18 + 0.12*Math.abs(Math.sin(t*1.3)); }\n    else { energy = Math.min(1, peak*1.8); }\n\n    var boing = readBoing();\n    if(boing===null){ boing = (Math.sin(t*0.9)>0.86)?0.8:0; }\n\n    // lamp: lit on boing / loud wet\n    var lit = (boing>0.04) || energy>0.55;\n    if(lit) lampHold = 8;\n    if(lampHold>0){ lamp.classList.add(\"on\"); lampHold--; }\n    else lamp.classList.remove(\"on\");\n\n    // Decay knob widens the wobble persistence, Boing scales the amplitude\n    var decay = values[4], boingK = values[2], tone = values[3];\n    var ampBase = 4 + energy*16*(0.5+boingK) ;\n    var jitter = (1+boing*3.0);\n\n    for(var s=0;s<3;s++){\n      var ph = t*(0.7 + s*0.22 + decay*0.6) + s*1.7;\n      var amp = (ampBase*(1 - s*0.18)) * jitter;\n      var coils = 26 - s*4 + tone*8;   // brighter tone => more visible chirp\n      var sag = 6 + s*3;\n      paths[s].setAttribute(\"d\", buildSpring(rows[s], amp, coils, ph, sag));\n      // brightness shimmer tied to energy\n      var b = 0.5 + energy*0.8 + (boing>0.05?0.4:0);\n      paths[s].style.filter = \"drop-shadow(0 1px 1px rgba(0,0,0,.6)) brightness(\"+b.toFixed(2)+\")\";\n    }\n    requestAnimationFrame(frame);\n  }\n\n  // ---- init ----\n  function start(){\n    PARAMS.forEach(function(p,i){ setVal(i, values[i], true); });\n    requestAnimationFrame(frame);\n  }\n  var h=host();\n  if(h && typeof h.onReady===\"function\"){ h.onReady(start); }\n  else { start(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DRIP TANK — drippy outboard spring reverb tank (effect)\n//\n//  Models the long, boingy \"surf amp\" spring sound of an outboard spring\n//  tank: 3 parallel spring lines, each a CHAIN of allpass filters\n//  (dispersive — high frequencies travel faster than low, giving the\n//  characteristic chirpy \"drip / boing\" + flutter) feeding a short\n//  damped delay loop. A transient detector drives an \"excite/boing\"\n//  burst into the tank so hard hits visibly boing. Tone tilts the loop\n//  damping dark->bright; Dwell sets the send level into the tank; Decay\n//  sets the loop feedback (bounded < 1, never runaway).\n//\n//  Pure algorithm — no samples. All f32, no alloc in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst P_MIX:   i32 = 0;   // 0..1 dry/wet\nconst P_DWELL: i32 = 1;   // 0..1 send/level into the tank\nconst P_BOING: i32 = 2;   // 0..1 excitation / drip intensity\nconst P_TONE:  i32 = 3;   // 0..1 dark -> bright (loop damping)\nconst P_DECAY: i32 = 4;   // 0..1 tail length (loop feedback)\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- spring lines: 3 per channel, each = allpass chain + delay loop ----\nconst NUM_SPRINGS: i32 = 3;\nconst AP_PER_SPRING: i32 = 8;          // dispersive allpass chain length\nconst TOTAL_AP: i32 = NUM_SPRINGS * AP_PER_SPRING; // 24 per channel\n\n// allpass state (one-sample, per allpass): we keep the input and output history\nconst apX: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * TOTAL_AP); // last input\nconst apY: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * TOTAL_AP); // last output\nconst apG: StaticArray<f32> = new StaticArray<f32>(NUM_SPRINGS * AP_PER_SPRING); // coeffs (shared L/R)\n\n// delay loop per spring (the \"tank length\" / boing repeat)\nconst DLEN: i32 = 4096;                 // power-of-two delay buffer per spring line\nconst DMASK: i32 = DLEN - 1;\nconst delayBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_SPRINGS * DLEN);\nconst delayPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_SPRINGS);\nconst springDelay: StaticArray<i32> = new StaticArray<i32>(NUM_SPRINGS); // loop length in samples\nconst dampState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_SPRINGS); // loop LP state\n\n// transient / excite detector (per channel)\nconst envFast: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst envSlow: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst boingEnv: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // decaying excite burst\n\n// input conditioning + output de-mud filters (per channel)\nconst preHP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);   // remove DC/lows before tank\nconst outLP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);   // tame fizz on the wet\n\n// telemetry for the GUI (last block peak of wet signal)\nlet wetPeak: f32 = 0.0;\nlet boingMeter: f32 = 0.0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  for (let i = 0; i < MAX_CHANNELS * TOTAL_AP; i++) { apX[i] = 0.0; apY[i] = 0.0; }\n  for (let i = 0; i < MAX_CHANNELS * NUM_SPRINGS * DLEN; i++) { delayBuf[i] = 0.0; }\n  for (let i = 0; i < MAX_CHANNELS * NUM_SPRINGS; i++) { delayPos[i] = 0; dampState[i] = 0.0; }\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    envFast[c] = 0.0; envSlow[c] = 0.0; boingEnv[c] = 0.0;\n    preHP[c] = 0.0; outLP[c] = 0.0;\n  }\n\n  // dispersive allpass coefficients: alternate sign + spread of values gives\n  // the chirpy frequency-dependent delay that makes the \"drip\". Each spring\n  // gets slightly different coeffs so the three lines are detuned.\n  for (let s = 0; s < NUM_SPRINGS; s++) {\n    const det: f32 = 1.0 + f32(s) * 0.13;\n    for (let k = 0; k < AP_PER_SPRING; k++) {\n      const idx: i32 = s * AP_PER_SPRING + k;\n      // coefficients near +/-0.6, alternating, scaled by detune\n      const base: f32 = 0.62 - f32(k) * 0.018;\n      const sign: f32 = (k & 1) == 0 ? 1.0 : -1.0;\n      apG[idx] = clampf(sign * base * (det > 1.4 ? 1.4 / det : 1.0), -0.85, 0.85);\n    }\n  }\n\n  // spring loop lengths in samples — short, slightly different per line so the\n  // boings repeat at musically-close but distinct rates (the \"tank\" character).\n  const baseMs: f32 = 21.0; // ~21 ms base round-trip\n  for (let s = 0; s < NUM_SPRINGS; s++) {\n    const ms: f32 = baseMs + f32(s) * 6.5;\n    let d: i32 = i32(ms * 0.001 * sampleRate);\n    if (d < 16) d = 16;\n    if (d > DLEN - 4) d = DLEN - 4;\n    springDelay[s] = d;\n  }\n\n  params[P_MIX] = 0.35; params[P_DWELL] = 0.55; params[P_BOING] = 0.5;\n  params[P_TONE] = 0.45; params[P_DECAY] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// telemetry getters for the GUI animation\nexport function getWetPeak(): f32  { return wetPeak; }\nexport function getBoing(): f32    { return boingMeter; }\n\n// one dispersive allpass: y = -g*x + xPrev + g*yPrev  (first-order allpass)\n@inline function allpass(ch: i32, idx: i32, x: f32): f32 {\n  const si: i32 = ch * TOTAL_AP + idx;\n  const g: f32 = apG[idx];\n  const xPrev: f32 = apX[si];\n  const yPrev: f32 = apY[si];\n  const y: f32 = f32(-g * x + xPrev + g * yPrev);\n  apX[si] = x;\n  apY[si] = y;\n  return y;\n}\n\nexport function process(n: i32): void {\n  const mix: f32   = clampf(params[P_MIX], 0.0, 1.0);\n  const dwell: f32 = clampf(params[P_DWELL], 0.0, 1.0);\n  const boing: f32 = clampf(params[P_BOING], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n\n  // pre high-pass corner ~140 Hz (springs hate low end — keeps the tank from booming)\n  const cHP: f32 = f32(1.0 - Mathf.exp(-2.0 * PI * 140.0 / sampleRate));\n  // wet output low-pass: Tone moves brightness 1.8k (dark) -> 8k (bright)\n  const toneHz: f32 = 1800.0 + toneN * toneN * 6200.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-2.0 * PI * toneHz / sampleRate));\n  // loop damping LP: darker tone => more damping in the feedback path\n  const dampHz: f32 = 2200.0 + toneN * 5000.0;\n  const cDamp: f32 = f32(1.0 - Mathf.exp(-2.0 * PI * dampHz / sampleRate));\n\n  // feedback (decay) — strictly < 1 so the tank can never run away\n  const fb: f32 = 0.45 + decayN * 0.52;       // 0.45..0.97\n  const sendLevel: f32 = dwell * 1.4;          // into the tank\n  const exciteAmt: f32 = 0.5 + boing * 2.5;    // transient spike gain\n\n  // transient detector time constants\n  const aFast: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.0006 * sampleRate)));\n  const aSlow: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.030 * sampleRate)));\n  const boingDecay: f32 = f32(Mathf.exp(-1.0 / (0.040 * sampleRate))); // ~40ms boing burst\n\n  // output normalisation: more springs + feedback => scale down to keep peak<~1\n  const wetGain: f32 = 0.42;\n\n  let blockPeak: f32 = 0.0;\n  let blockBoing: f32 = boingMeter;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let hp: f32 = preHP[c];\n    let lp: f32 = outLP[c];\n    let ef: f32 = envFast[c];\n    let es: f32 = envSlow[c];\n    let be: f32 = boingEnv[c];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n\n      // --- input conditioning: high-pass ---\n      hp = hp + cHP * (dry - hp);\n      const cond: f32 = dry - hp;\n\n      // --- transient detection -> boing excitation burst ---\n      const rect: f32 = cond < 0.0 ? -cond : cond;\n      ef = ef + aFast * (rect - ef);\n      es = es + aSlow * (rect - es);\n      const trans: f32 = ef - es;                 // positive on attacks\n      if (trans > 0.02) {\n        const hit: f32 = trans * exciteAmt;\n        if (hit > be) be = hit;                   // retrigger the burst\n      }\n      be = be * boingDecay;\n      if (be > blockBoing) blockBoing = be;\n\n      // excitation fed into the tank: conditioned signal + a sharp boing spike\n      const exc: f32 = (cond + be * (cond >= 0.0 ? 1.0 : -1.0)) * sendLevel;\n\n      // --- run the 3 parallel spring lines ---\n      let wet: f32 = 0.0;\n      for (let s = 0; s < NUM_SPRINGS; s++) {\n        const dBase: i32 = (c * NUM_SPRINGS + s) * DLEN;\n        const li: i32 = c * NUM_SPRINGS + s;\n        const dlen: i32 = springDelay[s];\n        let wp: i32 = delayPos[li];\n        const rp: i32 = (wp - dlen) & DMASK;\n        const delayed: f32 = delayBuf[dBase + rp];\n\n        // loop damping low-pass in the feedback path\n        let ds: f32 = dampState[li];\n        ds = ds + cDamp * (delayed - ds);\n\n        // dispersive allpass chain produces the chirpy drip\n        let v: f32 = exc + ds * fb;\n        for (let k = 0; k < AP_PER_SPRING; k++) {\n          v = allpass(c, s * AP_PER_SPRING + k, v);\n        }\n        // soft saturation in the loop keeps it bounded even at high decay\n        if (v > 1.5) v = 1.5; else if (v < -1.5) v = -1.5;\n        const vsoft: f32 = f32(v - 0.18 * v * v * v * 0.296296); // gentle cubic limit\n\n        delayBuf[dBase + wp] = vsoft;\n        wp = (wp + 1) & DMASK;\n        delayPos[li] = wp;\n        dampState[li] = ds;\n\n        // weight the three lines slightly differently (stereo spread of character)\n        const w: f32 = s == 0 ? 1.0 : (s == 1 ? 0.82 : 0.66);\n        wet += vsoft * w;\n      }\n\n      wet = wet * wetGain;\n\n      // --- output tone low-pass ---\n      lp = lp + cTone * (wet - lp);\n      const wetOut: f32 = lp;\n\n      const wpk: f32 = wetOut < 0.0 ? -wetOut : wetOut;\n      if (wpk > blockPeak) blockPeak = wpk;\n\n      outBuf[base + f] = dry * (1.0 - mix) + wetOut * mix;\n    }\n\n    preHP[c] = hp;\n    outLP[c] = lp;\n    envFast[c] = ef;\n    envSlow[c] = es;\n    boingEnv[c] = be;\n  }\n\n  wetPeak = blockPeak;\n  boingMeter = blockBoing * 0.9; // slow visual decay between blocks\n}\n",
  "publishedAt": 1751000106000
}