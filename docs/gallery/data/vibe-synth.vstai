{"format":1,"name":"VibeSynth","isInstrument":true,"explanation":"A monophonic analog-style synthesizer: three anti-aliased oscillators with per-osc octave and detune, a noise source, a four-pole resonant ladder filter with drive, independent filter and amplifier ADSR envelopes, and portamento glide. A stereo effects rack adds chorus, ping-pong delay and reverb, with live oscilloscope + spectrum displays. Play it with the keyboard, your computer keys (a\u2013k), or MIDI.","params":[{"name":"Tune","index":0,"min":-12,"max":12,"default":0,"value":0},{"name":"Glide","index":1,"min":0,"max":1,"default":0.05,"value":0.05},{"name":"Osc1 Wave","index":2,"min":0,"max":3,"default":1,"value":1},{"name":"Osc1 Oct","index":3,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Wave","index":4,"min":0,"max":3,"default":1,"value":1},{"name":"Osc2 Oct","index":5,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Detune","index":6,"min":-50,"max":50,"default":7,"value":7},{"name":"Osc3 Wave","index":7,"min":0,"max":3,"default":2,"value":2},{"name":"Osc3 Oct","index":8,"min":-2,"max":2,"default":-1,"value":-1},{"name":"Osc3 Detune","index":9,"min":-50,"max":50,"default":-5,"value":-5},{"name":"Mix Osc1","index":10,"min":0,"max":1,"default":0.9,"value":0.9},{"name":"Mix Osc2","index":11,"min":0,"max":1,"default":0.7,"value":0.7},{"name":"Mix Osc3","index":12,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Noise","index":13,"min":0,"max":1,"default":0.06,"value":0.06},{"name":"Cutoff","index":14,"min":0,"max":1,"default":0.42,"value":0.42},{"name":"Resonance","index":15,"min":0,"max":1,"default":0.55,"value":0.55},{"name":"Filter Env","index":16,"min":0,"max":1,"default":0.6,"value":0.6},{"name":"Filt Atk","index":17,"min":0,"max":1,"default":0.04,"value":0.04},{"name":"Filt Dec","index":18,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Filt Sus","index":19,"min":0,"max":1,"default":0.25,"value":0.25},{"name":"Filt Rel","index":20,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Atk","index":21,"min":0,"max":1,"default":0.02,"value":0.02},{"name":"Amp Dec","index":22,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Sus","index":23,"min":0,"max":1,"default":0.8,"value":0.8},{"name":"Amp Rel","index":24,"min":0,"max":1,"default":0.35,"value":0.35},{"name":"Drive","index":25,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Volume","index":26,"min":0,"max":1,"default":0.8,"value":0.8},{"name":"Chorus Mix","index":27,"min":0,"max":1,"default":0.35,"value":0.35},{"name":"Chorus Rate","index":28,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Chorus Depth","index":29,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Delay Mix","index":30,"min":0,"max":1,"default":0.22,"value":0.22},{"name":"Delay Time","index":31,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Delay Feedback","index":32,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Reverb Mix","index":33,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Reverb Size","index":34,"min":0,"max":1,"default":0.6,"value":0.6},{"name":"Reverb Damp","index":35,"min":0,"max":1,"default":0.4,"value":0.4}],"wasmBase64":"","html":"<!doctype html><html><head><meta charset=\"utf-8\">\n<style>\n  :root{\n    --bg:#0a0b0e; --surface:#14161c; --surface-2:#191c24; --line:rgba(255,255,255,.08);\n    --line-2:rgba(255,255,255,.13); --ink:#eceef3; --ink-2:#c2c8d4; --muted:#79818f;\n    --accent:#4f8dff; --accent-2:#9d7bff; --ok:#46d39a;\n    --sans:ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,Roboto,sans-serif;\n    --mono:ui-monospace,\"SF Mono\",\"JetBrains Mono\",Menlo,monospace;\n  }\n  *{box-sizing:border-box}\n  body{margin:0;font:13px var(--sans);color:var(--ink);\n    background:radial-gradient(130% 100% at 50% -10%,#1a1e27,var(--surface) 60%);\n    padding:14px 16px 18px;user-select:none;-webkit-user-select:none}\n  .head{display:flex;align-items:baseline;gap:10px;margin:0 0 12px}\n  .head b{font-size:14px;letter-spacing:.02em}\n  .head span{font:600 11px var(--mono);color:var(--muted);letter-spacing:.06em}\n\n  /* ---- control sections ---- */\n  .rack{display:grid;grid-template-columns:repeat(auto-fit,minmax(206px,1fr));gap:11px;align-items:start}\n  .sect{background:linear-gradient(180deg,var(--surface-2),#15171d);border:1px solid var(--line);\n    border-radius:13px;padding:12px 13px 14px;box-shadow:0 1px 0 rgba(255,255,255,.04) inset}\n  .sect h3{font:600 9px var(--mono);letter-spacing:.17em;color:var(--accent);opacity:.9;margin:0 0 11px;\n    text-transform:uppercase;display:flex;align-items:center;gap:7px}\n  .sect h3::after{content:\"\";flex:1;height:1px;background:var(--line)}\n  .knobs{display:flex;gap:15px 14px;flex-wrap:wrap;justify-content:center}\n\n  .knob{width:54px;display:flex;flex-direction:column;align-items:center;gap:5px}\n  .ring{width:48px;height:48px;border-radius:50%;padding:3px;cursor:ns-resize;position:relative;touch-action:none;\n    background:conic-gradient(from 225deg,\n      var(--accent) 0 var(--deg,0deg),\n      rgba(255,255,255,.09) var(--deg,0deg) 270deg,\n      transparent 270deg 360deg);\n    filter:drop-shadow(0 0 0 transparent);transition:filter .12s}\n  .knob:hover .ring{filter:drop-shadow(0 0 6px rgba(79,141,255,.45))}\n  .dial{position:absolute;inset:3px;border-radius:50%;\n    background:radial-gradient(58% 58% at 38% 30%,#333845,#181b22 70%,#0d0f14);\n    border:1px solid rgba(0,0,0,.55);box-shadow:0 2px 6px #0009,0 1px 0 rgba(255,255,255,.06) inset}\n  .dial::after{content:\"\";position:absolute;left:50%;top:5px;width:2px;height:13px;border-radius:2px;\n    background:#eef3fc;transform-origin:50% 16px;transform:translateX(-50%) rotate(var(--rot,-135deg));\n    box-shadow:0 0 6px var(--accent)}\n  .knob label{font:600 9px var(--sans);letter-spacing:.05em;color:var(--ink-2);text-align:center}\n  .knob .val{font:600 9px var(--mono);color:var(--muted)}\n  /* compact knob for the modulation matrix */\n  .knob.sm{width:46px} .knob.sm .ring{width:38px;height:38px}\n  .knob.sm .dial::after{height:11px;top:4px;transform-origin:50% 14px}\n\n  .oscname{font:700 9px var(--sans);letter-spacing:.1em;color:var(--ink-2);margin-bottom:6px;text-transform:uppercase}\n  .waves{display:flex;gap:3px;margin-bottom:8px}\n  .waves button{flex:1;display:flex;align-items:center;justify-content:center;\n    background:#0e1015;border:1px solid var(--line);color:var(--muted);border-radius:7px;\n    padding:5px 0;cursor:pointer;line-height:0;transition:.12s}\n  .waves button svg{width:26px;height:14px;display:block}\n  .waves button:hover{color:var(--ink-2);border-color:var(--line-2)}\n  .waves button.on{color:#fff;background:linear-gradient(180deg,#5b97ff,var(--accent));border-color:#3f74e0;\n    box-shadow:0 0 11px rgba(79,141,255,.4)}\n  .col{display:flex;flex-direction:column;align-items:center}\n\n  /* ---- LFO modulation matrix ---- */\n  .sect.mod{grid-column:1/-1}\n  .matrix{display:grid;gap:8px 12px;align-items:center}\n  .matrix .corner{font:600 8px var(--mono);letter-spacing:.14em;color:var(--muted);text-transform:uppercase}\n  .matrix .desthead{font:600 8px var(--mono);letter-spacing:.12em;color:var(--accent-2);\n    text-transform:uppercase;text-align:center;opacity:.9}\n  .lfo-src{display:flex;align-items:center;gap:10px}\n  .lfo-src .name{font:700 10px var(--sans);letter-spacing:.06em;color:var(--ink-2);width:42px}\n  .lfo-src .waves{margin:0;width:120px}\n  .matrix .cell{display:flex;justify-content:center}\n\n  /* ---- intro build animation (homepage only; gated by window.__vstaiIntro) ---- */\n  .build{margin:2px 0 14px;display:flex;flex-direction:column;gap:7px;\n    transition:opacity .5s ease,margin .5s ease}\n  .chat{display:flex;align-items:center;gap:11px;font-size:15px;\n    background:linear-gradient(180deg,#171b25,#11141b);border:1px solid var(--line-2);\n    border-radius:12px;padding:12px 15px;box-shadow:0 16px 50px -26px #000,inset 0 1px 0 rgba(255,255,255,.05)}\n  .chat .spark{width:18px;height:18px;flex:0 0 auto;color:var(--accent);\n    filter:drop-shadow(0 0 5px rgba(79,141,255,.6))}\n  .chat .tag{font:600 9px var(--mono);letter-spacing:.14em;color:var(--muted);text-transform:uppercase;\n    flex:0 0 auto;border-right:1px solid var(--line);padding-right:11px}\n  .ctext{font-weight:600;color:var(--ink);white-space:pre}\n  .ccaret{width:2px;height:1.05em;border-radius:2px;background:var(--accent);\n    box-shadow:0 0 8px var(--accent);animation:cbl 1s steps(1) infinite}\n  .chat.ready .ccaret{display:none}\n  @keyframes cbl{50%{opacity:0}}\n  .chat .skiph{margin-left:auto;flex:0 0 auto;font:600 9px var(--mono);letter-spacing:.12em;\n    color:var(--muted);opacity:.55;text-transform:uppercase}\n  .chat.ready .skiph{display:none}\n  .bcap{min-height:15px;font:600 12px var(--mono);letter-spacing:.04em;color:var(--muted);padding-left:2px}\n  .bcap.ok{color:var(--ok);font-size:13px}\n  .sect.pre,.head.pre{opacity:0;transform:translateY(12px) scale(.985);pointer-events:none}\n  .sect.in,.head.in{opacity:1;transform:none;\n    transition:opacity .5s ease,transform .55s cubic-bezier(.2,.7,.2,1)}\n</style></head>\n<body>\n  <div class=\"head\"><b>VibeSynth</b><span>monophonic analog \u00b7 3 osc \u00b7 ladder filter \u00b7 LFO matrix \u00b7 FX</span></div>\n\n  <div class=\"rack\" id=\"rack\"></div>\n\n<script>\nconst K=(label,idx,min,max,def,unit,step)=>({type:'knob',label,idx,min,max,def,unit,step});\nconst OSC=(name,wIdx,octIdx,detIdx,defWave,defOct,defDet)=>({type:'osc',name,wIdx,octIdx,detIdx,defWave,defOct,defDet});\nconst SECTIONS=[\n  {h:'Oscillator Bank',items:[ OSC('Osc 1',2,3,null,1,0,0), OSC('Osc 2',4,5,6,1,0,7), OSC('Osc 3',7,8,9,2,-1,-5) ]},\n  {h:'Mixer',items:[ K('Osc 1',10,0,1,0.9), K('Osc 2',11,0,1,0.7), K('Osc 3',12,0,1,0.5), K('Noise',13,0,1,0.06) ]},\n  {h:'Ladder Filter',items:[ K('Cutoff',14,0,1,0.42), K('Reso',15,0,1,0.55), K('Env',16,0,1,0.6),\n     K('Atk',17,0,1,0.04), K('Dec',18,0,1,0.5), K('Sus',19,0,1,0.25), K('Rel',20,0,1,0.4) ]},\n  {h:'Loudness \u00b7 Glide',items:[ K('Atk',21,0,1,0.02), K('Dec',22,0,1,0.4), K('Sus',23,0,1,0.8), K('Rel',24,0,1,0.35),\n     K('Drive',25,0,1,0.3), K('Glide',1,0,1,0.05), K('Tune',0,-12,12,0,'st',1), K('Vol',26,0,1,0.8) ]},\n  {h:'Chorus',items:[ K('Mix',27,0,1,0.35), K('Rate',28,0,1,0.3), K('Depth',29,0,1,0.5) ]},\n  {h:'Ping-Pong Delay',items:[ K('Mix',30,0,1,0.22), K('Time',31,0,1,0.4), K('F.back',32,0,1,0.4) ]},\n  {h:'Reverb',items:[ K('Mix',33,0,1,0.3), K('Size',34,0,1,0.6), K('Damp',35,0,1,0.4) ]},\n];\n\n/* ---- exact waveform icons (stroked SVG paths in a 28x16 box) ----------- */\nconst WAVE_PATHS={\n  sine:'M1 8 C 4.3 0.6, 9.7 0.6, 13 8 C 16.3 15.4, 21.7 15.4, 25 8',\n  tri :'M1 8 L 5 2 L 13 14 L 21 2 L 25 8',\n  saw :'M2 14 L 9 2 L 9 14 L 16 2 L 16 14 L 23 2',\n  sq  :'M1 13 L 1 3 L 8 3 L 8 13 L 15 13 L 15 3 L 22 3 L 22 13 L 25 13',\n  pulse:'M1 13 L 5 13 L 5 3 L 8 3 L 8 13 L 15 13 L 15 3 L 18 3 L 18 13 L 25 13',\n};\nconst waveSVG=(name)=>'<svg viewBox=\"0 0 26 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" '+\n  'stroke-linejoin=\"round\" stroke-linecap=\"round\"><path d=\"'+WAVE_PATHS[name]+'\"/></svg>';\n\n/* ---- params: setP tracks a base value so the LFO matrix can add on top --- */\nconst base={};\nfunction raw(i,v){ if(window.vstai) window.vstai.setParam(i,v); }\nfunction setP(i,v){ base[i]=v; raw(i,v); }\n\nfunction makeWaveBtns(icons,def,onPick){\n  const waves=document.createElement('div'); waves.className='waves';\n  const btns=icons.map((name,wi)=>{const b=document.createElement('button');\n    b.innerHTML=waveSVG(name); b.title=name[0].toUpperCase()+name.slice(1);\n    b.onclick=()=>{onPick(wi);btns.forEach(x=>x.classList.remove('on'));b.classList.add('on');};return b;});\n  btns[def].classList.add('on'); waves.append(...btns); return waves;\n}\n\nfunction knob(s){\n  const wrap=document.createElement('div'); wrap.className='knob'+(s.sm?' sm':'');\n  const ring=document.createElement('div'); ring.className='ring';\n  const dial=document.createElement('div'); dial.className='dial'; ring.append(dial);\n  const lab=document.createElement('label'); lab.textContent=s.label;\n  const val=document.createElement('div'); val.className='val';\n  wrap.append(ring,lab,val); let v=s.def;\n  const snap=(x)=> s.step? Math.round(x/s.step)*s.step : x;\n  const send=(sv)=> s.set? s.set(sv) : setP(s.idx,sv);\n  function apply(emit){\n    // keep v as a continuous accumulator (clamped); snap only for display + output,\n    // otherwise small drag increments on a stepped knob round back before they add up.\n    v=Math.max(s.min,Math.min(s.max,v));\n    const sv=snap(v);\n    const t=(sv-s.min)/(s.max-s.min);\n    ring.style.setProperty('--deg',(t*270)+'deg');\n    dial.style.setProperty('--rot',(-135+t*270)+'deg');\n    val.textContent = s.unit==='st'?(sv>0?'+':'')+sv.toFixed(0)+'st':(s.step?sv.toFixed(0):sv.toFixed(2));\n    if(emit) send(sv);\n  }\n  let ly=0;\n  const dn=(e)=>{ly=e.clientY;try{ring.setPointerCapture(e.pointerId);}catch(_){ }e.preventDefault();};\n  const mv=(e)=>{if(!ring.hasPointerCapture||!ring.hasPointerCapture(e.pointerId))return;const y=e.clientY;v+=(ly-y)*(s.max-s.min)/170;ly=y;apply(true);};\n  const up=(e)=>{try{ring.releasePointerCapture(e.pointerId);}catch(_){ }};\n  ring.addEventListener('pointerdown',dn);\n  ring.addEventListener('pointermove',mv);\n  ring.addEventListener('pointerup',up);\n  ring.addEventListener('pointercancel',up);\n  ring.addEventListener('dblclick',()=>{v=s.def;apply(true);});\n  apply(true); return wrap;\n}\nfunction osc(s){\n  const col=document.createElement('div'); col.className='col';\n  const name=document.createElement('div'); name.className='oscname'; name.textContent=s.name;\n  setP(s.wIdx,s.defWave);\n  const waves=makeWaveBtns(['tri','saw','sq','pulse'],s.defWave,(wi)=>setP(s.wIdx,wi));\n  const knobs=document.createElement('div'); knobs.className='knobs';\n  knobs.append(knob(K('Oct',s.octIdx,-2,2,s.defOct,'',1)));\n  if(s.detIdx!=null) knobs.append(knob(K('Detune',s.detIdx,-50,50,s.defDet)));\n  col.append(name,waves,knobs); return col;\n}\n\n/* ====================================================================== *\n *  LFO MATRIX \u2014 two LFOs run here in the GUI and modulate real params by  *\n *  streaming setParam() updates. (The DSP's 36 params are all in use, so  *\n *  modulation lives client-side; it's audible the moment you play.)       *\n * ====================================================================== */\nconst DESTS=[\n  {name:'Cutoff', idx:14, min:0,   max:1,  scale:0.55},\n  {name:'Pitch',  idx:0,  min:-12, max:12, scale:2.0 },   // vibrato via global Tune\n  {name:'Volume', idx:26, min:0,   max:1,  scale:0.45},   // tremolo\n  {name:'Reso',   idx:15, min:0,   max:1,  scale:0.5 },\n];\n// per-LFO state + a depth (0..1) for every destination\nconst LFOS=[\n  {shape:0, rate:0.55, phase:0,    depth:DESTS.map((_,i)=>i===0?0.35:0)}, // sine -> Cutoff\n  {shape:1, rate:0.42, phase:0.25, depth:DESTS.map(()=>0)},               // triangle, idle\n];\nconst RATE_HZ=(t)=>0.08*Math.pow(120,t);                  // ~0.08 .. 9.6 Hz, exponential\nfunction lfoOut(shape,p){\n  if(shape===0) return Math.sin(p*6.2831853);             // sine\n  if(shape===1) return p<0.5? -1+4*p : 3-4*p;             // triangle\n  if(shape===2) return 2*p-1;                             // saw\n  return p<0.5? 1 : -1;                                   // square\n}\nfunction buildMatrix(){\n  const el=document.createElement('div'); el.className='sect mod';\n  const h=document.createElement('h3'); h.textContent='LFO Matrix'; el.append(h);\n  const grid=document.createElement('div'); grid.className='matrix';\n  grid.style.gridTemplateColumns='minmax(180px,210px) repeat('+DESTS.length+',1fr)';\n  // header row\n  const corner=document.createElement('div'); corner.className='corner'; corner.textContent='Source / Dest';\n  grid.append(corner);\n  for(const d of DESTS){ const dh=document.createElement('div'); dh.className='desthead'; dh.textContent=d.name; grid.append(dh); }\n  // one row per LFO\n  LFOS.forEach((lfo,li)=>{\n    const src=document.createElement('div'); src.className='lfo-src';\n    const nm=document.createElement('div'); nm.className='name'; nm.textContent='LFO '+(li+1);\n    const waves=makeWaveBtns(['sine','tri','saw','sq'],lfo.shape,(wi)=>lfo.shape=wi);\n    const rate=knob({label:'Rate',min:0,max:1,def:lfo.rate,sm:true,\n      set:(v)=>{lfo.rate=v;}, });\n    src.append(nm,waves,rate); grid.append(src);\n    DESTS.forEach((d,di)=>{\n      const cell=document.createElement('div'); cell.className='cell';\n      cell.append(knob({label:'Amt',min:0,max:1,def:lfo.depth[di],sm:true,\n        set:(v)=>{lfo.depth[di]=v;}}));\n      grid.append(cell);\n    });\n  });\n  el.append(grid); return el;\n}\n// modulation loop: base + \u03a3(lfo\u00b7depth\u00b7scale) streamed to the DSP at frame rate\nlet last=null;\nfunction modTick(now){\n  requestAnimationFrame(modTick);\n  if(last==null){ last=now; return; }\n  const dt=Math.min(0.05,(now-last)/1000); last=now;\n  for(const lfo of LFOS){ lfo.phase=(lfo.phase+dt*RATE_HZ(lfo.rate))%1; }\n  for(let di=0; di<DESTS.length; di++){\n    const d=DESTS[di]; let mod=0, active=0;\n    for(const lfo of LFOS){ const a=lfo.depth[di]; if(a>0.001){ active=1; mod+=lfoOut(lfo.shape,lfo.phase)*a*d.scale; } }\n    if(!active) continue;                                  // leave the knob in charge\n    const b=(d.idx in base)?base[d.idx]:0;\n    raw(d.idx, Math.max(d.min,Math.min(d.max, b+mod)));\n  }\n}\n\nconst rack=document.getElementById('rack');\nconst sectionEls=[];\nfor(const sec of SECTIONS){\n  const el=document.createElement('div'); el.className='sect';\n  const h=document.createElement('h3'); h.textContent=sec.h; el.append(h);\n  const k=document.createElement('div'); k.className='knobs';\n  for(const it of sec.items) k.append(it.type==='osc'?osc(it):knob(it));\n  el.append(k); rack.append(el); sectionEls.push(el);\n}\nsectionEls.push(rack.appendChild(buildMatrix()));\nrequestAnimationFrame(modTick);\n\n/* ====================================================================== *\n *  INTRO BUILD \u2014 only on the homepage embed (play.html sets window.__vstaiIntro).\n *  Sections start hidden; a series of typed requests reveal them one group at a\n *  time, then a \"Try it out\" caption. The real plugin/gallery never sees this.  *\n * ====================================================================== */\nif(window.__vstaiIntro){\n  const head=document.querySelector('.head');\n  head.classList.add('pre'); sectionEls.forEach(el=>el.classList.add('pre'));\n  const build=document.createElement('div'); build.className='build';\n  build.innerHTML='<div class=\"chat\"><svg class=\"spark\" viewBox=\"0 0 24 24\" fill=\"currentColor\">'+\n    '<path d=\"M12 2l1.8 5.6L19 9.4l-4.6 3.1L16 18l-4-3.3L8 18l1.6-5.5L5 9.4l5.2-1.8z\"/></svg>'+\n    '<span class=\"tag\">You</span><span class=\"ctext\"></span><span class=\"ccaret\"></span>'+\n    '<span class=\"skiph\">click to skip</span></div>'+\n    '<div class=\"bcap\"></div>';\n  document.body.insertBefore(build, rack);\n  const chat=build.querySelector('.chat'), ctext=build.querySelector('.ctext'), bcap=build.querySelector('.bcap');\n  const postIntro=(phase)=>{try{parent.postMessage({__vstai:1,type:'intro',phase},'*');}catch(_){}}\n\n  const STEPS=[\n    {p:'a synth like a Moog Model D \u2014 three oscillators + a ladder filter', reveal:[0,1,2]},\n    {p:'add amp & filter envelopes with glide',                            reveal:[3]},\n    {p:'give it a lush stereo FX rack',                                     reveal:[4,5,6]},\n    {p:'and an LFO modulation matrix',                                      reveal:[7]},\n  ];\n  let done=false;\n  const show=(el)=>{el.classList.remove('pre');el.classList.add('in');};\n  function reveal(idxs){ idxs.forEach((gi,k)=>setTimeout(()=>{const el=sectionEls[gi];if(el)show(el);},k*120)); }\n  function fadeBuildSoon(){ setTimeout(()=>{ build.style.opacity='0'; build.style.margin='0';\n    setTimeout(()=>build.remove(),520); }, 4200); }\n  function finishAll(){ if(done)return; done=true;\n    show(head); sectionEls.forEach(show); postIntro('keys');\n    chat.classList.add('ready'); ctext.textContent='';\n    bcap.textContent='\u2713 Ready \u2014 try it out, play the keys'; bcap.classList.add('ok'); fadeBuildSoon(); }\n  document.body.addEventListener('pointerdown',()=>{ if(!done) finishAll(); });\n\n  function type(text,cb){ ctext.textContent=''; let i=0;\n    (function t(){ if(done)return; ctext.textContent=text.slice(0,i);\n      if(i++<text.length) setTimeout(t,22+Math.random()*34); else setTimeout(cb,320); })(); }\n  let si=0;\n  function step(){\n    if(done) return;\n    if(si===0) show(head);\n    if(si>=STEPS.length){ finale(); return; }\n    const st=STEPS[si++];\n    type(st.p,()=>{ if(done)return; bcap.textContent='compiling to WebAssembly\u2026'; reveal(st.reveal);\n      setTimeout(()=>{ if(done)return; bcap.textContent=''; step(); }, 700+st.reveal.length*120); });\n  }\n  function finale(){\n    type('\u2026and a playable keyboard',()=>{ if(done)return; done=true; postIntro('keys');\n      chat.classList.add('ready'); bcap.textContent='\u2713 Ready \u2014 try it out, play the keys'; bcap.classList.add('ok');\n      fadeBuildSoon(); });\n  }\n  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n  if(reduce) finishAll(); else setTimeout(step,500);\n}\n</script>\n</body></html>\n","publishedAt":1750000002000}