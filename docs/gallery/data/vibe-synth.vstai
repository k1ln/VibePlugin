{"format":1,"name":"VibeSynth","isInstrument":true,"explanation":"A monophonic analog-style synthesizer: three anti-aliased oscillators with per-osc octave and detune, a noise source, a four-pole resonant ladder filter with drive, independent filter and amplifier ADSR envelopes, and portamento glide. A stereo effects rack adds chorus, ping-pong delay and reverb, with live oscilloscope + spectrum displays. Play it with the keyboard, your computer keys (a–k), or MIDI.","params":[{"name":"Tune","index":0,"min":-12,"max":12,"default":0,"value":0},{"name":"Glide","index":1,"min":0,"max":1,"default":0.05,"value":0.05},{"name":"Osc1 Wave","index":2,"min":0,"max":3,"default":1,"value":1},{"name":"Osc1 Oct","index":3,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Wave","index":4,"min":0,"max":3,"default":1,"value":1},{"name":"Osc2 Oct","index":5,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Detune","index":6,"min":-50,"max":50,"default":7,"value":7},{"name":"Osc3 Wave","index":7,"min":0,"max":3,"default":2,"value":2},{"name":"Osc3 Oct","index":8,"min":-2,"max":2,"default":-1,"value":-1},{"name":"Osc3 Detune","index":9,"min":-50,"max":50,"default":-5,"value":-5},{"name":"Mix Osc1","index":10,"min":0,"max":1,"default":0.9,"value":0.9},{"name":"Mix Osc2","index":11,"min":0,"max":1,"default":0.7,"value":0.7},{"name":"Mix Osc3","index":12,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Noise","index":13,"min":0,"max":1,"default":0.06,"value":0.06},{"name":"Cutoff","index":14,"min":0,"max":1,"default":0.42,"value":0.42},{"name":"Resonance","index":15,"min":0,"max":1,"default":0.55,"value":0.55},{"name":"Filter Env","index":16,"min":0,"max":1,"default":0.6,"value":0.6},{"name":"Filt Atk","index":17,"min":0,"max":1,"default":0.04,"value":0.04},{"name":"Filt Dec","index":18,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Filt Sus","index":19,"min":0,"max":1,"default":0.25,"value":0.25},{"name":"Filt Rel","index":20,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Atk","index":21,"min":0,"max":1,"default":0.02,"value":0.02},{"name":"Amp Dec","index":22,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Sus","index":23,"min":0,"max":1,"default":0.8,"value":0.8},{"name":"Amp Rel","index":24,"min":0,"max":1,"default":0.35,"value":0.35},{"name":"Drive","index":25,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Volume","index":26,"min":0,"max":1,"default":0.8,"value":0.8},{"name":"Chorus Mix","index":27,"min":0,"max":1,"default":0.35,"value":0.35},{"name":"Chorus Rate","index":28,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Chorus Depth","index":29,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Delay Mix","index":30,"min":0,"max":1,"default":0.22,"value":0.22},{"name":"Delay Time","index":31,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Delay Feedback","index":32,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Reverb Mix","index":33,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Reverb Size","index":34,"min":0,"max":1,"default":0.6,"value":0.6},{"name":"Reverb Damp","index":35,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Arp","index":36,"min":0,"max":1,"default":1,"value":1},{"name":"Arp Rate","index":37,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Arp Octaves","index":38,"min":1,"max":4,"default":2,"value":2},{"name":"Arp Gate","index":39,"min":0.1,"max":1,"default":0.5,"value":0.5},{"name":"Arp Mode","index":40,"min":0,"max":3,"default":0,"value":0}],"assembly":"// =====================================================================\n//  \"Model D\" — a Minimoog-style monophonic synth (gallery showpiece).\n//\n//  Implements the VibePlugin WASM ABI (src/WasmAbi.h) + note exports. Built to\n//  show the engine can host a genuinely complex voice in the browser:\n//    • 3 anti-aliased oscillators (polyBLEP saw/pulse, naive tri) with per-osc\n//      octave + fine detune and a noise source\n//    • classic Moog 4-pole resonant ladder filter (Stilson/Smith) with drive\n//    • two ADSR envelopes (filter + amplifier)\n//    • portamento (glide) and last-note-priority mono with legato\n//\n//  Host passes note frequency in Hz to noteOn(id, freqHz, vel).\n//  Compile:  node compiler/asc-driver.mjs scripts/seeds/moog.ts out.wasm\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst PI: f32 = 3.14159265358979;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// ---- parameter map (must match the GUI indices) --------------------\nconst P_TUNE: i32 = 0;       // master tune, semitones -12..+12\nconst P_GLIDE: i32 = 1;      // 0..1 portamento amount\nconst P_O1_WAVE: i32 = 2;    // 0 tri,1 saw,2 square,3 pulse\nconst P_O1_OCT: i32 = 3;     // -2..+2 octaves\nconst P_O2_WAVE: i32 = 4;\nconst P_O2_OCT: i32 = 5;\nconst P_O2_DET: i32 = 6;     // detune, cents -50..+50\nconst P_O3_WAVE: i32 = 7;\nconst P_O3_OCT: i32 = 8;\nconst P_O3_DET: i32 = 9;\nconst P_MIX1: i32 = 10;      // 0..1\nconst P_MIX2: i32 = 11;\nconst P_MIX3: i32 = 12;\nconst P_NOISE: i32 = 13;\nconst P_CUTOFF: i32 = 14;    // 0..1 (exp to Hz)\nconst P_RESO: i32 = 15;      // 0..1\nconst P_FENV: i32 = 16;      // filter env amount 0..1\nconst P_FA: i32 = 17;        // filter ADSR\nconst P_FD: i32 = 18;\nconst P_FS: i32 = 19;\nconst P_FR: i32 = 20;\nconst P_AA: i32 = 21;        // amp ADSR\nconst P_AD: i32 = 22;\nconst P_AS: i32 = 23;\nconst P_AR: i32 = 24;\nconst P_DRIVE: i32 = 25;     // 0..1 pre-filter saturation\nconst P_VOL: i32 = 26;       // 0..1\n// ---- effects -------------------------------------------------------\nconst P_CHO_MIX: i32 = 27;   // chorus\nconst P_CHO_RATE: i32 = 28;\nconst P_CHO_DEPTH: i32 = 29;\nconst P_DLY_MIX: i32 = 30;   // ping-pong delay\nconst P_DLY_TIME: i32 = 31;\nconst P_DLY_FB: i32 = 32;\nconst P_REV_MIX: i32 = 33;   // reverb\nconst P_REV_SIZE: i32 = 34;\nconst P_REV_DAMP: i32 = 35;\n// ---- arpeggiator (DSP-level, so it follows DAW MIDI + keeps running with the GUI closed) ----\nconst P_ARP_ON: i32 = 36;    // 0/1\nconst P_ARP_RATE: i32 = 37;  // 0..1 -> ~2..18 steps/sec\nconst P_ARP_OCT: i32 = 38;   // 1..4 octave span\nconst P_ARP_GATE: i32 = 39;  // 0.1..1 note length (fraction of a step)\nconst P_ARP_MODE: i32 = 40;  // 0 up, 1 down, 2 up-down, 3 random\nconst NUM_PARAMS: i32 = 41;\n\nlet sampleRate: f32 = 44100;\n\n// ---- oscillator state ----------------------------------------------\nlet ph1: f32 = 0, ph2: f32 = 0, ph3: f32 = 0;\nlet curFreq: f32 = 220, tgtFreq: f32 = 220;\nlet noiseState: i32 = 0x1234567;\n\n// ---- ladder filter state (4 cascaded TPT one-pole lowpasses) -------\nlet s1f: f32 = 0, s2f: f32 = 0, s3f: f32 = 0, s4f: f32 = 0;\nlet fbk: f32 = 0;   // last stage output, fed back for resonance\n\n// ---- FX: stereo chorus (one modulated mono delay line, 2 LFO phases) ----\nconst CHORUS_LEN: i32 = 2048;\nconst choBuf: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nlet choW: i32 = 0;\nlet choPhase: f32 = 0;\n\n// ---- FX: stereo ping-pong delay ------------------------------------\nconst DELAY_LEN: i32 = 96000;   // ~2 s at 48 kHz\nconst dlyL: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst dlyR: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nlet dlyW: i32 = 0;\n\n// ---- FX: reverb (Schroeder: 4 parallel combs -> 2 series allpass) ----\nconst RV_C0: i32 = 1900, RV_A0: i32 = 700;\nconst rc0: StaticArray<f32> = new StaticArray<f32>(RV_C0);\nconst rc1: StaticArray<f32> = new StaticArray<f32>(RV_C0);\nconst rc2: StaticArray<f32> = new StaticArray<f32>(RV_C0);\nconst rc3: StaticArray<f32> = new StaticArray<f32>(RV_C0);\nconst ra0: StaticArray<f32> = new StaticArray<f32>(RV_A0);\nconst ra1: StaticArray<f32> = new StaticArray<f32>(RV_A0);\nlet ci0: i32 = 0, ci1: i32 = 0, ci2: i32 = 0, ci3: i32 = 0, ai0: i32 = 0, ai1: i32 = 0;\nlet cl0: f32 = 0, cl1: f32 = 0, cl2: f32 = 0, cl3: f32 = 0;   // comb damping lowpass state\nlet cLen0: i32 = 1557, cLen1: i32 = 1617, cLen2: i32 = 1491, cLen3: i32 = 1422;\nlet aLen0: i32 = 556, aLen1: i32 = 441;\n\n// ---- envelope state (0 off,1 atk,2 dec,3 sus,4 rel) ----------------\nlet aStage: i32 = 0, aLevel: f32 = 0;\nlet fStage: i32 = 0, fLevel: f32 = 0;\nlet vel: f32 = 1;\n\n// ---- note stack (mono, last-note priority) -------------------------\nconst stack: StaticArray<i32> = new StaticArray<i32>(16);\nconst stackHz: StaticArray<f32> = new StaticArray<f32>(16);\nlet stackN: i32 = 0;\n\n// ---- arpeggiator state ---------------------------------------------\nlet arpClock: f32 = 0;     // samples until the next step fires\nlet arpStep: i32 = 0;      // running pattern position\nlet arpGate: f32 = 0;      // samples left before the current step releases\nlet arpVoice: i32 = 0;     // 1 while an arp-triggered note is sounding\nlet arpRand: i32 = 0x2f6e2b1;\nconst arpSorted: StaticArray<f32> = new StaticArray<f32>(16);   // held freqs, ascending\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr;\n  ph1 = 0; ph2 = 0; ph3 = 0; stackN = 0;\n  arpClock = 0; arpStep = 0; arpGate = 0; arpVoice = 0;\n  aStage = 0; aLevel = 0; fStage = 0; fLevel = 0;\n  s1f = 0; s2f = 0; s3f = 0; s4f = 0; fbk = 0;\n\n  // FX state + sample-rate-correct reverb buffer lengths\n  choW = 0; choPhase = 0; dlyW = 0;\n  ci0 = ci1 = ci2 = ci3 = ai0 = ai1 = 0;\n  cl0 = cl1 = cl2 = cl3 = 0;\n  const rf: f32 = sr / 44100.0;\n  cLen0 = <i32>(1557.0 * rf); cLen1 = <i32>(1617.0 * rf);\n  cLen2 = <i32>(1491.0 * rf); cLen3 = <i32>(1422.0 * rf);\n  aLen0 = <i32>(556.0 * rf);  aLen1 = <i32>(441.0 * rf);\n  if (cLen1 >= RV_C0) cLen1 = RV_C0 - 1;\n  if (aLen0 >= RV_A0) aLen0 = RV_A0 - 1;\n\n  params[P_TUNE] = 0;\n  params[P_GLIDE] = 0.05;\n  params[P_O1_WAVE] = 1; params[P_O1_OCT] = 0;\n  params[P_O2_WAVE] = 1; params[P_O2_OCT] = 0; params[P_O2_DET] = 7;\n  params[P_O3_WAVE] = 2; params[P_O3_OCT] = -1; params[P_O3_DET] = -5;\n  params[P_MIX1] = 0.9; params[P_MIX2] = 0.7; params[P_MIX3] = 0.5; params[P_NOISE] = 0.06;\n  params[P_CUTOFF] = 0.42; params[P_RESO] = 0.55; params[P_FENV] = 0.6;\n  params[P_FA] = 0.04; params[P_FD] = 0.5; params[P_FS] = 0.25; params[P_FR] = 0.4;\n  params[P_AA] = 0.02; params[P_AD] = 0.4; params[P_AS] = 0.8; params[P_AR] = 0.35;\n  params[P_DRIVE] = 0.3; params[P_VOL] = 0.8;\n  params[P_CHO_MIX] = 0.35; params[P_CHO_RATE] = 0.3; params[P_CHO_DEPTH] = 0.5;\n  params[P_DLY_MIX] = 0.22; params[P_DLY_TIME] = 0.4; params[P_DLY_FB] = 0.4;\n  params[P_REV_MIX] = 0.3; params[P_REV_SIZE] = 0.6; params[P_REV_DAMP] = 0.4;\n  params[P_ARP_ON] = 1; params[P_ARP_RATE] = 0.5; params[P_ARP_OCT] = 2;\n  params[P_ARP_GATE] = 0.5; params[P_ARP_MODE] = 0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return NUM_PARAMS; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // push onto the stack (replace if already present)\n  let i = 0; for (; i < stackN; i++) if (stack[i] == id) break;\n  if (i == stackN && stackN < 16) stackN++;\n  stack[i] = id; stackHz[i] = f;\n  vel = v;\n  if (params[P_ARP_ON] > 0.5) return;                     // arp plays the held stack itself\n  const wasIdle = aStage == 0 || aStage == 4;\n  tgtFreq = f;\n  if (wasIdle) { curFreq = f; aStage = 1; fStage = 1; }   // retrigger from idle\n}\n\nexport function noteOff(id: i32): void {\n  let i = 0; for (; i < stackN; i++) if (stack[i] == id) break;\n  if (i == stackN) return;\n  for (let j = i; j < stackN - 1; j++) { stack[j] = stack[j + 1]; stackHz[j] = stackHz[j + 1]; }\n  stackN--;\n  if (params[P_ARP_ON] > 0.5) return;                     // arp manages the voice\n  if (stackN == 0) { aStage = 4; fStage = 4; }            // release\n  else tgtFreq = stackHz[stackN - 1];                     // glide to held note\n}\n\n// Pick the arpeggiated note frequency for sequence index `idx` across `octs` octaves:\n// the held notes sorted ascending, repeated up by octaves.\nfunction arpNoteFreq(idx: i32, octs: i32): f32 {\n  for (let i = 0; i < stackN; i++) {                      // insertion sort held freqs -> arpSorted\n    const x = stackHz[i]; let j = i - 1;\n    while (j >= 0 && arpSorted[j] > x) { arpSorted[j + 1] = arpSorted[j]; j--; }\n    arpSorted[j + 1] = x;\n  }\n  const within: i32 = idx % stackN;\n  const oct: i32 = idx / stackN;\n  let f: f32 = arpSorted[within];\n  for (let o = 0; o < oct; o++) f *= 2.0;\n  return f;\n}\n\n// ---- helpers -------------------------------------------------------\n// anti-aliasing residual for saw/pulse discontinuities\nfunction blep(t: f32, dt: f32): f32 {\n  if (t < dt) { const x = t / dt; return x + x - x * x - 1.0; }\n  if (t > 1.0 - dt) { const x = (t - 1.0) / dt; return x * x + x + x + 1.0; }\n  return 0.0;\n}\nfunction osc(wave: i32, ph: f32, dt: f32): f32 {\n  if (wave == 0) {                                   // triangle (naive — low aliasing)\n    return 4.0 * Mathf.abs(ph - 0.5) - 1.0;\n  } else if (wave == 1) {                            // saw (polyBLEP)\n    return (2.0 * ph - 1.0) - blep(ph, dt);\n  } else {                                           // square / pulse (polyBLEP)\n    const pw: f32 = wave == 3 ? 0.25 : 0.5;\n    let s: f32 = ph < pw ? 1.0 : -1.0;\n    s += blep(ph, dt);\n    let t2 = ph - pw; if (t2 < 0.0) t2 += 1.0;\n    s -= blep(t2, dt);\n    return s;\n  }\n}\nfunction adsr(stage: i32, level: f32, a: f32, d: f32, s: f32, r: f32, sr: f32): f32 {\n  // times: ~2 ms .. ~4 s, exponential feel\n  const ta = 0.002 + a * a * 3.0, td = 0.002 + d * d * 3.0, tr = 0.002 + r * r * 4.0;\n  if (stage == 1) {                                  // attack\n    level += <f32>(1.0 / (ta * sr));\n    if (level >= 1.0) { level = 1.0; }\n  } else if (stage == 2) {                           // decay\n    level += <f32>((s - level) * (1.0 / (td * sr)) * 4.0);\n  } else if (stage == 4) {                           // release\n    level += <f32>((0.0 - level) * (1.0 / (tr * sr)) * 4.0);\n  }\n  return level;\n}\n\n// interpolated read from the chorus delay line, `d` samples behind the write head\nfunction choRead(d: f32): f32 {\n  let rp: f32 = <f32>choW - d;\n  while (rp < 0.0) rp += <f32>CHORUS_LEN;\n  const i0: i32 = <i32>rp;\n  const frac: f32 = rp - <f32>i0;\n  let i1: i32 = i0 + 1; if (i1 >= CHORUS_LEN) i1 -= CHORUS_LEN;\n  return choBuf[i0] * (1.0 - frac) + choBuf[i1] * frac;\n}\n\nexport function process(n: i32): void {\n  const tuneRatio: f32 = Mathf.pow(2.0, params[P_TUNE] / 12.0);\n  const o1r: f32 = Mathf.pow(2.0, params[P_O1_OCT]);\n  const o2r: f32 = Mathf.pow(2.0, params[P_O2_OCT] + params[P_O2_DET] / 1200.0);\n  const o3r: f32 = Mathf.pow(2.0, params[P_O3_OCT] + params[P_O3_DET] / 1200.0);\n  const w1 = <i32>params[P_O1_WAVE], w2 = <i32>params[P_O2_WAVE], w3 = <i32>params[P_O3_WAVE];\n  const m1 = params[P_MIX1], m2 = params[P_MIX2], m3 = params[P_MIX3], mn = params[P_NOISE];\n  const drive: f32 = 1.0 + params[P_DRIVE] * 6.0;\n  const vol: f32 = params[P_VOL];\n  const fenv: f32 = params[P_FENV];\n  const reso: f32 = params[P_RESO] * 4.0;\n\n  // glide coefficient\n  const glideT: f32 = params[P_GLIDE] * params[P_GLIDE] * 0.6;\n  const glide: f32 = glideT < 0.0005 ? 1.0 : 1.0 - Mathf.exp(-1.0 / (glideT * sampleRate));\n\n  // FX params (read once per block)\n  const choMix: f32 = params[P_CHO_MIX];\n  const choInc: f32 = (0.1 + params[P_CHO_RATE] * 5.9) / sampleRate;\n  const choBase: f32 = 0.012 * sampleRate;\n  const choDepth: f32 = params[P_CHO_DEPTH] * 0.006 * sampleRate;\n  const dlyMix: f32 = params[P_DLY_MIX];\n  let dlySamp: i32 = <i32>((0.03 + params[P_DLY_TIME] * 0.67) * sampleRate);\n  if (dlySamp >= DELAY_LEN) dlySamp = DELAY_LEN - 1;\n  const dlyFb: f32 = params[P_DLY_FB] * 0.85;\n  const revMix: f32 = params[P_REV_MIX];\n  const revFb: f32 = 0.7 + params[P_REV_SIZE] * 0.28;\n  const revDamp: f32 = params[P_REV_DAMP] * 0.4;\n\n  const arpOn: bool = params[P_ARP_ON] > 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // --- arpeggiator: steps through the held-note stack, retriggering the voice.\n    //     Runs in the audio thread, so it follows DAW MIDI and survives a closed GUI.\n    if (arpOn) {\n      if (stackN == 0) {\n        if (arpVoice == 1) { aStage = 4; fStage = 4; arpVoice = 0; }   // no notes held -> release\n      } else {\n        const stepLen: f32 = sampleRate / (2.0 + params[P_ARP_RATE] * 16.0);   // ~2..18 steps/sec\n        if (arpVoice == 1) { arpGate -= 1.0; if (arpGate <= 0.0) { aStage = 4; fStage = 4; arpVoice = 0; } }\n        arpClock -= 1.0;\n        if (arpClock <= 0.0) {\n          arpClock += stepLen;\n          let octs: i32 = <i32>(params[P_ARP_OCT] + 0.5); if (octs < 1) octs = 1; if (octs > 4) octs = 4;\n          const seqN: i32 = stackN * octs;\n          const mode: i32 = <i32>(params[P_ARP_MODE] + 0.5);\n          let idx: i32;\n          if (mode == 1) {                                    // down\n            idx = seqN - 1 - (arpStep % seqN);\n          } else if (mode == 2) {                             // up-down (no doubled endpoints)\n            const period: i32 = seqN > 1 ? 2 * seqN - 2 : 1;\n            const p: i32 = arpStep % period;\n            idx = p < seqN ? p : period - p;\n          } else if (mode == 3) {                             // random\n            arpRand = (arpRand * 1103515245 + 12345) & 0x7fffffff;\n            idx = arpRand % seqN;\n          } else {                                            // up\n            idx = arpStep % seqN;\n          }\n          arpStep++;\n          const nf: f32 = arpNoteFreq(idx, octs);\n          tgtFreq = nf; curFreq = nf;                         // jump pitch (no glide between steps)\n          aStage = 1; fStage = 1;                             // retrigger both envelopes (pluck)\n          arpVoice = 1;\n          arpGate = stepLen * (0.1 + params[P_ARP_GATE] * 0.9);\n        }\n      }\n    }\n\n    // pitch glide\n    curFreq += (tgtFreq - curFreq) * glide;\n    const base: f32 = curFreq * tuneRatio;\n\n    // envelopes + stage transitions\n    aLevel = adsr(aStage, aLevel, params[P_AA], params[P_AD], params[P_AS], params[P_AR], sampleRate);\n    fLevel = adsr(fStage, fLevel, params[P_FA], params[P_FD], params[P_FS], params[P_FR], sampleRate);\n    if (aStage == 1 && aLevel >= 1.0) aStage = 2;\n    if (aStage == 2 && Mathf.abs(aLevel - params[P_AS]) < 0.001) aStage = 3;\n    if (fStage == 1 && fLevel >= 1.0) fStage = 2;\n    if (fStage == 2 && Mathf.abs(fLevel - params[P_FS]) < 0.001) fStage = 3;\n    if (aStage == 4 && aLevel < 0.0005) { aStage = 0; aLevel = 0; }\n\n    // oscillators\n    const f1hz = base * o1r, f2hz = base * o2r, f3hz = base * o3r;\n    const d1 = f1hz / sampleRate, d2 = f2hz / sampleRate, d3 = f3hz / sampleRate;\n    ph1 += d1; if (ph1 >= 1.0) ph1 -= 1.0;\n    ph2 += d2; if (ph2 >= 1.0) ph2 -= 1.0;\n    ph3 += d3; if (ph3 >= 1.0) ph3 -= 1.0;\n    noiseState = (noiseState * 1103515245 + 12345) & 0x7fffffff;\n    const noise: f32 = (<f32>noiseState / <f32>0x3fffffff) - 1.0;\n\n    let sig: f32 = osc(w1, ph1, d1) * m1 + osc(w2, ph2, d2) * m2\n                 + osc(w3, ph3, d3) * m3 + noise * mn;\n    sig *= 0.35;\n\n    // pre-filter drive (soft saturation)\n    sig = Mathf.tanh(sig * drive);\n\n    // cutoff from env: exponential 20 Hz .. ~14 kHz\n    let cut: f32 = params[P_CUTOFF] + fenv * fLevel;\n    if (cut > 1.0) cut = 1.0; if (cut < 0.0) cut = 0.0;\n    let fcHz: f32 = 20.0 * Mathf.pow(700.0, cut);\n    const fcMax: f32 = sampleRate * 0.45;\n    if (fcHz > fcMax) fcHz = fcMax;\n\n    // Moog ladder via 4 cascaded TPT one-pole lowpasses (stable, self-oscillates)\n    const g: f32 = Mathf.tan(PI * fcHz / sampleRate);\n    const G: f32 = g / (1.0 + g);\n    const x0: f32 = Mathf.tanh(sig - reso * fbk);    // resonance feedback, soft-limited\n    let v: f32; let y: f32;\n    v = (x0 - s1f) * G; y = v + s1f; s1f = y + v; const a1 = y;\n    v = (a1 - s2f) * G; y = v + s2f; s2f = y + v; const a2 = y;\n    v = (a2 - s3f) * G; y = v + s3f; s3f = y + v; const a3 = y;\n    v = (a3 - s4f) * G; y = v + s4f; s4f = y + v; fbk = y;\n\n    const dry: f32 = fbk * aLevel * vel * vol;\n\n    // --- stereo chorus ---\n    choBuf[choW] = dry;\n    choPhase += choInc; if (choPhase >= 1.0) choPhase -= 1.0;\n    const lfoL: f32 = 0.5 + 0.5 * Mathf.sin(6.2831853 * choPhase);\n    const lfoR: f32 = 0.5 + 0.5 * Mathf.sin(6.2831853 * choPhase + 1.5707963);\n    const wetCL: f32 = choRead(choBase + choDepth * lfoL);\n    const wetCR: f32 = choRead(choBase + choDepth * lfoR);\n    choW++; if (choW >= CHORUS_LEN) choW = 0;\n    let lch: f32 = dry + (wetCL - dry) * choMix;\n    let rch: f32 = dry + (wetCR - dry) * choMix;\n\n    // --- ping-pong delay (cross-fed) ---\n    let rp: i32 = dlyW - dlySamp; if (rp < 0) rp += DELAY_LEN;\n    const rdL: f32 = dlyL[rp];\n    const rdR: f32 = dlyR[rp];\n    dlyL[dlyW] = lch + rdR * dlyFb;\n    dlyR[dlyW] = rch + rdL * dlyFb;\n    dlyW++; if (dlyW >= DELAY_LEN) dlyW = 0;\n    lch = lch + (rdL - lch) * dlyMix;\n    rch = rch + (rdR - rch) * dlyMix;\n\n    // --- reverb: 4 parallel combs -> 2 series allpass ---\n    const rin: f32 = (lch + rch) * 0.5 * 0.015;\n    let cout: f32 = 0;\n    let rd: f32 = rc0[ci0]; cl0 = rd * (1.0 - revDamp) + cl0 * revDamp; rc0[ci0] = rin + cl0 * revFb; ci0++; if (ci0 >= cLen0) ci0 = 0; cout += rd;\n    rd = rc1[ci1];        cl1 = rd * (1.0 - revDamp) + cl1 * revDamp; rc1[ci1] = rin + cl1 * revFb; ci1++; if (ci1 >= cLen1) ci1 = 0; cout += rd;\n    rd = rc2[ci2];        cl2 = rd * (1.0 - revDamp) + cl2 * revDamp; rc2[ci2] = rin + cl2 * revFb; ci2++; if (ci2 >= cLen2) ci2 = 0; cout += rd;\n    rd = rc3[ci3];        cl3 = rd * (1.0 - revDamp) + cl3 * revDamp; rc3[ci3] = rin + cl3 * revFb; ci3++; if (ci3 >= cLen3) ci3 = 0; cout += rd;\n    const ar0: f32 = ra0[ai0]; const ao0: f32 = -cout + ar0; ra0[ai0] = cout + ar0 * 0.5; ai0++; if (ai0 >= aLen0) ai0 = 0;\n    const ar1: f32 = ra1[ai1]; const ao1: f32 = -ao0 + ar1; ra1[ai1] = ao0 + ar1 * 0.5; ai1++; if (ai1 >= aLen1) ai1 = 0;\n    lch = lch + (ao0 - lch) * revMix;   // slight L/R decorrelation: 1 vs 2 allpass\n    rch = rch + (ao1 - rch) * revMix;\n\n    if (lch > 1.5) lch = 1.5; else if (lch < -1.5) lch = -1.5;\n    if (rch > 1.5) rch = 1.5; else if (rch < -1.5) rch = -1.5;\n    outBuf[i] = lch;\n    outBuf[MAX_FRAMES + i] = rch;\n  }\n}\n","wasmBase64":"","html":"<!doctype html><html><head><meta charset=\"utf-8\">\n<style>\n  :root{\n    --bg:#0a0b0e; --surface:#14161c; --surface-2:#191c24; --line:rgba(255,255,255,.08);\n    --line-2:rgba(255,255,255,.13); --ink:#eceef3; --ink-2:#c2c8d4; --muted:#79818f;\n    --accent:#4f8dff; --accent-2:#9d7bff; --ok:#46d39a;\n    --sans:ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,Roboto,sans-serif;\n    --mono:ui-monospace,\"SF Mono\",\"JetBrains Mono\",Menlo,monospace;\n  }\n  *{box-sizing:border-box}\n  body{margin:0;font:13px var(--sans);color:var(--ink);\n    background:radial-gradient(130% 100% at 50% -10%,#1a1e27,var(--surface) 60%);\n    padding:14px 16px 18px;user-select:none;-webkit-user-select:none}\n  .head{display:flex;align-items:baseline;gap:10px;margin:0 0 12px}\n  .head b{font-size:14px;letter-spacing:.02em}\n  .head span{font:600 11px var(--mono);color:var(--muted);letter-spacing:.06em}\n\n  /* ---- control sections: masonry columns so the knobs pack tight (no big\n         empty gaps under the shorter sections like a grid would leave) ---- */\n  .rack{column-width:250px;column-gap:11px}\n  .sect{background:linear-gradient(180deg,var(--surface-2),#15171d);border:1px solid var(--line);\n    border-radius:13px;padding:12px 13px 14px;box-shadow:0 1px 0 rgba(255,255,255,.04) inset;\n    break-inside:avoid;-webkit-column-break-inside:avoid;margin:0 0 11px}\n  /* the oscillator bank, modulation + arp sections span the full width */\n  .sect.osc-bank, .sect.mod, .sect.arp{column-span:all;break-inside:avoid}\n  .sect.osc-bank .knobs{justify-content:space-evenly;gap:16px 30px}\n  .sect h3{font:600 9px var(--mono);letter-spacing:.17em;color:var(--accent);opacity:.9;margin:0 0 11px;\n    text-transform:uppercase;display:flex;align-items:center;gap:7px}\n  .sect h3::after{content:\"\";flex:1;height:1px;background:var(--line)}\n  .knobs{display:flex;gap:15px 14px;flex-wrap:wrap;justify-content:center}\n\n  .knob{width:54px;display:flex;flex-direction:column;align-items:center;gap:5px}\n  .ring{width:48px;height:48px;border-radius:50%;padding:3px;cursor:ns-resize;position:relative;touch-action:none;\n    background:conic-gradient(from 225deg,\n      var(--accent) 0 var(--deg,0deg),\n      rgba(255,255,255,.09) var(--deg,0deg) 270deg,\n      transparent 270deg 360deg);\n    filter:drop-shadow(0 0 0 transparent);transition:filter .12s}\n  .knob:hover .ring{filter:drop-shadow(0 0 6px rgba(79,141,255,.45))}\n  .dial{position:absolute;inset:3px;border-radius:50%;\n    background:radial-gradient(58% 58% at 38% 30%,#333845,#181b22 70%,#0d0f14);\n    border:1px solid rgba(0,0,0,.55);box-shadow:0 2px 6px #0009,0 1px 0 rgba(255,255,255,.06) inset}\n  .dial::after{content:\"\";position:absolute;left:50%;top:5px;width:2px;height:13px;border-radius:2px;\n    background:#eef3fc;transform-origin:50% 16px;transform:translateX(-50%) rotate(var(--rot,-135deg));\n    box-shadow:0 0 6px var(--accent)}\n  .knob label{font:600 9px var(--sans);letter-spacing:.05em;color:var(--ink-2);text-align:center}\n  .knob .val{font:600 9px var(--mono);color:var(--muted)}\n  /* compact knob for the modulation matrix */\n  .knob.sm{width:46px} .knob.sm .ring{width:38px;height:38px}\n  .knob.sm .dial::after{height:11px;top:4px;transform-origin:50% 14px}\n\n  .oscname{font:700 9px var(--sans);letter-spacing:.1em;color:var(--ink-2);margin-bottom:6px;text-transform:uppercase}\n  .waves{display:flex;gap:3px;margin-bottom:8px}\n  .waves button{flex:1;display:flex;align-items:center;justify-content:center;\n    background:#0e1015;border:1px solid var(--line);color:var(--muted);border-radius:7px;\n    padding:5px 0;cursor:pointer;line-height:0;transition:.12s}\n  .waves button svg{width:26px;height:14px;display:block}\n  .waves button:hover{color:var(--ink-2);border-color:var(--line-2)}\n  .waves button.on{color:#fff;background:linear-gradient(180deg,#5b97ff,var(--accent));border-color:#3f74e0;\n    box-shadow:0 0 11px rgba(79,141,255,.4)}\n  .col{display:flex;flex-direction:column;align-items:center}\n\n  /* ---- modulation (3 LFOs + routing list) ---- */\n  .sect.mod{margin-top:0}\n  .lfos{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}\n  .lfo-card{flex:1 1 180px;display:flex;align-items:center;gap:10px;\n    background:#0e1015;border:1px solid var(--line);border-radius:10px;padding:8px 11px}\n  .lfo-card .name{font:700 10px var(--sans);letter-spacing:.06em;color:var(--ink-2);width:40px}\n  .lfo-card .waves{margin:0;flex:1;max-width:128px}\n  .lfo1 .name{color:var(--accent)} .lfo2 .name{color:var(--accent-2)} .lfo3 .name{color:var(--ok)}\n  .routes{display:flex;flex-direction:column;gap:8px}\n  .route-list{display:flex;flex-direction:column;gap:8px}\n  .route{display:flex;align-items:center;gap:9px}\n  .msel{background:#0e1015;border:1px solid var(--line);color:var(--ink-2);border-radius:7px;\n    padding:7px 9px;font:600 11px var(--sans);cursor:pointer;outline:none}\n  .msel:hover{border-color:var(--line-2)}\n  .msel.dst{flex:1;min-width:130px}\n  .route .arrow{color:var(--muted)}\n  .route-del{background:none;border:1px solid var(--line);color:var(--muted);border-radius:6px;\n    width:26px;height:26px;cursor:pointer;font-size:14px;line-height:1;flex:0 0 auto}\n  .route-del:hover{color:#ff7a7a;border-color:#7a3030}\n  .route-add{align-self:flex-start;background:#0e1015;border:1px dashed var(--line-2);color:var(--accent);\n    border-radius:8px;padding:7px 13px;cursor:pointer;font:600 11px var(--sans);margin-top:2px}\n  .route-add:hover{border-color:var(--accent);background:#0f1320}\n  /* ---- arpeggiator ---- */\n  .arp-row{display:flex;align-items:flex-end;gap:18px 22px;flex-wrap:wrap}\n  .arp-field{display:flex;flex-direction:column;gap:7px}\n  .arp-flabel{font:600 8px var(--mono);letter-spacing:.15em;text-transform:uppercase;color:var(--muted)}\n  .arp-knobs{margin-left:auto;gap:14px}\n  .arp-on{background:#0e1015;border:1px solid var(--line);color:var(--muted);border-radius:8px;\n    padding:8px 17px;font:700 12px var(--mono);letter-spacing:.12em;cursor:pointer}\n  .arp-on.on{color:#06140f;background:linear-gradient(180deg,#5fe6bf,var(--ok));border-color:#2c8c79;\n    box-shadow:0 0 12px rgba(70,211,154,.45)}\n  .arp-hint{font:600 9px var(--mono);letter-spacing:.03em;color:var(--muted);opacity:.7;margin:12px 0 0}\n  .seg{display:flex;gap:3px}\n  .seg button{background:#0e1015;border:1px solid var(--line);color:var(--muted);border-radius:7px;\n    padding:6px 11px;cursor:pointer;font:600 13px var(--mono);line-height:1;transition:.12s}\n  .seg button:hover{color:var(--ink-2);border-color:var(--line-2)}\n  .seg button.on{color:#fff;background:linear-gradient(180deg,#5b97ff,var(--accent));border-color:#3f74e0}\n  .msel{background:#0e1015;border:1px solid var(--line);color:var(--ink-2);border-radius:7px;\n    padding:7px 9px;font:600 11px var(--mono);cursor:pointer}\n\n  /* ---- on-screen keyboard (self-contained: plays the synth + roots the arp) ---- */\n  .sect.keys{column-span:all;break-inside:avoid}\n  .kbd{position:relative;display:flex;height:94px;margin-top:2px;touch-action:none}\n  .key{position:relative;flex:1;border:1px solid #0a0c10;border-top:none;border-radius:0 0 6px 6px;\n    background:linear-gradient(180deg,#eef1f6,#ccd2dc);box-shadow:0 -3px 5px rgba(0,0,0,.32) inset;cursor:pointer}\n  .key.dn{background:linear-gradient(180deg,#9fc0ff,#6f97e6)}\n  .key.black{position:absolute;top:0;width:6%;height:60%;z-index:2;border-radius:0 0 5px 5px;\n    background:linear-gradient(180deg,#2b3140,#0b0d12);border:1px solid #000;\n    box-shadow:0 3px 6px rgba(0,0,0,.6);transform:translateX(-50%)}\n  .key.black.dn{background:linear-gradient(180deg,#5b8cff,#3358c8)}\n  .kbd-hint{font:600 9px var(--mono);letter-spacing:.04em;color:var(--muted);opacity:.7;margin:9px 0 0}\n\n  /* ---- intro build animation (homepage only; gated by window.__vstaiIntro) ---- */\n  /* the prompt box floats above everything (sections get a stacking context from\n     their reveal transform, so it needs an explicit z-index to stay on top) */\n  .build{position:relative;z-index:30;margin:2px 0 14px;display:flex;flex-direction:column;gap:7px;\n    transition:opacity .5s ease,margin .5s ease}\n  .chat{display:flex;align-items:center;gap:11px;font-size:15px;\n    background:linear-gradient(180deg,#171b25,#11141b);border:1px solid var(--line-2);\n    border-radius:12px;padding:12px 15px;box-shadow:0 16px 50px -26px #000,inset 0 1px 0 rgba(255,255,255,.05)}\n  .chat .spark{width:18px;height:18px;flex:0 0 auto;color:var(--accent);\n    filter:drop-shadow(0 0 5px rgba(79,141,255,.6))}\n  .chat .tag{font:600 9px var(--mono);letter-spacing:.14em;color:var(--muted);text-transform:uppercase;\n    flex:0 0 auto;border-right:1px solid var(--line);padding-right:11px}\n  .ctext{font-weight:600;color:var(--ink);white-space:pre}\n  .ccaret{width:2px;height:1.05em;border-radius:2px;background:var(--accent);\n    box-shadow:0 0 8px var(--accent);animation:cbl 1s steps(1) infinite}\n  .chat.ready .ccaret{display:none}\n  @keyframes cbl{50%{opacity:0}}\n  .chat .skiph{margin-left:auto;flex:0 0 auto;font:600 9px var(--mono);letter-spacing:.12em;\n    color:var(--muted);opacity:.55;text-transform:uppercase}\n  .chat.ready .skiph{display:none}\n  .bcap{min-height:15px;font:600 12px var(--mono);letter-spacing:.04em;color:var(--muted);padding-left:2px}\n  .bcap.ok{color:var(--ok);font-size:13px}\n  .sect.pre,.head.pre{opacity:0;transform:translateY(14px) scale(.985);pointer-events:none}\n  .sect.in,.head.in{opacity:1;transform:none;\n    transition:opacity .7s ease,transform .75s cubic-bezier(.2,.7,.2,1)}\n</style></head>\n<body>\n  <div class=\"head\"><b>VibeSynth</b><span>monophonic analog · 3 osc · ladder filter · LFO matrix · FX</span></div>\n\n  <div class=\"rack\" id=\"rack\"></div>\n\n<script>\nconst K=(label,idx,min,max,def,unit,step)=>({type:'knob',label,idx,min,max,def,unit,step});\nconst OSC=(name,wIdx,octIdx,detIdx,defWave,defOct,defDet)=>({type:'osc',name,wIdx,octIdx,detIdx,defWave,defOct,defDet});\nconst SECTIONS=[\n  {h:'Oscillator Bank',items:[ OSC('Osc 1',2,3,null,1,0,0), OSC('Osc 2',4,5,6,1,0,7), OSC('Osc 3',7,8,9,2,-1,-5) ]},\n  {h:'Mixer',items:[ K('Osc 1',10,0,1,0.9), K('Osc 2',11,0,1,0.7), K('Osc 3',12,0,1,0.5), K('Noise',13,0,1,0.06) ]},\n  {h:'Ladder Filter',items:[ K('Cutoff',14,0,1,0.42), K('Reso',15,0,1,0.55), K('Env',16,0,1,0.6),\n     K('Atk',17,0,1,0.04), K('Dec',18,0,1,0.5), K('Sus',19,0,1,0.25), K('Rel',20,0,1,0.4) ]},\n  {h:'Loudness · Glide',items:[ K('Atk',21,0,1,0.02), K('Dec',22,0,1,0.4), K('Sus',23,0,1,0.8), K('Rel',24,0,1,0.35),\n     K('Drive',25,0,1,0.3), K('Glide',1,0,1,0.05), K('Tune',0,-12,12,0,'st',1), K('Vol',26,0,1,0.8) ]},\n  {h:'Chorus',items:[ K('Mix',27,0,1,0.35), K('Rate',28,0,1,0.3), K('Depth',29,0,1,0.5) ]},\n  {h:'Ping-Pong Delay',items:[ K('Mix',30,0,1,0.22), K('Time',31,0,1,0.4), K('F.back',32,0,1,0.4) ]},\n  {h:'Reverb',items:[ K('Mix',33,0,1,0.3), K('Size',34,0,1,0.6), K('Damp',35,0,1,0.4) ]},\n];\n\n/* ---- exact waveform icons (stroked SVG paths in a 28x16 box) ----------- */\nconst WAVE_PATHS={\n  sine:'M1 8 C 4.3 0.6, 9.7 0.6, 13 8 C 16.3 15.4, 21.7 15.4, 25 8',\n  tri :'M1 8 L 5 2 L 13 14 L 21 2 L 25 8',\n  saw :'M2 14 L 9 2 L 9 14 L 16 2 L 16 14 L 23 2',\n  sq  :'M1 13 L 1 3 L 8 3 L 8 13 L 15 13 L 15 3 L 22 3 L 22 13 L 25 13',\n  pulse:'M1 13 L 5 13 L 5 3 L 8 3 L 8 13 L 15 13 L 15 3 L 18 3 L 18 13 L 25 13',\n};\nconst waveSVG=(name)=>'<svg viewBox=\"0 0 26 16\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" '+\n  'stroke-linejoin=\"round\" stroke-linecap=\"round\"><path d=\"'+WAVE_PATHS[name]+'\"/></svg>';\n\n/* ---- params: setP tracks a base value so the LFO matrix can add on top --- */\nconst base={};\nfunction raw(i,v){ if(window.vstai) window.vstai.setParam(i,v); }\nfunction setP(i,v){ base[i]=v; raw(i,v); }\n\nfunction makeWaveBtns(icons,def,onPick){\n  const waves=document.createElement('div'); waves.className='waves';\n  const btns=icons.map((name,wi)=>{const b=document.createElement('button');\n    b.innerHTML=waveSVG(name); b.title=name[0].toUpperCase()+name.slice(1);\n    b.onclick=()=>{onPick(wi);btns.forEach(x=>x.classList.remove('on'));b.classList.add('on');};return b;});\n  btns[def].classList.add('on'); waves.append(...btns); return waves;\n}\n\nfunction knob(s){\n  const wrap=document.createElement('div'); wrap.className='knob'+(s.sm?' sm':'');\n  const ring=document.createElement('div'); ring.className='ring';\n  const dial=document.createElement('div'); dial.className='dial'; ring.append(dial);\n  const lab=document.createElement('label'); lab.textContent=s.label;\n  const val=document.createElement('div'); val.className='val';\n  wrap.append(ring,lab,val); let v=s.def;\n  const snap=(x)=> s.step? Math.round(x/s.step)*s.step : x;\n  const send=(sv)=> s.set? s.set(sv) : setP(s.idx,sv);\n  function apply(emit){\n    // keep v as a continuous accumulator (clamped); snap only for display + output,\n    // otherwise small drag increments on a stepped knob round back before they add up.\n    v=Math.max(s.min,Math.min(s.max,v));\n    const sv=snap(v);\n    const t=(sv-s.min)/(s.max-s.min);\n    ring.style.setProperty('--deg',(t*270)+'deg');\n    dial.style.setProperty('--rot',(-135+t*270)+'deg');\n    val.textContent = s.unit==='st'?(sv>0?'+':'')+sv.toFixed(0)+'st':(s.step?sv.toFixed(0):sv.toFixed(2));\n    if(emit) send(sv);\n  }\n  let ly=0;\n  const dn=(e)=>{ly=e.clientY;try{ring.setPointerCapture(e.pointerId);}catch(_){ }e.preventDefault();};\n  const mv=(e)=>{if(!ring.hasPointerCapture||!ring.hasPointerCapture(e.pointerId))return;const y=e.clientY;v+=(ly-y)*(s.max-s.min)/170;ly=y;apply(true);};\n  const up=(e)=>{try{ring.releasePointerCapture(e.pointerId);}catch(_){ }};\n  ring.addEventListener('pointerdown',dn);\n  ring.addEventListener('pointermove',mv);\n  ring.addEventListener('pointerup',up);\n  ring.addEventListener('pointercancel',up);\n  ring.addEventListener('dblclick',()=>{v=s.def;apply(true);});\n  apply(true); return wrap;\n}\nfunction osc(s){\n  const col=document.createElement('div'); col.className='col';\n  const name=document.createElement('div'); name.className='oscname'; name.textContent=s.name;\n  setP(s.wIdx,s.defWave);\n  const waves=makeWaveBtns(['tri','saw','sq','pulse'],s.defWave,(wi)=>setP(s.wIdx,wi));\n  const knobs=document.createElement('div'); knobs.className='knobs';\n  knobs.append(knob(K('Oct',s.octIdx,-2,2,s.defOct,'',1)));\n  if(s.detIdx!=null) knobs.append(knob(K('Detune',s.detIdx,-50,50,s.defDet)));\n  col.append(name,waves,knobs); return col;\n}\n\n/* ====================================================================== *\n *  MODULATION + ARPEGGIATOR — three LFOs patchable onto ANY knob, plus an  *\n *  arp that starts when audio starts. All runs in the GUI, streaming        *\n *  setParam()/noteOn() to the DSP (its params are all in use server-side).  *\n * ====================================================================== */\n// every knob is a possible mod destination — derived from the section data\nconst MOD_DESTS=[];\n(function(){\n  const SHORT={'Oscillator Bank':'Osc','Mixer':'Mix','Ladder Filter':'Filt','Loudness · Glide':'Amp',\n    'Chorus':'Chorus','Ping-Pong Delay':'Delay','Reverb':'Reverb'};\n  const add=(idx,label,min,max)=>{ if(idx!=null) MOD_DESTS.push({idx,label,min,max}); };\n  for(const sec of SECTIONS){ const p=SHORT[sec.h]||sec.h;\n    for(const it of sec.items){\n      if(it.type==='osc'){ add(it.octIdx,p+' '+it.name+' Oct',-2,2); if(it.detIdx!=null) add(it.detIdx,p+' '+it.name+' Detune',-50,50); }\n      else add(it.idx,p+' '+it.label,it.min,it.max);\n    }\n  }\n})();\nconst destOf=(pidx)=>Math.max(0,MOD_DESTS.findIndex(d=>d.idx===pidx));\n\nconst RATE_HZ=(t)=>0.08*Math.pow(600,t);   // ~0.08 .. 48 Hz — top end is 5x the old LFO max\nfunction lfoOut(shape,p){\n  if(shape===0) return Math.sin(p*6.2831853);             // sine\n  if(shape===1) return p<0.5? -1+4*p : 3-4*p;             // triangle\n  if(shape===2) return 2*p-1;                             // saw\n  return p<0.5? 1 : -1;                                   // square\n}\nconst LFOS=[\n  {shape:0, rate:0.45, phase:0},\n  {shape:1, rate:0.34, phase:0.25},\n  {shape:2, rate:0.60, phase:0.5},\n];\n// modulation routes: source LFO -> destination (index into MOD_DESTS) * amount(-1..1)\nconst ROUTES=[\n  {lfo:0, dest:destOf(14), amt:0.35},   // LFO 1 -> Cutoff\n  {lfo:1, dest:destOf(15), amt:0.20},   // LFO 2 -> Reso\n  {lfo:2, dest:destOf(27), amt:0.30},   // LFO 3 -> Chorus Mix\n];\n\nfunction lfoCard(lfo,li){\n  const card=document.createElement('div'); card.className='lfo-card lfo'+(li+1);\n  const nm=document.createElement('div'); nm.className='name'; nm.textContent='LFO '+(li+1);\n  const waves=makeWaveBtns(['sine','tri','saw','sq'],lfo.shape,(wi)=>lfo.shape=wi);\n  const rate=knob({label:'Rate',min:0,max:1,def:lfo.rate,sm:true,set:(v)=>{lfo.rate=v;}});\n  card.append(nm,waves,rate); return card;\n}\nfunction routeRow(r,rerender){\n  const row=document.createElement('div'); row.className='route';\n  const src=document.createElement('select'); src.className='msel src';\n  ['LFO 1','LFO 2','LFO 3'].forEach((n,i)=>{const o=document.createElement('option');o.value=i;o.textContent=n;src.append(o);});\n  src.value=r.lfo; src.onchange=()=>r.lfo=+src.value;\n  const arrow=document.createElement('span'); arrow.className='arrow'; arrow.textContent='→';\n  const dst=document.createElement('select'); dst.className='msel dst';\n  MOD_DESTS.forEach((d,i)=>{const o=document.createElement('option');o.value=i;o.textContent=d.label;dst.append(o);});\n  dst.value=r.dest; dst.onchange=()=>r.dest=+dst.value;\n  const amt=knob({label:'Amt',min:-1,max:1,def:r.amt,sm:true,set:(v)=>{r.amt=v;}});\n  const del=document.createElement('button'); del.className='route-del'; del.title='remove'; del.textContent='×';\n  del.onclick=()=>{ const i=ROUTES.indexOf(r); if(i>=0) ROUTES.splice(i,1); rerender(); };\n  row.append(src,arrow,dst,amt,del); return row;\n}\nfunction buildMod(){\n  const el=document.createElement('div'); el.className='sect mod';\n  const h=document.createElement('h3'); h.textContent='Modulation · 3 LFOs'; el.append(h);\n  const lfos=document.createElement('div'); lfos.className='lfos';\n  LFOS.forEach((lfo,li)=>lfos.append(lfoCard(lfo,li)));\n  el.append(lfos);\n  const routes=document.createElement('div'); routes.className='routes';\n  const list=document.createElement('div'); list.className='route-list';\n  function rerender(){ list.innerHTML=''; ROUTES.forEach(r=>list.append(routeRow(r,rerender))); }\n  const add=document.createElement('button'); add.className='route-add'; add.textContent='+ patch an LFO onto any knob';\n  add.onclick=()=>{ ROUTES.push({lfo:0,dest:0,amt:0.3}); rerender(); };\n  routes.append(list,add); el.append(routes); rerender();\n  return el;\n}\n\n/* ---- arpeggiator UI — the arpeggiator itself lives in the WASM/DSP (moog.ts) so it\n   follows DAW MIDI and keeps running when this window is closed. Here we only set its\n   parameters; the on-screen keyboard and the DAW feed it the held notes to step. ---- */\nconst P_ARP_ON=36, P_ARP_RATE=37, P_ARP_OCT=38, P_ARP_GATE=39, P_ARP_MODE=40;\nlet arpOn=true;\nfunction segBtns(labels,def,onPick){\n  const w=document.createElement('div'); w.className='seg';\n  const bs=labels.map((t,i)=>{const b=document.createElement('button');b.textContent=t;b.title=['Up','Down','Up-Down','Random'][i]||'';\n    b.onclick=()=>{onPick(i);bs.forEach(x=>x.classList.remove('on'));b.classList.add('on');};return b;});\n  bs[def].classList.add('on'); w.append(...bs); return w;\n}\nfunction arpField(label,node){\n  const f=document.createElement('div'); f.className='arp-field';\n  const l=document.createElement('div'); l.className='arp-flabel'; l.textContent=label;\n  f.append(l,node); return f;\n}\nfunction buildArp(){\n  const el=document.createElement('div'); el.className='sect arp';\n  const h=document.createElement('h3'); h.textContent='Arpeggiator'; el.append(h);\n  const row=document.createElement('div'); row.className='arp-row';\n  const onb=document.createElement('button'); onb.className='arp-on on'; onb.textContent='ON';\n  onb.onclick=()=>{ arpOn=!arpOn; onb.classList.toggle('on',arpOn); onb.textContent=arpOn?'ON':'OFF'; setP(P_ARP_ON,arpOn?1:0); };\n  row.append(arpField('Arp',onb));\n  row.append(arpField('Direction', segBtns(['↑','↓','↑↓','✶'],0,(i)=>setP(P_ARP_MODE,i))));\n  const knobs=document.createElement('div'); knobs.className='knobs arp-knobs';\n  knobs.append(knob({label:'Rate',min:0,max:1,def:0.5,set:(v)=>setP(P_ARP_RATE,v)}));\n  knobs.append(knob({label:'Octaves',min:1,max:4,def:2,step:1,set:(v)=>setP(P_ARP_OCT,v)}));\n  knobs.append(knob({label:'Gate',min:0.1,max:1,def:0.5,set:(v)=>setP(P_ARP_GATE,v)}));\n  row.append(knobs); el.append(row);\n  const hint=document.createElement('div'); hint.className='arp-hint';\n  hint.textContent='ON: hold notes (the keys or your DAW) and they arpeggiate · OFF: play normally · keeps running with this window closed';\n  el.append(hint); return el;\n}\n\n// modulation + arp loop, streamed to the DSP at frame rate\nlet last=null;\nfunction modTick(now){\n  requestAnimationFrame(modTick);\n  if(last==null){ last=now; return; }\n  const dt=Math.min(0.05,(now-last)/1000); last=now;\n  for(const lfo of LFOS){ lfo.phase=(lfo.phase+dt*RATE_HZ(lfo.rate))%1; }\n  const acc=new Map();\n  for(const r of ROUTES){ if(!r||Math.abs(r.amt)<0.001) continue;\n    const d=MOD_DESTS[r.dest], lfo=LFOS[r.lfo]; if(!d||!lfo) continue;\n    const add=lfoOut(lfo.shape,lfo.phase)*r.amt*(d.max-d.min)*0.5;\n    const e=acc.get(d.idx)||{sum:0,d}; e.sum+=add; acc.set(d.idx,e);\n  }\n  for(const [idx,e] of acc){ const b=(idx in base)?base[idx]:0; raw(idx, Math.max(e.d.min,Math.min(e.d.max,b+e.sum))); }\n}\n\nconst rack=document.getElementById('rack');\nconst sectionEls=[];\nfor(const sec of SECTIONS){\n  const el=document.createElement('div'); el.className='sect'+(sec.h==='Oscillator Bank'?' osc-bank':'');\n  const h=document.createElement('h3'); h.textContent=sec.h; el.append(h);\n  const k=document.createElement('div'); k.className='knobs';\n  for(const it of sec.items) k.append(it.type==='osc'?osc(it):knob(it));\n  el.append(k); rack.append(el); sectionEls.push(el);\n}\nsectionEls.push(rack.appendChild(buildMod()));\nsectionEls.push(rack.appendChild(buildArp()));\n\n/* ---- on-screen keyboard — makes VibeSynth self-contained: it plays the synth and,\n   with the arp ON, a key sets the arpeggio root (and starts it). No longer depends on\n   the gallery's keyboard or its audio-start signal, so the arp works in the plugin. ---- */\nconst KB_LOW=48, KB_OCTS=2, WHITE_IV=[0,2,4,5,7,9,11], BLACK_AT={1:1,3:2,6:4,8:5,10:6};\nconst KEY_ROW='awsedftgyhujk';                  // computer keys: chromatic up from KB_LOW\nconst kbDown=new Set(), kbEls={};\nfunction kbPlay(note,on){\n  // Just send the note — the WASM arpeggiator (if on) steps the held notes itself.\n  if(window.vstai){ if(on) window.vstai.noteOn(note,0.95); else window.vstai.noteOff(note); }\n}\nfunction kbPress(n){ if(kbDown.has(n))return; kbDown.add(n); if(kbEls[n])kbEls[n].classList.add('dn'); kbPlay(n,true); }\nfunction kbRelease(n){ if(!kbDown.has(n))return; kbDown.delete(n); if(kbEls[n])kbEls[n].classList.remove('dn'); kbPlay(n,false); }\nfunction buildKeys(){\n  const el=document.createElement('div'); el.className='sect keys';\n  const h=document.createElement('h3'); h.textContent='Keyboard'; el.append(h);\n  const kb=document.createElement('div'); kb.className='kbd'; const W=KB_OCTS*7;\n  for(let o=0;o<KB_OCTS;o++) for(let i=0;i<7;i++){ const note=KB_LOW+o*12+WHITE_IV[i];\n    const k=document.createElement('div'); k.className='key'; k.dataset.note=note; kb.append(k); kbEls[note]=k; }\n  for(let o=0;o<KB_OCTS;o++) for(const w in BLACK_AT){ const note=KB_LOW+o*12+(+w);\n    const b=document.createElement('div'); b.className='key black'; b.dataset.note=note;\n    b.style.left=((o*7+BLACK_AT[w])/W*100)+'%'; kb.append(b); kbEls[note]=b; }\n  kb.addEventListener('pointerdown',(e)=>{ const n=e.target.dataset&&e.target.dataset.note; if(n){ e.preventDefault(); kbPress(+n); } });\n  el.append(kb);\n  const tip=document.createElement('div'); tip.className='kbd-hint';\n  tip.textContent='click the keys'+(window.top===window?' or type A–K':'')+' · with the arp ON, a key sets the arpeggio root';\n  el.append(tip); return el;\n}\nwindow.addEventListener('pointerup',    ()=>{ for(const n of [...kbDown]) kbRelease(n); });\nwindow.addEventListener('pointercancel',()=>{ for(const n of [...kbDown]) kbRelease(n); });\nif(window.top===window){                          // computer keys only when top-level (the plugin),\n  window.addEventListener('keydown',(e)=>{ if(e.repeat||e.metaKey||e.ctrlKey)return; const i=KEY_ROW.indexOf((e.key||'').toLowerCase()); if(i>=0) kbPress(KB_LOW+i); });\n  window.addEventListener('keyup',  (e)=>{ const i=KEY_ROW.indexOf((e.key||'').toLowerCase()); if(i>=0) kbRelease(KB_LOW+i); });\n}\nsectionEls.push(rack.appendChild(buildKeys()));\nrequestAnimationFrame(modTick);\n\n/* ====================================================================== *\n *  INTRO BUILD — only on the homepage embed (play.html sets window.__vstaiIntro).\n *  Sections start hidden; a series of typed requests reveal them one group at a\n *  time, then a \"Try it out\" caption. The real plugin/gallery never sees this.  *\n * ====================================================================== */\nif(window.__vstaiIntro){\n  const head=document.querySelector('.head');\n  head.classList.add('pre'); sectionEls.forEach(el=>el.classList.add('pre'));\n  const build=document.createElement('div'); build.className='build';\n  build.innerHTML='<div class=\"chat\"><svg class=\"spark\" viewBox=\"0 0 24 24\" fill=\"currentColor\">'+\n    '<path d=\"M12 2l1.8 5.6L19 9.4l-4.6 3.1L16 18l-4-3.3L8 18l1.6-5.5L5 9.4l5.2-1.8z\"/></svg>'+\n    '<span class=\"tag\">You</span><span class=\"ctext\"></span><span class=\"ccaret\"></span>'+\n    '<span class=\"skiph\">click to skip</span></div>'+\n    '<div class=\"bcap\"></div>';\n  document.body.insertBefore(build, rack);\n  const chat=build.querySelector('.chat'), ctext=build.querySelector('.ctext'), bcap=build.querySelector('.bcap');\n  const postIntro=(phase)=>{try{parent.postMessage({__vstai:1,type:'intro',phase},'*');}catch(_){}}\n\n  const STEPS=[\n    {p:'a synth like a Moog Model D — three oscillators + a ladder filter', reveal:[0,1,2]},\n    {p:'add amp & filter envelopes with glide',                            reveal:[3]},\n    {p:'give it a lush stereo FX rack',                                     reveal:[4,5,6]},\n    {p:'three LFOs I can patch onto any knob',                             reveal:[7]},\n    {p:'and an arpeggiator',                                                reveal:[8]},\n  ];\n  let done=false;\n  const show=(el)=>{el.classList.remove('pre');el.classList.add('in');};\n  function reveal(idxs){ idxs.forEach((gi,k)=>setTimeout(()=>{const el=sectionEls[gi];if(el)show(el);},k*190)); }\n  function fadeBuildSoon(){ setTimeout(()=>{ build.style.opacity='0'; build.style.margin='0';\n    setTimeout(()=>build.remove(),520); }, 5200); }\n  function finishAll(){ if(done)return; done=true;\n    show(head); sectionEls.forEach(show); postIntro('keys');\n    chat.classList.add('ready'); ctext.textContent='';\n    bcap.textContent='✓ Ready — try it out, play the keys'; bcap.classList.add('ok'); fadeBuildSoon(); }\n  document.body.addEventListener('pointerdown',()=>{ if(!done) finishAll(); });\n\n  function type(text,cb){ ctext.textContent=''; let i=0;\n    (function t(){ if(done)return; ctext.textContent=text.slice(0,i);\n      if(i++<text.length) setTimeout(t,30+Math.random()*32); else setTimeout(cb,520); })(); }\n  let si=0;\n  function step(){\n    if(done) return;\n    if(si===0) show(head);\n    if(si>=STEPS.length){ finale(); return; }\n    const st=STEPS[si++];\n    type(st.p,()=>{ if(done)return; bcap.textContent='compiling to WebAssembly…'; reveal(st.reveal);\n      setTimeout(()=>{ if(done)return; bcap.textContent=''; step(); }, 950+st.reveal.length*190); });\n  }\n  function finale(){\n    type('…and a playable keyboard',()=>{ if(done)return; done=true; postIntro('keys');\n      chat.classList.add('ready'); bcap.textContent='✓ Ready — try it out, play the keys'; bcap.classList.add('ok');\n      fadeBuildSoon(); });\n  }\n  const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;\n  if(reduce) finishAll(); else setTimeout(step,700);\n}\n</script>\n</body></html>\n","publishedAt":1750000002000}