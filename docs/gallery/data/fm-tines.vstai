{
  "format": 1,
  "name": "FM Tines",
  "isInstrument": true,
  "explanation": "A bright, polyphonic FM electric-piano synth. A two-operator phase-modulation engine drives a fast-decaying modulation-index envelope for the classic struck-tine bell attack that settles into a pure sine body, with attack/release amp shaping and a brightness tilt. Controls: Ratio, FMAmount, ModDecay, Attack, Release, Brightness and Level.",
  "params": [
    {
      "name": "Ratio",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "FMAmount",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "ModDecay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Attack",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Brightness",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>FM Tines</title>\n<style>\n  :root{\n    --ac:#7ab8ff; --ac2:#9ad0ff;\n    --lcd:#9fe88a; --lcd-dim:#3f7a3a; --lcd-bg:#10271a;\n    --plastic1:#2b2e33; --plastic2:#16181c; --plastic3:#0a0b0d;\n    --membrane:#1d2025; --membrane-lit:#2c313a;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0; font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace; color:#c7d2e0;\n    background:radial-gradient(120% 90% at 50% -10%,#202329,#0a0b0e 60%,#050506 100%);\n    display:flex; align-items:center; justify-content:center; padding:18px;\n    -webkit-font-smoothing:antialiased;\n  }\n\n  /* ====== the unit: a wedge of dark plastic ====== */\n  .unit{\n    position:relative; width:100%; max-width:620px;\n    background:\n      linear-gradient(180deg,#33373e 0%,#23262c 4%,#181b20 5%,#101216 100%);\n    border-radius:14px;\n    padding:0 0 18px;\n    box-shadow:\n      0 36px 80px rgba(0,0,0,.65),\n      0 2px 0 rgba(255,255,255,.05) inset,\n      0 -22px 40px rgba(0,0,0,.5) inset;\n    border:1px solid #000;\n    overflow:hidden;\n  }\n  /* fine moulded texture across the whole faceplate */\n  .unit::before{\n    content:\"\"; position:absolute; inset:0; pointer-events:none; z-index:0; opacity:.5;\n    background:\n      repeating-linear-gradient(0deg,rgba(255,255,255,.018) 0 1px,transparent 1px 3px),\n      repeating-linear-gradient(90deg,rgba(0,0,0,.10) 0 1px,transparent 1px 4px);\n    mix-blend-mode:overlay;\n  }\n  /* two faux screws */\n  .screw{position:absolute;width:11px;height:11px;border-radius:50%;z-index:6;\n    background:radial-gradient(circle at 38% 32%,#5a5f68,#1b1d21 70%);\n    box-shadow:0 1px 1px rgba(0,0,0,.7),0 0 0 1px #000 inset}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#0a0b0d 44% 56%,transparent 56%)}\n  .screw.tl{top:11px;left:11px} .screw.tr{top:11px;right:11px}\n  .screw.bl{bottom:11px;left:11px} .screw.br{bottom:11px;right:11px}\n\n  /* ====== header / brand bar ====== */\n  .head{position:relative;z-index:2;display:flex;align-items:center;gap:12px;\n    padding:14px 26px 12px;border-bottom:1px solid #000;\n    background:linear-gradient(180deg,rgba(255,255,255,.04),rgba(0,0,0,0))}\n  .pwr{width:10px;height:10px;border-radius:50%;flex:none;\n    background:radial-gradient(circle at 40% 35%,#cdeeff,var(--ac) 55%,#0c2a48 100%);\n    box-shadow:0 0 10px var(--ac),0 0 2px #fff inset;animation:pwr 2.6s ease-in-out infinite}\n  @keyframes pwr{0%,100%{opacity:.7;filter:brightness(.85)}50%{opacity:1;filter:brightness(1.25)}}\n  .brand{display:flex;flex-direction:column;line-height:1.05;flex:1}\n  .brand .mk{font-size:8.5px;letter-spacing:.42em;color:#6c7686;text-transform:uppercase}\n  .brand h1{margin:1px 0 0;font-size:21px;font-weight:800;letter-spacing:.14em;\n    font-family:ui-sans-serif,system-ui,sans-serif;\n    background:linear-gradient(180deg,#eef6ff,#7fa9d8);-webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 1px 0 rgba(0,0,0,.4)}\n  .model{font-size:8px;letter-spacing:.3em;color:#586273;text-transform:uppercase;\n    border:1px solid #2a2f38;border-radius:4px;padding:4px 8px;background:#0c0e12;\n    box-shadow:0 1px 0 rgba(255,255,255,.04) inset}\n\n  /* ====== the green LCD ====== */\n  .lcd{position:relative;z-index:2;margin:16px 26px 8px;border-radius:8px;\n    background:\n      linear-gradient(180deg,var(--lcd-bg),#0a1c12);\n    border:2px solid #05100a;\n    box-shadow:\n      0 3px 10px rgba(0,0,0,.6) inset,\n      0 0 0 4px #1a1c20,\n      0 0 24px rgba(60,180,90,.10);\n    padding:13px 16px 14px;overflow:hidden;\n    image-rendering:pixelated;\n  }\n  /* scanlines + glass glare on the LCD */\n  .lcd::before{content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:repeating-linear-gradient(0deg,rgba(0,0,0,.22) 0 1px,transparent 1px 3px)}\n  .lcd::after{content:\"\";position:absolute;top:-60%;left:-20%;width:60%;height:200%;pointer-events:none;\n    background:linear-gradient(115deg,rgba(255,255,255,.07),transparent 60%);transform:rotate(8deg)}\n  .lcd-row{position:relative;z-index:1;display:flex;align-items:flex-start;gap:18px}\n  .lcd-readout{flex:1;min-width:0}\n  .lcd-line{display:flex;justify-content:space-between;align-items:baseline;\n    color:var(--lcd);text-shadow:0 0 6px rgba(120,240,120,.55);\n    font-family:ui-monospace,monospace;letter-spacing:.06em}\n  .lcd-line.big{font-size:17px;font-weight:700}\n  .lcd-line.sub{font-size:10px;color:var(--lcd-dim);margin-top:5px;letter-spacing:.18em;text-shadow:none}\n  .lcd-name{text-transform:uppercase}\n  .lcd-val{font-variant-numeric:tabular-nums}\n  /* bar meter under text */\n  .lcd-bar{position:relative;height:9px;margin-top:9px;border-radius:2px;background:#082414;overflow:hidden;\n    box-shadow:0 0 0 1px #061a0e inset}\n  .lcd-bar i{position:absolute;left:0;top:0;bottom:0;width:50%;\n    background:repeating-linear-gradient(90deg,var(--lcd) 0 5px,transparent 5px 7px);\n    box-shadow:0 0 6px rgba(120,240,120,.5);transition:width .12s ease}\n  /* little waveform that breathes with brightness */\n  .lcd-wave{flex:none;width:120px;height:46px}\n  .lcd-wave path{fill:none;stroke:var(--lcd);stroke-width:1.4;\n    filter:drop-shadow(0 0 3px rgba(120,240,120,.6))}\n\n  /* ====== FM algorithm diagram ====== */\n  .algo{position:relative;z-index:2;margin:10px 26px 4px;padding:10px 14px;\n    border-radius:8px;background:linear-gradient(180deg,#101216,#0a0b0e);\n    border:1px solid #000;box-shadow:0 1px 0 rgba(255,255,255,.03) inset}\n  .algo .cap{font-size:8px;letter-spacing:.34em;color:#5d6675;text-transform:uppercase;margin-bottom:2px}\n  .algo svg{display:block;width:100%;height:74px}\n  .op-box{fill:#13161b;stroke:#2a3038;stroke-width:1.2}\n  .op-lit{fill:url(#opg)}\n  .op-t{font:700 13px ui-sans-serif,sans-serif;fill:#dce6f4}\n  .op-s{font:8px ui-monospace,monospace;fill:#7a8597;letter-spacing:.1em}\n  .wire{fill:none;stroke:#39414d;stroke-width:2}\n  .wire-hot{fill:none;stroke:var(--ac);stroke-width:2.4;\n    filter:drop-shadow(0 0 4px var(--ac));\n    stroke-dasharray:6 7;animation:flow 1s linear infinite}\n  @keyframes flow{to{stroke-dashoffset:-13}}\n  .fbk{fill:none;stroke:var(--ac2);stroke-width:2;stroke-dasharray:5 6;\n    filter:drop-shadow(0 0 3px var(--ac2));animation:flow2 1.4s linear infinite}\n  @keyframes flow2{to{stroke-dashoffset:-11}}\n  .spark{fill:var(--ac)}\n\n  /* ====== control deck ====== */\n  .deck{position:relative;z-index:2;display:grid;\n    grid-template-columns:repeat(4,1fr);gap:12px 10px;\n    padding:16px 22px 4px}\n  .ctl{position:relative;display:flex;flex-direction:column;align-items:center;gap:8px;\n    padding:11px 6px 12px;border-radius:10px;\n    background:linear-gradient(180deg,#1a1d22,#101216);\n    border:1px solid #000;\n    box-shadow:0 1px 0 rgba(255,255,255,.04) inset,0 6px 14px rgba(0,0,0,.4);\n    animation:rise .5s both;animation-delay:var(--d)}\n  @keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n  .ctl:hover{background:linear-gradient(180deg,#1f232a,#121419)}\n\n  /* membrane-button knob */\n  .knob{position:relative;width:62px;height:62px;cursor:ns-resize;touch-action:none;user-select:none}\n  .knob .ring{position:absolute;inset:0;border-radius:50%;\n    background:conic-gradient(from 220deg,\n      var(--ac) calc(var(--n,0)*280deg),\n      #20252d calc(var(--n,0)*280deg) 280deg,\n      transparent 280deg);\n    filter:drop-shadow(0 0 calc(2px + var(--n,0)*7px) color-mix(in srgb,var(--ac) 65%,transparent));\n    transition:filter .15s ease}\n  .knob .ring::after{content:\"\";position:absolute;inset:5px;border-radius:50%;\n    background:radial-gradient(circle at 50% 28%,#3a4150,#10131a 72%);\n    box-shadow:0 3px 8px rgba(0,0,0,.6) inset,0 -1px 0 rgba(255,255,255,.06) inset,0 1px 2px rgba(0,0,0,.6)}\n  .knob .pip{position:absolute;left:50%;top:6px;width:3px;height:16px;margin-left:-1.5px;border-radius:2px;\n    background:linear-gradient(var(--ac),var(--ac2));box-shadow:0 0 7px var(--ac);\n    transform-origin:50% 25px;\n    transform:rotate(calc((var(--n,0) - 0.5) * 280deg));\n    transition:transform .14s cubic-bezier(.2,.8,.25,1)}\n  .knob .ring{transition:filter .15s ease}\n  .knob.live .ring,.knob.live .pip{transition:none}\n\n  .ctl .nm{font-size:9px;letter-spacing:.16em;color:#8a95a6;text-transform:uppercase;text-align:center}\n  .ctl .vv{font-size:12px;font-weight:700;color:var(--lcd);font-variant-numeric:tabular-nums;\n    text-shadow:0 0 6px rgba(120,240,120,.4)}\n  /* membrane press feedback */\n  .knob.act .ring::after{box-shadow:0 4px 12px rgba(0,0,0,.75) inset,0 0 0 1px var(--ac) inset}\n\n  .ctl.wide{grid-column:span 1}\n  /* level control gets a vertical membrane fader instead of a knob */\n  .ctl.fader .track{position:relative;width:38px;height:62px;border-radius:8px;cursor:ns-resize;touch-action:none;\n    background:linear-gradient(180deg,#0a0c10,#15191f);\n    box-shadow:0 2px 6px rgba(0,0,0,.6) inset,0 0 0 1px #000;overflow:hidden}\n  .ctl.fader .track::before{content:\"\";position:absolute;left:50%;top:6px;bottom:6px;width:4px;margin-left:-2px;\n    border-radius:2px;background:#05070a;box-shadow:0 0 0 1px #000 inset}\n  .ctl.fader .fill{position:absolute;left:0;right:0;bottom:0;\n    background:linear-gradient(0deg,color-mix(in srgb,var(--ac) 60%,#0a1c2a),transparent);\n    box-shadow:0 0 10px color-mix(in srgb,var(--ac) 50%,transparent)}\n  .ctl.fader .cap{position:absolute;left:4px;right:4px;height:14px;border-radius:4px;\n    background:linear-gradient(180deg,#3a4150,#171b22);\n    box-shadow:0 1px 2px rgba(0,0,0,.6),0 -1px 0 rgba(255,255,255,.08) inset,0 0 8px var(--ac);\n    transform:translateY(-50%)}\n  .ctl.fader .cap::after{content:\"\";position:absolute;left:6px;right:6px;top:50%;height:2px;margin-top:-1px;\n    background:var(--ac);border-radius:1px;box-shadow:0 0 6px var(--ac)}\n\n  /* tiny embossed footer */\n  .foot{position:relative;z-index:2;margin:14px 26px 0;padding-top:10px;border-top:1px solid #000;\n    display:flex;justify-content:space-between;align-items:center;\n    font-size:8.5px;letter-spacing:.22em;color:#525b6a;text-transform:uppercase}\n  .foot .dots{display:flex;gap:5px}\n  .foot .dots i{width:5px;height:5px;border-radius:50%;background:#1c2026;box-shadow:0 0 0 1px #000 inset}\n  .foot .dots i.on{background:var(--ac);box-shadow:0 0 6px var(--ac)}\n\n  @media(max-width:520px){.deck{grid-template-columns:repeat(3,1fr)}}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <span class=\"pwr\"></span>\n      <div class=\"brand\">\n        <span class=\"mk\">Digital Programmable Algorithm Synthesizer</span>\n        <h1>FM&nbsp;TINES</h1>\n      </div>\n      <span class=\"model\">DX&middot;T7</span>\n    </div>\n\n    <!-- GREEN LCD -->\n    <div class=\"lcd\">\n      <div class=\"lcd-row\">\n        <div class=\"lcd-readout\">\n          <div class=\"lcd-line big\"><span class=\"lcd-name\" id=\"lcdName\">RATIO</span><span class=\"lcd-val\" id=\"lcdVal\">0.50</span></div>\n          <div class=\"lcd-bar\"><i id=\"lcdBar\"></i></div>\n          <div class=\"lcd-line sub\"><span id=\"lcdHint\">EDIT &middot; OP MOD &gt; CAR</span><span id=\"lcdPg\">PG 1/7</span></div>\n        </div>\n        <svg class=\"lcd-wave\" id=\"lcdWave\" viewBox=\"0 0 120 46\" preserveAspectRatio=\"none\"><path d=\"\"></path></svg>\n      </div>\n    </div>\n\n    <!-- FM ALGORITHM DIAGRAM -->\n    <div class=\"algo\">\n      <div class=\"cap\">Algorithm &mdash; 2-OP Phase Modulation</div>\n      <svg viewBox=\"0 0 560 74\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <linearGradient id=\"opg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#1a3a5c\"/><stop offset=\"1\" stop-color=\"#0c1c2c\"/>\n          </linearGradient>\n        </defs>\n        <!-- feedback loop on modulator -->\n        <path class=\"fbk\" id=\"fbk\" d=\"M120 16 C150 -2 168 6 168 26\"/>\n        <!-- modulator -> carrier (the FM amount wire) -->\n        <path class=\"wire\" d=\"M232 32 H322\"/>\n        <path class=\"wire-hot\" id=\"fmwire\" d=\"M232 32 H322\"/>\n        <!-- carrier -> output -->\n        <path class=\"wire\" d=\"M414 32 H520\"/>\n        <path class=\"wire-hot\" id=\"outwire\" d=\"M414 32 H520\" style=\"animation-duration:1.3s\"/>\n\n        <!-- MOD operator -->\n        <g>\n          <rect class=\"op-box\" id=\"modBox\" x=\"150\" y=\"10\" width=\"84\" height=\"44\" rx=\"9\"/>\n          <text class=\"op-t\" x=\"192\" y=\"30\" text-anchor=\"middle\">OP 2</text>\n          <text class=\"op-s\" x=\"192\" y=\"44\" text-anchor=\"middle\">MOD</text>\n        </g>\n        <!-- CAR operator -->\n        <g>\n          <rect class=\"op-box\" id=\"carBox\" x=\"330\" y=\"10\" width=\"84\" height=\"44\" rx=\"9\"/>\n          <text class=\"op-t\" x=\"372\" y=\"30\" text-anchor=\"middle\">OP 1</text>\n          <text class=\"op-s\" x=\"372\" y=\"44\" text-anchor=\"middle\">CAR</text>\n        </g>\n        <!-- output node -->\n        <circle class=\"spark\" id=\"outNode\" cx=\"520\" cy=\"32\" r=\"5\"/>\n        <text class=\"op-s\" x=\"520\" y=\"58\" text-anchor=\"middle\">OUT</text>\n        <!-- travelling spark on the FM wire -->\n        <circle class=\"spark\" id=\"sparkA\" cx=\"232\" cy=\"32\" r=\"3.2\"/>\n      </svg>\n    </div>\n\n    <!-- CONTROL DECK -->\n    <div class=\"deck\" id=\"deck\"></div>\n\n    <div class=\"foot\">\n      <span>VOICE / 16&nbsp;NOTE&nbsp;POLY</span>\n      <span class=\"dots\"><i class=\"on\"></i><i></i><i class=\"on\"></i><i></i><i class=\"on\"></i></span>\n      <span>EP&nbsp;TINE&nbsp;ENGINE</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // ---- param table (re-read from spec: index/min/max/default) ----\n  var PARAMS = [\n    {name:\"Ratio\",      index:0, min:0, max:1, def:0.5,  type:\"knob\",  hint:\"OP RATIO  MOD:CAR\",   fmt:ratioFmt},\n    {name:\"FMAmount\",   index:1, min:0, max:1, def:0.55, type:\"knob\",  hint:\"MOD INDEX  DEPTH\",    fmt:pctFmt},\n    {name:\"ModDecay\",   index:2, min:0, max:1, def:0.45, type:\"knob\",  hint:\"INDEX ENV  DECAY\",    fmt:msFmt},\n    {name:\"Attack\",     index:3, min:0, max:1, def:0.04, type:\"knob\",  hint:\"AMP ENV  ATTACK\",     fmt:msFmt},\n    {name:\"Release\",    index:4, min:0, max:1, def:0.55, type:\"knob\",  hint:\"AMP ENV  RELEASE\",    fmt:msFmt},\n    {name:\"Brightness\", index:5, min:0, max:1, def:0.6,  type:\"knob\",  hint:\"SPECTRAL  TILT\",      fmt:pctFmt},\n    {name:\"Level\",      index:6, min:0, max:1, def:0.7,  type:\"fader\", hint:\"MASTER  OUTPUT\",      fmt:dbFmt}\n  ];\n\n  function ratioFmt(n){ // map 0..1 -> a musical FM ratio readout\n    var ratios=[0.5,1,1.5,2,2.5,3,3.5,4,5,7,9,11,14];\n    var r=ratios[Math.min(ratios.length-1,Math.round(n*(ratios.length-1)))];\n    return r.toFixed(2).replace(/\\.00$/,\".00\");\n  }\n  function pctFmt(n){ return Math.round(n*100)+\"%\"; }\n  function msFmt(n){ var ms=Math.round(2+n*n*3000); return ms>=1000?(ms/1000).toFixed(2)+\"s\":ms+\"ms\"; }\n  function dbFmt(n){ if(n<=0.0001) return \"-INF\"; var db=20*Math.log10(n); return (db>=0?\"+\":\"\")+db.toFixed(1)+\"dB\"; }\n\n  var state = PARAMS.map(function(p){ return p.def; });\n  var lcd = {\n    name:document.getElementById('lcdName'), val:document.getElementById('lcdVal'),\n    bar:document.getElementById('lcdBar'), hint:document.getElementById('lcdHint'),\n    pg:document.getElementById('lcdPg'), wave:document.getElementById('lcdWave').querySelector('path')\n  };\n  var fmwire=document.getElementById('fmwire'), modBox=document.getElementById('modBox'),\n      carBox=document.getElementById('carBox'), fbk=document.getElementById('fbk'),\n      spark=document.getElementById('sparkA'), outNode=document.getElementById('outNode');\n\n  function nz(p,v){ return (v-p.min)/((p.max-p.min)||1); }\n  function send(p,v){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.index, v); }\n\n  // ---- LCD focus / live display ----\n  var focusIdx = 0;\n  function showLcd(i){\n    focusIdx=i; var p=PARAMS[i], v=state[i], n=nz(p,v);\n    lcd.name.textContent = p.name.toUpperCase();\n    lcd.val.textContent  = p.fmt(n);\n    lcd.bar.style.width  = (8+n*92)+\"%\";\n    lcd.hint.textContent = p.hint;\n    lcd.pg.textContent   = \"PG \"+(i+1)+\"/\"+PARAMS.length;\n  }\n\n  // ---- animated LCD waveform (reflects FMAmount + Brightness) ----\n  var t0=performance.now();\n  function lcdWaveTick(now){\n    var fm=nz(PARAMS[1],state[1]), br=nz(PARAMS[5],state[5]);\n    var ph=(now-t0)*0.004;\n    var pts=[], W=120,H=46;\n    for(var x=0;x<=W;x+=3){\n      var u=x/W;\n      // carrier + FM sideband richness driven by FMAmount & Brightness\n      var s = Math.sin(u*6.283*2 + ph)\n            + fm*0.9*Math.sin(u*6.283*2 + ph + 4*fm*Math.sin(u*6.283*2+ph))\n            + br*0.35*Math.sin(u*6.283*8 + ph*1.7);\n      var y = H/2 - s*(H*0.17);\n      pts.push(x.toFixed(0)+\" \"+y.toFixed(1));\n    }\n    lcd.wave.setAttribute('d','M'+pts.join(' L'));\n    requestAnimationFrame(lcdWaveTick);\n  }\n\n  // ---- algorithm diagram reacts to engine state ----\n  function refreshAlgo(){\n    var fm=nz(PARAMS[1],state[1]), ratio=nz(PARAMS[0],state[0]),\n        decay=nz(PARAMS[2],state[2]), bright=nz(PARAMS[5],state[5]);\n    // FM wire thickness + glow + flow speed = modulation index\n    fmwire.style.strokeWidth=(1.6+fm*3.4).toFixed(2);\n    fmwire.style.opacity=(0.25+fm*0.75).toFixed(2);\n    fmwire.style.animationDuration=(1.3-fm*0.9).toFixed(2)+\"s\";\n    fmwire.style.filter='drop-shadow(0 0 '+(2+fm*8).toFixed(1)+'px var(--ac))';\n    // modulator box lit by FM depth, carrier by brightness\n    modBox.setAttribute('class', fm>0.05?'op-lit':'op-box');\n    modBox.style.filter='drop-shadow(0 0 '+(fm*9).toFixed(1)+'px color-mix(in srgb,var(--ac) 70%,transparent))';\n    carBox.setAttribute('class','op-lit');\n    carBox.style.filter='drop-shadow(0 0 '+(3+bright*8).toFixed(1)+'px color-mix(in srgb,var(--ac) 70%,transparent))';\n    // feedback loop appears with high ratio\n    fbk.style.opacity=(0.15+ratio*0.85).toFixed(2);\n    fbk.style.animationDuration=(1.6-ratio*0.9).toFixed(2)+\"s\";\n    // out node pulse intensity by level\n    var lvl=nz(PARAMS[6],state[6]);\n    outNode.style.filter='drop-shadow(0 0 '+(2+lvl*8).toFixed(1)+'px var(--ac))';\n  }\n  // travelling spark riding the FM wire, paced by ModDecay\n  var sx=232, dir=1;\n  function sparkTick(now){\n    var decay=nz(PARAMS[2],state[2]), fm=nz(PARAMS[1],state[1]);\n    var speed=0.6+ (1-decay)*2.4; // faster decay -> faster bell flutter\n    sx += speed;\n    if(sx>322){ sx=232; }\n    spark.setAttribute('cx', sx.toFixed(1));\n    spark.style.opacity=(0.15+fm*0.85).toFixed(2);\n    spark.setAttribute('r',(2.2+fm*2.2).toFixed(1));\n    requestAnimationFrame(sparkTick);\n  }\n\n  // ---- build controls ----\n  var deck=document.getElementById('deck');\n  PARAMS.forEach(function(p,i){\n    var ctl=document.createElement('div');\n    ctl.className='ctl'+(p.type==='fader'?' fader':'');\n    ctl.style.setProperty('--d',(i*55)+'ms');\n\n    if(p.type==='fader'){\n      ctl.innerHTML=\n        '<div class=\"track\"><div class=\"fill\"></div><div class=\"cap\"></div></div>'+\n        '<div class=\"nm\">'+p.name+'</div><div class=\"vv\"></div>';\n    } else {\n      ctl.innerHTML=\n        '<div class=\"knob\"><div class=\"ring\"><div class=\"pip\"></div></div></div>'+\n        '<div class=\"nm\">'+p.name+'</div><div class=\"vv\"></div>';\n    }\n    deck.appendChild(ctl);\n\n    var vv=ctl.querySelector('.vv');\n    function paint(){\n      var n=nz(p,state[i]);\n      vv.textContent=p.fmt(n);\n      if(p.type==='fader'){\n        ctl.querySelector('.fill').style.height=(n*100)+'%';\n        ctl.querySelector('.cap').style.top=((1-n)*100)+'%';\n      } else {\n        var k=ctl.querySelector('.knob');\n        k.style.setProperty('--n', n);\n      }\n      if(focusIdx===i) showLcd(i);\n      refreshAlgo();\n    }\n    function set(n){\n      n=n<0?0:(n>1?1:n);\n      state[i]=p.min+(p.max-p.min)*n;\n      paint(); send(p,state[i]);\n    }\n    function reset(){ state[i]=p.def; paint(); send(p,state[i]); }\n\n    // pointer drag (vertical) for both knob and fader\n    var grip = p.type==='fader' ? ctl.querySelector('.track') : ctl.querySelector('.knob');\n    var dragY=0, dragN=0, dragging=false;\n    grip.addEventListener('pointerdown',function(e){\n      dragging=true; dragY=e.clientY; dragN=nz(p,state[i]);\n      grip.classList.add('act'); if(grip.classList.contains('knob')) grip.classList.add('live');\n      grip.setPointerCapture(e.pointerId); showLcd(i); e.preventDefault();\n    });\n    grip.addEventListener('pointermove',function(e){\n      if(!dragging)return;\n      set(dragN + (dragY-e.clientY)/180);\n    });\n    function end(){ dragging=false; grip.classList.remove('act'); grip.classList.remove('live'); }\n    grip.addEventListener('pointerup',end);\n    grip.addEventListener('pointercancel',end);\n    grip.addEventListener('dblclick',reset);\n    grip.addEventListener('wheel',function(e){\n      e.preventDefault(); showLcd(i);\n      set(nz(p,state[i]) + (e.deltaY<0?0.03:-0.03));\n    },{passive:false});\n    grip.addEventListener('pointerenter',function(){ showLcd(i); });\n\n    p._paint=paint;\n  });\n\n  function ready(){\n    PARAMS.forEach(function(p,i){ p._paint(); send(p, state[i]); });\n    showLcd(0);\n    refreshAlgo();\n    requestAnimationFrame(lcdWaveTick);\n    requestAnimationFrame(sparkTick);\n  }\n\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  FM TINES — bright FM electric-piano / bell synth\n//  A polyphonic 2-operator phase-modulation engine: a modulator operator\n//  phase-modulates a carrier, with a fast-decaying modulation-index\n//  envelope that gives the classic struck-tine \"bell\" attack that mellows\n//  into a pure sine body. A per-voice amp envelope (attack + exponential\n//  decay/release) and a one-pole brightness tilt finish the tone.\n//  Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_VOICES: i32 = 16;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831853071795864769;\n\n// ---- per-voice state (parallel StaticArrays, no allocation in process) ----\nconst vActive:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = in use\nconst vGate:     StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = key held\nconst vNote:     StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // note id\nconst vCarPh:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // carrier phase (radians)\nconst vModPh:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // modulator phase (radians)\nconst vFreq:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // carrier Hz\nconst vVel:      StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // 0..1\nconst vAmp:      StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // current amp-env level\nconst vIdxEnv:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // current mod-index env (0..1)\nconst vAge:      StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // for voice-steal LRU\nconst vTilt:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // brightness one-pole state\n\nlet ageCounter: f32 = 0.0;\n\n// ---- parameter indices (MUST match spec.json) ----\nconst P_RATIO:    i32 = 0; // modulator:carrier frequency ratio  (0.5 .. 14)\nconst P_FMAMOUNT: i32 = 1; // modulation index depth             (0 .. 1)\nconst P_MODDECAY: i32 = 2; // mod-index env decay time           (0 .. 1)\nconst P_ATTACK:   i32 = 3; // amp attack                         (0 .. 1)\nconst P_RELEASE:  i32 = 4; // amp decay/release                  (0 .. 1)\nconst P_BRIGHT:   i32 = 5; // brightness tilt                    (0 .. 1)\nconst P_LEVEL:    i32 = 6; // output level                       (0 .. 1)\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    vCarPh[v] = 0.0; vModPh[v] = 0.0; vFreq[v] = 0.0;\n    vVel[v] = 0.0; vAmp[v] = 0.0; vIdxEnv[v] = 0.0; vAge[v] = 0.0; vTilt[v] = 0.0;\n  }\n  ageCounter = 0.0;\n  params[P_RATIO]    = 0.5;   // -> ~3.5 ratio area (bell/tine sweet spot)\n  params[P_FMAMOUNT] = 0.55;\n  params[P_MODDECAY] = 0.45;\n  params[P_ATTACK]   = 0.04;\n  params[P_RELEASE]  = 0.55;\n  params[P_BRIGHT]   = 0.6;\n  params[P_LEVEL]    = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- note handling: find a free (or oldest) voice ----\nexport function noteOn(id: i32, freq: f32, velocity: f32): void {\n  if (freq <= 0.0) freq = 1.0;\n  // reuse a voice already playing this id, else a free slot, else steal oldest\n  let slot: i32 = -1;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) { slot = v; break; }\n  }\n  if (slot < 0) {\n    for (let v = 0; v < MAX_VOICES; v++) {\n      if (vActive[v] == 0) { slot = v; break; }\n    }\n  }\n  if (slot < 0) {\n    let oldest: f32 = vAge[0]; slot = 0;\n    for (let v = 1; v < MAX_VOICES; v++) {\n      if (vAge[v] < oldest) { oldest = vAge[v]; slot = v; }\n    }\n  }\n  ageCounter += 1.0;\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vNote[slot]   = id;\n  vFreq[slot]   = freq;\n  vVel[slot]    = clampf(velocity, 0.0, 1.0);\n  vCarPh[slot]  = 0.0;\n  vModPh[slot]  = 0.0;\n  vAmp[slot]    = 0.0;\n  vIdxEnv[slot] = 1.0;   // index env starts bright, then decays\n  vAge[slot]    = ageCounter;\n  vTilt[slot]   = 0.0;\n}\n\nexport function noteOff(id: i32): void {\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) vGate[v] = 0;\n  }\n}\n\nexport function process(n: i32): void {\n  // ---- resolve params once per block ----\n  const ratio: f32    = 0.5 + clampf(params[P_RATIO], 0.0, 1.0) * 13.5;        // 0.5 .. 14\n  const fmAmt: f32     = clampf(params[P_FMAMOUNT], 0.0, 1.0);\n  const modDecayN: f32 = clampf(params[P_MODDECAY], 0.0, 1.0);\n  const attackN: f32   = clampf(params[P_ATTACK], 0.0, 1.0);\n  const releaseN: f32  = clampf(params[P_RELEASE], 0.0, 1.0);\n  const brightN: f32   = clampf(params[P_BRIGHT], 0.0, 1.0);\n  const level: f32     = clampf(params[P_LEVEL], 0.0, 1.0) * 0.85;\n\n  // modulation index depth: scale so timbre clearly opens up with FMAmount\n  const peakIndex: f32 = fmAmt * 9.0;\n\n  // mod-index env decay: 30 ms (snappy bell) .. 2.5 s (slow chime)\n  const idxDecaySec: f32 = 0.03 + modDecayN * modDecayN * 2.47;\n  const idxDecayCoef: f32 = f32(Mathf.exp(-1.0 / (idxDecaySec * sampleRate)));\n\n  // amp attack: 1 ms .. 250 ms (one-pole rise toward velocity)\n  const attackSec: f32 = 0.001 + attackN * attackN * 0.249;\n  const attackCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (attackSec * sampleRate)));\n\n  // amp decay (while held) and release (after note-off).\n  // Electric-piano body: held notes ring out and fade; longer with Release.\n  const relSec: f32 = 0.08 + releaseN * releaseN * 5.0;          // 80 ms .. ~5 s\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relSec * sampleRate)));\n  // sustained decay is a gentle fraction of release so held tines slowly fade\n  const decSec: f32 = relSec * 3.0;\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / (decSec * sampleRate)));\n\n  // brightness tilt: low-pass that opens with brightN (1.5 kHz .. ~18 kHz)\n  let cutHz: f32 = 1500.0 + brightN * brightN * 16500.0;\n  if (cutHz > sampleRate * 0.45) cutHz = sampleRate * 0.45;\n  let tiltCoef: f32 = f32(1.0 - Mathf.exp(-TWO_PI * cutHz / sampleRate));\n  tiltCoef = clampf(tiltCoef, 0.0, 1.0);\n  // mix the tilt in: at high brightness pass more of the raw (bright) signal\n  const tiltMix: f32 = 0.25 + brightN * 0.75;\n\n  const invSr: f32 = 1.0 / sampleRate;\n\n  // ---- clear output block ----\n  for (let f = 0; f < n; f++) {\n    outBuf[f] = 0.0;\n    outBuf[MAX_FRAMES + f] = 0.0;\n  }\n\n  // ---- render each active voice (mono sum, copied to both channels) ----\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] == 0) continue;\n\n    const f0: f32 = vFreq[v];\n    const carInc: f32 = TWO_PI * f0 * invSr;\n    const modInc: f32 = TWO_PI * f0 * ratio * invSr;\n    const vel: f32 = vVel[v];\n    const ampTarget: f32 = vel;          // attack rises to velocity\n    const gate: i32 = vGate[v];\n\n    let carPh: f32 = vCarPh[v];\n    let modPh: f32 = vModPh[v];\n    let amp: f32 = vAmp[v];\n    let idxEnv: f32 = vIdxEnv[v];\n    let tilt: f32 = vTilt[v];\n    let reachedAttack: bool = amp >= ampTarget * 0.999 || ampTarget <= 0.0001;\n\n    for (let f = 0; f < n; f++) {\n      // mod-index envelope: decays from 1 toward 0\n      idxEnv *= idxDecayCoef;\n      const index: f32 = peakIndex * idxEnv;\n\n      // amp envelope: attack to velocity, then decay (held) / release (off)\n      if (gate != 0 && !reachedAttack) {\n        amp += attackCoef * (ampTarget - amp);\n        if (amp >= ampTarget * 0.999) { amp = ampTarget; reachedAttack = true; }\n      } else if (gate != 0) {\n        amp *= decCoef;     // held: slow electric-piano decay\n      } else {\n        amp *= relCoef;     // released: faster fade\n      }\n\n      // 2-operator FM: modulator sine phase-modulates the carrier\n      const modOut: f32 = Mathf.sin(modPh) * index;\n      let s: f32 = Mathf.sin(carPh + modOut);\n\n      // velocity scales brightness a touch (harder hits = more index already)\n      s *= amp;\n\n      // brightness tilt (one-pole LP) mixed with raw for an airy top\n      tilt += tiltCoef * (s - tilt);\n      const shaped: f32 = tilt + (s - tilt) * tiltMix;\n\n      outBuf[f] += shaped;\n\n      carPh += carInc; if (carPh >= TWO_PI) carPh -= TWO_PI;\n      modPh += modInc; if (modPh >= TWO_PI) modPh -= TWO_PI;\n    }\n\n    vCarPh[v] = carPh;\n    vModPh[v] = modPh;\n    vAmp[v] = amp;\n    vIdxEnv[v] = idxEnv;\n    vTilt[v] = tilt;\n\n    // retire voice once it has faded out and the key is released\n    if (gate == 0 && amp < 0.00008) {\n      vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    }\n  }\n\n  // ---- output level + soft safety limit, copy mono to stereo ----\n  for (let f = 0; f < n; f++) {\n    let s: f32 = outBuf[f] * level;\n    // gentle soft clip keeps dense chords < 1.0 without audible harshness\n    if (s > 1.2) s = 1.2; else if (s < -1.2) s = -1.2;\n    s = f32(s - 0.16666667 * s * s * s);\n    outBuf[f] = s;\n    outBuf[MAX_FRAMES + f] = s;\n  }\n}\n",
  "publishedAt": 1751000019000
}