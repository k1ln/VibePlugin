{
  "format": 1,
  "name": "Pin Matrix",
  "isInstrument": true,
  "explanation": "An eccentric British-modular mono/paraphonic synth instrument. Three free-running oscillators (saw, triangle, pulse) feed a ring modulator that multiplies two of them for clangy, inharmonic metallic tones, then a diode-ladder resonant low-pass that self-oscillates, all shaped by a snappy trapezoid-style envelope. Osc Mix crossfades saw against pulse over a triangle bed; Ring Mod sweeps in the bell-like inharmonic content; Cutoff and Resonance sweep and ring the filter toward self-oscillation; Env Amount and Decay drive the trapezoid's bite; pitch tracks the played note and the signal stays bounded by soft saturation.",
  "params": [
    {
      "name": "Osc Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Ring Mod",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Cutoff",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Env Amount",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pin Matrix</title>\n<style>\n  :root {\n    --accent:  #6ad0ff;\n    --accent2: #ff7a7a;\n    --teal:    #1f6e6a;\n    --teal-d:  #0f3b3a;\n    --panel:   #173436;\n    --panel-d: #0c2122;\n    --ivory:   #e9e3d2;\n    --ink:     #07181a;\n    --pin-off: #2a4d4e;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #1a4042 0%, #0a1b1c 60%, #050d0e 100%);\n    color: var(--ivory);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    min-height: 100%;\n  }\n\n  .wrap {\n    max-width: 900px;\n    margin: 0 auto;\n    padding: 16px 16px 28px;\n  }\n\n  /* ---- the enclosure ---- */\n  .enclosure {\n    position: relative;\n    border-radius: 18px;\n    padding: 18px;\n    background:\n      linear-gradient(180deg, #235c5b 0%, #16403f 38%, #102f2e 100%);\n    box-shadow:\n      inset 0 2px 0 rgba(255,255,255,0.12),\n      inset 0 -10px 26px rgba(0,0,0,0.55),\n      0 26px 60px rgba(0,0,0,0.6),\n      0 2px 0 rgba(0,0,0,0.4);\n    border: 1px solid #0a2322;\n    overflow: hidden;\n  }\n  /* corner screws */\n  .screw {\n    position: absolute;\n    width: 13px; height: 13px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #c9c2ad, #5b5747 70%, #2e2b22);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,0.5), 0 1px 2px rgba(0,0,0,0.6);\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute; inset: 4px 2px;\n    border-radius: 1px;\n    background: rgba(40,38,30,0.8);\n    transform: rotate(35deg);\n  }\n  .screw.tl { top: 8px; left: 8px; }\n  .screw.tr { top: 8px; right: 8px; }\n  .screw.bl { bottom: 8px; left: 8px; }\n  .screw.br { bottom: 8px; right: 8px; }\n\n  /* ---- header ---- */\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    margin: 2px 8px 14px;\n    flex-wrap: wrap;\n  }\n  .brand { display: flex; align-items: baseline; gap: 12px; }\n  .logo-dot {\n    width: 14px; height: 14px; border-radius: 50%;\n    background: var(--accent2);\n    box-shadow: 0 0 10px var(--accent2);\n    align-self: center;\n    animation: pwr 2.4s ease-in-out infinite;\n  }\n  @keyframes pwr {\n    0%, 100% { opacity: 0.5; box-shadow: 0 0 6px var(--accent2); }\n    50%      { opacity: 1;   box-shadow: 0 0 16px var(--accent2); }\n  }\n  h1 {\n    font-size: clamp(20px, 4vw, 30px);\n    margin: 0;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    font-weight: 800;\n    color: var(--ivory);\n    text-shadow: 0 1px 0 #000, 0 0 16px rgba(106,208,255,0.25);\n  }\n  .sub {\n    font-size: 10px;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--accent);\n    opacity: 0.85;\n  }\n  .plate {\n    font-size: 9px;\n    letter-spacing: 0.3em;\n    text-transform: uppercase;\n    color: #9fc7c4;\n    padding: 6px 10px;\n    border: 1px solid rgba(106,208,255,0.25);\n    border-radius: 6px;\n    background: rgba(0,0,0,0.25);\n    text-align: right;\n    line-height: 1.5;\n  }\n\n  /* ---- main layout ---- */\n  .body {\n    display: grid;\n    grid-template-columns: minmax(280px, 1.4fr) minmax(180px, 0.9fr);\n    gap: 16px;\n  }\n  @media (max-width: 720px) {\n    .body { grid-template-columns: 1fr; }\n  }\n\n  .module {\n    background:\n      linear-gradient(180deg, rgba(8,24,26,0.9), rgba(4,14,15,0.95));\n    border: 1px solid rgba(106,208,255,0.12);\n    border-radius: 12px;\n    padding: 14px;\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06), inset 0 -8px 18px rgba(0,0,0,0.5);\n  }\n  .module h2 {\n    margin: 0 0 12px;\n    font-size: 10px;\n    letter-spacing: 0.34em;\n    text-transform: uppercase;\n    color: #7fb6b3;\n    display: flex; align-items: center; gap: 8px;\n  }\n  .module h2::before {\n    content: \"\";\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 8px var(--accent);\n  }\n\n  /* ---- the PIN PATCH MATRIX ---- */\n  .matrix-wrap { display: flex; flex-direction: column; align-items: center; gap: 10px; }\n  .matrix {\n    background:\n      radial-gradient(140% 120% at 50% 0%, #14373a 0%, #0a2123 70%, #061516 100%);\n    border-radius: 10px;\n    padding: 12px;\n    border: 1px solid rgba(0,0,0,0.55);\n    box-shadow: inset 0 0 24px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.05);\n  }\n  .matrix svg { display: block; width: 100%; height: auto; }\n\n  .axis-label {\n    fill: #8fb9b6;\n    font-size: 7px;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    font-family: ui-sans-serif, system-ui, sans-serif;\n  }\n\n  .pin {\n    cursor: pointer;\n    transition: filter 0.15s ease;\n  }\n  .pin:hover { filter: brightness(1.4); }\n\n  .hint {\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: #6e9794;\n  }\n\n  /* ---- knobs ---- */\n  .knob-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(86px, 1fr));\n    gap: 12px 8px;\n  }\n  .knob {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n    user-select: none;\n  }\n  .knob svg { width: 64px; height: 64px; cursor: ns-resize; touch-action: none; }\n  .knob .name {\n    font-size: 9px;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: #a9d4d1;\n    text-align: center;\n  }\n  .knob .val {\n    font-size: 10px;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent);\n    letter-spacing: 0.04em;\n    min-height: 13px;\n  }\n\n  /* ---- joystick ---- */\n  .joy-wrap { display: flex; flex-direction: column; align-items: center; gap: 10px; }\n  .joy {\n    position: relative;\n    width: 132px; height: 132px;\n    border-radius: 14px;\n    background:\n      radial-gradient(circle at 50% 42%, #11393b 0%, #0a2425 60%, #061617 100%);\n    border: 1px solid rgba(0,0,0,0.6);\n    box-shadow: inset 0 0 26px rgba(0,0,0,0.7), inset 0 1px 0 rgba(255,255,255,0.06);\n    touch-action: none;\n    cursor: grab;\n    overflow: hidden;\n  }\n  .joy.grabbing { cursor: grabbing; }\n  .joy .cross-h, .joy .cross-v {\n    position: absolute;\n    background: rgba(106,208,255,0.12);\n  }\n  .joy .cross-h { left: 8%; right: 8%; top: 50%; height: 1px; }\n  .joy .cross-v { top: 8%; bottom: 8%; left: 50%; width: 1px; }\n  .joy .ring {\n    position: absolute; inset: 14px;\n    border-radius: 50%;\n    border: 1px dashed rgba(255,122,122,0.18);\n  }\n  .joy .stick {\n    position: absolute;\n    left: 50%; top: 50%;\n    width: 34px; height: 34px;\n    margin: -17px 0 0 -17px;\n    border-radius: 50%;\n    background:\n      radial-gradient(circle at 38% 32%, #ff9d9d, #ff7a7a 45%, #b53d3d 80%, #6e2222);\n    box-shadow:\n      0 0 0 4px rgba(255,122,122,0.12),\n      0 6px 14px rgba(0,0,0,0.6),\n      inset 0 2px 3px rgba(255,255,255,0.5);\n    transition: box-shadow 0.15s ease;\n  }\n  .joy .stick.lit { box-shadow: 0 0 22px rgba(255,122,122,0.7), 0 6px 14px rgba(0,0,0,0.6), inset 0 2px 3px rgba(255,255,255,0.5); }\n\n  /* ---- keyboard ---- */\n  .keys-module { margin-top: 16px; }\n  .keys {\n    position: relative;\n    display: flex;\n    height: 108px;\n    border-radius: 8px;\n    overflow: hidden;\n    border: 1px solid #06181a;\n    box-shadow: 0 8px 18px rgba(0,0,0,0.5), inset 0 -6px 12px rgba(0,0,0,0.4);\n    user-select: none;\n    touch-action: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    background: linear-gradient(180deg, #f4eedd 0%, #d8cfb6 100%);\n    border-right: 1px solid #b3a98c;\n    border-radius: 0 0 5px 5px;\n    cursor: pointer;\n    transition: background 0.06s ease;\n  }\n  .wkey:last-child { border-right: none; }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #3f9bc4 100%);\n    box-shadow: inset 0 4px 8px rgba(0,0,0,0.3);\n  }\n  .bkeys { position: absolute; top: 0; left: 0; right: 0; height: 64%; pointer-events: none; }\n  .bkey {\n    position: absolute;\n    width: 5.2%;\n    height: 100%;\n    margin-left: -2.6%;\n    background: linear-gradient(180deg, #16292b 0%, #06141500 100%), linear-gradient(180deg, #1d3537, #07191a);\n    border-radius: 0 0 4px 4px;\n    box-shadow: 0 4px 6px rgba(0,0,0,0.6), inset 0 -3px 4px rgba(0,0,0,0.5);\n    cursor: pointer;\n    pointer-events: auto;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, #ff7a7a, #b53d3d);\n    box-shadow: 0 0 14px rgba(255,122,122,0.6);\n  }\n\n  .footer {\n    margin: 14px 8px 0;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 9px;\n    letter-spacing: 0.24em;\n    text-transform: uppercase;\n    color: #5e8482;\n  }\n  .footer .meter {\n    width: 120px; height: 6px;\n    border-radius: 3px;\n    background: rgba(0,0,0,0.4);\n    overflow: hidden;\n    border: 1px solid rgba(106,208,255,0.15);\n  }\n  .footer .meter span {\n    display: block; height: 100%; width: 0%;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    transition: width 0.07s linear;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"enclosure\">\n    <div class=\"screw tl\"></div><div class=\"screw tr\"></div>\n    <div class=\"screw bl\"></div><div class=\"screw br\"></div>\n\n    <header>\n      <div class=\"brand\">\n        <span class=\"logo-dot\"></span>\n        <div>\n          <h1>Pin Matrix</h1>\n          <div class=\"sub\">Patch &nbsp;Synthesiser</div>\n        </div>\n      </div>\n      <div class=\"plate\">Model PM&middot;3<br>Mono / Paraphonic</div>\n    </header>\n\n    <div class=\"body\">\n      <!-- LEFT: the iconic pin patch matrix -->\n      <div class=\"module\">\n        <h2>Pin Patch Matrix</h2>\n        <div class=\"matrix-wrap\">\n          <div class=\"matrix\">\n            <svg id=\"matrixSvg\" viewBox=\"0 0 260 220\" aria-label=\"patch matrix\"></svg>\n          </div>\n          <div class=\"hint\">Click a hole to seat / pull a routing pin</div>\n        </div>\n      </div>\n\n      <!-- RIGHT: joystick + voice tone -->\n      <div class=\"module\">\n        <h2>Control Stick</h2>\n        <div class=\"joy-wrap\">\n          <div class=\"joy\" id=\"joy\">\n            <div class=\"cross-h\"></div>\n            <div class=\"cross-v\"></div>\n            <div class=\"ring\"></div>\n            <div class=\"stick\" id=\"stick\"></div>\n          </div>\n          <div class=\"hint\">X &rarr; Cutoff &nbsp;&middot;&nbsp; Y &rarr; Ring Mod</div>\n        </div>\n      </div>\n    </div>\n\n    <!-- KNOB BANK -->\n    <div class=\"module keys-module\">\n      <h2>Voice</h2>\n      <div class=\"knob-grid\" id=\"knobBank\"></div>\n    </div>\n\n    <!-- KEYBOARD -->\n    <div class=\"module keys-module\">\n      <h2>Keyboard</h2>\n      <div class=\"keys\" id=\"keys\">\n        <div class=\"bkeys\" id=\"bkeys\"></div>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <span>EMS-lineage &middot; Ring &middot; Diode Ladder</span>\n      <div class=\"meter\"><span id=\"meterBar\"></span></div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host bridge ---------------------------------------------------\n  var bridge = {\n    setParam: function (i, v) { if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v); },\n    noteOn:   function (n, v) { if (window.vstai && window.vstai.noteOn)  window.vstai.noteOn(n, v); },\n    noteOff:  function (n)    { if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n); }\n  };\n\n  // ---- parameter model ----------------------------------------------\n  // index, name, default. All ranges are 0..1.\n  var PARAMS = [\n    { index: 0, name: \"Osc Mix\",   def: 0.5  },\n    { index: 1, name: \"Ring Mod\",  def: 0.45 },\n    { index: 2, name: \"Cutoff\",    def: 0.5  },\n    { index: 3, name: \"Resonance\", def: 0.55 },\n    { index: 4, name: \"Env Amount\",def: 0.7  },\n    { index: 5, name: \"Decay\",     def: 0.45 },\n    { index: 6, name: \"Level\",     def: 0.7  }\n  ];\n  var values = {};         // index -> current 0..1 value\n  var knobEls = {};        // index -> { update() }\n\n  function pushParam(index, v) {\n    v = Math.max(0, Math.min(1, v));\n    values[index] = v;\n    bridge.setParam(index, v);\n    if (knobEls[index]) knobEls[index].update();\n  }\n\n  // ===================================================================\n  //  KNOBS (hand-drawn SVG, drag-vertical, dblclick reset, wheel fine)\n  // ===================================================================\n  var SVGNS = \"http://www.w3.org/2000/svg\";\n  function el(tag, attrs) {\n    var e = document.createElementNS(SVGNS, tag);\n    for (var k in attrs) e.setAttribute(k, attrs[k]);\n    return e;\n  }\n\n  function buildKnob(p) {\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"knob\";\n\n    var svg = document.createElementNS(SVGNS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 64 64\");\n\n    // outer well\n    svg.appendChild(el(\"circle\", { cx: 32, cy: 32, r: 27, fill: \"#0a1c1d\", stroke: \"#04100f\", \"stroke-width\": 2 }));\n    // track arc background\n    var A0 = 135, A1 = 405; // degrees (sweep 270)\n    function polar(deg, r) {\n      var a = (deg - 90) * Math.PI / 180;\n      return [32 + r * Math.cos(a), 32 + r * Math.sin(a)];\n    }\n    function arcPath(fromDeg, toDeg, r) {\n      var s = polar(fromDeg, r), e2 = polar(toDeg, r);\n      var large = (toDeg - fromDeg) > 180 ? 1 : 0;\n      return \"M \" + s[0] + \" \" + s[1] + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + e2[0] + \" \" + e2[1];\n    }\n    var bg = el(\"path\", { d: arcPath(A0, A1, 23), fill: \"none\", stroke: \"#16383a\", \"stroke-width\": 3.5, \"stroke-linecap\": \"round\" });\n    svg.appendChild(bg);\n    var arc = el(\"path\", { fill: \"none\", stroke: \"var(--accent)\", \"stroke-width\": 3.5, \"stroke-linecap\": \"round\" });\n    arc.style.filter = \"drop-shadow(0 0 4px var(--accent))\";\n    svg.appendChild(arc);\n\n    // knob body\n    var body = el(\"circle\", { cx: 32, cy: 32, r: 18, fill: \"url(#kbody\" + p.index + \")\", stroke: \"#05201f\", \"stroke-width\": 1 });\n    var defs = el(\"defs\", {});\n    var grad = el(\"radialGradient\", { id: \"kbody\" + p.index, cx: \"38%\", cy: \"30%\", r: \"75%\" });\n    grad.appendChild(el(\"stop\", { offset: \"0%\", \"stop-color\": \"#3b6e6c\" }));\n    grad.appendChild(el(\"stop\", { offset: \"60%\", \"stop-color\": \"#1d4544\" }));\n    grad.appendChild(el(\"stop\", { offset: \"100%\", \"stop-color\": \"#0c2625\" }));\n    defs.appendChild(grad);\n    svg.appendChild(defs);\n    svg.appendChild(body);\n\n    // pointer notch\n    var notch = el(\"line\", { x1: 32, y1: 32, x2: 32, y2: 17, stroke: \"var(--accent2)\", \"stroke-width\": 2.5, \"stroke-linecap\": \"round\" });\n    notch.style.filter = \"drop-shadow(0 0 3px var(--accent2))\";\n    svg.appendChild(notch);\n    svg.appendChild(el(\"circle\", { cx: 32, cy: 32, r: 2.2, fill: \"#e9e3d2\" }));\n\n    wrap.appendChild(svg);\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\"; name.textContent = p.name;\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n    wrap.appendChild(name);\n    wrap.appendChild(val);\n\n    function update() {\n      var v = values[p.index];\n      var deg = A0 + (A1 - A0) * v;\n      arc.setAttribute(\"d\", arcPath(A0, deg, 23));\n      var pt = polar(deg, 14);\n      notch.setAttribute(\"x2\", pt[0]);\n      notch.setAttribute(\"y2\", pt[1]);\n      val.textContent = Math.round(v * 100) + \"%\";\n    }\n\n    // interactions\n    var dragging = false, lastY = 0;\n    svg.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; lastY = e.clientY;\n      svg.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    svg.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.clientY;\n      lastY = e.clientY;\n      pushParam(p.index, values[p.index] + dy * 0.005);\n    });\n    svg.addEventListener(\"pointerup\", function (e) { dragging = false; });\n    svg.addEventListener(\"pointercancel\", function () { dragging = false; });\n    svg.addEventListener(\"dblclick\", function () { pushParam(p.index, p.def); });\n    svg.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      pushParam(p.index, values[p.index] - Math.sign(e.deltaY) * 0.02);\n    }, { passive: false });\n\n    knobEls[p.index] = { update: update };\n    return wrap;\n  }\n\n  var bank = document.getElementById(\"knobBank\");\n  PARAMS.forEach(function (p) {\n    values[p.index] = p.def;\n    bank.appendChild(buildKnob(p));\n  });\n\n  // ===================================================================\n  //  PIN PATCH MATRIX  (decorative routing grid that pulses with audio)\n  // ===================================================================\n  var ROWS = [\"OSC 1\", \"OSC 2\", \"OSC 3\", \"RING\", \"NOISE\", \"FILTER\"];\n  var COLS = [\"RING\", \"FILT\", \"ENV\", \"AMP\", \"OUT\"];\n  var matrix = document.getElementById(\"matrixSvg\");\n  var GX = 70, GY = 26, CW = 38, CH = 30;\n  var pins = []; // { circle, glow, on, row, col, base }\n\n  // pre-seated pins (the patch that matches the default sound)\n  var seeded = { \"0-0\": 1, \"1-0\": 1, \"3-1\": 1, \"0-2\": 1, \"5-2\": 1, \"5-3\": 1, \"4-3\": 1, \"0-4\": 1, \"2-4\": 1 };\n\n  // column labels\n  COLS.forEach(function (c, j) {\n    var t = el(\"text\", { x: GX + j * CW + CW / 2, y: 16, \"text-anchor\": \"middle\", \"class\": \"axis-label\" });\n    t.textContent = c;\n    matrix.appendChild(t);\n  });\n  // row labels + holes\n  ROWS.forEach(function (r, i) {\n    var t = el(\"text\", { x: GX - 8, y: GY + i * CH + CH / 2 + 3, \"text-anchor\": \"end\", \"class\": \"axis-label\" });\n    t.textContent = r;\n    matrix.appendChild(t);\n\n    COLS.forEach(function (c, j) {\n      var cx = GX + j * CW + CW / 2;\n      var cy = GY + i * CH + CH / 2;\n      // hole\n      matrix.appendChild(el(\"circle\", { cx: cx, cy: cy, r: 7, fill: \"#06181a\", stroke: \"#0c2b2c\", \"stroke-width\": 1.5 }));\n      // glow halo (animated)\n      var glow = el(\"circle\", { cx: cx, cy: cy, r: 7, fill: \"none\", stroke: \"var(--accent)\", \"stroke-width\": 0, opacity: 0 });\n      matrix.appendChild(glow);\n      // the pin itself\n      var key = i + \"-\" + j;\n      var on = !!seeded[key];\n      var fill = (j === 0 || i === 3) ? \"var(--accent2)\" : \"var(--accent)\";\n      var pin = el(\"circle\", { cx: cx, cy: cy, r: 5, \"class\": \"pin\",\n        fill: on ? fill : \"var(--pin-off)\" });\n      pin.dataset.key = key;\n      matrix.appendChild(pin);\n\n      var rec = { circle: pin, glow: glow, on: on, row: i, col: j, fill: fill };\n      pins.push(rec);\n      pin.addEventListener(\"click\", function () {\n        rec.on = !rec.on;\n        pin.setAttribute(\"fill\", rec.on ? rec.fill : \"var(--pin-off)\");\n        recomputeMatrix();\n      });\n    });\n  });\n\n  // The matrix is a REAL patch router: each destination COLUMN sums the\n  // sources seated into it and drives a live parameter, so seating / pulling\n  // pins genuinely reshapes the sound (not just a light show).\n  function recomputeMatrix() {\n    var c0 = 0, c1 = 0, c2 = 0, c3 = 0, o1 = false, o2 = false, o3 = false;\n    for (var q = 0; q < pins.length; q++) {\n      var r = pins[q]; if (!r.on) continue;\n      if (r.col === 0) c0++; else if (r.col === 1) c1++;\n      else if (r.col === 2) c2++; else if (r.col === 3) c3++;\n      else if (r.col === 4) { if (r.row === 0) o1 = true; else if (r.row === 1) o2 = true; else if (r.row === 2) o3 = true; }\n    }\n    pushParam(1, Math.min(1, 0.05 + c0 * 0.30));   // RING column -> Ring Mod\n    pushParam(3, Math.min(1, 0.30 + c1 * 0.18));   // FILT column -> Resonance\n    pushParam(4, Math.min(1, 0.15 + c2 * 0.28));   // ENV  column -> Env Amount\n    pushParam(6, Math.min(1, 0.35 + c3 * 0.22));   // AMP  column -> Level\n    pushParam(0, Math.max(0, Math.min(1, 0.5 + (o3 ? 0.30 : 0) - (o1 ? 0.30 : 0) - (o2 ? 0.15 : 0)))); // OUT -> Osc Mix\n  }\n\n  // ===================================================================\n  //  JOYSTICK  -> Cutoff (X) + Ring Mod (Y)\n  // ===================================================================\n  var joy = document.getElementById(\"joy\");\n  var stick = document.getElementById(\"stick\");\n  var joyDrag = false;\n\n  function placeStick() {\n    // reflect current Cutoff/RingMod onto the stick position\n    var x = values[2];       // 0..1\n    var y = values[1];       // 0..1\n    var px = (x - 0.5) * 0.78;   // -0.39..0.39 of half-size\n    var py = (0.5 - y) * 0.78;\n    stick.style.transform = \"translate(\" + (px * 132) + \"px,\" + (py * 132) + \"px)\";\n  }\n  function joyTo(clientX, clientY) {\n    var r = joy.getBoundingClientRect();\n    var nx = (clientX - r.left) / r.width;   // 0..1\n    var ny = (clientY - r.top) / r.height;   // 0..1\n    pushParam(2, Math.max(0, Math.min(1, nx)));         // cutoff\n    pushParam(1, Math.max(0, Math.min(1, 1 - ny)));     // ring mod\n    placeStick();\n  }\n  joy.addEventListener(\"pointerdown\", function (e) {\n    joyDrag = true; joy.classList.add(\"grabbing\"); stick.classList.add(\"lit\");\n    joy.setPointerCapture(e.pointerId);\n    joyTo(e.clientX, e.clientY);\n  });\n  joy.addEventListener(\"pointermove\", function (e) { if (joyDrag) joyTo(e.clientX, e.clientY); });\n  joy.addEventListener(\"pointerup\", function () { joyDrag = false; joy.classList.remove(\"grabbing\"); stick.classList.remove(\"lit\"); });\n  joy.addEventListener(\"pointercancel\", function () { joyDrag = false; joy.classList.remove(\"grabbing\"); stick.classList.remove(\"lit\"); });\n  joy.addEventListener(\"dblclick\", function () { pushParam(2, 0.5); pushParam(1, 0.45); placeStick(); });\n\n  // ===================================================================\n  //  KEYBOARD  (two octaves from C3) -> noteOn / noteOff\n  // ===================================================================\n  var keys = document.getElementById(\"keys\");\n  var bkeys = document.getElementById(\"bkeys\");\n  var START = 48;                       // C3\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 }; // white-index -> black semitone\n  var OCTAVES = 2;\n  var down = {};                        // midi -> el\n\n  var whiteList = [];\n  for (var o = 0; o < OCTAVES; o++) {\n    for (var w = 0; w < 7; w++) {\n      var midi = START + o * 12 + WHITE[w];\n      var k = document.createElement(\"div\");\n      k.className = \"wkey\";\n      k.dataset.midi = midi;\n      keys.appendChild(k);\n      whiteList.push({ el: k, midi: midi });\n    }\n  }\n  // place black keys over the gaps\n  var totalWhite = OCTAVES * 7;\n  for (var o2 = 0; o2 < OCTAVES; o2++) {\n    for (var wi in BLACK) {\n      wi = +wi;\n      var whiteIdx = o2 * 7 + wi;\n      var midiB = START + o2 * 12 + BLACK[wi];\n      var b = document.createElement(\"div\");\n      b.className = \"bkey\";\n      b.dataset.midi = midiB;\n      b.style.left = ((whiteIdx + 1) / totalWhite * 100) + \"%\";\n      bkeys.appendChild(b);\n    }\n  }\n\n  function keyDown(elm) {\n    var midi = +elm.dataset.midi;\n    if (down[midi]) return;\n    down[midi] = elm;\n    elm.classList.add(\"down\");\n    bridge.noteOn(midi, 0.9);\n    flashMatrix();\n  }\n  function keyUp(midi) {\n    if (!down[midi]) return;\n    down[midi].classList.remove(\"down\");\n    delete down[midi];\n    bridge.noteOff(midi);\n  }\n\n  function targetKey(t) {\n    if (!t) return null;\n    if (t.classList && (t.classList.contains(\"wkey\") || t.classList.contains(\"bkey\"))) return t;\n    return null;\n  }\n  var pointerHeld = false;\n  function handleDown(e) {\n    var t = targetKey(e.target);\n    if (!t) return;\n    pointerHeld = true;\n    keyDown(t);\n    e.preventDefault();\n  }\n  function handleMove(e) {\n    if (!pointerHeld) return;\n    var t = targetKey(document.elementFromPoint(e.clientX, e.clientY));\n    // release keys no longer under the pointer\n    for (var m in down) {\n      if (!t || +t.dataset.midi !== +m) keyUp(+m);\n    }\n    if (t) keyDown(t);\n  }\n  function handleUp() {\n    pointerHeld = false;\n    for (var m in down) keyUp(+m);\n  }\n  keys.addEventListener(\"pointerdown\", handleDown);\n  window.addEventListener(\"pointermove\", handleMove);\n  window.addEventListener(\"pointerup\", handleUp);\n\n  // computer keyboard: A W S E D F T G Y H U J K\n  var KEYMAP = { a:0, w:1, s:2, e:3, d:4, f:5, t:6, g:7, y:8, h:9, u:10, j:11, k:12 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var sk = KEYMAP[e.key.toLowerCase()];\n    if (sk === undefined) return;\n    var midi = START + sk;\n    if (down[midi]) return;\n    down[midi] = { classList: { remove: function () {}, add: function () {} }, dataset: { midi: midi } };\n    bridge.noteOn(midi, 0.9);\n    flashMatrix();\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var sk = KEYMAP[e.key.toLowerCase()];\n    if (sk === undefined) return;\n    var midi = START + sk;\n    if (down[midi]) { bridge.noteOff(midi); delete down[midi]; }\n  });\n\n  // ===================================================================\n  //  ANIMATION — matrix routing dots pulse + meter, on rAF\n  // ===================================================================\n  var meterBar = document.getElementById(\"meterBar\");\n  var pulse = 0;          // decays; jumps on note\n  var lit = 0;            // smoothed audio \"activity\"\n  function flashMatrix() { pulse = 1; }\n\n  var t0 = performance.now();\n  function loop(now) {\n    if (document.hidden) { requestAnimationFrame(loop); return; }\n    var dt = (now - t0) / 1000; t0 = now;\n\n    var active = Object.keys(down).length > 0;\n    var target = active ? 1 : 0;\n    lit += (target - lit) * Math.min(1, dt * 6);\n    pulse *= Math.pow(0.06, dt);   // fast decay\n\n    var energy = Math.max(lit, pulse);\n    var phase = now / 1000;\n\n    // pulse the seated pins; intensity ties to ring-mod + activity\n    var ringGlow = values[1];\n    for (var k = 0; k < pins.length; k++) {\n      var pn = pins[k];\n      if (!pn.on) { pn.glow.setAttribute(\"opacity\", 0); continue; }\n      // staggered shimmer so the routed dots feel alive\n      var s = 0.5 + 0.5 * Math.sin(phase * 4 + (pn.row * 1.3 + pn.col * 0.7));\n      var amp = energy * (0.35 + 0.65 * s) * (0.5 + 0.5 * ringGlow);\n      pn.glow.setAttribute(\"opacity\", (0.15 + 0.75 * amp).toFixed(3));\n      pn.glow.setAttribute(\"stroke-width\", (1 + 4 * amp).toFixed(2));\n      pn.circle.setAttribute(\"r\", (5 + 0.8 * amp).toFixed(2));\n    }\n\n    // output meter reflects level * activity\n    var m = energy * values[6];\n    meterBar.style.width = (m * 100).toFixed(1) + \"%\";\n\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n\n  // ===================================================================\n  //  INIT — push every default to the engine once\n  // ===================================================================\n  function initParams() {\n    PARAMS.forEach(function (p) { pushParam(p.index, p.def); });\n    recomputeMatrix();   // the seated patch defines the mapped params\n    placeStick();\n  }\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(initParams);\n  } else {\n    initParams();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  PIN MATRIX — an EMS-lineage British-modular MONO/paraphonic synth.\n//\n//  Original DSP inspired by the quirky patch-matrix monosynths of early\n//  1970s British studios. Three oscillators (saw, triangle, pulse) feed a\n//  RING MODULATOR that multiplies osc1 x osc2 for clangy, inharmonic metal,\n//  then a distinctive DIODE-LADDER resonant low-pass that self-oscillates,\n//  shaped by a snappy trapezoid-style envelope. The signal is deliberately\n//  asymmetric and slightly unstable so it sounds idiosyncratic and metallic,\n//  NOT a clean Moog. Pure algorithm, no samples, no host imports.\n//\n//  Two voices (paraphonic): the most-recent two held notes both sound,\n//  sharing one filter+envelope path per voice for the eccentric lab feel.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_OSCMIX:  i32 = 0;  // 0..1  -> blend osc1(saw) <-> osc3(pulse), tri filler\nconst P_RINGMOD: i32 = 1;  // 0..1  -> ring modulator amount (osc1 x osc2)\nconst P_CUTOFF:  i32 = 2;  // 0..1  -> diode-ladder base cutoff\nconst P_RESO:    i32 = 3;  // 0..1  -> resonance (-> self-oscillation)\nconst P_ENVAMT:  i32 = 4;  // 0..1  -> envelope -> cutoff amount\nconst P_DECAY:   i32 = 5;  // 0..1  -> trapezoid decay time\nconst P_LEVEL:   i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for note stealing\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// oscillator phases\nconst vPh1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw  (osc1)\nconst vPh2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // tri  (osc2, the ring partner)\nconst vPh3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse(osc3)\n\n// trapezoid-style envelope (snappy attack hold, then decay)\nconst vEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vEStg:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 rel\n\n// diode-ladder filter state (4 stages per voice)\nconst vL0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vL1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vL2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vL3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPh1[v] = 0.0; vPh2[v] = 0.0; vPh3[v] = 0.0;\n    vEnv[v] = 0.0; vEStg[v] = 0;\n    vL0[v] = 0.0; vL1[v] = 0.0; vL2[v] = 0.0; vL3[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_OSCMIX]  = 0.5;\n  params[P_RINGMOD] = 0.45;\n  params[P_CUTOFF]  = 0.5;\n  params[P_RESO]    = 0.55;\n  params[P_ENVAMT]  = 0.7;\n  params[P_DECAY]   = 0.45;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// polyBLEP correction tames the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\n// ---- voice allocation: last-two-note paraphony -----------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    // steal the oldest voice\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vEStg[slot]   = 1; // attack\n  // EMS oscillators free-run; offset phases so the ring product is lively\n  vPh1[slot] = 0.0;\n  vPh2[slot] = 0.17;\n  vPh3[slot] = 0.41;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vEStg[i] = 3; // release\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const oscMix: f32  = clampf(params[P_OSCMIX], 0.0, 1.0);\n  const ringAmt: f32 = clampf(params[P_RINGMOD], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const decayN: f32  = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // trapezoid envelope rates: snappy attack (~3 ms), decay 40 ms .. ~2.2 s\n  const atkRate: f32 = 1.0 / (0.003 * sr);\n  const decS: f32 = 0.04 + decayN * decayN * 2.2;\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (0.12 * sr); // gate-off release\n\n  // base cutoff in Hz, exponential ~50 Hz .. ~14 kHz\n  const baseHz: f32 = 50.0 * f32(Mathf.pow(280.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~7 octaves\n  const envOct: f32 = envAmt * 7.0;\n  // diode-ladder resonance feedback (pushes to self-oscillation near top)\n  const reso: f32 = resoN * 4.4;\n\n  // osc mix weights: saw <-> pulse crossfade, with a constant triangle bed\n  const sawW: f32 = (1.0 - oscMix);\n  const pulW: f32 = oscMix;\n\n  // ring-mod osc2 detuned a touch sharp + non-integer so the product is\n  // strongly inharmonic and clangy (a metallic, bell-like character)\n  const ringRatio: f32 = 1.4983;\n\n  // two voices summed -> scale so both held notes stay bounded\n  const voiceScale: f32 = 0.6;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let vi = 0; vi < NUM_VOICES; vi++) {\n      if (vActive[vi] == 0) continue;\n\n      // ---- trapezoid-style envelope -----------------------------\n      let env: f32 = vEnv[vi];\n      let stg: i32 = vEStg[vi];\n      if (stg == 1) {              // attack to 1\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {       // decay toward a low plateau\n        env -= decRate * (env - 0.18);\n        if (env < 0.181) { /* hold near plateau while gated */ }\n      } else if (stg == 3) {       // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[vi] = env;\n      vEStg[vi] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[vi] = 0; vGate[vi] = 0; vNote[vi] = -1;\n        continue;\n      }\n\n      const baseInc: f32 = vFreq[vi] / sr;\n\n      // ---- osc1: band-limited saw -------------------------------\n      let p1: f32 = vPh1[vi];\n      p1 += baseInc; if (p1 >= 1.0) p1 -= 1.0;\n      let saw: f32 = 2.0 * p1 - 1.0;\n      saw -= polyBlep(p1, baseInc);\n      vPh1[vi] = p1;\n\n      // ---- osc2: triangle, detuned (the ring-mod partner) -------\n      const inc2: f32 = baseInc * ringRatio;\n      let p2: f32 = vPh2[vi];\n      p2 += inc2; if (p2 >= 1.0) p2 -= 1.0;\n      // triangle from phase\n      let tri: f32 = 4.0 * (p2 < 0.5 ? p2 : (1.0 - p2)) - 1.0;\n      vPh2[vi] = p2;\n\n      // ---- osc3: band-limited pulse (slightly narrow duty) ------\n      const pw: f32 = 0.42;\n      let p3: f32 = vPh3[vi];\n      p3 += baseInc; if (p3 >= 1.0) p3 -= 1.0;\n      let pul: f32 = p3 < pw ? 1.0 : -1.0;\n      pul += polyBlep(p3, baseInc);\n      let p3b: f32 = p3 + (1.0 - pw);\n      if (p3b >= 1.0) p3b -= 1.0;\n      pul -= polyBlep(p3b, baseInc);\n      vPh3[vi] = p3;\n\n      // ---- mixer: saw<->pulse crossfade + triangle bed ----------\n      let dry: f32 = saw * sawW + pul * pulW + tri * 0.28;\n\n      // ---- RING MODULATOR: osc1 x osc2 (clangy inharmonic) ------\n      // multiply the saw by the detuned triangle; blend in by ringAmt.\n      const ring: f32 = saw * tri;\n      let osc: f32 = dry * (1.0 - ringAmt) + ring * ringAmt * 1.6;\n\n      // a little asymmetry/grit so it is not a clean classic synth\n      osc = osc + 0.12 * osc * osc;\n\n      // ---- diode-ladder resonant low-pass -----------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * env));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vL0[vi];\n      let s1: f32 = vL1[vi];\n      let s2: f32 = vL2[vi];\n      let s3: f32 = vL3[vi];\n\n      // resonance feedback from the last stage; diode-ish soft nonlinearity\n      // on the feedback path gives the EMS ladder its slightly unstable bite\n      let fb: f32 = reso * s3;\n      fb = f32(Mathf.tanh(fb * 1.3));\n      let inp: f32 = osc - fb;\n\n      // asymmetric diode shaping in the first stage\n      inp = inp + 0.15 * inp * inp;\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vL0[vi] = s0; vL1[vi] = s1; vL2[vi] = s2; vL3[vi] = s3;\n\n      let voice: f32 = s3 * env * (0.5 + 0.5 * vVel[vi]);\n      outL += voice;\n    }\n\n    // ---- sum + soft saturate for that overdriven lab character ---\n    let mix: f32 = outL * voiceScale;\n    mix = f32(Mathf.tanh(mix * 1.4)) * level;\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000097000
}