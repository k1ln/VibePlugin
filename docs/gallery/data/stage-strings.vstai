  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Stage Strings</title>\n<style>\n  :root{ --acc:#ffcf6a; --acc2:#ff8a6a; --wood:#5a3a22; --bg0:#140d07; --bg1:#231406; --ink:#f3e6cf; --dim:#a78a63; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{\n    font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#2c1b0c 0%,var(--bg1) 45%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%;\n  }\n  .unit{\n    width:min(94vw,760px); border-radius:18px; padding:18px 20px 22px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#3a2614,#1c1006);\n    border:1px solid rgba(255,200,120,.16);\n    box-shadow:0 24px 70px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,220,160,.06);\n  }\n  /* wood-grain end caps */\n  .unit::before,.unit::after{ content:\"\"; position:absolute; top:0; bottom:0; width:26px;\n    background:repeating-linear-gradient(180deg,#4a2f17 0 3px,#3a2410 3px 7px); opacity:.85; }\n  .unit::before{ left:0; border-right:1px solid rgba(0,0,0,.4);} .unit::after{ right:0; border-left:1px solid rgba(0,0,0,.4);}\n  header{ display:flex; align-items:baseline; gap:12px; margin:0 14px 14px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.14em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc);\n    box-shadow:0 0 10px var(--acc),0 0 20px var(--acc); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.45; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n\n  .stage{ position:relative; z-index:2; margin:0 14px; }\n  .screen{ height:120px; border-radius:12px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#100b05,#1a1108); border:1px solid rgba(255,200,120,.14); box-shadow:inset 0 2px 22px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.26em; color:var(--dim); z-index:2; }\n\n  .body{ display:grid; grid-template-columns:auto 1fr; gap:16px; align-items:stretch; }\n  .faders{ display:flex; gap:14px; }\n  .fader{ display:flex; flex-direction:column; align-items:center; gap:8px; }\n  .slot{ width:30px; height:150px; border-radius:16px; position:relative; cursor:ns-resize; touch-action:none;\n    background:linear-gradient(180deg,#0e0a05,#241608); border:1px solid rgba(255,200,120,.18); box-shadow:inset 0 2px 8px rgba(0,0,0,.6); }\n  .slotfill{ position:absolute; left:3px; right:3px; bottom:3px; border-radius:13px;\n    background:linear-gradient(180deg,var(--acc),var(--acc2)); box-shadow:0 0 12px rgba(255,180,90,.5); transition:height .04s linear; }\n  .cap{ position:absolute; left:-4px; right:-4px; height:16px; border-radius:7px; transform:translateY(50%);\n    background:linear-gradient(180deg,#fff3df,#caa97a); box-shadow:0 3px 6px rgba(0,0,0,.5),inset 0 1px 0 #fff; }\n  .flabel{ font-size:11px; letter-spacing:.14em; text-transform:uppercase; font-weight:700; color:var(--acc); }\n  .fval{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); }\n\n  .knobs{ display:grid; grid-template-columns:repeat(3,1fr); gap:10px 6px; align-content:center; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:6px 2px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,210,150,.14); stroke-width:6; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:6; stroke-linecap:round; filter:drop-shadow(0 0 4px rgba(255,180,90,.6)); }\n  .pcap{ fill:#1a1107; stroke:rgba(255,200,120,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 3px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.12em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,180,90,.08);\n    padding:1px 7px; border-radius:7px; border:1px solid rgba(255,180,90,.18); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">STAGE&nbsp;STRINGS</span>\n      <span class=\"sub\">string · brass ensemble</span>\n      <span class=\"led\"></span>\n    </header>\n    <div class=\"stage\">\n      <div class=\"screen\"><div class=\"scrlbl\">ENSEMBLE&nbsp;SWELL</div><canvas id=\"cv\"></canvas></div>\n      <div class=\"body\">\n        <div class=\"faders\" id=\"faders\"></div>\n        <div class=\"knobs\" id=\"knobs\"></div>\n      </div>\n    </div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var FADERS=[ {name:\"Strings\",idx:0,def:0.75}, {name:\"Brass\",idx:1,def:0.45} ];\n  var KNOBS=[\n    {name:\"Attack\",idx:2,def:0.35,ms:true},\n    {name:\"Release\",idx:3,def:0.5,ms:true},\n    {name:\"Ensemble\",idx:4,def:0.6},\n    {name:\"Tone\",idx:5,def:0.55},\n    {name:\"Level\",idx:6,def:0.8}\n  ];\n  var vals={}; FADERS.concat(KNOBS).forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n  function ms(v){ var m=Math.round(8+v*v*2000); return m>=1000?(m/1000).toFixed(1)+\"s\":m+\"ms\"; }\n\n  // ---- faders ----\n  var fwrap=document.getElementById(\"faders\");\n  var faderEls=FADERS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"fader\";\n    el.innerHTML='<div class=\"slot\"><div class=\"slotfill\"></div><div class=\"cap\"></div></div>'+\n                 '<span class=\"flabel\">'+p.name+'</span><span class=\"fval\"></span>';\n    fwrap.appendChild(el);\n    var slot=el.querySelector(\".slot\"), fill=el.querySelector(\".slotfill\"), cap=el.querySelector(\".cap\"), val=el.querySelector(\".fval\");\n    function render(v){ var h=Math.max(0,Math.min(1,v)); fill.style.height=(h*100)+\"%\"; cap.style.bottom=(h*100)+\"%\"; val.textContent=pct(v); }\n    var drag=null;\n    slot.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; slot.setPointerCapture(e.pointerId); e.preventDefault(); });\n    slot.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/150)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    slot.addEventListener(\"pointerup\",function(){ drag=null; });\n    slot.addEventListener(\"pointercancel\",function(){ drag=null; });\n    slot.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- knobs ----\n  var R=30, C=2*Math.PI*R, A0=-135, A1=135;\n  var kwrap=document.getElementById(\"knobs\");\n  var knobEls=KNOBS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffcf6a\"/><stop offset=\"1\" stop-color=\"#ff8a6a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"40\" cy=\"40\" r=\"30\"></circle>'+\n      '<circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"30\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"19\"></circle>'+\n      '<line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"24\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kwrap.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){\n      var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2));\n      ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=p.ms?ms(v):pct(v);\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- swelling string+brass waveform ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H);\n    var str=vals[0], brass=vals[1], ens=vals[4], tone=vals[5];\n    var mid=H*0.55;\n    // ensemble shimmer background\n    ctx.globalAlpha=0.12+ens*0.18; ctx.fillStyle=\"rgba(255,180,90,1)\";\n    for(var sx=0;sx<6;sx++){ var px=(ts/40+sx*120)% (W+80)-40; ctx.fillRect(px,0,1.4,H); }\n    ctx.globalAlpha=1;\n    // strings layer (smooth bowed) + brass layer (richer harmonics)\n    function wave(amp,harm,col,sp,off){\n      ctx.beginPath();\n      for(var x=0;x<=W;x+=3){\n        var t=x/W;\n        var y=0;\n        for(var h=1;h<=harm;h++){ y+=Math.sin(t*Math.PI*2*(2+h*0.7)+ts/(sp)+off+h)* (1/h); }\n        var sw=0.55+0.45*Math.sin(ts/900+off); // slow swell\n        ctx.lineTo(x, mid + y*amp*sw*(0.6+tone*0.8));\n      }\n      ctx.strokeStyle=col; ctx.lineWidth=2; ctx.shadowColor=col; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    }\n    wave(16*str+2, 3, \"rgba(255,207,106,\"+(0.5+0.5*str)+\")\", 520, 0);      // strings\n    wave(13*brass+1, 6, \"rgba(255,138,106,\"+(0.4+0.6*brass)+\")\", 360, 1.7); // brass\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function boot(){\n    host=window.vstai||null;\n    FADERS.forEach(function(p,i){ send(p.idx,vals[p.idx]); faderEls[i].render(vals[p.idx]); });\n    KNOBS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobEls[i].render(vals[p.idx]); });\n  }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STAGE STRINGS — a dual STRING + BRASS ensemble machine INSTRUMENT\n//  (in the lineage of the 70s divide-down \"string + brass\" stage keyboards).\n//\n//  Fully POLYPHONIC: a pool of independent voices, each allocated to a\n//  held note. Every voice synthesises TWO distinct, blendable timbres that\n//  share the note's pitch:\n//\n//    • STRINGS  — a bright, fast, divide-down section. Three slightly\n//      detuned sawtooths (note + an octave-up shimmer) give the buzzy,\n//      airy bowed-ensemble tone. It has a FAST attack so it speaks at once.\n//\n//    • BRASS    — a slower, swelling section. A narrow pulse + saw blend\n//      pushed through a per-voice low-pass that OPENS with its own slow\n//      \"brass swell\" envelope, so held notes bloom from dark to bright like\n//      a brass section leaning in. Its attack is deliberately slower than\n//      the strings'.\n//\n//  The two sections are mixed by the Strings / Brass levels, shaped by a\n//  shared Attack/Release amplitude contour, tilted by Tone, then run through\n//  a rich triple-tap ENSEMBLE chorus (three slow LFO-modulated delay lines)\n//  for the lush 70s stage-keyboard shimmer and stereo width.\n//\n//  Params: Strings, Brass, Attack, Release, Ensemble, Tone, Level.\n//  Pure algorithm — no samples, no imports, allocation-free process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI2: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_STRINGS:  i32 = 0;  // 0..1 -> string section level\nconst P_BRASS:    i32 = 1;  // 0..1 -> brass section level\nconst P_ATTACK:   i32 = 2;  // 0..1 -> amp attack time\nconst P_RELEASE:  i32 = 3;  // 0..1 -> amp release time\nconst P_ENSEMBLE: i32 = 4;  // 0..1 -> chorus depth / mix\nconst P_TONE:     i32 = 5;  // 0..1 -> master tone tilt (LP corner)\nconst P_LEVEL:    i32 = 6;  // 0..1 -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // note id or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vInc:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // base phase increment\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// strings: three detuned saw phases (+ shimmer octave phase)\nconst vSp0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vSp1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vSp2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vSo:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // octave shimmer\n\n// brass: pulse phase + saw phase, plus its own swell envelope + filter state\nconst vBp:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse phase\nconst vBs:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw phase\nconst vBenv: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // slow brass swell 0..1\nconst vBlp:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // brass low-pass state\n\n// shared amplitude envelope per voice\nconst vAEnv:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// small per-voice detune spread so the section never beats identically\nconst detA: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst detB: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// ---- ensemble: three BBD-style modulated delay lines (stereo) -------\nconst DLEN: i32 = 2048;                                   // ~42 ms at 48k\nconst delL: StaticArray<f32> = new StaticArray<f32>(DLEN);\nconst delR: StaticArray<f32> = new StaticArray<f32>(DLEN);\nlet dWrite: i32 = 0;\nlet lfo1: f32 = 0.0;\nlet lfo2: f32 = 0.0;\nlet lfo3: f32 = 0.0;\n\n// master tone tilt (stereo one-pole low-pass)\nlet toneZL: f32 = 0.0;\nlet toneZR: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vInc[v] = 0.0; vVel[v] = 0.0;\n    vSp0[v] = 0.0; vSp1[v] = 0.0; vSp2[v] = 0.0; vSo[v] = 0.0;\n    vBp[v] = 0.0; vBs[v] = 0.0; vBenv[v] = 0.0; vBlp[v] = 0.0;\n    vAEnv[v] = 0.0;\n    // symmetric detune spreads (a few cents) so dense chords shimmer\n    const c: f32 = (f32(v) - 3.5) * 0.0011;\n    detA[v] = 1.0 + c;\n    detB[v] = 1.0 - c * 0.6;\n  }\n  ageCounter = 0;\n  for (let i = 0; i < DLEN; i++) { delL[i] = 0.0; delR[i] = 0.0; }\n  dWrite = 0;\n  lfo1 = 0.0; lfo2 = 2.1; lfo3 = 4.2;\n  toneZL = 0.0; toneZR = 0.0;\n\n  params[P_STRINGS]  = 0.75;\n  params[P_BRASS]    = 0.5;\n  params[P_ATTACK]   = 0.28;\n  params[P_RELEASE]  = 0.4;\n  params[P_ENSEMBLE] = 0.7;\n  params[P_TONE]     = 0.55;\n  params[P_LEVEL]    = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function saw(p: f32): f32 { return p * 2.0 - 1.0; }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // retrigger a voice already holding this id\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vNote[i] == id) { slot = i; break; }\n  }\n  // else prefer a free voice\n  if (slot < 0) {\n    for (let i = 0; i < NUM_VOICES; i++) {\n      if (vActive[i] == 0) { slot = i; break; }\n    }\n  }\n  // else steal the oldest\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vInc[slot]    = (f > 0.0 ? f : 1.0) / sampleRate;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  // fresh brass swell + filter so the bloom starts dark each note\n  vBenv[slot]   = 0.0;\n  vBlp[slot]    = 0.0;\n  // stagger string phases so the section sounds wide immediately\n  vSp0[slot] = 0.0; vSp1[slot] = 0.33; vSp2[slot] = 0.66; vSo[slot] = 0.5;\n  vBp[slot] = 0.0;  vBs[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;   // env enters release; voice retires when it decays\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  const strLvl: f32 = clampf(params[P_STRINGS],  0.0, 1.0);\n  const brsLvl: f32 = clampf(params[P_BRASS],    0.0, 1.0);\n  const aN: f32     = clampf(params[P_ATTACK],   0.0, 1.0);\n  const rN: f32     = clampf(params[P_RELEASE],  0.0, 1.0);\n  const ens: f32    = clampf(params[P_ENSEMBLE], 0.0, 1.0);\n  const toneN: f32  = clampf(params[P_TONE],     0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL],    0.0, 1.0);\n\n  // amplitude attack/release as per-sample one-pole coefficients\n  const atkT: f32 = 0.004 + aN * aN * 1.8;            // 4 ms .. ~1.8 s\n  const relT: f32 = 0.03 + rN * rN * 3.5;             // 30 ms .. ~3.5 s\n  const atkC: f32 = 1.0 - f32(Mathf.exp(-1.0 / (atkT * sr)));\n  const relC: f32 = 1.0 - f32(Mathf.exp(-1.0 / (relT * sr)));\n\n  // brass swells SLOWER than the strings — its own envelope rate, scaled so a\n  // longer Attack also lengthens the bloom. This is what separates the two\n  // sections in time as well as timbre.\n  const brsT: f32 = 0.12 + aN * aN * 2.2;             // always slower than strings\n  const brsC: f32 = 1.0 - f32(Mathf.exp(-1.0 / (brsT * sr)));\n\n  // master tone tilt: one-pole LP corner ~600 .. ~9500 Hz\n  const toneHz: f32 = 600.0 + toneN * toneN * 8900.0;\n  const toneC: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * toneHz / sr)), 0.0, 1.0);\n\n  // ensemble: three slow LFOs at staggered rates; depth scales the sweep\n  const lfoR1: f32 = 0.62 / sr * PI2;\n  const lfoR2: f32 = 0.85 / sr * PI2;\n  const lfoR3: f32 = 1.14 / sr * PI2;\n  const baseDelay: f32 = 0.006 * sr;                  // ~6 ms centre tap\n  const modDepth: f32 = (0.0014 + ens * 0.0034) * sr; // up to ~5 ms sweep\n  const wet: f32 = 0.55 * ens;\n\n  // headroom for up to 8 voices summed\n  const voiceGain: f32 = 0.16;\n\n  for (let f = 0; f < n; f++) {\n    let busL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR envelope ------------------------------------\n      let aenv: f32 = vAEnv[v];\n      if (vGate[v] == 1) {\n        aenv = aenv + atkC * (1.0 - aenv);\n      } else {\n        aenv = aenv + relC * (0.0 - aenv);\n        if (aenv < 0.0002) {                          // fully released -> retire\n          vActive[v] = 0; vGate[v] = 0; vNote[v] = -1; vAEnv[v] = 0.0;\n          continue;\n        }\n      }\n      vAEnv[v] = aenv;\n\n      // ---- brass swell envelope (slow, only rises while held) -------\n      let benv: f32 = vBenv[v];\n      const bTarget: f32 = vGate[v] == 1 ? 1.0 : 0.0;\n      benv = benv + brsC * (bTarget - benv);\n      vBenv[v] = benv;\n\n      const inc: f32 = vInc[v];\n\n      // ---- STRINGS: three detuned saws + an octave-up shimmer -------\n      let s0: f32 = vSp0[v] + inc * detA[v];        if (s0 >= 1.0) s0 -= 1.0; vSp0[v] = s0;\n      let s1: f32 = vSp1[v] + inc * (2.0 - detA[v]); if (s1 >= 1.0) s1 -= 1.0; vSp1[v] = s1;\n      let s2: f32 = vSp2[v] + inc;                   if (s2 >= 1.0) s2 -= 1.0; vSp2[v] = s2;\n      let so: f32 = vSo[v]  + inc * 2.0;             if (so >= 1.0) so -= 1.0; vSo[v]  = so;\n      let strings: f32 = (saw(s0) + saw(s1) + saw(s2)) * 0.33 + saw(so) * 0.22;\n      strings *= 0.85;\n\n      // ---- BRASS: pulse + saw through a per-voice LP that OPENS ------\n      let bp: f32 = vBp[v] + inc * detB[v]; if (bp >= 1.0) bp -= 1.0; vBp[v] = bp;\n      let bs: f32 = vBs[v] + inc;           if (bs >= 1.0) bs -= 1.0; vBs[v] = bs;\n      const pulse: f32 = bp < 0.32 ? 1.0 : -1.0;     // narrow pulse = reedy buzz\n      let braw: f32 = pulse * 0.55 + saw(bs) * 0.6;\n      // brass filter corner sweeps up with its swell envelope (dark -> bright)\n      const bCut: f32 = 0.04 + 0.5 * benv;           // one-pole coeff 0.04..0.54\n      let blp: f32 = vBlp[v];\n      blp = blp + bCut * (braw - blp);\n      vBlp[v] = blp;\n      const brass: f32 = blp * (0.35 + 0.65 * benv); // also grows in level as it blooms\n\n      // ---- mix the two sections by their levels, apply amp env ------\n      const voice: f32 = (strings * strLvl + brass * brsLvl) * aenv * vVel[v];\n      busL += voice;\n    }\n\n    // soft-limit the summed bus so dense chords stay bounded\n    let mono: f32 = busL * voiceGain;\n    mono = mono / (1.0 + f32(Mathf.abs(mono)));       // |x| < 1\n\n    // master tone tilt\n    toneZL = toneZL + toneC * (mono - toneZL);\n    const dry: f32 = toneZL;\n\n    // ---- ensemble chorus: three modulated taps, stereo spread ------\n    lfo1 += lfoR1; if (lfo1 >= PI2) lfo1 -= PI2;\n    lfo2 += lfoR2; if (lfo2 >= PI2) lfo2 -= PI2;\n    lfo3 += lfoR3; if (lfo3 >= PI2) lfo3 -= PI2;\n\n    delL[dWrite] = dry;\n    delR[dWrite] = dry;\n\n    const d1: f32 = baseDelay + modDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo1)));\n    const d2: f32 = baseDelay + modDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo2)));\n    const d3: f32 = baseDelay + modDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo3)));\n\n    const tapL: f32 = readDelay(delL, d1) + readDelay(delL, d3);\n    const tapR: f32 = readDelay(delR, d2) + readDelay(delR, d3);\n\n    dWrite++; if (dWrite >= DLEN) dWrite = 0;\n\n    let outL: f32 = dry * (1.0 - 0.4 * wet) + tapL * wet * 0.5;\n    let outR: f32 = dry * (1.0 - 0.4 * wet) + tapR * wet * 0.5;\n\n    outL *= level;\n    outR *= level;\n\n    outBuf[f] = clampf(outL, -1.0, 1.0);\n    outBuf[MAX_FRAMES + f] = clampf(outR, -1.0, 1.0);\n  }\n}\n\n// fractional delay read with linear interpolation, relative to dWrite\n@inline function readDelay(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let d: f32 = delaySamples;\n  if (!(d > 1.0)) d = 1.0;                            // catches NaN and < 1\n  if (d > f32(DLEN - 2)) d = f32(DLEN - 2);\n  let rp: f32 = f32(dWrite) - d;\n  if (rp < 0.0) rp += f32(DLEN);\n  if (!(rp >= 0.0)) rp = 0.0;                         // NaN guard\n  let i0: i32 = i32(rp);\n  if (i0 < 0) i0 = 0;\n  if (i0 >= DLEN) i0 = DLEN - 1;\n  let i1: i32 = i0 + 1; if (i1 >= DLEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n",
  "publishedAt": 1751000145000
}