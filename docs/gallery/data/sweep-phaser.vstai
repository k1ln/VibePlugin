{
  "format": 1,
  "name": "Sweep Phaser",
  "isInstrument": false,
  "explanation": "A 4-stage analog-style phaser: four cascaded all-pass sections are swept by a sine LFO to create two moving notches, with a feedback path for sharper, more resonant sweeps. Controls: Rate, Depth, Feedback and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Feedback",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Sweep Phaser</title>\n<style>\n  :root{\n    --accent:#c08cff;       /* spec accent — used for the moving notches/glow */\n    --accent2:#e0a0ff;\n    --amber:#ff8a1e;        /* retro pedal orange */\n    --amber-lo:#c95a06;\n    --amber-hi:#ffc46b;\n    --cream:#f6e8cf;\n    --ink:#1a120b;\n    --panel:#2a1a0f;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{height:100%}\n  body{\n    font-family:\"Avenir Next\",\"Segoe UI\",system-ui,sans-serif;\n    background:\n      radial-gradient(120% 80% at 50% -10%, #4a2c12 0%, #2a1709 55%, #160d06 100%);\n    color:var(--cream);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100vh;padding:18px;overflow:hidden;\n    -webkit-user-select:none;user-select:none;\n  }\n\n  /* ---------- The pedal enclosure ---------- */\n  .pedal{\n    position:relative;width:430px;border-radius:26px;\n    padding:22px 22px 26px;\n    background:\n      linear-gradient(150deg,#e8861a 0%,#d96e10 38%,#b8530a 72%,#8f3d05 100%);\n    box-shadow:\n      0 28px 60px -16px rgba(0,0,0,.75),\n      0 2px 0 rgba(255,255,255,.22) inset,\n      0 -3px 14px rgba(0,0,0,.45) inset;\n    border:1px solid #6e3203;\n  }\n  /* brushed-metal sheen sweeping over the enclosure */\n  .pedal::before{\n    content:\"\";position:absolute;inset:0;border-radius:26px;pointer-events:none;\n    background:linear-gradient(115deg,transparent 30%,rgba(255,255,255,.16) 47%,rgba(255,255,255,.04) 53%,transparent 70%);\n    background-size:280% 100%;\n    animation:sheen 7s ease-in-out infinite;mix-blend-mode:screen;\n  }\n  @keyframes sheen{0%,100%{background-position:140% 0}50%{background-position:-40% 0}}\n\n  /* corner mounting bolts */\n  .bolt{position:absolute;width:15px;height:15px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff2d4,#7a4410 70%,#3a1f06);\n    box-shadow:0 1px 2px rgba(0,0,0,.6), 0 0 0 2px rgba(0,0,0,.18);}\n  .bolt::after{content:\"\";position:absolute;inset:4px;border-radius:1px;\n    background:linear-gradient(#3a1f06,#7a4410);transform:rotate(35deg);height:3px;top:6px;}\n  .bolt.tl{top:11px;left:11px}.bolt.tr{top:11px;right:11px}\n  .bolt.bl{bottom:11px;left:11px}.bolt.br{bottom:11px;right:11px}\n\n  /* ---------- Header: script logo + power LED ---------- */\n  .head{position:relative;display:flex;align-items:flex-end;justify-content:space-between;\n    padding:4px 14px 12px;z-index:2}\n  .brand{line-height:1}\n  .brand .sub{font-size:10px;letter-spacing:.42em;text-transform:uppercase;\n    color:rgba(26,18,11,.62);font-weight:700;margin-left:3px}\n  .script{\n    font-family:\"Snell Roundhand\",\"Brush Script MT\",\"Segoe Script\",cursive;\n    font-size:46px;font-weight:700;font-style:italic;color:#2a1607;\n    text-shadow:0 1px 0 rgba(255,225,180,.55), 0 -1px 1px rgba(0,0,0,.35);\n    letter-spacing:.5px;\n  }\n  .power{display:flex;flex-direction:column;align-items:center;gap:5px}\n  .led{width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff, var(--accent2) 40%, var(--accent) 70%, #5b2a8f 100%);\n    box-shadow:0 0 10px 2px var(--accent), 0 0 22px 4px rgba(192,140,255,.5), 0 1px 2px rgba(0,0,0,.5);\n    animation:throb 2.4s ease-in-out infinite;}\n  @keyframes throb{0%,100%{filter:brightness(.8)}50%{filter:brightness(1.35)}}\n  .led-lbl{font-size:8px;letter-spacing:.2em;color:rgba(26,18,11,.6);font-weight:700}\n\n  /* ---------- Spectrum / sweep window ---------- */\n  .screen{\n    position:relative;z-index:2;margin:0 8px 18px;border-radius:14px;overflow:hidden;\n    height:148px;\n    background:linear-gradient(#0c0a14,#0a0712 60%,#06040c);\n    box-shadow:0 0 0 1px #000 inset, 0 0 0 6px #14100a, 0 10px 22px -8px rgba(0,0,0,.8),\n      0 0 30px rgba(192,140,255,.10) inset;\n    border:2px solid #2c1c0e;\n  }\n  .screen svg{display:block;width:100%;height:100%}\n  .scan{position:absolute;inset:0;pointer-events:none;\n    background:repeating-linear-gradient(transparent 0 2px, rgba(0,0,0,.22) 2px 4px);\n    mix-blend-mode:multiply;opacity:.55}\n  .screen .glassglow{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(80% 60% at 50% 0%, rgba(192,140,255,.14), transparent 70%);}\n  .readout{position:absolute;left:10px;top:8px;font-size:9px;letter-spacing:.18em;\n    color:rgba(224,160,255,.85);text-transform:uppercase;font-weight:700;\n    text-shadow:0 0 8px rgba(192,140,255,.8)}\n  .readout.r{left:auto;right:10px;color:rgba(255,180,110,.8);text-shadow:0 0 8px rgba(255,138,30,.7)}\n\n  /* ---------- Knob row ---------- */\n  .knobs{position:relative;z-index:2;display:grid;grid-template-columns:repeat(4,1fr);\n    gap:6px;padding:0 6px}\n  .ctrl{display:flex;flex-direction:column;align-items:center;gap:7px}\n  .name{font-size:10px;letter-spacing:.22em;text-transform:uppercase;font-weight:800;\n    color:#2a1607;text-shadow:0 1px 0 rgba(255,220,170,.45)}\n  .dialwrap{position:relative;width:78px;height:78px;cursor:grab;touch-action:none}\n  .dialwrap.drag{cursor:grabbing}\n  .dialwrap svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;overflow:visible}\n  .tickring circle{fill:none;stroke:rgba(26,12,4,.5);stroke-width:1}\n  /* the metal knob cap */\n  .cap{filter:drop-shadow(0 4px 6px rgba(0,0,0,.5))}\n  .arc-bg{fill:none;stroke:rgba(20,10,4,.55);stroke-width:5;stroke-linecap:round}\n  .arc-fg{fill:none;stroke:url(#arcg);stroke-width:5;stroke-linecap:round;\n    filter:drop-shadow(0 0 5px rgba(192,140,255,.55))}\n  .val{font-variant-numeric:tabular-nums;font-size:14px;font-weight:800;color:var(--accent2);\n    text-shadow:0 0 8px rgba(192,140,255,.6);min-width:42px;text-align:center;\n    background:rgba(10,7,16,.55);border-radius:6px;padding:2px 6px;\n    box-shadow:0 0 0 1px rgba(0,0,0,.4) inset}\n\n  .foot{z-index:2;position:relative;text-align:center;margin-top:16px;\n    font-size:8.5px;letter-spacing:.32em;text-transform:uppercase;color:rgba(26,18,11,.55);font-weight:700}\n</style>\n</head>\n<body>\n  <div class=\"pedal\" id=\"pedal\">\n    <span class=\"bolt tl\"></span><span class=\"bolt tr\"></span>\n    <span class=\"bolt bl\"></span><span class=\"bolt br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"script\">Sweep&nbsp;Phaser</div>\n        <div class=\"sub\">4&middot;Stage &middot; All&middot;Pass</div>\n      </div>\n      <div class=\"power\"><span class=\"led\"></span><span class=\"led-lbl\">ON</span></div>\n    </div>\n\n    <div class=\"screen\">\n      <div class=\"readout\">Notch&nbsp;Sweep</div>\n      <div class=\"readout r\" id=\"rateRead\">— Hz</div>\n      <svg viewBox=\"0 0 400 148\" preserveAspectRatio=\"none\" id=\"scope\">\n        <defs>\n          <linearGradient id=\"specg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ff9b3e\" stop-opacity=\".9\"/>\n            <stop offset=\"1\" stop-color=\"#7a3a05\" stop-opacity=\".15\"/>\n          </linearGradient>\n          <linearGradient id=\"notchg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#e0a0ff\" stop-opacity=\".0\"/>\n            <stop offset=\".5\" stop-color=\"#c08cff\" stop-opacity=\".55\"/>\n            <stop offset=\"1\" stop-color=\"#c08cff\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <!-- shared knob arc/pointer gradient — defined ONCE, referenced by every knob -->\n          <linearGradient id=\"arcg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#e0a0ff\"/><stop offset=\"1\" stop-color=\"#ff8a1e\"/>\n          </linearGradient>\n          <filter id=\"soft\"><feGaussianBlur stdDeviation=\"1.1\"/></filter>\n        </defs>\n        <!-- faint frequency grid -->\n        <g stroke=\"rgba(192,140,255,.10)\" stroke-width=\"1\">\n          <line x1=\"80\"  y1=\"0\" x2=\"80\"  y2=\"148\"/><line x1=\"160\" y1=\"0\" x2=\"160\" y2=\"148\"/>\n          <line x1=\"240\" y1=\"0\" x2=\"240\" y2=\"148\"/><line x1=\"320\" y1=\"0\" x2=\"320\" y2=\"148\"/>\n        </g>\n        <!-- the spectrum body (comb) — repainted by rAF -->\n        <path id=\"spec\" class=\"spec\" fill=\"url(#specg)\" stroke=\"#ffb060\" stroke-width=\"1.4\" filter=\"url(#soft)\"/>\n        <!-- two gliding notch bands -->\n        <rect id=\"notchA\" x=\"0\" y=\"0\" width=\"20\" height=\"148\" fill=\"url(#notchg)\"/>\n        <rect id=\"notchB\" x=\"0\" y=\"0\" width=\"20\" height=\"148\" fill=\"url(#notchg)\" opacity=\".75\"/>\n      </svg>\n      <div class=\"glassglow\"></div>\n      <div class=\"scan\"></div>\n    </div>\n\n    <div class=\"knobs\" id=\"knobs\"></div>\n\n    <div class=\"foot\">Boutique &middot; Optical Phase Modulator</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- params (mirrors spec.json EXACTLY) ----\n  var PARAMS = [\n    { name:\"Rate\",     index:0, min:0, max:1, def:0.35 },\n    { name:\"Depth\",    index:1, min:0, max:1, def:0.7  },\n    { name:\"Feedback\", index:2, min:0, max:1, def:0.5  },\n    { name:\"Mix\",      index:3, min:0, max:1, def:0.5  }\n  ];\n\n  var state = { 0:0.35, 1:0.7, 2:0.5, 3:0.5 };\n  function send(i,v){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v); }\n\n  // geometry of the knob arc (degrees): -135 .. +135\n  var A0 = -135, A1 = 135;\n  function fmtPct(v){ return Math.round(v*100) + \"%\"; }\n  function fmtHz(rate){ // map Rate 0..1 -> 0.05 .. 8 Hz (display only)\n    var hz = 0.05 + rate*rate*7.95;\n    return (hz<1 ? hz.toFixed(2) : hz.toFixed(1)) + \" Hz\";\n  }\n\n  // ---- build knobs ----\n  var host = document.getElementById(\"knobs\");\n  var knobs = [];\n\n  function polar(cx,cy,r,deg){ var a=deg*Math.PI/180; return [cx+r*Math.sin(a), cy-r*Math.cos(a)]; }\n  function arcPath(cx,cy,r,d0,d1){\n    var p0=polar(cx,cy,r,d0), p1=polar(cx,cy,r,d1);\n    var large = (d1-d0)>180?1:0;\n    return \"M\"+p0[0].toFixed(2)+\" \"+p0[1].toFixed(2)+\n           \" A\"+r+\" \"+r+\" 0 \"+large+\" 1 \"+p1[0].toFixed(2)+\" \"+p1[1].toFixed(2);\n  }\n\n  PARAMS.forEach(function(p){\n    var c = document.createElement(\"div\"); c.className=\"ctrl\";\n    c.innerHTML =\n      '<div class=\"name\">'+p.name+'</div>'+\n      '<div class=\"dialwrap\" tabindex=\"0\">'+\n        '<svg viewBox=\"0 0 78 78\">'+\n          '<defs>'+\n            '<radialGradient id=\"capg'+p.index+'\" cx=\"38%\" cy=\"30%\" r=\"75%\">'+\n              '<stop offset=\"0\" stop-color=\"#5a4032\"/><stop offset=\"55%\" stop-color=\"#2c1c11\"/>'+\n              '<stop offset=\"100%\" stop-color=\"#160d07\"/>'+\n            '</radialGradient>'+\n          '</defs>'+\n          '<path class=\"arc-bg\" d=\"'+arcPath(39,39,31,A0,A1)+'\"/>'+\n          '<path class=\"arc-fg\" data-arc d=\"'+arcPath(39,39,31,A0,A0)+'\"/>'+\n          '<g class=\"cap\">'+\n            '<circle cx=\"39\" cy=\"39\" r=\"24\" fill=\"url(#capg'+p.index+')\" stroke=\"#0c0703\" stroke-width=\"1\"/>'+\n            '<circle cx=\"39\" cy=\"39\" r=\"24\" fill=\"none\" stroke=\"rgba(255,220,170,.18)\" stroke-width=\"1\" transform=\"translate(0,-1)\"/>'+\n            '<line data-ptr x1=\"39\" y1=\"22\" x2=\"39\" y2=\"33\" stroke=\"url(#arcg)\" stroke-width=\"3\" stroke-linecap=\"round\"/>'+\n            '<circle data-cap cx=\"39\" cy=\"17\" r=\"2.4\" fill=\"#e0a0ff\"/>'+\n          '</g>'+\n        '</svg>'+\n      '</div>'+\n      '<div class=\"val\">'+(p.index===0?fmtHz(p.def):fmtPct(p.def))+'</div>';\n    host.appendChild(c);\n\n    var wrap = c.querySelector(\".dialwrap\");\n    var arcFg= c.querySelector(\"[data-arc]\");\n    var ptr  = c.querySelector(\"[data-ptr]\");\n    var cap  = c.querySelector(\"[data-cap]\");\n    var valEl= c.querySelector(\".val\");\n    var rateRead = document.getElementById(\"rateRead\");\n\n    var obj = { p:p, val:p.def };\n\n    function paint(){\n      var n = (obj.val - p.min)/(p.max - p.min || 1);\n      var ang = A0 + (A1-A0)*n;\n      arcFg.setAttribute(\"d\", arcPath(39,39,31,A0,ang));\n      var rot = \"rotate(\"+ang+\" 39 39)\";\n      ptr.setAttribute(\"transform\", rot);\n      cap.setAttribute(\"transform\", rot);\n      valEl.textContent = (p.index===0 ? fmtHz(obj.val) : fmtPct(obj.val));\n      if(p.index===0) rateRead.textContent = fmtHz(obj.val);\n      state[p.index] = obj.val;\n    }\n    function commit(){ paint(); send(p.index, obj.val); }\n\n    function setN(n){ n = n<0?0:(n>1?1:n); obj.val = p.min + (p.max-p.min)*n; commit(); }\n    function norm(){ return (obj.val - p.min)/(p.max - p.min || 1); }\n\n    var dragging=false, startY=0, startN=0;\n    wrap.addEventListener(\"pointerdown\", function(e){\n      dragging=true; startY=e.clientY; startN=norm();\n      wrap.classList.add(\"drag\"); wrap.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    wrap.addEventListener(\"pointermove\", function(e){\n      if(!dragging) return;\n      var dy = startY - e.clientY;\n      var speed = e.shiftKey ? 600 : 220;   // shift = fine\n      setN(startN + dy/speed);\n    });\n    function end(){ dragging=false; wrap.classList.remove(\"drag\"); }\n    wrap.addEventListener(\"pointerup\", end);\n    wrap.addEventListener(\"pointercancel\", end);\n    wrap.addEventListener(\"dblclick\", function(){ obj.val=p.def; commit(); });\n    wrap.addEventListener(\"wheel\", function(e){\n      e.preventDefault(); setN(norm() + (e.deltaY<0?0.025:-0.025));\n    }, {passive:false});\n    wrap.addEventListener(\"keydown\", function(e){\n      if(e.key===\"ArrowUp\"||e.key===\"ArrowRight\"){ setN(norm()+0.02); e.preventDefault(); }\n      else if(e.key===\"ArrowDown\"||e.key===\"ArrowLeft\"){ setN(norm()-0.02); e.preventDefault(); }\n    });\n\n    obj.paint = paint; knobs.push(obj);\n  });\n\n  // ---- animated spectrum + gliding notches ----\n  var specEl  = document.getElementById(\"spec\");\n  var notchA  = document.getElementById(\"notchA\");\n  var notchB  = document.getElementById(\"notchB\");\n  var W=400, H=148, N=64;\n  var phase=0, last=0;\n\n  function frame(t){\n    if(!last) last=t;\n    var dt = Math.min(0.05,(t-last)/1000); last=t;\n\n    var rate = state[0], depth=state[1], fb=state[2], mix=state[3];\n    // LFO speed scales with Rate (display range ~0.05..8 Hz)\n    var hz = 0.05 + rate*rate*7.95;\n    phase += dt * hz * 0.55;       // gentle visual scaling\n\n    // two notch centres, 180deg apart, swept by the LFO; depth = travel width\n    var sweep = (0.5 + 0.42*depth);          // fraction of width travelled\n    var base  = 0.5 - sweep/2;\n    var lfo   = (Math.sin(phase*2*Math.PI)*0.5+0.5);\n    var cA    = base + sweep*lfo;\n    var cB    = base + sweep*(1-lfo);\n    var notchW= 0.06 + 0.05*(1-fb);          // feedback sharpens (narrows) the notch\n    var pxW   = notchW*W;\n\n    notchA.setAttribute(\"x\", (cA*W - pxW/2).toFixed(1));\n    notchA.setAttribute(\"width\", pxW.toFixed(1));\n    notchB.setAttribute(\"x\", (cB*W - pxW/2).toFixed(1));\n    notchB.setAttribute(\"width\", pxW.toFixed(1));\n    notchA.setAttribute(\"opacity\", (0.35 + 0.6*mix).toFixed(2));\n    notchB.setAttribute(\"opacity\", (0.30 + 0.5*mix).toFixed(2));\n\n    // build a comb spectrum with two dips carved at cA/cB, resonance from fb\n    var d=\"M0 \"+H;\n    for(var k=0;k<=N;k++){\n      var x = k/N;\n      var px = x*W;\n      // base rolling spectral shape\n      var amp = 0.55 + 0.30*Math.sin(x*7.5 + phase*1.3) * (0.5+0.5*Math.sin(x*2.1));\n      // carve notches (gaussian dips); feedback adds resonant peaks at the shoulders\n      function dip(c){\n        var dd=(x-c)/ (notchW*1.1);\n        var g=Math.exp(-dd*dd*9);\n        var res = fb*0.6*Math.exp(-Math.pow((Math.abs(x-c)-notchW*1.1)/(notchW*0.8),2)*6);\n        return g - res;\n      }\n      amp -= depth*0.85*(dip(cA)+dip(cB));\n      amp = amp<0.02?0.02:(amp>1?1:amp);\n      var y = H - amp*(H-14) - 8;\n      d += \" L\"+px.toFixed(1)+\" \"+y.toFixed(1);\n    }\n    d += \" L\"+W+\" \"+H+\" Z\";\n    specEl.setAttribute(\"d\", d);\n\n    requestAnimationFrame(frame);\n  }\n\n  // ---- boot ----\n  function ready(){\n    knobs.forEach(function(o){ o.paint(); send(o.p.index, o.val); });\n    requestAnimationFrame(frame);\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SWEEP PHASER — 4-stage analog-style phaser\n//  A cascade of four first-order all-pass sections whose break frequency\n//  is swept by a sine LFO. Mixing the all-pass output with the dry signal\n//  produces two moving notches; a feedback/resonance path sharpens them.\n//  Controls: Rate, Depth, Feedback, Mix. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst STAGES: i32 = 4;\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// Per-channel all-pass state: STAGES one-pole memories per channel.\nconst apState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * STAGES);\n// Per-channel feedback memory (last wet sample fed back into the chain).\nconst fbState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n// LFO phase (shared so both channels sweep together, like a true analog unit).\nlet lfoPhase: f32 = 0.0;\n\nconst P_RATE: i32 = 0;  // 0..1 -> 0.05..8 Hz LFO sweep speed\nconst P_DEPTH: i32 = 1; // 0..1 -> how far the notches sweep\nconst P_FB: i32 = 2;    // 0..1 -> resonance/feedback amount (sharper notches)\nconst P_MIX: i32 = 3;   // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  if (channels < 1) channels = 1;\n  for (let i = 0; i < MAX_CHANNELS * STAGES; i++) apState[i] = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) fbState[c] = 0.0;\n  lfoPhase = 0.0;\n  params[P_RATE] = 0.35; params[P_DEPTH] = 0.7; params[P_FB] = 0.5; params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  const rateN: f32  = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const fbN: f32    = clampf(params[P_FB], 0.0, 1.0);\n  const mix: f32    = clampf(params[P_MIX], 0.0, 1.0);\n\n  // LFO speed: 0.05 .. 8 Hz, exponential feel for musical control.\n  const rateHz: f32 = 0.05 + rateN * rateN * 7.95;\n  const lfoInc: f32 = TWO_PI * rateHz / sampleRate;\n\n  // Feedback: keep < 1 for stability; resonance up to ~0.9.\n  const feedback: f32 = fbN * 0.9;\n\n  // All-pass break-frequency sweep range (Hz). The LFO modulates the corner\n  // logarithmically between a low and high bound; Depth scales the excursion.\n  const fLo: f32 = 200.0;\n  const fHiMax: f32 = 1600.0;\n  // Depth widens the upper bound of the sweep; min half-octave for audible motion.\n  const fHi: f32 = fLo * f32(Mathf.exp((0.35 + depthN * 1.65) * f32(Mathf.log(fHiMax / fLo)) / 2.0));\n  const logLo: f32 = f32(Mathf.log(fLo));\n  const logHi: f32 = f32(Mathf.log(fHi));\n  const logMid: f32 = 0.5 * (logLo + logHi);\n  const logRange: f32 = 0.5 * (logHi - logLo);\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let f = 0; f < n; f++) {\n    // Sine LFO -> sweep all-pass corner frequency (log domain).\n    const lfo: f32 = f32(Mathf.sin(lfoPhase));\n    const logF: f32 = logMid + logRange * lfo;\n    let fc: f32 = f32(Mathf.exp(logF));\n    if (fc > nyq * 0.99) fc = nyq * 0.99;\n    if (fc < 20.0) fc = 20.0;\n\n    // First-order all-pass coefficient from tan() bilinear warp.\n    const t: f32 = f32(Mathf.tan(PI * fc / sampleRate));\n    const a: f32 = (t - 1.0) / (t + 1.0); // in (-1, 1)\n\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      const sBase: i32 = c * STAGES;\n      const dry: f32 = inBuf[base + f];\n\n      // Inject feedback from previous wet output of this channel.\n      let s: f32 = dry + feedback * fbState[c];\n\n      // 4 cascaded first-order all-pass sections (transposed direct form 1):\n      //   y[n] = a*x[n] + x[n-1] - a*y[n-1]\n      for (let k = 0; k < STAGES; k++) {\n        const idx: i32 = sBase + k;\n        const z: f32 = apState[idx];\n        const y: f32 = a * s + z;\n        apState[idx] = s - a * y;\n        s = y;\n      }\n\n      fbState[c] = s;\n      // Notches form where the 4-stage phase-shifted signal sums with dry.\n      const wet: f32 = 0.5 * (dry + s);\n      let o: f32 = dry + mix * (wet - dry);\n      // Safety clamp (feedback can briefly overshoot on transients).\n      o = clampf(o, -1.5, 1.5);\n      outBuf[base + f] = o;\n    }\n\n    lfoPhase += lfoInc;\n    if (lfoPhase >= TWO_PI) lfoPhase -= TWO_PI;\n  }\n}\n",
  "publishedAt": 1751000021000
}