{
  "format": 1,
  "name": "Bus Glue",
  "isInstrument": false,
  "explanation": "A VCA-style stereo bus compressor for the classic mix-glue character. A feed-forward, RMS-ish level detector watches the summed program and drives a smooth soft-knee gain reduction computed in the dB domain. The same gain is applied to both channels (stereo-linked) so the image stays put while the mix tightens and punches. Three switchable ratios (2:1 / 4:1 / 10:1) plus Attack and Release shape the gain-reduction envelope; Makeup restores level and Mix blends in the dry signal for parallel glue. Loud, dense material is pulled together more than quiet passages, gluing a mix into a cohesive whole. Controls: Threshold, Ratio, Attack, Release, Makeup and Mix.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Makeup",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Bus Glue</title>\n<style>\n  :root{\n    --accent:#ffb347;\n    --accent2:#ff6b6b;\n    --charcoal:#191613;\n    --panel:#2a2521;\n    --panel-hi:#3a342d;\n    --panel-lo:#15120f;\n    --ink:#f4e6cf;\n    --ink-dim:#9c8f7a;\n    --red:#ff5a47;\n  }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #3a322a 0%, #1b1714 55%, #100d0b 100%);\n    color:var(--ink);\n    display:flex; align-items:center; justify-content:center;\n    min-height:100vh; padding:18px; overflow:hidden;\n    user-select:none; -webkit-user-select:none;\n  }\n\n  /* ---- the console module chassis ------------------------------------ */\n  .module{\n    width:560px; max-width:96vw;\n    background:\n      linear-gradient(180deg,var(--panel-hi) 0%,var(--panel) 18%,var(--panel) 82%,var(--panel-lo) 100%);\n    border-radius:14px;\n    padding:18px 20px 22px;\n    box-shadow:\n      0 1px 0 rgba(255,210,140,.10) inset,\n      0 -2px 0 rgba(0,0,0,.6) inset,\n      0 30px 60px -20px rgba(0,0,0,.8),\n      0 0 0 2px #0c0a08;\n    position:relative;\n  }\n  /* corner rack screws */\n  .screw{\n    position:absolute; width:13px; height:13px; border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#5b5249,#211d18 70%,#000);\n    box-shadow:0 1px 1px rgba(0,0,0,.7), 0 0 0 1px #0a0806;\n  }\n  .screw::after{ content:\"\"; position:absolute; inset:3px; border-top:1.5px solid rgba(0,0,0,.55);\n    transform:rotate(35deg); }\n  .screw.tl{ top:9px; left:9px; } .screw.tr{ top:9px; right:9px; }\n  .screw.bl{ bottom:9px; left:9px; } .screw.br{ bottom:9px; right:9px; }\n\n  .head{ display:flex; align-items:baseline; justify-content:space-between; padding:2px 6px 12px; }\n  .brand{ font-weight:800; letter-spacing:2.5px; font-size:18px;\n    color:var(--ink);\n    text-shadow:0 1px 0 #000, 0 0 14px rgba(255,179,71,.25); }\n  .brand b{ color:var(--accent); }\n  .model{ font-size:9.5px; letter-spacing:3px; color:var(--ink-dim); text-transform:uppercase; }\n\n  /* ---- the VU meter --------------------------------------------------- */\n  .meter-wrap{\n    background:linear-gradient(180deg,#211d18,#15120f);\n    border-radius:9px; padding:10px 12px 8px;\n    box-shadow:0 0 0 1px #0a0806, 0 3px 8px rgba(0,0,0,.5) inset;\n    position:relative;\n  }\n  .vu{\n    position:relative; width:100%; height:148px; border-radius:6px;\n    background:\n      radial-gradient(140% 150% at 50% 130%, #fff6e4 0%, #f4dca8 38%, #d8b878 70%, #b8945a 100%);\n    box-shadow:0 0 0 1px #0a0806, 0 2px 6px rgba(0,0,0,.6) inset;\n    overflow:hidden;\n  }\n  /* warm back-light glow that pulses with reduction */\n  .vu .backlight{\n    position:absolute; inset:0;\n    background:radial-gradient(80% 120% at 50% 120%, rgba(255,179,71,.55), rgba(255,179,71,0) 60%);\n    mix-blend-mode:screen; opacity:.5; transition:opacity .1s linear;\n  }\n  .vu svg{ position:absolute; inset:0; width:100%; height:100%; }\n  .vu .glass{\n    position:absolute; inset:0; border-radius:6px; pointer-events:none;\n    background:linear-gradient(155deg, rgba(255,255,255,.35) 0%, rgba(255,255,255,0) 28%);\n  }\n  .vu .label{\n    position:absolute; left:50%; top:12px; transform:translateX(-50%);\n    font-size:8px; letter-spacing:3px; color:#5c4a2c; font-weight:700;\n  }\n  .vu .units{\n    position:absolute; left:50%; bottom:8px; transform:translateX(-50%);\n    font-size:7px; letter-spacing:2px; color:#7a6038; font-weight:700;\n  }\n  .needle{ transform-origin:200px 150px; transition:transform .06s cubic-bezier(.4,1.4,.5,1); }\n\n  /* ---- GR bar meter (vertical, glows) -------------------------------- */\n  .panel{ display:flex; gap:16px; margin-top:14px; }\n  .grcol{\n    width:46px; flex:0 0 auto;\n    background:linear-gradient(180deg,#211d18,#15120f);\n    border-radius:8px; padding:8px 0 6px;\n    box-shadow:0 0 0 1px #0a0806, 0 2px 6px rgba(0,0,0,.5) inset;\n    display:flex; flex-direction:column; align-items:center;\n  }\n  .grcap{ font-size:7px; letter-spacing:1.5px; color:var(--ink-dim); margin-bottom:5px; }\n  .grbar{\n    position:relative; width:14px; height:118px; border-radius:7px;\n    background:#0c0a08; box-shadow:0 0 0 1px #000 inset;\n    overflow:hidden;\n  }\n  .grfill{\n    position:absolute; left:0; right:0; top:0; height:0%;\n    background:linear-gradient(180deg,var(--accent2),var(--accent));\n    box-shadow:0 0 10px rgba(255,107,107,.7);\n    transition:height .07s linear;\n  }\n  .grnum{ font-size:9px; color:var(--accent); margin-top:5px; font-variant-numeric:tabular-nums;\n    text-shadow:0 0 8px rgba(255,179,71,.5); }\n\n  /* ---- knob deck ------------------------------------------------------ */\n  .deck{ flex:1; display:grid; grid-template-columns:repeat(3,1fr); gap:14px 10px;\n    align-content:center; }\n  .cell{ display:flex; flex-direction:column; align-items:center; gap:6px; }\n  .knob{\n    position:relative; width:78px; height:78px; cursor:grab; outline:none;\n    touch-action:none;\n  }\n  .knob.act{ cursor:grabbing; }\n  .knob .ring{\n    position:absolute; inset:0; border-radius:50%;\n    background:radial-gradient(circle at 50% 35%, #4a423a, #211c18 72%, #100d0b);\n    box-shadow:0 4px 10px rgba(0,0,0,.6), 0 1px 0 rgba(255,210,140,.12) inset, 0 0 0 1px #0a0806;\n  }\n  /* progress arc drawn with conic gradient masked to a ring */\n  .knob .arc{\n    position:absolute; inset:4px; border-radius:50%;\n    background:conic-gradient(from -135deg,\n      var(--accent) 0deg, var(--accent2) calc(var(--n,0)*270deg),\n      rgba(0,0,0,.55) calc(var(--n,0)*270deg), rgba(0,0,0,.55) 270deg,\n      transparent 270deg);\n    -webkit-mask:radial-gradient(circle, transparent 30px, #000 31px);\n    mask:radial-gradient(circle, transparent 30px, #000 31px);\n    filter:drop-shadow(0 0 5px rgba(255,179,71,.45));\n  }\n  /* chicken-head cap */\n  .cap{\n    position:absolute; inset:14px; border-radius:50%;\n    background:linear-gradient(150deg,#2c2722,#16120f);\n    box-shadow:0 2px 6px rgba(0,0,0,.7), 0 1px 0 rgba(255,210,140,.10) inset;\n    transform:rotate(calc(-135deg + var(--n,0)*270deg));\n    transition:transform .05s linear;\n  }\n  .cap::before{ /* the pointed chicken-head beak */\n    content:\"\"; position:absolute; left:50%; top:-3px; transform:translateX(-50%);\n    width:0; height:0; border-left:7px solid transparent; border-right:7px solid transparent;\n    border-bottom:18px solid var(--accent);\n    filter:drop-shadow(0 0 4px rgba(255,179,71,.7));\n  }\n  .cap::after{ content:\"\"; position:absolute; inset:9px; border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#3a342d,#181410); }\n  .pname{ font-size:9.5px; letter-spacing:1.5px; color:var(--ink-dim); text-transform:uppercase; }\n  .pval{ font-size:11px; color:var(--accent); font-variant-numeric:tabular-nums;\n    text-shadow:0 0 8px rgba(255,179,71,.4); min-height:13px; }\n\n  /* ratio = stepped detent ring */\n  .knob.stepped .arc{ background:conic-gradient(from -135deg,\n      var(--accent2) 0deg, var(--accent2) calc(var(--n,0)*270deg),\n      rgba(0,0,0,.55) calc(var(--n,0)*270deg), rgba(0,0,0,.55) 270deg, transparent 270deg); }\n\n  .footer{ display:flex; justify-content:space-between; align-items:center;\n    margin-top:14px; padding:0 4px; }\n  .led{ display:flex; align-items:center; gap:6px; font-size:8px; letter-spacing:1.5px; color:var(--ink-dim); }\n  .led i{ width:8px; height:8px; border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #ffd9a0, var(--accent) 60%, #7a4a10);\n    box-shadow:0 0 8px rgba(255,179,71,.8); animation:pwr 2.6s ease-in-out infinite; }\n  @keyframes pwr{ 0%,100%{ opacity:.55; } 50%{ opacity:1; } }\n  .tag{ font-size:8px; letter-spacing:2px; color:var(--ink-dim); }\n</style>\n</head>\n<body>\n  <div class=\"module\">\n    <i class=\"screw tl\"></i><i class=\"screw tr\"></i><i class=\"screw bl\"></i><i class=\"screw br\"></i>\n\n    <div class=\"head\">\n      <div class=\"brand\"><b>BUS</b> GLUE</div>\n      <div class=\"model\">STEREO · VCA BUS COMPRESSOR</div>\n    </div>\n\n    <div class=\"meter-wrap\">\n      <div class=\"vu\">\n        <div class=\"backlight\" id=\"backlight\"></div>\n        <svg viewBox=\"0 0 400 160\" preserveAspectRatio=\"xMidYMid meet\">\n          <!-- scale ticks: 0 (left) to heavy reduction (right/red) -->\n          <g id=\"ticks\" stroke=\"#5c4a2c\" stroke-width=\"1.4\" fill=\"#5c4a2c\" font-size=\"10\"\n             font-family=\"Helvetica,Arial\" text-anchor=\"middle\"></g>\n          <!-- red zone arc -->\n          <path id=\"redzone\" fill=\"none\" stroke=\"#d6422f\" stroke-width=\"6\" stroke-linecap=\"round\" opacity=\"0.85\"/>\n          <!-- the needle -->\n          <g class=\"needle\" id=\"needle\">\n            <line x1=\"200\" y1=\"150\" x2=\"200\" y2=\"30\" stroke=\"#1d1a16\" stroke-width=\"3.2\" stroke-linecap=\"round\"/>\n            <line x1=\"200\" y1=\"150\" x2=\"200\" y2=\"34\" stroke=\"#3a2f1c\" stroke-width=\"1.2\"/>\n          </g>\n          <circle cx=\"200\" cy=\"150\" r=\"9\" fill=\"#1d1a16\"/>\n          <circle cx=\"200\" cy=\"150\" r=\"4\" fill=\"#5c4a2c\"/>\n        </svg>\n        <div class=\"label\">GAIN REDUCTION</div>\n        <div class=\"units\">dB · VU</div>\n        <div class=\"glass\"></div>\n      </div>\n    </div>\n\n    <div class=\"panel\">\n      <div class=\"grcol\">\n        <div class=\"grcap\">GR</div>\n        <div class=\"grbar\"><div class=\"grfill\" id=\"grfill\"></div></div>\n        <div class=\"grnum\" id=\"grnum\">0.0</div>\n      </div>\n      <div class=\"deck\" id=\"deck\"></div>\n    </div>\n\n    <div class=\"footer\">\n      <div class=\"led\"><i></i> POWER · GLUE ENGAGED</div>\n      <div class=\"tag\">FEED-FORWARD · STEREO-LINKED</div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- parameter definitions (must match assembly.ts indices) ----------\n  var PARAMS=[\n    { name:\"Threshold\", index:0, min:0, max:1, def:0.45, fmt:function(v){ return (-40+v*40).toFixed(1)+\" dB\"; } },\n    { name:\"Ratio\",     index:1, min:0, max:2, def:1,    step:1,\n      fmt:function(v){ var s=Math.round(v); return [\"2:1\",\"4:1\",\"10:1\"][s]; } },\n    { name:\"Attack\",    index:2, min:0, max:1, def:0.4,\n      fmt:function(v){ return (30*Math.pow(0.0033333,v)).toFixed(2)+\" ms\"; } },\n    { name:\"Release\",   index:3, min:0, max:1, def:0.4,\n      fmt:function(v){ return (0.1+v*1.1).toFixed(2)+\" s\"; } },\n    { name:\"Makeup\",    index:4, min:0, max:1, def:0.3,\n      fmt:function(v){ return \"+\"+(24*v).toFixed(1)+\" dB\"; } },\n    { name:\"Mix\",       index:5, min:0, max:1, def:1,\n      fmt:function(v){ return Math.round(v*100)+\"%\"; } }\n  ];\n\n  var state={}; // index -> value\n\n  var deck=document.getElementById('deck');\n  var needle=document.getElementById('needle');\n  var grfill=document.getElementById('grfill');\n  var grnum=document.getElementById('grnum');\n  var backlight=document.getElementById('backlight');\n\n  // ---- build VU scale (ticks + red zone) -------------------------------\n  (function buildScale(){\n    var ticks=document.getElementById('ticks');\n    var redzone=document.getElementById('redzone');\n    // needle sweeps from -50deg (rest, no GR) to +50deg (heavy GR)\n    var A0=-52, A1=52, cx=200, cy=150, R=118, Rt=98;\n    var marks=[ {gr:0,t:\"0\"},{gr:3,t:\"3\"},{gr:6,t:\"6\"},{gr:10,t:\"10\"},{gr:16,t:\"20\"} ];\n    var maxGr=16;\n    function ang(gr){ var n=gr/maxGr; return A0+(A1-A0)*n; }\n    function rad(a){ return (a-90)*Math.PI/180; }\n    var s=\"\";\n    for(var i=0;i<marks.length;i++){\n      var a=rad(ang(marks[i].gr));\n      var x1=cx+Math.cos(a)*R, y1=cy+Math.sin(a)*R;\n      var x2=cx+Math.cos(a)*(R-9), y2=cy+Math.sin(a)*(R-9);\n      var tx=cx+Math.cos(a)*Rt, ty=cy+Math.sin(a)*Rt+3;\n      s+='<line x1=\"'+x1.toFixed(1)+'\" y1=\"'+y1.toFixed(1)+'\" x2=\"'+x2.toFixed(1)+'\" y2=\"'+y2.toFixed(1)+'\"/>';\n      s+='<text x=\"'+tx.toFixed(1)+'\" y=\"'+ty.toFixed(1)+'\">'+marks[i].t+'</text>';\n    }\n    ticks.innerHTML=s;\n    // red zone from 6 dB upward\n    var aa=rad(ang(6)), ab=rad(ang(maxGr));\n    var rr=R-2;\n    var p=\"M \"+(cx+Math.cos(aa)*rr).toFixed(1)+\" \"+(cy+Math.sin(aa)*rr).toFixed(1)+\n          \" A \"+rr+\" \"+rr+\" 0 0 1 \"+(cx+Math.cos(ab)*rr).toFixed(1)+\" \"+(cy+Math.sin(ab)*rr).toFixed(1);\n    redzone.setAttribute('d',p);\n    needle.dataset.a0=A0; needle.dataset.a1=A1; needle.dataset.max=maxGr;\n  })();\n\n  function setNeedle(grDb){\n    var maxGr=16, A0=-52, A1=52;\n    var n=Math.max(0,Math.min(1,grDb/maxGr));\n    var a=A0+(A1-A0)*n;\n    needle.style.transform=\"rotate(\"+a.toFixed(2)+\"deg)\";\n    var p=Math.min(1,grDb/12);\n    grfill.style.height=(p*100).toFixed(1)+\"%\";\n    grnum.textContent=\"-\"+grDb.toFixed(1);\n    backlight.style.opacity=(0.4+p*0.55).toFixed(2);\n  }\n\n  // ---- simulated detector so the needle/meter LIVE-track the settings --\n  // We model a moving program signal and run the same gain computer the\n  // DSP uses, so the meter responds to every knob in real time.\n  var simLevel=0;     // dB level of the imagined bus material (drifts)\n  var grSmooth=0;     // smoothed displayed GR\n  var tprev=0, phase=0;\n  function tick(ts){\n    if(!tprev) tprev=ts;\n    var dt=Math.min(0.05,(ts-tprev)/1000); tprev=ts;\n    phase+=dt;\n    // imagined program: a busy mix bobbing around -14 dBFS with transients\n    var prog=-14 + 8*Math.sin(phase*1.7) + 5*Math.sin(phase*4.3+1.1)\n                 + 4*Math.sin(phase*9.7);\n    // gain computer (matches assembly.ts: soft knee, ratio, threshold)\n    var thr=-40+(state[0]!=null?state[0]:0.45)*40;\n    var sel=Math.round(state[1]!=null?state[1]:1);\n    var ratio=[2,4,10][sel]||4;\n    var slope=1-1/ratio, knee=6, hk=knee/2;\n    var over=prog-thr, target;\n    if(over<=-hk) target=0;\n    else if(over>=hk) target=slope*over;\n    else target=slope*(over+hk)*(over+hk)/(2*knee);\n    // attack/release smoothing toward target\n    var atN=state[2]!=null?state[2]:0.4;\n    var relN=state[3]!=null?state[3]:0.4;\n    var atkMs=30*Math.pow(0.0033333,atN);\n    var relS=0.1+relN*1.1;\n    var coef= target>grSmooth ? 1-Math.exp(-dt/(atkMs*0.001)) : 1-Math.exp(-dt/relS);\n    grSmooth+=coef*(target-grSmooth);\n    if(grSmooth<0) grSmooth=0;\n    // Mix scales how much GR is visibly applied (parallel)\n    var mix=state[5]!=null?state[5]:1;\n    setNeedle(grSmooth*mix);\n    requestAnimationFrame(tick);\n  }\n\n  // ---- knob factory ----------------------------------------------------\n  function build(p){\n    var cell=document.createElement('div'); cell.className='cell';\n    var stepped=p.step?' stepped':'';\n    cell.innerHTML=\n      '<div class=\"knob'+stepped+'\" tabindex=\"0\" role=\"slider\" aria-label=\"'+p.name+'\">'+\n        '<i class=\"ring\"></i><i class=\"arc\"></i><i class=\"cap\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var cap=cell.querySelector('.cap');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n);\n      cap.style.setProperty('--n',n);\n      val.textContent=p.fmt?p.fmt(v):n.toFixed(2);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n    }\n    function setNorm(n){\n      n=n<0?0:n>1?1:n;\n      var raw=p.min+(p.max-p.min)*n;\n      if(p.step) raw=Math.round(raw/p.step)*p.step;\n      v=raw; paint();\n    }\n\n    var drag=false, startY=0, startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true; startY=e.clientY; startN=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?700:230;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();\n      var dn=p.step?(p.step/((p.max-p.min)||1)):0.03;\n      setNorm(norm()+(e.deltaY<0?dn:-dn));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      var dn=p.step?(p.step/((p.max-p.min)||1)):0.02;\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+dn);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-dn);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  function ready(){\n    for(var i=0;i<PARAMS.length;i++) build(PARAMS[i]);\n    requestAnimationFrame(tick);\n  }\n\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BUS GLUE — stereo VCA bus compressor (the classic mix \"glue\")\n//  A feed-forward, RMS-ish level detector watches the summed program and\n//  drives a smooth soft-knee gain reduction computed in the dB domain.\n//  The SAME gain is applied to L and R (stereo-linked) so the image never\n//  wanders — it just gets tighter and punchier. A loud bus compresses\n//  noticeably more than a quiet one; Makeup restores level and Mix blends\n//  in the dry signal for parallel \"New York\" glue. No samples, no imports.\n//\n//  Params: Threshold, Ratio (stepped 2:1/4:1/10:1), Attack, Release,\n//  Makeup, Mix.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (single linked detector for L+R) -----------\nlet rmsEnv: f32 = 0.0;   // smoothed mean-square of the side-chain\nlet grDb:   f32 = 0.0;   // current gain reduction in dB (>= 0)\n\n// exported scalar so the GUI can poll gain reduction for the VU needle\nlet lastGrDb: f32 = 0.0;\n\nconst P_THRESH:  i32 = 0;  // 0..1 -> -40..0 dBFS threshold\nconst P_RATIO:   i32 = 1;  // 0/1/2 -> 2:1 / 4:1 / 10:1 (discrete)\nconst P_ATTACK:  i32 = 2;  // 0..1 -> 30 ms .. 0.1 ms (1 = fastest)\nconst P_RELEASE: i32 = 3;  // 0..1 -> 0.1 s .. 1.2 s\nconst P_MAKEUP:  i32 = 4;  // 0..1 -> 0 .. +24 dB\nconst P_MIX:     i32 = 5;  // 0..1 dry/wet (parallel)\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function lin2db(x: f32): f32 { return f32(8.6858896 * Mathf.log(x + 1.0e-9)); } // 20/ln10\n@inline function db2lin(x: f32): f32 { return f32(Mathf.exp(x * 0.11512925)); }         // ln10/20\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  rmsEnv = 0.0;\n  grDb = 0.0;\n  lastGrDb = 0.0;\n  params[P_THRESH]  = 0.45; // ~ -22 dB\n  params[P_RATIO]   = 1.0;  // 4:1\n  params[P_ATTACK]  = 0.40;\n  params[P_RELEASE] = 0.40; // ~ 0.54 s\n  params[P_MAKEUP]  = 0.30; // ~ +7.2 dB\n  params[P_MIX]     = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\nexport function getGainReductionDb(): f32 { return lastGrDb; }\n\nexport function process(n: i32): void {\n  const thN:  f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const atN:  f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const relN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const mkN:  f32 = clampf(params[P_MAKEUP], 0.0, 1.0);\n  const mix:  f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Threshold: -40 dBFS (heavy glue) .. 0 dBFS (clean)\n  const threshDb: f32 = -40.0 + thN * 40.0;\n\n  // Discrete ratio selector -> 2 / 4 / 10\n  const sel: i32 = i32(clampf(params[P_RATIO], 0.0, 2.0) + 0.5);\n  let ratio: f32 = 4.0;\n  if (sel <= 0) ratio = 2.0;\n  else if (sel == 1) ratio = 4.0;\n  else ratio = 10.0;\n  const slope: f32 = 1.0 - 1.0 / ratio; // dB pulled back per dB over threshold\n\n  // Soft knee width in dB (gentle, classy bus-glue knee)\n  const knee: f32 = 6.0;\n  const halfKnee: f32 = knee * 0.5;\n\n  // Attack: 30 ms (slow) .. 0.1 ms (fast). atN=1 -> fastest.\n  const atkMs: f32 = 30.0 * f32(Mathf.pow(0.0033333, atN)); // 30 -> 0.1 ms\n  const atkCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.001 * atkMs * sampleRate)));\n\n  // Release: 0.1 s .. 1.2 s\n  const relS: f32 = 0.1 + relN * 1.1;\n  const relCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (relS * sampleRate)));\n\n  // RMS detector smoothing (~10 ms window) for the \"averaging\" feel\n  const rmsCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.010 * sampleRate)));\n\n  // Makeup 0..+24 dB\n  const makeup: f32 = db2lin(24.0 * mkN);\n\n  let rEnv: f32 = rmsEnv;\n  let gr: f32 = grDb;\n  let maxGrDb: f32 = 0.0;\n\n  const chan: i32 = channels;\n  const baseR: i32 = MAX_FRAMES; // right-channel offset\n\n  for (let f = 0; f < n; f++) {\n    const l: f32 = inBuf[f];\n    const r: f32 = chan > 1 ? inBuf[baseR + f] : l;\n\n    // stereo-linked side-chain: mean of squares (RMS-ish), smoothed\n    const sq: f32 = 0.5 * (l * l + r * r);\n    rEnv += rmsCoef * (sq - rEnv);\n    const det: f32 = rEnv > 1.0e-12 ? rEnv : 1.0e-12;\n\n    // mean-square -> dBFS  (10*log10(ms) == 20*log10(rms))\n    const levelDb: f32 = 0.5 * lin2db(det);\n\n    // soft-knee static curve -> target gain reduction (dB, >= 0)\n    const over: f32 = levelDb - threshDb;\n    let targetGr: f32;\n    if (over <= -halfKnee) {\n      targetGr = 0.0;\n    } else if (over >= halfKnee) {\n      targetGr = slope * over;\n    } else {\n      const x: f32 = over + halfKnee; // 0..knee\n      targetGr = slope * (x * x) / (2.0 * knee);\n    }\n\n    // attack when more reduction is wanted, release when less\n    const coef: f32 = targetGr > gr ? atkCoef : relCoef;\n    gr += coef * (targetGr - gr);\n    if (gr < 0.0) gr = 0.0;\n    if (gr > maxGrDb) maxGrDb = gr;\n\n    // dB gain reduction -> linear gain, applied EQUALLY to L and R\n    const g: f32 = db2lin(-gr) * makeup;\n    const wetL: f32 = l * g;\n    const wetR: f32 = r * g;\n\n    // parallel blend; soft-bound to keep peaks < ~1.0\n    const oL: f32 = l * (1.0 - mix) + wetL * mix;\n    const oR: f32 = r * (1.0 - mix) + wetR * mix;\n    outBuf[f] = f32(Mathf.tanh(oL * 0.85)) * 1.05;\n    if (chan > 1) outBuf[baseR + f] = f32(Mathf.tanh(oR * 0.85)) * 1.05;\n  }\n\n  rmsEnv = rEnv;\n  grDb = gr;\n  lastGrDb = maxGrDb;\n}\n",
  "publishedAt": 1751000088000
}