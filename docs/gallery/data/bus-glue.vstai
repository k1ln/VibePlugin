{
  "format": 1,
  "name": "Bus Glue",
  "isInstrument": false,
  "explanation": "A VCA-style stereo bus compressor for the classic mix-glue character. A stereo-linked RMS detector feeds a dB-domain gain computer with a gentle soft knee and three switchable ratios (2:1 / 4:1 / 10:1). Stepped Attack and Release times — with a program-dependent auto-release at the top of the Release range — shape a smooth gain-reduction envelope, and a Makeup gain restores level. Loud, dense material is gently pulled together more than quiet passages, gluing a mix into a cohesive whole. Controls: Threshold, Ratio, Attack, Release and Makeup.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Makeup",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Bus Glue</title>\n<style>\n  :root{\n    --accent:#c0c8d0;\n    --accent2:#9aa6b4;\n    --panel:#3a3d42;\n    --panel-hi:#4a4e54;\n    --panel-lo:#2a2c30;\n    --ink:#d8dde3;\n    --ink-dim:#8b9298;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;}\n  html,body{height:100%;}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #43474d 0%, #2e3034 55%, #232528 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    padding:18px;overflow:hidden;-webkit-font-smoothing:antialiased;\n  }\n\n  /* ---------- console chassis ---------- */\n  .unit{\n    width:560px;max-width:100%;\n    border-radius:14px;\n    background:linear-gradient(180deg,var(--panel-hi),var(--panel) 18%,var(--panel) 82%,var(--panel-lo));\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.10) inset,\n      0 -2px 0 rgba(0,0,0,.45) inset,\n      0 22px 50px rgba(0,0,0,.55),\n      0 2px 4px rgba(0,0,0,.4);\n    padding:18px 20px 22px;\n    position:relative;\n    border:1px solid rgba(0,0,0,.45);\n  }\n  /* rack screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#6a6e74,#34363a 70%,#1c1d20);\n    box-shadow:0 1px 1px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.4) inset;}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-top:1px solid rgba(0,0,0,.55);\n    transform:rotate(28deg);}\n  .screw.tl{top:9px;left:9px}.screw.tr{top:9px;right:9px}\n  .screw.bl{bottom:9px;left:9px}.screw.br{bottom:9px;right:9px}\n\n  .brand{\n    display:flex;align-items:baseline;justify-content:space-between;\n    padding:0 6px 12px;border-bottom:1px solid rgba(0,0,0,.35);\n    margin-bottom:14px;\n  }\n  .brand h1{\n    font-size:15px;letter-spacing:.42em;font-weight:700;\n    color:var(--accent);text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(0,0,0,.6);\n  }\n  .brand .sub{font-size:9px;letter-spacing:.32em;color:var(--ink-dim);text-transform:uppercase;}\n\n  /* ---------- VU meter ---------- */\n  .meter-wrap{\n    display:flex;justify-content:center;margin-bottom:18px;\n  }\n  .vu{\n    width:300px;height:152px;border-radius:8px;\n    background:linear-gradient(180deg,#f4ecd6,#e7dcbf 60%,#d8cba6);\n    box-shadow:\n      0 0 0 4px #1d1e21,\n      0 0 0 6px #45484e,\n      0 4px 10px rgba(0,0,0,.5) inset,\n      0 1px 0 rgba(255,255,255,.3);\n    position:relative;overflow:hidden;\n  }\n  .vu .glass{position:absolute;inset:0;border-radius:8px;pointer-events:none;\n    background:linear-gradient(135deg,rgba(255,255,255,.35),rgba(255,255,255,0) 40%);}\n  .vu svg{display:block;width:100%;height:100%;}\n  .vu .label{\n    position:absolute;left:0;right:0;bottom:8px;text-align:center;\n    font-size:8px;letter-spacing:.3em;color:#7c6f4f;text-transform:uppercase;\n  }\n  .vu .gr-num{\n    position:absolute;top:8px;left:0;right:0;text-align:center;\n    font-size:9px;letter-spacing:.18em;color:#8a7c58;\n  }\n  /* needle sway idle animation */\n  #needle{transform-box:fill-box;transform-origin:150px 138px;\n    transition:transform .09s cubic-bezier(.3,.7,.4,1);}\n  .idle #needle{animation:sway 5.5s ease-in-out infinite;}\n  @keyframes sway{\n    0%,100%{transform:rotate(-2deg);}\n    50%{transform:rotate(2.5deg);}\n  }\n  .vu .lamp{position:absolute;top:10px;right:12px;width:8px;height:8px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#ffe7a8,#e2b24a 60%,#7a5b1c);\n    box-shadow:0 0 8px 1px rgba(255,200,90,.6);animation:flick 6s ease-in-out infinite;}\n  @keyframes flick{0%,100%{opacity:.55}50%{opacity:1}}\n\n  /* ---------- control row ---------- */\n  .row{\n    display:flex;justify-content:space-between;gap:8px;\n    background:linear-gradient(180deg,#26282b,#303338);\n    border-radius:9px;padding:16px 14px 14px;\n    box-shadow:0 2px 5px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.06);\n  }\n  .cell{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1;}\n  .cell .cap{font-size:9px;letter-spacing:.18em;color:var(--ink-dim);text-transform:uppercase;}\n  .cell .val{font-size:10px;color:var(--accent);font-variant-numeric:tabular-nums;\n    letter-spacing:.04em;min-height:12px;}\n\n  /* knob */\n  .knob{\n    --ang:0deg;\n    width:62px;height:62px;border-radius:50%;position:relative;cursor:grab;\n    background:\n      radial-gradient(circle at 50% 38%,#5a5e64,#3c3f44 62%,#26282b);\n    box-shadow:\n      0 3px 6px rgba(0,0,0,.55),\n      0 1px 0 rgba(255,255,255,.12) inset,\n      0 -3px 5px rgba(0,0,0,.4) inset;\n    touch-action:none;user-select:none;\n  }\n  .knob:active{cursor:grabbing;}\n  .knob .face{position:absolute;inset:9px;border-radius:50%;\n    background:conic-gradient(from 140deg,#33363b 0 8%,#43474d 8% 92%,#33363b 92%);\n    box-shadow:0 1px 2px rgba(0,0,0,.5) inset;}\n  .knob .grip{position:absolute;inset:9px;border-radius:50%;\n    transform:rotate(var(--ang));transition:transform .04s linear;}\n  .knob .grip::before{content:\"\";position:absolute;left:50%;top:5px;\n    width:3px;height:15px;margin-left:-1.5px;border-radius:2px;\n    background:linear-gradient(180deg,var(--accent),var(--accent2));\n    box-shadow:0 0 5px var(--accent);}\n  /* tick ring */\n  .knob .ring{position:absolute;inset:-6px;border-radius:50%;pointer-events:none;}\n\n  /* stepped ratio switch */\n  .switch{\n    width:84px;display:flex;flex-direction:column;gap:5px;\n    padding:7px 6px;border-radius:7px;background:#24262a;\n    box-shadow:0 1px 2px rgba(0,0,0,.5) inset;\n  }\n  .switch button{\n    font:inherit;font-size:11px;letter-spacing:.04em;\n    border:none;cursor:pointer;border-radius:4px;padding:5px 0;\n    color:var(--ink-dim);background:linear-gradient(180deg,#3a3d42,#2c2f33);\n    box-shadow:0 1px 0 rgba(255,255,255,.06),0 1px 2px rgba(0,0,0,.4);\n    transition:all .14s ease;\n  }\n  .switch button:hover{color:var(--ink);}\n  .switch button.on{\n    color:#1c1d20;font-weight:700;\n    background:linear-gradient(180deg,var(--accent),var(--accent2));\n    box-shadow:0 0 10px rgba(192,200,208,.55),0 1px 0 rgba(255,255,255,.4) inset;\n  }\n  .ratio-cell{display:flex;flex-direction:column;align-items:center;gap:8px;flex:1.15;}\n\n  .hint{margin-top:12px;text-align:center;font-size:8.5px;letter-spacing:.16em;\n    color:var(--ink-dim);text-transform:uppercase;opacity:.7;}\n</style>\n</head>\n<body>\n  <div class=\"unit idle\" id=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"brand\">\n      <h1>Bus&nbsp;Glue</h1>\n      <span class=\"sub\">Stereo VCA Bus Compressor</span>\n    </div>\n\n    <div class=\"meter-wrap\">\n      <div class=\"vu\" id=\"vu\">\n        <span class=\"lamp\"></span>\n        <svg viewBox=\"0 0 300 152\" preserveAspectRatio=\"xMidYMid meet\">\n          <!-- arc -->\n          <path d=\"M 40 120 A 120 120 0 0 1 260 120\" fill=\"none\" stroke=\"#b7a877\" stroke-width=\"1.2\" opacity=\".6\"/>\n          <path d=\"M 60 108 A 100 100 0 0 1 240 108\" fill=\"none\" stroke=\"#9c5a3c\" stroke-width=\"2.4\"\n                stroke-dasharray=\"0 96 200\"/>\n          <!-- ticks -->\n          <g id=\"ticks\" stroke=\"#6f6446\" stroke-width=\"1.4\"></g>\n          <!-- scale numbers -->\n          <g id=\"nums\" fill=\"#7c6f4f\" font-size=\"9\" font-family=\"Helvetica,Arial\" text-anchor=\"middle\"></g>\n          <text x=\"150\" y=\"60\" fill=\"#9c5a3c\" font-size=\"9\" text-anchor=\"middle\" font-family=\"Helvetica,Arial\" letter-spacing=\"2\">GAIN REDUCTION</text>\n          <!-- needle -->\n          <g id=\"needle\">\n            <line x1=\"150\" y1=\"138\" x2=\"150\" y2=\"34\" stroke=\"#23252a\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n            <circle cx=\"150\" cy=\"138\" r=\"7\" fill=\"#23252a\"/>\n            <circle cx=\"150\" cy=\"138\" r=\"3\" fill=\"#54585e\"/>\n          </g>\n        </svg>\n        <div class=\"glass\"></div>\n        <div class=\"gr-num\" id=\"grNum\">−0.0 dB</div>\n        <div class=\"label\">VU · dB</div>\n      </div>\n    </div>\n\n    <div class=\"row\" id=\"row\">\n      <div class=\"cell\">\n        <div class=\"knob\" id=\"k0\" data-idx=\"0\"><div class=\"face\"></div><div class=\"grip\"></div></div>\n        <div class=\"cap\">Threshold</div><div class=\"val\" id=\"v0\"></div>\n      </div>\n\n      <div class=\"ratio-cell\">\n        <div class=\"switch\" id=\"ratio\">\n          <button data-v=\"0\">2 : 1</button>\n          <button data-v=\"1\">4 : 1</button>\n          <button data-v=\"2\">10 : 1</button>\n        </div>\n        <div class=\"cap\">Ratio</div><div class=\"val\" id=\"v1\"></div>\n      </div>\n\n      <div class=\"cell\">\n        <div class=\"knob\" id=\"k2\" data-idx=\"2\"><div class=\"face\"></div><div class=\"grip\"></div></div>\n        <div class=\"cap\">Attack</div><div class=\"val\" id=\"v2\"></div>\n      </div>\n      <div class=\"cell\">\n        <div class=\"knob\" id=\"k3\" data-idx=\"3\"><div class=\"face\"></div><div class=\"grip\"></div></div>\n        <div class=\"cap\">Release</div><div class=\"val\" id=\"v3\"></div>\n      </div>\n      <div class=\"cell\">\n        <div class=\"knob\" id=\"k4\" data-idx=\"4\"><div class=\"face\"></div><div class=\"grip\"></div></div>\n        <div class=\"cap\">Makeup</div><div class=\"val\" id=\"v4\"></div>\n      </div>\n    </div>\n\n    <div class=\"hint\">Drag knobs · double-click to reset · click ratio to switch</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- host bridge -------------------------------------------------\n  function host(){ return (typeof window!==\"undefined\" && window.vstai) ? window.vstai : null; }\n  function send(idx,val){ const h=host(); if(h && typeof h.setParam===\"function\") h.setParam(idx, val); }\n\n  // ---- param model -------------------------------------------------\n  // (min,max,default,fmt) — Ratio handled separately as a stepped switch\n  var P = {\n    0:{def:0.45, fmt:function(v){ return (-40*v).toFixed(1)+\" dB\"; }},\n    2:{def:0.40, fmt:function(v){ var ms=30*Math.pow(0.0033333,v); return ms.toFixed(ms<1?2:1)+\" ms\"; }},\n    3:{def:0.50, fmt:function(v){ if(v>0.92) return \"AUTO\"; return (0.1+v*1.1).toFixed(2)+\" s\"; }},\n    4:{def:0.30, fmt:function(v){ return \"+\"+(24*v).toFixed(1)+\" dB\"; }}\n  };\n  var state = {0:0.45, 1:1, 2:0.40, 3:0.50, 4:0.30};\n\n  // sweep -135deg..+135deg for the knob grip\n  function knobAngle(v){ return (-135 + v*270); }\n\n  function paintKnob(idx){\n    var k=document.getElementById(\"k\"+idx);\n    if(k) k.style.setProperty(\"--ang\", knobAngle(state[idx])+\"deg\");\n    var vEl=document.getElementById(\"v\"+idx);\n    if(vEl && P[idx]) vEl.textContent = P[idx].fmt(state[idx]);\n  }\n\n  function setParam(idx,val,silent){\n    val = Math.max(0, Math.min(1, val));\n    state[idx]=val;\n    paintKnob(idx);\n    if(!silent) send(idx, val);\n  }\n\n  // ---- continuous knob drag ---------------------------------------\n  function wireKnob(idx){\n    var k=document.getElementById(\"k\"+idx);\n    if(!k) return;\n    var dragging=false, lastY=0;\n    function down(e){\n      dragging=true; lastY=(e.touches?e.touches[0].clientY:e.clientY);\n      k.style.cursor=\"grabbing\"; e.preventDefault();\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=lastY-y; lastY=y;\n      setParam(idx, state[idx] + dy*0.005);\n      e.preventDefault();\n    }\n    function up(){ dragging=false; k.style.cursor=\"grab\"; }\n    k.addEventListener(\"mousedown\",down);\n    k.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"mouseup\",up);\n    window.addEventListener(\"touchend\",up);\n    k.addEventListener(\"dblclick\",function(){ setParam(idx, P[idx].def); });\n    k.addEventListener(\"wheel\",function(e){\n      setParam(idx, state[idx] - Math.sign(e.deltaY)*0.02); e.preventDefault();\n    },{passive:false});\n  }\n\n  // ---- ratio stepped switch ---------------------------------------\n  function paintRatio(){\n    var sel = Math.round(state[1]);\n    var btns=document.querySelectorAll(\"#ratio button\");\n    for(var i=0;i<btns.length;i++){\n      btns[i].classList.toggle(\"on\", +btns[i].getAttribute(\"data-v\")===sel);\n    }\n    var labels=[\"2 : 1\",\"4 : 1\",\"10 : 1\"];\n    var v1=document.getElementById(\"v1\"); if(v1) v1.textContent=labels[sel]||\"\";\n  }\n  function setRatio(v, silent){\n    state[1]=v; paintRatio();\n    if(!silent) send(1, v); // real value 0/1/2\n  }\n  (function(){\n    var btns=document.querySelectorAll(\"#ratio button\");\n    for(var i=0;i<btns.length;i++){\n      (function(b){\n        b.addEventListener(\"click\",function(){ setRatio(+b.getAttribute(\"data-v\")); });\n      })(btns[i]);\n    }\n  })();\n\n  // ---- VU needle: sway driven by simulated gain reduction ----------\n  var unit=document.getElementById(\"unit\");\n  var needle=document.getElementById(\"needle\");\n  var grNum=document.getElementById(\"grNum\");\n  var simGR=0;          // displayed GR in dB (0..-18)\n  var lastChange=0;\n\n  // build ticks + numbers 0 .. -20\n  (function(){\n    var ticks=document.getElementById(\"ticks\");\n    var nums=document.getElementById(\"nums\");\n    var cx=150, cy=138, r=104;\n    // needle maps 0 dB at -52deg .. -20 dB at +52deg\n    for(var d=0; d<=20; d+=2){\n      var t=d/20;\n      var a=(-52 + t*104) * Math.PI/180;\n      var x1=cx+Math.sin(a)*r, y1=cy-Math.cos(a)*r;\n      var x2=cx+Math.sin(a)*(r-(d%4===0?11:6)), y2=cy-Math.cos(a)*(r-(d%4===0?11:6));\n      var ln=document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n      ln.setAttribute(\"x1\",x1);ln.setAttribute(\"y1\",y1);\n      ln.setAttribute(\"x2\",x2);ln.setAttribute(\"y2\",y2);\n      ticks.appendChild(ln);\n      if(d%4===0){\n        var tx=document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n        var xx=cx+Math.sin(a)*(r-22), yy=cy-Math.cos(a)*(r-22)+3;\n        tx.setAttribute(\"x\",xx);tx.setAttribute(\"y\",yy);\n        tx.textContent = d===0?\"0\":(\"-\"+d);\n        nums.appendChild(tx);\n      }\n    }\n  })();\n\n  function grToAngle(db){ // db is 0..20 (positive magnitude)\n    var t=Math.min(1, db/20);\n    return -52 + t*104;\n  }\n\n  // estimate steady-state GR from current settings + a pulsing \"mix\"\n  function estimateTargetGR(){\n    var thr = -40*state[0];          // threshold dB\n    var ratios=[2,4,10];\n    var ratio = ratios[Math.round(state[1])];\n    // pretend a mix sits around -8 dBFS with a slow breathing level\n    var lvl = -8 + 6*Math.sin(performance.now()/900) + 2*Math.sin(performance.now()/310);\n    var over = lvl - thr;\n    if(over<=0) return 0;\n    return over*(1 - 1/ratio);\n  }\n\n  function tick(){\n    var target=estimateTargetGR();\n    // smooth toward target using attack/release-flavoured coefficients\n    var atk = 0.18 + 0.5*state[2];\n    var rel = 0.02 + 0.05*(1-state[3]);\n    if(target>simGR) simGR += (target-simGR)*atk;\n    else simGR += (target-simGR)*rel;\n    var shown=Math.max(0,simGR);\n    needle.style.transform=\"rotate(\"+grToAngle(shown)+\"deg)\";\n    grNum.textContent = \"−\"+shown.toFixed(1)+\" dB\";\n    requestAnimationFrame(tick);\n  }\n\n  // ---- init --------------------------------------------------------\n  function boot(){\n    [0,2,3,4].forEach(function(i){ wireKnob(i); });\n    // initialise to defaults and push to host\n    setParam(0, state[0]);\n    setRatio(state[1]);\n    setParam(2, state[2]);\n    setParam(3, state[3]);\n    setParam(4, state[4]);\n    // disable idle CSS sway once the live needle takes over\n    unit.classList.remove(\"idle\");\n    requestAnimationFrame(tick);\n  }\n\n  var h=host();\n  if(h && typeof h.onReady===\"function\"){ h.onReady(boot); }\n  else { boot(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BUS GLUE — VCA-style stereo bus compressor (the classic mix \"glue\")\n//  A stereo-linked RMS detector feeds a dB-domain gain computer with a\n//  gentle soft knee and three switchable ratios (2:1 / 4:1 / 10:1).\n//  Stepped Attack and Release time constants (with an auto-release option\n//  baked into the slowest setting) shape a smooth gain-reduction envelope;\n//  a makeup gain restores level. Loud, dense material is gently pulled\n//  together more than quiet passages — pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (mono-linked) ------------------------------\nlet rmsEnv: f32 = 0.0;   // smoothed mean-square of the link signal\nlet grEnv:  f32 = 1.0;   // current gain-reduction multiplier (1 = no GR)\nlet arEnv:  f32 = 0.0;   // slow envelope used for the auto-release mode\n\n// exported scalar so the GUI could poll reduction if it wanted to\nlet lastGainReductionDb: f32 = 0.0;\n\nconst P_THRESH:  i32 = 0;  // 0..1 -> threshold  0 dB .. -40 dB\nconst P_RATIO:   i32 = 1;  // 0/1/2 -> 2:1 / 4:1 / 10:1\nconst P_ATTACK:  i32 = 2;  // 0..1 -> 30 ms .. 0.1 ms\nconst P_RELEASE: i32 = 3;  // 0..1 -> 0.1 s .. 1.2 s (top = auto)\nconst P_MAKEUP:  i32 = 4;  // 0..1 -> 0 .. +24 dB\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  rmsEnv = 0.0;\n  grEnv = 1.0;\n  arEnv = 0.0;\n  lastGainReductionDb = 0.0;\n  params[P_THRESH] = 0.45;\n  params[P_RATIO] = 1.0;     // 4:1\n  params[P_ATTACK] = 0.4;\n  params[P_RELEASE] = 0.5;\n  params[P_MAKEUP] = 0.3;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\nexport function getGainReductionDb(): f32 { return lastGainReductionDb; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fast-ish dB helpers in f32\n@inline function lin2db(x: f32): f32 { return f32(8.6858896 * Mathf.log(x + 1e-9)); } // 20/ln10\n@inline function db2lin(x: f32): f32 { return f32(Mathf.exp(x * 0.11512925)); }       // ln10/20\n\nexport function process(n: i32): void {\n  const thN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const ratioSel: f32 = clampf(params[P_RATIO], 0.0, 2.0);\n  const atN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const relN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const mkN: f32 = clampf(params[P_MAKEUP], 0.0, 1.0);\n\n  // Threshold: 0 dB (clean) .. -40 dB (heavy glue)\n  const threshDb: f32 = -40.0 * thN;\n\n  // Discrete ratio selector -> 2 / 4 / 10\n  const sel: i32 = i32(ratioSel + 0.5);\n  let ratio: f32 = 4.0;\n  if (sel <= 0) ratio = 2.0;\n  else if (sel == 1) ratio = 4.0;\n  else ratio = 10.0;\n  const slope: f32 = f32(1.0 - 1.0 / ratio); // amount of dB pulled back per dB over\n\n  // Soft knee width in dB (gentle bus-glue knee)\n  const knee: f32 = 6.0;\n  const halfKnee: f32 = knee * 0.5;\n\n  // Attack: 30 ms (slow) .. 0.1 ms (fast). atN=1 -> fastest.\n  const atkMs: f32 = 30.0 * f32(Mathf.pow(0.0033333, atN)); // 30 -> 0.1 ms\n  const atkCoef: f32 = f32(Mathf.exp(-1.0 / (0.001 * atkMs * sampleRate)));\n\n  // Release: 0.1 s .. 1.2 s; the very top is \"auto\" (program-dependent).\n  const autoMode: bool = relN > 0.92;\n  const relS: f32 = 0.1 + relN * 1.1;\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relS * sampleRate)));\n  // auto-release uses a dual time constant blended by recent activity\n  const relFastCoef: f32 = f32(Mathf.exp(-1.0 / (0.08 * sampleRate)));\n  const relSlowCoef: f32 = f32(Mathf.exp(-1.0 / (0.9 * sampleRate)));\n  const arCoef: f32 = f32(Mathf.exp(-1.0 / (0.25 * sampleRate)));\n\n  // RMS detector smoothing (~10 ms window)\n  const rmsCoef: f32 = f32(Mathf.exp(-1.0 / (0.010 * sampleRate)));\n\n  // Makeup 0..+24 dB\n  const makeup: f32 = db2lin(24.0 * mkN);\n\n  let rEnv: f32 = rmsEnv;\n  let g: f32 = grEnv;\n  let ar: f32 = arEnv;\n  let maxGrDb: f32 = 0.0;\n\n  const chan: i32 = channels;\n  const baseR: i32 = MAX_FRAMES; // right-channel offset\n\n  for (let f = 0; f < n; f++) {\n    const l: f32 = inBuf[f];\n    const r: f32 = chan > 1 ? inBuf[baseR + f] : l;\n\n    // stereo-linked detector: mean of squares of the two channels\n    const sq: f32 = (l * l + r * r) * 0.5;\n    rEnv = rEnv * rmsCoef + sq * (1.0 - rmsCoef);\n    const rms: f32 = f32(Mathf.sqrt(rEnv));\n    const levelDb: f32 = lin2db(rms);\n\n    // soft-knee gain computer (target gain reduction in dB, negative)\n    const over: f32 = levelDb - threshDb;\n    let grDb: f32 = 0.0;\n    if (over <= -halfKnee) {\n      grDb = 0.0;\n    } else if (over >= halfKnee) {\n      grDb = -slope * over;\n    } else {\n      // quadratic knee\n      const x: f32 = over + halfKnee; // 0..knee\n      grDb = -slope * (x * x) / (2.0 * knee);\n    }\n\n    const targetGain: f32 = db2lin(grDb); // <= 1\n\n    // smooth toward target: fast attack when pulling down, slower release up\n    if (targetGain < g) {\n      g = atkCoef * g + (1.0 - atkCoef) * targetGain;\n    } else {\n      let rc: f32 = relCoef;\n      if (autoMode) {\n        // program-dependent: blend fast/slow by how much GR is being released\n        ar = arCoef * ar + (1.0 - arCoef) * (targetGain - g);\n        const blend: f32 = clampf(ar * 40.0, 0.0, 1.0);\n        rc = relSlowCoef + (relFastCoef - relSlowCoef) * blend;\n      }\n      g = rc * g + (1.0 - rc) * targetGain;\n    }\n\n    const curGrDb: f32 = -lin2db(g);\n    if (curGrDb > maxGrDb) maxGrDb = curGrDb;\n\n    const gm: f32 = g * makeup;\n    // gentle output saturator: ~unity for normal levels, soft-bounds to ±1\n    const oL: f32 = f32(Mathf.tanh(l * gm));\n    const oR: f32 = f32(Mathf.tanh(r * gm));\n\n    outBuf[f] = oL;\n    if (chan > 1) outBuf[baseR + f] = oR;\n  }\n\n  rmsEnv = rEnv;\n  grEnv = g;\n  arEnv = ar;\n  lastGainReductionDb = maxGrDb;\n}\n",
  "publishedAt": 1751000070000
}