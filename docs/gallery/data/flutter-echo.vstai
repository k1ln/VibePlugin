{
  "format": 1,
  "name": "Flutter Echo",
  "isInstrument": false,
  "explanation": "A physically-modelled tape delay that foregrounds the wow and flutter of an unstable tape transport. The read head is modulated by a slow wow LFO plus a faster flutter LFO with a little drift, so every repeat is audibly pitch-warbled; each pass through the loop adds tape saturation and high-frequency loss, so echoes darken and degrade as they stack. The Warble control scales the modulation from subtle vintage warmth to seasick wobble. Controls: Time, Feedback, Warble, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Warble",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --ac:#ffb86a;        /* warm sepia amber accent */\n  --ac2:#9a7bff;       /* worn violet accent */\n  --deck:#2a2118;      /* deck enclosure */\n  --deck2:#1a140d;\n  --tape:#3a2c1e;      /* tape brown */\n  --ink:#f6e7cf;       /* warm cream text */\n  --dim:#b89a74;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(130% 100% at 50% -10%,#3a2c1d 0%,#241a11 50%,#120c07 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:20px;min-height:100%;\n}\n\n/* ===== deck enclosure ===== */\n.deck{\n  position:relative;\n  width:380px;max-width:96vw;\n  border-radius:18px;\n  padding:18px 20px 22px;\n  background:\n    linear-gradient(165deg,#4a3a28 0%,var(--deck) 34%,var(--deck2) 100%);\n  box-shadow:\n    0 40px 80px -22px rgba(0,0,0,.8),\n    0 2px 0 rgba(255,220,170,.10) inset,\n    0 -24px 44px -20px rgba(0,0,0,.65) inset,\n    0 0 0 2px rgba(0,0,0,.5),\n    0 0 0 5px #160f08;\n  animation:rise .7s cubic-bezier(.2,.8,.25,1) both;\n  overflow:hidden;\n}\n@keyframes rise{from{opacity:0;transform:translateY(24px) scale(.97)}to{opacity:1;transform:none}}\n/* worn-tape grain + sheen overlay */\n.deck::before{\n  content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n  background:\n    repeating-linear-gradient(98deg,rgba(255,235,200,.025) 0 1px,transparent 1px 4px),\n    radial-gradient(150% 60% at 24% -8%,rgba(255,230,190,.14),transparent 52%);\n  mix-blend-mode:screen;opacity:.75;\n}\n/* faint flicker like an aging bulb */\n.deck::after{\n  content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n  background:radial-gradient(120% 80% at 50% 120%,rgba(255,184,106,.10),transparent 60%);\n  animation:flick 5.5s ease-in-out infinite;\n}\n@keyframes flick{0%,100%{opacity:.5}43%{opacity:.78}47%{opacity:.4}71%{opacity:.66}}\n\n.screw{position:absolute;width:11px;height:11px;border-radius:50%;z-index:3;\n  background:radial-gradient(circle at 35% 30%,#e7d6b8,#8a7355 55%,#3a2e1e);\n  box-shadow:0 1px 2px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.35) inset;}\n.screw::after{content:\"\";position:absolute;inset:2.5px;border-radius:1px;\n  background:linear-gradient(45deg,transparent 44%,#5a4730 44% 56%,transparent 56%);}\n.screw.tl{top:11px;left:11px}.screw.tr{top:11px;right:11px}\n.screw.bl{bottom:11px;left:11px}.screw.br{bottom:11px;right:11px}\n\n/* ===== header ===== */\n.head{position:relative;z-index:2;text-align:center;margin:0 0 12px}\n.brand{font-size:8.5px;letter-spacing:.42em;color:var(--dim);text-transform:uppercase}\nh1{\n  margin:3px 0 0;font-size:25px;font-weight:900;letter-spacing:.04em;line-height:1;\n  font-style:italic;\n  background:linear-gradient(180deg,#fff3df,var(--ac) 52%,#c77a3a);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  filter:drop-shadow(0 2px 5px rgba(0,0,0,.45));\n}\n.sub{font-size:8px;letter-spacing:.30em;color:var(--ac2);opacity:.8;text-transform:uppercase;margin-top:5px}\n\n/* ===== tape transport window (reels + warbling repeats) ===== */\n.transport{\n  position:relative;z-index:2;height:138px;margin:2px 2px 16px;border-radius:12px;overflow:hidden;\n  background:radial-gradient(120% 150% at 50% 120%,#241a10,#0d0905 72%);\n  box-shadow:0 0 0 1px rgba(0,0,0,.6),\n             0 0 0 2px rgba(255,184,106,.07),\n             inset 0 2px 12px rgba(0,0,0,.85),\n             inset 0 0 40px rgba(255,160,90,.06);\n}\n.transport svg{position:absolute;inset:0;width:100%;height:100%}\n.transport::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:linear-gradient(180deg,rgba(255,240,215,.09),transparent 28%);}\n\n.reel{transform-origin:center;animation:spin 2.6s linear infinite}\n.reel.right{animation-duration:2.0s}\n@keyframes spin{to{transform:rotate(360deg)}}\n.reelbody{fill:#1c140c;stroke:#6a543a;stroke-width:2}\n.spoke{stroke:#7a6038;stroke-width:3;stroke-linecap:round}\n.hub{fill:url(#hubg)}\n.tapepath{fill:none;stroke:#5a4226;stroke-width:5;opacity:.85}\n\n/* repeat waveform — pitch-warbles via @keyframes wobble */\n.wavewrap{transform-origin:center;animation:wob 3.1s ease-in-out infinite}\n@keyframes wob{\n  0%,100%{transform:translateY(0) scaleY(1)}\n  22%{transform:translateY(-1.2px) scaleY(1.08) skewX(-1.4deg)}\n  47%{transform:translateY(1.4px) scaleY(.9) skewX(1.2deg)}\n  68%{transform:translateY(-.6px) scaleY(1.05) skewX(-.8deg)}\n}\n.wpath{fill:none;stroke-linecap:round;stroke-linejoin:round}\n.flutline{stroke:rgba(255,184,106,.13);stroke-width:1}\n.flow{stroke-dasharray:4 8;animation:flow 1.0s linear infinite}\n@keyframes flow{to{stroke-dashoffset:-12}}\n.pin{fill:var(--ac);filter:drop-shadow(0 0 4px var(--ac))}\n\n/* ===== knob deck ===== */\n.knobs{position:relative;z-index:2;display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin:0 1px}\n.pot{display:flex;flex-direction:column;align-items:center;gap:6px;\n  animation:pop .5s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:60px;height:60px;cursor:ns-resize;touch-action:none;user-select:none}\n.skirt{position:absolute;inset:-2px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(255,225,185,.45) 0 1deg,transparent 1deg 13.846deg);\n  -webkit-mask:radial-gradient(circle,transparent 29px,#000 30px,#000 33px,transparent 34px);\n  mask:radial-gradient(circle,transparent 29px,#000 30px,#000 33px,transparent 34px)}\n.arc{position:absolute;inset:1px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.05) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*7px) var(--ac));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1)}\n.cap{position:absolute;top:8px;left:8px;width:44px;height:44px;border-radius:50%;\n  background:radial-gradient(circle at 50% 26%,#5a4630 0%,#2a1f14 62%,#150e08 100%);\n  box-shadow:inset 0 2px 5px rgba(255,220,170,.16),inset 0 -6px 13px rgba(0,0,0,.85),0 3px 8px rgba(0,0,0,.55)}\n.cap::after{content:\"\";position:absolute;inset:10px;border-radius:50%;\n  background:radial-gradient(circle at 50% 30%,#6a533a,#1c130b);\n  box-shadow:inset 0 1px 2px rgba(255,225,180,.2)}\n.ptr{position:absolute;top:5px;left:50%;width:3px;height:17px;margin-left:-1.5px;border-radius:3px;\n  background:linear-gradient(var(--ac2),var(--ac));\n  box-shadow:0 0 7px var(--ac),0 0 2px #fff;\n  transform-origin:50% 25px;\n  transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.pname{font-size:8.5px;font-weight:800;letter-spacing:.12em;color:#1c130b;\n  background:linear-gradient(var(--ac2),var(--ac));padding:2px 8px;border-radius:999px;\n  text-transform:uppercase;box-shadow:0 1px 0 rgba(255,255,255,.3) inset,0 2px 4px rgba(0,0,0,.4)}\n.pval{font-size:11px;font-weight:800;color:var(--ink);font-variant-numeric:tabular-nums;\n  min-height:13px;text-shadow:0 0 8px rgba(255,184,106,.4)}\n.knob.act .cap{box-shadow:inset 0 2px 5px rgba(255,220,170,.18),inset 0 -6px 13px rgba(0,0,0,.85),0 3px 12px rgba(255,184,106,.55)}\n\n/* ===== VU strip ===== */\n.foot{position:relative;z-index:2;display:flex;align-items:center;justify-content:space-between;\n  margin:16px 4px 0;gap:12px}\n.vu{flex:1;height:9px;border-radius:5px;overflow:hidden;position:relative;\n  background:linear-gradient(#0d0905,#1a120a);\n  box-shadow:inset 0 1px 3px rgba(0,0,0,.8),0 0 0 1px rgba(255,184,106,.08)}\n.vufill{position:absolute;left:0;top:0;bottom:0;width:30%;\n  background:linear-gradient(90deg,#7a5a2a,var(--ac) 70%,#fff0d8);\n  box-shadow:0 0 8px var(--ac);transition:width .08s ease-out}\n.led{width:11px;height:11px;border-radius:50%;flex:0 0 auto;\n  background:radial-gradient(circle at 40% 35%,#fff0d8,var(--ac) 45%,#5a3a16 90%);\n  box-shadow:0 0 12px var(--ac),0 0 4px #fff inset;animation:ledp 2.3s ease-in-out infinite}\n@keyframes ledp{0%,100%{opacity:.8;box-shadow:0 0 7px var(--ac),0 0 3px #fff inset}\n  50%{opacity:1;box-shadow:0 0 16px var(--ac),0 0 5px #fff inset}}\n.serial{font-size:7px;letter-spacing:.16em;color:var(--dim);opacity:.55;flex:0 0 auto}\n</style>\n</head>\n<body>\n<div class=\"deck\">\n  <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n  <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n  <div class=\"head\">\n    <div class=\"brand\">Vintage Transport Series</div>\n    <h1>Flutter Echo</h1>\n    <div class=\"sub\">Wow &amp; Flutter Tape Delay</div>\n  </div>\n\n  <!-- tape transport: two reels + warbling repeat waveform -->\n  <div class=\"transport\">\n    <svg viewBox=\"0 0 380 138\" preserveAspectRatio=\"none\">\n      <defs>\n        <radialGradient id=\"hubg\" cx=\"50%\" cy=\"42%\" r=\"60%\">\n          <stop offset=\"0%\" stop-color=\"#caa873\"/>\n          <stop offset=\"60%\" stop-color=\"#6a533a\"/>\n          <stop offset=\"100%\" stop-color=\"#241a10\"/>\n        </radialGradient>\n        <linearGradient id=\"wg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"#9a7bff\"/>\n          <stop offset=\"55%\" stop-color=\"#ffb86a\"/>\n          <stop offset=\"100%\" stop-color=\"#fff0d8\"/>\n        </linearGradient>\n      </defs>\n\n      <!-- tape path between reels -->\n      <path class=\"tapepath\" d=\"M 70 92 C 130 116, 250 116, 310 92\"/>\n\n      <!-- left reel -->\n      <g class=\"reel\" id=\"reelL\" transform=\"translate(70,52)\">\n        <circle class=\"reelbody\" r=\"34\"/>\n        <circle class=\"hub\" r=\"13\"/>\n        <g class=\"spokes\">\n          <line class=\"spoke\" x1=\"0\" y1=\"-13\" x2=\"0\" y2=\"-30\"/>\n          <line class=\"spoke\" x1=\"0\" y1=\"13\" x2=\"0\" y2=\"30\"/>\n          <line class=\"spoke\" x1=\"-13\" y1=\"0\" x2=\"-30\" y2=\"0\"/>\n          <line class=\"spoke\" x1=\"13\" y1=\"0\" x2=\"30\" y2=\"0\"/>\n        </g>\n      </g>\n\n      <!-- right reel -->\n      <g class=\"reel right\" id=\"reelR\" transform=\"translate(310,52)\">\n        <circle class=\"reelbody\" r=\"34\"/>\n        <circle class=\"hub\" r=\"13\"/>\n        <g class=\"spokes\">\n          <line class=\"spoke\" x1=\"0\" y1=\"-13\" x2=\"0\" y2=\"-30\"/>\n          <line class=\"spoke\" x1=\"0\" y1=\"13\" x2=\"0\" y2=\"30\"/>\n          <line class=\"spoke\" x1=\"-13\" y1=\"0\" x2=\"-30\" y2=\"0\"/>\n          <line class=\"spoke\" x1=\"13\" y1=\"0\" x2=\"30\" y2=\"0\"/>\n        </g>\n      </g>\n\n      <!-- flutter grid -->\n      <line class=\"flutline flow\" x1=\"110\" y1=\"40\" x2=\"270\" y2=\"40\"/>\n      <line class=\"flutline flow\" x1=\"110\" y1=\"64\" x2=\"270\" y2=\"64\"/>\n\n      <!-- the warbling repeat waveforms (decaying echoes) -->\n      <g class=\"wavewrap\">\n        <path id=\"wave1\" class=\"wpath\" stroke=\"url(#wg)\" stroke-width=\"2.6\" style=\"filter:drop-shadow(0 0 5px var(--ac))\" d=\"\"/>\n        <path id=\"wave2\" class=\"wpath\" stroke=\"var(--ac2)\" stroke-width=\"1.8\" opacity=\".55\" d=\"\"/>\n        <path id=\"wave3\" class=\"wpath\" stroke=\"var(--ac)\" stroke-width=\"1.2\" opacity=\".3\" d=\"\"/>\n      </g>\n      <!-- record-head pin -->\n      <circle class=\"pin\" cx=\"190\" cy=\"52\" r=\"2.6\"/>\n    </svg>\n  </div>\n\n  <!-- knob deck -->\n  <div class=\"knobs\" id=\"knobs\"></div>\n\n  <!-- VU + status -->\n  <div class=\"foot\">\n    <div class=\"led\"></div>\n    <div class=\"vu\"><div class=\"vufill\" id=\"vu\"></div></div>\n    <div class=\"serial\">FE&middot;1751</div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Time\",    index:0,min:0,max:1,def:0.45},\n    {name:\"Feedback\",index:1,min:0,max:1,def:0.5},\n    {name:\"Warble\",  index:2,min:0,max:1,def:0.4},\n    {name:\"Tone\",    index:3,min:0,max:1,def:0.55},\n    {name:\"Mix\",     index:4,min:0,max:1,def:0.5}\n  ];\n  var state={};\n  var knobsEl=document.getElementById('knobs');\n  var w1=document.getElementById('wave1');\n  var w2=document.getElementById('wave2');\n  var w3=document.getElementById('wave3');\n  var wrap=document.querySelector('.wavewrap');\n  var reelL=document.getElementById('reelL');\n  var reelR=document.getElementById('reelR');\n  var vu=document.getElementById('vu');\n\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*65)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"skirt\"></i>'+\n        '<i class=\"arc\"></i>'+\n        '<i class=\"cap\"></i>'+\n        '<i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    knobsEl.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var ptr=cell.querySelector('.ptr');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n);\n      ptr.style.setProperty('--n',n);\n      val.textContent=pct(n);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(n){\n      n=n<0?0:n>1?1:n;\n      v=p.min+(p.max-p.min)*n;\n      paint();\n    }\n\n    var drag=false, startY=0, startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true; startY=e.clientY; startN=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?700:230;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault(); setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ---- live repeat-waveform shaping from the params ----\n  function buildWave(amp,warble,tone,phaseShift,cycles){\n    var pts=[], N=90;\n    for(var x=0;x<=N;x++){\n      var t=x/N;\n      var ph=t*Math.PI*2*cycles + phaseShift;\n      // wow (slow) + flutter (fast) pitch-warble baked into the phase\n      var wow=Math.sin(t*Math.PI*1.0)*warble*1.1;\n      var flut=Math.sin(t*Math.PI*9.0)*warble*0.45;\n      var s=Math.sin(ph + wow + flut);\n      // tone darkens => softer/rounder top end\n      s*= (0.55+0.45*tone);\n      var px=110 + t*160;\n      var py=52 - s*amp;\n      pts.push(px.toFixed(1)+\",\"+py.toFixed(1));\n    }\n    return 'M'+pts.join(' L');\n  }\n\n  function onChange(){\n    var time=state[0]!=null?state[0]:0.45;\n    var fb  =state[1]!=null?state[1]:0.5;\n    var warb=state[2]!=null?state[2]:0.4;\n    var tone=state[3]!=null?state[3]:0.55;\n    var mix =state[4]!=null?state[4]:0.5;\n\n    // more repeats visible with higher feedback\n    w1.setAttribute('d',buildWave(15, warb, tone, 0,   2.0));\n    w2.setAttribute('d',buildWave(11, warb, tone, 1.1, 2.0));\n    w3.setAttribute('d',buildWave(7,  warb, tone, 2.2, 2.0));\n    w2.style.opacity=(0.18+fb*0.6).toFixed(2);\n    w3.style.opacity=(0.05+fb*0.5).toFixed(2);\n\n    // warble drives the wobble animation strength + speed\n    var wobDur=(4.2 - warb*2.6).toFixed(2)+'s';\n    wrap.style.animationDuration=wobDur;\n    // longer Time => slower reels\n    var spinL=(1.6 + time*2.4).toFixed(2)+'s';\n    reelL.style.animationDuration=spinL;\n    reelR.style.animationDuration=(parseFloat(spinL)*0.78).toFixed(2)+'s';\n\n    // VU reflects wet energy (mix * (1+feedback))\n    var energy=Math.min(1, mix*(0.5+fb*0.9)+0.1);\n    vu.style.width=(12+energy*86).toFixed(0)+'%';\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ onChange(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  FLUTTER ECHO — a physically-modelled tape delay foregrounding the\n//  WOW & FLUTTER of an unstable tape transport. A delay line whose read\n//  head is modulated by a slow WOW LFO plus a faster FLUTTER LFO (with a\n//  little drift), so every repeat is pitch-warbled. Each pass through the\n//  loop adds tape saturation and high-frequency loss, so echoes degrade\n//  and darken as they stack. The Warble control scales the modulation\n//  from subtle vintage warmth to seasick, sea-sick wobble.\n//\n//  Params: Time, Feedback, Warble (wow+flutter depth), Tone (HF loss), Mix.\n//  Pure algorithm, no samples. All math in f32.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\n// delay line: ~1.2 s per channel at 48k gives plenty of range\nconst DELAY_LEN: i32 = 65536; // power of two, ~1.36 s @ 48k\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// one delay line per channel (flattened: channel c at c * DELAY_LEN)\nconst delay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;            // shared write head (advances per frame)\n\n// per-channel feedback-loop HF-loss state (tape darkens repeats)\nconst loopLP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// wow / flutter LFO phases (shared transport, slight stereo offset)\nlet wowPhase: f32 = 0.0;\nlet flutPhase: f32 = 0.0;\nlet driftPhase: f32 = 0.0;\n\n// smoothed target delay (samples) so Time changes glide like a real motor\nlet curDelaySamp: f32 = 12000.0;\n\nconst P_TIME: i32 = 0;     // 0..1 -> 40..900 ms\nconst P_FEEDBACK: i32 = 1; // 0..1 -> 0..0.95\nconst P_WARBLE: i32 = 2;   // 0..1 -> wow+flutter depth\nconst P_TONE: i32 = 3;     // 0..1 -> loop HF loss (dark..bright)\nconst P_MIX: i32 = 4;      // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DELAY_LEN * MAX_CHANNELS; i++) delay[i] = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) loopLP[c] = 0.0;\n  writePos = 0;\n  wowPhase = 0.0;\n  flutPhase = 0.0;\n  driftPhase = 0.0;\n  curDelaySamp = 0.30 * sampleRate;\n  params[P_TIME] = 0.45;\n  params[P_FEEDBACK] = 0.5;\n  params[P_WARBLE] = 0.4;\n  params[P_TONE] = 0.55;\n  params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// soft tape-style saturation (odd-symmetric, gentle compression)\n@inline function tapeSat(x: f32): f32 {\n  // tanh-like with cheap rational approximation, bounded to ~±1\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// read the delay line for channel `c` at a fractional position `back`\n// samples behind the write head, with linear interpolation\n@inline function readDelay(c: i32, back: f32): f32 {\n  let rp: f32 = f32(writePos) - back;\n  // wrap into [0, DELAY_LEN)\n  while (rp < 0.0) rp += f32(DELAY_LEN);\n  while (rp >= f32(DELAY_LEN)) rp -= f32(DELAY_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 -= DELAY_LEN;\n  const frac: f32 = rp - f32(i0);\n  const base: i32 = c * DELAY_LEN;\n  const a: f32 = delay[base + i0];\n  const b: f32 = delay[base + i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const warbleN: f32 = clampf(params[P_WARBLE], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // target delay 40..900 ms\n  const timeMs: f32 = 40.0 + timeN * 860.0;\n  const targetSamp: f32 = clampf(timeMs * 0.001 * sampleRate, 8.0, f32(DELAY_LEN - 4));\n\n  // feedback up to 0.95 (bounded — never self-oscillate to clipping)\n  const feedback: f32 = fbN * 0.95;\n\n  // loop HF loss: Tone bright -> higher cutoff (less loss per repeat)\n  const toneHz: f32 = 1200.0 + toneN * toneN * 8000.0;\n  const cTone: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * toneHz / sampleRate)), 0.0, 1.0);\n\n  // wow: slow ~0.45 Hz, large excursion. flutter: ~7 Hz, small but fast.\n  // depths in SAMPLES, scaled by Warble (squared for a gentle low end).\n  const w2: f32 = warbleN * warbleN;\n  const wowHz: f32 = 0.45;\n  const flutHz: f32 = 6.7;\n  const driftHz: f32 = 0.11;\n  // excursions grow with both Warble and the delay length (longer tape = more wow)\n  const wowDepth: f32 = w2 * (0.012 * targetSamp + 6.0);   // up to ~1.2% of delay\n  const flutDepth: f32 = w2 * (0.0016 * targetSamp + 3.0); // fast jitter\n  const wowInc: f32 = PI2 * wowHz / sampleRate;\n  const flutInc: f32 = PI2 * flutHz / sampleRate;\n  const driftInc: f32 = PI2 * driftHz / sampleRate;\n\n  // glide coefficient for the motor (Time moves smoothly, not instantly)\n  const glide: f32 = clampf(80.0 / sampleRate, 0.0, 1.0);\n\n  // input drive into the tape (a touch of pre-gain for saturation character)\n  const inGain: f32 = 0.9;\n\n  // We advance the LFOs and write head once per FRAME (shared across channels),\n  // so process channels in an interleaved-by-frame manner.\n  let wPhase: f32 = wowPhase;\n  let fPhase: f32 = flutPhase;\n  let dPhase: f32 = driftPhase;\n  let dSamp: f32 = curDelaySamp;\n  let wpos: i32 = writePos;\n\n  const ch: i32 = channels;\n\n  for (let f = 0; f < n; f++) {\n    // glide the base delay toward target (motor inertia)\n    dSamp += glide * (targetSamp - dSamp);\n\n    // composite warble modulation (samples). Stereo handled per-channel via offset.\n    const wow: f32 = Mathf.sin(wPhase);\n    const drift: f32 = Mathf.sin(dPhase);\n    const flut: f32 = Mathf.sin(fPhase) + 0.4 * Mathf.sin(fPhase * 2.3);\n    // base modulation shared; per-channel adds a phase offset for stereo width\n    const modBase: f32 = wowDepth * (wow + 0.25 * drift) + flutDepth * flut;\n\n    for (let c = 0; c < ch; c++) {\n      // slight stereo decorrelation of the warble (right lags)\n      const chOff: f32 = c == 0 ? 0.0 : 0.6;\n      const wowC: f32 = Mathf.sin(wPhase + chOff);\n      const flutC: f32 = Mathf.sin(fPhase + chOff * 1.7);\n      const mod: f32 = c == 0\n        ? modBase\n        : wowDepth * (wowC + 0.25 * drift) + flutDepth * flutC;\n\n      const back: f32 = clampf(dSamp + mod, 4.0, f32(DELAY_LEN - 4));\n\n      const x: f32 = inBuf[c * MAX_FRAMES + f] * inGain;\n      let echo: f32 = readDelay(c, back);\n\n      // tape HF loss inside the loop (darken each repeat)\n      let lp: f32 = loopLP[c];\n      lp = lp + cTone * (echo - lp);\n      loopLP[c] = lp;\n      echo = lp;\n\n      // what we record back to tape: input + saturated feedback of the echo\n      const recorded: f32 = tapeSat(x + echo * feedback);\n\n      const base: i32 = c * DELAY_LEN;\n      delay[base + wpos] = recorded;\n\n      // wet = the (already-filtered) echo, dry = input/inGain\n      const dry: f32 = inBuf[c * MAX_FRAMES + f];\n      const wet: f32 = echo;\n      let outv: f32 = dry * (1.0 - mix) + wet * mix;\n      outBuf[c * MAX_FRAMES + f] = clampf(outv, -1.2, 1.2);\n    }\n\n    // advance shared transport state once per frame\n    wpos++;\n    if (wpos >= DELAY_LEN) wpos -= DELAY_LEN;\n    wPhase += wowInc; if (wPhase >= PI2) wPhase -= PI2;\n    fPhase += flutInc; if (fPhase >= PI2) fPhase -= PI2;\n    dPhase += driftInc; if (dPhase >= PI2) dPhase -= PI2;\n  }\n\n  writePos = wpos;\n  wowPhase = wPhase;\n  flutPhase = fPhase;\n  driftPhase = dPhase;\n  curDelaySamp = dSamp;\n}\n",
  "publishedAt": 1751000149000
}