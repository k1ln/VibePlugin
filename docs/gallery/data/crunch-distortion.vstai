{
  "format": 1,
  "name": "Crunch Distortion",
  "isInstrument": false,
  "explanation": "A bright transistor-boost distortion with aggressive midrange and asymmetric op-amp clipping for even-harmonic grit. The active Tone control tilts the spectrum, cutting lows while boosting highs (and vice-versa). Controls: Dist, Tone, Level and dry/wet Mix.",
  "params": [
    {
      "name": "Dist",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Level",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n  @property --n0{syntax:'<number>';inherits:false;initial-value:0}\n  :root{\n    --ac:#ff9e2c; --ac2:#ffd166;\n    --hot:#ff5b1a; --rust:#7a2e08;\n    --plate:#13110d; --steel:#2a2620;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0;\n    font:13px \"Arial Black\",ui-sans-serif,system-ui,sans-serif;\n    color:#f3ede0;\n    background:\n      radial-gradient(120% 90% at 50% -10%,#20160a 0%,#0c0906 55%,#040302 100%);\n    display:flex;align-items:center;justify-content:center;\n    padding:18px;overflow:hidden;\n    -webkit-user-select:none;user-select:none;\n  }\n\n  /* ===== THE PEDAL ===== */\n  .pedal{\n    position:relative;width:100%;max-width:430px;\n    padding:18px 18px 22px;\n    /* hard angular clipped corners — not a rounded card */\n    clip-path:polygon(0 16px,16px 0,calc(100% - 16px) 0,100% 16px,100% calc(100% - 28px),calc(100% - 28px) 100%,28px 100%,0 calc(100% - 28px));\n    background:\n      linear-gradient(160deg,#ff8a1e 0%,#ff6a10 38%,#e0530a 62%,#b53f06 100%);\n    box-shadow:\n      0 28px 60px rgba(0,0,0,.65),\n      0 2px 0 rgba(255,210,150,.5) inset,\n      0 -3px 14px rgba(80,20,0,.6) inset;\n    isolation:isolate;\n    animation:rumble 5.2s ease-in-out infinite;\n  }\n  /* brushed-metal scanlines + grime over the orange */\n  .pedal::before{\n    content:\"\";position:absolute;inset:0;z-index:0;pointer-events:none;\n    clip-path:inherit;\n    background:\n      repeating-linear-gradient(180deg,rgba(255,255,255,.05) 0 1px,transparent 1px 4px),\n      radial-gradient(140% 80% at 30% 0%,rgba(255,255,255,.18),transparent 55%),\n      radial-gradient(120% 70% at 80% 110%,rgba(50,12,0,.55),transparent 60%);\n    mix-blend-mode:overlay;\n  }\n  /* riveted dark inner faceplate */\n  .face{\n    position:relative;z-index:1;\n    padding:16px 16px 18px;\n    clip-path:polygon(0 10px,10px 0,calc(100% - 10px) 0,100% 10px,100% calc(100% - 18px),calc(100% - 18px) 100%,18px 100%,0 calc(100% - 18px));\n    background:linear-gradient(165deg,#1b1813,#0b0907 70%);\n    box-shadow:0 0 0 2px rgba(0,0,0,.6),0 6px 20px rgba(0,0,0,.55) inset;\n  }\n  .rivet{position:absolute;width:9px;height:9px;border-radius:50%;z-index:3;\n    background:radial-gradient(circle at 35% 30%,#fff3df,#b87b30 55%,#3a2208);\n    box-shadow:0 1px 2px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.4)}\n  .r1{top:8px;left:8px}.r2{top:8px;right:8px}.r3{bottom:34px;left:8px}.r4{bottom:34px;right:8px}\n\n  /* ===== HEADER ===== */\n  .hd{display:flex;align-items:center;gap:10px;margin-bottom:12px}\n  .bolt{\n    width:30px;height:30px;flex:none;position:relative;\n    filter:drop-shadow(0 0 6px var(--ac));\n    animation:zap 2.6s steps(1) infinite;\n  }\n  h1{\n    margin:0;font-size:19px;line-height:.95;letter-spacing:.04em;\n    font-weight:900;text-transform:uppercase;font-style:italic;\n    color:#fff;\n    text-shadow:\n      2px 2px 0 var(--hot), 3px 3px 0 var(--rust),\n      0 0 14px rgba(255,120,30,.55);\n    transform:skewX(-6deg);\n  }\n  h1 small{display:block;font-size:8.5px;letter-spacing:.42em;font-style:normal;\n    transform:skewX(6deg);color:var(--ac2);text-shadow:none;margin-top:3px;font-weight:700}\n  .grade{margin-left:auto;font-size:8px;letter-spacing:.18em;font-weight:800;\n    color:#0a0805;background:var(--ac);padding:4px 7px;text-transform:uppercase;\n    clip-path:polygon(8% 0,100% 0,92% 100%,0 100%);transform:skewX(-6deg)}\n\n  /* ===== CLIPPING SCOPE ===== */\n  .scope{\n    position:relative;height:96px;margin-bottom:14px;overflow:hidden;\n    clip-path:polygon(0 6px,6px 0,calc(100% - 6px) 0,100% 6px,100% calc(100% - 6px),calc(100% - 6px) 100%,6px 100%,0 calc(100% - 6px));\n    background:radial-gradient(120% 120% at 50% 50%,#1a0d04,#070402 85%);\n    box-shadow:0 0 0 2px #000 inset,0 0 22px rgba(255,90,20,.18) inset;\n  }\n  .scope .gridlines{position:absolute;inset:0;\n    background:\n      repeating-linear-gradient(90deg,rgba(255,120,40,.08) 0 1px,transparent 1px 22px),\n      repeating-linear-gradient(0deg,rgba(255,120,40,.08) 0 1px,transparent 1px 16px)}\n  .scope .clipline{position:absolute;left:0;right:0;height:1px;background:var(--hot);\n    box-shadow:0 0 6px var(--hot);opacity:.5}\n  .scope .clipline.hi{top:18%}.scope .clipline.lo{bottom:18%}\n  .scope svg{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .scope .wave{fill:none;stroke:url(#wg);stroke-width:2.4;\n    filter:drop-shadow(0 0 5px var(--hot));stroke-linejoin:round;stroke-linecap:round}\n  .scope .wglow{fill:none;stroke:var(--ac);stroke-width:6;opacity:.18;\n    filter:blur(3px);stroke-linejoin:round}\n  .scope .tag{position:absolute;top:5px;left:7px;font-size:7.5px;letter-spacing:.22em;\n    color:var(--ac2);font-weight:800;text-shadow:0 0 6px rgba(255,160,40,.5)}\n  .scope .meta{position:absolute;top:5px;right:7px;font-size:7.5px;letter-spacing:.12em;\n    color:var(--ac);font-weight:800;font-variant-numeric:tabular-nums}\n\n  /* ===== KNOB ROW ===== */\n  .row{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}\n  .ctl{display:flex;flex-direction:column;align-items:center;gap:6px;\n    animation:pop .5s both;animation-delay:var(--d)}\n  .knob{position:relative;width:78px;height:78px;cursor:ns-resize;touch-action:none}\n  /* angular notched bezel */\n  .bezel{position:absolute;inset:0;border-radius:50%;\n    background:conic-gradient(#0c0a07,#2a241b,#0c0a07,#322a1f,#0c0a07);\n    box-shadow:0 4px 10px rgba(0,0,0,.6),0 0 0 1px rgba(255,180,90,.12) inset}\n  /* the active arc that fills as you turn it up */\n  .arc{position:absolute;inset:4px;border-radius:50%;\n    background:conic-gradient(from 225deg,\n      var(--hot) calc(var(--n0,0)*270deg),\n      rgba(255,255,255,.06) calc(var(--n0,0)*270deg) 270deg,\n      transparent 270deg);\n    -webkit-mask:radial-gradient(circle,transparent 30px,#000 31px);\n    mask:radial-gradient(circle,transparent 30px,#000 31px);\n    filter:drop-shadow(0 0 calc(2px + var(--n0,0)*8px) var(--hot));\n    transition:--n0 .12s cubic-bezier(.2,.8,.2,1)}\n  /* hexagonal metal cap — distinct, hard-edged */\n  .cap{position:absolute;top:13px;left:13px;width:52px;height:52px;\n    clip-path:polygon(50% 0,93% 25%,93% 75%,50% 100%,7% 75%,7% 25%);\n    background:\n      radial-gradient(circle at 50% 28%,#5a4a36 0%,#2a2117 55%,#100c07 100%);\n    box-shadow:0 2px 6px rgba(0,0,0,.7) inset,0 1px 0 rgba(255,200,130,.18) inset;\n    transform:rotate(calc((var(--n0,0) - .5)*270deg));\n    transition:transform .12s cubic-bezier(.2,.8,.2,1)}\n  .cap::after{content:\"\";position:absolute;top:3px;left:50%;width:3px;height:14px;\n    margin-left:-1.5px;border-radius:1px;background:var(--ac2);\n    box-shadow:0 0 7px var(--ac)}\n  .knob.act .arc{filter:drop-shadow(0 0 14px var(--hot))}\n  .nm{font-size:9.5px;letter-spacing:.16em;font-weight:800;color:#1a120a;\n    background:linear-gradient(var(--ac2),var(--ac));padding:2px 8px;\n    text-transform:uppercase;clip-path:polygon(8% 0,100% 0,92% 100%,0 100%);\n    transform:skewX(-6deg);box-shadow:0 1px 3px rgba(0,0,0,.4)}\n  .val{font-size:13px;font-weight:900;color:var(--ac2);font-variant-numeric:tabular-nums;\n    text-shadow:0 0 8px rgba(255,160,40,.4);font-style:italic}\n\n  /* ===== FOOTSWITCH ===== */\n  .foot{display:flex;align-items:center;gap:10px;margin-top:16px}\n  .stomp{width:40px;height:40px;flex:none;border-radius:50%;position:relative;cursor:pointer;\n    background:radial-gradient(circle at 40% 30%,#e8ecf2,#9aa3b0 55%,#4a525e);\n    box-shadow:0 5px 0 #1c2026,0 8px 14px rgba(0,0,0,.6),0 1px 2px rgba(255,255,255,.5) inset;\n    transition:transform .07s,box-shadow .07s}\n  .stomp:active{transform:translateY(3px);box-shadow:0 2px 0 #1c2026,0 4px 8px rgba(0,0,0,.6)}\n  .engaged{display:flex;align-items:center;gap:8px;font-size:8.5px;letter-spacing:.2em;\n    font-weight:800;color:var(--ac2);text-transform:uppercase}\n  .led{width:11px;height:11px;border-radius:50%;background:var(--hot);\n    box-shadow:0 0 12px var(--hot),0 0 3px #fff inset;animation:throb 1.4s ease-in-out infinite}\n  . serial{margin-left:auto}\n  .serial{margin-left:auto;font-size:8px;letter-spacing:.18em;color:#3a2c1a;font-weight:800}\n\n  /* ===== ANIMATIONS ===== */\n  @keyframes pop{from{opacity:0;transform:translateY(12px) scale(.85)}to{opacity:1;transform:none}}\n  @keyframes throb{0%,100%{opacity:.45;box-shadow:0 0 6px var(--hot)}50%{opacity:1;box-shadow:0 0 16px var(--hot),0 0 4px #fff inset}}\n  @keyframes rumble{0%,100%{transform:translate(0,0)}25%{transform:translate(-.5px,.4px)}50%{transform:translate(.4px,-.3px)}75%{transform:translate(-.3px,-.4px)}}\n  @keyframes zap{0%,90%,100%{opacity:1}45%,55%{opacity:.35}}\n  @media (prefers-reduced-motion:reduce){\n    .pedal,.bolt,.led{animation:none}\n  }\n</style>\n</head>\n<body>\n  <div class=\"pedal\">\n    <i class=\"rivet r1\"></i><i class=\"rivet r2\"></i><i class=\"rivet r3\"></i><i class=\"rivet r4\"></i>\n    <div class=\"face\">\n      <div class=\"hd\">\n        <svg class=\"bolt\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n          <polygon points=\"13,2 4,13 11,13 9,22 20,9 13,9\" fill=\"#ffd166\" stroke=\"#7a2e08\" stroke-width=\"1\"/>\n        </svg>\n        <h1>Crunch<small>Distortion</small></h1>\n        <span class=\"grade\">Overdrive</span>\n      </div>\n\n      <!-- live clipping waveform -->\n      <div class=\"scope\">\n        <div class=\"gridlines\"></div>\n        <div class=\"clipline hi\"></div>\n        <div class=\"clipline lo\"></div>\n        <span class=\"tag\">CLIP&nbsp;TRACE</span>\n        <span class=\"meta\" id=\"meta\">+0.0dB</span>\n        <svg viewBox=\"0 0 400 96\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"wg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#ffd166\"/>\n              <stop offset=\".5\" stop-color=\"#ff5b1a\"/>\n              <stop offset=\"1\" stop-color=\"#ffd166\"/>\n            </linearGradient>\n          </defs>\n          <path class=\"wglow\" id=\"wglow\" d=\"\"/>\n          <path class=\"wave\" id=\"wave\" d=\"\"/>\n        </svg>\n      </div>\n\n      <!-- knobs (wired in JS) -->\n      <div class=\"row\" id=\"row\"></div>\n\n      <div class=\"foot\">\n        <div class=\"stomp\" id=\"stomp\" title=\"bypass (visual)\"></div>\n        <div class=\"engaged\"><span class=\"led\" id=\"led\"></span><span id=\"engtxt\">Engaged</span></div>\n        <span class=\"serial\">MOD&middot;CR-1</span>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // ---- exact param contract from spec.json ----\n  var PARAMS=[\n    {name:\"Dist\", index:0, min:0, max:1, def:0.5},\n    {name:\"Tone\", index:1, min:0, max:1, def:0.5},\n    {name:\"Level\",index:2, min:0, max:1, def:0.6},\n    {name:\"Mix\",  index:3, min:0, max:1, def:1}\n  ];\n  var state={0:0.5,1:0.5,2:0.6,3:1};\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmt(v){ return Math.round(v*100)+\"%\"; }\n\n  // ---- build knobs ----\n  var row=document.getElementById('row');\n  PARAMS.forEach(function(p,idx){\n    var ctl=document.createElement('div');\n    ctl.className='ctl'; ctl.style.setProperty('--d',(idx*70)+'ms');\n    ctl.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<div class=\"bezel\"></div>'+\n        '<div class=\"arc\"></div>'+\n        '<div class=\"cap\"></div>'+\n      '</div>'+\n      '<div class=\"nm\">'+p.name+'</div>'+\n      '<div class=\"val\"></div>';\n    row.appendChild(ctl);\n\n    var knob=ctl.querySelector('.knob');\n    var arc=ctl.querySelector('.arc');\n    var cap=ctl.querySelector('.cap');\n    var val=ctl.querySelector('.val');\n    var cur=p.def;\n\n    function norm(){ return (cur-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n0',n);\n      cap.style.setProperty('--n0',n);\n      val.textContent=fmt(n);\n      state[p.index]=cur;\n      send(p.index,cur);\n    }\n    function setN(n){\n      n=n<0?0:(n>1?1:n);\n      cur=p.min+(p.max-p.min)*n;\n      paint();\n    }\n\n    var dragging=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      dragging=true; startY=e.clientY; startN=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!dragging) return;\n      setN(startN+(startY-e.clientY)/200);\n    });\n    function end(){ dragging=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ cur=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault(); setN(norm()+(e.deltaY<0?0.03:-0.03));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){ setN(norm()+0.03); e.preventDefault(); }\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){ setN(norm()-0.03); e.preventDefault(); }\n    });\n\n    paint();\n  });\n\n  // ---- animated clipping waveform ----\n  // Dist tightens the soft-clip threshold; Tone tilts the spectrum (adds a\n  // bright upper partial); Level sets amplitude; Mix blends clean<->crushed.\n  var wave=document.getElementById('wave');\n  var wglow=document.getElementById('wglow');\n  var meta=document.getElementById('meta');\n  var W=400,H=96,MID=H/2,N=140;\n  var t=0;\n  function softclip(x,drive){\n    // asymmetric op-amp style: positive side clips harder\n    var k=1+drive*14;\n    var y=Math.tanh(x*k);\n    if(x>0) y=Math.tanh(x*k*1.35); // even-harmonic asymmetry\n    return y/Math.tanh(k*0.9);\n  }\n  function frame(){\n    var dist=state[0], tone=state[1], level=state[2], mix=state[3];\n    var amp=(0.18+level*0.78);\n    var thresh=(1-dist*0.86); // visual clip ceiling shrinks with Dist\n    document.querySelector('.clipline.hi').style.top=(MID-thresh*MID*0.84)/H*100+'%';\n    document.querySelector('.clipline.lo').style.bottom=(MID-thresh*MID*0.84)/H*100+'%';\n    var d='M ';\n    for(var i=0;i<=N;i++){\n      var ph=i/N;\n      var x=ph*W;\n      // base tone + Tone-driven bright partial\n      var sig=Math.sin(ph*Math.PI*2*2 + t)\n            + tone*0.55*Math.sin(ph*Math.PI*2*6 + t*1.7);\n      sig*=0.62;\n      var crushed=softclip(sig,dist);\n      var clean=sig;\n      var y=clean*(1-mix)+crushed*mix;\n      // clamp to the visible clip ceiling so flat-tops are obvious\n      var ceil=thresh;\n      if(y>ceil) y=ceil; if(y<-ceil) y=-ceil;\n      var py=MID - y*amp*MID*0.92;\n      d+=(i?'L ':'')+x.toFixed(1)+' '+py.toFixed(1)+' ';\n    }\n    wave.setAttribute('d',d);\n    wglow.setAttribute('d',d);\n    var db=(level*level*40-30)+dist*8;\n    meta.textContent=(db>=0?'+':'')+db.toFixed(1)+'dB';\n    t+=0.09;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- footswitch (visual engage/bypass; does not alter params) ----\n  var engaged=true;\n  var stomp=document.getElementById('stomp');\n  var led=document.getElementById('led');\n  var engtxt=document.getElementById('engtxt');\n  stomp.addEventListener('click',function(){\n    engaged=!engaged;\n    led.style.animationPlayState=engaged?'running':'paused';\n    led.style.opacity=engaged?'':'0.12';\n    engtxt.textContent=engaged?'Engaged':'Bypassed';\n    document.querySelector('.scope').style.filter=engaged?'':'grayscale(.7) brightness(.6)';\n  });\n\n  // ---- ready / re-sync to host defaults ----\n  function ready(){ PARAMS.forEach(function(p){ send(p.index,state[p.index]); }); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CRUNCH DISTORTION — bright transistor-boost + asymmetric op-amp clip\n//  An original model of the classic orange-box distortion pedal: a\n//  transistor input boost shapes a hard midrange, an asymmetric op-amp\n//  clipping stage adds even-harmonic grit and bias, then an ACTIVE tone\n//  tilt cuts lows while boosting highs (and vice-versa). Output level and\n//  a dry/wet Mix finish. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst hpState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-clip DC/low blocker (one-pole LP for HP)\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post-clip DC blocker (removes asym bias offset)\nconst tiltLoSt:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone tilt: low-band one-pole LP\nconst tiltHiSt:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone tilt: high-band one-pole LP (for HP)\n\nconst P_DIST:  i32 = 0;  // 0..1 -> input boost gain 1..120 (transistor + op-amp drive)\nconst P_TONE:  i32 = 1;  // 0..1 -> active tilt: 0 = dark (boost lows), 1 = bright (boost highs)\nconst P_LEVEL: i32 = 2;  // 0..1 -> output 0..1.2\nconst P_MIX:   i32 = 3;  // 0..1 dry/wet\n\nconst PI: f32 = 3.14159265;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    hpState[c] = 0.0; dcState[c] = 0.0; tiltLoSt[c] = 0.0; tiltHiSt[c] = 0.0;\n  }\n  params[P_DIST] = 0.5; params[P_TONE] = 0.5; params[P_LEVEL] = 0.6; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// one-pole smoothing coefficient for a corner frequency in Hz\n@inline function onePole(hz: f32): f32 {\n  return f32(1.0 - Mathf.exp(-2.0 * PI * hz / sampleRate));\n}\n\n// Asymmetric op-amp clipping. tanh-style soft saturation but with a small\n// positive bias so the positive and negative halves clip differently —\n// this is the signature even-harmonic grit of the orange-box circuit.\n@inline function clipAsym(x: f32): f32 {\n  // bias shifts the operating point; positive excursions saturate sooner\n  const b: f32 = f32(x + 0.18);\n  const t: f32 = f32(Mathf.tanh(b));\n  // harder edge on the positive lobe: blend tanh with a steeper folded curve\n  const hard: f32 = f32(t * (1.0 + 0.25 * t * t));\n  return f32(hard - 0.178);  // remove most of the static bias offset\n}\n\nexport function process(n: i32): void {\n  const dist01: f32 = clampf(params[P_DIST], 0.0, 1.0);\n  const tone01: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.2;\n  const mix:    f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Transistor boost: exponential-ish gain so the knob has musical taper.\n  const drive: f32 = f32(1.0 + dist01 * dist01 * 119.0);\n\n  // Pre-clip high-pass ~110 Hz: tightens lows so the midrange stays articulate.\n  const cHP: f32 = onePole(110.0);\n  // Post-clip DC blocker corner (slow) to null the asymmetric bias offset.\n  const cDC: f32 = onePole(15.0);\n\n  // Active tone tilt. Split into a low band (LP @ ~720 Hz) and a high band\n  // (HP @ ~720 Hz). tone01=0 -> lows up / highs down; tone01=1 -> opposite.\n  const cTilt: f32 = onePole(720.0);\n  const loGain: f32 = f32(1.4 - tone01 * 1.1);   // 1.4 .. 0.3\n  const hiGain: f32 = f32(0.3 + tone01 * 1.7);   // 0.3 .. 2.0\n\n  // Gain compensation so increasing Dist crunches rather than just gets louder.\n  const comp: f32 = f32(0.62 / Mathf.sqrt(drive) + 0.18);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let hp: f32 = hpState[c];\n    let dc: f32 = dcState[c];\n    let tl: f32 = tiltLoSt[c];\n    let th: f32 = tiltHiSt[c];\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // --- pre-clip tightening high-pass ---\n      hp = f32(hp + cHP * (x - hp));\n      const pre: f32 = f32(x - hp);\n\n      // --- transistor boost into asymmetric op-amp clipping ---\n      const clipped: f32 = f32(clipAsym(pre * drive) * comp);\n\n      // --- post-clip DC blocker (removes residual asymmetric offset) ---\n      dc = f32(dc + cDC * (clipped - dc));\n      const noDC: f32 = f32(clipped - dc);\n\n      // --- active tone tilt (low band vs high band) ---\n      tl = f32(tl + cTilt * (noDC - tl));   // low band\n      const lowB: f32 = tl;\n      th = f32(th + cTilt * (noDC - th));   // tracking LP for HP\n      const highB: f32 = f32(noDC - th);\n      const toned: f32 = f32(lowB * loGain + highB * hiGain);\n\n      const wet: f32 = f32(toned * level);\n      outBuf[base + f] = f32(x * (1.0 - mix) + wet * mix);\n    }\n    hpState[c] = hp;\n    dcState[c] = dc;\n    tiltLoSt[c] = tl;\n    tiltHiSt[c] = th;\n  }\n}\n",
  "publishedAt": 1751000009000
}