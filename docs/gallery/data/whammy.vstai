{
  "format": 1,
  "name": "Whammy",
  "isInstrument": false,
  "explanation": "An extreme expression-pedal pitch shifter. A dual-pointer, crossfaded delay-line shifter chases a target pitch ratio that the Pedal sweeps from dry (heel) to full shift (toe), so you can dive-bomb and soar in real time. Mode selects the direction — 0 up, 1 down, 2 a shimmering dual-octave stack — across a wide ±24-semitone Pitch range. Crossfaded read pointers keep big pitch leaps and dives click-free. Controls: Pitch, Pedal, Mode and dry/wet Mix.",
  "params": [
    {
      "name": "Pitch",
      "index": 0,
      "min": -24,
      "max": 24,
      "default": 12
    },
    {
      "name": "Pedal",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 2,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Whammy</title>\n<style>\n  :root{\n    --accent:#ff3b5c; --accent2:#ff8a3b;\n    --ink:#1a0d10; --steel:#cfd4da; --steel2:#9aa3ad;\n    --panel:#181014;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:\"Avenir Next\",\"Segoe UI\",system-ui,sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a161c 0%, #120a0d 55%, #080506 100%);\n    color:#fff;overflow:hidden;display:flex;align-items:center;justify-content:center;\n  }\n  .stage{\n    width:540px;max-width:96vw;aspect-ratio:540/700;position:relative;\n    perspective:1200px;\n  }\n\n  /* ---- pedal chassis ---- */\n  .pedal{\n    position:absolute;inset:0;border-radius:34px;\n    background:linear-gradient(160deg,#ff5570 0%,var(--accent) 38%,#c41f3c 100%);\n    box-shadow:\n      0 38px 60px -18px rgba(0,0,0,.75),\n      inset 0 2px 0 rgba(255,255,255,.35),\n      inset 0 -10px 28px rgba(0,0,0,.45);\n    overflow:hidden;\n  }\n  .pedal::before{ /* brushed sheen */\n    content:\"\";position:absolute;inset:0;border-radius:34px;\n    background:repeating-linear-gradient(115deg,rgba(255,255,255,.05) 0 2px,transparent 2px 5px);\n    mix-blend-mode:overlay;opacity:.6;pointer-events:none;\n  }\n  .screw{position:absolute;width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff,#8a8f96 60%,#4a4d52);\n    box-shadow:inset 0 0 0 1px rgba(0,0,0,.4),0 1px 2px rgba(0,0,0,.5);}\n  .screw::after{content:\"\";position:absolute;inset:4px;border-top:2px solid rgba(0,0,0,.45);transform:rotate(35deg);}\n  .screw.tl{top:16px;left:16px}.screw.tr{top:16px;right:16px}\n  .screw.bl{bottom:16px;left:16px}.screw.br{bottom:16px;right:16px}\n\n  .brand{position:absolute;top:22px;left:0;right:0;text-align:center;\n    font-weight:800;letter-spacing:.42em;font-size:13px;color:#2a0c12;\n    text-shadow:0 1px 0 rgba(255,255,255,.35);text-indent:.42em;}\n  .sub{position:absolute;top:42px;left:0;right:0;text-align:center;\n    font-size:9px;letter-spacing:.3em;color:rgba(40,8,14,.7);text-indent:.3em;}\n\n  /* ---- top control deck ---- */\n  .deck{\n    position:absolute;top:62px;left:26px;right:26px;height:188px;\n    border-radius:20px;\n    background:linear-gradient(180deg,#241319,#150b0f);\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.7),inset 0 -1px 0 rgba(255,255,255,.05),0 2px 0 rgba(255,120,140,.25);\n    padding:14px 16px;\n  }\n\n  /* pitch-bend ribbon (animated) */\n  .ribbon{position:relative;height:54px;border-radius:11px;overflow:hidden;\n    background:#0c0709;box-shadow:inset 0 0 0 1px rgba(255,255,255,.06),inset 0 6px 16px rgba(0,0,0,.8);}\n  .ribbon svg{position:absolute;inset:0;width:100%;height:100%;}\n  .grid line{stroke:rgba(255,255,255,.05);stroke-width:1;}\n  .wave{fill:none;stroke:url(#g1);stroke-width:2.4;filter:drop-shadow(0 0 5px var(--accent));}\n  .scan{position:absolute;top:0;bottom:0;width:2px;left:0;\n    background:linear-gradient(var(--accent2),transparent);opacity:.8;\n    box-shadow:0 0 10px var(--accent2);animation:scan 2.4s linear infinite;}\n  @keyframes scan{from{left:-2%}to{left:102%}}\n  .note{position:absolute;font-size:9px;color:var(--accent2);font-weight:700;\n    top:4px;right:8px;letter-spacing:.08em;text-shadow:0 0 6px var(--accent2);}\n\n  /* knob row */\n  .knobs{display:flex;justify-content:space-around;margin-top:14px;}\n  .ctrl{display:flex;flex-direction:column;align-items:center;gap:6px;}\n  .knob{width:64px;height:64px;position:relative;cursor:ns-resize;touch-action:none;}\n  .knob .ring{position:absolute;inset:0;border-radius:50%;\n    background:conic-gradient(from 220deg,var(--accent) 0deg,var(--accent2) var(--deg,180deg),#2a1b20 var(--deg,180deg) 280deg,#2a1b20 360deg);\n    -webkit-mask:radial-gradient(circle,transparent 56%,#000 57%);\n            mask:radial-gradient(circle,transparent 56%,#000 57%);\n    filter:drop-shadow(0 0 6px rgba(255,59,92,.35));}\n  .knob .cap{position:absolute;inset:9px;border-radius:50%;\n    background:radial-gradient(circle at 38% 30%,#3a262c,#140c0f 72%);\n    box-shadow:0 4px 8px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.12);}\n  .knob .ptr{position:absolute;left:50%;top:11px;width:3px;height:18px;border-radius:2px;\n    background:linear-gradient(var(--accent2),var(--accent));transform-origin:50% 21px;\n    transform:translateX(-50%) rotate(var(--rot,0deg));box-shadow:0 0 6px var(--accent2);}\n  .lab{font-size:10px;letter-spacing:.18em;color:#e9c2c8;font-weight:700;}\n  .val{font-size:10px;color:var(--accent2);font-variant-numeric:tabular-nums;min-height:12px;font-weight:700;}\n\n  /* mode switch */\n  .modewrap{display:flex;flex-direction:column;align-items:center;gap:6px;}\n  .modes{display:flex;gap:4px;background:#0c0709;border-radius:9px;padding:4px;\n    box-shadow:inset 0 0 0 1px rgba(255,255,255,.06),inset 0 4px 10px rgba(0,0,0,.7);}\n  .mbtn{font-size:9px;font-weight:800;letter-spacing:.06em;color:#7a5b61;\n    padding:6px 7px;border-radius:6px;cursor:pointer;transition:.18s;min-width:34px;text-align:center;}\n  .mbtn.on{color:#1a0d10;background:linear-gradient(var(--accent2),var(--accent));\n    box-shadow:0 0 10px rgba(255,59,92,.6),inset 0 1px 0 rgba(255,255,255,.4);}\n\n  /* ---- rocking treadle ---- */\n  .treadle-zone{position:absolute;left:26px;right:26px;top:268px;bottom:30px;\n    border-radius:24px;background:linear-gradient(180deg,#160c10,#0a0507);\n    box-shadow:inset 0 4px 12px rgba(0,0,0,.8);overflow:hidden;cursor:ns-resize;touch-action:none;}\n  .hinge{position:absolute;top:8px;left:50%;transform:translateX(-50%);\n    width:60%;height:8px;border-radius:5px;\n    background:linear-gradient(var(--steel),var(--steel2));box-shadow:0 2px 4px rgba(0,0,0,.6);}\n  .treadle{position:absolute;left:7%;right:7%;top:18px;bottom:14px;border-radius:16px;\n    transform-origin:50% 0%;transform:rotateX(var(--tilt,38deg));\n    transition:transform .08s ease-out;\n    background:linear-gradient(180deg,#ff5570,#d8243f 60%,#9a1730);\n    box-shadow:0 -10px 26px -6px rgba(0,0,0,.6),inset 0 2px 0 rgba(255,255,255,.4),inset 0 -16px 30px rgba(0,0,0,.5);}\n  /* chrome footplate ridges */\n  .plate{position:absolute;inset:10px 14px;border-radius:10px;\n    background:repeating-linear-gradient(180deg,#e8edf2 0 5px,#aab1ba 5px 10px);\n    box-shadow:inset 0 0 0 1px rgba(0,0,0,.25),inset 0 2px 4px rgba(255,255,255,.6);}\n  .plate::after{content:\"\";position:absolute;inset:0;border-radius:10px;\n    background:linear-gradient(110deg,transparent 30%,rgba(255,255,255,.55) 50%,transparent 70%);\n    background-size:300% 100%;animation:shine 3.4s ease-in-out infinite;}\n  @keyframes shine{0%,100%{background-position:120% 0}50%{background-position:-40% 0}}\n  .toe{position:absolute;bottom:6px;left:0;right:0;text-align:center;font-size:8px;\n    letter-spacing:.3em;color:rgba(20,6,10,.8);font-weight:800;text-indent:.3em;}\n  /* pedal glow that intensifies with toe */\n  .glow{position:absolute;left:7%;right:7%;bottom:14px;height:30px;border-radius:0 0 16px 16px;\n    background:radial-gradient(80% 140% at 50% 100%,rgba(255,138,59,var(--g,.5)),transparent 70%);\n    filter:blur(6px);pointer-events:none;transition:opacity .1s;}\n  .heeltoe{position:absolute;right:14px;top:50%;transform:translateY(-50%);\n    display:flex;flex-direction:column;gap:30px;font-size:8px;color:#6b4b51;\n    letter-spacing:.15em;font-weight:700;text-align:right;}\n\n  .readout{position:absolute;left:50%;bottom:38px;transform:translate(-50%,0);\n    font-size:11px;font-weight:800;letter-spacing:.1em;color:var(--accent2);\n    text-shadow:0 0 10px var(--accent2);font-variant-numeric:tabular-nums;pointer-events:none;}\n  .hint{position:absolute;left:0;right:0;bottom:8px;text-align:center;font-size:8px;\n    letter-spacing:.18em;color:rgba(255,255,255,.28);}\n</style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"pedal\">\n      <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n      <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n      <div class=\"brand\">WHAMMY</div>\n      <div class=\"sub\">EXTREME PITCH</div>\n\n      <div class=\"deck\">\n        <div class=\"ribbon\">\n          <svg viewBox=\"0 0 320 54\" preserveAspectRatio=\"none\">\n            <defs>\n              <linearGradient id=\"g1\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n                <stop offset=\"0\" stop-color=\"#ff3b5c\"/><stop offset=\"1\" stop-color=\"#ff8a3b\"/>\n              </linearGradient>\n            </defs>\n            <g class=\"grid\">\n              <line x1=\"0\" y1=\"27\" x2=\"320\" y2=\"27\"/>\n              <line x1=\"0\" y1=\"13\" x2=\"320\" y2=\"13\"/>\n              <line x1=\"0\" y1=\"41\" x2=\"320\" y2=\"41\"/>\n            </g>\n            <path class=\"wave\" id=\"wave\" d=\"\"/>\n          </svg>\n          <div class=\"scan\"></div>\n          <div class=\"note\" id=\"note\">+12 st</div>\n        </div>\n\n        <div class=\"knobs\">\n          <div class=\"ctrl\">\n            <div class=\"knob\" id=\"k0\" title=\"Pitch\"><div class=\"ring\"></div><div class=\"cap\"></div><div class=\"ptr\"></div></div>\n            <div class=\"lab\">PITCH</div><div class=\"val\" id=\"v0\"></div>\n          </div>\n          <div class=\"modewrap\">\n            <div class=\"modes\" id=\"modes\">\n              <div class=\"mbtn\" data-m=\"0\">UP</div>\n              <div class=\"mbtn\" data-m=\"1\">DOWN</div>\n              <div class=\"mbtn\" data-m=\"2\">DUAL</div>\n            </div>\n            <div class=\"lab\">MODE</div><div class=\"val\" id=\"v2\"></div>\n          </div>\n          <div class=\"ctrl\">\n            <div class=\"knob\" id=\"k3\" title=\"Mix\"><div class=\"ring\"></div><div class=\"cap\"></div><div class=\"ptr\"></div></div>\n            <div class=\"lab\">MIX</div><div class=\"val\" id=\"v3\"></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"treadle-zone\" id=\"pedalZone\">\n        <div class=\"hinge\"></div>\n        <div class=\"glow\" id=\"glow\"></div>\n        <div class=\"treadle\" id=\"treadle\">\n          <div class=\"plate\"></div>\n          <div class=\"toe\">TOE</div>\n        </div>\n        <div class=\"heeltoe\"><span>TOE</span><span>HEEL</span></div>\n        <div class=\"readout\" id=\"ro\">+12 st</div>\n        <div class=\"hint\">DRAG TREADLE · DOUBLE-CLICK TO RESET</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // ---- host bridge ----\n  var host = (window.vstai && typeof window.vstai.setParam===\"function\") ? window.vstai : null;\n  function send(i,v){ if(host) try{host.setParam(i,v);}catch(e){} }\n\n  // param defs: index, min, max, default\n  var P = {\n    pitch:{i:0,min:-24,max:24,def:12,v:12},\n    pedal:{i:1,min:0,max:1,def:1,v:1},\n    mode: {i:2,min:0,max:2,def:0,v:0},\n    mix:  {i:3,min:0,max:1,def:1,v:1}\n  };\n\n  // ---------- KNOBS (Pitch, Mix) ----------\n  function bindKnob(el, p, fmt){\n    var range=p.max-p.min;\n    function paint(){\n      var t=(p.v-p.min)/range;            // 0..1\n      var deg=t*280;                       // ring sweep\n      el.querySelector('.ring').style.setProperty('--deg',deg+'deg');\n      el.querySelector('.ptr').style.setProperty('--rot',(-140+t*280)+'deg');\n    }\n    function commit(){ send(p.i,p.v); paint(); fmt(); }\n    var drag=false,sy=0,sv=0;\n    function down(e){drag=true;sy=(e.touches?e.touches[0].clientY:e.clientY);sv=p.v;e.preventDefault();}\n    function move(e){ if(!drag)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      p.v=clamp(sv+(sy-y)/180*range, p.min,p.max); commit();\n    }\n    function up(){drag=false;}\n    el.addEventListener('mousedown',down); el.addEventListener('touchstart',down,{passive:false});\n    window.addEventListener('mousemove',move); window.addEventListener('touchmove',move,{passive:false});\n    window.addEventListener('mouseup',up); window.addEventListener('touchend',up);\n    el.addEventListener('dblclick',function(){p.v=p.def;commit();});\n    el.addEventListener('wheel',function(e){e.preventDefault();\n      p.v=clamp(p.v - Math.sign(e.deltaY)*range*0.03, p.min,p.max); commit();},{passive:false});\n    p._paint=function(){commit();};\n  }\n  function clamp(x,a,b){return x<a?a:(x>b?b:x);}\n\n  bindKnob(document.getElementById('k0'),P.pitch,function(){\n    var s=(P.pitch.v>=0?'+':'')+Math.round(P.pitch.v);\n    document.getElementById('v0').textContent=s+' st';\n    document.getElementById('note').textContent=s+' st';\n    drawWave();\n  });\n  bindKnob(document.getElementById('k3'),P.mix,function(){\n    document.getElementById('v3').textContent=Math.round(P.mix.v*100)+'%';\n  });\n\n  // ---------- MODE switch ----------\n  var MODES=['UP','DOWN','DUAL'];\n  var modeBtns=document.querySelectorAll('#modes .mbtn');\n  function paintMode(){\n    modeBtns.forEach(function(b){ b.classList.toggle('on', +b.dataset.m===Math.round(P.mode.v)); });\n    document.getElementById('v2').textContent=MODES[Math.round(P.mode.v)];\n    drawWave();\n  }\n  modeBtns.forEach(function(b){\n    b.addEventListener('click',function(){ P.mode.v=+b.dataset.m; send(P.mode.i,P.mode.v); paintMode(); });\n  });\n\n  // ---------- TREADLE (Pedal) ----------\n  var zone=document.getElementById('pedalZone'), treadle=document.getElementById('treadle'),\n      glow=document.getElementById('glow'), ro=document.getElementById('ro');\n  function paintPedal(){\n    var p=P.pedal.v;                        // 0 heel .. 1 toe\n    var tilt=38-p*36;                        // 38deg (up/heel) -> 2deg (down/toe)\n    treadle.style.setProperty('--tilt',tilt+'deg');\n    glow.style.setProperty('--g',(0.15+p*0.7).toFixed(2));\n    glow.style.opacity=(0.3+p*0.7).toFixed(2);\n    // live shifted-pitch readout = current target\n    var dir=Math.round(P.mode.v);\n    var mag=Math.abs(P.pitch.v)*p;\n    var st = dir===1 ? -mag : (dir===2 ? P.pitch.v*p : mag);\n    ro.textContent=(st>=0?'+':'')+st.toFixed(1)+' st';\n  }\n  var pdrag=false,py=0,pv=0;\n  function pdown(e){pdrag=true;py=(e.touches?e.touches[0].clientY:e.clientY);pv=P.pedal.v;e.preventDefault();}\n  function pmove(e){ if(!pdrag)return;\n    var y=(e.touches?e.touches[0].clientY:e.clientY);\n    P.pedal.v=clamp(pv+(py-y)/220,0,1); send(P.pedal.i,P.pedal.v); paintPedal();\n  }\n  function pup(){pdrag=false;}\n  zone.addEventListener('mousedown',pdown); zone.addEventListener('touchstart',pdown,{passive:false});\n  window.addEventListener('mousemove',pmove); window.addEventListener('touchmove',pmove,{passive:false});\n  window.addEventListener('mouseup',pup); window.addEventListener('touchend',pup);\n  zone.addEventListener('dblclick',function(){P.pedal.v=P.pedal.def;send(P.pedal.i,P.pedal.v);paintPedal();});\n\n  // ---------- animated pitch-bend ribbon ----------\n  var wavePath=document.getElementById('wave'), phase=0;\n  function drawWave(){\n    var dir=Math.round(P.mode.v);\n    var bend=(P.pitch.v/24);               // -1..1\n    var pts=[],W=320,H=54;\n    for(var x=0;x<=W;x+=8){\n      var u=x/W;\n      // base ripple + a swooping bend curve shaped by mode\n      var swoop = dir===2 ? Math.sin(u*Math.PI*2+phase)*0.5 : (dir===1? u : 1-u);\n      var amp = 10 + 8*Math.abs(bend);\n      var y = H/2 - bend*16*swoop + Math.sin(u*9+phase)*amp*0.25;\n      pts.push(x.toFixed(1)+','+y.toFixed(1));\n    }\n    wavePath.setAttribute('d','M'+pts.join(' L'));\n  }\n  function loop(){ phase+=0.06; drawWave(); requestAnimationFrame(loop); }\n\n  // ---------- init ----------\n  function init(){\n    P.pitch._paint(); P.mix._paint(); paintMode(); paintPedal();\n    // push every default to host\n    send(P.pitch.i,P.pitch.v); send(P.pedal.i,P.pedal.v);\n    send(P.mode.i,P.mode.v);  send(P.mix.i,P.mix.v);\n    loop();\n  }\n  if(host && typeof host.onReady===\"function\") host.onReady(init); else init();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  WHAMMY — extreme expression-pedal pitch shifter (effect)\n//  A delay-line (overlap-add) pitch shifter with two crossfaded read\n//  pointers chasing a write pointer at a speed set by the target ratio.\n//  The Pedal control sweeps the dry signal toward the shifted target\n//  (heel = dry, toe = full shift) so you can dive-bomb or soar in real\n//  time. Mode picks the direction: 0 up, 1 down, 2 dual octaves (a\n//  shimmering ±octave blend). Wide ±24-semitone Pitch range, Mix sets\n//  the wet balance. Crossfaded pointers keep big dives click-free.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// pitch-shift delay line: a generous ring buffer per channel\nconst DLINE: i32 = 16384;               // power of two -> cheap wrap mask\nconst DMASK: i32 = DLINE - 1;\nconst WIN: f32 = 3072.0;                 // crossfade grain length, in samples (~64ms @48k)\nconst ring: StaticArray<f32> = new StaticArray<f32>(DLINE * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel write position into the ring buffer\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\n// two read phases (in samples behind write), wrapped to [0, WIN)\nconst phaseA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst phaseB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n// second grain pair for the dual-octave mirror voice\nconst mphaseA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mphaseB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n// smoothed pitch ratio (one-pole) so pedal sweeps glide\nconst ratioState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n// DC-blocker state (per channel)\nconst dcX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst dcY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_PITCH: i32 = 0;  // -24..24 semitones (target at full pedal)\nconst P_PEDAL: i32 = 1;  // 0..1 blends dry(1.0x) -> target ratio\nconst P_MODE: i32  = 2;  // 0 up, 1 down, 2 dual octaves\nconst P_MIX: i32   = 3;  // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0;\n    phaseA[c] = 0.0;\n    phaseB[c] = WIN * 0.5;   // second pointer half a grain away\n    mphaseA[c] = 0.0;\n    mphaseB[c] = WIN * 0.5;\n    ratioState[c] = 1.0;\n    dcX1[c] = 0.0;\n    dcY1[c] = 0.0;\n  }\n  for (let i = 0; i < DLINE * MAX_CHANNELS; i++) ring[i] = 0.0;\n  params[P_PITCH] = 12.0;\n  params[P_PEDAL] = 1.0;\n  params[P_MODE]  = 0.0;\n  params[P_MIX]   = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linear read from the ring buffer at a fractional position `behind` write\n@inline function readRing(base: i32, wp: i32, behind: f32): f32 {\n  let pos: f32 = f32(wp) - behind;\n  // wrap into [0, DLINE)\n  while (pos < 0.0) pos += f32(DLINE);\n  const i0: i32 = i32(pos) & DMASK;\n  const i1: i32 = (i0 + 1) & DMASK;\n  const fr: f32 = pos - f32(i32(pos));\n  const a: f32 = ring[base + i0];\n  const b: f32 = ring[base + i1];\n  return a + (b - a) * fr;\n}\n\nexport function process(n: i32): void {\n  const pitchSemi: f32 = clampf(params[P_PITCH], -24.0, 24.0);\n  const pedal: f32 = clampf(params[P_PEDAL], 0.0, 1.0);\n  const mode: i32 = i32(clampf(params[P_MODE], 0.0, 2.0) + 0.5);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // smoothing coefficient: gentle glide on the ratio (~30ms)\n  const smooth: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * 12.0 / sampleRate)), 0.0, 1.0);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * DLINE;\n    const abase: i32 = c * MAX_FRAMES;\n    let wp: i32 = writePos[c];\n    let pa: f32 = phaseA[c];\n    let pb: f32 = phaseB[c];\n    let ma: f32 = mphaseA[c];\n    let mb: f32 = mphaseB[c];\n    let rs: f32 = ratioState[c];\n    let dx1: f32 = dcX1[c];\n    let dy1: f32 = dcY1[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[abase + f];\n\n      // write current input into the ring\n      ring[base + wp] = x;\n\n      // ---- target pitch ratio for this mode -----------------------\n      // ratioUp/ratioDown derived from the pedal-swept semitone amount.\n      // Pedal blends the *semitone* target from 0 (dry) to full Pitch.\n      let target: f32 = 1.0;\n      if (mode == 0) {\n        // UP: bend toward +|pitch| (heel dry -> toe up)\n        const semis: f32 = pedal * (pitchSemi >= 0.0 ? pitchSemi : -pitchSemi);\n        target = f32(Mathf.pow(2.0, semis / 12.0));\n      } else if (mode == 1) {\n        // DOWN: bend toward -|pitch| (heel dry -> toe down)\n        const semis: f32 = pedal * (pitchSemi >= 0.0 ? pitchSemi : -pitchSemi);\n        target = f32(Mathf.pow(2.0, -semis / 12.0));\n      } else {\n        // DUAL OCTAVES: pedal sweeps the magnitude; sign of Pitch chooses\n        // which octave leads, but always a blend of +1oct and -1oct flavour.\n        const semis: f32 = pedal * pitchSemi; // signed so dual differs from up\n        target = f32(Mathf.pow(2.0, semis / 12.0));\n      }\n\n      // smooth the ratio so dives don't zipper\n      rs += smooth * (target - rs);\n\n      // Per output sample the read pointer's distance \"behind\" the write head\n      // must change by (1 - ratio): a ratio > 1 (pitch UP) shrinks the gap so\n      // we read samples FASTER, chasing the write head and raising pitch.\n      const delta: f32 = 1.0 - rs;\n      pa += delta;\n      pb += delta;\n      // keep grain phases inside [0, WIN)\n      if (pa >= WIN) pa -= WIN; else if (pa < 0.0) pa += WIN;\n      if (pb >= WIN) pb -= WIN; else if (pb < 0.0) pb += WIN;\n\n      // two read taps, each its own grain position; crossfade with a\n      // raised-cosine so a tap is silent exactly where it would wrap.\n      const ga: f32 = 0.5 - 0.5 * f32(Mathf.cos(PI2 * pa / WIN));\n      const gb: f32 = 0.5 - 0.5 * f32(Mathf.cos(PI2 * pb / WIN));\n      const sa: f32 = readRing(base, wp, pa + 2.0);\n      const sb: f32 = readRing(base, wp, pb + 2.0);\n      let wet: f32 = sa * ga + sb * gb;\n\n      // dual-octave mode: add a mirror voice at the reciprocal ratio so the\n      // two voices straddle the dry pitch (classic shimmering ±octave stack).\n      if (mode == 2) {\n        const mrec: f32 = rs > 0.0001 ? 1.0 / rs : 1.0;\n        const mdelta: f32 = 1.0 - mrec;\n        ma += mdelta;\n        mb += mdelta;\n        if (ma >= WIN) ma -= WIN; else if (ma < 0.0) ma += WIN;\n        if (mb >= WIN) mb -= WIN; else if (mb < 0.0) mb += WIN;\n        const mga: f32 = 0.5 - 0.5 * f32(Mathf.cos(PI2 * ma / WIN));\n        const mgb: f32 = 0.5 - 0.5 * f32(Mathf.cos(PI2 * mb / WIN));\n        const mir: f32 = readRing(base, wp, ma + 2.0) * mga\n                       + readRing(base, wp, mb + 2.0) * mgb;\n        wet = wet * 0.6 + mir * 0.6;\n      }\n\n      // DC blocker (one-pole high-pass) so crossfaded taps sum cleanly.\n      const dy: f32 = wet - dx1 + 0.999 * dy1;\n      dx1 = wet;\n      dy1 = dy;\n      wet = dy;\n\n      // gentle limiter to keep peaks bounded on big stacks\n      wet = clampf(wet, -1.2, 1.2);\n\n      outBuf[abase + f] = x * (1.0 - mix) + wet * mix;\n\n      // advance write pointer\n      wp = (wp + 1) & DMASK;\n    }\n\n    writePos[c] = wp;\n    phaseA[c] = pa;\n    phaseB[c] = pb;\n    mphaseA[c] = ma;\n    mphaseB[c] = mb;\n    ratioState[c] = rs;\n    dcX1[c] = dx1;\n    dcY1[c] = dy1;\n  }\n}\n",
  "publishedAt": 1751000063000
}