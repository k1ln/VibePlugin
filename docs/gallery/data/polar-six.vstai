    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Sync",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
