  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Polar Six</title>\n<style>\n  :root{ --acc:#6ab8e0; --acc2:#f0e2c0; --bg0:#070c11; --bg1:#0d1822; --ink:#e8f1f7; --dim:#708595; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#122736 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#0f1e2a,#070c11); border:1px solid rgba(106,184,224,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(232,241,247,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.4s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:100px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0b1824,#070d13); border:1px solid rgba(106,184,224,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(214,230,240,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(106,184,224,.6)); }\n  .pcap{ fill:#0b1620; stroke:rgba(106,184,224,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(106,184,224,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(106,184,224,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">POLAR&nbsp;SIX</span><span class=\"sub\">hard-sync poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">OSC&nbsp;SYNC</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.6},{name:\"Reso\",idx:1,def:0.3},{name:\"Env\",idx:2,def:0.4},{name:\"Sync\",idx:3,def:0.4},{name:\"Detune\",idx:4,def:0.4},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#6ab8e0\"/><stop offset=\"1\" stop-color=\"#f0e2c0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], env=vals[2], sync=vals[3], det=vals[4]; var mid=H*0.54;\n    // polar aurora wash\n    var g=ctx.createLinearGradient(0,0,W,H); g.addColorStop(0,\"rgba(106,184,224,0.05)\"); g.addColorStop(0.5,\"rgba(240,226,192,0.03)\"); g.addColorStop(1,\"rgba(106,184,224,0.05)\"); ctx.fillStyle=g; ctx.fillRect(0,0,W,H);\n    // envelope sweeps the effective sync ratio a touch (movement)\n    var sr=1+ (sync*2.2) * (1 + env*0.4*Math.sin(ts/900));\n    var cycles=2.2;\n    // hard-sync saw: master period, osc2 reset at each master wrap (teeth)\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=1.2){ var t=x/W; var mp=(t*cycles + ts/1400)%1; // master phase\n      var sp=(mp*sr)%1; // synced phase resets each master cycle\n      var o1=(mp*2-1)*0.4; var o2=(sp*2-1)*0.55; var v=(o1+o2)*(0.4+cut*0.5);\n      ctx.lineTo(x, mid - v*(H*0.34)); }\n    ctx.strokeStyle=\"rgba(106,184,224,0.92)\"; ctx.lineWidth=2; ctx.shadowColor=\"#6ab8e0\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    // warmth detune layer (cream)\n    if(det>0.02){ ctx.beginPath(); for(var x2=0;x2<=W;x2+=2){ var t2=x2/W; var p3=(t2*cycles*(1.01)+ts/1400)%1; var v3=(p3*2-1)*det*0.35*(0.4+cut*0.4); ctx.lineTo(x2, mid - v3*(H*0.22)); }\n      ctx.strokeStyle=\"rgba(240,226,192,0.5)\"; ctx.lineWidth=1.3; ctx.stroke(); }\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  POLAR SIX — a warm 6-voice analog poly (Sequential/Chroma Polaris\n//  lineage). Its signature is oscillator HARD SYNC: a second sawtooth is\n//  locked to the first's period but runs at a higher ratio set by SYNC,\n//  so sweeping Sync (or letting the filter envelope open) gives the\n//  classic tearing sync-lead harmonics. A third gently-detuned saw layer\n//  (Detune) adds analog warmth, and a smooth resonant two-pole low-pass\n//  with its own envelope shapes it. 6-voice poly.\n//  Controls: Cutoff, Resonance, Env Amount, Sync, Detune, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 6;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vP1: StaticArray<f32> = new StaticArray<f32>(NVOX);   // master osc phase\nconst vP2: StaticArray<f32> = new StaticArray<f32>(NVOX);   // synced osc phase\nconst vP3: StaticArray<f32> = new StaticArray<f32>(NVOX);   // detuned warmth saw\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_SYNC: i32 = 3; const P_DETUNE: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vP1[i] = 0.0; vP2[i] = 0.0; vP3[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.6; params[P_RESO] = 0.3; params[P_ENV] = 0.4; params[P_SYNC] = 0.4; params[P_DETUNE] = 0.4; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vP1[slot] = 0.0; vP2[slot] = 0.0; vP3[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const syncN: f32 = clampf(params[P_SYNC], 0.0, 1.0);\n  const detN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.006 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.4 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.6 * sampleRate)));\n  const baseCut: f32 = 55.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const envSpan: f32 = envN * 8000.0;\n  const k: f32 = 2.0 - 1.9 * resoN;\n  const syncRatio: f32 = 1.0 + syncN * 2.2;               // osc2 pitch multiple\n  const det3: f32 = 1.0 + detN * 0.03;                    // warmth saw detune\n  const det3Lvl: f32 = detN * 0.5;\n  const out: f32 = level * 0.42;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else if (vSt[s] == 3) { /* sustain */ }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n\n      let p1: f32 = vP1[s] + fr / sampleRate;\n      let wrapped: bool = false;\n      if (p1 >= 1.0) { p1 -= 1.0; wrapped = true; }\n      vP1[s] = p1;\n      // synced osc2: reset when master wraps\n      let p2: f32 = vP2[s] + (fr * syncRatio) / sampleRate;\n      if (wrapped) { p2 = p1 * syncRatio; }               // hard sync reset (phase-aligned)\n      if (p2 >= 1.0) p2 -= f32(i32(p2));\n      vP2[s] = p2;\n      let p3: f32 = vP3[s] + (fr * det3) / sampleRate; if (p3 >= 1.0) p3 -= 1.0; vP3[s] = p3;\n\n      const o1: f32 = p1 * 2.0 - 1.0;\n      const o2: f32 = p2 * 2.0 - 1.0;\n      const o3: f32 = p3 * 2.0 - 1.0;\n      let osc: f32 = (o1 * 0.45 + o2 * 0.5 + o3 * det3Lvl) * 0.5;\n\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      mix += lpN * vAmp[s] * vVel[s];\n    }\n    let o: f32 = f32(Mathf.tanh(mix * out * 1.5));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751310800000
}