{
  "format": 1,
  "name": "Lab Mono",
  "isInstrument": true,
  "explanation": "An aggressive, patchable single-VCO monophonic synth: one oscillator (saw + PWM pulse) drives a screaming Korg-35-style 2-pole resonant low-pass that sings toward self-oscillation as Resonance is pushed. A punchy decay envelope sweeps the cutoff, and a patchable MOD source — stepped sample & hold at slow rates, a smooth triangle LFO at fast rates — wires straight into the filter for burbling, zapping movement. Last-note-priority mono; pitch tracks each played note in Hz. Raw, experimental lab-synth grit, fully bounded.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.62
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mod",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mod Rate",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Lab Mono</title>\n<style>\n  :root {\n    --accent: #43e0a0;\n    --accent2: #ff7adf;\n    --bg0: #07120e;\n    --bg1: #0d1f18;\n    --panel: #11271e;\n    --panel2: #0a1812;\n    --ink: #cfeede;\n    --ink-dim: #6f9886;\n    --jack: #1c3a2c;\n    --line: #20473500;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  #app {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 14px;\n    min-height: 100vh;\n  }\n\n  .face {\n    position: relative;\n    border-radius: 16px;\n    padding: 18px 20px 22px;\n    background:\n      radial-gradient(120% 90% at 12% -10%, rgba(67,224,160,0.10), transparent 55%),\n      radial-gradient(120% 120% at 110% 120%, rgba(255,122,223,0.10), transparent 55%),\n      linear-gradient(165deg, var(--panel) 0%, var(--panel2) 100%);\n    border: 1px solid rgba(67,224,160,0.18);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.06),\n      inset 0 -2px 14px rgba(0,0,0,0.5);\n    overflow: hidden;\n  }\n\n  /* faint engraved grid texture */\n  .face::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      linear-gradient(rgba(67,224,160,0.045) 1px, transparent 1px),\n      linear-gradient(90deg, rgba(67,224,160,0.045) 1px, transparent 1px);\n    background-size: 26px 26px;\n    mask-image: radial-gradient(120% 100% at 50% 0%, #000 30%, transparent 90%);\n    pointer-events: none;\n  }\n\n  header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    position: relative;\n    z-index: 2;\n    margin-bottom: 14px;\n  }\n\n  .brand {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n\n  .logo {\n    width: 40px;\n    height: 40px;\n    flex: none;\n  }\n\n  .titles h1 {\n    margin: 0;\n    font-size: 22px;\n    letter-spacing: 3px;\n    font-weight: 800;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n\n  .titles .sub {\n    margin: 2px 0 0;\n    font-size: 9.5px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .badge {\n    text-align: right;\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    line-height: 1.7;\n  }\n  .badge .dot {\n    display: inline-block;\n    width: 7px; height: 7px;\n    border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 8px var(--accent);\n    margin-right: 5px;\n    animation: blink 2.4s ease-in-out infinite;\n  }\n  @keyframes blink { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }\n\n  /* ---- patch-jack mod field ---- */\n  .modrack {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: 132px 1fr;\n    gap: 14px;\n    background: linear-gradient(160deg, rgba(0,0,0,0.35), rgba(0,0,0,0.15));\n    border: 1px solid rgba(67,224,160,0.12);\n    border-radius: 12px;\n    padding: 12px 14px;\n    margin-bottom: 16px;\n  }\n\n  .jacks {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px 10px;\n    align-content: center;\n  }\n  .jack {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 4px;\n  }\n  .jack svg { display: block; }\n  .jack .jl {\n    font-size: 7px;\n    letter-spacing: 1px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .jack.live .jl { color: var(--accent); }\n\n  /* stepped S&H readout */\n  .sh {\n    position: relative;\n    border-left: 1px solid rgba(67,224,160,0.12);\n    padding-left: 14px;\n    display: flex;\n    flex-direction: column;\n  }\n  .sh .shhead {\n    display: flex;\n    justify-content: space-between;\n    align-items: baseline;\n    margin-bottom: 6px;\n  }\n  .sh .shhead .lab {\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .sh .shhead .mode {\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    font-weight: 700;\n    color: var(--accent2);\n    text-shadow: 0 0 10px rgba(255,122,223,0.5);\n  }\n  .scope {\n    flex: 1;\n    width: 100%;\n    height: 64px;\n    border-radius: 8px;\n    background:\n      radial-gradient(80% 120% at 50% 0%, rgba(67,224,160,0.07), transparent 70%),\n      #04100b;\n    border: 1px solid rgba(67,224,160,0.15);\n    box-shadow: inset 0 0 18px rgba(0,0,0,0.7);\n    display: block;\n  }\n\n  /* ---- knob grid ---- */\n  .knobs {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 8px 6px;\n    margin-bottom: 16px;\n  }\n  @media (max-width: 560px) {\n    .knobs { grid-template-columns: repeat(3, 1fr); }\n    .modrack { grid-template-columns: 1fr; }\n    .sh { border-left: none; border-top: 1px solid rgba(67,224,160,0.12); padding-left: 0; padding-top: 12px; }\n  }\n\n  .knob {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 8px 4px 10px;\n    border-radius: 12px;\n    cursor: ns-resize;\n    user-select: none;\n    -webkit-user-select: none;\n    transition: background 0.2s, box-shadow 0.2s;\n  }\n  .knob:hover {\n    background: rgba(67,224,160,0.05);\n    box-shadow: inset 0 0 0 1px rgba(67,224,160,0.18);\n  }\n  .knob.scream:hover {\n    background: rgba(255,122,223,0.06);\n    box-shadow: inset 0 0 0 1px rgba(255,122,223,0.25);\n  }\n  .knob .dial { position: relative; }\n  .knob svg { display: block; overflow: visible; }\n  .knob .name {\n    margin-top: 8px;\n    font-size: 9px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    transition: color 0.2s;\n  }\n  .knob:hover .name { color: var(--ink); }\n  .knob .val {\n    margin-top: 2px;\n    font-size: 10.5px;\n    font-variant-numeric: tabular-nums;\n    letter-spacing: 0.5px;\n    color: var(--accent);\n    font-weight: 600;\n  }\n  .knob.scream .val { color: var(--accent2); }\n\n  /* ---- keyboard ---- */\n  .kbwrap {\n    position: relative;\n    z-index: 2;\n    border-radius: 12px;\n    padding: 10px 12px 12px;\n    background: linear-gradient(180deg, rgba(0,0,0,0.4), rgba(0,0,0,0.2));\n    border: 1px solid rgba(67,224,160,0.12);\n  }\n  .kbhead {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    margin-bottom: 8px;\n  }\n  .kbhead .lab {\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .kbhead .hint {\n    font-size: 8px;\n    letter-spacing: 1px;\n    color: var(--ink-dim);\n    opacity: 0.7;\n  }\n  .keys {\n    position: relative;\n    height: 92px;\n    display: flex;\n    touch-action: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 6px 6px;\n    background: linear-gradient(180deg, #d8efe4 0%, #aecdbe 100%);\n    box-shadow: inset 0 -6px 8px rgba(0,0,0,0.18), 0 2px 4px rgba(0,0,0,0.4);\n    cursor: pointer;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #2bb585 100%);\n    box-shadow: inset 0 0 14px rgba(0,0,0,0.3), 0 0 16px rgba(67,224,160,0.55);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 8.4%;\n    height: 58%;\n    margin-left: -4.2%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #0c1c15 0%, #03100a 100%);\n    box-shadow: inset 0 -4px 6px rgba(255,255,255,0.05), 0 3px 6px rgba(0,0,0,0.7);\n    cursor: pointer;\n    z-index: 3;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2) 0%, #b94f97 100%);\n    box-shadow: 0 0 18px rgba(255,122,223,0.6);\n  }\n</style>\n</head>\n<body>\n<div id=\"app\">\n  <div class=\"face\">\n    <header>\n      <div class=\"brand\">\n        <svg class=\"logo\" viewBox=\"0 0 40 40\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"lg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#43e0a0\"/>\n              <stop offset=\"1\" stop-color=\"#ff7adf\"/>\n            </linearGradient>\n          </defs>\n          <rect x=\"2\" y=\"2\" width=\"36\" height=\"36\" rx=\"9\" fill=\"none\" stroke=\"url(#lg)\" stroke-width=\"2\"/>\n          <path d=\"M9 26 L9 12 L16 12\" fill=\"none\" stroke=\"#43e0a0\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n          <path d=\"M21 14 q5 -6 10 0 q-5 12 0 12\" fill=\"none\" stroke=\"#ff7adf\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n          <circle cx=\"9\" cy=\"29\" r=\"2.1\" fill=\"#43e0a0\"/>\n        </svg>\n        <div class=\"titles\">\n          <h1>Lab Mono</h1>\n          <p class=\"sub\">Patchable Single&nbsp;&middot;&nbsp;VCO Mono</p>\n        </div>\n      </div>\n      <div class=\"badge\">\n        <div><span class=\"dot\"></span>SELF-OSC FILTER</div>\n        <div>S&amp;H&nbsp;/&nbsp;LFO MOD BUS</div>\n      </div>\n    </header>\n\n    <!-- patch field + stepped mod readout -->\n    <section class=\"modrack\">\n      <div class=\"jacks\" id=\"jacks\"></div>\n      <div class=\"sh\">\n        <div class=\"shhead\">\n          <span class=\"lab\">Mod Bus</span>\n          <span class=\"mode\" id=\"modMode\">S&amp;H</span>\n        </div>\n        <canvas class=\"scope\" id=\"scope\" width=\"380\" height=\"64\"></canvas>\n      </div>\n    </section>\n\n    <!-- knobs -->\n    <section class=\"knobs\" id=\"knobs\"></section>\n\n    <!-- keyboard -->\n    <div class=\"kbwrap\">\n      <div class=\"kbhead\">\n        <span class=\"lab\">Keys</span>\n        <span class=\"hint\">drag / click to play &middot; double-click a knob to reset</span>\n      </div>\n      <div class=\"keys\" id=\"keys\"></div>\n    </div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  var ACCENT = \"#43e0a0\";\n  var ACCENT2 = \"#ff7adf\";\n\n  // --- parameter model (indices MUST match assembly.ts / spec.json) ---\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.35, scream: false },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.62, scream: true  },\n    { name: \"Env Amount\", index: 2, min: 0, max: 1, def: 0.55, scream: false },\n    { name: \"Mod\",        index: 3, min: 0, max: 1, def: 0.45, scream: true  },\n    { name: \"Mod Rate\",   index: 4, min: 0, max: 1, def: 0.40, scream: false },\n    { name: \"Decay\",      index: 5, min: 0, max: 1, def: 0.45, scream: false },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.80, scream: false }\n  ];\n\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  // --- host bridge ---\n  function pushParam(i) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(PARAMS[i].index, values[i]);\n    }\n  }\n  function pushAll() { for (var i = 0; i < PARAMS.length; i++) pushParam(i); }\n\n  // ===================================================================\n  //  KNOBS  (hand-drawn SVG, drag to turn, dblclick reset, wheel fine)\n  // ===================================================================\n  var knobEls = [];\n\n  function makeKnob(p, i) {\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"knob\" + (p.scream ? \" scream\" : \"\");\n\n    var col = p.scream ? ACCENT2 : ACCENT;\n    var R = 30, CX = 36, CY = 36;\n    var A0 = 135, A1 = 405; // sweep degrees\n\n    var dial = document.createElement(\"div\");\n    dial.className = \"dial\";\n    dial.innerHTML =\n      '<svg width=\"72\" height=\"72\" viewBox=\"0 0 72 72\">' +\n        '<defs>' +\n          '<radialGradient id=\"kb' + i + '\" cx=\"50%\" cy=\"38%\" r=\"65%\">' +\n            '<stop offset=\"0\" stop-color=\"#1a3a2c\"/>' +\n            '<stop offset=\"1\" stop-color=\"#091811\"/>' +\n          '</radialGradient>' +\n          '<filter id=\"gl' + i + '\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\">' +\n            '<feGaussianBlur stdDeviation=\"2.4\" result=\"b\"/>' +\n            '<feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>' +\n          '</filter>' +\n        '</defs>' +\n        '<circle cx=\"36\" cy=\"36\" r=\"31\" fill=\"none\" stroke=\"#06140e\" stroke-width=\"6\"/>' +\n        '<path class=\"track\" fill=\"none\" stroke=\"#16332650\" stroke-width=\"4\" stroke-linecap=\"round\"/>' +\n        '<path class=\"arc\" fill=\"none\" stroke=\"' + col + '\" stroke-width=\"4\" stroke-linecap=\"round\" filter=\"url(#gl' + i + ')\"/>' +\n        '<circle cx=\"36\" cy=\"36\" r=\"22\" fill=\"url(#kb' + i + ')\" stroke=\"#2a5040\" stroke-width=\"1\"/>' +\n        '<circle cx=\"36\" cy=\"36\" r=\"22\" fill=\"none\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"/>' +\n        '<line class=\"ptr\" x1=\"36\" y1=\"36\" x2=\"36\" y2=\"18\" stroke=\"' + col + '\" stroke-width=\"2.6\" stroke-linecap=\"round\" filter=\"url(#gl' + i + ')\"/>' +\n        '<circle class=\"hub\" cx=\"36\" cy=\"36\" r=\"3.4\" fill=\"' + col + '\"/>' +\n      '</svg>';\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\";\n    name.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    wrap.appendChild(dial);\n    wrap.appendChild(name);\n    wrap.appendChild(val);\n\n    var svg = dial.querySelector(\"svg\");\n    var arc = svg.querySelector(\".arc\");\n    var track = svg.querySelector(\".track\");\n    var ptr = svg.querySelector(\".ptr\");\n\n    function deg2pt(a, r) {\n      var rad = (a - 90) * Math.PI / 180;\n      return [CX + r * Math.cos(rad), CY + r * Math.sin(rad)];\n    }\n    function arcPath(fromA, toA, r) {\n      var a = deg2pt(fromA, r), b = deg2pt(toA, r);\n      var large = (toA - fromA) > 180 ? 1 : 0;\n      return \"M\" + a[0].toFixed(2) + \" \" + a[1].toFixed(2) +\n             \" A\" + r + \" \" + r + \" 0 \" + large + \" 1 \" + b[0].toFixed(2) + \" \" + b[1].toFixed(2);\n    }\n    track.setAttribute(\"d\", arcPath(A0, A1, R));\n\n    function render() {\n      var v = values[i];\n      var t = (v - p.min) / (p.max - p.min);\n      var a = A0 + (A1 - A0) * t;\n      arc.setAttribute(\"d\", arcPath(A0, a, R));\n      var pe = deg2pt(a, 16);\n      ptr.setAttribute(\"x2\", pe[0].toFixed(2));\n      ptr.setAttribute(\"y2\", pe[1].toFixed(2));\n      val.textContent = Math.round(t * 100) + \"%\";\n    }\n\n    // drag vertically to turn\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var step = (e.shiftKey ? 0.0015 : 0.006);\n      values[i] = Math.max(p.min, Math.min(p.max, values[i] + dy * step * (p.max - p.min)));\n      render();\n      pushParam(i);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n    dial.addEventListener(\"mousedown\", onDown);\n    dial.addEventListener(\"touchstart\", onDown, { passive: false });\n\n    dial.addEventListener(\"dblclick\", function () {\n      values[i] = p.def;\n      render();\n      pushParam(i);\n    });\n    dial.addEventListener(\"wheel\", function (e) {\n      values[i] = Math.max(p.min, Math.min(p.max, values[i] - Math.sign(e.deltaY) * 0.02 * (p.max - p.min)));\n      render();\n      pushParam(i);\n      e.preventDefault();\n    }, { passive: false });\n\n    knobEls.push({ render: render });\n    document.getElementById(\"knobs\").appendChild(wrap);\n    render();\n  }\n\n  PARAMS.forEach(makeKnob);\n\n  // ===================================================================\n  //  PATCH JACKS  (decorative semi-modular field; light up live)\n  // ===================================================================\n  var JACK_DEFS = [\n    { n: \"VCO\",  live: true  },\n    { n: \"PWM\",  live: true  },\n    { n: \"S&H\",  live: true  },\n    { n: \"LFO\",  live: false },\n    { n: \"ENV\",  live: true  },\n    { n: \"VCF\",  live: true  }\n  ];\n  var jackEls = [];\n  (function buildJacks() {\n    var host = document.getElementById(\"jacks\");\n    JACK_DEFS.forEach(function (j) {\n      var el = document.createElement(\"div\");\n      el.className = \"jack\" + (j.live ? \" live\" : \"\");\n      el.innerHTML =\n        '<svg width=\"26\" height=\"26\" viewBox=\"0 0 26 26\">' +\n          '<circle cx=\"13\" cy=\"13\" r=\"11\" fill=\"#04100b\" stroke=\"#214234\" stroke-width=\"1.5\"/>' +\n          '<circle cx=\"13\" cy=\"13\" r=\"7\" fill=\"#0a1c14\" stroke=\"#16302440\" stroke-width=\"1\"/>' +\n          '<circle class=\"hole\" cx=\"13\" cy=\"13\" r=\"3.4\" fill=\"#020a07\"/>' +\n        '</svg>' +\n        '<span class=\"jl\">' + j.n + '</span>';\n      host.appendChild(el);\n      jackEls.push({ el: el, hole: el.querySelector(\".hole\"), def: j });\n    });\n  })();\n\n  // ===================================================================\n  //  MOD-BUS SCOPE  (animated stepped S&H / smooth LFO readout)\n  // ===================================================================\n  var scope = document.getElementById(\"scope\");\n  var ctx = scope.getContext(\"2d\");\n  var modModeEl = document.getElementById(\"modMode\");\n  var W = scope.width, H = scope.height;\n\n  var hist = new Array(120).fill(0);\n  var modPhase = 0;\n  var shVal = 0;\n  var shSmooth = 0;\n  var rng = 0x1234567 >>> 0;\n  function nextRand() {\n    rng ^= rng << 13; rng ^= rng >>> 17; rng ^= rng << 5; rng >>>= 0;\n    return (rng / 0xffffffff) * 2 - 1;\n  }\n\n  var glow = 0;        // pulses when a note triggers / S&H steps\n  var lastT = 0;\n\n  function drawScope(now) {\n    var dt = lastT ? (now - lastT) / 1000 : 0.016;\n    lastT = now;\n    if (dt > 0.05) dt = 0.05;\n\n    var rate = 0.3 + Math.pow(values[4], 2) * 27.7; // Hz, mirrors DSP\n    var depth = values[3];\n    var lfoBlend = Math.max(0, Math.min(1, (values[4] - 0.5) * 2));\n    modModeEl.textContent = lfoBlend > 0.5 ? \"LFO\" : \"S&H\";\n\n    modPhase += rate * dt;\n    while (modPhase >= 1) {\n      modPhase -= 1;\n      shVal = nextRand();\n      glow = 1;\n    }\n    shSmooth += Math.min(1, 14 * dt) * (shVal - shSmooth);\n    var tri = 4 * Math.abs(modPhase - 0.5) - 1;\n    var src = shSmooth * (1 - lfoBlend) + tri * lfoBlend;\n    var modOut = src * depth;\n\n    hist.push(modOut);\n    hist.shift();\n\n    glow *= Math.pow(0.0001, dt); // fast decay\n\n    // --- render ---\n    ctx.clearRect(0, 0, W, H);\n\n    // baseline grid\n    ctx.strokeStyle = \"rgba(67,224,160,0.10)\";\n    ctx.lineWidth = 1;\n    for (var gx = 0; gx <= 4; gx++) {\n      var x = (gx / 4) * W;\n      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();\n    }\n    ctx.beginPath(); ctx.moveTo(0, H / 2); ctx.lineTo(W, H / 2); ctx.stroke();\n\n    // waveform\n    var col = lfoBlend > 0.5 ? ACCENT2 : ACCENT;\n    ctx.strokeStyle = col;\n    ctx.lineWidth = 2;\n    ctx.shadowColor = col;\n    ctx.shadowBlur = 6 + glow * 10;\n    ctx.beginPath();\n    for (var k = 0; k < hist.length; k++) {\n      var px = (k / (hist.length - 1)) * W;\n      var py = H / 2 - hist[k] * (H / 2 - 6);\n      if (k === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);\n    }\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    // leading dot\n    var ly = H / 2 - hist[hist.length - 1] * (H / 2 - 6);\n    ctx.fillStyle = col;\n    ctx.beginPath(); ctx.arc(W - 2, ly, 2.6 + glow * 2, 0, Math.PI * 2); ctx.fill();\n\n    // pulse the S&H / VCF jacks with the mod glow\n    var a = 0.35 + glow * 0.65;\n    jackEls.forEach(function (jk) {\n      if (jk.def.n === \"S&H\" || jk.def.n === \"VCF\") {\n        jk.hole.setAttribute(\"fill\", glow > 0.05\n          ? \"rgba(67,224,160,\" + a.toFixed(2) + \")\"\n          : \"#020a07\");\n      }\n    });\n\n    if (!document.hidden) requestAnimationFrame(drawScope);\n  }\n  requestAnimationFrame(drawScope);\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden) { lastT = 0; requestAnimationFrame(drawScope); }\n  });\n\n  // ===================================================================\n  //  KEYBOARD  (on-screen, mono — calls vstai.noteOn / noteOff)\n  // ===================================================================\n  var START = 48; // C3\n  var NUM_WHITE = 15;\n  var WHITE_SEMI = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK_AFTER = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 }; // white-index -> black semitone offset\n\n  var keysHost = document.getElementById(\"keys\");\n  var keyEls = {}; // midi -> element\n  var pressed = {};\n\n  function noteOn(m) {\n    if (pressed[m]) return;\n    pressed[m] = true;\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(m, 0.9);\n    if (keyEls[m]) keyEls[m].classList.add(\"down\");\n    glow = 1;\n  }\n  function noteOff(m) {\n    if (!pressed[m]) return;\n    pressed[m] = false;\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(m);\n    if (keyEls[m]) keyEls[m].classList.remove(\"down\");\n  }\n\n  // build white keys\n  var whiteMidis = [];\n  for (var w = 0; w < NUM_WHITE; w++) {\n    var oct = Math.floor(w / 7);\n    var semi = WHITE_SEMI[w % 7];\n    var m = START + oct * 12 + semi;\n    whiteMidis.push(m);\n    var el = document.createElement(\"div\");\n    el.className = \"wkey\";\n    el.dataset.midi = m;\n    keysHost.appendChild(el);\n    keyEls[m] = el;\n  }\n  // build black keys positioned over the white row\n  for (var b = 0; b < NUM_WHITE; b++) {\n    var local = b % 7;\n    if (BLACK_AFTER[local] === undefined) continue;\n    if (b === NUM_WHITE - 1) continue;\n    var octB = Math.floor(b / 7);\n    var bm = START + octB * 12 + BLACK_AFTER[local];\n    var bk = document.createElement(\"div\");\n    bk.className = \"bkey\";\n    bk.dataset.midi = bm;\n    bk.style.left = (((b + 1) / NUM_WHITE) * 100) + \"%\";\n    keysHost.appendChild(bk);\n    keyEls[bm] = bk;\n  }\n\n  // pointer interaction (mono glide via drag across keys)\n  var mouseHeld = false;\n  function midiAt(target) {\n    if (target && target.dataset && target.dataset.midi) return +target.dataset.midi;\n    return null;\n  }\n  function elFromPoint(x, y) {\n    var t = document.elementFromPoint(x, y);\n    return midiAt(t);\n  }\n  keysHost.addEventListener(\"mousedown\", function (e) {\n    mouseHeld = true;\n    var m = elFromPoint(e.clientX, e.clientY);\n    if (m != null) { lastDown = m; noteOn(m); }\n    e.preventDefault();\n  });\n  var lastDown = null;\n  window.addEventListener(\"mousemove\", function (e) {\n    if (!mouseHeld) return;\n    var m = elFromPoint(e.clientX, e.clientY);\n    if (m != null && m !== lastDown) {\n      if (lastDown != null) noteOff(lastDown);\n      lastDown = m;\n      noteOn(m);\n    }\n  });\n  window.addEventListener(\"mouseup\", function () {\n    mouseHeld = false;\n    if (lastDown != null) { noteOff(lastDown); lastDown = null; }\n  });\n\n  // touch\n  keysHost.addEventListener(\"touchstart\", function (e) {\n    var t = e.changedTouches[0];\n    var m = elFromPoint(t.clientX, t.clientY);\n    if (m != null) { lastDown = m; noteOn(m); }\n    e.preventDefault();\n  }, { passive: false });\n  keysHost.addEventListener(\"touchmove\", function (e) {\n    var t = e.changedTouches[0];\n    var m = elFromPoint(t.clientX, t.clientY);\n    if (m != null && m !== lastDown) {\n      if (lastDown != null) noteOff(lastDown);\n      lastDown = m;\n      noteOn(m);\n    }\n    e.preventDefault();\n  }, { passive: false });\n  keysHost.addEventListener(\"touchend\", function (e) {\n    if (lastDown != null) { noteOff(lastDown); lastDown = null; }\n    e.preventDefault();\n  }, { passive: false });\n\n  // computer keyboard row (a..) for quick play\n  var KEYMAP = { a:48, w:49, s:50, e:51, d:52, f:53, t:54, g:55, y:56, h:57, u:58, j:59, k:60, o:61, l:62, p:63 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var m = KEYMAP[e.key];\n    if (m != null) noteOn(m);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var m = KEYMAP[e.key];\n    if (m != null) noteOff(m);\n  });\n\n  // ===================================================================\n  //  INIT — push defaults once the host bridge is ready\n  // ===================================================================\n  function start() {\n    pushAll();\n  }\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  LAB MONO — an aggressive, patchable single-VCO monophonic synth\n//  In the lineage of the raw Japanese semi-modular lab monos: ONE VCO\n//  (saw + pulse with PWM) feeding a screaming Korg-35-style 2-pole\n//  resonant low-pass that self-oscillates as Resonance is pushed, a\n//  punchy decay envelope, and a patchable MOD source (sample & hold OR\n//  triangle LFO) wired straight to the filter cutoff for burbling,\n//  zapping movement.\n//\n//  Signal path (mono, last-note priority):\n//    VCO (saw + PWM pulse) -> Korg-35 resonant LPF -> amp decay env -> level\n//      cutoff = base + EnvAmt*filterEnv + Mod(depth) * (S&H or LFO)\n//  A DC blocker and a bounded soft saturator keep the self-oscillating\n//  filter screaming but never exploding. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF: i32 = 0; // base cutoff 0..1\nconst P_RESO:   i32 = 1; // resonance 0..1 (screams toward self-oscillation)\nconst P_ENVAMT: i32 = 2; // filter-envelope amount 0..1\nconst P_MOD:    i32 = 3; // mod depth into cutoff 0..1\nconst P_MODRATE:i32 = 4; // mod rate 0..1 (Hz) AND S&H/LFO blend\nconst P_DECAY:  i32 = 5; // amp + filter decay 0..1\nconst P_LEVEL:  i32 = 6; // output level 0..1\n\n// ---- mono voice state (last-note priority) ----\nlet curNote: i32 = -1;   // currently sounding host note id (-1 = none)\nlet gate: i32 = 0;       // 1 while a key is held\nlet freq: f32 = 0.0;     // sounding frequency in Hz\nlet vel: f32 = 0.0;      // velocity 0..1\nlet phase: f32 = 0.0;    // oscillator phase 0..1\nlet fenv: f32 = 0.0;     // filter envelope 1 -> 0\nlet aenv: f32 = 0.0;     // amp envelope (decay/sustain)\n\n// Korg-35-style 2-pole low-pass state\nlet lp1: f32 = 0.0;\nlet lp2: f32 = 0.0;\n\n// ---- shared modulation: sample & hold + triangle LFO + RNG, DC, PWM ----\nlet modPhase: f32 = 0.0; // 0..1 clock for the mod source\nlet shValue: f32 = 0.0;  // current held random value (-1..1)\nlet shSmooth: f32 = 0.0; // lightly slewed S&H output (stepped but click-free)\nlet rngState: u32 = 0x1234567;\n\nlet pwmPhase: f32 = 0.0; // slow LFO that PWM-modulates the pulse width\n\nlet dcX: f32 = 0.0;      // DC blocker\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  curNote = -1; gate = 0;\n  freq = 0.0; vel = 0.0; phase = 0.0;\n  fenv = 0.0; aenv = 0.0;\n  lp1 = 0.0; lp2 = 0.0;\n  modPhase = 0.0; shValue = 0.0; shSmooth = 0.0;\n  rngState = 0x1234567;\n  pwmPhase = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_CUTOFF]  = 0.35;\n  params[P_RESO]    = 0.62;\n  params[P_ENVAMT]  = 0.55;\n  params[P_MOD]     = 0.45;\n  params[P_MODRATE] = 0.4;\n  params[P_DECAY]   = 0.45;\n  params[P_LEVEL]   = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// soft saturator: bounded, smooth, cheap (tames the screaming filter)\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// xorshift32 -> uniform random in [-1, 1]\n@inline function nextRand(): f32 {\n  let x: u32 = rngState;\n  x ^= x << 13;\n  x ^= x >> 17;\n  x ^= x << 5;\n  rngState = x;\n  const u: f32 = f32(x >> 8) * (1.0 / 16777216.0);\n  return f32(u * 2.0 - 1.0);\n}\n\n// Host passes frequency in Hz. Monophonic: a new note steals the voice.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 0.0001;\n  curNote = id;\n  gate = 1;\n  freq = nf;\n  vel = clampf(v, 0.0, 1.0);\n  phase = 0.0;\n  fenv = 1.0;      // retrigger the filter sweep\n  aenv = 1.0;      // retrigger the amp envelope\n}\n\nexport function noteOff(id: i32): void {\n  if (id == curNote) gate = 0;\n}\n\nexport function process(n: i32): void {\n  const cutoffN:  f32 = clampf(params[P_CUTOFF],  0.0, 1.0);\n  const resoN:    f32 = clampf(params[P_RESO],    0.0, 1.0);\n  const envAmtN:  f32 = clampf(params[P_ENVAMT],  0.0, 1.0);\n  const modN:     f32 = clampf(params[P_MOD],     0.0, 1.0);\n  const modRateN: f32 = clampf(params[P_MODRATE], 0.0, 1.0);\n  const decayN:   f32 = clampf(params[P_DECAY],   0.0, 1.0);\n  const level:    f32 = clampf(params[P_LEVEL],   0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Decay: filter env ~30 ms .. ~1.6 s; amp env follows for the percussive zap.\n  const fdecaySec: f32 = 0.03 + decayN * decayN * 1.6;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n  const adecaySec: f32 = 0.05 + decayN * decayN * 2.2;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n  // sustain floor scales with Decay so longer decay = more held body, shorter\n  // decay = more plucked — guarantees Decay changes the held note's loudness.\n  const sustainFloor: f32 = 0.12 + decayN * 0.55;\n\n  // Resonance 0..~1.6: pushes the Korg-35 feedback toward self-oscillation.\n  const reso: f32 = resoN * resoN * 1.62;\n\n  // Base cutoff (exponential, musical): ~60 Hz .. ~10 kHz.\n  const baseCut: f32 = f32(60.0 * Mathf.exp(cutoffN * 5.12));\n\n  // Filter-envelope sweep span (Hz).\n  const sweepSpan: f32 = envAmtN * 9000.0;\n\n  // Mod clock rate: ~0.3 Hz (slow burble) .. ~28 Hz (zapping).\n  const modRateHz: f32 = 0.3 + modRateN * modRateN * 27.7;\n  const modInc: f32 = modRateHz / sampleRate;\n\n  // Mod depth -> how many Hz the mod source moves the cutoff.\n  const modSpan: f32 = modN * 7000.0;\n\n  // Blend between S&H (low rate end) and triangle LFO (high rate end): the\n  // low half of Mod Rate is steppy S&H burble, the high half is smooth LFO\n  // zapping. This makes Mod Rate audibly change character, not just speed.\n  const lfoBlend: f32 = clampf((modRateN - 0.5) * 2.0, 0.0, 1.0);\n\n  // Lightly slew the stepped S&H value so steps are click-free but still steppy.\n  const shSlew: f32 = clampf(80.0 / sampleRate, 0.0, 1.0);\n\n  // PWM LFO ~2.7 Hz\n  const pwmInc: f32 = 2.7 / sampleRate;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // ---- mod source clock: triangle phase + stepped S&H ----\n    modPhase += modInc;\n    if (modPhase >= 1.0) {\n      modPhase -= 1.0;\n      shValue = nextRand();   // re-sample on each cycle\n    }\n    shSmooth += shSlew * (shValue - shSmooth);\n\n    // triangle LFO from the same phase (-1..1)\n    const tri: f32 = f32(4.0 * Mathf.abs(modPhase - 0.5) - 1.0);\n\n    // patchable mod: blend S&H (steppy) -> LFO (smooth) as rate rises\n    const modSrc: f32 = shSmooth * (1.0 - lfoBlend) + tri * lfoBlend;\n    const modCut: f32 = modSpan * modSrc;\n\n    // ---- PWM LFO ----\n    pwmPhase += pwmInc;\n    if (pwmPhase >= 1.0) pwmPhase -= 1.0;\n    const pw: f32 = 0.5 + 0.2 * f32(Mathf.sin(pwmPhase * TWO_PI));\n\n    // ---- oscillator: phase ramp -> saw + PWM pulse ----\n    let inc: f32 = freq / sampleRate;\n    if (inc < 0.0) inc = 0.0;\n    if (inc > 0.5) inc = 0.5;\n    phase += inc;\n    if (phase >= 1.0) phase -= 1.0;\n\n    const saw: f32 = phase * 2.0 - 1.0;\n    const pulse: f32 = phase < pw ? 1.0 : -1.0;\n    let osc: f32 = 0.62 * saw + 0.38 * pulse;\n    osc *= 0.9;\n\n    // ---- envelopes ----\n    let fe: f32 = fenv * fenvCoef;\n    fenv = fe;\n\n    let ae: f32 = aenv * aenvCoef;\n    if (gate != 0) {\n      if (ae < sustainFloor) ae = sustainFloor;   // decay to a Decay-scaled sustain\n    }\n    aenv = ae;\n\n    // ---- cutoff: base + filter-env sweep + patchable mod ----\n    let cutHz: f32 = baseCut + sweepSpan * fe + modCut;\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- Korg-35-style 2-pole resonant low-pass ----\n    let fc: f32 = cutHz / nyq;\n    if (fc > 0.49) fc = 0.49;\n    const g: f32 = fc * (1.85 - 0.85 * fc);\n\n    // feedback from the band-pass node drives the screaming resonance; the\n    // saturator inside the loop keeps self-oscillation bounded and gritty.\n    const bp: f32 = lp1 - lp2;\n    const fb: f32 = reso * satf(bp * 1.4);\n    const input: f32 = osc - fb;\n\n    lp1 += g * (input - lp1);\n    lp2 += g * (lp1 - lp2);\n\n    let filtered: f32 = satf(lp2 * 1.25);\n\n    // ---- amp env + velocity loudness ----\n    const ampBoost: f32 = 0.55 + 0.45 * vel;\n    let s: f32 = filtered * ae * ampBoost;\n\n    // ---- DC blocker ----\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // headroom + output level (keeps the screaming filter peak < ~1.0)\n    s = satf(s * 0.85) * level * 0.92;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n\n    // retire once fully released and silent\n    if (gate == 0 && aenv < 0.0006 && fenv < 0.0006) {\n      // voice idle; nothing to do (keeps state stable)\n    }\n  }\n}\n",
  "publishedAt": 1751000147000
}