{
  "format": 1,
  "name": "Rack Echo",
  "isInstrument": false,
  "explanation": "A pristine 80s studio rack digital delay with a doubler mode. Clean, hi-fi repeats (no tape grit, no companding) run through a low-pass filtered feedback path so successive echoes gently roll off their highs. A subtle stereo LFO modulates the read position so a single repeat can be fattened into a wide chorused double or slapback. Controls: Time, Feedback, Modulation (doubler/chorus depth), Tone (repeat HF) and dry/wet Mix; Mix at 0 is dry.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Modulation",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --ac:#6ad0ff;       /* cyan digital readout */\n  --ac2:#b0a0ff;      /* violet doubler tint */\n  --face:#161922;\n  --face2:#0c0e14;\n  --steel:#2a2f3b;\n  --led:#7dffb0;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:#cdd6e6;\n  background:\n    radial-gradient(130% 90% at 50% -10%,#1a1d27 0%,#0a0c11 60%,#05060a 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:22px;overflow:hidden;\n}\n\n/* ===== 1U rack face ===== */\n.rack{\n  position:relative;\n  width:640px;max-width:96vw;\n  border-radius:10px;\n  padding:16px 22px 18px;\n  background:\n    linear-gradient(180deg,#262b37 0%,#181c25 8%,#13161e 50%,#0d1016 92%,#1c2029 100%);\n  box-shadow:\n    0 30px 70px -20px rgba(0,0,0,.8),\n    0 1px 0 rgba(255,255,255,.10) inset,\n    0 -14px 30px -16px rgba(0,0,0,.7) inset,\n    0 0 0 1px #04060a,\n    0 0 0 4px #0a0d13;\n  animation:rise .65s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(20px) scale(.98)}to{opacity:1;transform:none}}\n/* brushed-metal horizontal grain + top sheen */\n.rack::before{\n  content:\"\";position:absolute;inset:0;border-radius:10px;pointer-events:none;\n  background:\n    repeating-linear-gradient(0deg,rgba(255,255,255,.022) 0 1px,transparent 1px 3px),\n    linear-gradient(180deg,rgba(255,255,255,.10),transparent 14%);\n  mix-blend-mode:screen;opacity:.7;\n}\n/* rack ears (mounting holes) */\n.ear{position:absolute;top:0;bottom:0;width:26px;display:flex;flex-direction:column;\n  justify-content:space-between;padding:14px 0;align-items:center}\n.ear.l{left:0}.ear.r{right:0}\n.hole{width:9px;height:9px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#05070b,#0c0f15 60%,#2a2f3b 100%);\n  box-shadow:0 1px 0 rgba(255,255,255,.12),inset 0 1px 2px rgba(0,0,0,.9)}\n\n.inner{position:relative;display:flex;gap:18px;align-items:stretch;margin:0 18px}\n\n/* ===== left: branding + readout ===== */\n.left{flex:0 0 222px;display:flex;flex-direction:column;gap:10px}\n.brand{font-size:8px;letter-spacing:.4em;color:#7d8aa3;text-transform:uppercase}\nh1{margin:1px 0 0;font-size:19px;font-weight:800;letter-spacing:.05em;\n  color:#e8eefb;text-shadow:0 1px 0 #000}\nh1 b{color:var(--ac);font-weight:800}\n.tag{font-size:7.5px;letter-spacing:.26em;color:#6f7c95;text-transform:uppercase;margin-top:-2px}\n\n/* green/cyan time readout — the signature display */\n.disp{\n  position:relative;margin-top:4px;height:74px;border-radius:7px;overflow:hidden;\n  background:linear-gradient(180deg,#03110f,#01080a 70%);\n  box-shadow:inset 0 2px 8px rgba(0,0,0,.9),\n             0 0 0 1px #04100d,\n             0 0 0 2px rgba(0,0,0,.5),\n             inset 0 0 30px rgba(106,208,255,.10);\n}\n.disp::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:repeating-linear-gradient(0deg,rgba(0,0,0,.32) 0 2px,transparent 2px 4px);opacity:.45}\n.disp .ms{position:absolute;left:14px;top:11px;font-variant-numeric:tabular-nums;\n  font-weight:800;font-size:34px;letter-spacing:.02em;color:var(--ac);\n  text-shadow:0 0 6px var(--ac),0 0 18px rgba(106,208,255,.5)}\n.disp .unit{font-size:13px;color:#3f9fc4;margin-left:3px;text-shadow:none}\n.disp .meta{position:absolute;left:15px;bottom:9px;font-size:8px;letter-spacing:.22em;\n  color:#3fa6cf;text-transform:uppercase;opacity:.85;font-variant-numeric:tabular-nums}\n.disp .mode{position:absolute;right:13px;top:13px;font-size:8.5px;letter-spacing:.18em;\n  text-transform:uppercase;padding:3px 7px;border-radius:4px;\n  color:var(--ac2);border:1px solid rgba(176,160,255,.4);\n  box-shadow:0 0 10px rgba(176,160,255,.25) inset;transition:opacity .3s, color .3s}\n.disp .mode.dbl{color:#0a0e14;background:var(--ac2);box-shadow:0 0 14px var(--ac2);\n  animation:dblpulse 1.4s ease-in-out infinite}\n@keyframes dblpulse{0%,100%{box-shadow:0 0 8px var(--ac2)}50%{box-shadow:0 0 18px var(--ac2)}}\n\n/* tiny power led */\n.pwr{display:flex;align-items:center;gap:6px;margin-top:2px}\n.led{width:7px;height:7px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#dfffe9,var(--led) 50%,#0c4a2c 90%);\n  box-shadow:0 0 9px var(--led);animation:ledp 2.4s ease-in-out infinite}\n@keyframes ledp{0%,100%{opacity:.7}50%{opacity:1}}\n.pwr span{font-size:7.5px;letter-spacing:.24em;color:#84a59a;text-transform:uppercase}\n\n/* ===== middle: mirrored repeat-waveform scope ===== */\n.scope{\n  flex:1 1 auto;min-width:120px;position:relative;border-radius:7px;overflow:hidden;\n  background:radial-gradient(120% 130% at 50% 50%,#0b1018,#05080d 75%);\n  box-shadow:inset 0 2px 8px rgba(0,0,0,.85),0 0 0 1px #04060a,\n             inset 0 0 28px rgba(106,208,255,.06);\n}\n.scope::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:linear-gradient(180deg,rgba(255,255,255,.06),transparent 22%)}\n.scope svg{position:absolute;inset:0;width:100%;height:100%}\n.axis{stroke:rgba(106,208,255,.10);stroke-width:1}\n.imp{fill:none;stroke-width:2.2;stroke-linecap:round}\n.impL{stroke:var(--ac);filter:drop-shadow(0 0 5px var(--ac))}\n.impR{stroke:var(--ac2);filter:drop-shadow(0 0 5px var(--ac2))}\n.head{stroke:rgba(255,255,255,.5);stroke-width:1;stroke-dasharray:2 4;\n  animation:flow 1.1s linear infinite}\n@keyframes flow{to{stroke-dashoffset:-12}}\n.scope .lbl{position:absolute;left:8px;top:6px;font-size:7px;letter-spacing:.2em;\n  color:#5b7c92;text-transform:uppercase}\n.scope .lblR{left:auto;right:8px;color:#7a6fb0}\n\n/* ===== knob deck ===== */\n.deck{display:flex;justify-content:space-between;gap:8px;margin:18px 18px 2px}\n.pot{display:flex;flex-direction:column;align-items:center;gap:6px;flex:1;\n  animation:pop .5s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:72px;height:72px;cursor:ns-resize;touch-action:none;user-select:none}\n/* tick ring */\n.ticks{position:absolute;inset:-2px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(180,200,230,.45) 0 1deg,transparent 1deg 16.875deg);\n  -webkit-mask:radial-gradient(circle,transparent 35px,#000 36px,#000 39px,transparent 40px);\n  mask:radial-gradient(circle,transparent 35px,#000 36px,#000 39px,transparent 40px)}\n/* value arc */\n.arc{position:absolute;inset:2px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.06) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(1px + var(--n)*7px) var(--ac));\n  transition:--n .1s cubic-bezier(.2,.8,.25,1)}\n/* metal cap */\n.cap{position:absolute;top:9px;left:9px;width:54px;height:54px;border-radius:50%;\n  background:radial-gradient(circle at 50% 26%,#3a4150 0%,#1b2029 58%,#0c0f15 100%);\n  box-shadow:inset 0 2px 5px rgba(255,255,255,.14),\n             inset 0 -6px 12px rgba(0,0,0,.8),\n             0 4px 9px rgba(0,0,0,.55)}\n.cap::before{content:\"\";position:absolute;inset:5px;border-radius:50%;\n  background:repeating-conic-gradient(#1c222c 0 11deg,#0d1116 11deg 22deg);opacity:.55}\n.cap::after{content:\"\";position:absolute;inset:13px;border-radius:50%;\n  background:radial-gradient(circle at 50% 30%,#414a59,#11151b);\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.2)}\n.ptr{position:absolute;top:6px;left:50%;width:3px;height:19px;margin-left:-1.5px;border-radius:3px;\n  background:linear-gradient(var(--ac2),var(--ac));\n  box-shadow:0 0 7px var(--ac),0 0 2px #fff;\n  transform-origin:50% 30px;\n  transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .1s cubic-bezier(.2,.8,.25,1)}\n.pname{font-size:8.5px;font-weight:700;letter-spacing:.18em;color:#9fb0c8;text-transform:uppercase}\n.pval{font-size:11px;font-weight:800;color:#e8f4ff;font-variant-numeric:tabular-nums;\n  min-height:13px;text-shadow:0 0 7px rgba(106,208,255,.4)}\n.knob.act .cap{box-shadow:inset 0 2px 5px rgba(255,255,255,.14),inset 0 -6px 12px rgba(0,0,0,.8),0 4px 13px rgba(106,208,255,.5)}\n.knob.act .arc{filter:drop-shadow(0 0 calc(3px + var(--n)*9px) var(--ac))}\n</style>\n</head>\n<body>\n<div class=\"rack\">\n  <div class=\"ear l\"><span class=\"hole\"></span><span class=\"hole\"></span></div>\n  <div class=\"ear r\"><span class=\"hole\"></span><span class=\"hole\"></span></div>\n\n  <div class=\"inner\">\n    <div class=\"left\">\n      <div class=\"brand\">Studio Rack Series &middot; 1U</div>\n      <h1>RACK <b>ECHO</b></h1>\n      <div class=\"tag\">Digital Delay / Doubler</div>\n\n      <div class=\"disp\">\n        <div class=\"ms\"><span id=\"msv\">0</span><span class=\"unit\">ms</span></div>\n        <div class=\"mode\" id=\"mode\">Delay</div>\n        <div class=\"meta\"><span id=\"fbv\">FB 0%</span> &middot; <span id=\"mixv\">MIX 0%</span></div>\n      </div>\n      <div class=\"pwr\"><span class=\"led\"></span><span>Power</span></div>\n    </div>\n\n    <div class=\"scope\">\n      <div class=\"lbl\">L</div><div class=\"lbl lblR\">R</div>\n      <svg viewBox=\"0 0 300 150\" preserveAspectRatio=\"none\">\n        <line class=\"axis\" x1=\"0\" y1=\"40\" x2=\"300\" y2=\"40\"/>\n        <line class=\"axis\" x1=\"0\" y1=\"110\" x2=\"300\" y2=\"110\"/>\n        <line class=\"head\" x1=\"14\" y1=\"6\" x2=\"14\" y2=\"144\"/>\n        <path id=\"impL\" class=\"imp impL\" d=\"\"/>\n        <path id=\"impR\" class=\"imp impR\" d=\"\"/>\n      </svg>\n    </div>\n  </div>\n\n  <div class=\"deck\" id=\"deck\"></div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Time\",       index:0,min:0,max:1,def:0.35},\n    {name:\"Feedback\",   index:1,min:0,max:1,def:0.35},\n    {name:\"Modulation\", index:2,min:0,max:1,def:0.30},\n    {name:\"Tone\",       index:3,min:0,max:1,def:0.65},\n    {name:\"Mix\",        index:4,min:0,max:1,def:0.40}\n  ];\n  var state={};\n  var deck=document.getElementById('deck');\n  var msv=document.getElementById('msv');\n  var fbv=document.getElementById('fbv');\n  var mixv=document.getElementById('mixv');\n  var modeEl=document.getElementById('mode');\n  var impL=document.getElementById('impL');\n  var impR=document.getElementById('impR');\n\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n  function timeMs(n){ return Math.round(20 + n*n*980); } // mirrors DSP 20..1000ms\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*60)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"ticks\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var ptr=cell.querySelector('.ptr');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n);\n      ptr.style.setProperty('--n',n);\n      val.textContent = p.index===0 ? timeMs(n)+\" ms\" : pct(n);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(n){\n      n=n<0?0:n>1?1:n;\n      v=p.min+(p.max-p.min)*n;\n      paint();\n    }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true; startY=e.clientY; startN=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?640:210;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault(); setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ---- update readout + mirrored repeat-impulse scope ----\n  function onChange(){\n    var timeN=state[0]!=null?state[0]:0.35;\n    var fb   =state[1]!=null?state[1]:0.35;\n    var mod  =state[2]!=null?state[2]:0.30;\n    var mix  =state[4]!=null?state[4]:0.40;\n\n    // readout\n    msv.textContent=timeMs(timeN);\n    fbv.textContent=\"FB \"+Math.round(fb*100)+\"%\";\n    mixv.textContent=\"MIX \"+Math.round(mix*100)+\"%\";\n    // mode flips to DOUBLE when modulation is up — the SDE-style doubler\n    if(mod>0.4){ modeEl.textContent=\"Double\"; modeEl.classList.add('dbl'); }\n    else{ modeEl.textContent=\"Delay\"; modeEl.classList.remove('dbl'); }\n\n    // scope: a row of decaying repeat impulses, spaced by Time.\n    // Modulation splits each repeat into a doubled (cyan/violet) pair and\n    // jitters them; Feedback sets how many repeats / how slowly they decay.\n    var W=300, headX=14;\n    var spacing=20 + timeN*40;          // px between repeats follows Time\n    var split=mod*7;                    // doubler L/R offset in px\n    var jitter=mod*4;                   // wobble width\n    var fall=0.55 + (1-fb)*0.35;        // decay per repeat (higher fb = slower)\n\n    function build(sideSplit){\n      var d=\"\";\n      var amp=34;\n      var x=headX, a=1.0, idx=0;\n      while(x<W && a>0.04 && idx<24){\n        var jx = (idx>0? Math.sin(idx*1.7)*jitter : 0);\n        var px = x + sideSplit + jx;\n        var h = amp*a;\n        // a short triangular impulse spike at this repeat\n        d+= \"M\"+(px-2).toFixed(1)+\",75 L\"+px.toFixed(1)+\",\"+(75-h).toFixed(1)+\n            \" L\"+(px+2).toFixed(1)+\",75 \";\n        x+=spacing;\n        a*=fall;\n        idx++;\n      }\n      return d;\n    }\n    impL.setAttribute('d', build(-split));\n    impR.setAttribute('d', build(+split));\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ onChange(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  RACK ECHO — clean 80s studio rack digital delay with a DOUBLER mode\n//  (SDE-3000 lineage, original algorithm).\n//\n//  A pristine, hi-fi delay line: no tape grit, no companding, no hold —\n//  just crisp digital repeats. A gentle stereo LFO modulates the read\n//  position so a single repeat can be fattened into a wide chorused\n//  DOUBLE / slapback (the Modulation control). The feedback path runs\n//  through a one-pole low-pass (Tone) so successive repeats roll off\n//  their high end, like the classic rack converters. Mix at 0 is dry.\n//\n//  Signal flow:\n//    in ─► [delay line]\n//             read at (delayTime + modL/R)  ──► wet tap (interp)\n//             feedback = LP(tone) of read   ──► write back into line\n//    out = dry*(1-mix) + wet*mix\n//\n//  Pure algorithm, no samples, no imports. All f32.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\n// Delay line capacity per channel: ~1.2 s at 48k is plenty for a rack delay.\nconst DELAY_LEN: i32 = 65536; // power of two, ~1.36 s @ 48k\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// one delay line per channel (planar, stride DELAY_LEN)\nconst line: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst fbState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // feedback LP memory\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // per-channel LFO phase\nlet smoothTime: f32 = 0.25; // smoothed delay time in seconds (avoids zipper/pitch jumps)\n\nconst PI2: f32 = 6.2831853;\n\nconst P_TIME: i32 = 0; // 0..1 -> 20ms .. 1000ms\nconst P_FB:   i32 = 1; // 0..1 -> 0 .. 0.92 feedback\nconst P_MOD:  i32 = 2; // 0..1 -> doubler/chorus depth on the repeats\nconst P_TONE: i32 = 3; // 0..1 -> repeat HF (feedback LP) 1.2k .. 16k\nconst P_MIX:  i32 = 4; // 0..1 -> dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0;\n    fbState[c] = 0.0;\n    lfoPhase[c] = c == 0 ? 0.0 : 0.25; // quarter-cycle offset → stereo width\n  }\n  for (let i = 0; i < DELAY_LEN * MAX_CHANNELS; i++) line[i] = 0.0;\n  smoothTime = 0.25;\n  params[P_TIME] = 0.35;\n  params[P_FB]   = 0.35;\n  params[P_MOD]  = 0.30;\n  params[P_TONE] = 0.65;\n  params[P_MIX]  = 0.40;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linear-interpolated read from a channel's delay line at a fractional\n// delay (in samples) behind the write head.\n@inline function readLine(base: i32, wp: i32, delaySamp: f32): f32 {\n  let d: f32 = delaySamp;\n  if (d < 1.0) d = 1.0;\n  const maxD: f32 = f32(DELAY_LEN - 2);\n  if (d > maxD) d = maxD;\n  const id: i32 = i32(d);\n  const frac: f32 = d - f32(id);\n  let r0: i32 = wp - id;\n  while (r0 < 0) r0 += DELAY_LEN;\n  let r1: i32 = r0 - 1;\n  if (r1 < 0) r1 += DELAY_LEN;\n  const a: f32 = line[base + r0];\n  const b: f32 = line[base + r1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fb:    f32 = clampf(params[P_FB],   0.0, 1.0) * 0.92;\n  const modN:  f32 = clampf(params[P_MOD],  0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix:   f32 = clampf(params[P_MIX],  0.0, 1.0);\n\n  // delay time 20ms..1000ms, perceptually scaled\n  const targetTime: f32 = 0.020 + timeN * timeN * 0.980;\n\n  // feedback-path low-pass corner: 1.2k (dark) .. 16k (pristine)\n  const toneHz: f32 = 1200.0 + toneN * toneN * 14800.0;\n  const cTone: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * toneHz / sampleRate)), 0.0, 1.0);\n\n  // LFO: ~0.45 Hz chorus/doubler wobble; depth up to ~7ms = lush double\n  const lfoInc: f32 = f32(0.45 / sampleRate);\n  const modDepthSamp: f32 = modN * modN * 0.007 * sampleRate; // seconds → samples\n  // a fixed short doubler offset so Modulation widens a single repeat into\n  // a slapback-thick double even at low feedback\n  const doubleOffSamp: f32 = modN * 0.004 * sampleRate;\n\n  // per-block delay-time smoothing coefficient\n  const tSmooth: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * 6.0 / sampleRate)), 0.0, 1.0);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * DELAY_LEN;\n    let wp: i32 = writePos[c];\n    let fbz: f32 = fbState[c];\n    let ph: f32 = lfoPhase[c];\n    let st: f32 = smoothTime;\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // smooth the base delay time toward target\n      st += tSmooth * (targetTime - st);\n\n      // LFO value (sine), per-channel phase for stereo doubler width\n      ph += lfoInc;\n      if (ph >= 1.0) ph -= 1.0;\n      const lfo: f32 = Mathf.sin(ph * PI2);\n\n      // primary read position (samples) with modulation + doubler offset\n      const baseSamp: f32 = st * sampleRate;\n      const modSamp: f32 = lfo * modDepthSamp + doubleOffSamp;\n      const readSamp: f32 = baseSamp + modSamp;\n\n      const wet: f32 = readLine(base, wp, readSamp);\n\n      // feedback through tone low-pass (darkens successive repeats)\n      fbz += cTone * (wet - fbz);\n      let into: f32 = x + fbz * fb;\n      // safety clamp so the feedback loop can never blow up\n      into = clampf(into, -1.2, 1.2);\n\n      line[base + wp] = into;\n      wp++;\n      if (wp >= DELAY_LEN) wp -= DELAY_LEN;\n\n      const y: f32 = x * (1.0 - mix) + wet * mix;\n      outBuf[c * MAX_FRAMES + f] = clampf(y, -1.0, 1.0);\n    }\n\n    writePos[c] = wp;\n    fbState[c] = fbz;\n    lfoPhase[c] = ph;\n    if (c == channels - 1) smoothTime = st; // commit smoothed time once per block\n  }\n}\n",
  "publishedAt": 1751000148000
}