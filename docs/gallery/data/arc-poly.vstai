{
  "format": 1,
  "name": "Arc Poly",
  "isInstrument": true,
  "explanation": "An American-style polyphonic synth voice: a bank of up to 8 independent voices, each with its own VCO (saw + PWM pulse), its own 4-pole resonant low-pass with a decay envelope, and its own amp envelope — so holding a chord sounds every note at its own pitch. A shared SAMPLE & HOLD source samples a new random level at the S&H Rate and wobbles every voice's cutoff by S&H Depth in lock-step, giving the classic stepped-random ARP burble. Pitch tracks each played note in Hz.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.42
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "S&H Depth",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "S&H Rate",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Arc Poly</title>\n<style>\n  :root {\n    --accent: #ff8a3d;\n    --accent2: #5ad0a0;\n    --slate-0: #1b1e22;\n    --slate-1: #23272c;\n    --slate-2: #2c3137;\n    --slate-3: #3a4047;\n    --edge-hi: rgba(255,255,255,0.10);\n    --edge-lo: rgba(0,0,0,0.55);\n    --ink: #d9dde1;\n    --ink-dim: #8b929a;\n    --font: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a2f35 0%, #1b1e22 55%, #15171a 100%);\n    color: var(--ink);\n    font-family: var(--font);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .shell {\n    max-width: 880px;\n    margin: 0 auto;\n    padding: 18px clamp(12px, 3vw, 26px) 26px;\n  }\n\n  /* ---------- hardware panel ---------- */\n  .panel {\n    position: relative;\n    border-radius: 16px;\n    padding: 18px 20px 22px;\n    background:\n      linear-gradient(180deg, #30353b 0%, #262b30 8%, #23272c 100%);\n    box-shadow:\n      inset 0 1px 0 var(--edge-hi),\n      inset 0 -2px 6px var(--edge-lo),\n      0 22px 50px rgba(0,0,0,0.55),\n      0 2px 0 rgba(0,0,0,0.4);\n    border: 1px solid #14171a;\n  }\n  /* brushed-metal hairlines */\n  .panel::before {\n    content: \"\";\n    position: absolute; inset: 0;\n    border-radius: 16px;\n    background: repeating-linear-gradient(\n      90deg, rgba(255,255,255,0.018) 0 2px, rgba(0,0,0,0.02) 2px 4px);\n    pointer-events: none;\n    mix-blend-mode: screen;\n  }\n  /* corner mounting screws */\n  .screw {\n    position: absolute;\n    width: 12px; height: 12px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #565d64, #2a2e33 70%, #1a1d20);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,0.25), 0 1px 2px rgba(0,0,0,0.6);\n  }\n  .screw::after {\n    content: \"\"; position: absolute; inset: 3px;\n    background: linear-gradient(45deg, transparent 44%, #1a1d20 44% 56%, transparent 56%);\n  }\n  .screw.tl { top: 10px; left: 10px; }\n  .screw.tr { top: 10px; right: 10px; }\n  .screw.bl { bottom: 10px; left: 10px; }\n  .screw.br { bottom: 10px; right: 10px; }\n\n  /* ---------- header ---------- */\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    padding: 2px 14px 14px;\n  }\n  .brand { display: flex; align-items: center; gap: 14px; }\n  .logo-mark {\n    width: 40px; height: 40px;\n    filter: drop-shadow(0 0 6px rgba(255,138,61,0.45));\n  }\n  .title { line-height: 1; }\n  .title h1 {\n    margin: 0;\n    font-size: 26px;\n    font-weight: 800;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, #fff, #c8ccd1 60%, #9aa0a7);\n    -webkit-background-clip: text; background-clip: text;\n    color: transparent;\n  }\n  .title .sub {\n    margin-top: 5px;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--accent);\n  }\n  .badge {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    border: 1px solid #14171a;\n    border-radius: 6px;\n    padding: 6px 9px;\n    background: linear-gradient(180deg, #2b3036, #21262b);\n    box-shadow: inset 0 1px 0 var(--edge-hi);\n  }\n  .badge b { color: var(--accent2); }\n\n  /* ---------- S&H scope ---------- */\n  .scope-wrap {\n    margin: 0 14px 18px;\n    border-radius: 12px;\n    padding: 12px 14px 10px;\n    background: linear-gradient(180deg, #0d1416, #0a0f11);\n    border: 1px solid #05080a;\n    box-shadow: inset 0 2px 10px rgba(0,0,0,0.7), inset 0 0 0 1px rgba(90,208,160,0.06);\n  }\n  .scope-head {\n    display: flex; justify-content: space-between; align-items: baseline;\n    margin-bottom: 6px;\n  }\n  .scope-head .lbl {\n    font-size: 10px; letter-spacing: 3px; text-transform: uppercase;\n    color: var(--accent2);\n  }\n  .scope-head .lbl .dot {\n    display: inline-block; width: 7px; height: 7px; border-radius: 50%;\n    background: var(--accent2); margin-right: 7px; vertical-align: middle;\n    box-shadow: 0 0 8px var(--accent2);\n    animation: pulse 1.6s ease-in-out infinite;\n  }\n  @keyframes pulse { 0%,100% { opacity: 0.45; } 50% { opacity: 1; } }\n  .scope-head .read {\n    font-size: 10px; letter-spacing: 1px; color: var(--ink-dim);\n    font-variant-numeric: tabular-nums;\n  }\n  canvas#scope {\n    display: block; width: 100%; height: 96px;\n    border-radius: 6px;\n  }\n\n  /* ---------- slider bank ---------- */\n  .bank {\n    display: flex;\n    gap: clamp(6px, 1.6vw, 16px);\n    justify-content: center;\n    padding: 4px 6px 0;\n    flex-wrap: wrap;\n  }\n  .slot {\n    flex: 1 1 0;\n    min-width: 78px;\n    max-width: 116px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .slot .name {\n    font-size: 9.5px;\n    letter-spacing: 1.8px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-bottom: 9px;\n    text-align: center;\n    min-height: 12px;\n  }\n  .slot.sh .name { color: var(--accent2); }\n\n  .fader {\n    position: relative;\n    width: 46px;\n    height: 168px;\n    border-radius: 9px;\n    background: linear-gradient(180deg, #1c2024, #15181b);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.7), inset 0 -1px 0 var(--edge-hi);\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  /* the slot well */\n  .fader .well {\n    position: absolute;\n    left: 50%; top: 12px; bottom: 12px;\n    width: 8px; transform: translateX(-50%);\n    border-radius: 5px;\n    background: linear-gradient(90deg, #000, #1e2226 50%, #000);\n    box-shadow: inset 0 0 3px rgba(0,0,0,0.9);\n    overflow: hidden;\n  }\n  /* filled (lit) portion below the cap */\n  .fader .fill {\n    position: absolute;\n    left: 0; right: 0; bottom: 0;\n    background: linear-gradient(180deg, var(--accent), #b85a1f);\n    box-shadow: 0 0 8px rgba(255,138,61,0.55);\n    transition: height 0.04s linear;\n  }\n  .slot.sh .fader .fill {\n    background: linear-gradient(180deg, var(--accent2), #2c7a5a);\n    box-shadow: 0 0 8px rgba(90,208,160,0.55);\n  }\n  /* tick marks */\n  .fader .ticks {\n    position: absolute;\n    right: 6px; top: 12px; bottom: 12px;\n    width: 6px;\n  }\n  .fader .ticks i {\n    position: absolute; right: 0; width: 6px; height: 1px;\n    background: rgba(255,255,255,0.16);\n  }\n  /* the cap */\n  .fader .cap {\n    position: absolute;\n    left: 50%;\n    width: 38px; height: 22px;\n    transform: translate(-50%, 50%);\n    border-radius: 5px;\n    background: linear-gradient(180deg, #4a525a 0%, #353b41 45%, #20242a 100%);\n    box-shadow:\n      0 3px 6px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.28),\n      inset 0 -2px 3px rgba(0,0,0,0.5);\n    transition: box-shadow 0.15s ease;\n  }\n  /* grip line in the cap, lit accent */\n  .fader .cap::after {\n    content: \"\";\n    position: absolute; left: 6px; right: 6px; top: 50%;\n    height: 3px; transform: translateY(-50%);\n    border-radius: 2px;\n    background: var(--accent);\n    box-shadow: 0 0 6px var(--accent);\n  }\n  .slot.sh .fader .cap::after {\n    background: var(--accent2);\n    box-shadow: 0 0 6px var(--accent2);\n  }\n  .fader:hover .cap,\n  .fader.drag .cap {\n    box-shadow:\n      0 4px 10px rgba(0,0,0,0.65),\n      inset 0 1px 0 rgba(255,255,255,0.35),\n      inset 0 -2px 3px rgba(0,0,0,0.5),\n      0 0 14px rgba(255,138,61,0.4);\n  }\n  .slot.sh .fader:hover .cap,\n  .slot.sh .fader.drag .cap {\n    box-shadow:\n      0 4px 10px rgba(0,0,0,0.65),\n      inset 0 1px 0 rgba(255,255,255,0.35),\n      inset 0 -2px 3px rgba(0,0,0,0.5),\n      0 0 14px rgba(90,208,160,0.4);\n  }\n  .slot .val {\n    margin-top: 10px;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n    color: var(--ink);\n    font-variant-numeric: tabular-nums;\n  }\n\n  /* ---------- keyboard ---------- */\n  .kbd-wrap {\n    margin: 20px 14px 2px;\n    padding: 12px 14px 14px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, #2a2f35, #1f2429);\n    box-shadow: inset 0 1px 0 var(--edge-hi), inset 0 -2px 5px var(--edge-lo);\n  }\n  .kbd-label {\n    font-size: 9px; letter-spacing: 3px; text-transform: uppercase;\n    color: var(--ink-dim); margin-bottom: 8px;\n  }\n  .keys {\n    position: relative;\n    height: 96px;\n    display: flex;\n    user-select: none;\n    touch-action: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1 1 0;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #f2efe8, #d8d3c8);\n    box-shadow: inset 0 -4px 5px rgba(0,0,0,0.18), 0 2px 3px rgba(0,0,0,0.4);\n    cursor: pointer;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent), #d8761f);\n    box-shadow: inset 0 3px 8px rgba(0,0,0,0.35);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 5.5%;\n    height: 60%;\n    margin-left: -2.75%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2c3036, #0f1215);\n    box-shadow: inset 0 -3px 3px rgba(255,255,255,0.08), 0 3px 4px rgba(0,0,0,0.6);\n    cursor: pointer;\n    z-index: 2;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2), #2c7a5a);\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"panel\">\n      <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n      <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n      <header>\n        <div class=\"brand\">\n          <svg class=\"logo-mark\" viewBox=\"0 0 48 48\" aria-hidden=\"true\">\n            <defs>\n              <linearGradient id=\"lg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                <stop offset=\"0\" stop-color=\"#ff8a3d\"/>\n                <stop offset=\"1\" stop-color=\"#5ad0a0\"/>\n              </linearGradient>\n            </defs>\n            <path d=\"M6 34 A18 18 0 0 1 42 34\" fill=\"none\" stroke=\"url(#lg)\" stroke-width=\"3.5\" stroke-linecap=\"round\"/>\n            <path d=\"M8 40 h6 v-8 h6 v6 h6 v-12 h6 v10 h6\" fill=\"none\" stroke=\"#5ad0a0\" stroke-width=\"2.4\" stroke-linecap=\"round\" stroke-linejoin=\"round\" opacity=\"0.85\"/>\n          </svg>\n          <div class=\"title\">\n            <h1>Arc Poly</h1>\n            <div class=\"sub\">American Poly Synthesizer</div>\n          </div>\n        </div>\n        <div class=\"badge\">Sample &amp; Hold &middot; <b>VCO/VCF</b></div>\n      </header>\n\n      <div class=\"scope-wrap\">\n        <div class=\"scope-head\">\n          <span class=\"lbl\"><span class=\"dot\"></span>Sample &amp; Hold</span>\n          <span class=\"read\" id=\"shRead\">depth 0% &middot; rate 0.0 hz</span>\n        </div>\n        <canvas id=\"scope\" width=\"780\" height=\"96\"></canvas>\n      </div>\n\n      <div class=\"bank\" id=\"bank\"></div>\n\n      <div class=\"kbd-wrap\">\n        <div class=\"kbd-label\">Keyboard &middot; click / drag to play</div>\n        <div class=\"keys\" id=\"keys\"></div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts / spec.json) ----\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.42, sh: false },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.55, sh: false },\n    { name: \"Env Amount\", index: 2, min: 0, max: 1, def: 0.60, sh: false },\n    { name: \"S&H Depth\",  index: 3, min: 0, max: 1, def: 0.45, sh: true },\n    { name: \"S&H Rate\",   index: 4, min: 0, max: 1, def: 0.40, sh: true },\n    { name: \"Decay\",      index: 5, min: 0, max: 1, def: 0.45, sh: false },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.80, sh: false }\n  ];\n\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  function pushParam(p) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(p.index, values[p.index] * (p.max - p.min) + p.min);\n    }\n  }\n\n  // ---- build faders ----\n  var bank = document.getElementById(\"bank\");\n\n  function fmt(p, v) {\n    if (p.name === \"S&H Rate\") {\n      var hz = 0.4 + v * v * 23.6;\n      return hz.toFixed(hz < 10 ? 2 : 1) + \" Hz\";\n    }\n    if (p.name === \"Cutoff\") {\n      var hz2 = 70 * Math.exp(v * 4.86);\n      return hz2 >= 1000 ? (hz2 / 1000).toFixed(2) + \" kHz\" : Math.round(hz2) + \" Hz\";\n    }\n    return Math.round(v * 100) + \"%\";\n  }\n\n  var faders = [];\n\n  PARAMS.forEach(function (p) {\n    var slot = document.createElement(\"div\");\n    slot.className = \"slot\" + (p.sh ? \" sh\" : \"\");\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\";\n    name.textContent = p.name;\n\n    var fader = document.createElement(\"div\");\n    fader.className = \"fader\";\n\n    var well = document.createElement(\"div\");\n    well.className = \"well\";\n    var fill = document.createElement(\"div\");\n    fill.className = \"fill\";\n    well.appendChild(fill);\n\n    var ticks = document.createElement(\"div\");\n    ticks.className = \"ticks\";\n    for (var t = 0; t <= 10; t++) {\n      var ti = document.createElement(\"i\");\n      ti.style.top = (t * 10) + \"%\";\n      ti.style.width = (t % 5 === 0) ? \"6px\" : \"3px\";\n      ticks.appendChild(ti);\n    }\n\n    var cap = document.createElement(\"div\");\n    cap.className = \"cap\";\n\n    fader.appendChild(well);\n    fader.appendChild(ticks);\n    fader.appendChild(cap);\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    slot.appendChild(name);\n    slot.appendChild(fader);\n    slot.appendChild(val);\n    bank.appendChild(slot);\n\n    var rec = { p: p, fader: fader, cap: cap, fill: fill, val: val };\n    faders.push(rec);\n\n    // travel range of the cap inside the fader (cap is 22px tall, 12px pad)\n    function layout() {\n      var v = values[p.index];\n      var h = fader.clientHeight;\n      var pad = 12;\n      var usable = h - pad * 2;\n      // cap centre travels from bottom(pad) to top(pad); css uses bottom offset\n      var bottom = pad + v * usable;\n      cap.style.bottom = bottom + \"px\";\n      cap.style.top = \"auto\";\n      fill.style.height = (v * (h - 24)) + \"px\";\n      val.textContent = fmt(p, v);\n    }\n    rec.layout = layout;\n\n    // ---- dragging ----\n    var dragging = false;\n    var startY = 0, startV = 0;\n\n    function setFromDelta(dy) {\n      var h = fader.clientHeight - 24;\n      var nv = startV + (-dy) / h;\n      nv = Math.max(0, Math.min(1, nv));\n      values[p.index] = nv;\n      layout();\n      pushParam(p);\n    }\n\n    fader.addEventListener(\"pointerdown\", function (e) {\n      dragging = true;\n      startY = e.clientY;\n      startV = values[p.index];\n      fader.classList.add(\"drag\");\n      fader.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    fader.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      setFromDelta(e.clientY - startY);\n    });\n    function endDrag(e) {\n      if (!dragging) return;\n      dragging = false;\n      fader.classList.remove(\"drag\");\n      try { fader.releasePointerCapture(e.pointerId); } catch (x) {}\n    }\n    fader.addEventListener(\"pointerup\", endDrag);\n    fader.addEventListener(\"pointercancel\", endDrag);\n\n    // wheel fine-tune\n    fader.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var nv = values[p.index] - Math.sign(e.deltaY) * 0.02;\n      values[p.index] = Math.max(0, Math.min(1, nv));\n      layout();\n      pushParam(p);\n    }, { passive: false });\n\n    // double-click reset\n    fader.addEventListener(\"dblclick\", function () {\n      values[p.index] = p.def;\n      layout();\n      pushParam(p);\n    });\n  });\n\n  function layoutAll() { faders.forEach(function (r) { r.layout(); }); }\n  window.addEventListener(\"resize\", layoutAll);\n\n  // ============================================================\n  //  S&H animated scope — a staircase of stepped random levels\n  //  that re-samples at the live S&H Rate, scaled by S&H Depth.\n  // ============================================================\n  var canvas = document.getElementById(\"scope\");\n  var ctx = canvas.getContext(\"2d\");\n  var shRead = document.getElementById(\"shRead\");\n\n  var STEPS = 26;\n  var levels = new Array(STEPS);\n  for (var s = 0; s < STEPS; s++) levels[s] = Math.random() * 2 - 1;\n  var smooth = new Array(STEPS).fill(0);\n\n  var stepClock = 0;       // seconds accumulator\n  var lastT = performance.now();\n  var glow = 0;            // brief brighten when a new step lands\n\n  function shRateHz() {\n    var v = values[4];\n    return 0.4 + v * v * 23.6;\n  }\n\n  function draw() {\n    if (document.hidden) { requestAnimationFrame(draw); lastT = performance.now(); return; }\n\n    var now = performance.now();\n    var dt = Math.min(0.05, (now - lastT) / 1000);\n    lastT = now;\n\n    var rate = shRateHz();\n    var depth = values[3];\n\n    // advance the step clock; each \"tick\" shifts the staircase + new random\n    stepClock += dt * rate;\n    while (stepClock >= 1) {\n      stepClock -= 1;\n      levels.shift();\n      levels.push(Math.random() * 2 - 1);\n      glow = 1;\n    }\n    glow *= 0.90;\n\n    // light slew so bars settle, matching the DSP's stepped-but-clickless feel\n    for (var i = 0; i < STEPS; i++) {\n      smooth[i] += (levels[i] - smooth[i]) * Math.min(1, dt * 28);\n    }\n\n    var W = canvas.width, H = canvas.height;\n    ctx.clearRect(0, 0, W, H);\n\n    // backdrop grid\n    ctx.strokeStyle = \"rgba(90,208,160,0.08)\";\n    ctx.lineWidth = 1;\n    for (var gx = 0; gx <= 6; gx++) {\n      var x = (gx / 6) * W;\n      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();\n    }\n    ctx.strokeStyle = \"rgba(255,255,255,0.05)\";\n    ctx.beginPath(); ctx.moveTo(0, H / 2); ctx.lineTo(W, H / 2); ctx.stroke();\n\n    // staircase\n    var bw = W / STEPS;\n    var mid = H / 2;\n    var amp = (H / 2 - 6) * depth;\n\n    // filled area under the staircase (orange wash scaled by depth)\n    ctx.beginPath();\n    ctx.moveTo(0, mid);\n    for (var k = 0; k < STEPS; k++) {\n      var yy = mid - smooth[k] * amp;\n      ctx.lineTo(k * bw, yy);\n      ctx.lineTo((k + 1) * bw, yy);\n    }\n    ctx.lineTo(W, mid);\n    ctx.closePath();\n    var grad = ctx.createLinearGradient(0, 0, 0, H);\n    grad.addColorStop(0, \"rgba(255,138,61,\" + (0.30 + glow * 0.25) + \")\");\n    grad.addColorStop(0.5, \"rgba(255,138,61,0.10)\");\n    grad.addColorStop(1, \"rgba(90,208,160,0.10)\");\n    ctx.fillStyle = grad;\n    ctx.fill();\n\n    // bright step line\n    ctx.lineWidth = 2;\n    ctx.strokeStyle = \"rgba(90,208,160,\" + (0.85 + glow * 0.15) + \")\";\n    ctx.shadowColor = \"rgba(90,208,160,0.7)\";\n    ctx.shadowBlur = 8 + glow * 10;\n    ctx.beginPath();\n    for (var j = 0; j < STEPS; j++) {\n      var y = mid - smooth[j] * amp;\n      if (j === 0) ctx.moveTo(0, y);\n      ctx.lineTo(j * bw, y);\n      ctx.lineTo((j + 1) * bw, y);\n    }\n    ctx.stroke();\n\n    // the newest (right-most) step node, lit accent\n    ctx.shadowBlur = 0;\n    var lastY = mid - smooth[STEPS - 1] * amp;\n    ctx.fillStyle = \"rgba(255,138,61,\" + (0.6 + glow * 0.4) + \")\";\n    ctx.beginPath();\n    ctx.arc(W - bw / 2, lastY, 3 + glow * 2.5, 0, Math.PI * 2);\n    ctx.fill();\n\n    shRead.textContent =\n      \"depth \" + Math.round(depth * 100) + \"% · rate \" +\n      (rate < 10 ? rate.toFixed(2) : rate.toFixed(1)) + \" hz\";\n\n    requestAnimationFrame(draw);\n  }\n\n  // ---- keyboard ----\n  var keysEl = document.getElementById(\"keys\");\n  var WHITE = [0, 2, 4, 5, 7, 9, 11, 12, 14, 16, 17, 19, 21, 23, 24];\n  var BLACK = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10, 7: 13, 8: 15, 10: 18, 11: 20, 12: 22 };\n  var BASE = 48; // C3\n  var down = {};\n\n  function mkNoteOn(n, el) {\n    if (down[n]) return;\n    down[n] = el;\n    el.classList.add(\"down\");\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, 0.85);\n  }\n  function mkNoteOff(n) {\n    var el = down[n];\n    if (!el) return;\n    el.classList.remove(\"down\");\n    delete down[n];\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  // build white keys then position black keys over them\n  WHITE.forEach(function (semi, wi) {\n    var note = BASE + semi;\n    var k = document.createElement(\"div\");\n    k.className = \"wkey\";\n    k.dataset.note = note;\n    keysEl.appendChild(k);\n  });\n\n  // black keys positioned relative to white index\n  var whiteCount = WHITE.length;\n  Object.keys(BLACK).forEach(function (wiKey) {\n    var wi = +wiKey;\n    var note = BASE + BLACK[wi];\n    var b = document.createElement(\"div\");\n    b.className = \"bkey\";\n    b.dataset.note = note;\n    // each white key spans (100/whiteCount)%; black sits at its right edge\n    b.style.left = (((wi + 1) / whiteCount) * 100) + \"%\";\n    keysEl.appendChild(b);\n  });\n\n  function noteFromEvent(e) {\n    var t = document.elementFromPoint(e.clientX, e.clientY);\n    if (t && t.dataset && t.dataset.note) return { n: +t.dataset.note, el: t };\n    return null;\n  }\n\n  var mouseHeld = null;\n  keysEl.addEventListener(\"pointerdown\", function (e) {\n    var hit = noteFromEvent(e);\n    if (!hit) return;\n    mkNoteOn(hit.n, hit.el);\n    mouseHeld = hit.n;\n    keysEl.setPointerCapture(e.pointerId);\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"pointermove\", function (e) {\n    if (mouseHeld === null) return;\n    var hit = noteFromEvent(e);\n    if (hit && hit.n !== mouseHeld) {\n      mkNoteOff(mouseHeld);\n      mkNoteOn(hit.n, hit.el);\n      mouseHeld = hit.n;\n    }\n  });\n  function releaseMouse(e) {\n    if (mouseHeld !== null) { mkNoteOff(mouseHeld); mouseHeld = null; }\n    try { keysEl.releasePointerCapture(e.pointerId); } catch (x) {}\n  }\n  keysEl.addEventListener(\"pointerup\", releaseMouse);\n  keysEl.addEventListener(\"pointercancel\", releaseMouse);\n\n  // computer-keyboard playing (A,W,S,E,D ... home row)\n  var KEYMAP = { a:0, w:1, s:2, e:3, d:4, f:5, t:6, g:7, y:8, h:9, u:10, j:11, k:12 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m === undefined) return;\n    var note = BASE + m;\n    var el = keysEl.querySelector('[data-note=\"' + note + '\"]');\n    if (el) mkNoteOn(note, el);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var m = KEYMAP[e.key.toLowerCase()];\n    if (m === undefined) return;\n    mkNoteOff(BASE + m);\n  });\n\n  // ---- init ----\n  function start() {\n    PARAMS.forEach(function (p) { pushParam(p); });\n    layoutAll();\n    requestAnimationFrame(draw);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  ARC POLY — a vintage American-style polyphonic synth voice\n//  A small bank of independent voices, each with its OWN oscillator\n//  (saw + pulse with PWM), its OWN 4-pole resonant low-pass and its OWN\n//  filter + amp envelopes. Holding a chord sounds every held note at its\n//  own pitch (true polyphony — 2 held notes give 2 distinct pitches).\n//  The signature trick is a shared SAMPLE & HOLD: a stepped-random source\n//  that re-samples at S&H Rate and wobbles every voice's filter cutoff in\n//  lock-step for the classic ARP-style burbling / random-step movement.\n//  Pure algorithm, no samples.\n//\n//  Signal path per voice:\n//    VCO (saw + pulse/PWM) -> 4-pole resonant LPF -> amp env -> sum\n//      cutoff = base + EnvAmt*filterEnv + S&HDepth*sampleHold(random steps)\n//  The summed voices then pass a DC blocker, a soft saturator and Level.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_VOICES: i32 = 8; // polyphony: up to 8 simultaneous notes\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32 = 3.14159265358979;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF:  i32 = 0; // base cutoff 0..1\nconst P_RESO:    i32 = 1; // resonance 0..1\nconst P_ENVAMT:  i32 = 2; // filter-envelope amount 0..1\nconst P_SHDEPTH: i32 = 3; // sample & hold depth into cutoff 0..1\nconst P_SHRATE:  i32 = 4; // sample & hold rate 0..1 (Hz)\nconst P_DECAY:   i32 = 5; // filter + amp decay 0..1\nconst P_LEVEL:   i32 = 6; // output level 0..1\n\n// ---- per-voice state (one independent synth voice per slot) ----\nconst vId:    StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // host note id (-1 = free)\nconst vActive:StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 if producing sound (held OR releasing)\nconst vGate:  StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 while the key is held\nconst vFreq:  StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // sounding freq (Hz)\nconst vVel:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // velocity 0..1\nconst vPhase: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // oscillator phase 0..1\nconst vFenv:  StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // filter envelope 1 -> 0\nconst vAenv:  StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // amp envelope\nconst vAge:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // for oldest-voice stealing\n// per-voice 4-pole ladder filter state\nconst vF0: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(MAX_VOICES);\nlet ageCtr: i32 = 0;\n\n// ---- shared modulation: sample & hold, PWM LFO, RNG, DC blocker ----\nlet shValue: f32 = 0.0;    // current held random value (-1..1)\nlet shPrev: f32 = 0.0;     // previous held value\nlet shSmooth: f32 = 0.0;   // lightly slewed S&H output (stepped but click-free)\nlet shPhase: f32 = 0.0;    // 0..1 clock for the S&H sampler\nlet rngState: u32 = 0x1234567;\n\nlet pwmPhase: f32 = 0.0;   // slow LFO that PWM-modulates the pulse width\n\nlet dcX: f32 = 0.0;        // DC blocker\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    vId[v] = -1; vActive[v] = 0; vGate[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vPhase[v] = 0.0;\n    vFenv[v] = 0.0; vAenv[v] = 0.0; vAge[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCtr = 0;\n  shValue = 0.0; shPrev = 0.0; shSmooth = 0.0; shPhase = 0.0;\n  rngState = 0x1234567;\n  pwmPhase = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_CUTOFF]  = 0.42;\n  params[P_RESO]    = 0.55;\n  params[P_ENVAMT]  = 0.6;\n  params[P_SHDEPTH] = 0.45;\n  params[P_SHRATE]  = 0.4;\n  params[P_DECAY]   = 0.45;\n  params[P_LEVEL]   = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// soft saturator: bounded, smooth, cheap (tames resonance + adds analog grit)\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// xorshift32 -> uniform random in [-1, 1]\n@inline function nextRand(): f32 {\n  let x: u32 = rngState;\n  x ^= x << 13;\n  x ^= x >> 17;\n  x ^= x << 5;\n  rngState = x;\n  const u: f32 = f32(x >> 8) * (1.0 / 16777216.0);\n  return f32(u * 2.0 - 1.0);\n}\n\n// Pick a voice slot for a new note: prefer a free slot, else steal the oldest.\n@inline function allocVoice(): i32 {\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] == 0) return v;\n  }\n  // none free — steal the oldest (lowest age counter)\n  let best: i32 = 0;\n  let bestAge: i32 = vAge[0];\n  for (let v = 1; v < MAX_VOICES; v++) {\n    if (vAge[v] < bestAge) { bestAge = vAge[v]; best = v; }\n  }\n  return best;\n}\n\n// Host passes frequency in Hz. Each note gets its own independent voice.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 0.0001;\n  const slot: i32 = allocVoice();\n  vId[slot]    = id;\n  vActive[slot]= 1;\n  vGate[slot]  = 1;\n  vFreq[slot]  = nf;\n  vVel[slot]   = clampf(v, 0.0, 1.0);\n  vPhase[slot] = 0.0;\n  vFenv[slot]  = 1.0;\n  vAenv[slot]  = 1.0;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot]   = ageCtr++;\n}\n\nexport function noteOff(id: i32): void {\n  // release every voice currently holding this id (gate off -> envelopes decay)\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vId[v] == id && vGate[v] != 0) {\n      vGate[v] = 0;\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32  = clampf(params[P_CUTOFF],  0.0, 1.0);\n  const resoN:   f32  = clampf(params[P_RESO],    0.0, 1.0);\n  const envAmtN: f32  = clampf(params[P_ENVAMT],  0.0, 1.0);\n  const shDepthN: f32 = clampf(params[P_SHDEPTH], 0.0, 1.0);\n  const shRateN: f32  = clampf(params[P_SHRATE],  0.0, 1.0);\n  const decayN:  f32  = clampf(params[P_DECAY],   0.0, 1.0);\n  const level:   f32  = clampf(params[P_LEVEL],   0.0, 1.0);\n\n  // ---- derived coefficients (shared across voices) ----\n\n  // Decay: filter env ~40 ms .. ~1.6 s; amp env a touch longer for ring-out.\n  const fdecaySec: f32 = 0.04 + decayN * decayN * 1.6;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n  const adecaySec: f32 = 0.07 + decayN * decayN * 2.0;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n\n  // Resonance 0..~3.9 (toward self-oscillation, bounded by satf).\n  const reso: f32 = resoN * 3.9;\n\n  // Base cutoff (exponential, musical): ~70 Hz .. ~9 kHz.\n  const baseCut: f32 = f32(70.0 * Mathf.exp(cutoffN * 4.86));\n\n  // Filter-envelope sweep span (Hz).\n  const sweepSpan: f32 = envAmtN * 8500.0;\n\n  // S&H clock rate: ~0.4 Hz (slow burble) .. ~24 Hz (fast bubbling).\n  const shRateHz: f32 = 0.4 + shRateN * shRateN * 23.6;\n  const shInc: f32 = shRateHz / sampleRate;\n\n  // S&H depth -> how many Hz the random step moves the cutoff.\n  const shSpan: f32 = shDepthN * 6500.0;\n\n  // Lightly slew the stepped value so steps are click-free but still obviously\n  // \"stepped\".\n  const shSlew: f32 = clampf(60.0 / sampleRate, 0.0, 1.0);\n\n  // PWM LFO ~3.1 Hz\n  const pwmInc: f32 = 3.1 / sampleRate;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // ---- shared sample & hold clock ----\n    shPhase += shInc;\n    if (shPhase >= 1.0) {\n      shPhase -= 1.0;\n      shPrev = shValue;\n      shValue = nextRand();\n    }\n    shSmooth += shSlew * (shValue - shSmooth);\n\n    // ---- shared PWM LFO ----\n    pwmPhase += pwmInc;\n    if (pwmPhase >= 1.0) pwmPhase -= 1.0;\n    const pw: f32 = 0.5 + 0.18 * f32(Mathf.sin(pwmPhase * 2.0 * PI));\n\n    // shared cutoff modulation contribution from filter-env-independent sources\n    const shCut: f32 = shSpan * shSmooth;\n\n    // ---- sum all active voices ----\n    let mix: f32 = 0.0;\n    for (let v = 0; v < MAX_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // oscillator: per-voice phase ramp -> saw + PWM pulse\n      let inc: f32 = vFreq[v] / sampleRate;\n      if (inc < 0.0) inc = 0.0;\n      if (inc > 0.5) inc = 0.5;\n      let ph: f32 = vPhase[v] + inc;\n      if (ph >= 1.0) ph -= 1.0;\n      vPhase[v] = ph;\n\n      const saw: f32 = ph * 2.0 - 1.0;\n      const pulse: f32 = ph < pw ? 1.0 : -1.0;\n      let osc: f32 = 0.6 * saw + 0.4 * pulse;\n      osc *= 0.9;\n\n      // per-voice envelopes\n      let fe: f32 = vFenv[v] * fenvCoef;\n      vFenv[v] = fe;\n      let ae: f32 = vAenv[v];\n      if (vGate[v] != 0) {\n        ae = ae * aenvCoef;\n        if (ae < 0.3) ae = 0.3; // sustain floor while held\n      } else {\n        ae = ae * aenvCoef;\n      }\n      vAenv[v] = ae;\n\n      // per-voice cutoff: base + filter-env sweep + shared S&H step\n      let cutHz: f32 = baseCut + sweepSpan * fe + shCut;\n      if (cutHz < 20.0) cutHz = 20.0;\n      if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n      // per-voice 4-pole resonant ladder\n      let fc: f32 = cutHz / nyq;\n      if (fc > 0.49) fc = 0.49;\n      const g: f32 = fc * (1.8 - 0.8 * fc);\n\n      const fb: f32 = reso * (1.0 - 0.15 * g);\n      let f3v: f32 = vF3[v];\n      const input: f32 = osc - fb * satf(f3v);\n\n      let f0v: f32 = vF0[v]; let f1v: f32 = vF1[v]; let f2v: f32 = vF2[v];\n      f0v += g * (input - f0v);\n      f1v += g * (f0v - f1v);\n      f2v += g * (f1v - f2v);\n      f3v += g * (f2v - f3v);\n      vF0[v] = f0v; vF1[v] = f1v; vF2[v] = f2v; vF3[v] = f3v;\n\n      let filtered: f32 = satf(f3v * 1.3);\n\n      // amp env + per-voice velocity loudness\n      const ampBoost: f32 = 0.5 + 0.5 * vVel[v];\n      mix += filtered * ae * ampBoost;\n\n      // retire the voice once it has fully released and gone quiet\n      if (vGate[v] == 0 && ae < 0.0008) {\n        vActive[v] = 0;\n        vId[v] = -1;\n      }\n    }\n\n    // ---- DC blocker on the summed mix ----\n    const y: f32 = mix - dcX + 0.9985 * dcY;\n    dcX = mix;\n    dcY = y;\n    let s: f32 = y;\n\n    // headroom: voices are summed, so scale before the saturator keeps peaks\n    // bounded no matter how many notes are held, then apply Level.\n    s = satf(s * 1.6) * level;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000122000
}