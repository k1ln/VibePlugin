{
  "format": 1,
  "name": "Master Glue",
  "isInstrument": false,
  "explanation": "A classic British console-style mix-bus 'glue' compressor for gelling a whole mix into one cohesive, punchy whole. A feed-forward, stereo-LINKED VCA detector watches the summed program and drives a single soft-knee gain-reduction element computed in the dB domain, so the same reduction hits both channels and the stereo image stays rock-solid. Ratio is stepped between the classic 2:1, 4:1 and 10:1 settings, Attack is stepped, and Release offers four fixed times plus an AUTO position whose program-dependent dual time-constant 'breathes' with the music — fast on transients, slow under sustained loudness. Makeup restores level, Mix blends parallel dry for New-York glue, and a soft output stage keeps the bus bounded. Controls: Threshold, Ratio, Attack, Release, Makeup and Mix.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 3,
      "default": 1
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 4,
      "default": 4
    },
    {
      "name": "Makeup",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Master Glue</title>\n<style>\n  :root{\n    --accent:#9aa6b2;\n    --accent2:#5ad0ff;\n    --blue:#2f6fd6;\n    --red:#d6433a;\n    --panel:#c7ccd2;\n    --panel2:#aeb4bb;\n    --ink:#23282d;\n    --etch:#7d848c;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none;}\n  html,body{margin:0;height:100%;background:radial-gradient(120% 120% at 50% 0%,#2a2f35 0%,#15181c 70%,#0c0e10 100%);font-family:\"Helvetica Neue\",Arial,sans-serif;color:var(--ink);}\n  .wrap{min-height:100%;display:flex;align-items:center;justify-content:center;padding:22px;}\n\n  /* ---- the console module: brushed silver-grey ---- */\n  .module{\n    position:relative;width:560px;border-radius:12px;padding:18px 20px 22px;\n    background:\n      repeating-linear-gradient(90deg,rgba(255,255,255,.05) 0 1px,rgba(0,0,0,.045) 1px 3px),\n      linear-gradient(180deg,#d9dde2 0%,#c2c7cd 40%,#b3b9c0 60%,#cdd2d8 100%);\n    box-shadow:0 22px 60px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.7),inset 0 -2px 6px rgba(0,0,0,.25);\n    border:1px solid #8d949b;\n  }\n  /* screw corners */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fafbfc,#9aa0a7 60%,#6b7077);\n    box-shadow:inset 0 0 2px rgba(0,0,0,.6),0 1px 1px rgba(255,255,255,.4);}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-top:1.5px solid #5c6168;transform:rotate(35deg);}\n  .screw.tl{top:7px;left:7px}.screw.tr{top:7px;right:7px}.screw.bl{bottom:7px;left:7px}.screw.br{bottom:7px;right:7px}\n\n  .brand{display:flex;align-items:baseline;justify-content:space-between;margin:0 6px 12px;}\n  .brand .name{font-weight:800;letter-spacing:3px;font-size:19px;color:#1d2227;text-shadow:0 1px 0 rgba(255,255,255,.6);}\n  .brand .sub{font-size:9.5px;letter-spacing:2px;color:#5a616a;text-transform:uppercase;}\n\n  /* ---- VU meter ---- */\n  .meterBox{\n    margin:0 6px 16px;border-radius:8px;padding:12px 14px 8px;\n    background:linear-gradient(180deg,#f3ead2 0%,#e7dcc0 100%);\n    border:1px solid #8c8674;box-shadow:inset 0 2px 8px rgba(0,0,0,.35),0 1px 0 rgba(255,255,255,.5);\n    position:relative;overflow:hidden;\n  }\n  .meterBox::before{content:\"GAIN REDUCTION (dB)\";position:absolute;top:6px;left:0;right:0;text-align:center;font-size:8px;letter-spacing:2px;color:#7a6f52;}\n  svg.vu{display:block;width:100%;height:118px;}\n  .needle{transform-box:fill-box;transform-origin:50% 100%;transition:transform .05s linear;}\n  .glass{position:absolute;inset:0;background:linear-gradient(120deg,rgba(255,255,255,.35),rgba(255,255,255,0) 45%);pointer-events:none;border-radius:8px;}\n\n  /* ---- controls row ---- */\n  .controls{display:flex;justify-content:space-between;gap:6px;margin:0 4px;}\n  .ctl{flex:1;display:flex;flex-direction:column;align-items:center;gap:7px;}\n  .ctl .cap{font-size:10px;letter-spacing:1.5px;font-weight:700;color:#2a2f34;text-transform:uppercase;}\n  .ctl .val{font-size:10px;color:#3a4047;font-variant-numeric:tabular-nums;min-height:12px;letter-spacing:.5px;}\n\n  .knob{position:relative;width:78px;height:78px;cursor:grab;touch-action:none;}\n  .knob.drag{cursor:grabbing;}\n  .knob .dial{position:absolute;inset:9px;border-radius:50%;\n    background:radial-gradient(circle at 38% 32%,#43494f,#22262b 70%,#15181b);\n    box-shadow:0 4px 8px rgba(0,0,0,.5),inset 0 1px 1px rgba(255,255,255,.18),inset 0 -3px 6px rgba(0,0,0,.6);}\n  .knob .ring{position:absolute;inset:0;}\n  /* chicken-head pointer */\n  .pointer{position:absolute;left:50%;top:50%;width:0;height:0;transform-origin:50% 50%;}\n  .pointer i{position:absolute;left:-5px;top:-3px;width:0;height:0;\n    border-top:5px solid transparent;border-bottom:5px solid transparent;border-left:26px solid var(--ph,#e9edf1);\n    filter:drop-shadow(0 1px 1px rgba(0,0,0,.5));}\n  .pointer b{position:absolute;left:-9px;top:-4px;width:8px;height:8px;border-radius:50%;background:#11140f;}\n  .ticks{position:absolute;inset:-3px;}\n  .tick{position:absolute;left:50%;top:50%;width:2px;height:7px;background:#4a5057;transform-origin:50% 40px;border-radius:1px;}\n  .tlbl{position:absolute;font-size:8.5px;color:#3b4147;font-weight:700;transform:translate(-50%,-50%);}\n\n  /* AUTO badge */\n  .autoBadge{margin-top:5px;font-size:8.5px;letter-spacing:2px;padding:2px 7px;border-radius:9px;font-weight:800;\n    color:#0c2230;background:#9aa6b2;border:1px solid #6f7882;opacity:.45;transition:all .25s;}\n  .autoBadge.on{opacity:1;background:linear-gradient(180deg,var(--accent2),#37b8e6);color:#04222e;\n    box-shadow:0 0 10px var(--accent2),0 0 22px rgba(90,208,255,.5);animation:breathe 2.4s ease-in-out infinite;}\n  @keyframes breathe{0%,100%{box-shadow:0 0 8px var(--accent2),0 0 16px rgba(90,208,255,.4);}50%{box-shadow:0 0 16px var(--accent2),0 0 34px rgba(90,208,255,.75);}}\n\n  .footer{margin:16px 8px 0;display:flex;justify-content:space-between;align-items:center;font-size:8px;letter-spacing:1.5px;color:#5b626b;}\n  .led{width:8px;height:8px;border-radius:50%;background:radial-gradient(circle at 35% 30%,#aef0ff,var(--accent2));box-shadow:0 0 8px var(--accent2);animation:pulse 1.6s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{opacity:.55}50%{opacity:1}}\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"module\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span><span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"brand\">\n      <span class=\"name\">MASTER&nbsp;GLUE</span>\n      <span class=\"sub\">Stereo&nbsp;Bus&nbsp;Compressor</span>\n    </div>\n\n    <div class=\"meterBox\">\n      <svg class=\"vu\" viewBox=\"0 0 320 120\" preserveAspectRatio=\"xMidYMid meet\">\n        <!-- arc -->\n        <path d=\"M40 110 A120 120 0 0 1 280 110\" fill=\"none\" stroke=\"#b6a987\" stroke-width=\"2\"/>\n        <!-- centre zero tick + scale -->\n        <g id=\"scale\" fill=\"#5d543b\" font-size=\"9\" font-family=\"Arial\" text-anchor=\"middle\"></g>\n        <line x1=\"160\" y1=\"20\" x2=\"160\" y2=\"34\" stroke=\"#2a3a1a\" stroke-width=\"2\"/>\n        <text x=\"160\" y=\"14\" fill=\"#2a3a1a\" font-size=\"9\" text-anchor=\"middle\" font-weight=\"700\">0</text>\n        <!-- red zone right (heavy reduction) -->\n        <path d=\"M205 41 A120 120 0 0 1 280 110\" fill=\"none\" stroke=\"#c44\" stroke-width=\"3\" opacity=\".55\"/>\n        <!-- needle -->\n        <g class=\"needle\" id=\"needle\">\n          <line x1=\"160\" y1=\"110\" x2=\"160\" y2=\"30\" stroke=\"#1a1d12\" stroke-width=\"2.4\"/>\n          <circle cx=\"160\" cy=\"110\" r=\"6\" fill=\"#2a2d20\"/>\n        </g>\n        <text x=\"160\" y=\"106\" fill=\"#7a6f52\" font-size=\"7\" text-anchor=\"middle\" letter-spacing=\"1\">VU</text>\n      </svg>\n      <div class=\"glass\"></div>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n\n    <div class=\"footer\">\n      <span>BRITISH&nbsp;MIX-BUS&nbsp;GLUE</span>\n      <span style=\"display:flex;align-items:center;gap:6px;\"><span class=\"led\"></span>POWER</span>\n    </div>\n  </div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n  // ---------- host bridge ----------\n  var HOST = (window.vstai && typeof window.vstai.setParam === \"function\") ? window.vstai : null;\n  function send(i,v){ if(HOST) try{ HOST.setParam(i,v); }catch(e){} }\n\n  // ---------- param model ----------\n  // continuous knobs map 0..1; stepped knobs map integer positions.\n  var RATIO_LBL = [\"2:1\",\"4:1\",\"10:1\"];\n  var ATTACK_LBL = [\"0.1\",\"0.3\",\"3\",\"10\"];        // ms feel\n  var RELEASE_LBL = [\"0.1\",\"0.3\",\"0.6\",\"1.2\",\"AUTO\"]; // s + AUTO\n\n  var PARAMS = [\n    {name:\"Threshold\", idx:0, type:\"cont\", min:0,max:1, def:0.5, fmt:function(v){return (-30+v*30).toFixed(1)+\" dB\";}},\n    {name:\"Ratio\",     idx:1, type:\"step\", steps:RATIO_LBL,  def:1, ph:\"var(--blue)\", color:\"var(--blue)\"},\n    {name:\"Attack\",    idx:2, type:\"step\", steps:ATTACK_LBL, def:1, ph:\"var(--red)\",  color:\"var(--red)\", unit:\" ms\"},\n    {name:\"Release\",   idx:3, type:\"step\", steps:RELEASE_LBL,def:4, ph:\"var(--blue)\", color:\"var(--blue)\", unit:\" s\"},\n    {name:\"Makeup\",    idx:4, type:\"cont\", min:0,max:1, def:0.3, fmt:function(v){return \"+\"+(v*18).toFixed(1)+\" dB\";}},\n    {name:\"Mix\",       idx:5, type:\"cont\", min:0,max:1, def:1.0, fmt:function(v){return Math.round(v*100)+\"%\";}}\n  ];\n\n  var state = {};   // idx -> current real value\n  var autoBadgeEl = null;\n\n  // sweep arc: -135deg .. +135deg\n  var A0=-135, A1=135;\n\n  function buildKnob(p){\n    var ctl = document.createElement(\"div\"); ctl.className=\"ctl\";\n    var cap = document.createElement(\"div\"); cap.className=\"cap\"; cap.textContent=p.name;\n    var knob = document.createElement(\"div\"); knob.className=\"knob\";\n    var ring = document.createElement(\"div\"); ring.className=\"ring\";\n    var ticks = document.createElement(\"div\"); ticks.className=\"ticks\";\n    var dial = document.createElement(\"div\"); dial.className=\"dial\";\n    var ptr = document.createElement(\"div\"); ptr.className=\"pointer\";\n    if(p.ph) ptr.style.setProperty(\"--ph\", p.ph.indexOf(\"var\")===0? getCss(p.ph):p.ph);\n    var pi=document.createElement(\"i\"); var pb=document.createElement(\"b\");\n    ptr.appendChild(pi); ptr.appendChild(pb);\n    knob.appendChild(ring); knob.appendChild(dial); knob.appendChild(ticks); knob.appendChild(ptr);\n    var val = document.createElement(\"div\"); val.className=\"val\";\n\n    // stepped tick marks\n    if(p.type===\"step\"){\n      var nS=p.steps.length;\n      for(var s=0;s<nS;s++){\n        var a=A0+(A1-A0)*(s/(nS-1));\n        var t=document.createElement(\"div\"); t.className=\"tick\";\n        t.style.transform=\"translate(-50%,-50%) rotate(\"+a+\"deg)\";\n        ticks.appendChild(t);\n      }\n    }\n\n    ctl.appendChild(cap); ctl.appendChild(knob); ctl.appendChild(val);\n\n    // AUTO badge under Release\n    var badge=null;\n    if(p.name===\"Release\"){\n      badge=document.createElement(\"div\"); badge.className=\"autoBadge\"; badge.textContent=\"AUTO\";\n      ctl.appendChild(badge); autoBadgeEl=badge;\n    }\n\n    p._el={knob:knob,ptr:ptr,val:val,badge:badge};\n    wireKnob(p);\n    return ctl;\n  }\n\n  function getCss(varExpr){\n    var name=varExpr.replace(\"var(\",\"\").replace(\")\",\"\").trim();\n    return getComputedStyle(document.documentElement).getPropertyValue(name).trim()||\"#e9edf1\";\n  }\n\n  function norm(p){ // current value -> 0..1 for the dial\n    var v=state[p.idx];\n    if(p.type===\"step\"){ return v/(p.steps.length-1); }\n    return (v-p.min)/(p.max-p.min);\n  }\n\n  function render(p){\n    var t=norm(p);\n    var ang=A0+(A1-A0)*t;\n    p._el.ptr.style.transform=\"rotate(\"+ang+\"deg)\";\n    // label\n    if(p.type===\"step\"){\n      var i=state[p.idx]|0;\n      var lbl=p.steps[i];\n      p._el.val.textContent = (lbl===\"AUTO\"? \"AUTO\" : lbl + (p.unit||\"\"));\n      if(p.badge){\n        if(lbl===\"AUTO\") p.badge.classList.add(\"on\"); else p.badge.classList.remove(\"on\");\n      }\n    }else{\n      p._el.val.textContent = p.fmt(state[p.idx]);\n    }\n  }\n\n  function setVal(p,v,push){\n    if(p.type===\"step\"){\n      var n=p.steps.length-1;\n      v=Math.max(0,Math.min(n,Math.round(v)));\n    }else{\n      v=Math.max(p.min,Math.min(p.max,v));\n    }\n    state[p.idx]=v;\n    render(p);\n    if(push!==false) send(p.idx,v);\n    updateMeter();\n  }\n\n  function wireKnob(p){\n    var el=p._el.knob;\n    var dragging=false, startY=0, startVal=0;\n\n    function down(e){\n      dragging=true; el.classList.add(\"drag\");\n      startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startVal=norm(p);\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move); window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false}); window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dn=(startY-y)/180; // up = increase\n      var nt=Math.max(0,Math.min(1,startVal+dn));\n      if(p.type===\"step\"){\n        setVal(p, nt*(p.steps.length-1));\n      }else{\n        setVal(p, p.min+(p.max-p.min)*nt);\n      }\n      e.preventDefault();\n    }\n    function up(){ dragging=false; el.classList.remove(\"drag\");\n      window.removeEventListener(\"mousemove\",move); window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move); window.removeEventListener(\"touchend\",up);\n    }\n    el.addEventListener(\"mousedown\",down);\n    el.addEventListener(\"touchstart\",down,{passive:false});\n    el.addEventListener(\"dblclick\",function(){ setVal(p, p.def); });\n    el.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      var step=(p.type===\"step\")?1:(e.shiftKey?0.005:0.02);\n      var dir=e.deltaY<0?1:-1;\n      if(p.type===\"step\") setVal(p, state[p.idx]+dir);\n      else setVal(p, state[p.idx]+dir*step*(p.max-p.min));\n    },{passive:false});\n  }\n\n  // ---------- GR meter (centre-zero, swings RIGHT with reduction) ----------\n  var needle=document.getElementById(\"needle\");\n  var grShown=0; // smoothed displayed reduction dB\n  function estimateGR(){\n    // rough visual estimate from threshold + ratio (no audio here): show a\n    // gentle, breathing reduction so the iconic needle moves.\n    var thr=state[0], ratioSel=state[1]|0, mix=state[5];\n    var ratio=[2,4,10][ratioSel];\n    // lower threshold -> more reduction; scale to ~0..10 dB\n    var base=(1-thr)*( (ratio-1)/9 *0.6+0.4 )*8.0*mix;\n    return base;\n  }\n  function updateMeter(){ grTarget=estimateGR(); }\n  var grTarget=0;\n  function tick(){\n    // breathing wobble when AUTO release is engaged\n    var auto=(state[3]|0)===4;\n    var t=performance.now()/1000;\n    var wob=auto? (Math.sin(t*1.7)*0.6+Math.sin(t*0.9)*0.4) : 0;\n    var target=grTarget+ (auto? wob:0);\n    grShown += (target-grShown)*0.08;\n    // map 0..12 dB reduction -> 0..+62deg (right of centre)\n    var dB=Math.max(0,Math.min(12,grShown));\n    var ang = dB/12*62;\n    needle.style.transform=\"rotate(\"+ang+\"deg)\";\n    requestAnimationFrame(tick);\n  }\n\n  // VU scale labels\n  (function(){\n    var g=document.getElementById(\"scale\");\n    var marks=[{db:\"-3\",a:-40},{db:\"-6\",a:-70},{db:\"3\",a:40},{db:\"6\",a:70}];\n    marks.forEach(function(m){\n      var rad=(m.a-90)*Math.PI/180;\n      var x=160+118*Math.cos(rad), y=110+118*Math.sin(rad);\n      var txt=document.createElementNS(\"http://www.w3.org/2000/svg\",\"text\");\n      txt.setAttribute(\"x\",x); txt.setAttribute(\"y\",y); txt.textContent=m.db;\n      g.appendChild(txt);\n    });\n  })();\n\n  // ---------- init ----------\n  function init(){\n    var host=document.getElementById(\"controls\");\n    PARAMS.forEach(function(p){\n      state[p.idx]=p.def;\n      host.appendChild(buildKnob(p));\n    });\n    PARAMS.forEach(function(p){ render(p); send(p.idx,state[p.idx]); });\n    updateMeter();\n    requestAnimationFrame(tick);\n  }\n\n  if(window.vstai && typeof window.vstai.onReady===\"function\"){\n    window.vstai.onReady(init);\n  }else{\n    init();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MASTER GLUE — classic British console-style \"glue\" bus compressor (effect)\n//\n//  The classic British mix-bus glue: a feed-forward, stereo-LINKED VCA\n//  compressor with STEPPED ratios (2:1 / 4:1 / 10:1), STEPPED attack\n//  times, and a program-dependent AUTO-RELEASE that \"breathes\" with the\n//  music. A loud, dense mix is smoothly leveled and gelled into a single\n//  cohesive whole; the stereo image stays put because one detector drives\n//  both channels. Makeup restores level, Mix blends parallel dry, and a\n//  soft output stage keeps the bus bounded. Pure algorithm, no samples.\n//\n//  - Detector: peak-ish smoothed level of the SUM of both channels, so the\n//    image is rock-solid (no L/R drift).\n//  - Gain computer in the dB domain with a soft knee and stepped ratio.\n//  - Attack: 4 stepped positions (0.1 / 0.3 / 1 / 3 / 10 ms feel — mapped\n//    to one-pole coefficients).\n//  - Release: 4 fixed positions (0.1 / 0.3 / 0.6 / 1.2 s) PLUS an AUTO\n//    position (max) where two release time-constants are blended by the\n//    amount of gain reduction — the program-dependent \"breathing\" release.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// detector / envelope state (mono, stereo-linked)\nlet det: f32 = 0.0;      // smoothed detector level (linear)\nlet envDb: f32 = 0.0;    // current gain reduction in dB (>= 0)\nlet rel2: f32 = 0.0;     // slow release reservoir for AUTO breathing\n\nconst P_THRESH: i32 = 0; // 0..1 -> threshold dBFS  (-30..0)\nconst P_RATIO:  i32 = 1; // 0/1/2 -> 2:1 / 4:1 / 10:1   (stepped)\nconst P_ATTACK: i32 = 2; // 0..3 -> stepped attack times (stepped)\nconst P_RELEASE:i32 = 3; // 0..4 -> 0.1/0.3/0.6/1.2s + AUTO (stepped)\nconst P_MAKEUP: i32 = 4; // 0..1 -> 0..+18 dB\nconst P_MIX:    i32 = 5; // 0..1 dry/wet\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  det = 0.0;\n  envDb = 0.0;\n  rel2 = 0.0;\n  params[P_THRESH]  = 0.5;\n  params[P_RATIO]   = 1.0;  // 4:1\n  params[P_ATTACK]  = 1.0;  // medium attack\n  params[P_RELEASE] = 4.0;  // AUTO\n  params[P_MAKEUP]  = 0.3;\n  params[P_MIX]     = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n// one-pole coefficient for a given time constant in seconds\n@inline function tcCoef(seconds: f32, sr: f32): f32 {\n  if (seconds <= 0.0) return 1.0;\n  return f32(1.0 - Mathf.exp(-1.0 / (seconds * sr)));\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- threshold ----\n  const thN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const threshDb: f32 = -30.0 + thN * 30.0;          // -30..0 dBFS\n\n  // ---- ratio (stepped: 2 / 4 / 10) ----\n  const ratioSel: i32 = i32(clampf(params[P_RATIO], 0.0, 2.0) + 0.5);\n  let ratio: f32 = 4.0;\n  if (ratioSel == 0) ratio = 2.0;\n  else if (ratioSel == 2) ratio = 10.0;\n  const slope: f32 = 1.0 - 1.0 / ratio;               // dB out per dB over\n\n  // ---- attack (stepped: 0.1 / 0.3 / 1 / 3 ms feel) ----\n  const atkSel: i32 = i32(clampf(params[P_ATTACK], 0.0, 3.0) + 0.5);\n  let atkMs: f32 = 1.0;\n  if (atkSel == 0) atkMs = 0.1;\n  else if (atkSel == 1) atkMs = 0.3;\n  else if (atkSel == 2) atkMs = 3.0;\n  else atkMs = 10.0;\n  const atkCoef: f32 = tcCoef(atkMs * 0.001, sr);\n\n  // ---- release (stepped: 0.1 / 0.3 / 0.6 / 1.2 s + AUTO) ----\n  const relSel: i32 = i32(clampf(params[P_RELEASE], 0.0, 4.0) + 0.5);\n  const isAuto: bool = (relSel == 4);\n  let relMs: f32 = 600.0;\n  if (relSel == 0) relMs = 100.0;\n  else if (relSel == 1) relMs = 300.0;\n  else if (relSel == 2) relMs = 600.0;\n  else if (relSel == 3) relMs = 1200.0;\n  // AUTO: blend a fast (~150 ms) and slow (~2 s) release by GR depth\n  const relFastCoef: f32 = tcCoef(0.15, sr);\n  const relSlowCoef: f32 = tcCoef(2.0, sr);\n  const relFixedCoef: f32 = tcCoef(relMs * 0.001, sr);\n\n  // detector smoothing (fast, peak-ish)\n  const detCoef: f32 = tcCoef(0.003, sr);\n\n  // ---- makeup & mix ----\n  const makeupDb: f32 = clampf(params[P_MAKEUP], 0.0, 1.0) * 18.0;\n  const makeup: f32 = f32(Mathf.exp(makeupDb * 0.11512925)); // 10^(dB/20)\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  const ln10over20: f32 = 0.11512925; // ln(10)/20\n  const c20overln10: f32 = 8.6858896; // 20/ln(10)\n  const knee: f32 = 6.0; // dB soft knee (half-width handled below)\n\n  let d: f32 = det;\n  let gDb: f32 = envDb;\n  let r2: f32 = rel2;\n\n  for (let f = 0; f < n; f++) {\n    // stereo-linked detector: peak of |L|+|R| average\n    const l: f32 = inBuf[f];\n    const r: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : l;\n    let mono: f32 = (l + r) * 0.5;\n    if (mono < 0.0) mono = -mono;\n\n    // smooth detector toward the input magnitude (attack-fast, gentle decay)\n    if (mono > d) d = d + detCoef * (mono - d);\n    else d = d + detCoef * 0.25 * (mono - d);\n\n    // level in dB\n    const lvlDb: f32 = c20overln10 * f32(Mathf.log(d + 1e-9));\n    const over: f32 = lvlDb - threshDb;\n\n    // soft-knee gain computer -> target reduction (dB, >= 0)\n    let targetGr: f32 = 0.0;\n    if (over <= -knee * 0.5) {\n      targetGr = 0.0;\n    } else if (over >= knee * 0.5) {\n      targetGr = slope * over;\n    } else {\n      const x: f32 = over + knee * 0.5; // 0..knee\n      targetGr = slope * (x * x) / (2.0 * knee);\n    }\n\n    // envelope: fast attack toward more reduction, program release back\n    if (targetGr > gDb) {\n      gDb = gDb + atkCoef * (targetGr - gDb);\n    } else {\n      if (isAuto) {\n        // dual time-constant breathing release:\n        // r2 is a slow reservoir that lags gDb; blend fast/slow by depth.\n        r2 = r2 + relSlowCoef * (gDb - r2);\n        const depth: f32 = clampf(gDb * 0.15, 0.0, 1.0); // deeper GR -> slower\n        const relCoef: f32 = relFastCoef + (relSlowCoef - relFastCoef) * depth;\n        // breathe: release toward a level pulled up by the slow reservoir\n        const floorGr: f32 = targetGr < r2 ? r2 * 0.0 : targetGr;\n        gDb = gDb + relCoef * (floorGr - gDb);\n      } else {\n        gDb = gDb + relFixedCoef * (targetGr - gDb);\n      }\n    }\n    if (gDb < 0.0) gDb = 0.0;\n\n    // linear gain from reduction dB\n    const gain: f32 = f32(Mathf.exp(-gDb * ln10over20)) * makeup;\n\n    const wetL: f32 = l * gain;\n    const wetR: f32 = r * gain;\n\n    // soft output clamp keeps the bus bounded (~±1)\n    const outL: f32 = l * (1.0 - mix) + wetL * mix;\n    const outR: f32 = r * (1.0 - mix) + wetR * mix;\n\n    outBuf[f] = f32(Mathf.tanh(outL * 0.92)) * 1.02;\n    if (channels > 1) outBuf[MAX_FRAMES + f] = f32(Mathf.tanh(outR * 0.92)) * 1.02;\n  }\n\n  det = d;\n  envDb = gDb;\n  rel2 = r2;\n}\n",
  "publishedAt": 1751000132000
}