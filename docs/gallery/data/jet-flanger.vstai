{
  "format": 1,
  "name": "Jet Flanger",
  "isInstrument": false,
  "explanation": "A modulated short-delay flanger: a swept fractional delay (about 0.2 to 10 ms) is read with linear interpolation and summed with the dry signal to form a moving comb filter. A bipolar Regen (feedback) control deepens the resonant notches, with negative settings giving the hollow, metallic through-zero-style jet sweep. Controls: Rate, Depth, Regen, Manual base delay and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Regen",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Manual",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.2
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Jet Flanger</title>\n<style>\n  :root{\n    --accent:#40b8d0;\n    --accent2:#7ad0e8;\n    --steel0:#0a0f14;\n    --steel1:#141d26;\n    --steel2:#1f2b38;\n    --rim:#2c3e4d;\n    --txt:#cfe6ee;\n    --txtdim:#6f8a96;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{width:100%;height:100%;overflow:hidden;background:var(--steel0)}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    color:var(--txt);\n    -webkit-user-select:none;user-select:none;\n    -webkit-font-smoothing:antialiased;\n    display:flex;justify-content:center;align-items:center;\n  }\n  #panel{\n    position:relative;\n    width:660px;height:420px;\n    border-radius:20px;\n    background:\n      radial-gradient(140% 120% at 50% -20%, #1c2a36 0%, #0d141b 55%, #070b0f 100%);\n    box-shadow:\n      inset 0 1px 0 rgba(122,208,232,.10),\n      inset 0 0 60px rgba(0,0,0,.6),\n      0 30px 60px rgba(0,0,0,.55);\n    border:1px solid #1b2832;\n    overflow:hidden;\n  }\n  /* brushed-metal sheen sweeping across the whole panel */\n  #panel::before{\n    content:\"\";position:absolute;inset:0;\n    background:\n      repeating-linear-gradient(96deg, rgba(255,255,255,.018) 0 2px, transparent 2px 5px);\n    pointer-events:none;mix-blend-mode:screen;opacity:.6;\n  }\n  /* whoosh streak layer that sweeps right→off and back */\n  #streaks{position:absolute;inset:0;pointer-events:none;overflow:hidden;border-radius:20px}\n  .streak{\n    position:absolute;height:2px;left:-40%;width:140%;\n    background:linear-gradient(90deg,transparent,var(--accent2),transparent);\n    opacity:0;filter:blur(.4px);\n    transform:translateX(-30%);\n    animation:whoosh var(--dur,2.4s) linear infinite;\n  }\n  @keyframes whoosh{\n    0%{transform:translateX(-60%) scaleX(.7);opacity:0}\n    15%{opacity:.55}\n    60%{opacity:.18}\n    100%{transform:translateX(60%) scaleX(1.3);opacity:0}\n  }\n\n  header{\n    position:absolute;top:20px;left:26px;right:26px;\n    display:flex;align-items:center;justify-content:space-between;z-index:6;\n  }\n  .brand{display:flex;align-items:baseline;gap:10px}\n  .brand h1{\n    font-size:21px;font-weight:800;letter-spacing:.32em;text-transform:uppercase;\n    color:var(--txt);\n    text-shadow:0 0 18px rgba(64,184,208,.35);\n  }\n  .brand h1 b{color:var(--accent2);font-weight:800}\n  .sub{font-size:9px;letter-spacing:.42em;color:var(--txtdim);text-transform:uppercase}\n  .rpm{\n    font-variant-numeric:tabular-nums;font-size:11px;letter-spacing:.18em;\n    color:var(--accent2);border:1px solid var(--rim);border-radius:20px;\n    padding:5px 12px;background:rgba(8,14,19,.6);\n    box-shadow:inset 0 0 12px rgba(64,184,208,.12);\n  }\n\n  /* ───── TURBINE ───── */\n  #turbineWrap{\n    position:absolute;left:34px;top:84px;width:300px;height:300px;\n    z-index:4;cursor:ns-resize;touch-action:none;\n  }\n  #turbine{display:block;width:100%;height:100%;overflow:visible}\n  .spin{transform-origin:160px 160px;animation:spin var(--spin,3s) linear infinite}\n  @keyframes spin{to{transform:rotate(360deg)}}\n  .spinR{transform-origin:160px 160px;animation:spinR calc(var(--spin,3s)*1.7) linear infinite}\n  @keyframes spinR{to{transform:rotate(-360deg)}}\n  .glowring{filter:drop-shadow(0 0 8px rgba(64,184,208,.55))}\n  .knobcap{cursor:ns-resize}\n  #turbineHint{\n    position:absolute;left:0;right:0;bottom:-2px;text-align:center;\n    font-size:9px;letter-spacing:.3em;color:var(--txtdim);text-transform:uppercase;\n    pointer-events:none;\n  }\n\n  /* ───── RACK of vertical fader-throttles ───── */\n  #rack{\n    position:absolute;right:30px;top:96px;\n    display:flex;gap:14px;z-index:5;\n  }\n  .ctrl{\n    width:62px;display:flex;flex-direction:column;align-items:center;gap:7px;\n  }\n  .ctrl .nm{\n    font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--txtdim);\n  }\n  .track{\n    position:relative;width:30px;height:188px;border-radius:16px;\n    background:linear-gradient(180deg,#06090c,#10181f);\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.8),inset 0 0 0 1px var(--rim);\n    cursor:ns-resize;touch-action:none;overflow:hidden;\n  }\n  /* glowing fill from bottom to thumb (or bipolar centre for Regen) */\n  .fill{\n    position:absolute;left:0;right:0;bottom:0;\n    background:linear-gradient(180deg,var(--accent2),var(--accent));\n    box-shadow:0 0 16px rgba(64,184,208,.6);\n    transition:none;\n  }\n  .midline{\n    position:absolute;left:4px;right:4px;top:50%;height:1px;\n    background:repeating-linear-gradient(90deg,var(--txtdim) 0 3px,transparent 3px 6px);\n    opacity:.45;display:none;\n  }\n  .ctrl.bipolar .midline{display:block}\n  .thumb{\n    position:absolute;width:40px;height:18px;border-radius:5px;left:50%;margin-left:-20px;\n    background:linear-gradient(180deg,#3a4b59,#1b2630);\n    box-shadow:\n      0 2px 4px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(122,208,232,.5),\n      inset 0 -2px 4px rgba(0,0,0,.6);\n    pointer-events:none;\n  }\n  .thumb::after{\n    content:\"\";position:absolute;left:7px;right:7px;top:50%;height:2px;margin-top:-1px;\n    background:var(--accent2);border-radius:2px;box-shadow:0 0 6px var(--accent2);\n  }\n  .val{\n    font-variant-numeric:tabular-nums;font-size:11px;letter-spacing:.05em;\n    color:var(--accent2);min-height:13px;\n  }\n\n  footer{\n    position:absolute;left:0;right:0;bottom:11px;text-align:center;\n    font-size:8px;letter-spacing:.5em;color:#3c5563;text-transform:uppercase;z-index:6;\n  }\n</style>\n</head>\n<body>\n<div id=\"panel\">\n  <div id=\"streaks\"></div>\n\n  <header>\n    <div class=\"brand\">\n      <div>\n        <h1>JET<b>·</b>FLANGER</h1>\n        <div class=\"sub\">Through-Zero Turbine Sweep</div>\n      </div>\n    </div>\n    <div class=\"rpm\" id=\"rpm\">— RPM</div>\n  </header>\n\n  <!-- TURBINE = Rate (drag) -->\n  <div id=\"turbineWrap\" data-idx=\"0\" title=\"Drag the turbine to set sweep Rate\">\n    <svg id=\"turbine\" viewBox=\"0 0 320 320\">\n      <defs>\n        <radialGradient id=\"cone\" cx=\"50%\" cy=\"42%\" r=\"62%\">\n          <stop offset=\"0%\" stop-color=\"#24323f\"/>\n          <stop offset=\"55%\" stop-color=\"#121b23\"/>\n          <stop offset=\"100%\" stop-color=\"#070b0f\"/>\n        </radialGradient>\n        <radialGradient id=\"hub\" cx=\"42%\" cy=\"38%\" r=\"65%\">\n          <stop offset=\"0%\" stop-color=\"#9fdcec\"/>\n          <stop offset=\"35%\" stop-color=\"var(--accent)\"/>\n          <stop offset=\"100%\" stop-color=\"#0c3a45\"/>\n        </radialGradient>\n        <linearGradient id=\"blade\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#46606f\"/>\n          <stop offset=\"48%\" stop-color=\"#1d2a34\"/>\n          <stop offset=\"100%\" stop-color=\"#0c141a\"/>\n        </linearGradient>\n        <linearGradient id=\"bladeHi\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0%\" stop-color=\"rgba(122,208,232,.0)\"/>\n          <stop offset=\"100%\" stop-color=\"rgba(122,208,232,.6)\"/>\n        </linearGradient>\n      </defs>\n\n      <!-- outer cowling -->\n      <circle cx=\"160\" cy=\"160\" r=\"150\" fill=\"url(#cone)\" stroke=\"#243440\" stroke-width=\"2\"/>\n      <circle cx=\"160\" cy=\"160\" r=\"150\" fill=\"none\" stroke=\"#0a1015\" stroke-width=\"6\" opacity=\".6\"/>\n      <!-- intake ring ticks -->\n      <g id=\"ticks\" opacity=\".7\"></g>\n\n      <!-- progress arc (Rate amount) -->\n      <circle id=\"rateArc\" class=\"glowring\" cx=\"160\" cy=\"160\" r=\"138\" fill=\"none\"\n              stroke=\"var(--accent)\" stroke-width=\"4\" stroke-linecap=\"round\"\n              stroke-dasharray=\"867\" stroke-dashoffset=\"650\"\n              transform=\"rotate(-90 160 160)\"/>\n\n      <!-- spinning fan -->\n      <g class=\"spin\">\n        <g id=\"blades\"></g>\n      </g>\n      <!-- counter-rotating inner stator for depth -->\n      <g class=\"spinR\" opacity=\".5\">\n        <g id=\"stator\"></g>\n      </g>\n\n      <!-- hub / spinner -->\n      <circle cx=\"160\" cy=\"160\" r=\"34\" fill=\"url(#hub)\" stroke=\"#0a3d49\" stroke-width=\"2\"/>\n      <circle cx=\"160\" cy=\"160\" r=\"34\" fill=\"none\" stroke=\"rgba(255,255,255,.25)\" stroke-width=\"1\"/>\n      <path d=\"M160 132 L150 160 L160 168 L170 160 Z\" fill=\"#06121a\" opacity=\".55\"/>\n      <circle cx=\"153\" cy=\"151\" r=\"6\" fill=\"rgba(255,255,255,.7)\"/>\n    </svg>\n    <div id=\"turbineHint\">Rate · drag ↕ · dbl-click resets</div>\n  </div>\n\n  <!-- RACK: Depth, Regen, Manual, Mix -->\n  <div id=\"rack\"></div>\n\n  <footer>boutique modulation · ducted-fan flanger</footer>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // EXACT params from spec.json\n  var PARAMS = [\n    {name:\"Rate\",   index:0, min:0, max:1, def:0.25},\n    {name:\"Depth\",  index:1, min:0, max:1, def:0.70},\n    {name:\"Regen\",  index:2, min:0, max:1, def:0.65, bipolar:true},\n    {name:\"Manual\", index:3, min:0, max:1, def:0.20},\n    {name:\"Mix\",    index:4, min:0, max:1, def:0.50}\n  ];\n  var vals = PARAMS.map(function(p){return p.def;});\n\n  function clamp(v,a,b){return v<a?a:(v>b?b:v);}\n  function norm(p){return (vals[p.index]-p.min)/(p.max-p.min);} // 0..1\n  function send(p){\n    if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index, vals[p.index]);\n  }\n\n  // ── build turbine geometry (blades + ticks + stator) ──\n  var blades=document.getElementById(\"blades\"),\n      stator=document.getElementById(\"stator\"),\n      ticks=document.getElementById(\"ticks\");\n  var NB=14;\n  for(var i=0;i<NB;i++){\n    var a=i*(360/NB);\n    var g=document.createElementNS(\"http://www.w3.org/2000/svg\",\"g\");\n    g.setAttribute(\"transform\",\"rotate(\"+a+\" 160 160)\");\n    var b=document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n    b.setAttribute(\"d\",\"M160 50 C 178 84, 182 118, 168 130 L160 132 L152 130 C 138 118, 142 84, 160 50 Z\");\n    b.setAttribute(\"fill\",\"url(#blade)\");\n    b.setAttribute(\"stroke\",\"#0a141b\");\n    b.setAttribute(\"stroke-width\",\"1\");\n    var hi=document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n    hi.setAttribute(\"d\",\"M160 52 C 176 86, 180 116, 167 128\");\n    hi.setAttribute(\"fill\",\"none\");\n    hi.setAttribute(\"stroke\",\"url(#bladeHi)\");\n    hi.setAttribute(\"stroke-width\",\"2\");\n    g.appendChild(b);g.appendChild(hi);blades.appendChild(g);\n  }\n  for(var j=0;j<10;j++){\n    var sa=j*36+18;\n    var s=document.createElementNS(\"http://www.w3.org/2000/svg\",\"g\");\n    s.setAttribute(\"transform\",\"rotate(\"+sa+\" 160 160)\");\n    var sb=document.createElementNS(\"http://www.w3.org/2000/svg\",\"rect\");\n    sb.setAttribute(\"x\",\"156\");sb.setAttribute(\"y\",\"96\");\n    sb.setAttribute(\"width\",\"8\");sb.setAttribute(\"height\",\"30\");\n    sb.setAttribute(\"rx\",\"3\");sb.setAttribute(\"fill\",\"#1a2a34\");\n    sb.setAttribute(\"stroke\",\"rgba(122,208,232,.35)\");sb.setAttribute(\"stroke-width\",\"1\");\n    s.appendChild(sb);stator.appendChild(s);\n  }\n  for(var k=0;k<48;k++){\n    var ta=k*(360/48);\n    var t=document.createElementNS(\"http://www.w3.org/2000/svg\",\"line\");\n    t.setAttribute(\"x1\",\"160\");t.setAttribute(\"y1\",\"14\");\n    t.setAttribute(\"x2\",\"160\");t.setAttribute(\"y2\",(k%4===0)?\"24\":\"19\");\n    t.setAttribute(\"transform\",\"rotate(\"+ta+\" 160 160)\");\n    t.setAttribute(\"stroke\",(k%4===0)?\"var(--accent)\":\"#33485a\");\n    t.setAttribute(\"stroke-width\",(k%4===0)?\"1.6\":\"1\");t.setAttribute(\"opacity\",\".55\");\n    ticks.appendChild(t);\n  }\n\n  // ── whoosh streaks ──\n  var sl=document.getElementById(\"streaks\");\n  for(var w=0;w<5;w++){\n    var d=document.createElement(\"div\");d.className=\"streak\";\n    d.style.top=(12+w*19)+\"%\";\n    d.style.animationDelay=(-w*0.42)+\"s\";\n    sl.appendChild(d);\n  }\n  var streakEls=sl.querySelectorAll(\".streak\");\n\n  // ── motion driven by Rate + Depth ──\n  var spinEl=document.querySelector(\".spin\");\n  var spinREl=document.querySelector(\".spinR\");\n  var rpmEl=document.getElementById(\"rpm\");\n  function applyMotion(){\n    var rate=norm(PARAMS[0]);          // 0..1\n    var depth=norm(PARAMS[1]);\n    // spin period: slow (6s) → fast (0.45s)\n    var spin=(6.0 - rate*5.55).toFixed(3)+\"s\";\n    spinEl.style.animationDuration=spin;\n    spinREl.style.animationDuration=(parseFloat(spin)*1.7)+\"s\";\n    var dur=(3.2 - rate*2.6).toFixed(3)+\"s\";\n    streakEls.forEach(function(e){\n      e.style.animationDuration=dur;\n      e.style.opacity=(0.25+depth*0.75);\n    });\n    // rate arc\n    var arc=document.getElementById(\"rateArc\");\n    arc.setAttribute(\"stroke-dashoffset\", (867*(1-rate)).toFixed(1));\n    // faux RPM readout\n    var rpm=Math.round(800+rate*32000);\n    rpmEl.textContent=rpm.toLocaleString()+\" RPM\";\n  }\n\n  // ── TURBINE drag → Rate ──\n  (function(){\n    var wrap=document.getElementById(\"turbineWrap\");\n    var p=PARAMS[0];\n    var dragging=false,startY=0,startV=0;\n    function setN(n){vals[p.index]=clamp(n,0,1)*(p.max-p.min)+p.min;applyMotion();send(p);}\n    wrap.addEventListener(\"pointerdown\",function(e){\n      dragging=true;startY=e.clientY;startV=norm(p);\n      wrap.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    wrap.addEventListener(\"pointermove\",function(e){\n      if(!dragging)return;\n      var dy=(startY-e.clientY)/220;\n      setN(startV+dy);\n    });\n    function end(){dragging=false;}\n    wrap.addEventListener(\"pointerup\",end);\n    wrap.addEventListener(\"pointercancel\",end);\n    wrap.addEventListener(\"dblclick\",function(){vals[p.index]=p.def;applyMotion();send(p);});\n  })();\n\n  // ── RACK faders: Depth, Regen, Manual, Mix ──\n  var rack=document.getElementById(\"rack\");\n  var TRACK_H=188;\n  [PARAMS[1],PARAMS[2],PARAMS[3],PARAMS[4]].forEach(function(p){\n    var c=document.createElement(\"div\");c.className=\"ctrl\"+(p.bipolar?\" bipolar\":\"\");\n    c.innerHTML=\n      '<div class=\"nm\">'+p.name+'</div>'+\n      '<div class=\"track\"><div class=\"fill\"></div><div class=\"midline\"></div><div class=\"thumb\"></div></div>'+\n      '<div class=\"val\"></div>';\n    rack.appendChild(c);\n    var track=c.querySelector(\".track\"),\n        fill=c.querySelector(\".fill\"),\n        thumb=c.querySelector(\".thumb\"),\n        valEl=c.querySelector(\".val\");\n\n    function fmt(){\n      var v=vals[p.index];\n      if(p.name===\"Manual\"){ return (0.2+v*9.8).toFixed(2)+\" ms\"; }\n      if(p.name===\"Regen\"){ var b=(v*2-1); return (b>=0?\"+\":\"\")+Math.round(b*100)+\"%\"; }\n      return Math.round(v*100)+\"%\";\n    }\n    function render(){\n      var n=norm(p); // 0..1\n      var y=(1-n)*TRACK_H;\n      thumb.style.top=y+\"px\";\n      if(p.bipolar){\n        // fill from centre toward thumb\n        var mid=TRACK_H/2;\n        if(y<=mid){ fill.style.top=y+\"px\"; fill.style.bottom=(TRACK_H-mid)+\"px\"; }\n        else { fill.style.top=mid+\"px\"; fill.style.bottom=(TRACK_H-y)+\"px\"; }\n      } else {\n        fill.style.top=\"auto\";fill.style.bottom=\"0\";fill.style.height=(n*TRACK_H)+\"px\";\n      }\n      valEl.textContent=fmt();\n    }\n    function setFromY(clientY){\n      var r=track.getBoundingClientRect();\n      var n=clamp(1-(clientY-r.top)/r.height,0,1);\n      vals[p.index]=n*(p.max-p.min)+p.min;render();send(p);\n    }\n    var dragging=false;\n    track.addEventListener(\"pointerdown\",function(e){\n      dragging=true;track.setPointerCapture(e.pointerId);setFromY(e.clientY);e.preventDefault();\n    });\n    track.addEventListener(\"pointermove\",function(e){if(dragging)setFromY(e.clientY);});\n    function end(){dragging=false;}\n    track.addEventListener(\"pointerup\",end);\n    track.addEventListener(\"pointercancel\",end);\n    track.addEventListener(\"dblclick\",function(){vals[p.index]=p.def;render();send(p);});\n\n    p._render=render;\n  });\n\n  // ── init ──\n  function ready(){\n    applyMotion();\n    PARAMS.forEach(function(p){ if(p._render)p._render(); send(p); });\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  JET FLANGER — modulated short-delay flanger with regeneration\n//  A swept fractional delay (~0.2..10 ms) is read with linear\n//  interpolation and summed with the dry signal to form a moving comb\n//  filter. A bipolar Regen (feedback) control feeds the delayed signal\n//  back into the line; negative values give the hollow through-zero-style\n//  metallic \"jet\" sweep. A triangle LFO modulates the delay around a\n//  Manual base time. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: max 12 ms @ 96k -> 1152 samples; give generous headroom.\nconst DLY_LEN: i32 = 2048;          // power-of-two-ish ring per channel\nconst dline:  StaticArray<f32> = new StaticArray<f32>(DLY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // 0..1\nconst fbState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // last delayed out (for feedback)\n\nconst P_RATE:   i32 = 0;  // 0..1 -> 0.05..8 Hz\nconst P_DEPTH:  i32 = 1;  // 0..1 sweep depth\nconst P_REGEN:  i32 = 2;  // 0..1 -> -0.9..0.9 feedback (bipolar)\nconst P_MANUAL: i32 = 3;  // 0..1 -> base delay 0.2..6 ms\nconst P_MIX:    i32 = 4;  // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0;\n    lfoPhase[c] = c == 1 ? 0.25 : 0.0;   // slight stereo offset\n    fbState[c] = 0.0;\n  }\n  for (let i = 0; i < DLY_LEN * MAX_CHANNELS; i++) dline[i] = 0.0;\n  params[P_RATE] = 0.25; params[P_DEPTH] = 0.7; params[P_REGEN] = 0.65;\n  params[P_MANUAL] = 0.2; params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  const rateN: f32   = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32  = clampf(params[P_DEPTH], 0.0, 1.0);\n  const regenN: f32  = clampf(params[P_REGEN], 0.0, 1.0);\n  const manualN: f32 = clampf(params[P_MANUAL], 0.0, 1.0);\n  const mix: f32     = clampf(params[P_MIX], 0.0, 1.0);\n\n  // LFO rate: gentle exponential map 0.05..8 Hz\n  const rateHz: f32 = f32(0.05 * Mathf.pow(160.0, rateN));\n  const phInc: f32  = rateHz / sampleRate;\n\n  // Delay times in SAMPLES.\n  const minMs: f32  = 0.2;\n  const baseMs: f32 = minMs + manualN * 5.8;            // 0.2..6.0 ms base\n  const sweepMs: f32 = depthN * 4.0;                    // up to +4 ms of sweep\n  const baseSamp: f32  = baseMs  * sampleRate * 0.001;\n  const sweepSamp: f32 = sweepMs * sampleRate * 0.001;\n\n  // Bipolar feedback -0.9..0.9\n  const fb: f32 = clampf(regenN * 1.8 - 0.9, -0.9, 0.9);\n\n  for (let c = 0; c < channels; c++) {\n    const cbase: i32 = c * DLY_LEN;\n    let wp: i32 = writePos[c];\n    let ph: f32 = lfoPhase[c];\n    let fbs: f32 = fbState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // Triangle LFO 0..1 (smoother than sine for symmetric jet sweep edges)\n      const tri: f32 = ph < 0.5 ? (ph * 2.0) : (2.0 - ph * 2.0);\n      // delay in samples for this frame\n      let dSamp: f32 = baseSamp + tri * sweepSamp;\n      const maxD: f32 = f32(DLY_LEN - 2);\n      dSamp = clampf(dSamp, 1.0, maxD);\n\n      // fractional read position behind the write pointer\n      let rp: f32 = f32(wp) - dSamp;\n      while (rp < 0.0) rp += f32(DLY_LEN);\n      const i0: i32 = i32(rp);\n      const frac: f32 = rp - f32(i0);\n      let i1: i32 = i0 + 1;\n      if (i1 >= DLY_LEN) i1 -= DLY_LEN;\n      const s0: f32 = dline[cbase + i0];\n      const s1: f32 = dline[cbase + i1];\n      const delayed: f32 = s0 + (s1 - s0) * frac;\n\n      // write input + feedback of the delayed signal\n      dline[cbase + wp] = x + delayed * fb;\n\n      // flanger sum: 0.7 dry + 0.7 wet keeps the comb peaks below clipping\n      const wet: f32 = x * 0.7 + delayed * 0.7;\n      outBuf[c * MAX_FRAMES + f] = x * (1.0 - mix) + wet * mix;\n\n      fbs = delayed;\n\n      wp++;\n      if (wp >= DLY_LEN) wp = 0;\n      ph += phInc;\n      if (ph >= 1.0) ph -= 1.0;\n    }\n\n    writePos[c] = wp;\n    lfoPhase[c] = ph;\n    fbState[c] = fbs;\n  }\n}\n",
  "publishedAt": 1751000022000
}