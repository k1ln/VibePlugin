{
  "format": 1,
  "name": "State Filter",
  "isInstrument": false,
  "explanation": "A 2-pole multimode state-variable filter built on a two-integrator core that yields low-pass, high-pass, band-pass and notch outputs at once; a Mode selector taps which one is heard. Resonance climbs all the way to self-oscillation while a soft saturator inside the loop keeps it bounded, and a gentle input Drive adds warmth. Controls: Cutoff, Resonance, Mode, Drive and dry/wet Mix.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 3,
      "default": 0
    },
    {
      "name": "Drive",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.2
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>State Filter</title>\n<style>\n  :root {\n    --accent:  #66e0c0;\n    --accent2: #54d1ff;\n    --bg0: #060b10;\n    --bg1: #0b141b;\n    --panel: #0e1a22;\n    --line: rgba(102,224,192,0.16);\n    --ink: #cfe9e6;\n    --ink-dim: #6f8a8a;\n    --glass: rgba(255,255,255,0.04);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    width: 100%;\n    height: 100%;\n    background:\n      radial-gradient(120% 90% at 18% -10%, #11242b 0%, transparent 60%),\n      radial-gradient(140% 120% at 100% 120%, #0a1620 0%, transparent 55%),\n      linear-gradient(160deg, var(--bg1), var(--bg0));\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    overflow: auto;\n  }\n\n  .device {\n    max-width: 720px;\n    margin: 0 auto;\n    padding: 18px 20px 24px;\n    display: flex;\n    flex-direction: column;\n    gap: 16px;\n    min-height: 100%;\n  }\n\n  /* ---------- header ---------- */\n  .head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n  }\n  .brand { display: flex; align-items: center; gap: 13px; }\n  .sigil {\n    width: 42px; height: 42px;\n    position: relative;\n    border-radius: 11px;\n    background:\n      linear-gradient(150deg, rgba(102,224,192,0.22), rgba(84,209,255,0.12)),\n      #0a141a;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.12),\n      inset 0 -8px 16px rgba(0,0,0,0.5),\n      0 6px 18px rgba(0,0,0,0.45);\n    overflow: hidden;\n  }\n  .sigil svg { position: absolute; inset: 0; }\n  .sigil .pulse {\n    stroke-dasharray: 60;\n    stroke-dashoffset: 0;\n    animation: dash 3.2s linear infinite;\n    filter: drop-shadow(0 0 4px var(--accent));\n  }\n  @keyframes dash { to { stroke-dashoffset: -120; } }\n\n  .title h1 {\n    font-size: 16px;\n    font-weight: 650;\n    letter-spacing: 0.5px;\n  }\n  .title .sub {\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 2px;\n  }\n  .mode-readout {\n    text-align: right;\n    font-variant-numeric: tabular-nums;\n  }\n  .mode-readout .big {\n    font-size: 15px;\n    font-weight: 650;\n    letter-spacing: 1px;\n    color: var(--accent);\n    text-shadow: 0 0 12px rgba(102,224,192,0.55);\n  }\n  .mode-readout .small {\n    font-size: 9px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 2px;\n  }\n\n  /* ---------- scope ---------- */\n  .scope-wrap {\n    position: relative;\n    border-radius: 14px;\n    background:\n      radial-gradient(120% 140% at 50% 0%, rgba(84,209,255,0.06), transparent 60%),\n      linear-gradient(180deg, #08151b, #060f14);\n    border: 1px solid var(--line);\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.05),\n      inset 0 0 40px rgba(0,0,0,0.6),\n      0 14px 40px rgba(0,0,0,0.5);\n    overflow: hidden;\n  }\n  .scope-wrap::after {\n    /* scanline / glass sheen */\n    content: \"\";\n    position: absolute; inset: 0;\n    pointer-events: none;\n    background:\n      repeating-linear-gradient(0deg, rgba(255,255,255,0.018) 0 1px, transparent 1px 3px);\n    mix-blend-mode: overlay;\n  }\n  #scope { display: block; width: 100%; height: 188px; }\n\n  .scope-tags {\n    position: absolute;\n    left: 12px; top: 10px;\n    display: flex; gap: 6px;\n    pointer-events: none;\n  }\n  .tag {\n    font-size: 8.5px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    padding: 2px 6px;\n    border: 1px solid rgba(255,255,255,0.06);\n    border-radius: 5px;\n    background: rgba(0,0,0,0.25);\n  }\n  .tag.live { color: var(--accent2); border-color: rgba(84,209,255,0.3); }\n\n  /* ---------- controls ---------- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n  }\n  @media (max-width: 560px) { .rack { grid-template-columns: repeat(2, 1fr); } }\n\n  .cell {\n    background:\n      linear-gradient(180deg, var(--glass), rgba(0,0,0,0.18)),\n      var(--panel);\n    border: 1px solid rgba(255,255,255,0.05);\n    border-radius: 12px;\n    padding: 13px 10px 11px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.06),\n      0 8px 20px rgba(0,0,0,0.35);\n  }\n  .cell .lab {\n    font-size: 9.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .cell .val {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent);\n    letter-spacing: 0.5px;\n  }\n\n  .knob {\n    width: 80px; height: 80px;\n    position: relative;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { width: 100%; height: 100%; display: block; }\n  .knob .cap {\n    fill: url(#capgrad);\n    stroke: rgba(255,255,255,0.08);\n    stroke-width: 1;\n  }\n  .knob:hover .arc { filter: drop-shadow(0 0 6px var(--accent)); }\n  .knob.drag .arc { filter: drop-shadow(0 0 9px var(--accent)); }\n\n  /* mode selector buttons */\n  .mode-cell { grid-column: span 2; }\n  @media (max-width: 560px) { .mode-cell { grid-column: span 2; } }\n  .modes {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 7px;\n    width: 100%;\n  }\n  .mbtn {\n    position: relative;\n    border: 1px solid rgba(255,255,255,0.07);\n    border-radius: 9px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.25));\n    color: var(--ink-dim);\n    padding: 9px 4px 8px;\n    cursor: pointer;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n    transition: color .18s, border-color .18s, box-shadow .18s, transform .08s;\n    user-select: none;\n  }\n  .mbtn:hover { color: var(--ink); transform: translateY(-1px); }\n  .mbtn svg { width: 30px; height: 16px; }\n  .mbtn .mn {\n    font-size: 8.5px;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n  }\n  .mbtn.on {\n    color: var(--accent);\n    border-color: rgba(102,224,192,0.55);\n    box-shadow:\n      0 0 0 1px rgba(102,224,192,0.25),\n      0 0 18px rgba(102,224,192,0.3),\n      inset 0 0 14px rgba(102,224,192,0.12);\n    background: linear-gradient(180deg, rgba(102,224,192,0.16), rgba(0,0,0,0.2));\n  }\n  .mbtn .led {\n    width: 5px; height: 5px; border-radius: 50%;\n    background: #16323a;\n    transition: background .18s, box-shadow .18s;\n  }\n  .mbtn.on .led {\n    background: var(--accent);\n    box-shadow: 0 0 8px var(--accent);\n  }\n\n  .foot {\n    text-align: center;\n    font-size: 8.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: rgba(111,138,138,0.55);\n  }\n</style>\n</head>\n<body>\n<div class=\"device\">\n\n  <div class=\"head\">\n    <div class=\"brand\">\n      <div class=\"sigil\">\n        <svg viewBox=\"0 0 42 42\" fill=\"none\">\n          <path d=\"M2 30 C 10 30, 12 12, 21 12 S 32 30, 40 30\"\n                stroke=\"rgba(84,209,255,0.35)\" stroke-width=\"2\" fill=\"none\"/>\n          <path class=\"pulse\" d=\"M2 30 C 10 30, 12 12, 21 12 S 32 30, 40 30\"\n                stroke=\"var(--accent)\" stroke-width=\"2\" fill=\"none\"/>\n        </svg>\n      </div>\n      <div class=\"title\">\n        <h1>STATE&nbsp;FILTER</h1>\n        <div class=\"sub\">Multimode SVF</div>\n      </div>\n    </div>\n    <div class=\"mode-readout\">\n      <div class=\"big\" id=\"modeName\">LOW-PASS</div>\n      <div class=\"small\" id=\"cutReadout\">— Hz</div>\n    </div>\n  </div>\n\n  <div class=\"scope-wrap\">\n    <div class=\"scope-tags\">\n      <span class=\"tag\">RESPONSE</span>\n      <span class=\"tag live\" id=\"resTag\">Q —</span>\n    </div>\n    <canvas id=\"scope\"></canvas>\n  </div>\n\n  <div class=\"rack\">\n    <div class=\"cell\" data-knob=\"0\">\n      <div class=\"lab\">Cutoff</div>\n      <div class=\"knob\" id=\"k0\"></div>\n      <div class=\"val\" id=\"v0\">—</div>\n    </div>\n    <div class=\"cell\" data-knob=\"1\">\n      <div class=\"lab\">Resonance</div>\n      <div class=\"knob\" id=\"k1\"></div>\n      <div class=\"val\" id=\"v1\">—</div>\n    </div>\n    <div class=\"cell\" data-knob=\"3\">\n      <div class=\"lab\">Drive</div>\n      <div class=\"knob\" id=\"k3\"></div>\n      <div class=\"val\" id=\"v3\">—</div>\n    </div>\n    <div class=\"cell\" data-knob=\"4\">\n      <div class=\"lab\">Mix</div>\n      <div class=\"knob\" id=\"k4\"></div>\n      <div class=\"val\" id=\"v4\">—</div>\n    </div>\n\n    <div class=\"cell mode-cell\" style=\"grid-column: 1 / -1;\">\n      <div class=\"lab\">Mode</div>\n      <div class=\"modes\" id=\"modes\"></div>\n    </div>\n  </div>\n\n  <div class=\"foot\">Cutoff · Resonance · Mode · Drive · Mix</div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // -------- parameter model (indices match spec.json) --------\n  var PARAMS = {\n    0: { name: \"Cutoff\",    min: 0, max: 1, def: 0.5,  fmt: fmtCutoff },\n    1: { name: \"Resonance\", min: 0, max: 1, def: 0.35, fmt: fmtPct },\n    2: { name: \"Mode\",      min: 0, max: 3, def: 0,    step: 1 },\n    3: { name: \"Drive\",     min: 0, max: 1, def: 0.2,  fmt: fmtPct },\n    4: { name: \"Mix\",       min: 0, max: 1, def: 1,    fmt: fmtPct }\n  };\n  var state = {};\n  var MODE_NAMES = [\"LOW-PASS\", \"HIGH-PASS\", \"BAND-PASS\", \"NOTCH\"];\n  var MODE_SHORT = [\"LP\", \"HP\", \"BP\", \"NOTCH\"];\n\n  function fmtPct(v) { return Math.round(v * 100) + \" %\"; }\n  function fmtCutoff(v) {\n    var hz = 30 * Math.exp(v * 6.396929655);\n    if (hz >= 1000) return (hz / 1000).toFixed(2) + \" kHz\";\n    return Math.round(hz) + \" Hz\";\n  }\n  function cutoffHz(v) { return 30 * Math.exp(v * 6.396929655); }\n\n  // -------- host bridge --------\n  function push(idx, value) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(idx, value);\n    }\n  }\n  function setParam(idx, value, fromInit) {\n    var p = PARAMS[idx];\n    value = Math.min(p.max, Math.max(p.min, value));\n    if (p.step) value = Math.round(value);\n    state[idx] = value;\n    push(idx, value);\n    reflect(idx);\n    drawScope();\n  }\n\n  function reflect(idx) {\n    var p = PARAMS[idx];\n    if (idx === 2) {\n      var m = state[2] | 0;\n      document.getElementById(\"modeName\").textContent = MODE_NAMES[m];\n      var btns = document.querySelectorAll(\".mbtn\");\n      for (var i = 0; i < btns.length; i++) btns[i].classList.toggle(\"on\", i === m);\n      return;\n    }\n    var ve = document.getElementById(\"v\" + idx);\n    if (ve && p.fmt) ve.textContent = p.fmt(state[idx]);\n    if (idx === 0) document.getElementById(\"cutReadout\").textContent = fmtCutoff(state[0]);\n    if (idx === 1) document.getElementById(\"resTag\").textContent = \"Q \" + Math.round(state[1] * 100) + \"%\";\n    var kn = document.getElementById(\"k\" + idx);\n    if (kn && kn._render) kn._render((state[idx] - p.min) / (p.max - p.min));\n  }\n\n  // -------- SVG knobs --------\n  function buildKnob(idx) {\n    var host = document.getElementById(\"k\" + idx);\n    var p = PARAMS[idx];\n    var A0 = -135, A1 = 135;\n    var ns = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(ns, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    svg.innerHTML =\n      '<defs>' +\n      '<radialGradient id=\"capgrad\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n        '<stop offset=\"0%\" stop-color=\"#1d3038\"/>' +\n        '<stop offset=\"60%\" stop-color=\"#10212a\"/>' +\n        '<stop offset=\"100%\" stop-color=\"#081117\"/>' +\n      '</radialGradient>' +\n      '</defs>' +\n      '<circle cx=\"50\" cy=\"50\" r=\"40\" fill=\"none\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"6\"/>' +\n      '<path class=\"arc\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"6\" stroke-linecap=\"round\"/>' +\n      '<circle class=\"cap\" cx=\"50\" cy=\"50\" r=\"29\"/>' +\n      '<line class=\"ptr\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"26\" stroke=\"var(--accent2)\" ' +\n        'stroke-width=\"3\" stroke-linecap=\"round\"/>';\n    host.appendChild(svg);\n\n    var arc = svg.querySelector(\".arc\");\n    var ptr = svg.querySelector(\".ptr\");\n    var R = 40;\n\n    function polar(deg) {\n      var r = (deg - 90) * Math.PI / 180;\n      return [50 + R * Math.cos(r), 50 + R * Math.sin(r)];\n    }\n    function arcPath(frac) {\n      var a = A0 + (A1 - A0) * frac;\n      var s = polar(A0), e = polar(a);\n      var large = (a - A0) > 180 ? 1 : 0;\n      if (frac <= 0.0001) return \"\";\n      return \"M\" + s[0].toFixed(2) + \" \" + s[1].toFixed(2) +\n             \" A\" + R + \" \" + R + \" 0 \" + large + \" 1 \" +\n             e[0].toFixed(2) + \" \" + e[1].toFixed(2);\n    }\n    host._render = function (frac) {\n      arc.setAttribute(\"d\", arcPath(frac));\n      var a = (A0 + (A1 - A0) * frac) * Math.PI / 180;\n      ptr.setAttribute(\"x2\", (50 + 24 * Math.sin(a)).toFixed(2));\n      ptr.setAttribute(\"y2\", (50 - 24 * Math.cos(a)).toFixed(2));\n    };\n\n    // drag interaction (vertical) + wheel + dblclick reset\n    var dragging = false, startY = 0, startV = 0;\n    function onDown(e) {\n      dragging = true; host.classList.add(\"drag\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = state[idx];\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dv = (startY - y) / 180 * (p.max - p.min);\n      setParam(idx, startV + dv);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; host.classList.remove(\"drag\"); }\n\n    host.addEventListener(\"mousedown\", onDown);\n    host.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"mouseup\", onUp);\n    window.addEventListener(\"touchend\", onUp);\n    host.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var step = (p.max - p.min) * 0.04 * (e.deltaY < 0 ? 1 : -1);\n      setParam(idx, state[idx] + step);\n    }, { passive: false });\n    host.addEventListener(\"dblclick\", function () { setParam(idx, p.def); });\n  }\n\n  // -------- mode buttons --------\n  function modeIcon(m) {\n    // tiny response glyph per mode\n    var paths = [\n      \"M2 4 H14 C18 4 18 14 22 14 H30\",          // LP\n      \"M2 14 C6 14 12 14 16 4 H30\",              // HP (rising)\n      \"M2 14 C8 14 9 4 15 4 S22 14 28 14\",       // BP bump\n      \"M2 4 H11 C13 4 14 13 16 13 S19 4 21 4 H30\"// notch dip\n    ];\n    return '<svg viewBox=\"0 0 32 18\" fill=\"none\">' +\n      '<path d=\"' + paths[m] + '\" stroke=\"currentColor\" stroke-width=\"2\" ' +\n      'stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>';\n  }\n  function buildModes() {\n    var wrap = document.getElementById(\"modes\");\n    for (var m = 0; m < 4; m++) {\n      (function (mm) {\n        var b = document.createElement(\"div\");\n        b.className = \"mbtn\";\n        b.innerHTML = '<span class=\"led\"></span>' + modeIcon(mm) +\n                      '<span class=\"mn\">' + MODE_SHORT[mm] + '</span>';\n        b.addEventListener(\"click\", function () { setParam(2, mm); });\n        wrap.appendChild(b);\n      })(m);\n    }\n  }\n\n  // -------- response scope --------\n  var cv = document.getElementById(\"scope\");\n  var ctx = cv.getContext(\"2d\");\n  var W = 0, H = 0, dpr = 1;\n  var glow = 0, glowTarget = 0; // animated sweep marker glow\n\n  function resize() {\n    dpr = window.devicePixelRatio || 1;\n    W = cv.clientWidth; H = cv.clientHeight;\n    cv.width = W * dpr; cv.height = H * dpr;\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n    drawScope();\n  }\n\n  // analytic 2-pole SVF magnitude (normalised), x in 0..1 across log freq\n  function response(xNorm, mode, fcN, q) {\n    var fc = cutoffHz(fcN);\n    var fMin = 20, fMax = 20000;\n    var f = fMin * Math.pow(fMax / fMin, xNorm);\n    var w = f / fc;\n    var damp = (1 - q * 0.97) + 0.03; // ~ 1/Q\n    var denom = Math.sqrt(Math.pow(1 - w * w, 2) + Math.pow(damp * w, 2));\n    var lp = 1 / denom;\n    var hp = (w * w) / denom;\n    var bp = (damp * w) / denom;\n    var notch = Math.abs(1 - w * w) / denom;\n    var v;\n    if (mode === 0) v = lp;\n    else if (mode === 1) v = hp;\n    else if (mode === 2) v = bp;\n    else v = notch;\n    return v;\n  }\n\n  function drawScope() {\n    if (!W) return;\n    ctx.clearRect(0, 0, W, H);\n\n    // graticule\n    ctx.lineWidth = 1;\n    ctx.strokeStyle = \"rgba(102,224,192,0.10)\";\n    ctx.beginPath();\n    for (var gx = 0; gx <= 10; gx++) {\n      var x = gx / 10 * W;\n      ctx.moveTo(x, 0); ctx.lineTo(x, H);\n    }\n    for (var gy = 0; gy <= 4; gy++) {\n      var y = gy / 4 * H;\n      ctx.moveTo(0, y); ctx.lineTo(W, y);\n    }\n    ctx.stroke();\n\n    var mode = state[2] | 0;\n    var fcN = state[0], q = state[1];\n\n    // cutoff marker (log position of fc on 20..20k axis)\n    var fc = cutoffHz(fcN);\n    var mx = Math.log(fc / 20) / Math.log(20000 / 20) * W;\n    ctx.fillStyle = \"rgba(84,209,255,\" + (0.10 + glow * 0.18) + \")\";\n    ctx.fillRect(mx - 1, 0, 2, H);\n\n    // build curve\n    var pts = [];\n    var maxV = 0.0001;\n    for (var i = 0; i <= 220; i++) {\n      var xn = i / 220;\n      var v = response(xn, mode, fcN, q);\n      pts.push(v);\n      if (v > maxV) maxV = v;\n    }\n    var norm = 1 / Math.max(1, maxV * 0.7);\n\n    function plot(scale, alpha, width) {\n      ctx.beginPath();\n      for (var i = 0; i <= 220; i++) {\n        var xn = i / 220;\n        var x = xn * W;\n        var v = Math.min(1.25, pts[i] * norm * scale);\n        var y = H - 8 - v * (H - 18);\n        if (i === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n      }\n      ctx.globalAlpha = alpha;\n      ctx.lineWidth = width;\n      ctx.stroke();\n      ctx.globalAlpha = 1;\n    }\n\n    // outer glow pass then crisp line\n    var grad = ctx.createLinearGradient(0, 0, W, 0);\n    grad.addColorStop(0, \"#54d1ff\");\n    grad.addColorStop(1, \"#66e0c0\");\n    ctx.strokeStyle = grad;\n    ctx.shadowColor = \"rgba(102,224,192,0.55)\";\n    ctx.shadowBlur = 10 + glow * 8;\n    plot(1, 0.9, 2.4);\n    ctx.shadowBlur = 0;\n\n    // faint fill under curve\n    ctx.beginPath();\n    for (var i2 = 0; i2 <= 220; i2++) {\n      var xn2 = i2 / 220;\n      var x2 = xn2 * W;\n      var v2 = Math.min(1.25, pts[i2] * norm);\n      var y2 = H - 8 - v2 * (H - 18);\n      if (i2 === 0) ctx.moveTo(x2, y2); else ctx.lineTo(x2, y2);\n    }\n    ctx.lineTo(W, H); ctx.lineTo(0, H); ctx.closePath();\n    var fg = ctx.createLinearGradient(0, 0, 0, H);\n    fg.addColorStop(0, \"rgba(102,224,192,0.16)\");\n    fg.addColorStop(1, \"rgba(102,224,192,0)\");\n    ctx.fillStyle = fg;\n    ctx.fill();\n  }\n\n  // gentle living animation: the cutoff marker breathes\n  var t0 = performance.now();\n  function tick(now) {\n    if (!document.hidden) {\n      var dt = (now - t0) / 1000; t0 = now;\n      glowTarget = 0.5 + 0.5 * Math.sin(now / 700);\n      glow += (glowTarget - glow) * Math.min(1, dt * 6);\n      drawScope();\n    } else { t0 = now; }\n    requestAnimationFrame(tick);\n  }\n\n  // -------- init --------\n  function start() {\n    [0, 1, 3, 4].forEach(buildKnob);\n    buildModes();\n    for (var idx in PARAMS) {\n      var p = PARAMS[idx];\n      var init = (window.vstai && window.vstai.getParam)\n        ? window.vstai.getParam(+idx) : p.def;\n      if (init === undefined || init === null || isNaN(init)) init = p.def;\n      setParam(+idx, init, true);\n    }\n    resize();\n    requestAnimationFrame(tick);\n  }\n\n  window.addEventListener(\"resize\", resize);\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(start);\n  else start();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STATE FILTER — a 2-pole multimode state-variable filter\n//  A classic two-integrator state-variable topology produces low-pass,\n//  high-pass, band-pass and notch outputs simultaneously from a single\n//  recursion; a Mode selector taps which one is heard. Resonance can be\n//  pushed all the way to self-oscillation while a soft saturator inside\n//  the resonance path keeps the peak bounded. A gentle input Drive adds\n//  harmonic warmth before the filter. Pure algorithm, no samples.\n//\n//  The integrator coefficient f = 2*sin(pi*fc/fs) is the textbook form;\n//  it is only stable up to fc ≈ fs/6, so the whole filter runs at 2x\n//  oversampling (with a tiny half-band smoother) to keep high cutoffs\n//  clean and the response well-behaved across the full sweep.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel SVF integrator state (the two \"state variables\")\nconst svLow:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low-pass integrator\nconst svBand: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // band-pass integrator\n// per-channel upsample hold + post-decimation smoother\nconst upZ:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // last input (linear up)\nconst downZ:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // half-band smoother\n\nconst P_CUTOFF: i32 = 0; // 0..1 -> ~30 Hz .. ~18 kHz (exp)\nconst P_RES:    i32 = 1; // 0..1 -> resonance, climbs to self-oscillation\nconst P_MODE:   i32 = 2; // 0..3 step 1 -> 0 LP, 1 HP, 2 BP, 3 Notch\nconst P_DRIVE:  i32 = 3; // 0..1 -> pre-filter drive / warmth\nconst P_MIX:    i32 = 4; // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    svLow[c] = 0.0; svBand[c] = 0.0; upZ[c] = 0.0; downZ[c] = 0.0;\n  }\n  params[P_CUTOFF] = 0.5;\n  params[P_RES]    = 0.35;\n  params[P_MODE]   = 0.0;\n  params[P_DRIVE]  = 0.2;\n  params[P_MIX]    = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// smooth bounded saturator: tanh-like, keeps the resonance loop stable\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resN:    f32 = clampf(params[P_RES], 0.0, 1.0);\n  const mode:    i32 = i32(clampf(params[P_MODE], 0.0, 3.0) + 0.5);\n  const driveN:  f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const mix:     f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // running at 2x oversampling, so design against twice the rate\n  const fsOver: f32 = sampleRate * 2.0;\n\n  // exponential cutoff map ~30 Hz .. ~18 kHz\n  let fcHz: f32 = f32(30.0 * Mathf.exp(cutoffN * 6.396929655)); // 30 * (600)^cutoff\n  const fcMax: f32 = fsOver * 0.18; // stay within stable region of this SVF form\n  if (fcHz > fcMax) fcHz = fcMax;\n  if (fcHz < 10.0) fcHz = 10.0;\n\n  // SVF tuning coefficient f = 2*sin(pi*fc/fs)\n  const fCoef: f32 = f32(2.0 * Mathf.sin(3.14159265358979 * fcHz / fsOver));\n\n  // damping q = 1/Q. At resN=1 -> near 0 -> self-oscillation, but floored so\n  // the loop never goes fully undamped (kept stable & bounded by the saturator).\n  const q: f32 = f32(1.0 - resN * 0.97) + 0.02; // 1.0 .. ~0.05\n\n  // input drive: 1x .. ~6x, with output compensation so it stays musical\n  const drive: f32 = 1.0 + driveN * 5.0;\n  const comp: f32 = f32(1.0 / (1.0 + driveN * 1.5));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let low: f32 = svLow[c];\n    let band: f32 = svBand[c];\n    let prevIn: f32 = upZ[c];\n    let dz: f32 = downZ[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n      const driven: f32 = satf(x * drive) * comp;\n\n      // 2x oversampled SVF: two sub-steps, input linearly interpolated\n      let outOver: f32 = 0.0;\n      for (let k: i32 = 0; k < 2; k++) {\n        // linear upsample between previous and current driven sample\n        const frac: f32 = k == 0 ? 0.5 : 1.0;\n        const xin: f32 = prevIn + (driven - prevIn) * frac;\n\n        // Chamberlin two-integrator core\n        const high: f32 = xin - low - q * band;\n        band = band + fCoef * high;\n        band = satf(band); // bound the resonance state -> stable self-osc\n        low = low + fCoef * band;\n\n        let tap: f32 = low;\n        if (mode == 1) tap = high;            // high-pass\n        else if (mode == 2) tap = band;       // band-pass\n        else if (mode == 3) tap = xin - band * q; // notch = in - bp*damp ≈ low+high\n\n        outOver = tap;\n      }\n      prevIn = driven;\n\n      // half-band-ish decimation smoother (simple 1-pole on the 2x stream)\n      dz = dz + 0.5 * (outOver - dz);\n      const wet: f32 = dz;\n\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    svLow[c] = low;\n    svBand[c] = band;\n    upZ[c] = prevIn;\n    downZ[c] = dz;\n  }\n}\n",
  "publishedAt": 1751000048000
}