  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Onyx Eight</title>\n<style>\n  :root{ --acc:#9a6cff; --acc2:#ffb24a; --bg0:#08060f; --bg1:#120e22; --ink:#efeaf8; --dim:#8276a0; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#211a3c 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#1a1430,#08060f); border:1px solid rgba(154,108,255,.24); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(235,225,255,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#100b1f,#07050d); border:1px solid rgba(154,108,255,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(220,212,240,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(154,108,255,.6)); }\n  .pcap{ fill:#0e0a1c; stroke:rgba(154,108,255,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(154,108,255,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(154,108,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">ONYX&nbsp;EIGHT</span><span class=\"sub\">four-pole pwm poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">PWM&nbsp;/&nbsp;4-POLE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.55},{name:\"Reso\",idx:1,def:0.35},{name:\"Env\",idx:2,def:0.5},{name:\"PWM\",idx:3,def:0.4},{name:\"Spread\",idx:4,def:0.3},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#9a6cff\"/><stop offset=\"1\" stop-color=\"#ffb24a\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], reso=vals[1], pwm=vals[3], spread=vals[4]; var mid=H*0.54;\n    var duty=0.5+pwm*0.42*Math.sin(ts/620);   // breathing pulse width\n    // pulse train (amber) with morphing duty\n    ctx.beginPath(); var cyc=5.2;\n    for(var x=0;x<=W;x+=2){ var t=((x/W)*cyc+ts/1400)%1; var pv=(t<duty?1:-1)*(0.42+cut*0.45); ctx.lineTo(x, mid - pv*(H*0.30)); }\n    ctx.strokeStyle=\"rgba(255,178,74,0.9)\"; ctx.lineWidth=2; ctx.shadowColor=\"#ffb24a\"; ctx.shadowBlur=7; ctx.stroke(); ctx.shadowBlur=0;\n    // detuned saw underlay (purple)\n    ctx.beginPath();\n    for(var x2=0;x2<=W;x2+=2){ var t2=((x2/W)*cyc*(1+spread*0.02)+ts/1400)%1; var sv=(2*t2-1)*(0.3+cut*0.3); ctx.lineTo(x2, mid - sv*(H*0.20)); }\n    ctx.strokeStyle=\"rgba(154,108,255,0.55)\"; ctx.lineWidth=1.4; ctx.stroke();\n    // 4-pole resonance lens: a bright peak whose x = cutoff, height = reso\n    var px=20+cut*(W-40), ph=10+reso*(H*0.34);\n    var grd=ctx.createRadialGradient(px,mid,0,px,mid,40+ph); grd.addColorStop(0,\"rgba(154,108,255,\"+(0.18+reso*0.4)+\")\"); grd.addColorStop(1,\"rgba(154,108,255,0)\");\n    ctx.fillStyle=grd; ctx.beginPath(); ctx.arc(px,mid,40+ph,0,Math.PI*2); ctx.fill();\n    ctx.strokeStyle=\"rgba(255,178,74,\"+(0.3+reso*0.5)+\")\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(px,8); ctx.lineTo(px,H-8); ctx.stroke();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  ONYX EIGHT — a bright, punchy analog poly (Oberheim OB-8 lineage).\n//  Sister to the warm 2-pole Voice Eight, but with a steeper, brighter\n//  voice: each of 8 voices runs a sawtooth + a pulse whose width is swept\n//  by a per-patch PWM LFO, through a cascaded FOUR-POLE resonant low-pass\n//  with its own envelope. A unison Spread detunes the two oscillators for\n//  the classic brassy OB pad. 8-voice poly.\n//  Controls: Cutoff, Resonance, Env Amount, PWM, Spread, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vA: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vB: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\n// two cascaded SVF stages per voice (4-pole)\nconst vLp1: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp1: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp2: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp2: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vDrift: StaticArray<f32> = new StaticArray<f32>(NVOX);   // slow analog pitch drift\nconst vGL: StaticArray<f32> = new StaticArray<f32>(NVOX);      // per-voice pan gain L\nconst vGR: StaticArray<f32> = new StaticArray<f32>(NVOX);      // per-voice pan gain R\nconst PANTAB: StaticArray<f32> = new StaticArray<f32>(NVOX);   // interleaved stereo spread\nlet vNext: i32 = 0;\nlet lfo: f32 = 0.0;\nlet sampleRate: f32 = 48000.0;\nlet rngState: i32 = 0x1d3b9f;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_PWM: i32 = 3; const P_SPREAD: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0; lfo = 0.0; rngState = 0x1d3b9f;\n  PANTAB[0] = 0.0; PANTAB[1] = -0.78; PANTAB[2] = 0.78; PANTAB[3] = -0.4; PANTAB[4] = 0.4; PANTAB[5] = -1.0; PANTAB[6] = 1.0; PANTAB[7] = 0.16;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vA[i] = 0.0; vB[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp1[i] = 0.0; vBp1[i] = 0.0; vLp2[i] = 0.0; vBp2[i] = 0.0; vNote[i] = -1; vDrift[i] = 0.0; vGL[i] = 0.707; vGR[i] = 0.707; }\n  params[P_CUTOFF] = 0.55; params[P_RESO] = 0.35; params[P_ENV] = 0.5; params[P_PWM] = 0.4; params[P_SPREAD] = 0.3; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vA[slot] = 0.0; vB[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp1[slot] = 0.0; vBp1[slot] = 0.0; vLp2[slot] = 0.0; vBp2[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const pwmN: f32 = clampf(params[P_PWM], 0.0, 1.0);\n  const spreadN: f32 = clampf(params[P_SPREAD], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.006 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.4 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.55 * sampleRate)));\n  const baseCut: f32 = 60.0 * f32(Mathf.exp(cutoffN * 5.3));\n  const envSpan: f32 = envN * 8500.0;\n  const k: f32 = 1.6 - 1.5 * resoN;             // per-stage damping (cascaded → strong reso)\n  const det: f32 = 1.0 + spreadN * 0.045;\n  const lfoInc: f32 = 4.2 / sampleRate * 6.2831853;\n  const pwmDepth: f32 = pwmN * 0.42;\n  const out: f32 = level * 0.42;\n  const width: f32 = spreadN * 0.92;\n  for (let s = 0; s < NVOX; s++) {\n    const pan: f32 = PANTAB[s] * width;\n    vGL[s] = f32(Mathf.sqrt(0.5 * (1.0 - pan)));\n    vGR[s] = f32(Mathf.sqrt(0.5 * (1.0 + pan)));\n  }\n  const driftLeak: f32 = 0.9998; const driftStep: f32 = 0.00006;\n\n  for (let i = 0; i < n; i++) {\n    lfo += lfoInc; if (lfo > 6.2831853) lfo -= 6.2831853;\n    const pw: f32 = 0.5 + pwmDepth * f32(Mathf.sin(lfo));\n    let mixL: f32 = 0.0; let mixR: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      vDrift[s] = vDrift[s] * driftLeak + rnd() * driftStep;\n      const fr: f32 = vFreq[s] * (1.0 + vDrift[s]);\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let a: f32 = vA[s] + fr / sampleRate; if (a >= 1.0) a -= 1.0; vA[s] = a;\n      let b: f32 = vB[s] + (fr * det) / sampleRate; if (b >= 1.0) b -= 1.0; vB[s] = b;\n      const saw: f32 = a * 2.0 - 1.0;\n      const pulse: f32 = b < pw ? 1.0 : -1.0;\n      let osc: f32 = (saw * 0.55 + pulse * 0.45) * 0.5;\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      // stage 1\n      const hp1: f32 = (osc - (g + k) * vBp1[s] - vLp1[s]) * a1;\n      const bp1: f32 = g * hp1 + vBp1[s]; const lp1: f32 = g * bp1 + vLp1[s];\n      vBp1[s] = bp1; vLp1[s] = lp1;\n      // stage 2 (cascade → 4-pole)\n      const hp2: f32 = (lp1 - (g + k) * vBp2[s] - vLp2[s]) * a1;\n      const bp2: f32 = g * hp2 + vBp2[s]; const lp2: f32 = g * bp2 + vLp2[s];\n      vBp2[s] = bp2; vLp2[s] = lp2;\n      const val: f32 = lp2 * vAmp[s] * vVel[s];\n      mixL += val * vGL[s]; mixR += val * vGR[s];\n    }\n    let oL: f32 = mixL * out; let oR: f32 = mixR * out;\n    if (oL > 1.4) oL = 1.4; else if (oL < -1.4) oL = -1.4;\n    if (oR > 1.4) oR = 1.4; else if (oR < -1.4) oR = -1.4;\n    outBuf[i] = oL; outBuf[MAX_FRAMES + i] = oR;\n  }\n}\n",
  "publishedAt": 1751301200000
}