  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Grit Wave</title>\n<style>\n  :root{ --acc:#ff6a4a; --acc2:#4ad0c0; --bg0:#0f0806; --bg1:#1e0f0b; --ink:#f7e9e4; --dim:#9a7a70; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#2c1810 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#26130d,#0f0806); border:1px solid rgba(255,106,74,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(247,233,228,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 1.8s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:118px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#180c08,#0e0705); border:1px solid rgba(255,106,74,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(238,220,214,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,106,74,.6)); }\n  .pcap{ fill:#160b07; stroke:rgba(255,106,74,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,106,74,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,106,74,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">GRIT&nbsp;WAVE</span><span class=\"sub\">wavetable poly</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">WAVETABLE&nbsp;SCAN</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.6},{name:\"Reso\",idx:1,def:0.3},{name:\"Position\",idx:2,def:0.3},{name:\"Scan\",idx:3,def:0.4},{name:\"Drive\",idx:4,def:0.35},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ff6a4a\"/><stop offset=\"1\" stop-color=\"#4ad0c0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  // precompute 8 wavetable frames (approx of the DSP frames)\n  var NF=8, FL=128, FR=[];\n  for(var f=0;f<NF;f++){ var ff=f/(NF-1); var nh=1+Math.floor(ff*20); var fc=2+ff*10; var arr=new Float32Array(FL); var pk=1e-4;\n    for(var i=0;i<FL;i++){ var ph=i/FL; var v=0; for(var h=1;h<=nh;h++){ var amp=1/h + 0.5*Math.exp(-((h-fc)*(h-fc))/6); v+=amp*Math.sin(2*Math.PI*h*ph); } arr[i]=v; if(Math.abs(v)>pk)pk=Math.abs(v); }\n    for(var i2=0;i2<FL;i2++) arr[i2]*=0.9/pk; FR.push(arr); }\n  function sampleFrame(fp,ph){ if(fp<0)fp=0; if(fp>NF-1)fp=NF-1; var f0=Math.floor(fp), f1=Math.min(NF-1,f0+1), fr=fp-f0;\n    var x=ph*FL, i0=Math.floor(x)%FL, i1=(i0+1)%FL, xf=x-Math.floor(x);\n    var a=FR[f0][i0]+(FR[f0][i1]-FR[f0][i0])*xf, b=FR[f1][i0]+(FR[f1][i1]-FR[f1][i0])*xf; return a+(b-a)*fr; }\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var pos=vals[2], scan=vals[3], drive=vals[4];\n    var lfo=0.5+0.5*Math.sin(ts/1000*(0.3+scan*4));\n    var framePos=pos*(NF-1)+scan*3.5*lfo; if(framePos>NF-1)framePos=NF-1;\n    var mid=H*0.42, amp=H*0.30;\n    // main morphing waveform (2 cycles), drive thickens/grits\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=1.5){ var t=x/W; var ph=(t*2)%1; var v=sampleFrame(framePos,ph); v=Math.tanh(v*(1+drive*5))/(1+drive*1.2);\n      ctx.lineTo(x, mid - v*amp); }\n    var grd=ctx.createLinearGradient(0,0,W,0); grd.addColorStop(0,\"#ff6a4a\"); grd.addColorStop(1,\"#4ad0c0\");\n    ctx.strokeStyle=grd; ctx.lineWidth=2; ctx.shadowColor=\"#ff6a4a\"; ctx.shadowBlur=7+drive*6; ctx.stroke(); ctx.shadowBlur=0;\n    // filmstrip of 8 frames at bottom\n    var stripY=H-22, tw=(W-24)/NF;\n    for(var f=0;f<NF;f++){ var x0=12+f*tw; var active=(Math.abs(f-framePos)<0.6);\n      ctx.strokeStyle=active?\"#4ad0c0\":\"rgba(255,106,74,0.3)\"; ctx.lineWidth=active?1.4:1; ctx.beginPath();\n      for(var xx=0;xx<tw-3;xx+=2){ var ph2=(xx/(tw-3)); var vv=FR[f][Math.floor(ph2*FL)%FL]; ctx.lineTo(x0+xx, stripY - vv*7); }\n      ctx.stroke(); }\n    // scan playhead over filmstrip\n    var hx=12+(framePos/(NF-1))*(W-24); ctx.strokeStyle=\"rgba(74,208,192,0.7)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(hx,stripY-12); ctx.lineTo(hx,stripY+12); ctx.stroke();\n    ctx.fillStyle=\"#4ad0c0\"; ctx.beginPath(); ctx.arc(hx,stripY-12,2.5,0,Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  GRIT WAVE — a gritty digital wavetable poly (Waldorf Microwave\n//  lineage). Sister to the smooth Wave Storm, but harsher and more\n//  aliased: an 8-frame wavetable (built at init, from near-sine up to\n//  bright formant-heavy frames) is scanned by Position, the signature\n//  SCAN sweeps that position with an LFO so the timbre morphs on a held\n//  note, and DRIVE adds saturation + digital grain for the characterful\n//  edge. 8-voice poly through a resonant two-pole low-pass.\n//  Controls: Cutoff, Resonance, Position, Scan, Drive, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\nconst NFRAMES: i32 = 8;\nconst FLEN: i32 = 256;\nconst TAU: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\nconst vDrift: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGL: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGR: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst WT: StaticArray<f32> = new StaticArray<f32>(NFRAMES * FLEN);\n\nconst vPh: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet lfo: f32 = 0.0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_POS: i32 = 2; const P_SCAN: i32 = 3; const P_DRIVE: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\nlet rngState: i32 = 0x2b9f17;\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nfunction buildWavetable(): void {\n  for (let f = 0; f < NFRAMES; f++) {\n    const ff: f32 = f32(f) / f32(NFRAMES - 1);        // 0..1 frame morph\n    const nharm: i32 = 1 + i32(ff * 40.0);            // more harmonics as frame rises\n    const fc: f32 = 2.0 + ff * 10.0;                  // moving formant centre (harmonic index)\n    let peak: f32 = 0.0001;\n    for (let i = 0; i < FLEN; i++) {\n      const ph: f32 = f32(i) / f32(FLEN);\n      let v: f32 = 0.0;\n      for (let h = 1; h <= nharm; h++) {\n        let amp: f32 = 1.0 / f32(h);\n        // formant emphasis for the digital/gritty character\n        const d: f32 = f32(h) - fc;\n        amp += 0.5 * f32(Mathf.exp(-(d * d) / 6.0));\n        v += amp * f32(Mathf.sin(TAU * f32(h) * ph));\n      }\n      WT[f * FLEN + i] = v;\n      const av: f32 = v < 0.0 ? -v : v; if (av > peak) peak = av;\n    }\n    const norm: f32 = 0.9 / peak;\n    for (let i = 0; i < FLEN; i++) { WT[f * FLEN + i] = WT[f * FLEN + i] * norm; }\n  }\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0; lfo = 0.0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vPh[i] = 0.0; vAmp[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.6; params[P_RESO] = 0.3; params[P_POS] = 0.3; params[P_SCAN] = 0.4; params[P_DRIVE] = 0.35; params[P_LEVEL] = 0.8;\n  buildWavetable();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPh[slot] = 0.0; vAmp[slot] = 0.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\n@inline function readWT(framePos: f32, ph: f32): f32 {\n  let fp: f32 = framePos; if (fp < 0.0) fp = 0.0; if (fp > f32(NFRAMES - 1)) fp = f32(NFRAMES - 1);\n  const f0: i32 = i32(fp); let f1: i32 = f0 + 1; if (f1 > NFRAMES - 1) f1 = NFRAMES - 1;\n  const fr: f32 = fp - f32(f0);\n  const x: f32 = ph * f32(FLEN);\n  let i0: i32 = i32(x); const xf: f32 = x - f32(i0); if (i0 >= FLEN) i0 = FLEN - 1;\n  let i1: i32 = i0 + 1; if (i1 >= FLEN) i1 = 0;\n  const a0: f32 = WT[f0 * FLEN + i0] + (WT[f0 * FLEN + i1] - WT[f0 * FLEN + i0]) * xf;\n  const a1: f32 = WT[f1 * FLEN + i0] + (WT[f1 * FLEN + i1] - WT[f1 * FLEN + i0]) * xf;\n  return a0 + (a1 - a0) * fr;\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const posN: f32 = clampf(params[P_POS], 0.0, 1.0);\n  const scanN: f32 = clampf(params[P_SCAN], 0.0, 1.0);\n  const driveN: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.008 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.45 * sampleRate)));\n  const baseCut: f32 = 60.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const k: f32 = 2.0 - 1.9 * resoN;\n  const lfoInc: f32 = (0.3 + scanN * 4.0) / sampleRate * TAU;\n  const scanDepth: f32 = scanN * 3.5;\n  const basePos: f32 = posN * f32(NFRAMES - 1);\n  const drive: f32 = 1.0 + driveN * 5.0;\n  const driveComp: f32 = 1.0 / (1.0 + driveN * 1.6);\n  const out: f32 = level * 0.42;\n\n  let fc: f32 = baseCut;\n  if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n  const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n  const a1c: f32 = 1.0 / (1.0 + g * (g + k));\n\n    const _width: f32 = 0.55;\n  for (let _s = 0; _s < NVOX; _s++) { const _pr: i32 = (_s + 1) / 2; const _mg: f32 = _s == 0 ? 0.0 : (1.0 - f32(_pr - 1) / f32(NVOX)); const _pan: f32 = ((_s % 2 == 1) ? -_mg : _mg) * _width; vGL[_s] = f32(Mathf.sqrt(0.5 * (1.0 - _pan))); vGR[_s] = f32(Mathf.sqrt(0.5 * (1.0 + _pan))); }\n  const _dLeak: f32 = 0.9998; const _dStep: f32 = 0.00006;\n\n  for (let i = 0; i < n; i++) {\n    lfo += lfoInc; if (lfo > TAU) lfo -= TAU;\n    const framePos: f32 = basePos + scanDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo)));\n    let mixL: f32 = 0.0; let mixR: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      vDrift[s] = vDrift[s] * _dLeak + rnd() * _dStep;\n      const fr: f32 = vFreq[s] * (1.0 + vDrift[s]);\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let ph: f32 = vPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; vPh[s] = ph;\n      let osc: f32 = readWT(framePos, ph);\n      // drive grit: saturation\n      osc = f32(Mathf.tanh(osc * drive)) * driveComp;\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1c;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const _v: f32 = lpN * vAmp[s] * vVel[s]; mixL += _v * vGL[s]; mixR += _v * vGR[s];\n    }\n    let oL: f32 = mixL * out; let oR: f32 = mixR * out;\n    if (oL > 1.4) oL = 1.4; else if (oL < -1.4) oL = -1.4; if (oR > 1.4) oR = 1.4; else if (oR < -1.4) oR = -1.4;\n    outBuf[i] = oL; outBuf[MAX_FRAMES + i] = oR;\n  }\n}\n",
  "publishedAt": 1751306000000
}