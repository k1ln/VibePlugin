{
  "format": 1,
  "name": "Oberon",
  "isInstrument": true,
  "explanation": "A fat discrete-oscillator analog polyphonic synthesizer with six independent voices. Each voice runs two oscillators — a band-limited saw and a hollow pulse — plus a wide-detuned fat layer, into a raw resonant 2-pole (12 dB/oct) low-pass shaped by its own envelope, then an amplitude envelope. A unison Spread detunes the layers and pans each voice across the stereo field for huge, brassy late-70s American-poly stabs — deliberately fatter and rawer than a clean ladder-filter poly. Controls: Cutoff, Resonance, Env Amount, Spread, Attack, Release and Level.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "EnvAmount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Spread",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --p{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --ac:#caa6ff; --ac2:#ff8fb0;\n  --cream:#f3ead6; --cream2:#e6d8ba; --ink:#33291f;\n  --wood:#6a4327; --wood2:#3f2614; --woodHi:#8a5d39;\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:var(--ink);\n  background:radial-gradient(130% 100% at 50% -12%,#221b14 0%,#120d08 60%,#070503 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;-webkit-font-smoothing:antialiased;\n}\n\n/* ============ chassis: cream panel between two wood end-cheeks ======= */\n.synth{\n  position:relative;width:100%;max-width:820px;display:flex;\n  border-radius:13px;\n  box-shadow:0 40px 90px rgba(0,0,0,.66),0 2px 0 rgba(255,255,255,.05) inset;\n  animation:rise .75s cubic-bezier(.2,.85,.2,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(26px) scale(.984)}to{opacity:1;transform:none}}\n\n/* the two wooden end-cheeks */\n.cheek{flex:0 0 28px;position:relative;\n  background:\n    repeating-linear-gradient(176deg,rgba(0,0,0,.16) 0 3px,rgba(255,255,255,.045) 3px 7px),\n    linear-gradient(160deg,var(--woodHi),var(--wood) 40%,var(--wood2) 100%);\n  box-shadow:0 1px 0 rgba(255,255,255,.1) inset,0 -2px 10px rgba(0,0,0,.5) inset;\n}\n.cheek.l{border-radius:13px 0 0 13px}\n.cheek.r{border-radius:0 13px 13px 0}\n.cheek::after{content:\"\";position:absolute;inset:5px 6px;border-radius:7px;\n  box-shadow:0 0 0 1px rgba(0,0,0,.25),0 0 0 2px rgba(255,255,255,.06)}\n\n.surface{\n  position:relative;flex:1 1 auto;border-radius:4px;overflow:hidden;\n  background:linear-gradient(180deg,#f7efdd,#ebe0c6 60%,#ddceac 100%);\n  box-shadow:0 1px 0 rgba(255,255,255,.7) inset,0 -12px 30px rgba(120,90,48,.2) inset,0 0 0 1px rgba(80,52,30,.35);\n}\n.surface::before{content:\"\";position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.55;\n  background:\n    repeating-linear-gradient(91deg,rgba(120,90,48,.04) 0 2px,transparent 2px 6px),\n    radial-gradient(150% 70% at 50% 0%,rgba(255,255,255,.5),transparent 62%);\n  mix-blend-mode:multiply}\n\n/* ---------------- header / brand plate ---------------- */\n.head{position:relative;z-index:2;display:flex;align-items:flex-end;gap:14px;\n  padding:16px 24px 12px;border-bottom:2px solid rgba(80,52,30,.26)}\n.brand{display:flex;flex-direction:column;line-height:1}\n.brand .mk{font-size:9px;letter-spacing:.46em;color:#9a7c4c;font-weight:700;text-transform:uppercase}\n.brand h1{margin:4px 0 0;font-size:27px;font-weight:900;letter-spacing:.04em;color:#33291f;\n  text-shadow:0 1px 0 rgba(255,255,255,.6),0 -1px 0 rgba(80,52,30,.18)}\n.brand h1 em{font-style:normal;background:linear-gradient(90deg,var(--ac),var(--ac2));\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  filter:drop-shadow(0 0 8px rgba(202,166,255,.35))}\n.tag{font-size:9px;letter-spacing:.3em;color:#a98a58;text-transform:uppercase;margin-top:4px}\n\n/* ---- the breathing stacked-saw scope (the motif) ---- */\n.scope{margin-left:auto;width:230px;height:62px;border-radius:8px;position:relative;overflow:hidden;\n  background:linear-gradient(180deg,#241c12,#0f0a05);\n  box-shadow:0 1px 0 rgba(255,255,255,.16),0 -2px 8px rgba(0,0,0,.55) inset,0 2px 6px rgba(0,0,0,.4)}\n.scope svg{position:absolute;inset:0;width:100%;height:100%}\n.scope .sgrid{stroke:rgba(255,255,255,.05)}\n.swave{fill:none;stroke-linejoin:round;stroke-linecap:round}\n.swave.a{stroke:var(--ac);stroke-width:2;filter:drop-shadow(0 0 5px var(--ac));animation:breathe 3.4s ease-in-out infinite}\n.swave.b{stroke:var(--ac2);stroke-width:1.6;opacity:.8;filter:drop-shadow(0 0 5px var(--ac2));animation:breathe 3.4s ease-in-out infinite .9s}\n.swave.c{stroke:color-mix(in srgb,var(--ac) 60%,var(--ac2));stroke-width:1.2;opacity:.55;animation:breathe 3.4s ease-in-out infinite 1.8s}\n@keyframes breathe{0%,100%{transform:translateX(0) scaleY(.9)}50%{transform:translateX(-6px) scaleY(1.12)}}\n.scope .glo{position:absolute;inset:0;background:radial-gradient(90% 120% at 30% 50%,rgba(202,166,255,.14),transparent 70%);\n  animation:sweepg 3.4s ease-in-out infinite}\n@keyframes sweepg{0%,100%{opacity:.4;transform:translateX(-12%)}50%{opacity:.9;transform:translateX(12%)}}\n\n/* ---------------- body ---------------- */\n.body{position:relative;z-index:2;padding:18px 24px 8px}\n.row{display:flex;gap:20px;align-items:stretch;flex-wrap:wrap}\n.module{flex:1 1 0;min-width:210px;position:relative;padding:14px 18px 18px;border-radius:9px;\n  background:linear-gradient(180deg,rgba(255,255,255,.34),rgba(255,255,255,0));\n  box-shadow:0 0 0 1px rgba(80,52,30,.16),0 1px 0 rgba(255,255,255,.5) inset}\n.module>.mt{font-size:9px;letter-spacing:.32em;color:#9a7c4c;text-transform:uppercase;font-weight:800;\n  margin-bottom:14px;display:flex;align-items:center;gap:8px}\n.module>.mt::after{content:\"\";flex:1;height:1px;background:repeating-linear-gradient(90deg,rgba(80,52,30,.3) 0 5px,transparent 5px 9px)}\n.knobs{display:flex;gap:6px;justify-content:space-around;flex-wrap:wrap}\n\n/* ---------------- bakelite/ivory knob ---------------- */\n.cell{display:flex;flex-direction:column;align-items:center;gap:8px;width:78px;\n  animation:pop .55s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(10px) scale(.9)}to{opacity:1;transform:none}}\n.knob{--p:0;position:relative;width:60px;height:60px;cursor:ns-resize;touch-action:none;user-select:none}\n.knob .scale{position:absolute;inset:-9px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(80,52,30,.5) 0 1.1deg,transparent 1.1deg 13.5deg);\n  -webkit-mask:radial-gradient(circle,transparent 32px,#000 33px,#000 35px,transparent 36px);\n  mask:radial-gradient(circle,transparent 32px,#000 33px,#000 35px,transparent 36px)}\n.knob .arc{position:absolute;inset:-5px;border-radius:50%;\n  background:conic-gradient(from 215deg,\n    var(--ac) calc(var(--p)*290deg),\n    color-mix(in srgb,var(--ac2) 65%,var(--ac)) calc(var(--p)*290deg),\n    rgba(80,52,30,.13) calc(var(--p)*290deg) 290deg,\n    transparent 290deg);\n  -webkit-mask:radial-gradient(circle,transparent 29px,#000 30px,#000 32.5px,transparent 33.5px);\n  mask:radial-gradient(circle,transparent 29px,#000 30px,#000 32.5px,transparent 33.5px);\n  filter:drop-shadow(0 0 calc(2px + var(--p)*8px) color-mix(in srgb,var(--ac) 72%,transparent));\n  transition:--p .13s cubic-bezier(.2,.8,.25,1)}\n.knob .cap{position:absolute;inset:8px;border-radius:50%;\n  background:radial-gradient(circle at 40% 28%,#fdf7ea,#e8dcc4 52%,#bca882 100%);\n  box-shadow:0 2px 6px rgba(55,38,24,.45),0 1px 0 rgba(255,255,255,.85) inset,0 -4px 9px rgba(120,90,48,.34) inset}\n.knob.act .cap{box-shadow:0 2px 6px rgba(55,38,24,.45),0 1px 0 rgba(255,255,255,.85) inset,0 -4px 9px rgba(120,90,48,.34) inset,0 0 0 2px color-mix(in srgb,var(--ac) 62%,transparent)}\n.knob .ptr{position:absolute;left:50%;top:9px;width:3px;height:17px;margin-left:-1.5px;border-radius:2px;\n  background:linear-gradient(var(--ink),#6a4327);box-shadow:0 0 0 1px rgba(255,255,255,.3);\n  transform-origin:50% 21px;transform:rotate(calc((var(--p) - .5)*290deg));\n  transition:transform .13s cubic-bezier(.2,.8,.25,1)}\n.cnm{font-size:9px;letter-spacing:.12em;color:#7a623e;text-transform:uppercase;font-weight:800;text-align:center}\n.cval{font-size:11px;font-weight:800;color:#33291f;font-variant-numeric:tabular-nums;\n  background:rgba(80,52,30,.1);padding:1px 8px;border-radius:5px;min-width:42px;text-align:center}\n.cell:hover .cval{background:color-mix(in srgb,var(--ac) 30%,rgba(80,52,30,.1))}\n\n/* ---------------- voice LED bank ---------------- */\n.voices{display:flex;flex-direction:column;align-items:center;gap:8px;justify-content:center;padding:0 4px}\n.voices .vlbl{font-size:8px;letter-spacing:.32em;color:#9a7c4c;text-transform:uppercase;font-weight:700}\n.bank{display:flex;gap:9px;padding:9px 11px;border-radius:9px;\n  background:linear-gradient(180deg,#2a2114,#15100a);\n  box-shadow:0 1px 0 rgba(255,255,255,.16),0 -2px 6px rgba(0,0,0,.5) inset,0 2px 5px rgba(0,0,0,.4)}\n.voice{position:relative;width:13px;height:13px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#5e564a,#221d15 75%);\n  box-shadow:0 1px 1px rgba(0,0,0,.6) inset,0 1px 0 rgba(255,255,255,.07)}\n.voice::after{content:\"\";position:absolute;inset:2px;border-radius:50%;background:var(--ac);opacity:0;transform:scale(.5);\n  box-shadow:0 0 9px var(--ac),0 0 18px var(--ac2);transition:opacity .12s,transform .12s}\n.voice.on::after{opacity:1;transform:scale(1)}\n\nfooter{position:relative;z-index:2;display:flex;align-items:center;gap:10px;\n  padding:11px 24px 16px;font-size:10px;color:#9a7c4c;letter-spacing:.04em}\nfooter .dotL{width:7px;height:7px;border-radius:50%;background:var(--ac);\n  box-shadow:0 0 8px var(--ac);animation:bp 2.4s ease-in-out infinite}\n@keyframes bp{0%,100%{opacity:.5}50%{opacity:1}}\nfooter b{color:#7a623e;font-weight:800;letter-spacing:.22em;text-transform:uppercase}\nfooter .sp{margin-left:auto;font-style:italic;color:#a98a58;max-width:420px;text-align:right;line-height:1.4}\n</style></head><body>\n<div class=\"synth\">\n <div class=\"cheek l\"></div>\n <div class=\"surface\">\n  <div class=\"head\">\n    <div class=\"brand\">\n      <span class=\"mk\">Vibe Instruments</span>\n      <h1>Ober<em>on</em></h1>\n      <span class=\"tag\">6-Voice · Discrete Dual-Osc · SEM-Flavour</span>\n    </div>\n    <div class=\"scope\">\n      <div class=\"glo\"></div>\n      <svg viewBox=\"0 0 230 62\" preserveAspectRatio=\"none\">\n        <line class=\"sgrid\" x1=\"0\" y1=\"31\" x2=\"230\" y2=\"31\"/>\n        <path class=\"swave c\" id=\"wc\"></path>\n        <path class=\"swave b\" id=\"wb\"></path>\n        <path class=\"swave a\" id=\"wa\"></path>\n      </svg>\n    </div>\n  </div>\n\n  <div class=\"body\">\n   <div class=\"row\">\n      <div class=\"module\">\n        <div class=\"mt\">Filter</div>\n        <div class=\"knobs\" id=\"filtK\"></div>\n      </div>\n      <div class=\"module\">\n        <div class=\"mt\">Oscillators</div>\n        <div class=\"knobs\" id=\"oscK\"></div>\n      </div>\n   </div>\n   <div class=\"row\">\n      <div class=\"module\">\n        <div class=\"mt\">Envelope</div>\n        <div class=\"knobs\" id=\"envK\"></div>\n      </div>\n      <div class=\"module\" style=\"flex:0 0 150px;min-width:150px\">\n        <div class=\"mt\">Output</div>\n        <div class=\"knobs\" id=\"outK\"></div>\n      </div>\n      <div class=\"module\" style=\"flex:0 0 130px;min-width:130px\">\n        <div class=\"mt\">Voices</div>\n        <div class=\"voices\"><div class=\"bank\" id=\"bank\"></div></div>\n      </div>\n   </div>\n  </div>\n\n  <footer>\n    <span class=\"dotL\"></span><b>Oberon</b>\n    <span class=\"sp\" id=\"sp\"></span>\n  </footer>\n </div>\n <div class=\"cheek r\"></div>\n</div>\n\n<script>\n(function(){\n  var P=[\n    {name:\"Cutoff\",    index:0,min:0,max:1,def:0.5 },\n    {name:\"Resonance\", index:1,min:0,max:1,def:0.4 },\n    {name:\"EnvAmount\", index:2,min:0,max:1,def:0.55},\n    {name:\"Spread\",    index:3,min:0,max:1,def:0.4 },\n    {name:\"Attack\",    index:4,min:0,max:1,def:0.04},\n    {name:\"Release\",   index:5,min:0,max:1,def:0.35},\n    {name:\"Level\",     index:6,min:0,max:1,def:0.6 }\n  ];\n  var byName={}; P.forEach(function(p){byName[p.name]=p;});\n  var live={}; P.forEach(function(p){ live[p.name]=(p.def-p.min)/(p.max-p.min); });\n  document.getElementById('sp').textContent=\"Fat discrete dual-oscillator poly — raw resonant filter, wide unison spread.\";\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmtPct(v){ return Math.round(v*100)+\"%\"; }\n  function fmtMs(v){ var ms=Math.round((v*v)*3500)+1; return ms>=1000?(ms/1000).toFixed(2)+\"s\":ms+\"ms\"; }\n  function labelFor(p,v){\n    if(p.name===\"Attack\"||p.name===\"Release\") return fmtMs(v);\n    if(p.name===\"Cutoff\"){ var hz=Math.round(70*Math.pow(214,v)); return hz>=1000?(hz/1000).toFixed(1)+\"k\":hz+\"Hz\"; }\n    return fmtPct(v);\n  }\n\n  function makeKnob(host,p){\n    var cell=document.createElement('div'); cell.className='cell';\n    cell.style.setProperty('--d',(p.index*55)+'ms');\n    cell.innerHTML='<div class=\"knob\"><i class=\"scale\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i></div>'+\n      '<div class=\"cnm\">'+(p.name===\"EnvAmount\"?\"Env Amt\":p.name)+'</div><div class=\"cval\"></div>';\n    host.appendChild(cell);\n    var knob=cell.querySelector('.knob'), val=cell.querySelector('.cval');\n    var v=p.def;\n    function norm(){ return (v-p.min)/(p.max-p.min||1); }\n    function paint(){ var n=norm(); knob.style.setProperty('--p',n); val.textContent=labelFor(p,n); live[p.name]=n; send(p.index,v); reshape(); }\n    function setN(n){ n=n<0?0:n>1?1:n; v=p.min+(p.max-p.min)*n; paint(); }\n    knob.addEventListener('pointerdown',function(e){ knob._d=1;knob._y=e.clientY;knob._n=norm();knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault(); });\n    knob.addEventListener('pointermove',function(e){ if(!knob._d)return; var spd=e.shiftKey?640:200; setN(knob._n+(knob._y-e.clientY)/spd); });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end); knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n    paint();\n  }\n\n  makeKnob(document.getElementById('filtK'), byName[\"Cutoff\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"Resonance\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"EnvAmount\"]);\n  makeKnob(document.getElementById('oscK'),  byName[\"Spread\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Attack\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Release\"]);\n  makeKnob(document.getElementById('outK'),  byName[\"Level\"]);\n\n  // ---- stacked-saw scope reshaped live by Spread + Cutoff ----\n  var wa=document.getElementById('wa'),wb=document.getElementById('wb'),wc=document.getElementById('wc');\n  function sawPath(off,amp,duty){\n    // 3 stacked detuned saw teeth across the width\n    var W=230,Hm=31, teeth=4, d=document; var s=\"M 0 \"+Hm;\n    var step=W/teeth;\n    for(var k=0;k<=teeth;k++){\n      var x=k*step+off;\n      var open=Hm-amp; // top\n      var close=Hm+amp*duty; // bottom\n      s+=\" L \"+(x).toFixed(1)+\" \"+open.toFixed(1)+\" L \"+(x).toFixed(1)+\" \"+close.toFixed(1);\n    }\n    return s;\n  }\n  function reshape(){\n    var sp=live[\"Spread\"]||0, cut=live[\"Cutoff\"]||0;\n    var amp=8+cut*16;            // brighter cutoff -> taller teeth\n    var duty=0.5+sp*0.4;\n    wa.setAttribute('d',sawPath(0,amp,duty));\n    wb.setAttribute('d',sawPath(6+sp*10,amp*0.85,duty));\n    wc.setAttribute('d',sawPath(12+sp*20,amp*0.7,duty));\n  }\n  reshape();\n\n  // ---- voice LED bank (6) ----\n  var BANK=document.getElementById('bank'), voices=[];\n  for(var i=0;i<6;i++){ var vv=document.createElement('div'); vv.className='voice'; BANK.appendChild(vv); voices.push(vv); }\n  var voiceOfNote={}, nextV=0;\n  function lightOn(note){ if(voiceOfNote[note]!=null)return; var v=nextV; nextV=(nextV+1)%6; voiceOfNote[note]=v; voices[v].classList.add('on'); }\n  function lightOff(note){ var v=voiceOfNote[note]; if(v!=null){ voices[v].classList.remove('on'); delete voiceOfNote[note]; } }\n  window.addEventListener('message',function(e){ var d=e.data||{}; if(d.t==='on')lightOn(d.id); else if(d.t==='off')lightOff(d.id); });\n  var idleV=-1, idleT=0;\n  function idle(now){ requestAnimationFrame(idle);\n    if(Object.keys(voiceOfNote).length) return;\n    if(now-idleT>560){ idleT=now; if(idleV>=0)voices[idleV].classList.remove('on'); idleV=(idleV+1)%6; voices[idleV].classList.add('on'); } }\n  requestAnimationFrame(idle);\n\n  function ready(){}\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  OBERON — a fat discrete-oscillator analog polyphonic synthesizer.\n//  Six voices, each with TWO oscillators (a band-limited saw + a pulse)\n//  fed through a slightly raw resonant 2-pole (12 dB/oct SEM-flavour)\n//  low-pass driven by its own envelope (Cutoff + Env Amount + Resonance),\n//  then an amplitude envelope. A wide unison Spread detunes the two\n//  oscillators AND pans the voice across the stereo field for huge,\n//  brassy late-70s American-poly stabs. Deliberately fatter and rawer\n//  than a clean ladder-filter poly. Pure algorithm, no samples, no imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:  i32 = 0;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 1;  // 0..1  -> filter resonance (raw)\nconst P_ENVAMT:  i32 = 2;  // 0..1  -> filter envelope amount\nconst P_SPREAD:  i32 = 3;  // 0..1  -> unison detune + stereo width\nconst P_ATTACK:  i32 = 4;  // 0..1  -> seconds (both envelopes)\nconst P_RELEASE: i32 = 5;  // 0..1  -> seconds\nconst P_LEVEL:   i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPan:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // -1..1 deterministic per slot\n\nconst vPhase1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw phase\nconst vPhase2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse phase\nconst vPhase3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // sub/detune saw phase\n\n// amplitude envelope (attack -> sustain(=1) -> release)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 3 sus 4 rel\n// filter envelope\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// 2-pole state-variable-ish filter state (2 one-pole stages per voice)\nconst vS1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vS2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhase1[v] = 0.0; vPhase2[v] = 0.0; vPhase3[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vS1[v] = 0.0; vS2[v] = 0.0;\n    // spread voices across the stereo field deterministically\n    vPan[v] = (f32(v) / f32(NUM_VOICES - 1)) * 2.0 - 1.0;\n  }\n  ageCounter = 0;\n  params[P_CUTOFF]  = 0.5;\n  params[P_RESO]    = 0.4;\n  params[P_ENVAMT]  = 0.55;\n  params[P_SPREAD]  = 0.4;\n  params[P_ATTACK]  = 0.04;\n  params[P_RELEASE] = 0.35;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n  // offset phases so detuned layers don't start phase-locked (fatter onset)\n  vPhase1[slot] = 0.0;\n  vPhase2[slot] = 0.33;\n  vPhase3[slot] = 0.66;\n  vS1[slot] = 0.0; vS2[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const spread: f32  = clampf(params[P_SPREAD], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.6;\n  const relS: f32 = 0.01  + clampf(params[P_RELEASE], 0.0, 1.0) * 2.4;\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.1;\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune spread: up to ~ +/-0.32 semitone between the layers (fat, beaty)\n  const detSemi: f32 = spread * 0.32;\n  const ratioUp: f32   = f32(Mathf.pow(2.0,  detSemi / 12.0));\n  const ratioDn: f32   = f32(Mathf.pow(2.0, -detSemi / 12.0));\n  // a wider third layer detune for thickness\n  const ratioWide: f32 = f32(Mathf.pow(2.0, (detSemi * 1.7) / 12.0));\n  // stereo width grows with spread\n  const width: f32 = spread;\n\n  // base cutoff in Hz, exponential ~70 Hz .. ~15 kHz\n  const baseHz: f32 = 70.0 * f32(Mathf.pow(214.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~5.5 octaves\n  const envOct: f32 = envAmt * 5.5;\n  // resonance feedback 0..~1.9 (raw, can ring hard but stays bounded)\n  const reso: f32 = resoN * 1.9;\n\n  // headroom: up to 6 fat voices -> scale so big chords stay < 1\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n    let outR: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope (A / sustain=1 / R) ---------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 3; }\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter envelope --------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 3; }\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- oscillators (saw + pulse + wide saw, detuned) --------\n      const baseInc: f32 = vFreq[v] / sr;\n      const inc1: f32 = baseInc * ratioDn;     // saw, tuned down\n      const inc2: f32 = baseInc * ratioUp;     // pulse, tuned up\n      const inc3: f32 = baseInc * ratioWide;   // wide saw (fatness layer)\n\n      // saw 1\n      let p1: f32 = vPhase1[v];\n      p1 += inc1; if (p1 >= 1.0) p1 -= 1.0;\n      let saw1: f32 = 2.0 * p1 - 1.0;\n      saw1 -= polyBlep(p1, inc1);\n      vPhase1[v] = p1;\n\n      // pulse (asymmetric ~45% duty -> richer, hollower OB-style tone)\n      let p2: f32 = vPhase2[v];\n      p2 += inc2; if (p2 >= 1.0) p2 -= 1.0;\n      const pw: f32 = 0.45;\n      let sq: f32 = p2 < pw ? 1.0 : -1.0;\n      sq += polyBlep(p2, inc2);\n      let p2b: f32 = p2 + (1.0 - pw);\n      if (p2b >= 1.0) p2b -= 1.0;\n      sq -= polyBlep(p2b, inc2);\n      vPhase2[v] = p2;\n\n      // saw 3 (wide-detuned, scaled by spread for extra fat/beating)\n      let p3: f32 = vPhase3[v];\n      p3 += inc3; if (p3 >= 1.0) p3 -= 1.0;\n      let saw3: f32 = 2.0 * p3 - 1.0;\n      saw3 -= polyBlep(p3, inc3);\n      vPhase3[v] = p3;\n\n      // mix oscillators: saw body + hollow pulse + spread-driven fat layer\n      let osc: f32 = saw1 * 0.6 + sq * 0.42 + saw3 * (0.18 + 0.4 * spread);\n\n      // ---- raw resonant 2-pole low-pass (SEM-ish, 12 dB/oct) ----\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s1: f32 = vS1[v];\n      let s2: f32 = vS2[v];\n\n      // resonance feedback from 2nd stage; soft drive for raw analog edge\n      let inp: f32 = osc - reso * s2;\n      inp = f32(Mathf.tanh(inp * 1.3));   // slight pre-filter grit\n      s1 += g * (inp - s1);\n      s2 += g * (s1 - s2);\n\n      vS1[v] = s1; vS2[v] = s2;\n\n      const voice: f32 = s2 * aenv * (0.4 + 0.6 * vVel[v]);\n\n      // ---- per-voice stereo pan scaled by Spread -----------------\n      const pan: f32 = vPan[v] * width;            // -1..1\n      const lg: f32 = 0.5 + 0.5 * (1.0 - pan);     // simple equal-ish pan\n      const rg: f32 = 0.5 + 0.5 * (1.0 + pan);\n      outL += voice * lg;\n      outR += voice * rg;\n    }\n\n    // ---- sum + soft saturate for analog glue --------------------\n    let mL: f32 = f32(Mathf.tanh(outL * voiceScale * 1.15)) * level;\n    let mR: f32 = f32(Mathf.tanh(outR * voiceScale * 1.15)) * level;\n\n    outBuf[f] = mL;\n    outBuf[MAX_FRAMES + f] = mR;\n  }\n}\n",
  "publishedAt": 1751000094000
}