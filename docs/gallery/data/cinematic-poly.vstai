  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Cinematic Poly</title>\n<style>\n  :root {\n    --accent: #e0b070;\n    --accent2: #c08040;\n    --wood1: #5a3320;\n    --wood2: #3a1f12;\n    --panel1: #211b18;\n    --panel2: #16110e;\n    --ink: #efe2cf;\n    --ink-dim: #9c8a76;\n    --metal1: #46403a;\n    --metal2: #24201c;\n  }\n\n  * { box-sizing: border-box; -webkit-user-select: none; user-select: none; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a221d 0%, #120d0a 60%, #0a0706 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    min-height: 100%;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .cabinet {\n    width: 100%;\n    max-width: 880px;\n    border-radius: 16px;\n    padding: 14px;\n    background:\n      linear-gradient(180deg, #1d1714 0%, #100c0a 100%);\n    box-shadow:\n      0 26px 60px rgba(0,0,0,0.7),\n      0 2px 0 rgba(255,255,255,0.05) inset,\n      0 -2px 0 rgba(0,0,0,0.6) inset;\n    position: relative;\n    display: flex;\n    gap: 10px;\n  }\n\n  /* wooden end cheeks */\n  .cheek {\n    width: 30px;\n    flex: 0 0 30px;\n    border-radius: 10px;\n    background:\n      repeating-linear-gradient(180deg,\n        rgba(0,0,0,0.18) 0px, rgba(0,0,0,0.18) 2px,\n        rgba(255,255,255,0.04) 3px, rgba(255,255,255,0.04) 5px),\n      linear-gradient(95deg, var(--wood1), var(--wood2));\n    box-shadow:\n      0 2px 0 rgba(255,210,150,0.18) inset,\n      0 -6px 14px rgba(0,0,0,0.6) inset,\n      0 14px 26px rgba(0,0,0,0.5);\n    position: relative;\n  }\n  .cheek::after {\n    content: \"\";\n    position: absolute;\n    inset: 5px;\n    border-radius: 7px;\n    border: 1px solid rgba(0,0,0,0.4);\n    box-shadow: 0 1px 0 rgba(255,210,150,0.12) inset;\n  }\n\n  .face {\n    flex: 1 1 auto;\n    min-width: 0;\n    border-radius: 10px;\n    padding: 16px 18px 14px;\n    background:\n      linear-gradient(180deg, var(--panel1), var(--panel2));\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.06) inset,\n      0 -16px 30px rgba(0,0,0,0.5) inset;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* faint brushed-metal sheen sweeping across the panel */\n  .face::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(115deg,\n      transparent 30%,\n      rgba(224,176,112,0.06) 48%,\n      rgba(224,176,112,0.10) 50%,\n      transparent 70%);\n    background-size: 280% 100%;\n    animation: sheen 9s ease-in-out infinite;\n    pointer-events: none;\n  }\n  @keyframes sheen {\n    0%, 100% { background-position: 120% 0; }\n    50% { background-position: -40% 0; }\n  }\n\n  header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 14px;\n    position: relative;\n    z-index: 2;\n    margin-bottom: 12px;\n  }\n  .brand {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n  }\n  .logo-orb {\n    width: 34px;\n    height: 34px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, var(--accent), var(--accent2) 60%, #5a2f12);\n    box-shadow:\n      0 0 18px rgba(224,176,112,0.55),\n      0 2px 4px rgba(0,0,0,0.6),\n      0 1px 0 rgba(255,255,255,0.4) inset;\n    animation: orbPulse 4s ease-in-out infinite;\n  }\n  @keyframes orbPulse {\n    0%, 100% { box-shadow: 0 0 14px rgba(224,176,112,0.4), 0 2px 4px rgba(0,0,0,0.6), 0 1px 0 rgba(255,255,255,0.4) inset; }\n    50% { box-shadow: 0 0 26px rgba(224,176,112,0.8), 0 2px 4px rgba(0,0,0,0.6), 0 1px 0 rgba(255,255,255,0.5) inset; }\n  }\n  .titles h1 {\n    margin: 0;\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, #fff3df, var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles .sub {\n    margin: 2px 0 0;\n    font-size: 9.5px;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* voice/activity indicator lamps */\n  .lamps {\n    display: flex;\n    gap: 6px;\n    align-items: center;\n  }\n  .lamp {\n    width: 9px;\n    height: 9px;\n    border-radius: 50%;\n    background: #2a211a;\n    box-shadow: 0 0 0 1px rgba(0,0,0,0.6), 0 1px 1px rgba(255,255,255,0.06) inset;\n    transition: background 0.12s, box-shadow 0.12s;\n  }\n  .lamp.on {\n    background: var(--accent);\n    box-shadow: 0 0 10px var(--accent), 0 0 0 1px rgba(0,0,0,0.5);\n  }\n\n  /* the dual-layer glow scope across the top */\n  .scope {\n    position: relative;\n    z-index: 2;\n    height: 70px;\n    border-radius: 8px;\n    margin-bottom: 14px;\n    background:\n      linear-gradient(180deg, #0d0907, #060403);\n    box-shadow:\n      0 0 0 1px rgba(224,176,112,0.18),\n      0 8px 18px rgba(0,0,0,0.5) inset;\n    overflow: hidden;\n  }\n  .scope canvas { width: 100%; height: 100%; display: block; }\n\n  .controls {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px 8px;\n    margin-bottom: 14px;\n  }\n\n  .knob-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 4px;\n    padding: 8px 4px 6px;\n    border-radius: 9px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.18));\n    box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 1px 3px rgba(0,0,0,0.4);\n  }\n  .knob {\n    width: 70px;\n    height: 70px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { width: 100%; height: 100%; display: block; }\n  .lbl {\n    font-size: 9px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .val {\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    letter-spacing: 0.04em;\n    color: var(--accent);\n    min-height: 13px;\n  }\n\n  /* ribbon controller strip */\n  .ribbon-wrap {\n    position: relative;\n    z-index: 2;\n    margin-bottom: 12px;\n  }\n  .ribbon-label {\n    font-size: 8.5px;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin: 0 0 4px 2px;\n  }\n  .ribbon {\n    height: 26px;\n    border-radius: 13px;\n    position: relative;\n    cursor: pointer;\n    touch-action: none;\n    background:\n      linear-gradient(180deg, #2b231d, #15100c);\n    box-shadow:\n      0 0 0 1px rgba(0,0,0,0.6),\n      0 2px 6px rgba(0,0,0,0.5) inset,\n      0 1px 0 rgba(255,255,255,0.05);\n    overflow: hidden;\n  }\n  .ribbon-grooves {\n    position: absolute;\n    inset: 0;\n    background: repeating-linear-gradient(90deg,\n      rgba(255,255,255,0.03) 0px, rgba(255,255,255,0.03) 1px,\n      transparent 1px, transparent 14px);\n  }\n  .ribbon-glow {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    width: 46px;\n    left: 50%;\n    transform: translateX(-50%);\n    border-radius: 13px;\n    background: radial-gradient(closest-side, var(--accent), rgba(224,176,112,0.0));\n    opacity: 0.35;\n    transition: opacity 0.2s;\n    pointer-events: none;\n  }\n  .ribbon.touched .ribbon-glow { opacity: 0.85; }\n\n  /* keyboard */\n  .keys {\n    position: relative;\n    z-index: 2;\n    height: 116px;\n    border-radius: 7px;\n    padding: 7px 7px 0;\n    background: linear-gradient(180deg, #0c0907, #050302);\n    box-shadow: 0 8px 16px rgba(0,0,0,0.5) inset, 0 0 0 1px rgba(224,176,112,0.12);\n    display: flex;\n    position: relative;\n  }\n  .key {\n    position: relative;\n    flex: 1 1 0;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #f3ead8 0%, #d8cab2 88%, #b6a888 100%);\n    box-shadow:\n      0 -1px 0 rgba(0,0,0,0.3) inset,\n      0 4px 5px rgba(0,0,0,0.4);\n    cursor: pointer;\n    transition: background 0.04s, transform 0.04s;\n  }\n  .key.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #d8a45c 70%, #b6843c 100%);\n    transform: translateY(2px);\n    box-shadow: 0 0 14px rgba(224,176,112,0.7) inset, 0 1px 2px rgba(0,0,0,0.5);\n  }\n  .key.black {\n    position: absolute;\n    top: 7px;\n    width: 5.4%;\n    height: 64%;\n    margin: 0;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a221c 0%, #100c09 100%);\n    box-shadow: 0 3px 4px rgba(0,0,0,0.6), 0 -1px 0 rgba(255,255,255,0.08) inset;\n    z-index: 3;\n  }\n  .key.black.down {\n    background: linear-gradient(180deg, var(--accent2) 0%, #6a3c16 100%);\n    box-shadow: 0 0 12px rgba(192,128,64,0.8) inset;\n    transform: translateY(1px);\n  }\n\n  .footer {\n    position: relative;\n    z-index: 2;\n    margin-top: 9px;\n    display: flex;\n    justify-content: space-between;\n    font-size: 8.5px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n</style>\n</head>\n<body>\n  <div class=\"cabinet\">\n    <div class=\"cheek\"></div>\n    <div class=\"face\">\n      <header>\n        <div class=\"brand\">\n          <div class=\"logo-orb\"></div>\n          <div class=\"titles\">\n            <h1>Cinematic Poly</h1>\n            <p class=\"sub\">Dual-Layer Grand Polysynth</p>\n          </div>\n        </div>\n        <div class=\"lamps\" id=\"lamps\"></div>\n      </header>\n\n      <div class=\"scope\"><canvas id=\"scope\"></canvas></div>\n\n      <div class=\"controls\" id=\"controls\"></div>\n\n      <div class=\"ribbon-wrap\">\n        <p class=\"ribbon-label\">Ribbon &mdash; Brightness</p>\n        <div class=\"ribbon\" id=\"ribbon\">\n          <div class=\"ribbon-grooves\"></div>\n          <div class=\"ribbon-glow\" id=\"ribbonGlow\"></div>\n        </div>\n      </div>\n\n      <div class=\"keys\" id=\"keys\"></div>\n\n      <div class=\"footer\">\n        <span>8 Voices &middot; 2 Layers</span>\n        <span>Drag knobs &middot; dbl-click resets</span>\n      </div>\n    </div>\n    <div class=\"cheek\"></div>\n  </div>\n\n<script>\n  \"use strict\";\n\n  // ---- host bridge --------------------------------------------------\n  function setParam(i, v) {\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n  function hostNoteOn(n, vel) {\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, vel);\n  }\n  function hostNoteOff(n) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  // ---- parameter model (indices match assembly.ts / spec.json) ------\n  var PARAMS = [\n    { name: \"Detune\",     index: 0, min: 0, max: 1, def: 0.35, fmt: pct },\n    { name: \"Cutoff\",     index: 1, min: 0, max: 1, def: 0.5,  fmt: pct },\n    { name: \"Resonance\",  index: 2, min: 0, max: 1, def: 0.3,  fmt: pct },\n    { name: \"Filt Env\",   index: 3, min: 0, max: 1, def: 0.55, fmt: pct },\n    { name: \"Attack\",     index: 4, min: 0, max: 1, def: 0.18, fmt: secs },\n    { name: \"Release\",    index: 5, min: 0, max: 1, def: 0.4,  fmt: secs },\n    { name: \"Brightness\", index: 6, min: 0, max: 1, def: 0.55, fmt: pct },\n    { name: \"Level\",      index: 7, min: 0, max: 1, def: 0.7,  fmt: pct }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function secs(v, p) {\n    // Attack maps ~0..2.2s, Release ~0.02..3.5s in the DSP; show approx time.\n    var t = p.index === 4 ? 0.002 + v * 2.2 : 0.02 + v * 3.5;\n    return t < 1 ? Math.round(t * 1000) + \" ms\" : t.toFixed(2) + \" s\";\n  }\n\n  var ACCENT = \"#e0b070\";\n  var ACCENT2 = \"#c08040\";\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  // ---- knob factory (SVG, drag vertical, wheel, dbl-click reset) ----\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob-cell\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n\n    var NS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    function arc(r, a0, a1) {\n      var x0 = 50 + r * Math.cos(a0), y0 = 50 + r * Math.sin(a0);\n      var x1 = 50 + r * Math.cos(a1), y1 = 50 + r * Math.sin(a1);\n      var large = (a1 - a0) > Math.PI ? 1 : 0;\n      return \"M \" + x0 + \" \" + y0 + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + x1 + \" \" + y1;\n    }\n    var A_START = Math.PI * 0.75;\n    var A_END = Math.PI * 2.25;\n\n    var track = document.createElementNS(NS, \"path\");\n    track.setAttribute(\"d\", arc(38, A_START, A_END));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"#000\");\n    track.setAttribute(\"stroke-width\", \"7\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    track.setAttribute(\"opacity\", \"0.55\");\n    svg.appendChild(track);\n\n    var fill = document.createElementNS(NS, \"path\");\n    fill.setAttribute(\"fill\", \"none\");\n    fill.setAttribute(\"stroke\", \"url(#g\" + p.index + \")\");\n    fill.setAttribute(\"stroke-width\", \"7\");\n    fill.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(fill);\n\n    var defs = document.createElementNS(NS, \"defs\");\n    var grad = document.createElementNS(NS, \"linearGradient\");\n    grad.setAttribute(\"id\", \"g\" + p.index);\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"1\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"0\");\n    var st1 = document.createElementNS(NS, \"stop\");\n    st1.setAttribute(\"offset\", \"0%\"); st1.setAttribute(\"stop-color\", ACCENT2);\n    var st2 = document.createElementNS(NS, \"stop\");\n    st2.setAttribute(\"offset\", \"100%\"); st2.setAttribute(\"stop-color\", ACCENT);\n    grad.appendChild(st1); grad.appendChild(st2);\n    defs.appendChild(grad);\n    svg.appendChild(defs);\n\n    // body\n    var body = document.createElementNS(NS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"#1c1713\");\n    body.setAttribute(\"stroke\", \"#0a0706\");\n    body.setAttribute(\"stroke-width\", \"2\");\n    svg.appendChild(body);\n\n    var bevel = document.createElementNS(NS, \"circle\");\n    bevel.setAttribute(\"cx\", \"50\"); bevel.setAttribute(\"cy\", \"47\"); bevel.setAttribute(\"r\", \"24\");\n    bevel.setAttribute(\"fill\", \"none\");\n    bevel.setAttribute(\"stroke\", \"rgba(255,225,180,0.18)\");\n    bevel.setAttribute(\"stroke-width\", \"1.5\");\n    svg.appendChild(bevel);\n\n    var pointer = document.createElementNS(NS, \"line\");\n    pointer.setAttribute(\"x1\", \"50\"); pointer.setAttribute(\"y1\", \"50\");\n    pointer.setAttribute(\"stroke\", ACCENT);\n    pointer.setAttribute(\"stroke-width\", \"3\");\n    pointer.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(pointer);\n\n    knob.appendChild(svg);\n    cell.appendChild(knob);\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"lbl\";\n    lbl.textContent = p.name;\n    cell.appendChild(lbl);\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n    cell.appendChild(val);\n\n    function norm() { return (values[p.index] - p.min) / (p.max - p.min); }\n\n    function paint() {\n      var t = norm();\n      var a = A_START + t * (A_END - A_START);\n      fill.setAttribute(\"d\", arc(38, A_START, a + 0.0001));\n      var px = 50 + 30 * Math.cos(a), py = 50 + 30 * Math.sin(a);\n      pointer.setAttribute(\"x2\", px);\n      pointer.setAttribute(\"y2\", py);\n      val.textContent = p.fmt(values[p.index], p);\n      var glow = 0.3 + t * 0.7;\n      pointer.setAttribute(\"stroke\", ACCENT);\n      pointer.style.filter = \"drop-shadow(0 0 \" + (2 + t * 4) + \"px rgba(224,176,112,\" + glow + \"))\";\n    }\n\n    function setNorm(t) {\n      t = Math.max(0, Math.min(1, t));\n      values[p.index] = p.min + t * (p.max - p.min);\n      setParam(p.index, values[p.index]);\n      paint();\n      if (p.index === 6) syncRibbon();\n    }\n\n    var dragging = false, lastY = 0;\n    knob.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; lastY = e.clientY;\n      knob.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    knob.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.clientY;\n      lastY = e.clientY;\n      var speed = e.shiftKey ? 0.0008 : 0.004;\n      setNorm(norm() + dy * speed);\n    });\n    function endDrag(e) {\n      dragging = false;\n      try { knob.releasePointerCapture(e.pointerId); } catch (_) {}\n    }\n    knob.addEventListener(\"pointerup\", endDrag);\n    knob.addEventListener(\"pointercancel\", endDrag);\n    knob.addEventListener(\"dblclick\", function () {\n      values[p.index] = p.def;\n      setParam(p.index, p.def);\n      paint();\n      if (p.index === 6) syncRibbon();\n    });\n    knob.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      setNorm(norm() + (e.deltaY < 0 ? 0.03 : -0.03));\n    }, { passive: false });\n\n    p._paint = paint;\n    return cell;\n  }\n\n  // ---- build knobs --------------------------------------------------\n  var controls = document.getElementById(\"controls\");\n  PARAMS.forEach(function (p) { controls.appendChild(makeKnob(p)); });\n\n  // ---- ribbon controller (mirrors Brightness, index 6) --------------\n  var ribbon = document.getElementById(\"ribbon\");\n  var ribbonGlow = document.getElementById(\"ribbonGlow\");\n  var BRIGHT = PARAMS[6];\n\n  function syncRibbon() {\n    var t = values[6];\n    ribbonGlow.style.left = (8 + t * 84) + \"%\";\n  }\n  function ribbonSet(clientX) {\n    var r = ribbon.getBoundingClientRect();\n    var t = (clientX - r.left) / r.width;\n    t = Math.max(0, Math.min(1, t));\n    values[6] = t;\n    setParam(6, t);\n    BRIGHT._paint();\n    syncRibbon();\n  }\n  var ribDrag = false;\n  ribbon.addEventListener(\"pointerdown\", function (e) {\n    ribDrag = true;\n    ribbon.classList.add(\"touched\");\n    ribbon.setPointerCapture(e.pointerId);\n    ribbonSet(e.clientX);\n  });\n  ribbon.addEventListener(\"pointermove\", function (e) {\n    if (ribDrag) ribbonSet(e.clientX);\n  });\n  function ribEnd(e) {\n    ribDrag = false;\n    ribbon.classList.remove(\"touched\");\n    try { ribbon.releasePointerCapture(e.pointerId); } catch (_) {}\n  }\n  ribbon.addEventListener(\"pointerup\", ribEnd);\n  ribbon.addEventListener(\"pointercancel\", ribEnd);\n\n  // ---- keyboard -----------------------------------------------------\n  var keysEl = document.getElementById(\"keys\");\n  var START_NOTE = 48; // C3\n  var WHITE_COUNT = 17;\n  var WHITE_SEMI = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK_AFTER = [0, 1, 3, 4, 5]; // white indices that have a black to their right\n  var whiteNotes = [];\n\n  for (var i = 0; i < WHITE_COUNT; i++) {\n    var oct = Math.floor(i / 7);\n    var deg = i % 7;\n    var note = START_NOTE + oct * 12 + WHITE_SEMI[deg];\n    whiteNotes.push(note);\n    var k = document.createElement(\"div\");\n    k.className = \"key\";\n    k.dataset.note = note;\n    keysEl.appendChild(k);\n  }\n\n  // black keys positioned absolutely over the whites\n  function placeBlacks() {\n    var existing = keysEl.querySelectorAll(\".key.black\");\n    existing.forEach(function (e) { e.remove(); });\n    var rect = keysEl.getBoundingClientRect();\n    var pad = 7;\n    var usable = rect.width - pad * 2;\n    var wWidth = usable / WHITE_COUNT;\n    for (var w = 0; w < WHITE_COUNT - 1; w++) {\n      var deg = w % 7;\n      if (BLACK_AFTER.indexOf(deg) === -1) continue;\n      var oct = Math.floor(w / 7);\n      var degSemi = WHITE_SEMI[deg];\n      var blackNote = START_NOTE + oct * 12 + degSemi + 1;\n      var bk = document.createElement(\"div\");\n      bk.className = \"key black\";\n      bk.dataset.note = blackNote;\n      var center = pad + (w + 1) * wWidth;\n      bk.style.left = \"calc(\" + (center / rect.width * 100) + \"% - 2.7%)\";\n      keysEl.appendChild(bk);\n    }\n  }\n\n  var activeNotes = {};\n  function pressNote(note, el) {\n    if (activeNotes[note]) return;\n    activeNotes[note] = el;\n    el.classList.add(\"down\");\n    hostNoteOn(note, 0.9);\n    burst(note);\n  }\n  function releaseNote(note) {\n    var el = activeNotes[note];\n    if (!el) return;\n    el.classList.remove(\"down\");\n    hostNoteOff(note);\n    delete activeNotes[note];\n  }\n\n  function noteFromEvent(e) {\n    var t = document.elementFromPoint(e.clientX, e.clientY);\n    if (t && t.dataset && t.dataset.note) return { note: +t.dataset.note, el: t };\n    return null;\n  }\n\n  var mouseDown = false;\n  keysEl.addEventListener(\"pointerdown\", function (e) {\n    mouseDown = true;\n    var hit = noteFromEvent(e);\n    if (hit) pressNote(hit.note, hit.el);\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"pointermove\", function (e) {\n    if (!mouseDown) return;\n    var hit = noteFromEvent(e);\n    if (hit && !activeNotes[hit.note]) {\n      // mono-glide while dragging: release others\n      for (var n in activeNotes) releaseNote(+n);\n      pressNote(hit.note, hit.el);\n    }\n  });\n  function releaseAll() {\n    mouseDown = false;\n    for (var n in activeNotes) releaseNote(+n);\n  }\n  window.addEventListener(\"pointerup\", releaseAll);\n  window.addEventListener(\"pointercancel\", releaseAll);\n\n  // computer-keyboard play (a row maps to white keys)\n  var KEYMAP = \"awsedftgyhujkolp;\";\n  var keyDownSet = {};\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var idx = KEYMAP.indexOf(e.key.toLowerCase());\n    if (idx < 0 || idx >= whiteNotes.length) return;\n    var note = whiteNotes[idx];\n    var el = keysEl.querySelector('.key[data-note=\"' + note + '\"]');\n    if (el) { keyDownSet[e.key.toLowerCase()] = note; pressNote(note, el); }\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var note = keyDownSet[e.key.toLowerCase()];\n    if (note != null) { releaseNote(note); delete keyDownSet[e.key.toLowerCase()]; }\n  });\n\n  // ---- voice lamps --------------------------------------------------\n  var lampsEl = document.getElementById(\"lamps\");\n  var lamps = [];\n  for (var L = 0; L < 8; L++) {\n    var lp = document.createElement(\"div\");\n    lp.className = \"lamp\";\n    lampsEl.appendChild(lp);\n    lamps.push(lp);\n  }\n  function updateLamps() {\n    var count = Object.keys(activeNotes).length;\n    for (var i = 0; i < 8; i++) {\n      lamps[i].classList.toggle(\"on\", i < count);\n    }\n  }\n\n  // ---- animated dual-layer scope ------------------------------------\n  var canvas = document.getElementById(\"scope\");\n  var ctx = canvas.getContext(\"2d\");\n  var bursts = [];\n  function burst(note) {\n    bursts.push({ x: ((note - START_NOTE) % 24) / 24, life: 1 });\n    updateLamps();\n  }\n  // remove finished notes from lamp count\n  var _origRelease = releaseNote;\n  releaseNote = function (note) { _origRelease(note); updateLamps(); };\n\n  function resizeCanvas() {\n    var r = canvas.getBoundingClientRect();\n    var dpr = window.devicePixelRatio || 1;\n    canvas.width = r.width * dpr;\n    canvas.height = r.height * dpr;\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n    placeBlacks();\n  }\n  window.addEventListener(\"resize\", resizeCanvas);\n\n  var t0 = performance.now();\n  function frame(now) {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    var r = canvas.getBoundingClientRect();\n    var W = r.width, H = r.height;\n    ctx.clearRect(0, 0, W, H);\n\n    var active = Object.keys(activeNotes).length;\n    var energy = Math.min(1, active / 4);\n    var bright = values[6];\n    var t = (now - t0) / 1000;\n\n    // two amber sine layers — brighter/faster with brightness + voices\n    for (var layer = 0; layer < 2; layer++) {\n      var amp = (layer === 0 ? 0.34 : 0.2) * (0.25 + energy * 0.9);\n      var fr = (layer === 0 ? 2.0 : 3.0 + bright * 3.0);\n      var speed = (layer === 0 ? 1.4 : 2.2);\n      var alpha = layer === 0 ? 0.85 : 0.5 + bright * 0.4;\n      ctx.beginPath();\n      for (var x = 0; x <= W; x += 3) {\n        var ph = (x / W) * Math.PI * 2 * fr + t * speed;\n        var env = 0.5 + 0.5 * Math.sin((x / W) * Math.PI);\n        var y = H / 2 + Math.sin(ph) * H * amp * env;\n        if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n      }\n      ctx.strokeStyle = layer === 0 ? ACCENT : ACCENT2;\n      ctx.globalAlpha = alpha;\n      ctx.lineWidth = layer === 0 ? 2 : 1.4;\n      ctx.shadowColor = ACCENT;\n      ctx.shadowBlur = 6 + bright * 10;\n      ctx.stroke();\n    }\n    ctx.globalAlpha = 1;\n    ctx.shadowBlur = 0;\n\n    // note bursts (vertical light columns fading out)\n    for (var b = bursts.length - 1; b >= 0; b--) {\n      var bb = bursts[b];\n      bb.life -= 0.04;\n      if (bb.life <= 0) { bursts.splice(b, 1); continue; }\n      var bx = bb.x * W;\n      var grad = ctx.createLinearGradient(bx, 0, bx, H);\n      grad.addColorStop(0, \"rgba(224,176,112,0)\");\n      grad.addColorStop(0.5, \"rgba(224,176,112,\" + (bb.life * 0.5) + \")\");\n      grad.addColorStop(1, \"rgba(224,176,112,0)\");\n      ctx.fillStyle = grad;\n      ctx.fillRect(bx - 8, 0, 16, H);\n    }\n\n    requestAnimationFrame(frame);\n  }\n\n  // ---- init ---------------------------------------------------------\n  function ready() {\n    PARAMS.forEach(function (p) {\n      setParam(p.index, values[p.index]);\n      p._paint();\n    });\n    syncRibbon();\n    resizeCanvas();\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CINEMATIC POLY — a lush, grand, brass-leaning polyphonic synthesizer.\n//  An original instrument inspired by the great wood-cheeked cinematic\n//  polysynths: up to EIGHT voices keyed by noteId, each voice running TWO\n//  independent layers. Every layer pairs a band-limited saw with a pulse\n//  oscillator (slightly detuned against each other and against the other\n//  layer) and feeds them through its OWN resonant low-pass filter that is\n//  swept by a per-layer filter ADSR (Cutoff + FilterEnvAmt). An amplitude\n//  ADSR shapes each voice, the two layers are octave/detune-stacked for a\n//  thick choral body, and the summed mix passes through a gentle global\n//  ensemble chorus plus a brightness tilt for the cinematic brass sheen.\n//  Pure algorithm — no samples, no host imports, allocation-free process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\nconst NUM_LAYERS: i32 = 2;\nconst NUM_SLOTS: i32 = 16;   // NUM_VOICES * NUM_LAYERS — one filter set per layer\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_DETUNE:  i32 = 0;  // 0..1  -> layer + osc detune spread\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount (octaves)\nconst P_ATTACK:  i32 = 4;  // 0..1  -> amp + filter attack time\nconst P_RELEASE: i32 = 5;  // 0..1  -> amp + filter release time\nconst P_BRIGHT:  i32 = 6;  // 0..1  -> global high-frequency tilt / sheen\nconst P_LEVEL:   i32 = 7;  // 0..1  -> master output level\n\n// ---- per-VOICE state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// amplitude envelope (one per voice)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 sus 4 rel\n// filter envelope (one per voice, shared by its two layers)\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// ---- per-LAYER state (NUM_SLOTS = voice*NUM_LAYERS + layer) ---------\nconst lPhaseA: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS); // saw phase\nconst lPhaseB: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS); // pulse phase\n// resonant 4-pole ladder low-pass per layer (4 one-pole states)\nconst lF0: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS);\nconst lF1: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS);\nconst lF2: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS);\nconst lF3: StaticArray<f32> = new StaticArray<f32>(NUM_SLOTS);\n\nlet ageCounter: i32 = 0;\n\n// ---- global ensemble chorus state (3 modulated delay taps) ----------\nconst CHORUS_LEN: i32 = 2048;\nconst chorusL: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nconst chorusR: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nlet chorusW: i32 = 0;\nlet lfo1: f32 = 0.0;\nlet lfo2: f32 = 0.0;\nlet lfo3: f32 = 0.0;\n\n// global brightness tilt one-pole (per channel) for the post sheen\nlet tiltL: f32 = 0.0;\nlet tiltR: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n  }\n  for (let s = 0; s < NUM_SLOTS; s++) {\n    lPhaseA[s] = 0.0; lPhaseB[s] = 0.0;\n    lF0[s] = 0.0; lF1[s] = 0.0; lF2[s] = 0.0; lF3[s] = 0.0;\n  }\n  for (let i = 0; i < CHORUS_LEN; i++) { chorusL[i] = 0.0; chorusR[i] = 0.0; }\n  chorusW = 0; lfo1 = 0.0; lfo2 = 0.0; lfo3 = 0.0;\n  tiltL = 0.0; tiltR = 0.0;\n  ageCounter = 0;\n\n  params[P_DETUNE] = 0.35;\n  params[P_CUTOFF] = 0.5;\n  params[P_RESO]   = 0.3;\n  params[P_ENVAMT] = 0.55;\n  params[P_ATTACK] = 0.18;\n  params[P_RELEASE]= 0.4;\n  params[P_BRIGHT] = 0.55;\n  params[P_LEVEL]  = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n\n  // reset both layers' oscillators with offset phases so detune beats start\n  // coherently but the stack is never phase-locked\n  const base: i32 = slot * NUM_LAYERS;\n  lPhaseA[base + 0] = 0.0;  lPhaseB[base + 0] = 0.25;\n  lPhaseA[base + 1] = 0.5;  lPhaseB[base + 1] = 0.75;\n  for (let k = 0; k < NUM_LAYERS; k++) {\n    const s: i32 = base + k;\n    lF0[s] = 0.0; lF1[s] = 0.0; lF2[s] = 0.0; lF3[s] = 0.0;\n  }\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const detune: f32  = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const brightN: f32 = clampf(params[P_BRIGHT], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // cinematic vibe: long, expressive attacks/releases by default; sustain is full\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 2.2;\n  const relS: f32 = 0.02  + clampf(params[P_RELEASE], 0.0, 1.0) * 3.5;\n  const decS: f32 = 0.6;            // gentle internal decay to sustain\n  const susL: f32 = 0.85;           // near-full sustain for a lush pad\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune spread (semitone fractions). One layer sits slightly sharp, one\n  // slightly flat, and inside each layer the two oscillators spread further.\n  const layerSemi: f32 = detune * 0.12;                 // between the two layers\n  const oscSemi: f32   = detune * 0.22;                 // saw vs pulse within a layer\n  const layerUp: f32   = f32(Mathf.pow(2.0,  layerSemi / 12.0));\n  const layerDn: f32   = f32(Mathf.pow(2.0, -layerSemi / 12.0));\n  const oscUp: f32     = f32(Mathf.pow(2.0,  oscSemi / 12.0));\n  const oscDn: f32     = f32(Mathf.pow(2.0, -oscSemi / 12.0));\n\n  // base cutoff in Hz, exponential 80 Hz .. ~14 kHz; brightness lifts it too\n  const baseHz: f32 = 80.0 * f32(Mathf.pow(180.0, cutoffN)) * (0.7 + brightN * 0.8);\n  const envOct: f32 = envAmt * 6.0;                     // env sweep range in octaves\n  const reso: f32   = resoN * 3.8;                      // ladder feedback\n\n  // headroom: 8 voices * 2 layers summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.34;\n\n  // global ensemble chorus rates (slow, multi-phase) — depth tracks brightness\n  const lfoInc1: f32 = TWO_PI * 0.18 / sr;\n  const lfoInc2: f32 = TWO_PI * 0.27 / sr;\n  const lfoInc3: f32 = TWO_PI * 0.41 / sr;\n  const chDepth: f32 = 7.0 + brightN * 6.0;             // samples of delay sweep\n  const chCenter: f32 = 20.0;\n\n  // post brightness tilt: a one-pole high-shelf-ish blend. brightN raises the\n  // proportion of the high (residual) band added back in.\n  const tiltCoef: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 2600.0 / sr));\n  const tiltAmt: f32  = -0.5 + brightN * 1.4;           // -0.5 (dark) .. +0.9 (bright)\n\n  for (let f = 0; f < n; f++) {\n    let mixL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude ADSR ---------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {\n        aenv -= decRate * (1.0 - susL);\n        if (aenv <= susL) { aenv = susL; astg = 3; }\n      } else if (astg == 3) {\n        aenv = susL;\n      } else if (astg == 4) {\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter ADSR (shared by both layers) ------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * (1.0 - susL);\n        if (fenv <= susL) { fenv = susL; fstg = 3; }\n      } else if (fstg == 3) {\n        fenv = susL;\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      const baseInc: f32 = vFreq[v] / sr;\n      const ampV: f32 = aenv * vVel[v];\n\n      // layer cutoff (Hz) from base + filter envelope, clamped\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 30.0) fc = 30.0;\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      const base: i32 = v * NUM_LAYERS;\n\n      // ---- LAYER 0 (lower, fundamental) -------------------------\n      {\n        const s: i32 = base + 0;\n        const incA: f32 = baseInc * layerDn * oscDn;     // saw\n        const incB: f32 = baseInc * layerDn * oscUp;     // pulse\n\n        let pa: f32 = lPhaseA[s];\n        pa += incA; if (pa >= 1.0) pa -= 1.0;\n        let saw: f32 = 2.0 * pa - 1.0;\n        saw -= polyBlep(pa, incA);\n        lPhaseA[s] = pa;\n\n        let pb: f32 = lPhaseB[s];\n        pb += incB; if (pb >= 1.0) pb -= 1.0;\n        const pw: f32 = 0.5;\n        let sq: f32 = pb < pw ? 1.0 : -1.0;\n        sq += polyBlep(pb, incB);\n        let pb2: f32 = pb + (1.0 - pw); if (pb2 >= 1.0) pb2 -= 1.0;\n        sq -= polyBlep(pb2, incB);\n        lPhaseB[s] = pb;\n\n        let osc: f32 = saw * 0.6 + sq * 0.42;\n\n        let s0: f32 = lF0[s];\n        let s1: f32 = lF1[s];\n        let s2: f32 = lF2[s];\n        let s3: f32 = lF3[s];\n        let inp: f32 = osc - reso * s3;\n        inp = f32(Mathf.tanh(inp));\n        s0 += g * (inp - s0);\n        s1 += g * (s0 - s1);\n        s2 += g * (s1 - s2);\n        s3 += g * (s2 - s3);\n        lF0[s] = s0; lF1[s] = s1; lF2[s] = s2; lF3[s] = s3;\n\n        mixL += s3 * ampV;\n      }\n\n      // ---- LAYER 1 (upper, brighter octave-ish stack) -----------\n      {\n        const s: i32 = base + 1;\n        // upper layer rides a touch sharp and a hair higher in register\n        const incA: f32 = baseInc * layerUp * oscUp;     // saw\n        const incB: f32 = baseInc * layerUp * oscDn;     // pulse\n\n        let pa: f32 = lPhaseA[s];\n        pa += incA; if (pa >= 1.0) pa -= 1.0;\n        let saw: f32 = 2.0 * pa - 1.0;\n        saw -= polyBlep(pa, incA);\n        lPhaseA[s] = pa;\n\n        let pb: f32 = lPhaseB[s];\n        pb += incB; if (pb >= 1.0) pb -= 1.0;\n        const pw: f32 = 0.4;                              // narrower pulse = reedier\n        let sq: f32 = pb < pw ? 1.0 : -1.0;\n        sq += polyBlep(pb, incB);\n        let pb2: f32 = pb + (1.0 - pw); if (pb2 >= 1.0) pb2 -= 1.0;\n        sq -= polyBlep(pb2, incB);\n        lPhaseB[s] = pb;\n\n        let osc: f32 = saw * 0.5 + sq * 0.4;\n\n        // upper layer opens a little brighter for the brass sheen\n        let g2: f32 = g * (1.0 + brightN * 0.6);\n        if (g2 > 0.99) g2 = 0.99;\n\n        let s0: f32 = lF0[s];\n        let s1: f32 = lF1[s];\n        let s2: f32 = lF2[s];\n        let s3: f32 = lF3[s];\n        let inp: f32 = osc - reso * s3;\n        inp = f32(Mathf.tanh(inp));\n        s0 += g2 * (inp - s0);\n        s1 += g2 * (s0 - s1);\n        s2 += g2 * (s1 - s2);\n        s3 += g2 * (s2 - s3);\n        lF0[s] = s0; lF1[s] = s1; lF2[s] = s2; lF3[s] = s3;\n\n        mixL += s3 * ampV * 0.85;\n      }\n    }\n\n    // ---- voice sum + analog glue -------------------------------\n    let dry: f32 = mixL * voiceScale;\n    dry = f32(Mathf.tanh(dry * 1.1));\n\n    // ---- post brightness tilt (residual high band) -------------\n    tiltL += tiltCoef * (dry - tiltL);\n    const high: f32 = dry - tiltL;                // high-frequency residual\n    let toned: f32 = dry + high * tiltAmt;\n\n    // ---- global ensemble chorus (stereo) -----------------------\n    lfo1 += lfoInc1; if (lfo1 > TWO_PI) lfo1 -= TWO_PI;\n    lfo2 += lfoInc2; if (lfo2 > TWO_PI) lfo2 -= TWO_PI;\n    lfo3 += lfoInc3; if (lfo3 > TWO_PI) lfo3 -= TWO_PI;\n\n    // write current sample into the ring buffers\n    chorusL[chorusW] = toned;\n    chorusR[chorusW] = toned;\n\n    const d1: f32 = chCenter + chDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo1)));\n    const d2: f32 = chCenter + chDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo2)));\n    const d3: f32 = chCenter + chDepth * (0.5 + 0.5 * f32(Mathf.sin(lfo3)));\n\n    const wetL: f32 = readDelay(chorusL, d1) * 0.6 + readDelay(chorusL, d3) * 0.4;\n    const wetR: f32 = readDelay(chorusR, d2) * 0.6 + readDelay(chorusR, d3) * 0.4;\n\n    chorusW++; if (chorusW >= CHORUS_LEN) chorusW = 0;\n\n    // gentle ensemble blend — always present, a touch wider with brightness\n    const chMix: f32 = 0.4 + brightN * 0.15;\n    let outL: f32 = toned * (1.0 - chMix * 0.5) + wetL * chMix;\n    let outR: f32 = toned * (1.0 - chMix * 0.5) + wetR * chMix;\n\n    // ---- master level + safety clip ----------------------------\n    const gain: f32 = level * 1.05;\n    outL = f32(Mathf.tanh(outL * gain));\n    outR = f32(Mathf.tanh(outR * gain));\n\n    outBuf[f] = outL;\n    outBuf[MAX_FRAMES + f] = outR;\n  }\n}\n\n// read a fractional delay from a chorus ring buffer (linear interp)\n@inline function readDelay(buf: StaticArray<f32>, delay: f32): f32 {\n  let d: f32 = delay;\n  if (d < 1.0) d = 1.0;\n  if (d > f32(CHORUS_LEN - 2)) d = f32(CHORUS_LEN - 2);\n  let rp: f32 = f32(chorusW) - d;\n  while (rp < 0.0) rp += f32(CHORUS_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= CHORUS_LEN) i1 -= CHORUS_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = buf[i0];\n  const b: f32 = buf[i1];\n  return f32(a + (b - a) * frac);\n}\n",
  "publishedAt": 1751000064000
}