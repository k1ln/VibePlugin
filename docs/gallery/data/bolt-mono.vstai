{
  "format": 1,
  "name": "Bolt Mono",
  "isInstrument": true,
  "explanation": "A lean, punchy two-oscillator hard-sync mono synth in the compact American two-VCO lead/bass tradition. OSC-1 is a saw master; OSC-2 is a detuned pulse that hard-syncs to the master, resetting its phase every master cycle for the signature zappy, metallic sync edge. Both feed a punchy Moog-style 4-pole resonant ladder low-pass driven by a fast decay envelope, with quick glide and a snappy amp envelope. Sync adds the aggressive edge, Cutoff and Resonance snap, Detune fattens slightly, and the whole voice stays tight, fast and immediate — a small, aggressive lead/bass machine. Pure algorithm, no samples; pitch tracks each played note in Hz.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Sync",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Bolt Mono</title>\n<style>\n  :root {\n    --accent: #ffd23d;\n    --accent2: #ff4d4d;\n    --bg0: #0a0a0c;\n    --bg1: #141417;\n    --panel: #18181b;\n    --panel2: #202024;\n    --line: #2c2c31;\n    --ink: #f4f1e8;\n    --dim: #8b8b92;\n    --font: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background:\n      radial-gradient(120% 90% at 50% -10%, #1a1a1f 0%, var(--bg0) 60%);\n    color: var(--ink);\n    font-family: var(--font);\n    -webkit-font-smoothing: antialiased;\n    min-height: 100%;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 16px;\n  }\n\n  .unit {\n    width: 100%;\n    max-width: 640px;\n    background:\n      linear-gradient(180deg, var(--panel2) 0%, var(--panel) 14%, var(--bg1) 100%);\n    border: 1px solid var(--line);\n    border-radius: 16px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.05) inset,\n      0 30px 60px -24px rgba(0,0,0,0.85);\n    overflow: hidden;\n    position: relative;\n  }\n\n  /* hazard stripe accents top + bottom */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    top: 0; left: 0; right: 0;\n    height: 4px;\n    background: repeating-linear-gradient(\n      -45deg,\n      var(--accent) 0 14px,\n      #0a0a0c 14px 22px);\n    opacity: 0.9;\n  }\n\n  /* ---------------- header ---------------- */\n  .head {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    padding: 22px 22px 14px;\n    border-bottom: 1px solid var(--line);\n  }\n\n  .badge {\n    width: 46px; height: 46px;\n    flex: 0 0 auto;\n    border-radius: 11px;\n    background:\n      radial-gradient(circle at 32% 28%, #2a2a2f, #111114);\n    border: 1px solid #34343a;\n    display: grid; place-items: center;\n    box-shadow: 0 0 18px -4px rgba(255,210,61,0.5);\n    position: relative;\n  }\n\n  .bolt {\n    width: 22px; height: 28px;\n    filter: drop-shadow(0 0 6px rgba(255,210,61,0.85));\n    animation: flicker 3.4s ease-in-out infinite;\n  }\n\n  @keyframes flicker {\n    0%, 92%, 100% { opacity: 1; filter: drop-shadow(0 0 6px rgba(255,210,61,0.85)); }\n    93% { opacity: 0.35; }\n    95% { opacity: 1; filter: drop-shadow(0 0 14px rgba(255,77,77,0.95)); }\n    97% { opacity: 0.5; }\n  }\n\n  .titles { display: flex; flex-direction: column; line-height: 1.05; }\n  .titles h1 {\n    font-size: 26px;\n    font-weight: 800;\n    letter-spacing: 0.5px;\n    background: linear-gradient(90deg, var(--accent), #fff6d6 60%, var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles .sub {\n    margin-top: 3px;\n    font-size: 9.5px;\n    letter-spacing: 3.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n    font-weight: 600;\n  }\n\n  .powerdot {\n    margin-left: auto;\n    display: flex; align-items: center; gap: 8px;\n    font-size: 9px; letter-spacing: 2px; color: var(--dim);\n    text-transform: uppercase;\n  }\n  .powerdot i {\n    width: 9px; height: 9px; border-radius: 50%;\n    background: var(--accent2);\n    box-shadow: 0 0 10px var(--accent2);\n    animation: pulse 1.6s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50% { opacity: 0.45; transform: scale(0.82); }\n  }\n\n  /* ---------------- scope ---------------- */\n  .scopewrap {\n    margin: 16px 22px 6px;\n    border-radius: 12px;\n    border: 1px solid var(--line);\n    background:\n      linear-gradient(180deg, #050506, #0c0c0e);\n    box-shadow: inset 0 0 30px -8px rgba(0,0,0,0.9);\n    overflow: hidden;\n    position: relative;\n  }\n  .scopewrap::after {\n    content: \"\";\n    position: absolute; inset: 0;\n    background: repeating-linear-gradient(\n      0deg, transparent 0 3px, rgba(255,255,255,0.018) 3px 4px);\n    pointer-events: none;\n  }\n  #scope { display: block; width: 100%; height: 120px; }\n\n  .scopelabel {\n    position: absolute;\n    top: 8px; left: 12px;\n    font-size: 8.5px; letter-spacing: 2.5px;\n    color: var(--dim); text-transform: uppercase;\n  }\n\n  /* ---------------- body grid ---------------- */\n  .body {\n    display: grid;\n    grid-template-columns: 1.05fr 1fr;\n    gap: 14px;\n    padding: 14px 22px 20px;\n  }\n\n  .section {\n    background:\n      linear-gradient(180deg, #1b1b1f, #141417);\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 14px 16px 16px;\n  }\n  .section h2 {\n    font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--accent);\n    margin-bottom: 14px;\n    display: flex; align-items: center; gap: 7px;\n  }\n  .section h2::after {\n    content: \"\"; flex: 1; height: 1px;\n    background: linear-gradient(90deg, var(--line), transparent);\n  }\n\n  /* sliders (oscillators / level) */\n  .faders { display: flex; flex-direction: column; gap: 16px; }\n\n  .fader { display: flex; align-items: center; gap: 12px; }\n  .fader .lab {\n    width: 70px; flex: 0 0 auto;\n    font-size: 10px; letter-spacing: 1px; text-transform: uppercase;\n    color: var(--dim); font-weight: 600;\n  }\n  .fader .track {\n    position: relative;\n    flex: 1; height: 26px;\n    border-radius: 7px;\n    background: #0c0c0e;\n    border: 1px solid #2a2a2f;\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.8);\n    cursor: ew-resize;\n    overflow: hidden;\n    touch-action: none;\n  }\n  .fader .fill {\n    position: absolute; left: 0; top: 0; bottom: 0;\n    width: 50%;\n    background:\n      linear-gradient(90deg, rgba(255,210,61,0.12), var(--accent));\n    box-shadow: 0 0 14px -2px var(--accent);\n    transition: filter 0.15s;\n  }\n  .fader.hot .fill { filter: brightness(1.25); }\n  .fader .cap {\n    position: absolute; top: -2px; bottom: -2px;\n    width: 8px; margin-left: -4px;\n    border-radius: 4px;\n    background: linear-gradient(180deg, #fff, #cfa400);\n    box-shadow: 0 0 10px rgba(255,210,61,0.9), 0 2px 4px rgba(0,0,0,0.6);\n  }\n  .fader .val {\n    width: 40px; flex: 0 0 auto; text-align: right;\n    font-size: 11px; font-variant-numeric: tabular-nums;\n    color: var(--ink); font-weight: 600;\n  }\n\n  /* knobs */\n  .knobs {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 12px 6px;\n    justify-items: center;\n  }\n  .knob {\n    display: flex; flex-direction: column; align-items: center; gap: 7px;\n    user-select: none;\n  }\n  .knob .dial {\n    width: 66px; height: 66px;\n    cursor: ns-resize; touch-action: none;\n  }\n  .knob .nm {\n    font-size: 9px; letter-spacing: 1.3px; text-transform: uppercase;\n    color: var(--dim); font-weight: 600;\n  }\n  .knob .kv {\n    font-size: 10.5px; font-variant-numeric: tabular-nums;\n    color: var(--accent); font-weight: 700;\n  }\n\n  /* big filter knob feature */\n  .filter { grid-column: 1 / -1; }\n  .filter .bigknob {\n    display: flex; flex-direction: column; align-items: center; gap: 8px;\n  }\n  .filter .dial { width: 96px; height: 96px; }\n  .filter .nm { font-size: 9.5px; letter-spacing: 2px; color: var(--accent2); }\n\n  /* ---------------- keyboard ---------------- */\n  .kbwrap {\n    padding: 0 22px 22px;\n  }\n  .kbtitle {\n    font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--dim); margin-bottom: 9px; display: flex; gap: 8px; align-items: center;\n  }\n  .kbtitle::after {\n    content: \"\"; flex: 1; height: 1px; background: linear-gradient(90deg, var(--line), transparent);\n  }\n  .keys {\n    position: relative;\n    height: 96px;\n    display: flex;\n    border-radius: 9px;\n    overflow: hidden;\n    border: 1px solid #000;\n    box-shadow: 0 6px 14px -6px rgba(0,0,0,0.8);\n    touch-action: none;\n  }\n  .wkey {\n    flex: 1;\n    background: linear-gradient(180deg, #f3efe2, #cfc9ba);\n    border-right: 1px solid #b3ad9e;\n    position: relative;\n    cursor: pointer;\n  }\n  .wkey:last-child { border-right: none; }\n  .wkey.on {\n    background: linear-gradient(180deg, var(--accent), #e0b400);\n    box-shadow: inset 0 0 18px rgba(255,77,77,0.4);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 7.2%;\n    height: 60%;\n    margin-left: -3.6%;\n    background: linear-gradient(180deg, #2a2a2d, #0a0a0b);\n    border: 1px solid #000;\n    border-radius: 0 0 4px 4px;\n    z-index: 3;\n    cursor: pointer;\n    box-shadow: 0 4px 6px rgba(0,0,0,0.6);\n  }\n  .bkey.on {\n    background: linear-gradient(180deg, var(--accent2), #8a1010);\n    box-shadow: 0 0 14px rgba(255,77,77,0.7);\n  }\n\n  .foot {\n    display: flex; justify-content: space-between; align-items: center;\n    padding: 12px 22px 18px;\n    border-top: 1px solid var(--line);\n    font-size: 9px; letter-spacing: 1.5px; color: var(--dim);\n    text-transform: uppercase;\n  }\n  .foot b { color: var(--accent); font-weight: 700; }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"head\">\n      <div class=\"badge\">\n        <svg class=\"bolt\" viewBox=\"0 0 24 32\" fill=\"none\">\n          <path d=\"M14 0 L2 18 H10 L8 32 L22 12 H13 L14 0 Z\"\n                fill=\"var(--accent)\" stroke=\"var(--accent2)\" stroke-width=\"1\"/>\n        </svg>\n      </div>\n      <div class=\"titles\">\n        <h1>BOLT MONO</h1>\n        <div class=\"sub\">2&middot;OSC HARD-SYNC LEAD</div>\n      </div>\n      <div class=\"powerdot\"><i></i> live</div>\n    </div>\n\n    <div class=\"scopewrap\">\n      <span class=\"scopelabel\">SYNC SCOPE</span>\n      <canvas id=\"scope\" width=\"600\" height=\"120\"></canvas>\n    </div>\n\n    <div class=\"body\">\n      <div class=\"section\">\n        <h2>Oscillators</h2>\n        <div class=\"faders\">\n          <div class=\"fader\" data-fader id=\"f-sync\">\n            <span class=\"lab\">Sync</span>\n            <div class=\"track\"><div class=\"fill\"></div><div class=\"cap\"></div></div>\n            <span class=\"val\">0</span>\n          </div>\n          <div class=\"fader\" data-fader id=\"f-detune\">\n            <span class=\"lab\">Detune</span>\n            <div class=\"track\"><div class=\"fill\"></div><div class=\"cap\"></div></div>\n            <span class=\"val\">0</span>\n          </div>\n          <div class=\"fader\" data-fader id=\"f-level\">\n            <span class=\"lab\">Level</span>\n            <div class=\"track\"><div class=\"fill\"></div><div class=\"cap\"></div></div>\n            <span class=\"val\">0</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"section\">\n        <h2>Filter &amp; Envelope</h2>\n        <div class=\"knobs\">\n          <div class=\"filter\">\n            <div class=\"bigknob\">\n              <svg class=\"dial\" data-knob id=\"k-cutoff\" viewBox=\"0 0 100 100\"></svg>\n              <div class=\"nm\">Cutoff</div>\n              <div class=\"kv\">0</div>\n            </div>\n          </div>\n          <div class=\"knob\">\n            <svg class=\"dial\" data-knob id=\"k-reso\" viewBox=\"0 0 100 100\"></svg>\n            <div class=\"nm\">Reso</div>\n            <div class=\"kv\">0</div>\n          </div>\n          <div class=\"knob\">\n            <svg class=\"dial\" data-knob id=\"k-env\" viewBox=\"0 0 100 100\"></svg>\n            <div class=\"nm\">Env Amt</div>\n            <div class=\"kv\">0</div>\n          </div>\n          <div class=\"knob\" style=\"grid-column:1/-1;\">\n            <svg class=\"dial\" data-knob id=\"k-decay\" viewBox=\"0 0 100 100\"></svg>\n            <div class=\"nm\">Decay</div>\n            <div class=\"kv\">0</div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"kbwrap\">\n      <div class=\"kbtitle\">Keyboard</div>\n      <div class=\"keys\" id=\"keys\"></div>\n    </div>\n\n    <div class=\"foot\">\n      <span>MONO &middot; LAST-NOTE</span>\n      <span>DRAG TO ADJUST &middot; <b>DBL-CLICK</b> RESETS</span>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model -------------------------------------------------\n  // index matches assembly.ts P_* constants.\n  var PARAMS = {\n    cutoff: { index: 0, def: 0.45, val: 0.45 },\n    reso:   { index: 1, def: 0.55, val: 0.55 },\n    env:    { index: 2, def: 0.60, val: 0.60 },\n    sync:   { index: 3, def: 0.40, val: 0.40 },\n    detune: { index: 4, def: 0.25, val: 0.25 },\n    decay:  { index: 5, def: 0.40, val: 0.40 },\n    level:  { index: 6, def: 0.80, val: 0.80 }\n  };\n\n  function push(key) {\n    var p = PARAMS[key];\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(p.index, p.val);\n    }\n  }\n\n  function pct(v) { return Math.round(v * 100); }\n\n  // ---- FADERS ----------------------------------------------------------\n  function bindFader(elId, key) {\n    var el = document.getElementById(elId);\n    var track = el.querySelector(\".track\");\n    var fill = el.querySelector(\".fill\");\n    var cap = el.querySelector(\".cap\");\n    var val = el.querySelector(\".val\");\n    var p = PARAMS[key];\n\n    function render() {\n      var v = p.val;\n      fill.style.width = (v * 100) + \"%\";\n      cap.style.left = (v * 100) + \"%\";\n      val.textContent = pct(v);\n    }\n\n    function setFromX(clientX) {\n      var r = track.getBoundingClientRect();\n      var v = (clientX - r.left) / r.width;\n      v = Math.max(0, Math.min(1, v));\n      p.val = v;\n      render();\n      push(key);\n    }\n\n    var dragging = false;\n    track.addEventListener(\"pointerdown\", function (e) {\n      dragging = true;\n      el.classList.add(\"hot\");\n      track.setPointerCapture(e.pointerId);\n      setFromX(e.clientX);\n      e.preventDefault();\n    });\n    track.addEventListener(\"pointermove\", function (e) {\n      if (dragging) setFromX(e.clientX);\n    });\n    track.addEventListener(\"pointerup\", function () {\n      dragging = false;\n      el.classList.remove(\"hot\");\n    });\n    track.addEventListener(\"dblclick\", function () {\n      p.val = p.def;\n      render();\n      push(key);\n    });\n    track.addEventListener(\"wheel\", function (e) {\n      p.val = Math.max(0, Math.min(1, p.val - e.deltaY * 0.0008));\n      render();\n      push(key);\n      e.preventDefault();\n    }, { passive: false });\n\n    render();\n  }\n\n  // ---- KNOBS (SVG) -----------------------------------------------------\n  var SVGNS = \"http://www.w3.org/2000/svg\";\n  var A0 = -135, A1 = 135; // sweep range in degrees\n\n  function bindKnob(elId, key) {\n    var svg = document.getElementById(elId);\n    var p = PARAMS[key];\n    var box = svg.closest(\".knob\") || svg.closest(\".bigknob\").parentNode;\n    var readout = box.querySelector(\".kv\");\n\n    // build static + dynamic SVG\n    function mk(tag, attrs) {\n      var e = document.createElementNS(SVGNS, tag);\n      for (var k in attrs) e.setAttribute(k, attrs[k]);\n      return e;\n    }\n\n    var trackArc = mk(\"path\", {\n      d: arc(0, 1), fill: \"none\", stroke: \"#2a2a2f\",\n      \"stroke-width\": 8, \"stroke-linecap\": \"round\"\n    });\n    var valArc = mk(\"path\", {\n      d: arc(0, p.val), fill: \"none\", stroke: \"var(--accent)\",\n      \"stroke-width\": 8, \"stroke-linecap\": \"round\"\n    });\n    valArc.style.filter = \"drop-shadow(0 0 4px var(--accent))\";\n\n    var body = mk(\"circle\", {\n      cx: 50, cy: 50, r: 27,\n      fill: \"url(#g\" + elId + \")\", stroke: \"#000\", \"stroke-width\": 1\n    });\n    var grad = mk(\"radialGradient\", { id: \"g\" + elId, cx: \"35%\", cy: \"30%\", r: \"75%\" });\n    grad.appendChild(mk(\"stop\", { offset: \"0%\", \"stop-color\": \"#34343a\" }));\n    grad.appendChild(mk(\"stop\", { offset: \"100%\", \"stop-color\": \"#111114\" }));\n    var defs = mk(\"defs\", {});\n    defs.appendChild(grad);\n\n    var notch = mk(\"line\", {\n      x1: 50, y1: 50, x2: 50, y2: 27,\n      stroke: \"var(--accent)\", \"stroke-width\": 3, \"stroke-linecap\": \"round\"\n    });\n    notch.style.filter = \"drop-shadow(0 0 3px var(--accent))\";\n\n    svg.appendChild(defs);\n    svg.appendChild(trackArc);\n    svg.appendChild(valArc);\n    svg.appendChild(body);\n    svg.appendChild(notch);\n\n    function arc(a, b) {\n      var ang0 = (A0 + (A1 - A0) * a) * Math.PI / 180;\n      var ang1 = (A0 + (A1 - A0) * b) * Math.PI / 180;\n      var r = 40;\n      var x0 = 50 + r * Math.sin(ang0), y0 = 50 - r * Math.cos(ang0);\n      var x1 = 50 + r * Math.sin(ang1), y1 = 50 - r * Math.cos(ang1);\n      var large = (b - a) > 0.5 ? 1 : 0;\n      return \"M \" + x0 + \" \" + y0 + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + x1 + \" \" + y1;\n    }\n\n    function render() {\n      var v = p.val;\n      valArc.setAttribute(\"d\", arc(0, Math.max(0.0001, v)));\n      var ang = A0 + (A1 - A0) * v;\n      notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n      readout.textContent = pct(v);\n    }\n\n    var dragging = false, startY = 0, startV = 0;\n    svg.addEventListener(\"pointerdown\", function (e) {\n      dragging = true;\n      startY = e.clientY;\n      startV = p.val;\n      svg.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    svg.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dv = (startY - e.clientY) / 180;\n      p.val = Math.max(0, Math.min(1, startV + dv));\n      render();\n      push(key);\n    });\n    svg.addEventListener(\"pointerup\", function () { dragging = false; });\n    svg.addEventListener(\"dblclick\", function () {\n      p.val = p.def;\n      render();\n      push(key);\n    });\n    svg.addEventListener(\"wheel\", function (e) {\n      p.val = Math.max(0, Math.min(1, p.val - e.deltaY * 0.0008));\n      render();\n      push(key);\n      e.preventDefault();\n    }, { passive: false });\n\n    render();\n  }\n\n  // ---- KEYBOARD --------------------------------------------------------\n  var keysEl = document.getElementById(\"keys\");\n  var START = 48; // C3\n  var WHITE = [0, 2, 4, 5, 7, 9, 11, 12, 14, 16, 17, 19, 21, 23]; // two octaves\n  var BLACKMAP = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10, 7: 13, 8: 15, 10: 18, 11: 20 };\n  var whiteEls = [];\n  var heldNote = -1;\n\n  WHITE.forEach(function (semi, i) {\n    var k = document.createElement(\"div\");\n    k.className = \"wkey\";\n    k.dataset.note = START + semi;\n    keysEl.appendChild(k);\n    whiteEls.push(k);\n  });\n\n  // place black keys relative to white-key slots\n  var nWhite = WHITE.length;\n  Object.keys(BLACKMAP).forEach(function (wi) {\n    var semi = BLACKMAP[wi];\n    var b = document.createElement(\"div\");\n    b.className = \"bkey\";\n    b.dataset.note = START + semi;\n    b.style.left = ((parseInt(wi, 10) + 1) / nWhite * 100) + \"%\";\n    keysEl.appendChild(b);\n  });\n\n  function noteOn(n, el) {\n    if (heldNote === n) return;\n    if (heldNote >= 0) noteOff(heldNote);\n    heldNote = n;\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, 0.95);\n    paint(n, true);\n    triggerZap();\n  }\n  function noteOff(n) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n    paint(n, false);\n    if (heldNote === n) heldNote = -1;\n  }\n  function paint(n, on) {\n    var sel = keysEl.querySelectorAll('[data-note=\"' + n + '\"]');\n    sel.forEach(function (e) { e.classList.toggle(\"on\", on); });\n  }\n\n  var pointerDown = false;\n  keysEl.addEventListener(\"pointerdown\", function (e) {\n    var el = e.target.closest(\"[data-note]\");\n    if (!el) return;\n    pointerDown = true;\n    keysEl.setPointerCapture(e.pointerId);\n    noteOn(parseInt(el.dataset.note, 10), el);\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"pointermove\", function (e) {\n    if (!pointerDown) return;\n    var el = document.elementFromPoint(e.clientX, e.clientY);\n    el = el && el.closest ? el.closest(\"[data-note]\") : null;\n    if (el) {\n      var n = parseInt(el.dataset.note, 10);\n      if (n !== heldNote) noteOn(n, el);\n    }\n  });\n  function releaseAll() {\n    pointerDown = false;\n    if (heldNote >= 0) noteOff(heldNote);\n  }\n  keysEl.addEventListener(\"pointerup\", releaseAll);\n  keysEl.addEventListener(\"pointercancel\", releaseAll);\n  window.addEventListener(\"pointerup\", function () { if (pointerDown) releaseAll(); });\n\n  // computer keyboard (a..k as a white-key row)\n  var KEYROW = \"awsedftgyhujk\";\n  var keyDownSet = {};\n  window.addEventListener(\"keydown\", function (e) {\n    var idx = KEYROW.indexOf(e.key.toLowerCase());\n    if (idx < 0 || keyDownSet[e.key]) return;\n    keyDownSet[e.key] = true;\n    noteOn(START + idx, null);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var idx = KEYROW.indexOf(e.key.toLowerCase());\n    if (idx < 0) return;\n    keyDownSet[e.key] = false;\n    noteOff(START + idx);\n  });\n\n  // ---- SCOPE animation -------------------------------------------------\n  var cv = document.getElementById(\"scope\");\n  var ctx = cv.getContext(\"2d\");\n  var zap = 0; // decays after a note triggers the sync transient\n\n  function triggerZap() { zap = 1; }\n\n  function resize() {\n    var r = cv.getBoundingClientRect();\n    cv.width = Math.max(300, r.width * (window.devicePixelRatio || 1));\n    cv.height = 120 * (window.devicePixelRatio || 1);\n  }\n  window.addEventListener(\"resize\", resize);\n  resize();\n\n  var t = 0;\n  function frame() {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    t += 0.025;\n    zap *= 0.94;\n\n    var w = cv.width, h = cv.height, mid = h / 2;\n    ctx.clearRect(0, 0, w, h);\n\n    // faint grid\n    ctx.strokeStyle = \"rgba(255,255,255,0.04)\";\n    ctx.lineWidth = 1;\n    ctx.beginPath();\n    ctx.moveTo(0, mid); ctx.lineTo(w, mid); ctx.stroke();\n\n    var sync = PARAMS.sync.val;     // sharper edges\n    var detune = PARAMS.detune.val; // beating\n    var cutoff = PARAMS.cutoff.val; // brightness -> amplitude shimmer\n    var reso = PARAMS.reso.val;\n\n    var ratio = 1 + sync * 2.5;\n    var amp = (h * 0.36) * (0.5 + 0.5 * cutoff) * (1 + zap * 0.5);\n\n    // master saw + synced slave pulse rendered as a single zappy trace\n    ctx.lineWidth = 2 * (window.devicePixelRatio || 1);\n    var grd = ctx.createLinearGradient(0, 0, w, 0);\n    grd.addColorStop(0, \"#ffd23d\");\n    grd.addColorStop(0.5 + 0.4 * Math.sin(t), zap > 0.15 ? \"#ff4d4d\" : \"#ffe27a\");\n    grd.addColorStop(1, \"#ff4d4d\");\n    ctx.strokeStyle = grd;\n    ctx.shadowColor = zap > 0.15 ? \"rgba(255,77,77,0.8)\" : \"rgba(255,210,61,0.5)\";\n    ctx.shadowBlur = (6 + zap * 18) * (window.devicePixelRatio || 1);\n\n    ctx.beginPath();\n    var cycles = 3;\n    for (var x = 0; x <= w; x++) {\n      var ph = (x / w) * cycles;            // master phase, 3 cycles\n      var mfrac = ph - Math.floor(ph);      // 0..1 master saw\n      var saw = mfrac * 2 - 1;\n      // slave phase resets every master cycle (HARD SYNC)\n      var sfrac = (mfrac * ratio) % 1;\n      var pulse = sfrac < (0.35 + 0.1 * detune) ? 1 : -1;\n      // detune adds a slow drift to the slave\n      var drift = Math.sin(t * (1 + detune * 4) + ph * 6) * detune * 0.25;\n      var y = (saw * 0.6 + pulse * (0.3 + 0.3 * sync) + drift);\n      // resonant ring near edges\n      y += Math.sin(sfrac * Math.PI * 2) * reso * 0.18 * (1 + zap);\n      var py = mid - y * amp;\n      if (x === 0) ctx.moveTo(x, py); else ctx.lineTo(x, py);\n    }\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- INIT ------------------------------------------------------------\n  function boot() {\n    bindFader(\"f-sync\", \"sync\");\n    bindFader(\"f-detune\", \"detune\");\n    bindFader(\"f-level\", \"level\");\n    bindKnob(\"k-cutoff\", \"cutoff\");\n    bindKnob(\"k-reso\", \"reso\");\n    bindKnob(\"k-env\", \"env\");\n    bindKnob(\"k-decay\", \"decay\");\n    // initialise engine to defaults\n    for (var key in PARAMS) push(key);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BOLT MONO — a lean, punchy two-oscillator hard-sync mono synth.\n//  Lineage: the compact American two-VCO mono lead/bass (Moog Prodigy\n//  family) — tight, snappy and immediate rather than a fat triple-osc\n//  beast. OSC-1 (saw) is the master; OSC-2 (pulse) detunes and HARD-SYNCS\n//  to OSC-1 so its phase resets on every master cycle, giving the zappy,\n//  metallic sync edge. Both oscillators feed a punchy Moog-style 4-pole\n//  resonant ladder low-pass driven by a fast decay envelope (Env Amount),\n//  with glide and an amp envelope. Pure algorithm, no samples.\n//\n//  Signal path:\n//    OSC1 saw (master) + OSC2 pulse (synced, detuned) -> mix/drive\n//      -> 4-pole resonant ladder LPF (cutoff = base + EnvAmount*fenv)\n//      -> amp env -> soft clip -> Level\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32 = 3.14159265358979;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF:  i32 = 0; // base cutoff 0..1\nconst P_RESO:    i32 = 1; // resonance 0..1\nconst P_ENVAMT:  i32 = 2; // filter envelope amount 0..1\nconst P_SYNC:    i32 = 3; // hard-sync edge / OSC2 pitch ratio 0..1\nconst P_DETUNE:  i32 = 4; // OSC2 fine detune 0..1\nconst P_DECAY:   i32 = 5; // filter + amp decay 0..1\nconst P_LEVEL:   i32 = 6; // output level 0..1\n\n// ---- voice state ----\nlet ph1: f32 = 0.0;        // OSC1 (master, saw) phase 0..1\nlet ph2: f32 = 0.0;        // OSC2 (slave, pulse) phase 0..1\nlet targetFreq: f32 = 0.0; // requested note pitch in Hz\nlet curFreq: f32 = 0.0;    // current (glided) pitch\nlet gate: i32 = 0;         // 1 while held\nlet note: i32 = -1;        // sounding note id\n\n// envelopes\nlet fenv: f32 = 0.0;       // filter envelope (decays 1 -> 0)\nlet aenv: f32 = 0.0;       // amplitude envelope\n\n// 4-pole (Moog-style) ladder state\nlet f0: f32 = 0.0;\nlet f1: f32 = 0.0;\nlet f2: f32 = 0.0;\nlet f3: f32 = 0.0;\n\n// DC blocker\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  ph1 = 0.0; ph2 = 0.0;\n  targetFreq = 0.0; curFreq = 0.0;\n  gate = 0; note = -1;\n  fenv = 0.0; aenv = 0.0;\n  f0 = 0.0; f1 = 0.0; f2 = 0.0; f3 = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_CUTOFF] = 0.45;\n  params[P_RESO]   = 0.55;\n  params[P_ENVAMT] = 0.6;\n  params[P_SYNC]   = 0.4;\n  params[P_DETUNE] = 0.25;\n  params[P_DECAY]  = 0.4;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// fast bounded tanh-ish saturator\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// Host passes Hz. Last-note priority; each note re-triggers the envelopes\n// and re-aligns the slave oscillator for a consistent sync transient.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const newFreq: f32 = f > 0.0 ? f : 0.0001;\n  if (gate == 0 && curFreq <= 0.0) {\n    curFreq = newFreq; // snap on first note\n  }\n  targetFreq = newFreq;\n  note = id;\n  gate = 1;\n  // reset oscillators so the sync transient is identical every attack\n  ph1 = 0.0;\n  ph2 = 0.0;\n  // (re)trigger envelopes scaled by velocity for a punchy attack\n  const vv: f32 = clampf(v, 0.0, 1.0);\n  fenv = 0.6 + 0.4 * vv;\n  aenv = 1.0;\n}\n\nexport function noteOff(id: i32): void {\n  if (id == note) gate = 0;\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN:   f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envAmtN: f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const syncN:   f32 = clampf(params[P_SYNC],   0.0, 1.0);\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const decayN:  f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Filter envelope: ~25 ms (snappy) up to ~1.4 s (long sweep).\n  const fdecaySec: f32 = 0.025 + decayN * decayN * 1.4;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n\n  // Amp envelope: a little longer so notes ring out musically.\n  const adecaySec: f32 = 0.05 + decayN * decayN * 1.8;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n\n  // Snappy fixed glide (lean synth — quick portamento ~12 ms).\n  const glideCoef: f32 = f32(Mathf.exp(-1.0 / (0.012 * sampleRate)));\n\n  // Resonance 0..~3.9 (approaches self-oscillation, bounded by satf).\n  const reso: f32 = resoN * 3.9;\n\n  // Base cutoff in Hz (exponential, musical): ~70 Hz .. ~10 kHz.\n  const baseCut: f32 = f32(70.0 * Mathf.exp(cutoffN * 4.96));\n\n  // Envelope sweep span in Hz on top of base.\n  const sweepSpan: f32 = envAmtN * 9000.0;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  // SYNC: OSC2 runs at a higher pitch ratio that increases with Sync, so the\n  // forced phase reset (sync) carves a brighter, more aggressive sweep into the\n  // slave waveform. ratio 1.0 .. ~3.5.\n  const syncRatio: f32 = 1.0 + syncN * 2.5;\n  // how much of the synced OSC2 is blended in (always audible, grows with sync)\n  const osc2Mix: f32 = 0.35 + 0.45 * syncN;\n\n  // DETUNE: OSC2 fine offset, +/- ~30 cents -> small multiplier around the ratio.\n  const detSemis: f32 = (detuneN - 0.5) * 0.6;     // +/-0.3 semitone-ish\n  const detMul: f32 = f32(Mathf.exp(detSemis * 0.0577623)); // 2^(s/12)\n\n  // pulse width for OSC2 (fixed-ish narrow pulse for the zappy character)\n  const pw: f32 = 0.35;\n\n  for (let i = 0; i < n; i++) {\n    // ---- glide pitch toward target ----\n    curFreq = targetFreq + (curFreq - targetFreq) * glideCoef;\n\n    let inc1: f32 = curFreq / sampleRate;\n    if (inc1 < 0.0) inc1 = 0.0;\n    if (inc1 > 0.5) inc1 = 0.5;\n\n    // OSC2 increment = master * sync ratio * detune\n    let inc2: f32 = inc1 * syncRatio * detMul;\n    if (inc2 > 0.5) inc2 = 0.5;\n\n    // ---- OSC1 master (saw) advance; detect cycle wrap for hard sync ----\n    ph1 += inc1;\n    let synced: bool = false;\n    if (ph1 >= 1.0) { ph1 -= 1.0; synced = true; }\n\n    const saw: f32 = ph1 * 2.0 - 1.0;\n\n    // ---- OSC2 slave (pulse) ----\n    ph2 += inc2;\n    if (ph2 >= 1.0) ph2 -= 1.0;\n    // HARD SYNC: master cycle forces the slave phase to reset -> sync edge\n    if (synced) ph2 = 0.0;\n    const pulse: f32 = ph2 < pw ? 1.0 : -1.0;\n\n    // ---- mix oscillators ----\n    let osc: f32 = saw + pulse * osc2Mix;\n    osc *= 0.65; // headroom before the filter\n\n    // ---- envelopes ----\n    fenv *= fenvCoef;\n    if (gate != 0) {\n      // hold near full while gated, then release on noteOff\n      aenv = aenv + (1.0 - aenv) * 0.002;\n      if (aenv > 1.0) aenv = 1.0;\n    } else {\n      aenv *= aenvCoef;\n    }\n\n    // ---- cutoff for this sample ----\n    let cutHz: f32 = baseCut + sweepSpan * fenv;\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- 4-pole resonant ladder ----\n    let fc: f32 = cutHz / nyq;\n    if (fc > 0.49) fc = 0.49;\n    const g: f32 = fc * (1.8 - 0.8 * fc);\n\n    const fb: f32 = reso * (1.0 - 0.15 * g);\n    const input: f32 = osc - fb * satf(f3);\n\n    f0 += g * (input - f0);\n    f1 += g * (f0 - f1);\n    f2 += g * (f1 - f2);\n    f3 += g * (f2 - f3);\n\n    let filtered: f32 = satf(f3 * 1.4);\n\n    // ---- amp + level ----\n    let s: f32 = filtered * aenv;\n\n    // DC blocker\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // final level + headroom guard (peak stays < ~1.0)\n    s = satf(s * level * 1.25) * 0.8;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000146000
}