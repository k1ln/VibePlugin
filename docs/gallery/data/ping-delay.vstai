{
  "format": 1,
  "name": "Ping Delay",
  "isInstrument": false,
  "explanation": "A stereo ping-pong / multi-tap delay. The wet signal cross-feeds between the left and right channels so every repeat bounces to the opposite side, while a chain of extra rhythmic taps thickens the pattern. A tone low-pass darkens each repeat, a width control spreads the bounce, and a saturated feedback path keeps near-max feedback ringing but bounded. Controls: Time, Feedback, Taps, Tone, Width and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.33
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Taps",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Width",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.8
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n:root{--ac:#5ad1ff;--ac2:#8ae0ff;--bg0:#040810;--bg1:#0a1422}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;color:#dceaf6;\n  background:radial-gradient(120% 90% at 50% -10%,#0e1c30 0%,var(--bg1) 50%,var(--bg0) 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;overflow:hidden}\n.unit{position:relative;width:100%;max-width:560px;border-radius:20px;overflow:hidden;\n  background:linear-gradient(168deg,rgba(16,28,46,.96),rgba(5,10,18,.97));\n  border:1px solid rgba(120,200,255,.14);\n  box-shadow:0 36px 80px rgba(0,0,0,.66),inset 0 1px 0 rgba(140,220,255,.10),inset 0 0 60px rgba(8,20,40,.6)}\n.unit::after{content:\"\";position:absolute;inset:0;pointer-events:none;border-radius:20px;\n  background:linear-gradient(transparent 0,transparent 1px) 0 0/100% 3px,\n            repeating-linear-gradient(90deg,transparent 0 2px,rgba(90,209,255,.012) 2px 3px);\n  mix-blend-mode:screen;opacity:.5}\n/* header */\n.hd{position:relative;z-index:3;display:flex;align-items:center;gap:11px;padding:15px 20px 13px;\n  border-bottom:1px solid rgba(90,209,255,.12);\n  background:linear-gradient(180deg,rgba(90,209,255,.07),transparent)}\n.beacon{position:relative;width:11px;height:11px}\n.beacon i{position:absolute;inset:0;border-radius:50%;background:var(--ac);\n  box-shadow:0 0 12px var(--ac),0 0 3px #fff inset;animation:beat var(--beat,500ms) linear infinite}\n.beacon i::after{content:\"\";position:absolute;inset:-4px;border-radius:50%;border:1px solid var(--ac);\n  animation:ring var(--beat,500ms) linear infinite;opacity:0}\n@keyframes beat{0%{transform:scale(.7);opacity:.5}30%{transform:scale(1);opacity:1}100%{transform:scale(.7);opacity:.5}}\n@keyframes ring{0%{transform:scale(.6);opacity:.8}100%{transform:scale(2.4);opacity:0}}\n.ttl{flex:1;min-width:0}\n.ttl h1{margin:0;font-size:16px;font-weight:800;letter-spacing:.16em;text-transform:uppercase;\n  background:linear-gradient(90deg,var(--ac),var(--ac2));-webkit-background-clip:text;background-clip:text;color:transparent}\n.ttl p{margin:2px 0 0;font-size:9.5px;letter-spacing:.34em;text-transform:uppercase;color:#5d7a94}\n.chip{font-size:9px;letter-spacing:.18em;text-transform:uppercase;color:#7fb6d8;\n  border:1px solid rgba(90,209,255,.28);border-radius:999px;padding:4px 10px;white-space:nowrap}\n/* arena: the bounce field */\n.arena{position:relative;z-index:2;height:148px;margin:16px 18px 6px;border-radius:14px;\n  background:\n    radial-gradient(80% 130% at 50% 120%,rgba(90,209,255,.10),transparent 60%),\n    linear-gradient(180deg,#020912,#06121f);\n  border:1px solid rgba(90,209,255,.14);overflow:hidden;\n  box-shadow:inset 0 2px 18px rgba(0,0,0,.7),inset 0 0 0 1px rgba(0,0,0,.4)}\n/* L / R goal posts */\n.wall{position:absolute;top:0;bottom:0;width:34px;display:flex;align-items:center;justify-content:center;\n  font-size:11px;font-weight:800;letter-spacing:.1em;color:#3f5e78}\n.wall.l{left:0;border-right:1px solid rgba(90,209,255,.10);background:linear-gradient(90deg,rgba(90,209,255,.08),transparent)}\n.wall.r{right:0;border-left:1px solid rgba(90,209,255,.10);background:linear-gradient(270deg,rgba(90,209,255,.08),transparent)}\n.wall b{transition:color .12s,text-shadow .12s}\n.wall.hit b{color:var(--ac);text-shadow:0 0 14px var(--ac)}\n/* centre net + lane guides */\n.net{position:absolute;left:50%;top:8px;bottom:8px;width:1px;margin-left:-.5px;\n  background:repeating-linear-gradient(180deg,rgba(90,209,255,.30) 0 5px,transparent 5px 11px)}\n.lane{position:absolute;left:34px;right:34px;height:1px;background:rgba(90,209,255,.07)}\n/* travelling SVG path for taps/trail */\n.field{position:absolute;inset:0;width:100%;height:100%}\n.trail{fill:none;stroke:var(--ac);stroke-width:1.4;opacity:.28;\n  stroke-dasharray:3 6;animation:flow 1.4s linear infinite}\n@keyframes flow{to{stroke-dashoffset:-18}}\n/* the bouncing ball */\n.ball{position:absolute;top:50%;left:0;width:18px;height:18px;margin:-9px 0 0 -9px;border-radius:50%;\n  background:radial-gradient(circle at 36% 32%,#fff,var(--ac2) 38%,var(--ac) 70%,#1d6f95 100%);\n  box-shadow:0 0 18px var(--ac),0 0 40px rgba(90,209,255,.6);\n  animation:px var(--beat,500ms) cubic-bezier(.42,0,.58,1) infinite alternate,\n            py calc(var(--beat,500ms)/2) cubic-bezier(.33,0,.67,1) infinite alternate;\n  will-change:transform}\n@keyframes px{from{left:var(--lx,42px)}to{left:var(--rx,calc(100% - 42px))}}\n@keyframes py{from{transform:translateY(calc(-1*var(--arc,34px)))}to{transform:translateY(var(--arc,34px))}}\n/* echo ghosts trailing behind */\n.ghost{position:absolute;top:50%;left:0;width:14px;height:14px;margin:-7px 0 0 -7px;border-radius:50%;\n  background:radial-gradient(circle,var(--ac),transparent 70%);pointer-events:none;\n  animation:px var(--beat,500ms) cubic-bezier(.42,0,.58,1) infinite alternate,\n            py calc(var(--beat,500ms)/2) cubic-bezier(.33,0,.67,1) infinite alternate;will-change:transform}\n.ghost.g1{opacity:.55;animation-delay:calc(-1*var(--beat,500ms)*.16),calc(-1*var(--beat,500ms)*.16)}\n.ghost.g2{opacity:.32;animation-delay:calc(-1*var(--beat,500ms)*.34),calc(-1*var(--beat,500ms)*.34)}\n.ghost.g3{opacity:.16;animation-delay:calc(-1*var(--beat,500ms)*.55),calc(-1*var(--beat,500ms)*.55)}\n/* tap pips along the bottom */\n.taps{position:absolute;left:40px;right:40px;bottom:9px;height:10px;display:flex;gap:5px;align-items:flex-end}\n.tap{flex:1;height:3px;border-radius:2px;background:rgba(90,209,255,.16);transition:.18s}\n.tap.on{height:9px;background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 8px var(--ac)}\n/* readout overlay */\n.read{position:absolute;left:40px;bottom:24px;font-size:9px;letter-spacing:.22em;text-transform:uppercase;\n  color:#4f718c;pointer-events:none}\n/* ===== control deck — bespoke \"paddle rails\" (vertical bounce-faders) ===== */\n.deck{position:relative;z-index:2;display:grid;grid-template-columns:repeat(6,1fr);gap:8px;padding:14px 16px 8px}\n@media(max-width:520px){.deck{grid-template-columns:repeat(3,1fr)}}\n.rail{position:relative;display:flex;flex-direction:column;align-items:center;gap:8px;\n  padding:10px 4px 11px;border-radius:14px;animation:rise .5s both;animation-delay:var(--d);\n  transition:background .18s,transform .18s}\n.rail:hover{background:rgba(90,209,255,.05);transform:translateY(-2px)}\n@keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n/* the lane the paddle slides along */\n.slot{position:relative;width:34px;height:88px;cursor:ns-resize;touch-action:none;user-select:none;\n  border-radius:11px;\n  background:linear-gradient(180deg,#04101c,#020a13);\n  border:1px solid rgba(90,209,255,.14);\n  box-shadow:inset 0 2px 10px rgba(0,0,0,.7),inset 0 0 0 1px rgba(0,0,0,.4)}\n/* dashed centre net inside each lane — echoes the arena */\n.slot::before{content:\"\";position:absolute;left:50%;top:7px;bottom:7px;width:1px;margin-left:-.5px;\n  background:repeating-linear-gradient(180deg,rgba(90,209,255,.22) 0 4px,transparent 4px 9px)}\n/* the energy fill that rises with the value (the \"charge\" the ball gets) */\n.fill{position:absolute;left:3px;right:3px;bottom:3px;border-radius:9px;height:var(--h,30%);\n  background:linear-gradient(180deg,var(--ac2),var(--ac) 60%,rgba(90,209,255,.25));\n  box-shadow:0 0 14px rgba(90,209,255,.5),inset 0 1px 0 rgba(255,255,255,.25);\n  transition:height .12s cubic-bezier(.2,.8,.3,1)}\n/* the paddle puck that floats on top of the fill */\n.puck{position:absolute;left:-3px;right:-3px;height:11px;border-radius:7px;\n  bottom:calc(var(--h,30%) - 5px);\n  background:radial-gradient(120% 180% at 50% 0,#eafaff,var(--ac2) 45%,var(--ac) 100%);\n  box-shadow:0 0 12px var(--ac),0 2px 4px rgba(0,0,0,.6);\n  transition:bottom .12s cubic-bezier(.2,.8,.3,1)}\n/* a little pip that pings off the paddle when grabbed */\n.slot.act .puck{box-shadow:0 0 18px var(--ac),0 0 0 1px #eafaff,0 2px 4px rgba(0,0,0,.6)}\n.slot.act{border-color:rgba(90,209,255,.45)}\n.spark{position:absolute;left:50%;width:6px;height:6px;margin-left:-3px;border-radius:50%;\n  background:var(--ac2);box-shadow:0 0 10px var(--ac);opacity:0;pointer-events:none}\n.slot.act .spark{animation:spark .5s ease-out infinite}\n@keyframes spark{0%{opacity:.9;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-26px) scale(.3)}}\n.nm{font-size:9.5px;letter-spacing:.13em;text-transform:uppercase;color:#7f9ab4}\n.val{font-size:12px;font-weight:800;color:#eaf6ff;font-variant-numeric:tabular-nums;\n  text-shadow:0 0 10px rgba(90,209,255,.4)}\n.ft{position:relative;z-index:2;font-size:10px;line-height:1.5;color:#5d7a94;margin:2px 18px 14px;\n  border-top:1px solid rgba(90,209,255,.10);padding-top:9px}\n</style></head><body>\n<div class=\"unit\">\n  <div class=\"hd\">\n    <span class=\"beacon\"><i></i></span>\n    <div class=\"ttl\"><h1>Ping&nbsp;Delay</h1><p>Stereo&nbsp;Bounce&nbsp;Engine</p></div>\n    <span class=\"chip\">6 · ping&#8596;pong</span>\n  </div>\n\n  <div class=\"arena\" id=\"arena\">\n    <div class=\"lane\" style=\"top:50%\"></div>\n    <div class=\"net\"></div>\n    <svg class=\"field\" viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n      <path class=\"trail\" id=\"trail\" d=\"M8,50 Q50,12 92,50 Q50,88 8,50\"/>\n    </svg>\n    <div class=\"wall l\" id=\"wallL\"><b>L</b></div>\n    <div class=\"wall r\" id=\"wallR\"><b>R</b></div>\n    <div class=\"ghost g3\"></div><div class=\"ghost g2\"></div><div class=\"ghost g1\"></div>\n    <div class=\"ball\" id=\"ball\"></div>\n    <div class=\"taps\" id=\"taps\"></div>\n    <span class=\"read\" id=\"read\">— ms · ∞</span>\n  </div>\n\n  <div class=\"deck\" id=\"deck\"></div>\n  <div class=\"ft\" id=\"ft\"></div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Time\",index:0,min:0,max:1,def:0.33},\n    {name:\"Feedback\",index:1,min:0,max:1,def:0.45},\n    {name:\"Taps\",index:2,min:0,max:1,def:0.4},\n    {name:\"Tone\",index:3,min:0,max:1,def:0.55},\n    {name:\"Width\",index:4,min:0,max:1,def:0.8},\n    {name:\"Mix\",index:5,min:0,max:1,def:0.5}\n  ];\n  var STEP=0.001;\n  var vals={}; // index -> value\n  var deck=document.getElementById('deck');\n  var ft=document.getElementById('ft');\n  ft.textContent=\"A stereo ping-pong / multi-tap delay. The wet signal cross-feeds between left and right so every repeat bounces to the opposite side; extra taps thicken the pattern, Tone darkens repeats, Width spreads the bounce, and a saturated feedback path stays bounded near max.\";\n\n  function fmt(v){return (Math.round(v*100)/100).toFixed(2);}\n\n  function host(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n\n  /* each param is a bespoke vertical \"paddle rail\": grab the puck and slide;\n     the energy fill rises with the value and sparks ping off while dragging. */\n  function makeRail(p,di){\n    var rail=document.createElement('div');\n    rail.className='rail'; rail.style.setProperty('--d',(di*55)+'ms');\n    rail.innerHTML=\n      '<div class=\"slot\" tabindex=\"0\">'+\n        '<div class=\"fill\"></div><div class=\"puck\"></div><div class=\"spark\"></div>'+\n      '</div>'+\n      '<div class=\"nm\">'+p.name+'</div><div class=\"val\">0.00</div>';\n    deck.appendChild(rail);\n    var slot=rail.querySelector('.slot'),\n        fill=rail.querySelector('.fill'),\n        puck=rail.querySelector('.puck'),\n        spark=rail.querySelector('.spark'),\n        out=rail.querySelector('.val');\n\n    function paint(){\n      var n=(vals[p.index]-p.min)/(p.max-p.min||1);\n      var pct=(6+n*88); // keep puck inside the lane\n      fill.style.setProperty('--h',pct+'%');\n      slot.style.setProperty('--h',pct+'%');\n      out.textContent=fmt(vals[p.index]);\n      host(p.index,vals[p.index]);\n      onChange(p.index,n);\n    }\n    function setN(n){ n=n<0?0:n>1?1:n; var v=p.min+(p.max-p.min)*n;\n      v=Math.round(v/STEP)*STEP; vals[p.index]=v; paint(); }\n    function norm(){ return (vals[p.index]-p.min)/(p.max-p.min||1); }\n\n    // map a pointer Y inside the slot to a normalised value (bottom=0,top=1)\n    function yToN(clientY){ var r=slot.getBoundingClientRect();\n      return 1-(clientY-r.top)/(r.height||1); }\n\n    var drag=false;\n    slot.addEventListener('pointerdown',function(e){drag=true;\n      slot.classList.add('act');slot.setPointerCapture(e.pointerId);\n      setN(yToN(e.clientY));e.preventDefault();});\n    slot.addEventListener('pointermove',function(e){if(!drag)return;setN(yToN(e.clientY));});\n    slot.addEventListener('pointerup',function(){drag=false;slot.classList.remove('act');});\n    slot.addEventListener('pointercancel',function(){drag=false;slot.classList.remove('act');});\n    slot.addEventListener('dblclick',function(){vals[p.index]=p.def;paint();});\n    slot.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?.025:-.025));},{passive:false});\n    slot.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setN(norm()+.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setN(norm()-.02);e.preventDefault();}});\n\n    vals[p.index]=p.def; paint();\n  }\n\n  /* ---- live bounce-field reactions ---- */\n  var ball=document.getElementById('ball'),\n      arena=document.getElementById('arena'),\n      wallL=document.getElementById('wallL'), wallR=document.getElementById('wallR'),\n      beacon=document.querySelector('.beacon'),\n      trail=document.getElementById('trail'),\n      read=document.getElementById('read'),\n      tapsBox=document.getElementById('taps');\n  var TAP_MAX=8, tapEls=[];\n  for(var t=0;t<TAP_MAX;t++){var el=document.createElement('span');el.className='tap';tapsBox.appendChild(el);tapEls.push(el);}\n\n  function onChange(i,n){\n    if(i===0){ // Time -> beat period (60..900ms), arc height shrinks as faster\n      var ms=60+(1-n)*840; // long time = slow bounce\n      var period=Math.max(140,ms*2);\n      document.documentElement.style.setProperty('--beat',period+'ms');\n      beacon.style.setProperty('--beat',period+'ms');\n      var arc=18+n*30;\n      ball.style.setProperty('--arc',arc+'px');\n      document.querySelectorAll('.ghost').forEach(function(g){g.style.setProperty('--arc',arc+'px');});\n      updateRead();\n    } else if(i===1){ // Feedback -> ghost count / persistence + walls glow + read\n      var ghosts=document.querySelectorAll('.ghost');\n      ghosts.forEach(function(g,k){g.style.display=(n>(k+1)/5)?'block':'none';});\n      arena.style.boxShadow='inset 0 2px 18px rgba(0,0,0,.7),inset 0 0 '+(20+n*60)+'px rgba(90,209,255,'+(n*.22)+')';\n      updateRead();\n    } else if(i===2){ // Taps -> number of lit pips\n      var cnt=Math.round(1+n*(TAP_MAX-1));\n      tapEls.forEach(function(e,k){e.classList.toggle('on',k<cnt);});\n    } else if(i===3){ // Tone -> trail opacity / blur of ball (darker = dimmer)\n      ball.style.filter='blur('+((1-n)*1.4)+'px)';\n      trail.style.opacity=(0.12+n*0.34).toFixed(2);\n      ball.style.opacity=(0.55+n*0.45).toFixed(2);\n    } else if(i===4){ // Width -> horizontal travel span (how far it pings)\n      var inset=42-n*22; // wider = closer to walls (bigger swing)\n      var lx=inset+'px', rx='calc(100% - '+inset+'px)';\n      ball.style.setProperty('--lx',lx); ball.style.setProperty('--rx',rx);\n      document.querySelectorAll('.ghost').forEach(function(g){g.style.setProperty('--lx',lx);g.style.setProperty('--rx',rx);});\n      // bend the trail arc with width\n      var q=8+n*8, e=92-n*8;\n      trail.setAttribute('d','M'+q+',50 Q50,'+(50-30-n*14)+' '+e+',50 Q50,'+(50+30+n*14)+' '+q+',50');\n    } else if(i===5){ // Mix -> overall ball brightness / size\n      ball.style.boxShadow='0 0 '+(8+n*22)+'px var(--ac),0 0 '+(20+n*40)+'px rgba(90,209,255,'+(0.2+n*0.5)+')';\n      ball.style.width=(14+n*8)+'px'; ball.style.height=(14+n*8)+'px';\n      ball.style.margin='-'+(7+n*4)+'px 0 0 -'+(7+n*4)+'px';\n    }\n  }\n  function updateRead(){\n    var tn=(vals[0]-0)/1, fbn=(vals[1]-0)/1;\n    var ms=Math.round(60+(1-tn)*840);\n    var rep = fbn>=0.98? '∞' : Math.max(1,Math.round(1/(1.02-fbn)));\n    read.textContent=ms+' ms · '+rep+' rpt';\n  }\n\n  /* sync ball flip to wall hits via animationiteration on the x animation */\n  function flashWall(side){\n    var w=side<0?wallL:wallR; w.classList.add('hit');\n    setTimeout(function(){w.classList.remove('hit');},120);\n  }\n  var lastDir=1;\n  ball.addEventListener('animationiteration',function(e){\n    if(e.animationName==='px'){ flashWall(lastDir); lastDir*=-1; }\n  });\n\n  function ready(){\n    PARAMS.forEach(makeRail);\n    updateRead();\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  PING DELAY — stereo ping-pong / multi-tap delay\n//  A cross-fed stereo delay: the wet signal bounces between the left and\n//  right channels so each repeat alternates sides. On top of the main\n//  ping-pong echo sit extra rhythmic taps (the Taps control adds and\n//  pans a chain of fractional-time echoes), a one-pole tone low-pass that\n//  darkens every repeat, and a width control that spreads the bounce. A\n//  tanh saturator in the feedback path keeps near-max feedback ringing but\n//  bounded. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: up to ~1.5 s per channel at 48 kHz plus headroom. The base\n// ping-pong time tops out at ~1 s and the extra taps read further back, so\n// the line must be long enough for the longest tap.\nconst DELAY_LEN: i32 = 96000 + 8192;\nconst delayL: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\n\n// feedback tone-LP state (per channel)\nlet fbLpL: f32 = 0.0;\nlet fbLpR: f32 = 0.0;\n\n// smoothed delay time (samples) to avoid zipper noise on Time changes\nlet smoothDelay: f32 = 9600.0;\n\nconst P_TIME: i32 = 0;     // 0..1 -> 30..1000 ms\nconst P_FEEDBACK: i32 = 1; // 0..1 -> 0..0.92 (clamped)\nconst P_TAPS: i32 = 2;     // 0..1 -> density/level of extra rhythmic taps\nconst P_TONE: i32 = 3;     // 0..1 -> repeat darkness (LP cutoff in feedback)\nconst P_WIDTH: i32 = 4;    // 0..1 -> stereo spread of the bounce\nconst P_MIX: i32 = 5;      // 0..1 dry/wet\n\nconst TWO_PI: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  fbLpL = 0.0;\n  fbLpR = 0.0;\n  for (let i = 0; i < DELAY_LEN; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  smoothDelay = 0.3 * sampleRate; // ~300 ms default\n  params[P_TIME] = 0.33;     // ~300 ms\n  params[P_FEEDBACK] = 0.45;\n  params[P_TAPS] = 0.4;\n  params[P_TONE] = 0.55;\n  params[P_WIDTH] = 0.8;\n  params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// read a delay line at a fractional sample distance behind the write head,\n// linear interpolation, wrap-safe.\n@inline function readDelay(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(DELAY_LEN);\n  while (rp >= f32(DELAY_LEN)) rp -= f32(DELAY_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const tapsN: f32 = clampf(params[P_TAPS], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Time: 30..1000 ms (perceptual-ish curve), in samples.\n  const timeMs: f32 = 30.0 + timeN * timeN * 970.0;\n  let targetDelay: f32 = timeMs * 0.001 * sampleRate;\n  const maxDelay: f32 = f32(DELAY_LEN - 8);\n  // The longest extra tap reads at ~1.85x the base time, so cap the base so\n  // every tap stays inside the line.\n  const tapMax: f32 = maxDelay / 1.9;\n  if (targetDelay > tapMax) targetDelay = tapMax;\n  if (targetDelay < 8.0) targetDelay = 8.0;\n\n  // Feedback gain — clamped so the ping-pong can ring near self-oscillation\n  // but never diverges.\n  const fbGain: f32 = clampf(fbN * 0.92, 0.0, 0.92);\n\n  // Feedback tone low-pass: brighter when Tone high, darker when low.\n  // Cutoff ~600 Hz (dark) .. ~9000 Hz (bright).\n  const toneHz: f32 = 600.0 + toneN * toneN * 8400.0;\n  let cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  cTone = clampf(cTone, 0.0, 1.0);\n\n  // one-pole smoothing coeff for delay time (~8 Hz corner)\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 8.0 / sampleRate));\n\n  // Width: 0 = mono-ish (taps centred), 1 = hard ping-pong with the extra\n  // taps thrown wide. Used to scale the L/R spread of every wet component.\n  const spread: f32 = widthN;\n\n  // Taps: a chain of three extra echoes between the main repeats, panned\n  // alternately. Their overall level rises with the Taps control so the knob\n  // audibly thickens the pattern; at 0 only the clean ping-pong remains.\n  const tapLvl: f32 = tapsN;\n\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    // smooth the base delay toward target\n    smoothDelay += smoothCoeff * (targetDelay - smoothDelay);\n    const d: f32 = smoothDelay;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n    const xMono: f32 = (xL + xR) * 0.5;\n\n    // --- main ping-pong tap (one full delay back) ---\n    const echoL: f32 = readDelay(delayL, d);\n    const echoR: f32 = readDelay(delayR, d);\n\n    // --- extra rhythmic taps at fractional sub-divisions, alternately panned.\n    // tap A at 1/2 d (centre-ish), tap B at 5/4 d (left), tap C at 7/4 d (right)\n    const tA: f32 = readDelay(delayL, d * 0.5) * 0.6;\n    const tB: f32 = readDelay(delayR, d * 1.25) * 0.5;\n    const tC: f32 = readDelay(delayL, d * 1.75) * 0.42;\n\n    // pan the extra taps: A centre, B to the left, C to the right; the spread\n    // pushes them outward as Width rises.\n    const tapL: f32 = tapLvl * (tA + tB * (0.5 + 0.5 * spread) + tC * (0.5 - 0.5 * spread));\n    const tapR: f32 = tapLvl * (tA + tB * (0.5 - 0.5 * spread) + tC * (0.5 + 0.5 * spread));\n\n    // --- wet bus: ping-pong cross-fed echoes plus the extra taps.\n    // Width crossfades each side between the centre sum (narrow) and the\n    // opposite-channel bounce (wide ping-pong).\n    const sumLR: f32 = (echoL + echoR) * 0.5;\n    const wetL: f32 = (sumLR + (echoR - sumLR) * spread) + tapL;\n    const wetR: f32 = (sumLR + (echoL - sumLR) * spread) + tapR;\n\n    // --- feedback path: cross-couple L<->R so repeats bounce sides, darken\n    // with the tone LP, and soft-saturate so high feedback stays bounded.\n    fbLpL += cTone * (echoR - fbLpL); // note the cross: L line fed by R echo\n    fbLpR += cTone * (echoL - fbLpR);\n\n    let fbInL: f32 = xMono + fbLpL * fbGain;\n    let fbInR: f32 = xMono + fbLpR * fbGain;\n    fbInL = f32(Mathf.tanh(fbInL));\n    fbInR = f32(Mathf.tanh(fbInR));\n\n    delayL[writePos] = fbInL;\n    delayR[writePos] = fbInR;\n\n    // gain-stage the wet a touch so dense taps + feedback stay below full-scale\n    const wL: f32 = wetL * 0.7;\n    const wR: f32 = wetR * 0.7;\n\n    outBuf[f] = f32(xL * (1.0 - mix) + wL * mix);\n    if (stereo) outBuf[MAX_FRAMES + f] = f32(xR * (1.0 - mix) + wR * mix);\n    else outBuf[MAX_FRAMES + f] = outBuf[f];\n\n    writePos++;\n    if (writePos >= DELAY_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000033000
}