{
  "format": 1,
  "name": "Dimensional",
  "isInstrument": false,
  "explanation": "A dimensional BBD-style stereo chorus. Two gently pitch-modulated short delay lines per channel are cross-fed left-to-right to bloom a mono source into a wide, animated stereo image with very little obvious wobble. Mode picks four intensity presets; Depth, Width and Mix shape the spread.",
  "params": [
    {
      "name": "Mode",
      "index": 0,
      "min": 0,
      "max": 3,
      "default": 0
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Width",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Dimensional</title>\n<style>\n  :root {\n    --accent: #8fb6ff;\n    --accent2: #b0e0ff;\n    --bg0: #0a0d16;\n    --bg1: #121826;\n    --panel: #161d2e;\n    --panel-hi: #1f2840;\n    --ink: #d8e3ff;\n    --ink-dim: #7d8aad;\n    --line: rgba(143, 182, 255, 0.14);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    height: 100%;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #1a2742 0%, var(--bg0) 60%) fixed;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n    overflow: auto;\n  }\n\n  /* ---- the rack faceplate -------------------------------------- */\n  .unit {\n    width: 100%;\n    max-width: 560px;\n    border-radius: 16px;\n    padding: 1px;\n    background:\n      linear-gradient(160deg, rgba(176,224,255,0.35), rgba(143,182,255,0.05) 40%, rgba(0,0,0,0.4));\n    box-shadow:\n      0 30px 70px -28px rgba(0,0,0,0.9),\n      0 2px 0 rgba(255,255,255,0.04) inset;\n  }\n  .face {\n    border-radius: 15px;\n    background:\n      linear-gradient(180deg, var(--panel-hi), var(--panel) 18%, var(--bg1) 100%);\n    padding: 20px 22px 24px;\n    position: relative;\n    overflow: hidden;\n  }\n  /* brushed-metal sheen */\n  .face::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      repeating-linear-gradient(90deg, rgba(255,255,255,0.018) 0 2px, transparent 2px 4px);\n    pointer-events: none;\n    opacity: 0.6;\n  }\n\n  /* ---- header --------------------------------------------------- */\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    margin-bottom: 16px;\n    position: relative;\n    z-index: 2;\n  }\n  .brand { display: flex; align-items: center; gap: 12px; }\n  .logo {\n    width: 30px; height: 30px;\n    filter: drop-shadow(0 0 6px rgba(143,182,255,0.5));\n  }\n  .titles h1 {\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 5px;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, #fff, var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles p {\n    font-size: 9px;\n    letter-spacing: 3.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 2px;\n  }\n  .screws { display: flex; gap: 10px; }\n  .screw {\n    width: 11px; height: 11px; border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #2b3756, #0c1120 80%);\n    box-shadow: 0 1px 1px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.03) inset;\n    position: relative;\n  }\n  .screw::after {\n    content: \"\"; position: absolute; inset: 3px;\n    border-top: 1px solid rgba(143,182,255,0.25);\n    transform: rotate(35deg);\n  }\n\n  /* ---- the dimensional field (visualiser) ---------------------- */\n  .stage {\n    position: relative;\n    height: 168px;\n    border-radius: 12px;\n    margin-bottom: 18px;\n    background:\n      radial-gradient(80% 120% at 50% 50%, #0e1626 0%, #070a12 100%);\n    box-shadow:\n      0 0 0 1px var(--line) inset,\n      0 18px 30px -22px rgba(0,0,0,0.9) inset;\n    overflow: hidden;\n  }\n  #field { width: 100%; height: 100%; display: block; }\n  .stage .glabel {\n    position: absolute; bottom: 8px;\n    font-size: 8px; letter-spacing: 2px; text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .stage .glabel.l { left: 12px; }\n  .stage .glabel.r { right: 12px; }\n\n  /* ---- mode buttons -------------------------------------------- */\n  .modes {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 10px;\n    margin-bottom: 20px;\n  }\n  .modebtn {\n    position: relative;\n    border: 1px solid var(--line);\n    border-radius: 10px;\n    background: linear-gradient(180deg, #1a2238, #11172500);\n    padding: 12px 0 10px;\n    cursor: pointer;\n    text-align: center;\n    transition: transform 0.12s ease, border-color 0.2s, background 0.2s;\n    user-select: none;\n  }\n  .modebtn:hover { transform: translateY(-1px); border-color: rgba(143,182,255,0.4); }\n  .modebtn:active { transform: translateY(1px); }\n  .modebtn .lamp {\n    width: 9px; height: 9px; border-radius: 50%;\n    margin: 0 auto 9px;\n    background: #1d2742;\n    box-shadow: 0 0 0 1px rgba(0,0,0,0.5) inset;\n    transition: background 0.2s, box-shadow 0.2s;\n  }\n  .modebtn .num {\n    font-size: 17px; font-weight: 700;\n    color: var(--ink-dim);\n    transition: color 0.2s;\n    font-variant-numeric: tabular-nums;\n  }\n  .modebtn .sub {\n    font-size: 7.5px; letter-spacing: 1.5px; text-transform: uppercase;\n    color: var(--ink-dim); margin-top: 3px;\n  }\n  .modebtn.on {\n    background: linear-gradient(180deg, rgba(143,182,255,0.20), rgba(143,182,255,0.02));\n    border-color: rgba(143,182,255,0.65);\n    box-shadow: 0 0 18px -4px rgba(143,182,255,0.45);\n  }\n  .modebtn.on .lamp {\n    background: var(--accent2);\n    box-shadow: 0 0 10px 1px var(--accent2), 0 0 2px #fff inset;\n    animation: pulse 1.8s ease-in-out infinite;\n  }\n  .modebtn.on .num { color: #fff; }\n  @keyframes pulse {\n    0%, 100% { box-shadow: 0 0 8px 0 var(--accent2), 0 0 2px #fff inset; }\n    50%      { box-shadow: 0 0 16px 3px var(--accent2), 0 0 2px #fff inset; }\n  }\n\n  /* ---- knobs row ----------------------------------------------- */\n  .knobs {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n  }\n  .knob {\n    display: flex; flex-direction: column; align-items: center;\n    gap: 9px;\n    padding: 8px 0;\n  }\n  .dial {\n    width: 86px; height: 86px;\n    cursor: ns-resize;\n    touch-action: none;\n    -webkit-user-select: none; user-select: none;\n  }\n  .klabel {\n    font-size: 9px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .kval {\n    font-size: 13px; font-weight: 600;\n    color: var(--accent2);\n    font-variant-numeric: tabular-nums;\n    min-height: 16px;\n  }\n\n  footer {\n    margin-top: 16px;\n    display: flex; justify-content: space-between; align-items: center;\n    font-size: 8px; letter-spacing: 2px; text-transform: uppercase;\n    color: var(--ink-dim);\n    border-top: 1px solid var(--line);\n    padding-top: 10px;\n    position: relative; z-index: 2;\n  }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n   <div class=\"face\">\n\n    <header>\n      <div class=\"brand\">\n        <svg class=\"logo\" viewBox=\"0 0 40 40\" fill=\"none\">\n          <circle cx=\"20\" cy=\"20\" r=\"3.4\" fill=\"#b0e0ff\"/>\n          <ellipse cx=\"20\" cy=\"20\" rx=\"9\"  ry=\"15\" stroke=\"#8fb6ff\" stroke-width=\"1.3\" opacity=\"0.85\"/>\n          <ellipse cx=\"20\" cy=\"20\" rx=\"15\" ry=\"9\"  stroke=\"#8fb6ff\" stroke-width=\"1.3\" opacity=\"0.55\"/>\n          <ellipse cx=\"20\" cy=\"20\" rx=\"17\" ry=\"17\" stroke=\"#b0e0ff\" stroke-width=\"1\"   opacity=\"0.3\"/>\n        </svg>\n        <div class=\"titles\">\n          <h1>Dimensional</h1>\n          <p>Stereo Chorus &middot; BBD Space</p>\n        </div>\n      </div>\n      <div class=\"screws\">\n        <div class=\"screw\"></div>\n        <div class=\"screw\"></div>\n      </div>\n    </header>\n\n    <div class=\"stage\">\n      <canvas id=\"field\"></canvas>\n      <span class=\"glabel l\">L</span>\n      <span class=\"glabel r\">R</span>\n    </div>\n\n    <div class=\"modes\" id=\"modes\"></div>\n\n    <div class=\"knobs\" id=\"knobs\"></div>\n\n    <footer>\n      <span>Dimensional&nbsp;Engine</span>\n      <span id=\"modeName\">MODE I</span>\n    </footer>\n\n   </div>\n  </div>\n\n<script>\n\"use strict\";\n\n// ---- param map (indices MUST match assembly.ts P_*) -------------\nvar P_MODE = 0, P_DEPTH = 1, P_WIDTH = 2, P_MIX = 3;\n\nvar SPEC = [\n  { idx: P_MODE,  name: \"Mode\",  min: 0, max: 3, def: 0 },\n  { idx: P_DEPTH, name: \"Depth\", min: 0, max: 1, def: 0.5 },\n  { idx: P_WIDTH, name: \"Width\", min: 0, max: 1, def: 0.6 },\n  { idx: P_MIX,   name: \"Mix\",   min: 0, max: 1, def: 0.7 }\n];\n\nvar values = {};          // idx -> real value\nSPEC.forEach(function (p) { values[p.idx] = p.def; });\n\nvar MODE_NAMES = [\"I\", \"II\", \"III\", \"IV\"];\n\n// ---- host bridge ------------------------------------------------\nfunction push(idx, v) {\n  values[idx] = v;\n  if (window.vstai && window.vstai.setParam) {\n    try { window.vstai.setParam(idx, v); } catch (e) {}\n  }\n}\n\n// ===============================================================\n//  KNOBS  (SVG, vertical drag, double-click reset, wheel fine)\n// ===============================================================\nvar SVGNS = \"http://www.w3.org/2000/svg\";\n\nfunction buildKnob(spec) {\n  var wrap = document.createElement(\"div\");\n  wrap.className = \"knob\";\n\n  var svg = document.createElementNS(SVGNS, \"svg\");\n  svg.setAttribute(\"class\", \"dial\");\n  svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n  // outer ring well\n  var well = document.createElementNS(SVGNS, \"circle\");\n  well.setAttribute(\"cx\", \"50\"); well.setAttribute(\"cy\", \"50\"); well.setAttribute(\"r\", \"42\");\n  well.setAttribute(\"fill\", \"none\");\n  well.setAttribute(\"stroke\", \"rgba(0,0,0,0.5)\");\n  well.setAttribute(\"stroke-width\", \"7\");\n  svg.appendChild(well);\n\n  // value arc track (dim)\n  var track = document.createElementNS(SVGNS, \"path\");\n  track.setAttribute(\"fill\", \"none\");\n  track.setAttribute(\"stroke\", \"rgba(143,182,255,0.12)\");\n  track.setAttribute(\"stroke-width\", \"5\");\n  track.setAttribute(\"stroke-linecap\", \"round\");\n  svg.appendChild(track);\n\n  // value arc (lit)\n  var arc = document.createElementNS(SVGNS, \"path\");\n  arc.setAttribute(\"fill\", \"none\");\n  arc.setAttribute(\"stroke\", \"url(#kg)\");\n  arc.setAttribute(\"stroke-width\", \"5\");\n  arc.setAttribute(\"stroke-linecap\", \"round\");\n  svg.appendChild(arc);\n\n  // gradient + glow defs (shared, defined once)\n  if (!document.getElementById(\"kg-defs\")) {\n    var defs = document.createElementNS(SVGNS, \"defs\");\n    defs.setAttribute(\"id\", \"kg-defs\");\n    defs.innerHTML =\n      '<linearGradient id=\"kg\" x1=\"0\" y1=\"1\" x2=\"1\" y2=\"0\">' +\n        '<stop offset=\"0\" stop-color=\"#8fb6ff\"/>' +\n        '<stop offset=\"1\" stop-color=\"#b0e0ff\"/>' +\n      '</linearGradient>' +\n      '<radialGradient id=\"kbody\" cx=\"0.4\" cy=\"0.32\" r=\"0.8\">' +\n        '<stop offset=\"0\" stop-color=\"#2a3654\"/>' +\n        '<stop offset=\"0.7\" stop-color=\"#161d2e\"/>' +\n        '<stop offset=\"1\" stop-color=\"#0c111c\"/>' +\n      '</radialGradient>';\n    svg.appendChild(defs);\n  }\n\n  // knob body\n  var body = document.createElementNS(SVGNS, \"circle\");\n  body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"31\");\n  body.setAttribute(\"fill\", \"url(#kbody)\");\n  body.setAttribute(\"stroke\", \"rgba(255,255,255,0.06)\");\n  body.setAttribute(\"stroke-width\", \"1\");\n  svg.appendChild(body);\n\n  // pointer notch\n  var ptr = document.createElementNS(SVGNS, \"line\");\n  ptr.setAttribute(\"x1\", \"50\"); ptr.setAttribute(\"y1\", \"50\");\n  ptr.setAttribute(\"x2\", \"50\"); ptr.setAttribute(\"y2\", \"24\");\n  ptr.setAttribute(\"stroke\", \"#cfe3ff\");\n  ptr.setAttribute(\"stroke-width\", \"2.5\");\n  ptr.setAttribute(\"stroke-linecap\", \"round\");\n  ptr.style.filter = \"drop-shadow(0 0 3px rgba(176,224,255,0.7))\";\n  svg.appendChild(ptr);\n\n  wrap.appendChild(svg);\n\n  var lab = document.createElement(\"div\");\n  lab.className = \"klabel\";\n  lab.textContent = spec.name;\n  wrap.appendChild(lab);\n\n  var val = document.createElement(\"div\");\n  val.className = \"kval\";\n  wrap.appendChild(val);\n\n  // --- geometry: arc spans 135°..405° (270° sweep) ---\n  var A0 = 135, A1 = 405;\n  function polar(deg, r) {\n    var rad = (deg - 90) * Math.PI / 180;\n    return [50 + r * Math.cos(rad), 50 + r * Math.sin(rad)];\n  }\n  function arcPath(fromDeg, toDeg, r) {\n    var a = polar(fromDeg, r), b = polar(toDeg, r);\n    var large = (toDeg - fromDeg) > 180 ? 1 : 0;\n    return \"M \" + a[0].toFixed(2) + \" \" + a[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + b[0].toFixed(2) + \" \" + b[1].toFixed(2);\n  }\n  track.setAttribute(\"d\", arcPath(A0, A1, 38));\n\n  function norm() {\n    return (values[spec.idx] - spec.min) / (spec.max - spec.min);\n  }\n\n  function render() {\n    var t = norm();\n    var ang = A0 + t * (A1 - A0);\n    arc.setAttribute(\"d\", arcPath(A0, Math.max(A0 + 0.001, ang), 38));\n    ptr.setAttribute(\"transform\", \"rotate(\" + (ang - 270) + \" 50 50)\");\n    if (spec.max - spec.min <= 1.001) {\n      val.textContent = Math.round(values[spec.idx] * 100) + \"%\";\n    } else {\n      val.textContent = values[spec.idx].toFixed(0);\n    }\n  }\n\n  function setNorm(t) {\n    t = Math.max(0, Math.min(1, t));\n    push(spec.idx, spec.min + t * (spec.max - spec.min));\n    render();\n  }\n\n  // vertical drag\n  var dragging = false, startY = 0, startT = 0;\n  function onDown(e) {\n    dragging = true;\n    startY = (e.touches ? e.touches[0].clientY : e.clientY);\n    startT = norm();\n    e.preventDefault();\n  }\n  function onMove(e) {\n    if (!dragging) return;\n    var y = (e.touches ? e.touches[0].clientY : e.clientY);\n    var dy = startY - y;\n    setNorm(startT + dy / 180);\n    e.preventDefault();\n  }\n  function onUp() { dragging = false; }\n\n  svg.addEventListener(\"mousedown\", onDown);\n  window.addEventListener(\"mousemove\", onMove);\n  window.addEventListener(\"mouseup\", onUp);\n  svg.addEventListener(\"touchstart\", onDown, { passive: false });\n  window.addEventListener(\"touchmove\", onMove, { passive: false });\n  window.addEventListener(\"touchend\", onUp);\n\n  svg.addEventListener(\"dblclick\", function () {\n    push(spec.idx, spec.def);\n    render();\n  });\n  svg.addEventListener(\"wheel\", function (e) {\n    setNorm(norm() - e.deltaY * 0.0006);\n    e.preventDefault();\n  }, { passive: false });\n\n  render();\n  return wrap;\n}\n\n// ===============================================================\n//  MODE BUTTONS\n// ===============================================================\nvar modeBtns = [];\nfunction buildModes() {\n  var host = document.getElementById(\"modes\");\n  var subs = [\"Subtle\", \"Wide\", \"Lush\", \"Vast\"];\n  for (var i = 0; i < 4; i++) {\n    (function (m) {\n      var b = document.createElement(\"div\");\n      b.className = \"modebtn\";\n      b.innerHTML =\n        '<div class=\"lamp\"></div>' +\n        '<div class=\"num\">' + MODE_NAMES[m] + '</div>' +\n        '<div class=\"sub\">' + subs[m] + '</div>';\n      b.addEventListener(\"click\", function () { selectMode(m); });\n      host.appendChild(b);\n      modeBtns.push(b);\n    })(i);\n  }\n}\nfunction selectMode(m) {\n  push(P_MODE, m);\n  for (var i = 0; i < modeBtns.length; i++) {\n    modeBtns[i].classList.toggle(\"on\", i === m);\n  }\n  document.getElementById(\"modeName\").textContent = \"MODE \" + MODE_NAMES[m];\n}\n\n// ===============================================================\n//  DIMENSIONAL FIELD  (animated stereo-bloom visualiser)\n// ===============================================================\nvar cv = document.getElementById(\"field\");\nvar ctx = cv.getContext(\"2d\");\nvar W = 0, H = 0, DPR = Math.min(window.devicePixelRatio || 1, 2);\n\nfunction resize() {\n  var r = cv.getBoundingClientRect();\n  W = r.width; H = r.height;\n  cv.width = Math.round(W * DPR);\n  cv.height = Math.round(H * DPR);\n  ctx.setTransform(DPR, 0, 0, DPR, 0, 0);\n}\nwindow.addEventListener(\"resize\", resize);\n\nvar t = 0;\nfunction draw() {\n  if (document.hidden) { requestAnimationFrame(draw); return; }\n  t += 0.016;\n  ctx.clearRect(0, 0, W, H);\n\n  var cx = W / 2, cy = H / 2;\n  var width = values[P_WIDTH];   // 0..1\n  var depth = values[P_DEPTH];   // 0..1\n  var mix = values[P_MIX];       // 0..1\n  var mode = Math.round(values[P_MODE]);\n  var rate = 0.5 + mode * 0.45;\n\n  // faint grid that breathes\n  ctx.lineWidth = 1;\n  ctx.strokeStyle = \"rgba(143,182,255,0.05)\";\n  for (var gx = 0; gx <= W; gx += 28) {\n    ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, H); ctx.stroke();\n  }\n\n  // central origin dot — the mono source\n  var pulse = 0.5 + 0.5 * Math.sin(t * 2);\n  ctx.beginPath();\n  ctx.arc(cx, cy, 4 + pulse * 2, 0, Math.PI * 2);\n  ctx.fillStyle = \"rgba(255,255,255,0.95)\";\n  ctx.shadowColor = \"#b0e0ff\";\n  ctx.shadowBlur = 18;\n  ctx.fill();\n  ctx.shadowBlur = 0;\n\n  // the bloom: two clouds of points drifting out L and R, modulated\n  var spread = (0.12 + width * 0.78) * (W * 0.5 - 14);\n  var verticalRange = H * 0.34 * (0.4 + depth * 0.6);\n  var pairs = 26;\n\n  for (var s = -1; s <= 1; s += 2) {           // -1 = L cloud, +1 = R cloud\n    for (var i = 0; i < pairs; i++) {\n      var ph = i / pairs;\n      // each particle orbits with a phase, modulated by depth + LFO\n      var wob = Math.sin(t * rate * Math.PI + ph * 7 + (s > 0 ? 1.6 : 0)) * depth;\n      var x = cx + s * spread * (0.3 + 0.7 * ph) * (0.9 + 0.1 * wob);\n      var y = cy + Math.sin(ph * Math.PI * 2 + t * rate + s) * verticalRange * (0.5 + 0.5 * ph);\n      var rad = 2.6 * (1 - ph * 0.6) + pulse * 0.8;\n      var alpha = (1 - ph * 0.7) * (0.25 + mix * 0.65);\n\n      ctx.beginPath();\n      ctx.arc(x, y, rad, 0, Math.PI * 2);\n      var grad = ctx.createRadialGradient(x, y, 0, x, y, rad * 3);\n      grad.addColorStop(0, \"rgba(176,224,255,\" + alpha.toFixed(3) + \")\");\n      grad.addColorStop(1, \"rgba(143,182,255,0)\");\n      ctx.fillStyle = grad;\n      ctx.fill();\n\n      // connective thread back toward origin (depth/width tracery)\n      ctx.beginPath();\n      ctx.moveTo(cx, cy);\n      ctx.lineTo(x, y);\n      ctx.strokeStyle = \"rgba(143,182,255,\" + (alpha * 0.12).toFixed(3) + \")\";\n      ctx.stroke();\n    }\n  }\n\n  // expanding \"dimension\" ring whose radius tracks width\n  var ringR = (W * 0.18 + width * W * 0.30) * (0.92 + 0.08 * pulse);\n  ctx.beginPath();\n  ctx.ellipse(cx, cy, ringR, ringR * 0.5 * (0.5 + depth), 0, 0, Math.PI * 2);\n  ctx.strokeStyle = \"rgba(176,224,255,\" + (0.10 + width * 0.18).toFixed(3) + \")\";\n  ctx.lineWidth = 1.5;\n  ctx.stroke();\n\n  requestAnimationFrame(draw);\n}\n\n// ===============================================================\n//  INIT\n// ===============================================================\nfunction start() {\n  // knobs (skip Mode — it has its own buttons)\n  var khost = document.getElementById(\"knobs\");\n  [SPEC[P_DEPTH], SPEC[P_WIDTH], SPEC[P_MIX]].forEach(function (sp) {\n    khost.appendChild(buildKnob(sp));\n  });\n\n  buildModes();\n\n  // push all defaults to the engine\n  SPEC.forEach(function (p) { push(p.idx, p.def); });\n  selectMode(Math.round(values[P_MODE]));\n\n  resize();\n  requestAnimationFrame(draw);\n}\n\nif (window.vstai && window.vstai.onReady) {\n  window.vstai.onReady(start);\n} else {\n  start();\n}\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DIMENSIONAL — dimensional BBD-style stereo chorus\n//  Two short bucket-brigade delay lines per channel, gently pitch-\n//  modulated by quadrature LFOs and cross-fed L<->R. The modulation is\n//  deliberately subtle: it widens and animates a mono source into a\n//  spacious stereo image with very little obvious wobble. A Mode selector\n//  (1..4) picks four intensity presets in the classic dimensional spirit.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay lines — one per channel. Sized for ~40 ms at 96 kHz (plenty).\nconst DLEN: i32 = 4096;\nconst DMASK: i32 = DLEN - 1;\nconst dlineL: StaticArray<f32> = new StaticArray<f32>(DLEN);\nconst dlineR: StaticArray<f32> = new StaticArray<f32>(DLEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// write head + per-channel LFO phases (quadrature => stereo motion)\nlet widx: i32 = 0;\nlet phaseL: f32 = 0.0;\nlet phaseR: f32 = 0.25; // 90° apart for stereo de-correlation\n\n// one-pole smoothers for the modulated delay (BBD-ish gentle top loss)\nlet bbdL: f32 = 0.0;\nlet bbdR: f32 = 0.0;\n\nconst P_MODE:  i32 = 0;  // 0..3 (step 1) -> four intensity presets\nconst P_DEPTH: i32 = 1;  // 0..1 modulation depth\nconst P_WIDTH: i32 = 2;  // 0..1 stereo cross-feed / spread\nconst P_MIX:   i32 = 3;  // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DLEN; i++) { dlineL[i] = 0.0; dlineR[i] = 0.0; }\n  widx = 0;\n  phaseL = 0.0;\n  phaseR = 0.25;\n  bbdL = 0.0;\n  bbdR = 0.0;\n  params[P_MODE]  = 0.0;\n  params[P_DEPTH] = 0.5;\n  params[P_WIDTH] = 0.6;\n  params[P_MIX]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fractional read from a delay line, linear interpolation. `delay` in samples.\n@inline function readDelay(line: StaticArray<f32>, wi: i32, delay: f32): f32 {\n  let d: f32 = delay;\n  if (d < 1.0) d = 1.0;\n  const rp: f32 = f32(wi) - d;\n  let i0: i32 = i32(Mathf.floor(rp));\n  const frac: f32 = rp - f32(i0);\n  i0 = i0 & DMASK; if (i0 < 0) i0 += DLEN;\n  let i1: i32 = (i0 + 1) & DMASK;\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const mode: i32 = i32(clampf(params[P_MODE], 0.0, 3.0) + 0.5);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Four intensity presets (rate Hz, base delay ms, sweep ms, cross-feed).\n  // Higher modes = a touch faster + deeper + wider, in the dimensional spirit.\n  let rateHz: f32 = 0.45;\n  let baseMs: f32 = 4.0;\n  let sweepMs: f32 = 1.4;\n  let xfeed: f32 = 0.30;\n  if (mode == 1) { rateHz = 0.55; baseMs = 5.0; sweepMs = 1.9; xfeed = 0.45; }\n  else if (mode == 2) { rateHz = 0.72; baseMs = 6.5; sweepMs = 2.6; xfeed = 0.62; }\n  else if (mode == 3) { rateHz = 0.95; baseMs = 8.0; sweepMs = 3.4; xfeed = 0.80; }\n\n  const baseSmp: f32 = baseMs * 0.001 * sampleRate;\n  const sweepSmp: f32 = sweepMs * 0.001 * sampleRate * depthN;\n  const inc: f32 = rateHz / sampleRate;\n\n  // cross-feed amount scaled by Width; the wet of each side mixes the\n  // opposite channel's modulated tap to throw the image wide.\n  const cross: f32 = xfeed * widthN;\n  const direct: f32 = 1.0 - 0.5 * cross;\n\n  // gentle BBD top-end softening coefficient (~one-pole LP near 6 kHz)\n  const bbdC: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * 6000.0 / sampleRate)), 0.0, 1.0);\n\n  const baseL: i32 = 0;\n  const baseR: i32 = MAX_FRAMES;\n\n  let pL: f32 = phaseL;\n  let pR: f32 = phaseR;\n  let wi: i32 = widx;\n  let zL: f32 = bbdL;\n  let zR: f32 = bbdR;\n\n  for (let f = 0; f < n; f++) {\n    const inL: f32 = inBuf[baseL + f];\n    const inR: f32 = channels > 1 ? inBuf[baseR + f] : inL;\n\n    // write into the delay lines\n    dlineL[wi] = inL;\n    dlineR[wi] = inR;\n\n    // quadrature LFOs -> two opposing modulated delays\n    const modL: f32 = Mathf.sin(PI2 * pL);\n    const modR: f32 = Mathf.sin(PI2 * pR);\n    const delL: f32 = baseSmp + sweepSmp * modL;\n    const delR: f32 = baseSmp - sweepSmp * modR;\n\n    let tapL: f32 = readDelay(dlineL, wi, delL);\n    let tapR: f32 = readDelay(dlineR, wi, delR);\n\n    // BBD softening\n    zL = zL + bbdC * (tapL - zL);\n    zR = zR + bbdC * (tapR - zR);\n    tapL = zL;\n    tapR = zR;\n\n    // cross-feed for width: each side gets its own tap plus a slice of the other\n    const wetL: f32 = direct * tapL + cross * tapR;\n    const wetR: f32 = direct * tapR + cross * tapL;\n\n    outBuf[baseL + f] = inL * (1.0 - mix) + wetL * mix;\n    if (channels > 1) outBuf[baseR + f] = inR * (1.0 - mix) + wetR * mix;\n\n    wi = (wi + 1) & DMASK;\n    pL += inc; if (pL >= 1.0) pL -= 1.0;\n    pR += inc; if (pR >= 1.0) pR -= 1.0;\n  }\n\n  phaseL = pL;\n  phaseR = pR;\n  widx = wi;\n  bbdL = zL;\n  bbdR = zR;\n}\n",
  "publishedAt": 1751000043000
}