{
  "format": 1,
  "name": "Edge Echo",
  "isInstrument": false,
  "explanation": "A bright rackmount digital delay with a coloured input preamp. The preamp adds drive and presence for the punchy, present 'edge' tone, feeding clean, slightly bright digital repeats with filtered feedback. Controls: preamp Drive, delay Time (20 ms to ~1.2 s), Feedback, repeat Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Drive",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Time",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.38
    },
    {
      "name": "Feedback",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Edge Echo</title>\n<style>\n  :root{ --acc:#6ad0ff; --acc2:#b0a0ff; --bg0:#070a0e; --bg1:#0d141c; --ink:#dceaf2; --dim:#5e7686; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#16222e 0%,var(--bg1) 42%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(94vw,760px); border-radius:14px; padding:16px 20px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#1c2a36,#0a1118);\n    border:1px solid rgba(120,200,255,.16);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(190,230,255,.06); }\n  /* rack ears */\n  .unit::before,.unit::after{ content:\"\"; position:absolute; top:8px; bottom:8px; width:12px; border-radius:4px;\n    background:repeating-linear-gradient(180deg,#243441 0 6px,#1a2630 6px 12px); }\n  .unit::before{ left:6px;} .unit::after{ right:6px;}\n  header{ display:flex; align-items:center; gap:12px; margin:0 18px 12px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .readout{ margin-left:auto; font-variant-numeric:tabular-nums; font-size:15px; letter-spacing:.08em;\n    color:#7fffce; text-shadow:0 0 8px rgba(80,255,180,.7); background:#06120c; padding:3px 10px; border-radius:5px;\n    border:1px solid rgba(80,255,180,.25); }\n\n  .stage{ position:relative; z-index:2; margin:0 18px; }\n  .screen{ height:110px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#0a121a,#0c1820); border:1px solid rgba(120,200,255,.14); box-shadow:inset 0 2px 20px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.26em; color:var(--dim); z-index:2; }\n\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:6px 2px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(150,200,230,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(106,208,255,.6)); }\n  .pcap{ fill:#0c1620; stroke:rgba(120,200,255,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:10px; letter-spacing:.14em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(106,208,255,.08);\n    padding:1px 8px; border-radius:7px; border:1px solid rgba(106,208,255,.18); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">EDGE&nbsp;ECHO</span>\n      <span class=\"sub\">preamp digital delay</span>\n      <span class=\"readout\" id=\"ro\">— ms</span>\n    </header>\n    <div class=\"stage\">\n      <div class=\"screen\"><div class=\"scrlbl\">REPEATS</div><canvas id=\"cv\"></canvas></div>\n      <div class=\"knobs\" id=\"knobs\"></div>\n    </div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var PARAMS=[\n    {name:\"Drive\",idx:0,def:0.45},\n    {name:\"Time\", idx:1,def:0.38},\n    {name:\"Feedback\",idx:2,def:0.4},\n    {name:\"Tone\", idx:3,def:0.6},\n    {name:\"Mix\",  idx:4,def:0.35}\n  ];\n  var vals={}; PARAMS.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function fmtTime(v){ var ms=Math.round(20+v*1180); return ms>=1000?(ms/1000).toFixed(2)+\" s\":ms+\" ms\"; }\n  function fmt(p,v){ return p.name===\"Time\"?fmtTime(v):Math.round(v*100)+\"%\"; }\n  var ro=document.getElementById(\"ro\");\n\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var wrap=document.getElementById(\"knobs\");\n  var knobs=PARAMS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#6ad0ff\"/><stop offset=\"1\" stop-color=\"#b0a0ff\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle>'+\n      '<line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    wrap.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){\n      var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2));\n      ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2));\n      val.textContent=fmt(p,v);\n      if(p.idx===1 && ro) ro.textContent=fmtTime(v);\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- repeats visualization: an impulse re-triggers, echoes march across, fading by feedback ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  var pulses=[]; var acc=0, last=0;\n  function frame(ts){\n    if(!last)last=ts; var dt=Math.min(50,ts-last); last=ts; acc+=dt;\n    var time=vals[1], fb=vals[2], drive=vals[0], tone=vals[3];\n    var gapMs=120+time*900; // visual spacing follows Time\n    if(acc>gapMs*0.9){ acc=0; pulses.push({t:0, born:ts}); }\n    ctx.clearRect(0,0,W,H);\n    // base line\n    ctx.strokeStyle=\"rgba(106,208,255,0.12)\"; ctx.lineWidth=1;\n    ctx.beginPath(); ctx.moveTo(0,H*0.62); ctx.lineTo(W,H*0.62); ctx.stroke();\n    // input \"edge\" marker on the left, brighter with drive\n    var gx=14;\n    ctx.fillStyle=\"rgba(176,160,255,\"+(0.5+0.5*drive)+\")\"; ctx.shadowColor=\"#b0a0ff\"; ctx.shadowBlur=10+drive*14;\n    ctx.fillRect(gx-3,H*0.18,6,H*0.44); ctx.shadowBlur=0;\n    // echoes march right, amplitude decays by feedback\n    var spacing=(W-40)/8;\n    for(var i=pulses.length-1;i>=0;i--){\n      var p=pulses[i]; p.t+=dt*0.05*(0.5+ (1-time)*0.8);\n      if(p.t>9){ pulses.splice(i,1); continue; }\n      for(var k=1;k<=8;k++){\n        var x=gx+spacing*k - (p.t*0); // static comb positions, animate brightness\n        var amp=Math.pow(0.55+fb*0.42,k)*(1-Math.min(1,Math.abs(p.t-k)));\n        if(amp<=0.01) continue;\n        var h=amp*(H*0.40);\n        var hue=tone; var col=\"rgba(\"+Math.round(106+ (1-tone)*60)+\",\"+Math.round(208*0.7+tone*60)+\",\"+Math.round(255)+\",\"+amp+\")\";\n        ctx.fillStyle=col; ctx.shadowColor=\"#6ad0ff\"; ctx.shadowBlur=6*amp;\n        ctx.fillRect(x-2, H*0.62-h, 4, h*1.0);\n        ctx.shadowBlur=0;\n      }\n    }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function boot(){ host=window.vstai||null; PARAMS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  EDGE ECHO — a bright rack DIGITAL DELAY with a coloured input PREAMP.\n//  Lineage: the early-80s programmable rackmount digital delay (Korg\n//  SDD-3000 family) famous for a punchy, present \"edge\" tone — its input\n//  PREAMP adds drive/presence before clean, slightly bright digital\n//  repeats. Distinct from the pristine/tape/BBD echoes already in the\n//  factory by that preamp colour + crisp rhythmic repeats.\n//\n//  Signal: in -> preamp drive (soft clip + presence tilt) -> delay line\n//          with filtered feedback -> dry/wet mix.\n//  Pure algorithm, no host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst DLEN: i32 = 131072;          // ~2.7 s @ 48k, power of two\nconst DMASK: i32 = DLEN - 1;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst dlL: StaticArray<f32> = new StaticArray<f32>(DLEN);\nconst dlR: StaticArray<f32> = new StaticArray<f32>(DLEN);\n\nlet sampleRate: f32 = 48000.0;\nlet wp: i32 = 0;            // write pointer\nlet lpL: f32 = 0.0;        // feedback tone state\nlet lpR: f32 = 0.0;\nlet preL: f32 = 0.0;       // preamp presence-tilt state\nlet preR: f32 = 0.0;\nlet curDelay: f32 = 12000.0; // smoothed delay length in samples\n\nconst P_DRIVE: i32 = 0;    // preamp drive / presence\nconst P_TIME:  i32 = 1;    // delay time\nconst P_FB:    i32 = 2;    // feedback\nconst P_TONE:  i32 = 3;    // repeat tone (HF damping)\nconst P_MIX:   i32 = 4;    // dry/wet\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function satf(x: f32): f32 { const c: f32 = clampf(x, -3.0, 3.0); return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c)); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  wp = 0; lpL = 0.0; lpR = 0.0; preL = 0.0; preR = 0.0;\n  for (let i = 0; i < DLEN; i++) { dlL[i] = 0.0; dlR[i] = 0.0; }\n  curDelay = 0.18 * sampleRate;\n  params[P_DRIVE] = 0.45;\n  params[P_TIME]  = 0.38;\n  params[P_FB]    = 0.4;\n  params[P_TONE]  = 0.6;\n  params[P_MIX]   = 0.35;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const drive: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const timeN: f32 = clampf(params[P_TIME],  0.0, 1.0);\n  const fbN:   f32 = clampf(params[P_FB],    0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE],  0.0, 1.0);\n  const mix:   f32 = clampf(params[P_MIX],   0.0, 1.0);\n\n  // delay time: ~20 ms .. ~1.2 s\n  const tgtDelay: f32 = (0.02 + timeN * 1.18) * sampleRate;\n  const dSmooth: f32 = 0.0006;\n\n  // preamp: drive into a soft clip + a presence tilt (high shelf-ish)\n  const preGain: f32 = 1.0 + drive * 4.0;\n  const presence: f32 = 0.15 + drive * 0.55;     // amount of HF emphasis\n\n  // feedback amount (bounded < 1 for stability)\n  const fb: f32 = fbN * 0.92;\n  // repeat tone: bright (toneN high) -> less damping\n  const damp: f32 = 0.05 + (1.0 - toneN) * 0.85;\n\n  const dry: f32 = 1.0 - mix * 0.5;   // gentle dry attenuation so wet sits in\n  const wet: f32 = mix;\n  const stereo: i32 = 1;\n\n  for (let i = 0; i < n; i++) {\n    curDelay += (tgtDelay - curDelay) * dSmooth;\n\n    let xl: f32 = inBuf[i];\n    let xr: f32 = inBuf[MAX_FRAMES + i];\n\n    // ---- input PREAMP: presence tilt then soft drive ----\n    preL += (xl - preL) * 0.5; const hpl: f32 = xl - preL; // crude HP for presence\n    preR += (xr - preR) * 0.5; const hpr: f32 = xr - preR;\n    let dl: f32 = satf((xl + hpl * presence) * preGain) * (0.7 / (0.7 + drive * 0.6));\n    let dr: f32 = satf((xr + hpr * presence) * preGain) * (0.7 / (0.7 + drive * 0.6));\n\n    // ---- read delayed (linear interpolation) ----\n    const rp: f32 = f32(wp) - curDelay;\n    let ri: i32 = i32(rp);\n    const fr: f32 = rp - f32(ri);\n    const a0: i32 = ri & DMASK;\n    const a1: i32 = (ri + 1) & DMASK;\n    let yL: f32 = dlL[a0] + (dlL[a1] - dlL[a0]) * fr;\n    let yR: f32 = dlR[a0] + (dlR[a1] - dlR[a0]) * fr;\n\n    // ---- damp the repeats (one-pole LP in feedback) ----\n    lpL += (yL - lpL) * (1.0 - damp); const fbL: f32 = lpL;\n    lpR += (yR - lpR) * (1.0 - damp); const fbR: f32 = lpR;\n\n    // ---- write input + feedback ----\n    dlL[wp] = clampf(dl + fbL * fb, -1.5, 1.5);\n    dlR[wp] = clampf(dr + fbR * fb, -1.5, 1.5);\n    wp = (wp + 1) & DMASK;\n\n    // ---- mix ----\n    let ol: f32 = xl * dry + yL * wet;\n    let orr: f32 = xr * dry + yR * wet;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[i] = ol;\n    outBuf[MAX_FRAMES + i] = stereo ? orr : ol;\n  }\n}\n",
  "publishedAt": 1751000152000
}