{
  "format": 1,
  "name": "Pitch Snap",
  "isInstrument": false,
  "explanation": "A real-time pitch corrector in the Antares Auto-Tune lineage. It detects the input's pitch by autocorrelation, snaps it to the nearest note of the chosen scale, and shifts the audio to that pitch with a crossfaded two-grain delay-line shifter. Fast retune gives the robotic 'T-Pain' snap; slow gives natural correction. Controls: Speed (retune time), Amount (correction strength), Key (chromatic / major / minor / fifths), Mix and Output. Works best on monophonic, pitched input.",
  "params": [
    {
      "name": "Speed",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Amount",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.8
    },
    {
      "name": "Key",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pitch Snap</title>\n<style>\n  :root{ --acc:#43e0c4; --acc2:#ff5a8c; --bg0:#070d0c; --bg1:#0e1a18; --ink:#e4f4f0; --dim:#5e8480; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#0f2a28 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(94vw,720px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#143230,#070f0e); border:1px solid rgba(67,224,196,.2); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(200,255,245,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 1.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:100px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0a1c1a,#0a1312); border:1px solid rgba(67,224,196,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(180,230,225,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(67,224,196,.6)); }\n  .pcap{ fill:#0a1614; stroke:rgba(67,224,196,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(67,224,196,.1); padding:1px 8px; border-radius:7px; border:1px solid rgba(67,224,196,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">PITCH&nbsp;SNAP</span><span class=\"sub\">pitch correction</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">NOTE GRID</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var KEYS=[\"Chromatic\",\"Major\",\"Minor\",\"Fifths\"];\n  var P=[{name:\"Speed\",idx:0,def:0.6},{name:\"Amount\",idx:1,def:0.8},{name:\"Key\",idx:2,def:0.0},{name:\"Mix\",idx:3,def:1.0},{name:\"Output\",idx:4,def:0.7}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function keyName(){ var k=Math.floor(vals[2]*3.999); return KEYS[k<0?0:(k>3?3:k)]; }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#43e0c4\"/><stop offset=\"1\" stop-color=\"#ff5a8c\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle><circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle><line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2));\n      val.textContent=(p.idx===2)?keyName():Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def); return {render:render};\n  });\n  // note-grid with a wandering \"detected\" pitch that snaps toward grid lines (speed/amount)\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  var trail=[];\n  function frame(ts){ ctx.clearRect(0,0,W,H); var rows=8; var amt=vals[1], spd=vals[0];\n    for(var r=0;r<rows;r++){ var y=10+r*((H-20)/(rows-1)); ctx.strokeStyle=\"rgba(67,224,196,0.12)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(10,y); ctx.lineTo(W-10,y); ctx.stroke(); }\n    var raw=3.5+2.6*Math.sin(ts/700)+0.6*Math.sin(ts/130);\n    var snapped=Math.round(raw); var cur=raw+(snapped-raw)*amt*(0.3+spd*0.7);\n    trail.push(cur); if(trail.length>90) trail.shift();\n    ctx.beginPath();\n    for(var i=0;i<trail.length;i++){ var x=10+(i/89)*(W-20); var yy=10+(trail[i]/(rows-1))*(H-20); if(i===0)ctx.moveTo(x,yy); else ctx.lineTo(x,yy); }\n    ctx.strokeStyle=\"rgba(255,90,140,0.9)\"; ctx.lineWidth=2; ctx.shadowColor=\"#ff5a8c\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    // dot at current\n    var dx=W-12, dy=10+(cur/(rows-1))*(H-20); ctx.fillStyle=\"#43e0c4\"; ctx.beginPath(); ctx.arc(dx,dy,3,0,Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  PITCH SNAP — a real-time pitch corrector (Antares Auto-Tune lineage).\n//  Detects the input's pitch by autocorrelation, snaps it to the nearest\n//  note of the chosen scale, and shifts the audio to that pitch with a\n//  crossfaded two-grain delay-line shifter. Fast retune = the robotic\n//  \"T-Pain\" snap; slow = natural correction. Controls: Speed (retune\n//  time), Amount (correction strength), Key (scale), Mix, Output.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst HIST: i32 = 8192; const HMASK: i32 = HIST - 1;\nconst GLEN: f32 = 1024.0;       // grain length (samples)\nconst WIN: i32 = 1024;          // autocorrelation window\nconst HOP: i32 = 512;\nconst MINLAG: i32 = 48;         // ~1 kHz @48k\nconst MAXLAG: i32 = 760;        // ~63 Hz @48k\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst hist: StaticArray<f32> = new StaticArray<f32>(HIST);\nlet wp: i32 = 0;\nlet hopCount: i32 = 0;\nlet detFreq: f32 = 220.0;\nlet ratio: f32 = 1.0;\nlet smRatio: f32 = 1.0;\nlet g0: f32 = 0.0; let g1: f32 = 0.5;\nlet sampleRate: f32 = 48000.0;\n\nconst P_SPEED: i32 = 0; const P_AMOUNT: i32 = 1; const P_KEY: i32 = 2; const P_MIX: i32 = 3; const P_OUTPUT: i32 = 4;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  wp = 0; hopCount = 0; detFreq = 220.0; ratio = 1.0; smRatio = 1.0; g0 = 0.0; g1 = 0.5;\n  for (let i = 0; i < HIST; i++) hist[i] = 0.0;\n  params[P_SPEED] = 0.6; params[P_AMOUNT] = 0.8; params[P_KEY] = 0.0; params[P_MIX] = 1.0; params[P_OUTPUT] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// snap a frequency to the nearest scale note (key: 0 chromatic, 1 major, 2 minor, 3 fifths)\nfunction snapFreq(f: f32, key: i32): f32 {\n  if (f < 20.0) return f;\n  const midi: f32 = 69.0 + 12.0 * f32(Mathf.log2(f / 440.0));\n  let m: i32 = i32(midi + 0.5);\n  // quantise to scale within the octave\n  const pc: i32 = ((m % 12) + 12) % 12;\n  if (key == 1) { // major\n    const maj: bool = pc==0||pc==2||pc==4||pc==5||pc==7||pc==9||pc==11;\n    if (!maj) m += 1;\n  } else if (key == 2) { // minor\n    const mn: bool = pc==0||pc==2||pc==3||pc==5||pc==7||pc==8||pc==10;\n    if (!mn) m += 1;\n  } else if (key == 3) { // fifths (root + fifth)\n    if (!(pc==0||pc==7)) { m = pc < 4 ? m - pc : (pc < 10 ? m + (7 - pc) : m + (12 - pc)); }\n  }\n  return f32(440.0 * Mathf.pow(2.0, (f32(m) - 69.0) / 12.0));\n}\n\nfunction detect(): void {\n  // autocorrelation over the last WIN samples ending at wp\n  let bestLag: i32 = 0; let best: f32 = 0.0; let e0: f32 = 0.0001;\n  for (let i = 0; i < WIN; i++) { const v = hist[(wp - 1 - i) & HMASK]; e0 += v * v; }\n  for (let lag = MINLAG; lag <= MAXLAG; lag++) {\n    let ac: f32 = 0.0;\n    for (let i = 0; i < WIN; i += 2) {\n      ac += hist[(wp - 1 - i) & HMASK] * hist[(wp - 1 - i - lag) & HMASK];\n    }\n    if (ac > best) { best = ac; bestLag = lag; }\n  }\n  const norm: f32 = best / (e0 * 0.5);\n  if (bestLag > 0 && norm > 0.25) {\n    detFreq = sampleRate / f32(bestLag);\n  }\n}\n\nexport function process(n: i32): void {\n  const speedN: f32 = clampf(params[P_SPEED], 0.0, 1.0);\n  const amountN: f32 = clampf(params[P_AMOUNT], 0.0, 1.0);\n  let key: i32 = i32(clampf(params[P_KEY], 0.0, 1.0) * 3.999); if (key < 0) key = 0; if (key > 3) key = 3;\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const outLevel: f32 = 0.5 + clampf(params[P_OUTPUT], 0.0, 1.0) * 1.0;\n\n  // retune smoothing: fast (robotic) .. slow (natural)\n  const speedCoef: f32 = f32(Mathf.exp(-1.0 / ((0.002 + (1.0 - speedN) * 0.18) * sampleRate)));\n  const dry: f32 = 1.0 - mix;\n  const gInc: f32 = 1.0 / GLEN;\n\n  for (let i = 0; i < n; i++) {\n    const xl: f32 = inBuf[i];\n    const xr: f32 = inBuf[MAX_FRAMES + i];\n    const x: f32 = (xl + xr) * 0.5;\n    hist[wp] = x;\n\n    if (hopCount <= 0) { detect(); hopCount = HOP; }\n    hopCount -= 1;\n\n    // target ratio toward the snapped note, scaled by Amount\n    const tgt: f32 = snapFreq(detFreq, key);\n    let r: f32 = detFreq > 1.0 ? tgt / detFreq : 1.0;\n    r = clampf(r, 0.5, 2.0);\n    ratio = 1.0 + (r - 1.0) * amountN;\n    smRatio += (ratio - smRatio) * (1.0 - speedCoef);\n\n    // two-grain crossfaded pitch shift\n    g0 += (smRatio - 1.0) * gInc; g0 -= f32(Mathf.floor(g0));\n    g1 += (smRatio - 1.0) * gInc; g1 -= f32(Mathf.floor(g1));\n    const d0: f32 = g0 * GLEN; const d1: f32 = g1 * GLEN;\n    const rp0: f32 = f32(wp) - d0; const rp1: f32 = f32(wp) - d1;\n    let i0: i32 = i32(rp0); const f0: f32 = rp0 - f32(i0);\n    let i1: i32 = i32(rp1); const f1: f32 = rp1 - f32(i1);\n    const s0: f32 = hist[i0 & HMASK] + (hist[(i0 + 1) & HMASK] - hist[i0 & HMASK]) * f0;\n    const s1: f32 = hist[i1 & HMASK] + (hist[(i1 + 1) & HMASK] - hist[i1 & HMASK]) * f1;\n    // hann-ish crossfade windows (zero at wrap point)\n    const w0: f32 = 0.5 - 0.5 * f32(Mathf.cos(g0 * 6.2831853));\n    const w1: f32 = 0.5 - 0.5 * f32(Mathf.cos(g1 * 6.2831853));\n    let wet: f32 = (s0 * w0 + s1 * w1);\n\n    wp = (wp + 1) & HMASK;\n\n    let o: f32 = (x * dry + wet * mix) * outLevel;\n    if (o > 1.5) o = 1.5; else if (o < -1.5) o = -1.5;\n    outBuf[i] = o;\n    outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000176000
}