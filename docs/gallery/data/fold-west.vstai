  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Fold West</title>\n<style>\n  :root{ --acc:#e0d060; --acc2:#d05040; --bg0:#100c06; --bg1:#1d1609; --ink:#f6efdc; --dim:#988a66; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#2c2410 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#241c0e,#100c06); border:1px solid rgba(224,208,96,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(246,239,220,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.0s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:104px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#1a140a,#0f0b06); border:1px solid rgba(224,208,96,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(232,224,200,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(224,208,96,.6)); }\n  .pcap{ fill:#18120a; stroke:rgba(224,208,96,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(224,208,96,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(224,208,96,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">FOLD&nbsp;WEST</span><span class=\"sub\">wavefolder complex-osc</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">WAVEFOLDER</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Fold\",idx:0,def:0.5},{name:\"Timbre\",idx:1,def:0.4},{name:\"Cutoff\",idx:2,def:0.7},{name:\"Env\",idx:3,def:0.6},{name:\"Decay\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#e0d060\"/><stop offset=\"1\" stop-color=\"#d05040\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var fold=vals[0], timbre=vals[1], env=vals[3]; var mid=H*0.52;\n    var foldE=Math.exp(-((ts/1300)%1)*(1+env*3));\n    var foldAmt=1+fold*7*(1-env+env*foldE);\n    // folded waveform (2 cycles)\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=1.2){ var t=x/W; var ph=((t*2+ts/1400)%1);\n      var sine=Math.sin(ph*6.2831853); var tri=1-4*Math.abs(ph-0.5); var core=sine*(1-timbre)+tri*timbre;\n      var folded=Math.sin(core*foldAmt*1.5708); folded=folded*0.8+Math.sin(folded*(1+fold*2)*1.5708)*0.2;\n      ctx.lineTo(x, mid - folded*(H*0.34)); }\n    var grd=ctx.createLinearGradient(0,0,W,0); grd.addColorStop(0,\"#e0d060\"); grd.addColorStop(1,\"#d05040\");\n    ctx.strokeStyle=grd; ctx.lineWidth=2; ctx.shadowColor=\"#e0d060\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    // fold transfer-curve inset (top-right): input->output fold function\n    var iw=64, ih=40, ix=W-iw-10, iy=8;\n    ctx.strokeStyle=\"rgba(208,80,64,0.25)\"; ctx.lineWidth=1; ctx.strokeRect(ix,iy,iw,ih);\n    ctx.beginPath(); for(var xx=0;xx<=iw;xx+=2){ var inp=(xx/iw*2-1); var o=Math.sin(inp*foldAmt*1.5708); ctx.lineTo(ix+xx, iy+ih/2 - o*(ih/2-2)); }\n    ctx.strokeStyle=\"rgba(224,208,96,0.8)\"; ctx.lineWidth=1.3; ctx.stroke();\n    ctx.fillStyle=\"rgba(224,208,96,0.5)\"; ctx.font=\"7px Inter,sans-serif\"; ctx.fillText(\"FOLD ×\"+foldAmt.toFixed(1), ix, iy-1>6?iy-1:iy+ih+9);\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  FOLD WEST — a West-Coast complex-oscillator wavefolder (Serge modular\n//  lineage). Instead of subtracting harmonics with a filter, it ADDS\n//  them by folding: a sine/triangle core (morphed by TIMBRE) is driven\n//  into a smooth WAVEFOLDER whose depth blooms with an envelope, so a\n//  held note grows brighter and more metallic then settles — the classic\n//  Buchla/Serge \"timbre from folding\" movement. A gentle low-pass tames\n//  the top. 6-voice poly. Controls: Fold, Timbre, Cutoff, Env, Decay, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 6;\nconst TAU: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vPh: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFold: StaticArray<f32> = new StaticArray<f32>(NVOX);   // fold-bloom envelope\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_FOLD: i32 = 0; const P_TIMBRE: i32 = 1; const P_CUTOFF: i32 = 2; const P_ENV: i32 = 3; const P_DECAY: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vPh[i] = 0.0; vAmp[i] = 0.0; vFold[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_FOLD] = 0.5; params[P_TIMBRE] = 0.4; params[P_CUTOFF] = 0.7; params[P_ENV] = 0.6; params[P_DECAY] = 0.6; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPh[slot] = 0.0; vAmp[slot] = 0.0; vFold[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const foldN: f32 = clampf(params[P_FOLD], 0.0, 1.0);\n  const timbreN: f32 = clampf(params[P_TIMBRE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.006 * sampleRate);\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / ((0.2 + decayN * 2.6) * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.3 * sampleRate)));\n  const foldEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.6 * sampleRate)));\n  const baseCut: f32 = 200.0 * f32(Mathf.exp(cutoffN * 4.4));\n  const k: f32 = 1.2;\n  let fc: f32 = baseCut; if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n  const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n  const a1c: f32 = 1.0 / (1.0 + g * (g + k));\n  const maxFold: f32 = 7.0;\n  const out: f32 = level * 0.42;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] >= 1.0) { vAmp[s] = 1.0; vSt[s] = 3; } }\n      else if (vSt[s] == 3) { vAmp[s] *= decCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let ph: f32 = vPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; vPh[s] = ph;\n      // core wave: sine morphed toward triangle by Timbre\n      const sine: f32 = f32(Mathf.sin(ph * TAU));\n      const tri: f32 = 1.0 - 4.0 * f32(Mathf.abs(ph - 0.5));\n      let core: f32 = sine * (1.0 - timbreN) + tri * timbreN;\n      // fold-bloom envelope\n      vFold[s] *= foldEnvCoef;\n      const foldAmt: f32 = 1.0 + foldN * maxFold * (1.0 - envN + envN * vFold[s]);\n      // smooth wavefolder: repeated sine folding\n      let folded: f32 = f32(Mathf.sin(core * foldAmt * 1.5708));\n      // a touch of the second fold stage for richer harmonics at high fold\n      folded = folded * 0.8 + f32(Mathf.sin(folded * (1.0 + foldN * 2.0) * 1.5708)) * 0.2;\n      // gentle low-pass\n      const hp: f32 = (folded - (g + k) * vBp[s] - vLp[s]) * a1c;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      mix += lpN * vAmp[s] * vVel[s];\n    }\n    let o: f32 = f32(Mathf.tanh(mix * out * 1.4));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751313200000
}