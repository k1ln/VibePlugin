{
  "format": 1,
  "name": "Octave Up",
  "isInstrument": false,
  "explanation": "An octave-up fuzz: a silicon fuzz stage feeds a full-wave rectifier so the signal's negative half folds upward, ringing out a strong upper octave on top of the fuzz. The doubling is strongest on clean single notes. Controls: Fuzz, Octave, Tone and Volume.",
  "params": [
    {
      "name": "Fuzz",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Octave",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Volume",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Octave Up</title>\n<style>\n  :root {\n    --accent: #c08cff;\n    --accent2: #ff8cf0;\n    --bg0: #160a26;\n    --bg1: #2a0f47;\n    --ink: #f3e9ff;\n    --ink-dim: #b79ad6;\n    --glass: rgba(255,255,255,0.06);\n    --line: rgba(255,255,255,0.10);\n  }\n\n  * { box-sizing: border-box; -webkit-user-select: none; user-select: none; }\n\n  html, body {\n    margin: 0;\n    height: 100%;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    overflow: hidden;\n  }\n\n  /* ---------- swirling purple-haze backdrop ---------- */\n  .haze {\n    position: fixed;\n    inset: -30%;\n    z-index: 0;\n    background:\n      radial-gradient(40% 50% at 25% 30%, rgba(192,140,255,0.45), transparent 70%),\n      radial-gradient(45% 55% at 78% 65%, rgba(255,140,240,0.40), transparent 72%),\n      radial-gradient(60% 60% at 55% 90%, rgba(120,60,200,0.50), transparent 75%),\n      conic-gradient(from 0deg at 50% 50%, #2a0f47, #3a1366, #2a0f47, #45106e, #2a0f47);\n    filter: blur(40px) saturate(140%);\n    animation: swirl 38s linear infinite;\n    opacity: 0.85;\n  }\n  .haze.b {\n    inset: -40%;\n    mix-blend-mode: screen;\n    animation: swirl 26s linear infinite reverse;\n    opacity: 0.55;\n  }\n  @keyframes swirl {\n    0%   { transform: rotate(0deg)   scale(1.05); }\n    50%  { transform: rotate(180deg) scale(1.25); }\n    100% { transform: rotate(360deg) scale(1.05); }\n  }\n\n  /* film-grain / vignette */\n  .vignette {\n    position: fixed;\n    inset: 0;\n    z-index: 1;\n    pointer-events: none;\n    background: radial-gradient(120% 90% at 50% 35%, transparent 55%, rgba(8,2,18,0.75) 100%);\n  }\n\n  .wrap {\n    position: relative;\n    z-index: 2;\n    height: 100%;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: clamp(12px, 3vw, 28px);\n    gap: clamp(10px, 2vh, 20px);\n    overflow: auto;\n  }\n\n  /* ---------- header ---------- */\n  header {\n    width: 100%;\n    max-width: 760px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n  }\n  .brand { display: flex; align-items: center; gap: 14px; }\n  .sigil {\n    width: 46px; height: 46px;\n    flex: none;\n    filter: drop-shadow(0 0 10px rgba(192,140,255,0.8));\n  }\n  .title {\n    font-weight: 800;\n    font-size: clamp(20px, 3.4vw, 30px);\n    letter-spacing: 0.5px;\n    line-height: 1;\n    background: linear-gradient(92deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .subtitle {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-top: 5px;\n  }\n  .badge {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid var(--line);\n    border-radius: 999px;\n    padding: 6px 12px;\n    background: var(--glass);\n    backdrop-filter: blur(6px);\n  }\n\n  /* ---------- waveform / octave viz ---------- */\n  .scope {\n    width: 100%;\n    max-width: 760px;\n    height: clamp(120px, 22vh, 190px);\n    border-radius: 16px;\n    border: 1px solid var(--line);\n    background:\n      linear-gradient(180deg, rgba(20,6,40,0.7), rgba(8,2,20,0.85));\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.08),\n      inset 0 0 40px rgba(120,40,200,0.25),\n      0 18px 40px rgba(0,0,0,0.45);\n    position: relative;\n    overflow: hidden;\n  }\n  .scope canvas { display: block; width: 100%; height: 100%; }\n  .scope .legend {\n    position: absolute;\n    top: 10px; left: 14px;\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    display: flex; gap: 16px;\n  }\n  .legend .dot { display: inline-flex; align-items: center; gap: 6px; }\n  .legend .dot i { width: 9px; height: 9px; border-radius: 50%; display: inline-block; }\n\n  /* ---------- knob panel ---------- */\n  .panel {\n    width: 100%;\n    max-width: 760px;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: clamp(10px, 2vw, 22px);\n    padding: clamp(14px, 3vw, 26px);\n    border-radius: 20px;\n    border: 1px solid var(--line);\n    background:\n      linear-gradient(160deg, rgba(60,20,100,0.42), rgba(20,8,40,0.55));\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.10),\n      0 24px 60px rgba(0,0,0,0.5);\n    backdrop-filter: blur(10px);\n  }\n  @media (max-width: 520px) {\n    .panel { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  .knobcell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 10px;\n  }\n  .knob {\n    position: relative;\n    width: clamp(86px, 16vw, 116px);\n    height: clamp(86px, 16vw, 116px);\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { width: 100%; height: 100%; overflow: visible; display: block; }\n  .knob .cap {\n    transition: filter 0.18s ease;\n    filter: drop-shadow(0 6px 12px rgba(0,0,0,0.55));\n  }\n  .knob:hover .cap,\n  .knob.drag .cap {\n    filter: drop-shadow(0 0 14px rgba(192,140,255,0.85)) drop-shadow(0 6px 12px rgba(0,0,0,0.55));\n  }\n\n  .label {\n    font-size: 11px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .value {\n    font-size: 15px;\n    font-weight: 700;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    min-width: 48px;\n    text-align: center;\n  }\n\n  footer {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    opacity: 0.7;\n  }\n</style>\n</head>\n<body>\n  <div class=\"haze\"></div>\n  <div class=\"haze b\"></div>\n  <div class=\"vignette\"></div>\n\n  <div class=\"wrap\">\n    <header>\n      <div class=\"brand\">\n        <svg class=\"sigil\" viewBox=\"0 0 100 100\" aria-hidden=\"true\">\n          <defs>\n            <linearGradient id=\"sg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#c08cff\"/>\n              <stop offset=\"1\" stop-color=\"#ff8cf0\"/>\n            </linearGradient>\n          </defs>\n          <circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"none\" stroke=\"url(#sg)\" stroke-width=\"4\"/>\n          <path d=\"M14 64 Q32 18 50 64 Q68 18 86 64\" fill=\"none\" stroke=\"url(#sg)\" stroke-width=\"5\" stroke-linecap=\"round\"/>\n          <path d=\"M22 50 Q36 32 50 50 Q64 32 78 50\" fill=\"none\" stroke=\"#ff8cf0\" stroke-width=\"3\" stroke-linecap=\"round\" opacity=\"0.8\"/>\n        </svg>\n        <div>\n          <div class=\"title\">OCTAVE UP</div>\n          <div class=\"subtitle\">Octave&nbsp;Fuzz · Mk.I</div>\n        </div>\n      </div>\n      <div class=\"badge\">Rectified&nbsp;Octave</div>\n    </header>\n\n    <div class=\"scope\">\n      <div class=\"legend\">\n        <span class=\"dot\"><i style=\"background:#c08cff\"></i>Fuzz</span>\n        <span class=\"dot\"><i style=\"background:#ff8cf0\"></i>Octave</span>\n      </div>\n      <canvas id=\"scope\"></canvas>\n    </div>\n\n    <div class=\"panel\" id=\"panel\"></div>\n\n    <footer>Drag to turn · Double-click to reset</footer>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- param map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Fuzz\",   index: 0, min: 0, max: 1, def: 0.70 },\n    { name: \"Octave\", index: 1, min: 0, max: 1, def: 0.60 },\n    { name: \"Tone\",   index: 2, min: 0, max: 1, def: 0.55 },\n    { name: \"Volume\", index: 3, min: 0, max: 1, def: 0.70 }\n  ];\n\n  var state = {}; // index -> normalised 0..1\n  PARAMS.forEach(function (p) { state[p.index] = (p.def - p.min) / (p.max - p.min); });\n\n  // ---- host bridge ----\n  function pushParam(p) {\n    var norm = state[p.index];\n    var val = p.min + norm * (p.max - p.min);\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(p.index, val);\n    }\n    return val;\n  }\n\n  // ---- knob rendering ----\n  var R = 40, CX = 50, CY = 50;\n  var A0 = 135, A1 = 405; // sweep in degrees (270deg arc)\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) };\n  }\n  function arcPath(r, fromDeg, toDeg) {\n    var s = polar(CX, CY, r, fromDeg);\n    var e = polar(CX, CY, r, toDeg);\n    var large = (toDeg - fromDeg) % 360 > 180 ? 1 : 0;\n    return \"M \" + s.x + \" \" + s.y + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + e.x + \" \" + e.y;\n  }\n\n  function buildKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knobcell\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n\n    var ns = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(ns, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    var gid = \"kg\" + p.index;\n    svg.innerHTML =\n      '<defs>' +\n        '<radialGradient id=\"' + gid + '\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n          '<stop offset=\"0\" stop-color=\"#6a4a9e\"/>' +\n          '<stop offset=\"0.55\" stop-color=\"#3a2160\"/>' +\n          '<stop offset=\"1\" stop-color=\"#1a0e30\"/>' +\n        '</radialGradient>' +\n        '<linearGradient id=\"' + gid + 'a\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n          '<stop offset=\"0\" stop-color=\"#c08cff\"/>' +\n          '<stop offset=\"1\" stop-color=\"#ff8cf0\"/>' +\n        '</linearGradient>' +\n      '</defs>' +\n      // outer recessed well\n      '<circle cx=\"50\" cy=\"50\" r=\"46\" fill=\"#0d0620\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"/>' +\n      // track (background arc)\n      '<path d=\"' + arcPath(R, A0, A1) + '\" fill=\"none\" stroke=\"rgba(255,255,255,0.10)\" stroke-width=\"6\" stroke-linecap=\"round\"/>' +\n      // value arc\n      '<path class=\"varc\" d=\"\" fill=\"none\" stroke=\"url(#' + gid + 'a)\" stroke-width=\"6\" stroke-linecap=\"round\"/>' +\n      // knob cap body\n      '<g class=\"cap\">' +\n        '<circle cx=\"50\" cy=\"50\" r=\"30\" fill=\"url(#' + gid + ')\" stroke=\"rgba(0,0,0,0.5)\" stroke-width=\"1.5\"/>' +\n        '<circle cx=\"50\" cy=\"50\" r=\"30\" fill=\"none\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1\" transform=\"translate(0,-1)\"/>' +\n        '<line class=\"ptr\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"26\" stroke=\"#fff\" stroke-width=\"3\" stroke-linecap=\"round\"/>' +\n      '</g>';\n    knob.appendChild(svg);\n    cell.appendChild(knob);\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n    cell.appendChild(label);\n\n    var value = document.createElement(\"div\");\n    value.className = \"value\";\n    cell.appendChild(value);\n\n    var varc = svg.querySelector(\".varc\");\n    var ptr = svg.querySelector(\".ptr\");\n\n    function redraw() {\n      var n = state[p.index];\n      var ang = A0 + n * (A1 - A0);\n      // value arc from start to current\n      if (n <= 0.0001) {\n        varc.setAttribute(\"d\", \"\");\n      } else {\n        varc.setAttribute(\"d\", arcPath(R, A0, ang));\n      }\n      ptr.setAttribute(\"transform\", \"rotate(\" + (ang - 270) + \" 50 50)\");\n      var val = pushParam(p);\n      value.textContent = (val).toFixed(2);\n    }\n\n    // ---- drag interaction ----\n    var dragging = false, startY = 0, startN = 0;\n\n    function onDown(e) {\n      dragging = true;\n      knob.classList.add(\"drag\");\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startN = state[p.index];\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = startY - y;\n      var fine = (e.shiftKey) ? 0.25 : 1.0;\n      var n = startN + (dy / 200) * fine;\n      n = Math.max(0, Math.min(1, n));\n      state[p.index] = n;\n      redraw();\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      knob.classList.remove(\"drag\");\n    }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    knob.addEventListener(\"wheel\", function (e) {\n      var n = state[p.index] - Math.sign(e.deltaY) * 0.02;\n      state[p.index] = Math.max(0, Math.min(1, n));\n      redraw();\n      e.preventDefault();\n    }, { passive: false });\n\n    knob.addEventListener(\"dblclick\", function () {\n      state[p.index] = (p.def - p.min) / (p.max - p.min);\n      redraw();\n    });\n\n    p._redraw = redraw;\n    redraw();\n    return cell;\n  }\n\n  function initUI() {\n    var panel = document.getElementById(\"panel\");\n    PARAMS.forEach(function (p) { panel.appendChild(buildKnob(p)); });\n    startScope();\n  }\n\n  // ---- octave-doubling waveform visualiser ----\n  function startScope() {\n    var cv = document.getElementById(\"scope\");\n    var ctx = cv.getContext(\"2d\");\n    var W = 0, H = 0, dpr = Math.min(window.devicePixelRatio || 1, 2);\n\n    function resize() {\n      var r = cv.getBoundingClientRect();\n      W = Math.max(1, r.width); H = Math.max(1, r.height);\n      cv.width = W * dpr; cv.height = H * dpr;\n      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n    }\n    resize();\n    window.addEventListener(\"resize\", resize);\n\n    var t = 0;\n\n    function wave(x, freqMul, drive, oct) {\n      // base fundamental\n      var ph = x * 2 * Math.PI * freqMul + t;\n      var s = Math.sin(ph);\n      // fuzz: soft saturate driven by Fuzz knob\n      var d = 1 + drive * 9;\n      var fz = Math.tanh(s * d) / Math.tanh(d * 0.6 + 0.6);\n      // rectified octave path: |fz| folds, doubling pitch\n      var rect = Math.abs(fz) * 2 - 0.9;\n      return fz * (1 - oct * 0.6) + rect * oct;\n    }\n\n    function frame() {\n      if (document.hidden) { requestAnimationFrame(frame); return; }\n      t += 0.045;\n      ctx.clearRect(0, 0, W, H);\n\n      var fuzz = state[0], oct = state[1], tone = state[2], vol = state[3];\n      var mid = H * 0.5;\n      var amp = (H * 0.30) * (0.5 + vol * 0.7);\n      var freqMul = 2.2 + tone * 3.0;\n\n      // grid baseline\n      ctx.strokeStyle = \"rgba(255,255,255,0.06)\";\n      ctx.lineWidth = 1;\n      ctx.beginPath(); ctx.moveTo(0, mid); ctx.lineTo(W, mid); ctx.stroke();\n\n      // --- fuzz layer (accent 1) ---\n      drawLayer(function (x) {\n        var ph = (x / W) * 2 * Math.PI * freqMul + t;\n        var d = 1 + fuzz * 9;\n        var s = Math.sin(ph);\n        return Math.tanh(s * d) / (Math.tanh(d * 0.6 + 0.6));\n      }, \"#c08cff\", 0.55, amp * 0.85);\n\n      // --- octave layer (accent 2), glowing ---\n      ctx.save();\n      ctx.shadowColor = \"rgba(255,140,240,0.7)\";\n      ctx.shadowBlur = 12;\n      drawLayer(function (x) {\n        return wave(x / W, freqMul, fuzz, oct);\n      }, \"#ff8cf0\", 0.95, amp);\n      ctx.restore();\n\n      function drawLayer(fn, color, alpha, a) {\n        ctx.globalAlpha = alpha;\n        ctx.strokeStyle = color;\n        ctx.lineWidth = 2.2;\n        ctx.beginPath();\n        for (var x = 0; x <= W; x += 2) {\n          var y = mid - fn(x) * a;\n          if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n        }\n        ctx.stroke();\n        ctx.globalAlpha = 1;\n      }\n\n      requestAnimationFrame(frame);\n    }\n    requestAnimationFrame(frame);\n  }\n\n  // ---- boot (honour onReady) ----\n  function boot() {\n    initUI();\n    // ensure all params initialised to defaults on the engine\n    PARAMS.forEach(function (p) { pushParam(p); });\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  OCTAVE UP — octave-up fuzz\n//  A silicon-style fuzz feeding a full-wave rectifier: the rectified signal\n//  folds the fundamental's negative half up, doubling the pitch, which then\n//  rings as a strong upper octave on top of the fuzz. The octave is strongest\n//  on clean single notes (it tracks the loudest partial), and a high-pass\n//  before the rectifier emphasises the doubling. Post tone low-pass and an\n//  output level finish the voice. Pure algorithm, no samples.\n//\n//  Signal path per sample:\n//    input -> pre HP (tighten) -> fuzz gain -> hard/soft fuzz clip = FUZZ\n//    FUZZ -> full-wave rectify (|x|) -> DC-block -> normalise = OCTAVE\n//    out = blend(FUZZ, OCTAVE by P_OCTAVE) -> tone LP -> volume\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst hpState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-fuzz HP\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post-rectify DC block\nconst toneState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone LP\n\nconst P_FUZZ:   i32 = 0;  // 0..1 -> input gain 1..120\nconst P_OCTAVE: i32 = 1;  // 0..1 -> amount of rectified octave blended in\nconst P_TONE:   i32 = 2;  // 0..1 -> post LP 600..7000 Hz\nconst P_VOLUME: i32 = 3;  // 0..1 -> 0..1.2 output\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    hpState[c] = 0.0;\n    dcState[c] = 0.0;\n    toneState[c] = 0.0;\n  }\n  params[P_FUZZ] = 0.7;\n  params[P_OCTAVE] = 0.6;\n  params[P_TONE] = 0.55;\n  params[P_VOLUME] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// Asymmetric fuzz clip: hard-ish saturation with a soft knee, slightly\n// asymmetric so the fuzz keeps even-harmonic bite even before the octave.\n@inline function fuzzClip(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  // tanh-like via rational approx, then a touch of asymmetry\n  const t: f32 = c / f32(1.0 + Mathf.abs(c));\n  return f32(t + 0.08 * (t * t - 0.5));\n}\n\nexport function process(n: i32): void {\n  const fuzzN: f32 = clampf(params[P_FUZZ], 0.0, 1.0);\n  const octN: f32  = clampf(params[P_OCTAVE], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const vol: f32   = clampf(params[P_VOLUME], 0.0, 1.0) * 1.2;\n\n  // fuzz drive 1..120 (exponential feel)\n  const drive: f32 = 1.0 + fuzzN * fuzzN * 119.0;\n\n  // pre-fuzz high-pass ~150 Hz: tightens lows and helps the octave track the\n  // upper partial cleanly instead of the rectifier smearing bass.\n  const cHP: f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 150.0 / sampleRate)), 0.0, 1.0);\n  // DC blocker on the rectified path (~20 Hz) so |x| doesn't add a DC step.\n  const cDC: f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 20.0 / sampleRate)), 0.0, 1.0);\n  // post tone low-pass 600..7000 Hz\n  const toneHz: f32 = 600.0 + toneN * toneN * 6400.0;\n  const cTone: f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * toneHz / sampleRate)), 0.0, 1.0);\n\n  // gain compensation so fuzz isn't just \"louder\"; rectified path is gained\n  // to roughly match the fuzz level.\n  const comp: f32 = 1.4 / f32(Mathf.sqrt(drive));\n  // The octave blend: equal-power-ish so it's audible at low settings too.\n  const fuzzMix: f32 = f32(Mathf.sqrt(clampf(1.0 - octN * 0.85, 0.0, 1.0)));\n  const octMix: f32  = f32(Mathf.sqrt(octN)) * 1.6;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let hp: f32 = hpState[c];\n    let dc: f32 = dcState[c];\n    let tn: f32 = toneState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // pre-fuzz high-pass\n      hp = hp + cHP * (x - hp);\n      const tight: f32 = x - hp;\n\n      // FUZZ stage\n      const fuzz: f32 = fuzzClip(tight * drive) * comp;\n\n      // OCTAVE stage: full-wave rectify the fuzz, DC-block, re-centre.\n      const rect: f32 = Mathf.abs(fuzz);\n      dc = dc + cDC * (rect - dc);\n      const oct: f32 = (rect - dc) * 2.0; // re-centre + lift level\n\n      // blend fuzz + octave\n      let y: f32 = fuzz * fuzzMix + oct * octMix;\n\n      // post tone low-pass\n      tn = tn + cTone * (y - tn);\n\n      // safety clip then volume\n      const shaped: f32 = clampf(tn, -1.0, 1.0);\n      outBuf[base + f] = f32(shaped * vol);\n    }\n\n    hpState[c] = hp;\n    dcState[c] = dc;\n    toneState[c] = tn;\n  }\n}\n",
  "publishedAt": 1751000044000
}