      "max": 1,
      "default": 0.7
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Bits",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Attack",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.08
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
