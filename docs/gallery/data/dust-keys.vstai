  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Dust Keys</title>\n<style>\n  :root{ --acc:#b08cff; --acc2:#ffb86a; --bg0:#0a0710; --bg1:#160f1f; --ink:#ece3f5; --dim:#7d6e94; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#241634 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 20px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#26183a,#0c0814);\n    border:1px solid rgba(176,140,255,.18); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(220,200,255,.06); }\n  /* dust speckle */\n  .unit::after{ content:\"\"; position:absolute; inset:0; pointer-events:none; opacity:.5;\n    background-image:radial-gradient(rgba(255,184,106,.10) 1px,transparent 1px); background-size:7px 7px; }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.15em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .badge{ margin-left:auto; font-size:10px; letter-spacing:.16em; color:var(--acc2); font-variant-numeric:tabular-nums;\n    background:#1c1226; padding:3px 9px; border-radius:5px; border:1px solid rgba(255,184,106,.28); }\n\n  .screen{ height:100px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#120a1e,#0c0714); border:1px solid rgba(176,140,255,.16); box-shadow:inset 0 2px 20px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.24em; color:var(--dim); z-index:2; }\n\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(200,180,240,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(176,140,255,.6)); }\n  .pcap{ fill:#140d20; stroke:rgba(176,140,255,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(176,140,255,.1);\n    padding:1px 7px; border-radius:7px; border:1px solid rgba(176,140,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">DUST&nbsp;KEYS</span>\n      <span class=\"sub\">lo-fi sampler</span>\n      <span class=\"badge\" id=\"badge\">8-BIT</span>\n    </header>\n    <div class=\"screen\"><div class=\"scrlbl\">SAMPLE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var PARAMS=[\n    {name:\"Cutoff\",idx:0,def:0.7},\n    {name:\"Reso\",  idx:1,def:0.3},\n    {name:\"Bits\",  idx:2,def:0.45},\n    {name:\"Attack\",idx:3,def:0.08,ms:true},\n    {name:\"Decay\", idx:4,def:0.6,ms:true},\n    {name:\"Level\", idx:5,def:0.8}\n  ];\n  var vals={}; PARAMS.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function ms(v){ var m=Math.round(2+v*v*1500); return m>=1000?(m/1000).toFixed(1)+\"s\":m+\"ms\"; }\n  function fmt(p,v){ return p.ms?ms(v):Math.round(v*100)+\"%\"; }\n  var badge=document.getElementById(\"badge\");\n  function setBadge(){ var bits=Math.round(3+vals[2]*10); badge.textContent=bits+\"-BIT\"; }\n\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=PARAMS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#b08cff\"/><stop offset=\"1\" stop-color=\"#ffb86a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle>'+\n      '<circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle>'+\n      '<line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){\n      var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2));\n      ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2));\n      val.textContent=fmt(p,v);\n      if(p.idx===2) setBadge();\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n\n  // ---- quantised sample waveform: gets crunchier (stepped) as Bits drops ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H);\n    var bits=vals[2], cut=vals[0];\n    var levels=Math.max(3,Math.round(3+bits*10));     // quantisation steps to draw\n    var decim=1+Math.round((1-bits)*10);              // horizontal blockiness\n    var mid=H*0.55;\n    // baseline\n    ctx.strokeStyle=\"rgba(176,140,255,0.12)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke();\n    // build a sample-ish waveform, then quantise both axes for the lo-fi look\n    var step=Math.max(2,decim*2);\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=step){\n      var t=x/W;\n      var raw=Math.sin(t*Math.PI*6+ts/600)*0.6 + 0.3*Math.sin(t*Math.PI*13+ts/400) + 0.15*Math.sin(t*Math.PI*23);\n      raw*=(0.4+cut*0.6);\n      var q=Math.round(raw*levels)/levels;            // bit-quantise vertical\n      var y=mid - q*(H*0.36);\n      if(x===0) ctx.moveTo(x,y); else { ctx.lineTo(x,y); }\n    }\n    ctx.strokeStyle=\"rgba(176,140,255,0.95)\"; ctx.lineWidth=2; ctx.shadowColor=\"#b08cff\"; ctx.shadowBlur=7; ctx.stroke(); ctx.shadowBlur=0;\n    // golden sample-points dots\n    for(var x2=0;x2<=W;x2+=step){\n      var t2=x2/W; var raw2=Math.sin(t2*Math.PI*6+ts/600)*0.6+0.3*Math.sin(t2*Math.PI*13+ts/400)+0.15*Math.sin(t2*Math.PI*23);\n      raw2*=(0.4+cut*0.6); var q2=Math.round(raw2*levels)/levels;\n      ctx.fillStyle=\"rgba(255,184,106,0.6)\"; ctx.fillRect(x2-1, mid - q2*(H*0.36)-1, 2,2);\n    }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function boot(){ host=window.vstai||null; setBadge(); PARAMS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DUST KEYS — a LO-FI 8-bit melodic sampler (Ensoniq Mirage lineage).\n//  One ORIGINAL sampled instrument voice (a warm detuned choir/string pad,\n//  self-authored CC0) is baked in as base64 Int16 PCM @ 22050 Hz (C3),\n//  decoded at init() and played back polyphonically, pitch-tracked, with a\n//  sustain LOOP. The signature grit comes from a lo-fi stage — bit-depth\n//  reduction + sample-rate decimation (the \"Bits\" knob) — into a resonant\n//  low-pass and an ADSR. No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst SAMP_CAP: i32 = 40000;\nconst SAMP_SR: f32 = 22050.0;\nconst BASE_HZ: f32 = 130.81;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst samp: StaticArray<f32> = new StaticArray<f32>(SAMP_CAP);\nlet sampLen: i32 = 0;\nlet loopStart: i32 = 0;\n\nconst vPos:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vRate:  StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vEnv:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vState: StaticArray<i32> = new StaticArray<i32>(NVOX); // 0 off,1 attack,2 decay,3 release\nconst vAmp:   StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote:  StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\n\nlet sampleRate: f32 = 48000.0;\n// SVF filter state\nlet lp: f32 = 0.0;\nlet bp: f32 = 0.0;\n// decimator state\nlet holdV: f32 = 0.0;\nlet holdC: f32 = 0.0;\n\nconst P_CUTOFF: i32 = 0;\nconst P_RESO: i32 = 1;\nconst P_BITS: i32 = 2;\nconst P_ATTACK: i32 = 3;\nconst P_DECAY: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\n\nconst PCM_B64: string = \"\";\n\nfunction decodePCM(): void {\n  const s = PCM_B64; const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else { let val = (byte << 8) | lo; if (val >= 32768) val -= 65536; if (si < SAMP_CAP) { samp[si] = f32(val) / 32768.0; si++; } lo = -1; }\n    }\n  }\n  sampLen = si;\n  loopStart = i32(f32(si) * 0.4);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0; lp = 0.0; bp = 0.0; holdV = 0.0; holdC = 0.0;\n  for (let i = 0; i < NVOX; i++) { vState[i] = 0; vPos[i] = 0.0; vEnv[i] = 0.0; vRate[i] = 1.0; vAmp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.7;\n  params[P_RESO]   = 0.3;\n  params[P_BITS]   = 0.45;\n  params[P_ATTACK] = 0.08;\n  params[P_DECAY]  = 0.6;\n  params[P_LEVEL]  = 0.8;\n  decodePCM();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPos[slot] = 0.0;\n  vRate[slot] = (f > 0.0 ? f : BASE_HZ) / BASE_HZ * (SAMP_SR / sampleRate);\n  vEnv[slot] = 0.0;\n  vState[slot] = 1;\n  vAmp[slot] = clampf(v, 0.05, 1.0);\n  vNote[slot] = id;\n}\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NVOX; i++) { if (vState[i] != 0 && vNote[i] == id) vState[i] = 3; }\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO],   0.0, 1.0);\n  const bitsN: f32   = clampf(params[P_BITS],   0.0, 1.0);\n  const attackN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const decayN: f32  = clampf(params[P_DECAY],  0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.002 + attackN * attackN * 1.5) / sampleRate;\n  const decaySec: f32 = 0.1 + decayN * decayN * 4.0;\n  const decayCoef: f32 = f32(Mathf.exp(-1.0 / (decaySec * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.08 * sampleRate)));\n\n  // lo-fi: Bits high = clean (16-ish bit, no decimation); Bits low = crunchy 4-bit + heavy decimation\n  const clean: f32 = bitsN;\n  const levels: f32 = f32(Mathf.pow(2.0, 3.0 + clean * 10.0));   // 8 .. ~8192 quantisation steps\n  const decim: i32 = 1 + i32((1.0 - clean) * 12.0);             // hold 1..13 samples\n\n  // SVF coefficients (resonant low-pass)\n  const fc: f32 = 40.0 * f32(Mathf.exp(cutoffN * 5.5));         // ~40 Hz .. ~10 kHz\n  let g: f32 = f32(Mathf.tan(3.14159265 * clampf(fc / sampleRate, 0.0005, 0.49)));\n  const k: f32 = 2.0 - 1.94 * resoN;                            // resonance (k small = high Q)\n  const a1: f32 = 1.0 / (1.0 + g * (g + k));\n  const out: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vState[s] == 0) continue;\n      let pos: f32 = vPos[s];\n      let ip: i32 = i32(pos);\n      if (ip >= sampLen - 1) {\n        if (vState[s] == 3) { vState[s] = 0; continue; }\n        pos = f32(loopStart) + (pos - f32(sampLen - 1));   // sustain loop\n        ip = i32(pos);\n        if (ip >= sampLen - 1) ip = loopStart;\n      }\n      const fr: f32 = pos - f32(ip);\n      const a: f32 = samp[ip];\n      const b: f32 = samp[ip + 1 < sampLen ? ip + 1 : ip];\n      let smp: f32 = a + (b - a) * fr;\n      if (vState[s] == 1) { vEnv[s] += atkInc; if (vEnv[s] >= 1.0) { vEnv[s] = 1.0; vState[s] = 2; } }\n      else if (vState[s] == 2) { vEnv[s] *= decayCoef; if (vEnv[s] < 0.0004) vState[s] = 0; }\n      else { vEnv[s] *= relCoef; if (vEnv[s] < 0.0004) vState[s] = 0; }\n      mix += smp * vEnv[s] * vAmp[s];\n      vPos[s] = pos + vRate[s];\n    }\n\n    // ---- lo-fi: decimate (sample & hold) then bit-quantise ----\n    holdC += 1.0;\n    if (holdC >= f32(decim)) { holdC = 0.0; holdV = mix; }\n    let lof: f32 = holdV;\n    lof = f32(Mathf.floor(lof * levels + 0.5)) / levels;\n\n    // ---- resonant SVF low-pass ----\n    const hp: f32 = (lof - (g + k) * bp - lp) * a1;\n    const b2: f32 = g * hp + bp;\n    const l2: f32 = g * b2 + lp;\n    bp = b2; lp = l2;\n\n    let o: f32 = lp * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o;\n    outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000155000
}