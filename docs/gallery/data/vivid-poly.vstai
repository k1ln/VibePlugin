{
  "format": 1,
  "name": "Vivid Poly",
  "isInstrument": true,
  "explanation": "A bright, punchy 8-voice analog-style polyphonic synthesizer built for cutting leads and forward brass stabs. Each voice runs two DCOs — a band-limited saw and a variable-width pulse with PWM — plus a Ring control that morphs in oscillator-sync and ring-modulation grit for an aggressive metallic top end. The mix feeds a snappy resonant 4-pole low-pass driven by a fast, punchy filter envelope, then a quick amplitude AR; chords ring with independent contours and pitch tracks the keyboard. Controls: Cutoff, Resonance, Env Amount, PWM, Ring, Attack, Release and Level. Vivid and aggressive rather than mellow.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.62
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "EnvAmount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "PWM",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Ring",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Attack",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Vivid Poly</title>\n<style>\n  :root{\n    --gold:#ffd23d;\n    --red:#ff5a4d;\n    --ink:#1a0f0a;\n    --cream:#fff4dc;\n    --panel:#c8231d;\n    --panel2:#8e110d;\n  }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:\n      radial-gradient(120% 90% at 20% -10%, #e6433a 0%, transparent 55%),\n      radial-gradient(130% 110% at 110% 120%, #6b0c08 0%, transparent 60%),\n      linear-gradient(160deg,#b81d18 0%, #7d0d09 100%);\n    color:var(--cream);\n    -webkit-user-select:none; user-select:none;\n    overflow:hidden;\n    display:flex; align-items:center; justify-content:center;\n    min-height:100%;\n  }\n\n  /* ---------- bezel / panel ---------- */\n  .unit{\n    position:relative;\n    width:760px; max-width:96vw;\n    border-radius:18px;\n    padding:18px 20px 22px;\n    background:\n      linear-gradient(180deg,#d9261f 0%, #a3140f 60%, #7d0d09 100%);\n    box-shadow:\n      0 30px 80px rgba(0,0,0,.55),\n      0 2px 0 rgba(255,210,61,.35) inset,\n      0 -18px 40px rgba(0,0,0,.35) inset;\n    border:2px solid #5d0805;\n  }\n  .unit::before{\n    /* gold pin-stripe frame */\n    content:\"\"; position:absolute; inset:9px;\n    border:2px solid var(--gold);\n    border-radius:12px;\n    opacity:.85;\n    pointer-events:none;\n    box-shadow:0 0 18px rgba(255,210,61,.25);\n  }\n\n  /* ---------- header ---------- */\n  .head{\n    position:relative; display:flex; align-items:center; gap:14px;\n    padding:6px 8px 14px;\n  }\n  .logo{\n    display:flex; flex-direction:column; line-height:.92;\n  }\n  .logo .vivid{\n    font-weight:900; font-size:34px; letter-spacing:2px;\n    color:var(--cream);\n    text-shadow:0 2px 0 #5d0805, 0 0 22px rgba(255,210,61,.45);\n  }\n  .logo .poly{\n    font-weight:800; font-size:15px; letter-spacing:7px;\n    color:var(--gold);\n    text-shadow:0 1px 0 #5d0805;\n  }\n  .tag{\n    margin-left:auto; text-align:right; font-size:10px; letter-spacing:2px;\n    color:#ffe8a8; opacity:.8; text-transform:uppercase;\n  }\n  .power{\n    width:14px; height:14px; border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff6c4, var(--gold) 55%, #b58400);\n    box-shadow:0 0 14px var(--gold), 0 0 4px #fff inset;\n    animation:pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse{ 0%,100%{ box-shadow:0 0 10px var(--gold);} 50%{ box-shadow:0 0 22px var(--gold), 0 0 6px #fff;} }\n\n  /* ---------- scope ---------- */\n  .scope-wrap{\n    position:relative; height:118px; margin:0 8px 16px;\n    border-radius:10px;\n    background:linear-gradient(180deg,#240603,#3a0a06);\n    border:2px solid #5d0805;\n    box-shadow:0 6px 18px rgba(0,0,0,.5) inset, 0 0 0 2px rgba(255,210,61,.18);\n    overflow:hidden;\n  }\n  .scope-wrap::after{ /* scanline sheen */\n    content:\"\"; position:absolute; inset:0;\n    background:repeating-linear-gradient(0deg, rgba(255,255,255,.04) 0 1px, transparent 1px 4px);\n    pointer-events:none;\n  }\n  svg.scope{ display:block; width:100%; height:100%; }\n  .gridline{ stroke:rgba(255,210,61,.12); stroke-width:1; }\n  .wave{ fill:none; stroke:var(--gold); stroke-width:2.4; filter:drop-shadow(0 0 6px rgba(255,210,61,.8)); }\n  .wave2{ fill:none; stroke:var(--red); stroke-width:1.6; opacity:.85; filter:drop-shadow(0 0 5px rgba(255,90,77,.7)); }\n\n  /* segment meter */\n  .meter{ position:absolute; right:10px; top:10px; bottom:10px; width:12px;\n    display:flex; flex-direction:column-reverse; gap:3px; }\n  .seg{ flex:1; border-radius:2px; background:rgba(255,255,255,.08); transition:background .08s, box-shadow .08s; }\n  .seg.on{ background:var(--gold); box-shadow:0 0 8px var(--gold); }\n  .seg.hot{ background:var(--red); box-shadow:0 0 9px var(--red); }\n\n  /* ---------- knob grid ---------- */\n  .grid{\n    display:grid; grid-template-columns:repeat(4,1fr);\n    gap:8px 6px; padding:4px 6px 2px;\n  }\n  .cell{\n    position:relative; display:flex; flex-direction:column; align-items:center;\n    padding:8px 4px 10px;\n    border-radius:10px;\n    background:linear-gradient(180deg, rgba(0,0,0,.10), rgba(0,0,0,.22));\n    box-shadow:0 1px 0 rgba(255,210,61,.10) inset;\n  }\n  .knob{\n    position:relative; width:84px; height:84px; cursor:ns-resize; touch-action:none;\n  }\n  .knob svg{ position:absolute; inset:0; overflow:visible; }\n  .arc-bg{ fill:none; stroke:rgba(0,0,0,.45); stroke-width:7; stroke-linecap:round; }\n  .arc-fg{ fill:none; stroke:url(#vg); stroke-width:7; stroke-linecap:round;\n           filter:drop-shadow(0 0 6px rgba(255,210,61,.6)); transition:stroke-dashoffset .04s linear; }\n  .cap{\n    position:absolute; inset:16px;\n    border-radius:50%;\n    background:\n      radial-gradient(circle at 38% 30%, #ffffff 0%, #f3f0e6 38%, #cfc8b6 78%, #a59d88 100%);\n    box-shadow:\n      0 4px 10px rgba(0,0,0,.5),\n      0 1px 0 #fff inset,\n      0 -3px 8px rgba(0,0,0,.25) inset;\n    border:1px solid rgba(0,0,0,.25);\n  }\n  .cap::after{\n    /* white pointer line */\n    content:\"\"; position:absolute; left:50%; top:7px;\n    width:3px; height:34%;\n    margin-left:-1.5px;\n    border-radius:2px;\n    background:linear-gradient(180deg,var(--red),#9c1c14);\n    box-shadow:0 0 5px rgba(255,90,77,.7);\n  }\n  .pointer{ position:absolute; inset:16px; pointer-events:none; }\n  .knob:hover .cap{ box-shadow:0 5px 14px rgba(0,0,0,.55), 0 0 0 2px rgba(255,210,61,.5), 0 1px 0 #fff inset; }\n  .knob.drag .cap{ box-shadow:0 5px 16px rgba(0,0,0,.6), 0 0 0 3px var(--gold), 0 1px 0 #fff inset; }\n\n  .lbl{ margin-top:9px; font-size:11px; font-weight:800; letter-spacing:2px; text-transform:uppercase; color:var(--cream); }\n  .val{ margin-top:2px; font-size:11px; font-weight:700; color:var(--gold); font-variant-numeric:tabular-nums; min-height:13px; }\n\n  .foot{ display:flex; align-items:center; gap:8px; padding:10px 10px 2px; font-size:10px; letter-spacing:2px; color:#ffd9a0; opacity:.7; }\n  .foot .dot{ width:6px; height:6px; border-radius:50%; background:var(--gold); box-shadow:0 0 6px var(--gold); }\n  .made{ margin-left:auto; text-transform:uppercase; }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"head\">\n      <span class=\"power\" title=\"on\"></span>\n      <div class=\"logo\">\n        <span class=\"vivid\">VIVID</span>\n        <span class=\"poly\">POLY&nbsp;&middot;&nbsp;8</span>\n      </div>\n      <div class=\"tag\">Bright&nbsp;Italian&nbsp;Polyphonic<br>DCO &middot; PWM &middot; RING</div>\n    </div>\n\n    <div class=\"scope-wrap\">\n      <svg class=\"scope\" viewBox=\"0 0 700 118\" preserveAspectRatio=\"none\">\n        <line class=\"gridline\" x1=\"0\" y1=\"59\" x2=\"700\" y2=\"59\"/>\n        <line class=\"gridline\" x1=\"0\" y1=\"29\" x2=\"700\" y2=\"29\"/>\n        <line class=\"gridline\" x1=\"0\" y1=\"89\" x2=\"700\" y2=\"89\"/>\n        <polyline class=\"wave2\" id=\"wave2\" points=\"\"/>\n        <polyline class=\"wave\" id=\"wave\" points=\"\"/>\n      </svg>\n      <div class=\"meter\" id=\"meter\"></div>\n    </div>\n\n    <div class=\"grid\" id=\"grid\"></div>\n\n    <div class=\"foot\">\n      <span class=\"dot\"></span><span>VIVID POLY ENGINE</span>\n      <span class=\"made\">Original instrument &mdash; bright &middot; punchy &middot; forward</span>\n    </div>\n  </div>\n\n<svg width=\"0\" height=\"0\"><defs>\n  <linearGradient id=\"vg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n    <stop offset=\"0\" stop-color=\"#ffd23d\"/>\n    <stop offset=\"1\" stop-color=\"#ff5a4d\"/>\n  </linearGradient>\n</defs></svg>\n\n<script>\n(function(){\n  \"use strict\";\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n\n  // ----- param definitions (index must match spec.json) -----\n  var PARAMS=[\n    { i:0, name:\"CUTOFF\",  def:0.62, fmt:function(v){ return Math.round(120*Math.pow(150,v))+\" Hz\"; } },\n    { i:1, name:\"RESO\",    def:0.40, fmt:function(v){ return Math.round(v*100)+\"%\"; } },\n    { i:2, name:\"ENV AMT\", def:0.65, fmt:function(v){ return (v*6.5).toFixed(1)+\" oct\"; } },\n    { i:3, name:\"PWM\",     def:0.35, fmt:function(v){ return Math.round((0.5+v*0.42)*100)+\"%\"; } },\n    { i:4, name:\"RING\",    def:0.25, fmt:function(v){ return Math.round(v*100)+\"%\"; } },\n    { i:5, name:\"ATTACK\",  def:0.04, fmt:function(v){ return Math.round((1+v*120))+\" ms\"; } },\n    { i:6, name:\"RELEASE\", def:0.30, fmt:function(v){ return ((0.005+v*1.6)*1000|0)+\" ms\"; } },\n    { i:7, name:\"LEVEL\",   def:0.80, fmt:function(v){ return Math.round(v*100)+\"%\"; } }\n  ];\n\n  var ARC_LEN=Math.PI*1.5*38; // radius 38, 270deg sweep\n  var grid=document.getElementById(\"grid\");\n  var state={}; // index -> value\n\n  function buildKnob(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var knob=document.createElement(\"div\"); knob.className=\"knob\";\n    knob.innerHTML=\n      '<svg viewBox=\"0 0 84 84\">'+\n      '<path class=\"arc-bg\" d=\"M 17 67 A 38 38 0 1 1 67 67\"/>'+\n      '<path class=\"arc-fg\" d=\"M 17 67 A 38 38 0 1 1 67 67\" '+\n        'stroke-dasharray=\"'+ARC_LEN+'\" stroke-dashoffset=\"'+ARC_LEN+'\"/>'+\n      '</svg>'+\n      '<div class=\"pointer\"><div class=\"cap\"></div></div>';\n    var lbl=document.createElement(\"div\"); lbl.className=\"lbl\"; lbl.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    cell.appendChild(knob); cell.appendChild(lbl); cell.appendChild(val);\n    grid.appendChild(cell);\n\n    var arc=knob.querySelector(\".arc-fg\");\n    var pointer=knob.querySelector(\".pointer\");\n    var v=p.def;\n\n    function paint(){\n      // arc fill\n      arc.style.strokeDashoffset=(ARC_LEN*(1-v))+\"\";\n      // rotate cap: -135deg .. +135deg\n      var deg=-135+v*270;\n      pointer.style.transform=\"rotate(\"+deg+\"deg)\";\n      val.textContent=p.fmt(v);\n      state[p.i]=v;\n    }\n    function set(nv){ v=Math.max(0,Math.min(1,nv)); send(p.i,v); paint(); }\n\n    // ----- drag (vertical) -----\n    var dragging=false, lastY=0;\n    knob.addEventListener(\"pointerdown\",function(e){\n      dragging=true; lastY=e.clientY; knob.classList.add(\"drag\");\n      knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener(\"pointermove\",function(e){\n      if(!dragging) return;\n      var dy=lastY-e.clientY; lastY=e.clientY;\n      var speed=e.shiftKey?0.0008:0.004;\n      set(v+dy*speed);\n    });\n    function up(e){ dragging=false; knob.classList.remove(\"drag\"); try{knob.releasePointerCapture(e.pointerId);}catch(_){} }\n    knob.addEventListener(\"pointerup\",up);\n    knob.addEventListener(\"pointercancel\",up);\n    knob.addEventListener(\"wheel\",function(e){ e.preventDefault(); set(v-(e.deltaY>0?1:-1)*0.03); },{passive:false});\n    knob.addEventListener(\"dblclick\",function(){ set(p.def); });\n\n    set(p.def); // init -> sends default\n    return { get:function(){return v;} };\n  }\n\n  var knobs=PARAMS.map(buildKnob);\n\n  // ----- segment meter -----\n  var meter=document.getElementById(\"meter\");\n  var SEGS=14, segEls=[];\n  for(var s=0;s<SEGS;s++){ var d=document.createElement(\"div\"); d.className=\"seg\"; meter.appendChild(d); segEls.push(d); }\n\n  // ----- animated scope -----\n  var wave=document.getElementById(\"wave\");\n  var wave2=document.getElementById(\"wave2\");\n  var W=700,H=118,N=140;\n  var t=0;\n  function frame(){\n    t+=0.045;\n    var cut=state[0]||0.5, reso=state[1]||0.4, pwm=state[3]||0.35, ring=state[4]||0.25, lvl=state[7]||0.8;\n    // bright snapping saw: harmonics scale with cutoff; ring adds metallic upper partials\n    var bright=1+cut*9;\n    var pw=0.5+pwm*0.42;\n    var pts1=\"\", pts2=\"\";\n    var amp=24+lvl*22;\n    var peak=0;\n    for(var x=0;x<=N;x++){\n      var ph=(x/N)*4 + t;             // 4 cycles across screen, scrolling\n      var fr=ph-Math.floor(ph);       // 0..1 saw ramp\n      // band-limited-ish saw with cutoff brightening the edge snap\n      var saw=(fr*2-1);\n      saw= saw*(0.6+0.4*Math.tanh(saw*bright)); // sharpen edge with cutoff\n      // resonant ring on the falling edge\n      saw+= reso*0.35*Math.sin(ph*6.283*(2+ring*5))*Math.exp(-fr*4);\n      // pulse component (PWM)\n      var pul=(fr<pw)?1:-1;\n      var y1=H/2 - saw*amp*0.9;\n      var y2=H/2 - (pul*0.6 + saw*0.2)*amp*0.6;\n      var px=(x/N)*W;\n      pts1+=px.toFixed(1)+\",\"+y1.toFixed(1)+\" \";\n      pts2+=px.toFixed(1)+\",\"+y2.toFixed(1)+\" \";\n      var a=Math.abs(saw); if(a>peak)peak=a;\n    }\n    wave.setAttribute(\"points\",pts1);\n    wave2.setAttribute(\"points\",pts2);\n\n    // meter: drive by level*peak with a little movement\n    var lit=Math.round((0.25+lvl*0.7)*SEGS*(0.7+0.3*Math.abs(Math.sin(t*1.3))));\n    for(var s=0;s<SEGS;s++){\n      var on=s<lit;\n      segEls[s].className=\"seg\"+(on?(s>=SEGS-3?\" hot\":\" on\"):\"\");\n    }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // host ready hook\n  function ready(){ /* defaults already sent during build */ }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VIVID POLY — a bright, punchy 8-voice analog polyphonic synthesizer.\n//  Italian-poly lineage (vivid, forward, cutting). Each voice runs two\n//  DCOs — a band-limited saw and a band-limited variable-width pulse with\n//  PWM — summed, with a \"Ring\" control that morphs in oscillator-sync /\n//  ring-modulation grit for extra bite. The mix feeds a snappy resonant\n//  2x2-pole (24 dB/oct) low-pass driven by a FAST punchy filter envelope\n//  (Attack + Env Amount), then a fast amplitude AR. Voices are allocated\n//  per noteId so chords ring independently. Pure algorithm, no samples,\n//  no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:  i32 = 0;  // 0..1  -> base filter cutoff (bright)\nconst P_RESO:    i32 = 1;  // 0..1  -> filter resonance / bite\nconst P_ENVAMT:  i32 = 2;  // 0..1  -> filter envelope amount\nconst P_PWM:     i32 = 3;  // 0..1  -> pulse width (thin <-> hollow)\nconst P_RING:    i32 = 4;  // 0..1  -> sync / ring grit amount\nconst P_ATTACK:  i32 = 5;  // 0..1  -> seconds (fast)\nconst P_RELEASE: i32 = 6;  // 0..1  -> seconds\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:     StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhase1:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw phase\nconst vPhase2:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse phase\nconst vPhaseS:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // sync/ring master phase\n\n// amplitude envelope (AR): 0 idle 1 atk 2 sustain 4 rel\nconst vAEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n// filter envelope (AR, snappy decay-to-zero feel via release on gate-off)\nconst vFEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// 4-pole ladder state per voice\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhase1[v] = 0.0; vPhase2[v] = 0.0; vPhaseS[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_CUTOFF]  = 0.62;\n  params[P_RESO]    = 0.40;\n  params[P_ENVAMT]  = 0.65;\n  params[P_PWM]     = 0.35;\n  params[P_RING]    = 0.25;\n  params[P_ATTACK]  = 0.04;\n  params[P_RELEASE] = 0.30;\n  params[P_LEVEL]   = 0.80;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vPhase1[slot] = 0.0;\n  vPhase2[slot] = 0.2;\n  vPhaseS[slot] = 0.0;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const pwmN: f32    = clampf(params[P_PWM], 0.0, 1.0);\n  const ringN: f32   = clampf(params[P_RING], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // FAST punchy envelope: attack 1..~120 ms, release 5 ms..~1.6 s\n  const atkS: f32 = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0) * 0.12;\n  const relS: f32 = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 1.6;\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n  // filter env has its own snappy decay even while held -> punch\n  const fDecRate: f32 = 1.0 / (0.18 * sr);\n\n  // base cutoff in Hz: bright range 120 Hz .. ~18 kHz (forward, not mellow)\n  const baseHz: f32 = 120.0 * f32(Mathf.pow(150.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6.5 octaves -> snappy zing\n  const envOct: f32 = envAmt * 6.5;\n  // resonance feedback 0..~4 (sharp bite, near self-oscillation at top)\n  const reso: f32 = resoN * 4.0;\n\n  // pulse width: 0.5 (square) .. 0.92 (thin/nasal) for PWM bite\n  const pw: f32 = 0.5 + pwmN * 0.42;\n\n  // ring/sync grit: how much sync+ring replaces the clean osc mix\n  const ringMix: f32 = ringN;\n  // sync master runs a fixed ratio above the voice -> hard-sync edge\n  const syncRatio: f32 = 1.0 + ringN * 1.5;   // 1.0 .. 2.5\n\n  // headroom: 8 voices summed -> scale so big chords stay bounded\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR -----------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // sustain (held at full)\n        aenv = 1.0;\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter AR (snappy: attack to 1, decays toward a floor) ----\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {            // fast attack\n        fenv += atkRate * 1.5;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {     // punchy decay toward 0.25 floor while held\n        fenv -= fDecRate * (fenv - 0.25);\n        if (fenv < 0.25) fenv = 0.25;\n      } else if (fstg == 4) {     // release to zero\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- oscillators ------------------------------------------\n      const baseInc: f32 = vFreq[v] / sr;\n\n      // DCO1: band-limited saw (a touch flat for slight analog drift)\n      let p1: f32 = vPhase1[v];\n      p1 += baseInc; if (p1 >= 1.0) p1 -= 1.0;\n      let saw: f32 = 2.0 * p1 - 1.0;\n      saw -= polyBlep(p1, baseInc);\n      vPhase1[v] = p1;\n\n      // DCO2: band-limited variable-width pulse (PWM) a touch sharp\n      const inc2: f32 = baseInc * 1.003;\n      let p2: f32 = vPhase2[v];\n      p2 += inc2; if (p2 >= 1.0) p2 -= 1.0;\n      let sq: f32 = p2 < pw ? 1.0 : -1.0;\n      sq += polyBlep(p2, inc2);\n      let p2b: f32 = p2 + (1.0 - pw);\n      if (p2b >= 1.0) p2b -= 1.0;\n      sq -= polyBlep(p2b, inc2);\n      vPhase2[v] = p2;\n\n      // clean DCO mix (saw for body, pulse for buzz)\n      let osc: f32 = saw * 0.6 + sq * 0.5;\n\n      // ---- ring / hard-sync grit --------------------------------\n      // a master oscillator at syncRatio; ring-mod its saw with the mix,\n      // and crossfade in for an aggressive metallic edge.\n      let ps: f32 = vPhaseS[v];\n      const incS: f32 = baseInc * syncRatio;\n      ps += incS; if (ps >= 1.0) ps -= 1.0;\n      vPhaseS[v] = ps;\n      const masterSaw: f32 = 2.0 * ps - 1.0;\n      // ring modulation product (bipolar, metallic)\n      const ring: f32 = osc * masterSaw;\n      // blend: more Ring -> more grit replacing the clean tone\n      osc = osc * (1.0 - ringMix * 0.85) + ring * (ringMix * 1.1);\n\n      // ---- resonant 4-pole low-pass -----------------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 30.0) fc = 30.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      // slight high-frequency emphasis (s2-s3) keeps it vivid, not mellow\n      let voice: f32 = (s3 + (s2 - s3) * 0.35) * aenv * vVel[v];\n      outL += voice;\n    }\n\n    // ---- sum + bright soft saturate for Italian-poly glue ----------\n    let mix: f32 = outL * voiceScale * (0.4 + level * 1.2);\n    mix = f32(Mathf.tanh(mix));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000109000
}