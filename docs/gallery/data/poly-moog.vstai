{
  "format": 1,
  "name": "Poly Moog",
  "isInstrument": true,
  "explanation": "A fat, warm polyphonic analog synthesizer with up to eight independent voices. Each voice runs three detuned oscillators (two band-limited saws and a pulse) into a 4-pole ladder-style low-pass with tanh saturation, swept by its own filter envelope, then an amplitude envelope; chords ring as separate fat voices. Controls: Detune, Cutoff, Resonance, Filter Env Amount, Attack, Release and Level.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "FilterEnvAmt",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.06
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Poly Moog</title>\n<style>\n  :root {\n    --accent: #ffae5a;\n    --accent2: #ff7a5a;\n    --panel: #141210;\n    --panel2: #1d1a16;\n    --ink: #efe6d8;\n    --dim: #8c8275;\n    --wood1: #6b3d1c;\n    --wood2: #97582b;\n    --wood3: #4a2a13;\n    --scope: #4dff8e;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background: #0a0908;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .stage {\n    min-height: 100vh;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #1b1815 0%, #0a0908 60%);\n  }\n\n  /* ---- the synth chassis: wood cheeks + black panel ---- */\n  .synth {\n    width: min(960px, 100%);\n    display: grid;\n    grid-template-columns: 34px 1fr 34px;\n    border-radius: 14px;\n    box-shadow:\n      0 30px 70px rgba(0,0,0,0.7),\n      0 2px 0 rgba(255,255,255,0.05) inset;\n    overflow: hidden;\n  }\n\n  .cheek {\n    background:\n      repeating-linear-gradient(\n        178deg,\n        var(--wood1) 0px,\n        var(--wood2) 3px,\n        var(--wood3) 6px,\n        var(--wood1) 9px);\n    box-shadow:\n      inset 0 0 30px rgba(0,0,0,0.55),\n      inset -3px 0 6px rgba(0,0,0,0.4);\n    position: relative;\n  }\n  .cheek.right { box-shadow: inset 0 0 30px rgba(0,0,0,0.55), inset 3px 0 6px rgba(0,0,0,0.4); }\n  .cheek::after {\n    content: \"\";\n    position: absolute;\n    inset: 6px 4px;\n    border-radius: 6px;\n    box-shadow: inset 0 0 0 1px rgba(255,220,180,0.08);\n  }\n\n  .panel {\n    background:\n      linear-gradient(180deg, #211d18 0%, var(--panel) 12%, var(--panel) 100%);\n    padding: 16px 22px 22px;\n    position: relative;\n  }\n  .panel::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      radial-gradient(rgba(255,255,255,0.018) 1px, transparent 1px);\n    background-size: 4px 4px;\n    pointer-events: none;\n  }\n\n  /* ---- header ---- */\n  header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 12px;\n    border-bottom: 1px solid rgba(255,255,255,0.06);\n    padding-bottom: 12px;\n    margin-bottom: 14px;\n  }\n  .brand { display: flex; align-items: baseline; gap: 10px; }\n  .logo {\n    font-weight: 800;\n    font-size: 26px;\n    letter-spacing: 0.5px;\n    background: linear-gradient(180deg, #fff 0%, var(--accent) 70%, var(--accent2) 100%);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.4);\n  }\n  .tagline {\n    font-size: 10px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  /* ---- voice LED row ---- */\n  .voices { display: flex; align-items: center; gap: 9px; }\n  .voices .vlabel {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n    margin-right: 4px;\n  }\n  .led {\n    width: 13px; height: 13px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #3a342c, #0d0b09);\n    box-shadow: inset 0 1px 2px rgba(0,0,0,0.8), 0 1px 0 rgba(255,255,255,0.04);\n    transition: background 0.08s linear, box-shadow 0.08s linear;\n  }\n  .led.on {\n    background: radial-gradient(circle at 35% 30%, #fff2d8, var(--accent) 55%, var(--accent2) 100%);\n    box-shadow:\n      0 0 8px var(--accent),\n      0 0 16px rgba(255,122,90,0.55),\n      inset 0 0 2px #fff;\n  }\n\n  /* ---- scope ---- */\n  .scopewrap {\n    margin: 0 0 16px;\n    border-radius: 9px;\n    padding: 8px;\n    background:\n      linear-gradient(180deg, #050b07, #02160b);\n    box-shadow:\n      inset 0 0 0 1px rgba(77,255,142,0.12),\n      inset 0 6px 24px rgba(0,0,0,0.7);\n    position: relative;\n  }\n  canvas { display: block; width: 100%; height: 116px; border-radius: 5px; }\n  .scopeglow {\n    position: absolute; inset: 8px;\n    pointer-events: none;\n    background: radial-gradient(80% 60% at 50% 50%, rgba(77,255,142,0.07), transparent 70%);\n    border-radius: 5px;\n  }\n\n  /* ---- knob grid ---- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(7, 1fr);\n    gap: 10px;\n  }\n  @media (max-width: 720px) { .rack { grid-template-columns: repeat(4, 1fr); } }\n  @media (max-width: 430px) { .rack { grid-template-columns: repeat(3, 1fr); } }\n\n  .knobcell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n    padding: 12px 4px 10px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, var(--panel2), #100e0c);\n    box-shadow:\n      inset 0 1px 0 rgba(255,255,255,0.05),\n      0 2px 6px rgba(0,0,0,0.5);\n  }\n  .knoblabel {\n    font-size: 9.5px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--dim);\n    text-align: center;\n  }\n  .knob {\n    width: 64px; height: 64px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .knob:focus { outline: none; }\n  .val {\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    background: #0c0a08;\n    border-radius: 4px;\n    padding: 2px 7px;\n    min-width: 42px;\n    text-align: center;\n    box-shadow: inset 0 1px 3px rgba(0,0,0,0.8);\n  }\n\n  /* ---- keyboard ---- */\n  .kbd {\n    margin-top: 16px;\n    display: flex;\n    position: relative;\n    height: 92px;\n    border-radius: 8px;\n    padding: 6px;\n    background: linear-gradient(180deg, #0c0a08, #1a1714);\n    box-shadow: inset 0 2px 8px rgba(0,0,0,0.7);\n    user-select: none;\n    -webkit-user-select: none;\n    touch-action: none;\n  }\n  .keys { position: relative; flex: 1; height: 100%; }\n  .wkey {\n    position: absolute; top: 0; bottom: 0;\n    background: linear-gradient(180deg, #f3ece0, #c9bda9);\n    border-radius: 0 0 5px 5px;\n    box-shadow: inset 0 -3px 5px rgba(0,0,0,0.25), 0 1px 0 #fff inset;\n    border: 1px solid #2b2620;\n    cursor: pointer;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent), var(--accent2));\n    box-shadow: inset 0 -4px 8px rgba(0,0,0,0.35);\n  }\n  .bkey {\n    position: absolute; top: 0;\n    height: 58%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a2620, #050403);\n    box-shadow: inset 0 -3px 4px rgba(255,255,255,0.08), 0 3px 5px rgba(0,0,0,0.6);\n    border: 1px solid #000;\n    z-index: 3;\n    cursor: pointer;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2), #7a2d1a);\n  }\n  .hint {\n    margin-top: 9px;\n    font-size: 10px;\n    letter-spacing: 1px;\n    color: var(--dim);\n    text-align: center;\n  }\n</style>\n</head>\n<body>\n<div class=\"stage\">\n  <div class=\"synth\">\n    <div class=\"cheek left\"></div>\n    <div class=\"panel\">\n      <header>\n        <div class=\"brand\">\n          <div class=\"logo\">POLY MOOG</div>\n          <div class=\"tagline\">8-Voice Ladder Polysynth</div>\n        </div>\n        <div class=\"voices\" id=\"voices\">\n          <span class=\"vlabel\">Voices</span>\n        </div>\n      </header>\n\n      <div class=\"scopewrap\">\n        <canvas id=\"scope\"></canvas>\n        <div class=\"scopeglow\"></div>\n      </div>\n\n      <div class=\"rack\" id=\"rack\"></div>\n\n      <div class=\"kbd\">\n        <div class=\"keys\" id=\"keys\"></div>\n      </div>\n      <div class=\"hint\">Drag a knob vertically · double-click to reset · click the keys or use your computer keyboard (A&ndash;K)</div>\n    </div>\n    <div class=\"cheek right\"></div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Detune\",     index: 0, min: 0, max: 1, def: 0.35, fmt: pct },\n    { name: \"Cutoff\",     index: 1, min: 0, max: 1, def: 0.50, fmt: hz },\n    { name: \"Resonance\",  index: 2, min: 0, max: 1, def: 0.35, fmt: pct },\n    { name: \"Env Amt\",    index: 3, min: 0, max: 1, def: 0.60, fmt: pct },\n    { name: \"Attack\",     index: 4, min: 0, max: 1, def: 0.06, fmt: secAtk },\n    { name: \"Release\",    index: 5, min: 0, max: 1, def: 0.35, fmt: secRel },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.70, fmt: pct }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function hz(v) {\n    var f = 50 * Math.pow(320, v);\n    return f >= 1000 ? (f / 1000).toFixed(1) + \"k\" : Math.round(f) + \"Hz\";\n  }\n  function secAtk(v) { return (0.002 + v * 1.2).toFixed(2) + \"s\"; }\n  function secRel(v) { return (0.02 + v * 2.5).toFixed(2) + \"s\"; }\n\n  // ---- host bridge (guard against undefined) ----\n  function setParam(i, v) {\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n  function noteOn(n, vel) {\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, vel);\n  }\n  function noteOff(n) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  // ===================================================================\n  //  KNOBS — SVG, drag to turn, dbl-click reset, wheel fine-tune\n  // ===================================================================\n  var rack = document.getElementById(\"rack\");\n  var knobState = [];\n\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knobcell\";\n\n    var label = document.createElement(\"div\");\n    label.className = \"knoblabel\";\n    label.textContent = p.name;\n\n    var SVGNS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(SVGNS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n    svg.setAttribute(\"class\", \"knob\");\n    svg.setAttribute(\"tabindex\", \"0\");\n\n    // track arc (270 deg)\n    var track = document.createElementNS(SVGNS, \"path\");\n    track.setAttribute(\"d\", arcPath(50, 50, 38, -135, 135));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"#322c25\");\n    track.setAttribute(\"stroke-width\", \"7\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n\n    // value arc\n    var arc = document.createElementNS(SVGNS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#kg)\");\n    arc.setAttribute(\"stroke-width\", \"7\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n\n    // gradient def\n    var defs = document.createElementNS(SVGNS, \"defs\");\n    var grad = document.createElementNS(SVGNS, \"linearGradient\");\n    grad.setAttribute(\"id\", \"kg\");\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"1\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"0\");\n    var st1 = document.createElementNS(SVGNS, \"stop\");\n    st1.setAttribute(\"offset\", \"0%\"); st1.setAttribute(\"stop-color\", \"#ff7a5a\");\n    var st2 = document.createElementNS(SVGNS, \"stop\");\n    st2.setAttribute(\"offset\", \"100%\"); st2.setAttribute(\"stop-color\", \"#ffae5a\");\n    grad.appendChild(st1); grad.appendChild(st2); defs.appendChild(grad);\n\n    // body\n    var body = document.createElementNS(SVGNS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"url(#kb)\");\n    body.setAttribute(\"stroke\", \"#000\"); body.setAttribute(\"stroke-width\", \"1\");\n    var bgrad = document.createElementNS(SVGNS, \"radialGradient\");\n    bgrad.setAttribute(\"id\", \"kb\");\n    bgrad.setAttribute(\"cx\", \"0.4\"); bgrad.setAttribute(\"cy\", \"0.32\"); bgrad.setAttribute(\"r\", \"0.8\");\n    var b1 = document.createElementNS(SVGNS, \"stop\");\n    b1.setAttribute(\"offset\", \"0%\"); b1.setAttribute(\"stop-color\", \"#3a342c\");\n    var b2 = document.createElementNS(SVGNS, \"stop\");\n    b2.setAttribute(\"offset\", \"100%\"); b2.setAttribute(\"stop-color\", \"#0c0a08\");\n    bgrad.appendChild(b1); bgrad.appendChild(b2); defs.appendChild(bgrad);\n\n    // pointer notch\n    var notch = document.createElementNS(SVGNS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"27\");\n    notch.setAttribute(\"stroke\", \"#ffd9a8\");\n    notch.setAttribute(\"stroke-width\", \"3.2\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n\n    svg.appendChild(defs);\n    svg.appendChild(track);\n    svg.appendChild(arc);\n    svg.appendChild(body);\n    svg.appendChild(notch);\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(label);\n    cell.appendChild(svg);\n    cell.appendChild(val);\n    rack.appendChild(cell);\n\n    var st = { p: p, value: p.def, arc: arc, notch: notch, val: val };\n    knobState.push(st);\n    draw(st);\n\n    // ---- interactions ----\n    var dragging = false, startY = 0, startVal = 0;\n\n    function clientY(e) { return e.touches ? e.touches[0].clientY : e.clientY; }\n\n    function onDown(e) {\n      dragging = true;\n      startY = clientY(e);\n      startVal = st.value;\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var dy = startY - clientY(e);\n      var range = p.max - p.min;\n      var fine = (e.shiftKey) ? 0.25 : 1;\n      setVal(startVal + (dy / 180) * range * fine);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n\n    function setVal(v) {\n      st.value = Math.max(p.min, Math.min(p.max, v));\n      draw(st);\n      setParam(p.index, st.value);\n    }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    svg.addEventListener(\"dblclick\", function () { setVal(p.def); });\n    svg.addEventListener(\"wheel\", function (e) {\n      var range = p.max - p.min;\n      setVal(st.value - Math.sign(e.deltaY) * range * 0.03);\n      e.preventDefault();\n    }, { passive: false });\n    svg.addEventListener(\"keydown\", function (e) {\n      var range = p.max - p.min;\n      if (e.key === \"ArrowUp\" || e.key === \"ArrowRight\") { setVal(st.value + range * 0.04); e.preventDefault(); }\n      if (e.key === \"ArrowDown\" || e.key === \"ArrowLeft\") { setVal(st.value - range * 0.04); e.preventDefault(); }\n    });\n\n    st.setVal = setVal;\n    return st;\n  }\n\n  function draw(st) {\n    var p = st.p;\n    var norm = (st.value - p.min) / (p.max - p.min);\n    var ang = -135 + norm * 270;\n    st.arc.setAttribute(\"d\", arcPath(50, 50, 38, -135, ang));\n    var rad = (ang - 90) * Math.PI / 180;\n    var x2 = 50 + Math.cos(rad) * 23;\n    var y2 = 50 + Math.sin(rad) * 23;\n    st.notch.setAttribute(\"x2\", x2.toFixed(2));\n    st.notch.setAttribute(\"y2\", y2.toFixed(2));\n    st.val.textContent = p.fmt(st.value);\n  }\n\n  function arcPath(cx, cy, r, a0, a1) {\n    var p0 = polar(cx, cy, r, a0);\n    var p1 = polar(cx, cy, r, a1);\n    var large = (a1 - a0) > 180 ? 1 : 0;\n    return \"M \" + p0.x + \" \" + p0.y + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + p1.x + \" \" + p1.y;\n  }\n  function polar(cx, cy, r, deg) {\n    var rad = (deg - 90) * Math.PI / 180;\n    return { x: (cx + Math.cos(rad) * r).toFixed(2), y: (cy + Math.sin(rad) * r).toFixed(2) };\n  }\n\n  // ===================================================================\n  //  VOICE LEDS\n  // ===================================================================\n  var NUM_VOICES = 8;\n  var voicesEl = document.getElementById(\"voices\");\n  var leds = [];\n  for (var i = 0; i < NUM_VOICES; i++) {\n    var d = document.createElement(\"div\");\n    d.className = \"led\";\n    voicesEl.appendChild(d);\n    leds.push(d);\n  }\n  // voice allocation mirror (free-first, oldest-steal) so LEDs match the engine\n  var voiceNote = new Array(NUM_VOICES).fill(-1);\n  var voiceAge = new Array(NUM_VOICES).fill(0);\n  var ageCtr = 0;\n\n  function ledOn(note) {\n    var slot = -1;\n    for (var i = 0; i < NUM_VOICES; i++) if (voiceNote[i] < 0) { slot = i; break; }\n    if (slot < 0) {\n      slot = 0; var oldest = voiceAge[0];\n      for (var j = 1; j < NUM_VOICES; j++) if (voiceAge[j] < oldest) { oldest = voiceAge[j]; slot = j; }\n    }\n    voiceNote[slot] = note;\n    voiceAge[slot] = ageCtr++;\n    leds[slot].classList.add(\"on\");\n  }\n  function ledOff(note) {\n    for (var i = 0; i < NUM_VOICES; i++) {\n      if (voiceNote[i] === note) {\n        voiceNote[i] = -1;\n        leds[i].classList.remove(\"on\");\n      }\n    }\n  }\n\n  // ===================================================================\n  //  KEYBOARD\n  // ===================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var FIRST = 48; // C3\n  var NKEYS = 25; // two octaves + 1\n  var isBlack = function (n) { var m = n % 12; return m === 1 || m === 3 || m === 6 || m === 8 || m === 10; };\n\n  var whiteCount = 0;\n  for (var k = 0; k < NKEYS; k++) if (!isBlack(FIRST + k)) whiteCount++;\n  var wIdx = 0;\n  var keyEls = {};\n\n  for (var k2 = 0; k2 < NKEYS; k2++) {\n    var note = FIRST + k2;\n    var el = document.createElement(\"div\");\n    if (isBlack(note)) {\n      el.className = \"bkey\";\n      // position relative to the previous white key\n      var leftPct = (wIdx / whiteCount) * 100 - (1 / whiteCount) * 32;\n      el.style.left = leftPct + \"%\";\n      el.style.width = (1 / whiteCount) * 64 + \"%\";\n    } else {\n      el.className = \"wkey\";\n      el.style.left = (wIdx / whiteCount) * 100 + \"%\";\n      el.style.width = (1 / whiteCount) * 100 + \"%\";\n      wIdx++;\n    }\n    el.dataset.note = note;\n    keysEl.appendChild(el);\n    keyEls[note] = el;\n  }\n\n  var heldPointer = {};\n\n  function press(note) {\n    if (keyEls[note] && !keyEls[note].classList.contains(\"down\")) {\n      keyEls[note].classList.add(\"down\");\n      noteOn(note, 0.9);\n      ledOn(note);\n    }\n  }\n  function release(note) {\n    if (keyEls[note] && keyEls[note].classList.contains(\"down\")) {\n      keyEls[note].classList.remove(\"down\");\n      noteOff(note);\n      ledOff(note);\n    }\n  }\n\n  keysEl.addEventListener(\"mousedown\", function (e) {\n    var n = +e.target.dataset.note;\n    if (n) { press(n); heldPointer.mouse = n; }\n  });\n  window.addEventListener(\"mouseup\", function () {\n    if (heldPointer.mouse) { release(heldPointer.mouse); heldPointer.mouse = 0; }\n  });\n  keysEl.addEventListener(\"mouseover\", function (e) {\n    if (heldPointer.mouse) {\n      var n = +e.target.dataset.note;\n      if (n && n !== heldPointer.mouse) { release(heldPointer.mouse); press(n); heldPointer.mouse = n; }\n    }\n  });\n  keysEl.addEventListener(\"touchstart\", function (e) {\n    for (var t = 0; t < e.changedTouches.length; t++) {\n      var el = document.elementFromPoint(e.changedTouches[t].clientX, e.changedTouches[t].clientY);\n      if (el && el.dataset.note) press(+el.dataset.note);\n    }\n    e.preventDefault();\n  }, { passive: false });\n  keysEl.addEventListener(\"touchend\", function (e) {\n    // release everything held on touchend (simple + robust)\n    for (var n in keyEls) if (keyEls[n].classList.contains(\"down\")) release(+n);\n    e.preventDefault();\n  }, { passive: false });\n\n  // computer keyboard\n  var KEYMAP = { a:48, w:49, s:50, e:51, d:52, f:53, t:54, g:55, y:56, h:57, u:58, j:59, k:60, o:61, l:62, p:63 };\n  var keyDown = {};\n  window.addEventListener(\"keydown\", function (e) {\n    var n = KEYMAP[e.key];\n    if (n != null && !keyDown[e.key]) { keyDown[e.key] = true; press(n); }\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var n = KEYMAP[e.key];\n    if (n != null) { keyDown[e.key] = false; release(n); }\n  });\n\n  // ===================================================================\n  //  OSCILLOSCOPE — synthesized from active voices + envelopes,\n  //  fat green CRT trace driven by which knobs are set.\n  // ===================================================================\n  var cv = document.getElementById(\"scope\");\n  var ctx = cv.getContext(\"2d\");\n  var phase = 0;\n\n  function resize() {\n    var r = cv.getBoundingClientRect();\n    var dpr = window.devicePixelRatio || 1;\n    cv.width = Math.max(1, r.width * dpr);\n    cv.height = Math.max(1, r.height * dpr);\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n  window.addEventListener(\"resize\", resize);\n\n  function valOf(idx) {\n    for (var i = 0; i < knobState.length; i++) if (knobState[i].p.index === idx) return knobState[i].value;\n    return 0;\n  }\n\n  function activeVoices() {\n    var c = 0;\n    for (var i = 0; i < NUM_VOICES; i++) if (voiceNote[i] >= 0) c++;\n    return c;\n  }\n\n  var energy = 0;\n\n  function frame() {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    var r = cv.getBoundingClientRect();\n    var W = r.width, H = r.height;\n    ctx.clearRect(0, 0, W, H);\n\n    // grid\n    ctx.strokeStyle = \"rgba(77,255,142,0.10)\";\n    ctx.lineWidth = 1;\n    for (var gx = 0; gx <= 8; gx++) {\n      var x = (gx / 8) * W;\n      ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, H); ctx.stroke();\n    }\n    for (var gy = 0; gy <= 4; gy++) {\n      var y = (gy / 4) * H;\n      ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(W, y); ctx.stroke();\n    }\n\n    var active = activeVoices();\n    var target = active > 0 ? 1 : 0;\n    energy += (target - energy) * 0.08;\n\n    // shape from knobs\n    var detune = valOf(0);\n    var cutoff = valOf(1);\n    var reso = valOf(2);\n    var level = valOf(6);\n    var amp = (0.12 + level * 0.78) * energy;\n    var speed = 0.6 + cutoff * 2.2 + active * 0.15;\n    phase += 0.02 * speed;\n\n    // draw the fat green trace\n    ctx.lineWidth = 2.4;\n    ctx.strokeStyle = \"rgba(77,255,142,0.9)\";\n    ctx.shadowColor = \"rgba(77,255,142,0.8)\";\n    ctx.shadowBlur = 9;\n    ctx.beginPath();\n    var N = 256;\n    for (var i = 0; i <= N; i++) {\n      var t = i / N;\n      var ph = t * Math.PI * 2 * (2 + Math.floor(cutoff * 5));\n      // base saw-ish + detune beating + resonant ring\n      var saw = ((t * (2 + Math.floor(detune * 4)) % 1) * 2 - 1);\n      var beat = Math.sin(phase * 0.5 + t * Math.PI * 2 * (1 + detune * 3));\n      var ring = reso * 0.6 * Math.sin(ph * (1 + reso) + phase);\n      var s = (saw * 0.5 + beat * 0.4 + ring) * amp;\n      var px = t * W;\n      var py = H / 2 - s * (H * 0.40);\n      if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);\n    }\n    ctx.stroke();\n    ctx.shadowBlur = 0;\n\n    // center line\n    ctx.strokeStyle = \"rgba(77,255,142,0.18)\";\n    ctx.lineWidth = 1;\n    ctx.beginPath(); ctx.moveTo(0, H / 2); ctx.lineTo(W, H / 2); ctx.stroke();\n\n    requestAnimationFrame(frame);\n  }\n\n  // ===================================================================\n  //  BOOT\n  // ===================================================================\n  function boot() {\n    PARAMS.forEach(makeKnob);\n    // initialise every param to its default\n    knobState.forEach(function (st) { setParam(st.p.index, st.value); });\n    resize();\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  POLY MOOG — a fat, warm polyphonic analog instrument.\n//  Original synth modelled on the behaviour of a classic six-voice\n//  ladder polysynth. Up to EIGHT independent voices, each:\n//    * THREE detuned oscillators (two band-limited saws + one pulse),\n//      spread by the Detune control for a thick, beating analog tone;\n//    * a 4-pole MOOG-style ladder low-pass with per-stage tanh\n//      saturation, driven by its own filter envelope (+amount);\n//    * an amplitude envelope.\n//  Voices are keyed by noteId so a chord rings as separate fat voices.\n//  Pure algorithm — no samples, no host imports, allocation-free.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_DETUNE:  i32 = 0;  // 0..1  -> oscillator spread\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 2;  // 0..1  -> ladder resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount\nconst P_ATTACK:  i32 = 4;  // 0..1  -> seconds (amp + filter attack)\nconst P_RELEASE: i32 = 5;  // 0..1  -> seconds (amp + filter release)\nconst P_LEVEL:   i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:     StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// three oscillator phases per voice\nconst vPhA:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw, tuned down\nconst vPhB:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw, tuned up\nconst vPhC:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse, centre\n\n// amplitude envelope\nconst vAEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 sus 4 rel\n// filter envelope\nconst vFEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhA[v] = 0.0; vPhB[v] = 0.0; vPhC[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_DETUNE]  = 0.35;\n  params[P_CUTOFF]  = 0.5;\n  params[P_RESO]    = 0.35;\n  params[P_ENVAMT]  = 0.6;\n  params[P_ATTACK]  = 0.06;\n  params[P_RELEASE] = 0.35;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // prefer a free voice, else steal the oldest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  // staggered start phases so the three detuned oscillators beat from the\n  // first sample rather than phase-locking to a thin tone.\n  vPhA[slot] = 0.0;\n  vPhB[slot] = 0.33;\n  vPhC[slot] = 0.66;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const detune: f32  = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // attack/release in seconds; fixed musical decay + sustain inside (a\n  // classic fat-pad contour, controlled by the two exposed time knobs).\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.2;\n  const relS: f32 = 0.02  + clampf(params[P_RELEASE], 0.0, 1.0) * 2.5;\n  const decS: f32 = 0.35;   // internal decay time\n  const susL: f32 = 0.75;   // internal sustain level\n\n  // per-sample envelope coefficients (linear-ish rates)\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune in semitones: up to ~ +/-0.30 semitone -> rich tri-osc beating\n  const detSemi: f32 = detune * 0.30;\n  const ratioUp: f32   = f32(Mathf.pow(2.0, detSemi / 12.0));\n  const ratioDown: f32 = f32(Mathf.pow(2.0, -detSemi / 12.0));\n\n  // base cutoff in Hz, exponential 50 Hz .. ~16 kHz\n  const baseHz: f32 = 50.0 * f32(Mathf.pow(320.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6.5 octaves\n  const envOct: f32 = envAmt * 6.5;\n  // ladder resonance feedback 0..~4 (approaches self-oscillation near top)\n  const reso: f32 = resoN * 4.0;\n\n  // headroom: 8 voices summed -> scale so a big chord stays well below 1\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude ADSR ---------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // decay\n        aenv -= decRate * (1.0 - susL);\n        if (aenv <= susL) { aenv = susL; astg = 3; }\n      } else if (astg == 3) {     // sustain\n        aenv = susL;\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      // voice finished?\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter ADSR ------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * (1.0 - susL);\n        if (fenv <= susL) { fenv = susL; fstg = 3; }\n      } else if (fstg == 3) {\n        fenv = susL;\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- three detuned oscillators (saw + saw + pulse) --------\n      const baseInc: f32 = vFreq[v] / sr;\n      const incA: f32 = baseInc * ratioDown;   // saw, tuned down\n      const incB: f32 = baseInc * ratioUp;     // saw, tuned up\n      const incC: f32 = baseInc;               // pulse, centre\n\n      let pa: f32 = vPhA[v];\n      pa += incA; if (pa >= 1.0) pa -= 1.0;\n      let sawA: f32 = 2.0 * pa - 1.0;\n      sawA -= polyBlep(pa, incA);\n      vPhA[v] = pa;\n\n      let pb: f32 = vPhB[v];\n      pb += incB; if (pb >= 1.0) pb -= 1.0;\n      let sawB: f32 = 2.0 * pb - 1.0;\n      sawB -= polyBlep(pb, incB);\n      vPhB[v] = pb;\n\n      let pc: f32 = vPhC[v];\n      pc += incC; if (pc >= 1.0) pc -= 1.0;\n      // band-limited pulse (50% duty) via two saws\n      const pw: f32 = 0.5;\n      let sq: f32 = pc < pw ? 1.0 : -1.0;\n      sq += polyBlep(pc, incC);\n      let pcb: f32 = pc + (1.0 - pw);\n      if (pcb >= 1.0) pcb -= 1.0;\n      sq -= polyBlep(pcb, incC);\n      vPhC[v] = pc;\n\n      // mix the three oscillators (two saws give the fat body, pulse adds\n      // hollow weight). detune spreads the saws so the sum beats richly.\n      let osc: f32 = (sawA + sawB) * 0.38 + sq * 0.30;\n\n      // ---- MOOG-style 4-pole ladder low-pass --------------------\n      // cutoff from base + filter envelope (octaves), per-voice\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      // one-pole coefficient\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      // resonance feedback from last stage; tanh on the input keeps the\n      // ladder warm and stable (the signature soft saturation).\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      // each stage gently saturates too, for that fat ladder colour\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      let voice: f32 = s3 * aenv * vVel[v];\n      outL += voice;\n    }\n\n    // ---- sum + soft saturate for analog glue + output level -----\n    let mix: f32 = outL * voiceScale;\n    mix = f32(Mathf.tanh(mix * 3.2));\n    mix *= level;\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000061000
}