  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Realm FM</title>\n<style>\n  :root{ --acc:#e0509a; --acc2:#50c8d0; --bg0:#0e0710; --bg1:#1a0d1e; --ink:#f6e9f2; --dim:#9a7090; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#2a1230 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#1c0f22,#0e0710); border:1px solid rgba(224,80,154,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(246,233,242,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.0s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:104px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#180b1c,#0d0710); border:1px solid rgba(224,80,154,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(232,214,228,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(224,80,154,.6)); }\n  .pcap{ fill:#160a1a; stroke:rgba(224,80,154,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(224,80,154,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(224,80,154,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">REALM&nbsp;FM</span><span class=\"sub\">fm + filter (rcm)</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">FM&nbsp;·&nbsp;FILTER</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Ratio\",idx:0,def:0.28},{name:\"Index\",idx:1,def:0.45},{name:\"Cutoff\",idx:2,def:0.5},{name:\"Env\",idx:3,def:0.6},{name:\"Decay\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#e0509a\"/><stop offset=\"1\" stop-color=\"#50c8d0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=(p.idx===0)?(Math.round((0.5+v*6.5)*2)/2).toFixed(1)+\":1\":Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var ratio=vals[0], index=vals[1], cut=vals[2], env=vals[3]; var baseY=H-12, top=14;\n    var rq=Math.round((0.5+ratio*6.5)*2)/2;\n    // filter env sweeps cutoff (loops) — RCM movement\n    var cyc=(ts/1600)%1; var fenv=Math.exp(-cyc*(1+env*3)); var effCut=cut+env*0.5*fenv; if(effCut>1)effCut=1;\n    // FM harmonic spectrum bars (magenta), attenuated above cutoff\n    var N=30;\n    for(var h=1;h<=N;h++){ var f=(h*rq*0.11)%3.0; // spectral position spread by ratio (folded)\n      var lx=(h/N); // draw evenly for clarity\n      // FM harmonic amplitude grows with Index\n      var amp=(1/(1+h*0.35))*(0.4+index*0.9*Math.abs(Math.sin(h*rq*0.7)));\n      // filter attenuation\n      var roll = lx<=effCut ? 1 : Math.exp(-(lx-effCut)*7);\n      var reso = (Math.abs(lx-effCut)<0.03)?1.6:1; // resonant bump\n      var a=amp*roll*reso; var bh=Math.min(baseY-top, a*(baseY-top));\n      var x=12+lx*(W-24);\n      ctx.strokeStyle=\"rgba(224,80,154,\"+(0.35+a*0.5)+\")\"; ctx.lineWidth=Math.max(2,(W-24)/N-2.5);\n      ctx.beginPath(); ctx.moveTo(x,baseY); ctx.lineTo(x,baseY-bh); ctx.stroke();\n    }\n    // filter response curve (cyan)\n    ctx.beginPath();\n    for(var xx=0;xx<=W-24;xx+=3){ var lx=xx/(W-24); var roll= lx<=effCut?1:Math.exp(-(lx-effCut)*7); var reso=(Math.abs(lx-effCut)<0.04)?(1+ (0.6)):1; var y=baseY-(roll*reso)*(baseY-top)*0.9; if(xx===0)ctx.moveTo(12+xx,y); else ctx.lineTo(12+xx,y); }\n    ctx.strokeStyle=\"rgba(80,200,208,0.9)\"; ctx.lineWidth=1.8; ctx.shadowColor=\"#50c8d0\"; ctx.shadowBlur=7; ctx.stroke(); ctx.shadowBlur=0;\n    // cutoff marker\n    var cx=12+effCut*(W-24); ctx.strokeStyle=\"rgba(80,200,208,0.4)\"; ctx.setLineDash([3,3]); ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(cx,top); ctx.lineTo(cx,baseY); ctx.stroke(); ctx.setLineDash([]);\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  REALM FM — an FM+filter hybrid voice (Yamaha SY77/SY99 \"RCM\"\n//  lineage). Where FM Core is pure operators, Realm FM runs a two-op FM\n//  carrier THROUGH a resonant analog-style low-pass with its own\n//  envelope — the \"Realtime Convolution & Modulation\" idea of pairing\n//  digital FM with a subtractive filter. Ratio and Index shape the FM\n//  timbre; Cutoff + Env Amount sweep the filter for the evolving, vocal\n//  RCM character. 8-voice poly. Controls: Ratio, Index, Cutoff, Env\n//  Amount, Decay, Level. No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\nconst TAU: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vCar: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vMod: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_RATIO: i32 = 0; const P_INDEX: i32 = 1; const P_CUTOFF: i32 = 2; const P_ENV: i32 = 3; const P_DECAY: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vCar[i] = 0.0; vMod[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_RATIO] = 0.28; params[P_INDEX] = 0.45; params[P_CUTOFF] = 0.5; params[P_ENV] = 0.6; params[P_DECAY] = 0.6; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vCar[slot] = 0.0; vMod[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const ratioN: f32 = clampf(params[P_RATIO], 0.0, 1.0);\n  const indexN: f32 = clampf(params[P_INDEX], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const ratio: f32 = f32(i32((0.5 + ratioN * 6.5) * 2.0 + 0.5)) * 0.5;\n  const index: f32 = indexN * 6.0;\n  const atkInc: f32 = 1.0 / (0.005 * sampleRate);\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / ((0.1 + decayN * 2.4) * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.3 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate)));\n  const baseCut: f32 = 60.0 * f32(Mathf.exp(cutoffN * 5.2));\n  const envSpan: f32 = envN * 8500.0;\n  const k: f32 = 2.0 - 1.85 * 0.5;                       // moderate resonance\n  const out: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] >= 1.0) { vAmp[s] = 1.0; vSt[s] = 3; } }\n      else if (vSt[s] == 3) { vAmp[s] *= decCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      // 2-op FM\n      let mp: f32 = vMod[s] + (fr * ratio) / sampleRate; if (mp >= 1.0) mp -= 1.0; vMod[s] = mp;\n      const modOut: f32 = f32(Mathf.sin(mp * TAU));\n      let cp: f32 = vCar[s] + fr / sampleRate; if (cp >= 1.0) cp -= 1.0; vCar[s] = cp;\n      let osc: f32 = f32(Mathf.sin(cp * TAU + index * modOut));\n      // resonant LP with filter env\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      mix += lpN * vAmp[s] * vVel[s];\n    }\n    let o: f32 = f32(Mathf.tanh(mix * out * 1.3));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751311400000
}