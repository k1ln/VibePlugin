{
  "format": 1,
  "name": "Console EQ",
  "isInstrument": false,
  "explanation": "A class-A console channel equaliser: a musical low shelf, a sweepable mid bell with proportional-Q that narrows as you push it, and a high shelf with air. The full strip runs through gentle transformer-style saturation for analog weight. Controls: Low Gain, Mid Freq, Mid Gain, High Gain and Drive.",
  "params": [
    {
      "name": "Low Gain",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mid Freq",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mid Gain",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "High Gain",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Drive",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.25
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --rot{syntax:'<angle>';inherits:false;initial-value:0deg}\n:root{\n  --ac:#ffd166;--ac2:#ffe08a;\n  --red:#c4302b;--red2:#e94e3c;--redDk:#7a1410;\n  --face:#1d1c1b;--face2:#262321;\n  --steel:#3a352f;\n  --ink:#0c0b0a;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{margin:0;font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#e8e1d4;\n  background:\n    radial-gradient(120% 80% at 50% -10%,#2a2724 0%,#121110 60%,#070605 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px}\n\n/* ====== THE CHANNEL STRIP ====== */\n.strip{\n  position:relative;width:300px;\n  border-radius:8px 8px 10px 10px;\n  background:\n    /* brushed vertical satin */\n    repeating-linear-gradient(90deg,rgba(255,255,255,.018) 0 1px,transparent 1px 3px),\n    linear-gradient(180deg,#34302a 0%,#27231f 7%,#1f1c19 8%,#221f1b 60%,#1a1815 100%);\n  border:1px solid #0a0908;\n  box-shadow:\n    0 40px 80px rgba(0,0,0,.7),\n    0 6px 14px rgba(0,0,0,.55),\n    inset 0 1px 0 rgba(255,255,255,.07),\n    inset 0 0 0 1px rgba(0,0,0,.45);\n  padding:0 0 18px;\n  animation:rise .7s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(18px) scale(.985)}to{opacity:1;transform:none}}\n\n/* screws in the four corners */\n.screw{position:absolute;width:13px;height:13px;border-radius:50%;z-index:6;\n  background:radial-gradient(circle at 38% 32%,#7d756a,#2c2823 70%,#181513);\n  box-shadow:inset 0 1px 1px rgba(255,255,255,.35),inset 0 -1px 2px rgba(0,0,0,.7),0 1px 2px rgba(0,0,0,.6)}\n.screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n  background:linear-gradient(var(--sa,55deg),transparent 44%,#0c0a09 44% 56%,transparent 56%)}\n.screw.tl{top:9px;left:9px;--sa:120deg}.screw.tr{top:9px;right:9px;--sa:35deg}\n.screw.bl{bottom:9px;left:9px;--sa:70deg}.screw.br{bottom:9px;right:9px;--sa:150deg}\n\n/* ====== HEADER PLATE ====== */\n.head{position:relative;margin:0;padding:16px 16px 13px;text-align:center;\n  border-bottom:1px solid #0b0a09;\n  background:linear-gradient(180deg,rgba(255,255,255,.04),transparent 70%)}\n.brand{display:flex;align-items:center;justify-content:center;gap:9px}\n.pwr{width:8px;height:8px;border-radius:50%;background:var(--red2);\n  box-shadow:0 0 8px var(--red2),0 0 2px #fff;animation:beat 2.6s ease-in-out infinite}\n@keyframes beat{0%,100%{opacity:.5;box-shadow:0 0 4px var(--red)}50%{opacity:1;box-shadow:0 0 12px var(--red2)}}\nh1{margin:0;font-size:15px;font-weight:800;letter-spacing:.34em;text-transform:uppercase;\n  color:#efe7d8;text-shadow:0 1px 0 #000,0 0 14px rgba(255,209,102,.12)}\n.model{margin-top:4px;font-size:8.5px;letter-spacing:.42em;color:#8a7f6c;text-transform:uppercase}\n.serial{position:absolute;top:14px;right:14px;font-size:7px;letter-spacing:.2em;color:#5d564b;\n  font-variant-numeric:tabular-nums}\n\n/* ====== EQ CURVE WINDOW ====== */\n.scope{position:relative;margin:13px 16px 4px;height:84px;border-radius:5px;\n  background:\n    radial-gradient(120% 140% at 50% 0%,#0e1612 0%,#070b09 70%),\n    #060807;\n  border:1px solid #000;\n  box-shadow:inset 0 2px 8px rgba(0,0,0,.85),inset 0 0 0 1px rgba(255,209,102,.05),\n    0 0 0 1px rgba(255,255,255,.03);\n  overflow:hidden}\n.scope svg{position:absolute;inset:0;width:100%;height:100%}\n.glassgrid line{stroke:rgba(255,209,102,.07);stroke-width:.5}\n.zeroline{stroke:rgba(255,209,102,.22);stroke-width:.8;stroke-dasharray:2 3}\n#curve{fill:none;stroke:var(--ac);stroke-width:2;\n  filter:drop-shadow(0 0 4px rgba(255,209,102,.7));\n  transition:none}\n#fill{fill:url(#fg);opacity:.16}\n.scan{position:absolute;inset:0;pointer-events:none;\n  background:repeating-linear-gradient(0deg,rgba(0,0,0,.18) 0 1px,transparent 1px 3px)}\n.glow{position:absolute;inset:0;pointer-events:none;\n  background:radial-gradient(60% 80% at 50% 120%,rgba(255,209,102,.10),transparent 70%)}\n.scoplbl{position:absolute;bottom:3px;left:6px;font-size:7px;letter-spacing:.18em;color:#5e7568}\n.scoplbl.r{left:auto;right:6px}\n\n/* ====== KNOB ROWS ====== */\n.bank{padding:8px 6px 0}\n.row{position:relative;display:flex;align-items:center;gap:13px;\n  padding:11px 14px;margin:0 8px;border-radius:6px;\n  transition:background .2s ease}\n.row+.row{border-top:1px solid rgba(0,0,0,.55);box-shadow:0 -1px 0 rgba(255,255,255,.025)}\n.row:hover{background:rgba(255,255,255,.022)}\n.row.drv{margin-top:6px}\n\n/* the knob */\n.knob{position:relative;width:74px;height:74px;flex:0 0 74px;cursor:ns-resize;\n  user-select:none;touch-action:none;--rot:0deg}\n.knob .ring{position:absolute;inset:-3px;border-radius:50%;\n  background:conic-gradient(from 215deg,\n    color-mix(in srgb,var(--kc,var(--red2)) 90%,#fff) 0deg,\n    var(--kc,var(--red2)) calc(var(--rot) + .001deg),\n    rgba(255,255,255,.06) var(--rot) 290deg, transparent 290deg);\n  -webkit-mask:radial-gradient(circle,transparent 35px,#000 36px);\n  mask:radial-gradient(circle,transparent 35px,#000 36px);\n  filter:drop-shadow(0 0 5px color-mix(in srgb,var(--kc,var(--red2)) 55%,transparent))}\n.knob .ticks{position:absolute;inset:-7px;border-radius:50%;\n  background:repeating-conic-gradient(from 211deg,\n    rgba(255,255,255,.3) 0 .9deg,transparent .9deg 25.4deg);\n  -webkit-mask:radial-gradient(circle,transparent 39px,#000 40px,#000 43px,transparent 44px);\n  mask:radial-gradient(circle,transparent 39px,#000 40px,#000 43px,transparent 44px);\n  opacity:.7}\n/* the body of the knob — chicken-head console style */\n.knob .body{position:absolute;inset:7px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 22%,#5a504a 0%,#2c2724 38%,#171311 72%,#0a0807 100%);\n  box-shadow:\n    inset 0 3px 6px rgba(255,255,255,.14),\n    inset 0 -6px 12px rgba(0,0,0,.8),\n    0 4px 8px rgba(0,0,0,.65),\n    0 1px 0 rgba(255,255,255,.05);\n  transform:rotate(var(--rot));\n  transition:filter .15s}\n.knob .body::before{content:\"\";position:absolute;inset:11px;border-radius:50%;\n  background:radial-gradient(circle at 50% 35%,#352f2a,#141110);\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.08),inset 0 -2px 4px rgba(0,0,0,.7)}\n/* pointer notch */\n.knob .body::after{content:\"\";position:absolute;top:6px;left:50%;width:4px;height:17px;\n  margin-left:-2px;border-radius:2px;\n  background:linear-gradient(var(--kc,var(--red2)),color-mix(in srgb,var(--kc,var(--red2)) 50%,#000));\n  box-shadow:0 0 7px var(--kc,var(--red2)),inset 0 1px 0 rgba(255,255,255,.4)}\n.knob.act .body{filter:brightness(1.12)}\n.knob.act .ring{filter:drop-shadow(0 0 11px color-mix(in srgb,var(--kc,var(--red2)) 80%,transparent))}\n\n/* the label + readout block */\n.meta{flex:1;min-width:0}\n.lbl{font-size:11px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:#d7cdba}\n.sub{font-size:8px;letter-spacing:.16em;text-transform:uppercase;color:#857a68;margin-top:2px}\n.readout{margin-top:8px;display:inline-flex;align-items:baseline;gap:4px;\n  padding:4px 9px;border-radius:4px;min-width:74px;justify-content:center;\n  background:linear-gradient(#0a0d0b,#050706);\n  border:1px solid #000;box-shadow:inset 0 1px 3px rgba(0,0,0,.8),0 1px 0 rgba(255,255,255,.04)}\n.num{font-size:15px;font-weight:700;font-variant-numeric:tabular-nums;\n  color:#9ff0c8;text-shadow:0 0 7px rgba(120,255,190,.45);letter-spacing:.02em}\n.row.drv .num{color:#ffb37a;text-shadow:0 0 7px rgba(255,150,80,.5)}\n.unit{font-size:8px;letter-spacing:.1em;color:#5f7a6c}\n.row.drv .unit{color:#7a5f4f}\n\n/* drive: small VU needle next to the readout */\n.vu{position:relative;width:54px;height:30px;flex:0 0 54px;border-radius:3px;\n  background:radial-gradient(120% 150% at 50% 120%,#f3e6c4,#d8c79b 60%,#b9a878);\n  border:1px solid #2a2218;overflow:hidden;\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.5),inset 0 -3px 6px rgba(120,90,40,.4),0 1px 2px rgba(0,0,0,.5)}\n.vu .arc{position:absolute;inset:0}\n.vu .arc path{fill:none;stroke:#6b5a3a;stroke-width:.7}\n.vu .arc .hot{stroke:#b3361f;stroke-width:1.4}\n.vu .needle{position:absolute;left:50%;bottom:-2px;width:1.4px;height:26px;margin-left:-.7px;\n  background:linear-gradient(#1a1208,#3a2a14);transform-origin:50% 100%;\n  transform:rotate(var(--vu,-42deg));transition:transform .18s cubic-bezier(.3,.7,.3,1)}\n.vu .pin{position:absolute;left:50%;bottom:-2px;width:5px;height:5px;margin-left:-2.5px;\n  border-radius:50%;background:#2a1f10;box-shadow:0 0 0 1px rgba(0,0,0,.4)}\n.vu .lbl{position:absolute;top:1px;left:0;right:0;text-align:center;font-size:6px;\n  letter-spacing:.1em;color:#5a4a2c}\n\n/* footer */\n.foot{margin:14px 18px 0;padding-top:11px;border-top:1px solid rgba(255,255,255,.045);\n  font-size:9.5px;line-height:1.5;color:#8a7f6c;letter-spacing:.02em}\n.foot b{color:#bfae90;font-weight:700;letter-spacing:.06em}\n</style></head><body>\n  <div class=\"strip\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"serial\">№ 1073 · CH-01</div>\n      <div class=\"brand\"><span class=\"pwr\"></span><h1>Console&nbsp;EQ</h1></div>\n      <div class=\"model\">Class-A Discrete Channel Equaliser</div>\n    </div>\n\n    <!-- live EQ transfer-curve window -->\n    <div class=\"scope\">\n      <svg viewBox=\"0 0 300 84\" preserveAspectRatio=\"none\">\n        <defs><linearGradient id=\"fg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0\" stop-color=\"#ffd166\"/><stop offset=\"1\" stop-color=\"#ffd166\" stop-opacity=\"0\"/>\n        </linearGradient></defs>\n        <g class=\"glassgrid\">\n          <line x1=\"0\" y1=\"21\" x2=\"300\" y2=\"21\"/><line x1=\"0\" y1=\"63\" x2=\"300\" y2=\"63\"/>\n          <line x1=\"75\" y1=\"0\" x2=\"75\" y2=\"84\"/><line x1=\"150\" y1=\"0\" x2=\"150\" y2=\"84\"/><line x1=\"225\" y1=\"0\" x2=\"225\" y2=\"84\"/>\n        </g>\n        <line class=\"zeroline\" x1=\"0\" y1=\"42\" x2=\"300\" y2=\"42\"/>\n        <path id=\"fill\"></path>\n        <path id=\"curve\"></path>\n      </svg>\n      <div class=\"scan\"></div><div class=\"glow\"></div>\n      <div class=\"scoplbl\">20 Hz</div><div class=\"scoplbl r\">20 kHz</div>\n    </div>\n\n    <div class=\"bank\" id=\"bank\"></div>\n\n    <div class=\"foot\">\n      <b>SIGNAL PATH</b> — musical low shelf · proportional-Q mid bell · airy high shelf, all driven through transformer-style saturation. Drag knobs · double-click to reset.\n    </div>\n  </div>\n\n<script>\n(function(){\n  // ---- params straight from spec ----\n  var P=[\n    {i:0,name:\"Low Gain\", sub:\"Shelf · 100 Hz\",  min:0,max:1,def:0.5,  kc:\"var(--red2)\", unit:\"dB\", map:gainDb},\n    {i:1,name:\"Mid Freq\", sub:\"Sweep · Hz\",       min:0,max:1,def:0.45, kc:\"#ff8a3c\",     unit:\"Hz\", map:freqHz},\n    {i:2,name:\"Mid Gain\", sub:\"Prop-Q Bell\",      min:0,max:1,def:0.5,  kc:\"var(--red2)\", unit:\"dB\", map:gainDb},\n    {i:3,name:\"High Gain\",sub:\"Shelf · Air\",      min:0,max:1,def:0.5,  kc:\"#ffb454\",     unit:\"dB\", map:gainDb},\n    {i:4,name:\"Drive\",    sub:\"Transformer\",      min:0,max:1,def:0.25, kc:\"#e94e3c\",     unit:\"%\",  map:pct, drive:true}\n  ];\n  // value mappers (purely for the readout/curve; raw [min,max] still sent to host)\n  function gainDb(n){ return (n*2-1)*15; }        // -15..+15 dB\n  function freqHz(n){ return Math.round(200*Math.pow(50,n)); } // 200 Hz .. 10 kHz log\n  function pct(n){ return n*100; }\n  function fmt(p,n){ var v=p.map(n);\n    if(p.unit===\"Hz\"){ return v>=1000?(v/1000).toFixed(2).replace(/0$/,\"\")+\"k\":Math.round(v); }\n    if(p.unit===\"dB\"){ return (v>=0?\"+\":\"\")+v.toFixed(1); }\n    return Math.round(v); }\n\n  var bank=document.getElementById('bank'), state=[];\n  P.forEach(function(p){\n    var row=document.createElement('div');\n    row.className='row'+(p.drive?' drv':'');\n    row.style.setProperty('--kc',p.kc);\n    var vu = p.drive\n      ? '<div class=\"vu\"><svg class=\"arc\" viewBox=\"0 0 54 30\">'\n       +'<path d=\"M8 28 A 22 22 0 0 1 46 28\"/>'\n       +'<path class=\"hot\" d=\"M37 13.2 A 22 22 0 0 1 46 28\"/></svg>'\n       +'<div class=\"lbl\">DRIVE</div><div class=\"needle\"></div><div class=\"pin\"></div></div>'\n      : '';\n    row.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\"><div class=\"ticks\"></div><div class=\"ring\"></div><div class=\"body\"></div></div>'+\n      '<div class=\"meta\"><div class=\"lbl\">'+p.name+'</div><div class=\"sub\">'+p.sub+'</div>'+\n        '<div class=\"readout\"><span class=\"num\"></span><span class=\"unit\">'+p.unit+'</span></div></div>'+\n      vu;\n    bank.appendChild(row);\n\n    var knob=row.querySelector('.knob'), num=row.querySelector('.num'),\n        needle=row.querySelector('.needle');\n    var st={p:p, n:p.def, knob:knob,\n      paint:function(){\n        var n=this.n;\n        knob.style.setProperty('--rot',(n*290)+'deg');\n        num.textContent=fmt(p,n);\n        if(needle) needle.style.setProperty('--vu',(-42+n*84)+'deg');\n        if(window.vstai&&window.vstai.setParam){\n          var v=p.min+(p.max-p.min)*n; window.vstai.setParam(p.i,v);\n        }\n        drawCurve();\n      }};\n    state.push(st);\n\n    var dy=0,start=0;\n    knob.addEventListener('pointerdown',function(e){\n      knob.classList.add('act'); dy=e.clientY; start=st.n;\n      knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!knob.classList.contains('act'))return;\n      var n=start+(dy-e.clientY)/220; st.n=n<0?0:n>1?1:n; st.paint();\n    });\n    function end(){ knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ st.n=p.def; st.paint(); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault();\n      st.n=Math.max(0,Math.min(1,st.n+(e.deltaY<0?.03:-.03))); st.paint(); },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      var s=e.shiftKey?.1:.02;\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){st.n=Math.min(1,st.n+s);st.paint();e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){st.n=Math.max(0,st.n-s);st.paint();e.preventDefault();}\n    });\n  });\n\n  // ---- live EQ transfer curve ----\n  var curve=document.getElementById('curve'), fill=document.getElementById('fill');\n  var rafPending=false;\n  function drawCurve(){ if(rafPending)return; rafPending=true; requestAnimationFrame(_draw); }\n  function _draw(){\n    rafPending=false;\n    var lo=gainDb(state[0].n), mf=state[1].n, mg=gainDb(state[2].n),\n        hi=gainDb(state[3].n), dr=state[4].n;\n    // proportional Q: bell narrows as gain pushes\n    var Q=0.6+Math.abs(mg)/15*1.7;\n    var fc=Math.log(freqHz(state[1].n))/Math.log(2);   // mid centre in log2\n    var W=300,H=84, pts=[];\n    for(var x=0;x<=W;x+=3){\n      var f=Math.log2(20)+(x/W)*(Math.log2(20000)-Math.log2(20)); // log freq axis\n      // low shelf around ~120Hz\n      var ls=lo*0.5*(1-Math.tanh((f-Math.log2(160))*1.3));\n      // high shelf around ~5kHz\n      var hs=hi*0.5*(1+Math.tanh((f-Math.log2(4500))*1.1));\n      // mid bell\n      var d=(f-fc)*Q;\n      var bell=mg*Math.exp(-d*d*1.1);\n      // drive lifts the whole curve slightly (transformer weight)\n      var g=ls+hs+bell+dr*1.2;\n      var y=H/2 - g*(H/2/18); // ±18 dB fits window\n      pts.push([x,y]);\n    }\n    var dpath=\"M\"+pts.map(function(q){return q[0].toFixed(1)+\" \"+q[1].toFixed(1);}).join(\" L\");\n    curve.setAttribute('d',dpath);\n    fill.setAttribute('d',dpath+\" L\"+W+\" \"+H+\" L0 \"+H+\" Z\");\n  }\n\n  function init(){ state.forEach(function(s){ s.paint(); }); drawCurve(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(init); else init();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  CONSOLE EQ — class-A console channel equaliser\n//  A three-band program EQ modelled on a vintage broadcast console strip:\n//  a musical LOW SHELF, a sweepable MID BELL with proportional-Q (the bell\n//  narrows as you push it, the way an inductor-coupled console band does),\n//  and a HIGH SHELF with an \"air\" lift. The whole strip runs through a gentle\n//  class-A style transformer/op-amp saturation (DRIVE) for analog weight.\n//  Bands are stable RBJ biquads in Direct-Form I. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- parameter indices (must match spec.json + the GUI) --------------\nconst P_LOW_GAIN:  i32 = 0; // 0..1 -> low shelf  -12..+12 dB  (corner ~100 Hz)\nconst P_MID_FREQ:  i32 = 1; // 0..1 -> mid bell centre 220..7000 Hz (log)\nconst P_MID_GAIN:  i32 = 2; // 0..1 -> mid bell   -15..+15 dB  (proportional-Q)\nconst P_HIGH_GAIN: i32 = 3; // 0..1 -> high shelf -12..+15 dB  (air, corner ~10 kHz)\nconst P_DRIVE:     i32 = 4; // 0..1 -> class-A saturation amount\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- per-channel Direct-Form I biquad state (x[n-1],x[n-2],y[n-1],y[n-2]) ----\n// three cascaded bands: 0 = low shelf, 1 = mid bell, 2 = high shelf\nconst lsX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst mdX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst hsX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hsX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hsY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hsY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// ---- shared coefficient registers (recomputed once per process block) ----\n// low shelf\nlet ls_b0: f32 = 1.0; let ls_b1: f32 = 0.0; let ls_b2: f32 = 0.0;\nlet ls_a1: f32 = 0.0; let ls_a2: f32 = 0.0;\n// mid bell\nlet md_b0: f32 = 1.0; let md_b1: f32 = 0.0; let md_b2: f32 = 0.0;\nlet md_a1: f32 = 0.0; let md_a2: f32 = 0.0;\n// high shelf\nlet hs_b0: f32 = 1.0; let hs_b1: f32 = 0.0; let hs_b2: f32 = 0.0;\nlet hs_a1: f32 = 0.0; let hs_a2: f32 = 0.0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lsX1[c] = 0.0; lsX2[c] = 0.0; lsY1[c] = 0.0; lsY2[c] = 0.0;\n    mdX1[c] = 0.0; mdX2[c] = 0.0; mdY1[c] = 0.0; mdY2[c] = 0.0;\n    hsX1[c] = 0.0; hsX2[c] = 0.0; hsY1[c] = 0.0; hsY2[c] = 0.0;\n  }\n  params[P_LOW_GAIN]  = 0.5;  // flat\n  params[P_MID_FREQ]  = 0.45; // ~1 kHz region\n  params[P_MID_GAIN]  = 0.5;  // flat\n  params[P_HIGH_GAIN] = 0.5;  // flat\n  params[P_DRIVE]     = 0.25; // a touch of analog weight\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// dB -> linear amplitude\n@inline function dbToGain(db: f32): f32 {\n  return f32(Mathf.exp(db * 0.11512925)); // ln(10)/20\n}\n\n// class-A style asymmetric soft saturation: warm, harmonically rich,\n// bounded to roughly ±1.1 so the output never runs away.\n@inline function saturate(x: f32, amt: f32): f32 {\n  // amt 0 -> near transparent, 1 -> noticeable transformer warmth\n  const k: f32 = 1.0 + amt * 3.0;\n  const t: f32 = f32(Mathf.tanh(x * k));\n  // gentle even-harmonic asymmetry for \"class-A\" feel\n  const asym: f32 = amt * 0.10 * (t * t - 0.5);\n  // blend dry/driven and compensate the make-up of tanh so level stays put\n  const driven: f32 = (t + asym) / k;\n  return x + amt * (driven - x);\n}\n\n// ---- coefficient builders (RBJ cookbook, normalised by a0) -----------\nfunction computeLowShelf(f0: f32, dbGain: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const S: f32 = 0.8; // shelf slope (broad, console-like)\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / S - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) - (A - 1.0) * cw + tsa);\n  const b1: f32 =  2.0 * A * ((A - 1.0) - (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) - (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) + (A - 1.0) * cw + tsa;\n  const a1: f32 = -2.0 *    ((A - 1.0) + (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) + (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  ls_b0 = b0 * inv; ls_b1 = b1 * inv; ls_b2 = b2 * inv;\n  ls_a1 = a1 * inv; ls_a2 = a2 * inv;\n}\n\nfunction computeMidBell(f0: f32, dbGain: f32, q: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw / (2.0 * q);\n\n  const b0: f32 = 1.0 + alpha * A;\n  const b1: f32 = -2.0 * cw;\n  const b2: f32 = 1.0 - alpha * A;\n  const a0: f32 = 1.0 + alpha / A;\n  const a1: f32 = -2.0 * cw;\n  const a2: f32 = 1.0 - alpha / A;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  md_b0 = b0 * inv; md_b1 = b1 * inv; md_b2 = b2 * inv;\n  md_a1 = a1 * inv; md_a2 = a2 * inv;\n}\n\nfunction computeHighShelf(f0: f32, dbGain: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const S: f32 = 0.9;\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / S - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) + (A - 1.0) * cw + tsa);\n  const b1: f32 = -2.0 * A * ((A - 1.0) + (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) + (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) - (A - 1.0) * cw + tsa;\n  const a1: f32 =  2.0 *    ((A - 1.0) - (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) - (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  hs_b0 = b0 * inv; hs_b1 = b1 * inv; hs_b2 = b2 * inv;\n  hs_a1 = a1 * inv; hs_a2 = a2 * inv;\n}\n\nexport function process(n: i32): void {\n  // --- map params to musical ranges -----------------------------------\n  const lowDb:  f32 = (clampf(params[P_LOW_GAIN],  0.0, 1.0) - 0.5) * 24.0;   // -12..+12\n  const midN:   f32 = clampf(params[P_MID_FREQ],   0.0, 1.0);\n  const midDb:  f32 = (clampf(params[P_MID_GAIN],  0.0, 1.0) - 0.5) * 30.0;   // -15..+15\n  const highDb: f32 = (clampf(params[P_HIGH_GAIN], 0.0, 1.0) - 0.5) * 27.0;   // -13.5..+13.5\n  const drive:  f32 = clampf(params[P_DRIVE],      0.0, 1.0);\n\n  // log-sweep the mid centre 220 Hz .. 7000 Hz, clamped below Nyquist\n  let midHz: f32 = f32(220.0 * Mathf.exp(midN * 3.456)); // 220 * (7000/220)^midN\n  const nyq: f32 = sampleRate * 0.45;\n  if (midHz > nyq) midHz = nyq;\n  if (midHz < 20.0) midHz = 20.0;\n\n  // proportional-Q: gentle at small boosts, tighter as you push it,\n  // the way a console's inductor band narrows with drive.\n  const adb: f32 = midDb < 0.0 ? -midDb : midDb;\n  const midQ: f32 = clampf(0.5 + adb * 0.13, 0.4, 4.0);\n\n  // fixed shelf corners, console-style\n  let lowHz: f32 = 100.0;\n  let highHz: f32 = 10000.0;\n  if (highHz > nyq) highHz = nyq;\n  if (lowHz < 20.0) lowHz = 20.0;\n\n  computeLowShelf(lowHz, lowDb);\n  computeMidBell(midHz, midDb, midQ);\n  computeHighShelf(highHz, highDb);\n\n  // a tiny output trim so heavy simultaneous boosts + drive stay <~1.0 peak\n  const outTrim: f32 = 0.85;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n\n    let lx1: f32 = lsX1[c]; let lx2: f32 = lsX2[c]; let ly1: f32 = lsY1[c]; let ly2: f32 = lsY2[c];\n    let mx1: f32 = mdX1[c]; let mx2: f32 = mdX2[c]; let my1: f32 = mdY1[c]; let my2: f32 = mdY2[c];\n    let hx1: f32 = hsX1[c]; let hx2: f32 = hsX2[c]; let hy1: f32 = hsY1[c]; let hy2: f32 = hsY2[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // low shelf\n      let y: f32 = ls_b0 * x + ls_b1 * lx1 + ls_b2 * lx2 - ls_a1 * ly1 - ls_a2 * ly2;\n      lx2 = lx1; lx1 = x; ly2 = ly1; ly1 = y;\n\n      // mid bell\n      const mIn: f32 = y;\n      let ym: f32 = md_b0 * mIn + md_b1 * mx1 + md_b2 * mx2 - md_a1 * my1 - md_a2 * my2;\n      mx2 = mx1; mx1 = mIn; my2 = my1; my1 = ym;\n\n      // high shelf\n      const hIn: f32 = ym;\n      let yh: f32 = hs_b0 * hIn + hs_b1 * hx1 + hs_b2 * hx2 - hs_a1 * hy1 - hs_a2 * hy2;\n      hx2 = hx1; hx1 = hIn; hy2 = hy1; hy1 = yh;\n\n      // class-A style saturation across the whole strip\n      let s: f32 = saturate(yh, drive);\n\n      outBuf[base + f] = clampf(s * outTrim, -1.2, 1.2);\n    }\n\n    lsX1[c] = lx1; lsX2[c] = lx2; lsY1[c] = ly1; lsY2[c] = ly2;\n    mdX1[c] = mx1; mdX2[c] = mx2; mdY1[c] = my1; mdY2[c] = my2;\n    hsX1[c] = hx1; hsX2[c] = hx2; hsY1[c] = hy1; hsY2[c] = hy2;\n  }\n}\n",
  "publishedAt": 1751000037000
}