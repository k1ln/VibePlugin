{
  "format": 1,
  "name": "Vector Wave",
  "isInstrument": true,
  "explanation": "A polyphonic vector / wave-sequencing synthesizer. Four single-cycle waves are generated in code and placed on the corners of a square morph pad; a Vector X/Y joystick bilinearly crossfades between them while a slow Wave-Sequence rate walks that point around the pad so the timbre evolves over time on a held note. Up to eight voices keyed per note, each running two slightly detuned vector oscillators into a resonant low-pass with an attack/release contour. Controls: Vector X, Vector Y, Sequence Rate, Cutoff, Attack, Release, Detune and Level.",
  "params": [
    {
      "name": "Vector X",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Vector Y",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Sequence Rate",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Cutoff",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.05
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Detune",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Vector Wave</title>\n<style>\n  :root{\n    --accent:#2ec4b6;\n    --accent2:#54d1ff;\n    --bg0:#04161a;\n    --bg1:#072a30;\n    --panel:#0a3138;\n    --ink:#bfeef0;\n    --dim:#5e8f93;\n    --grid:rgba(46,196,182,.14);\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:'Segoe UI',Helvetica,Arial,sans-serif;\n    background:\n      radial-gradient(120% 90% at 20% 0%,#0b3b42 0%,var(--bg1) 45%,var(--bg0) 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100%;padding:18px;overflow:hidden;\n  }\n  .shell{\n    width:560px;border-radius:18px;position:relative;\n    background:linear-gradient(160deg,#0c373f 0%,#082a30 60%,#062227 100%);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,.6),\n      inset 0 1px 0 rgba(255,255,255,.06),\n      inset 0 0 0 1px rgba(46,196,182,.18);\n    padding:18px 20px 22px;\n  }\n  /* faint moving grid behind everything for 90s-workstation depth */\n  .shell::before{\n    content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n    background-image:\n      linear-gradient(var(--grid) 1px,transparent 1px),\n      linear-gradient(90deg,var(--grid) 1px,transparent 1px);\n    background-size:22px 22px;opacity:.5;\n    animation:drift 14s linear infinite;\n    mask:radial-gradient(120% 120% at 50% 30%,#000 40%,transparent 90%);\n  }\n  @keyframes drift{to{background-position:22px 22px,22px 22px;}}\n\n  header{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;position:relative;}\n  .brand{display:flex;align-items:center;gap:10px;}\n  .logo{width:30px;height:30px;}\n  .title{font-weight:800;letter-spacing:.14em;font-size:15px;\n    background:linear-gradient(90deg,var(--accent),var(--accent2));\n    -webkit-background-clip:text;background-clip:text;color:transparent;}\n  .sub{font-size:9px;letter-spacing:.34em;color:var(--dim);margin-top:2px;}\n  .led{width:9px;height:9px;border-radius:50%;background:var(--accent2);\n    box-shadow:0 0 8px var(--accent2),0 0 16px var(--accent2);\n    animation:pulse 2.4s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{opacity:.45;}50%{opacity:1;}}\n\n  .main{display:flex;gap:18px;position:relative;}\n\n  /* ---------- vector pad ---------- */\n  .padwrap{flex:0 0 246px;}\n  .pad{\n    width:246px;height:246px;border-radius:14px;position:relative;cursor:crosshair;\n    background:radial-gradient(120% 120% at 50% 50%,#0a3036 0%,#05181c 100%);\n    box-shadow:inset 0 0 0 1px rgba(46,196,182,.25),inset 0 0 40px rgba(0,0,0,.6);\n    overflow:hidden;touch-action:none;\n  }\n  .pad svg{position:absolute;inset:0;width:100%;height:100%;}\n  .corner{position:absolute;font-size:8.5px;letter-spacing:.18em;color:var(--dim);\n    text-transform:uppercase;pointer-events:none;}\n  .c-tl{top:7px;left:9px;}.c-tr{top:7px;right:9px;}.c-bl{bottom:7px;left:9px;}.c-br{bottom:7px;right:9px;}\n  .puck{\n    position:absolute;width:26px;height:26px;border-radius:50%;left:0;top:0;\n    margin:-13px 0 0 -13px;pointer-events:none;\n    background:radial-gradient(circle at 35% 30%,#eafffe,var(--accent2) 55%,var(--accent) 100%);\n    box-shadow:0 0 14px var(--accent2),0 0 30px rgba(84,209,255,.6),0 3px 6px rgba(0,0,0,.5);\n  }\n  .puck::after{content:\"\";position:absolute;inset:-12px;border-radius:50%;\n    border:1px solid rgba(84,209,255,.4);animation:halo 2.2s ease-out infinite;}\n  @keyframes halo{0%{transform:scale(.6);opacity:.8;}100%{transform:scale(1.5);opacity:0;}}\n  .orbit{position:absolute;border:1px dashed rgba(84,209,255,.35);border-radius:50%;\n    left:0;top:0;pointer-events:none;transform:translate(-50%,-50%);display:none;}\n  .padmeta{display:flex;justify-content:space-between;margin-top:8px;font-size:10px;}\n  .padmeta b{color:var(--accent2);font-variant-numeric:tabular-nums;}\n\n  /* ---------- right column ---------- */\n  .right{flex:1;display:flex;flex-direction:column;gap:12px;}\n\n  /* wave-sequence timeline */\n  .seq{background:rgba(4,18,21,.6);border-radius:10px;padding:9px 10px 7px;\n    box-shadow:inset 0 0 0 1px rgba(46,196,182,.16);}\n  .seqhead{display:flex;justify-content:space-between;font-size:9px;letter-spacing:.2em;\n    color:var(--dim);text-transform:uppercase;margin-bottom:6px;}\n  .timeline{display:flex;gap:5px;height:42px;align-items:flex-end;position:relative;}\n  .step{flex:1;height:100%;border-radius:5px;position:relative;overflow:hidden;\n    background:rgba(46,196,182,.07);box-shadow:inset 0 0 0 1px rgba(46,196,182,.18);}\n  .step svg{position:absolute;inset:0;width:100%;height:100%;opacity:.85;}\n  .step.on{background:rgba(46,196,182,.2);box-shadow:inset 0 0 0 1px var(--accent),0 0 12px rgba(46,196,182,.5);}\n\n  /* knobs */\n  .knobs{display:grid;grid-template-columns:repeat(3,1fr);gap:8px 6px;}\n  .knob{display:flex;flex-direction:column;align-items:center;gap:3px;cursor:ns-resize;padding:4px 0;}\n  .dial{width:54px;height:54px;position:relative;}\n  .dial svg{width:100%;height:100%;transform:rotate(-90deg);}\n  .dial .cap{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;\n    font-size:9px;color:var(--accent2);font-variant-numeric:tabular-nums;pointer-events:none;}\n  .klabel{font-size:8.5px;letter-spacing:.14em;color:var(--dim);text-transform:uppercase;}\n  .knob:hover .ring{stroke:var(--accent2);}\n  footer{margin-top:12px;display:flex;justify-content:space-between;align-items:center;\n    font-size:8px;letter-spacing:.24em;color:var(--dim);text-transform:uppercase;position:relative;}\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <header>\n      <div class=\"brand\">\n        <svg class=\"logo\" viewBox=\"0 0 40 40\" fill=\"none\">\n          <defs><linearGradient id=\"lg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#2ec4b6\"/><stop offset=\"1\" stop-color=\"#54d1ff\"/></linearGradient></defs>\n          <rect x=\"3\" y=\"3\" width=\"34\" height=\"34\" rx=\"9\" stroke=\"url(#lg)\" stroke-width=\"2\"/>\n          <path d=\"M8 28 C14 8,26 32,32 12\" stroke=\"url(#lg)\" stroke-width=\"2.4\" fill=\"none\" stroke-linecap=\"round\"/>\n          <circle cx=\"20\" cy=\"20\" r=\"3\" fill=\"#54d1ff\"/>\n        </svg>\n        <div>\n          <div class=\"title\">VECTOR WAVE</div>\n          <div class=\"sub\">VECTOR · WAVE-SEQUENCE SYNTHESIZER</div>\n        </div>\n      </div>\n      <div class=\"led\"></div>\n    </header>\n\n    <div class=\"main\">\n      <div class=\"padwrap\">\n        <div class=\"pad\" id=\"pad\">\n          <svg viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">\n            <line x1=\"50\" y1=\"0\" x2=\"50\" y2=\"100\" stroke=\"rgba(46,196,182,.18)\" stroke-width=\".5\"/>\n            <line x1=\"0\" y1=\"50\" x2=\"100\" y2=\"50\" stroke=\"rgba(46,196,182,.18)\" stroke-width=\".5\"/>\n          </svg>\n          <span class=\"corner c-tl\">Saw</span>\n          <span class=\"corner c-tr\">Pulse</span>\n          <span class=\"corner c-bl\">Sine</span>\n          <span class=\"corner c-br\">Tri</span>\n          <div class=\"orbit\" id=\"orbit\"></div>\n          <div class=\"puck\" id=\"puck\"></div>\n        </div>\n        <div class=\"padmeta\">\n          <span>X <b id=\"vx\">0.50</b></span>\n          <span>VECTOR JOYSTICK</span>\n          <span>Y <b id=\"vy\">0.50</b></span>\n        </div>\n      </div>\n\n      <div class=\"right\">\n        <div class=\"seq\">\n          <div class=\"seqhead\"><span>Wave Sequence</span><span id=\"seqlbl\">RATE 0.30</span></div>\n          <div class=\"timeline\" id=\"timeline\"></div>\n        </div>\n        <div class=\"knobs\" id=\"knobs\"></div>\n      </div>\n    </div>\n\n    <footer><span>8-VOICE POLY</span><span>MORPH ENGINE</span><span>v1.0</span></footer>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,+v); }\n  function clamp(x,a,b){ return x<a?a:(x>b?b:x); }\n\n  // ---- single-cycle wave shapes for the previews (match the DSP corners) ----\n  function shape(name,n,phase){\n    var t=(n+ (phase||0))%1; var w=2*Math.PI*t, s=0,k;\n    if(name==='sine') return Math.sin(w);\n    if(name==='tri')  return 4*(t<0.5?t:1-t)-1;\n    if(name==='saw'){ for(k=1;k<=8;k++) s+=Math.sin(w*k)/k; return s*0.55; }\n    for(k=1;k<=9;k+=2) s+=Math.sin(w*k)/k; return s*0.95; // pulse\n  }\n  function wavePath(name,wp,phase,W,H){\n    var d='',N=48,i,x,y;\n    for(i=0;i<=N;i++){ x=i/N*W; y=H/2-shape(name,i/N,phase)*(H*0.36);\n      d+=(i?'L':'M')+x.toFixed(1)+' '+y.toFixed(1); }\n    return d;\n  }\n\n  // ---- VECTOR PAD (params 0 = X, 1 = Y) ----\n  var pad=document.getElementById('pad'),puck=document.getElementById('puck'),\n      orbit=document.getElementById('orbit'),\n      vxEl=document.getElementById('vx'),vyEl=document.getElementById('vy');\n  var vx=0.5, vy=0.5;            // defaults\n  function paintPad(){\n    var w=pad.clientWidth,h=pad.clientHeight;\n    puck.style.left=(vx*w)+'px';\n    puck.style.top=((1-vy)*h)+'px';     // y up\n    vxEl.textContent=vx.toFixed(2);\n    vyEl.textContent=vy.toFixed(2);\n    paintOrbit();\n  }\n  function setPadFromEvent(e){\n    var r=pad.getBoundingClientRect();\n    var px=(e.touches?e.touches[0].clientX:e.clientX)-r.left;\n    var py=(e.touches?e.touches[0].clientY:e.clientY)-r.top;\n    vx=clamp(px/r.width,0,1);\n    vy=clamp(1-py/r.height,0,1);\n    send(0,vx); send(1,vy); paintPad();\n  }\n  var dragPad=false;\n  pad.addEventListener('pointerdown',function(e){ dragPad=true; pad.setPointerCapture(e.pointerId); setPadFromEvent(e); });\n  pad.addEventListener('pointermove',function(e){ if(dragPad) setPadFromEvent(e); });\n  pad.addEventListener('pointerup',function(){ dragPad=false; });\n  pad.addEventListener('dblclick',function(){ vx=0.5; vy=0.5; send(0,vx); send(1,vy); paintPad(); });\n\n  // ---- KNOBS (params 2..7) ----\n  var defs=[\n    {i:2,name:'Seq Rate',def:0.3},\n    {i:3,name:'Cutoff',  def:0.6},\n    {i:4,name:'Attack',  def:0.05},\n    {i:5,name:'Release', def:0.4},\n    {i:6,name:'Detune',  def:0.25},\n    {i:7,name:'Level',   def:0.6}\n  ];\n  var seqRate=0.3;\n  var host=document.getElementById('knobs');\n  var R=22, CIRC=2*Math.PI*R;\n  defs.forEach(function(p){\n    var wrap=document.createElement('div'); wrap.className='knob';\n    wrap.innerHTML=\n      '<div class=\"dial\"><svg viewBox=\"0 0 60 60\">'+\n        '<circle cx=\"30\" cy=\"30\" r=\"22\" fill=\"none\" stroke=\"rgba(46,196,182,.16)\" stroke-width=\"5\"/>'+\n        '<circle class=\"ring\" cx=\"30\" cy=\"30\" r=\"22\" fill=\"none\" stroke=\"#2ec4b6\" stroke-width=\"5\" '+\n          'stroke-linecap=\"round\" stroke-dasharray=\"'+CIRC.toFixed(2)+'\" stroke-dashoffset=\"'+CIRC.toFixed(2)+'\"/>'+\n      '</svg><div class=\"cap\">0</div></div>'+\n      '<div class=\"klabel\">'+p.name+'</div>';\n    host.appendChild(wrap);\n    var ring=wrap.querySelector('.ring'), cap=wrap.querySelector('.cap');\n    var val=p.def;\n    function paint(){\n      var frac=clamp(val,0,1);\n      ring.style.strokeDashoffset=(CIRC*(1-frac*0.78)).toFixed(2); // 0..280deg arc\n      cap.textContent=val.toFixed(2);\n      if(p.i===2){ seqRate=val; document.getElementById('seqlbl').textContent='RATE '+val.toFixed(2); }\n    }\n    function commit(){ send(p.i,val); paint(); }\n    var dragging=false,lastY=0;\n    wrap.addEventListener('pointerdown',function(e){ dragging=true; lastY=e.clientY; wrap.setPointerCapture(e.pointerId); });\n    wrap.addEventListener('pointermove',function(e){\n      if(!dragging) return;\n      val=clamp(val+(lastY-e.clientY)/170,0,1); lastY=e.clientY; commit();\n    });\n    wrap.addEventListener('pointerup',function(){ dragging=false; });\n    wrap.addEventListener('dblclick',function(){ val=p.def; commit(); });\n    commit();\n  });\n\n  // ---- WAVE-SEQUENCE TIMELINE (visualises the rotating corner steps) ----\n  var STEPS=['saw','pulse','sine','tri'];   // rotation order across the pad\n  var tl=document.getElementById('timeline'), steps=[];\n  for(var s=0;s<8;s++){\n    var name=STEPS[s%4];\n    var d=document.createElement('div'); d.className='step';\n    d.innerHTML='<svg viewBox=\"0 0 100 100\" preserveAspectRatio=\"none\">'+\n      '<path d=\"'+wavePath(name,0,0,100,100)+'\" fill=\"none\" stroke=\"#54d1ff\" stroke-width=\"2.5\"/></svg>';\n    tl.appendChild(d); steps.push(d);\n  }\n\n  // ---- ANIMATION: orbit + timeline scan driven by seq rate ----\n  var seqPos=0, last=performance.now();\n  function paintOrbit(){\n    var w=pad.clientWidth, rad=0.35*seqRate; // matches DSP orbit\n    var rpx=rad*w;\n    if(rad<0.01){ orbit.style.display='none'; return; }\n    orbit.style.display='block';\n    orbit.style.width=(rpx*2)+'px'; orbit.style.height=(rpx*2)+'px';\n    orbit.style.left=(vx*w)+'px'; orbit.style.top=((1-vy)*pad.clientHeight)+'px';\n  }\n  function frame(now){\n    var dt=(now-last)/1000; last=now;\n    var stepsPerSec=0.05+seqRate*seqRate*12.0;     // matches DSP\n    seqPos=(seqPos+stepsPerSec*dt)%8;\n    var cur=Math.floor(seqPos);\n    for(var k=0;k<8;k++) steps[k].classList.toggle('on',k===cur);\n    // glide the puck visual marker around the orbit (purely cosmetic feedback)\n    paintOrbit();\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  function ready(){\n    // push defaults to the host and paint\n    send(0,vx); send(1,vy);\n    paintPad();\n  }\n  window.addEventListener('resize',paintPad);\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VECTOR WAVE — a polyphonic vector / wave-sequencing synthesizer.\n//  Four single-cycle waves are generated in code (no samples) and laid\n//  out on the corners of a square morph pad. A Vector X/Y pair bilinearly\n//  crossfades between the four corner waves; a slow Wave-Sequence rate\n//  steps a rotating offset through the corners so the timbre evolves over\n//  time on a single held note. Up to eight voices keyed by noteId, each:\n//  two slightly detuned vector-mixed oscillators -> resonant low-pass\n//  driven by an ADSR contour. Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst TWO_PI: f32 = 6.28318530717959;\nconst TABLE_SIZE: i32 = 1024;   // single-cycle wavetable length\nconst TABLE_MASK: i32 = 1023;\nconst NUM_WAVES: i32 = 4;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// four single-cycle waves, generated at init, laid flat: wave w sample i -> w*TABLE_SIZE + i\nconst waves: StaticArray<f32> = new StaticArray<f32>(NUM_WAVES * TABLE_SIZE);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_VECX:    i32 = 0;  // 0..1  -> vector X (corner crossfade)\nconst P_VECY:    i32 = 1;  // 0..1  -> vector Y (corner crossfade)\nconst P_SEQRATE: i32 = 2;  // 0..1  -> wave-sequence step rate\nconst P_CUTOFF:  i32 = 3;  // 0..1  -> low-pass cutoff\nconst P_ATTACK:  i32 = 4;  // 0..1  -> attack seconds\nconst P_RELEASE: i32 = 5;  // 0..1  -> release seconds\nconst P_DETUNE:  i32 = 6;  // 0..1  -> osc pair detune\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhaseA: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc A phase 0..1\nconst vPhaseB: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc B phase 0..1\n\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // amplitude env\nconst vStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\n\nconst vLp:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // 1-pole LP state\nconst vBp:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // resonance state\n\nlet ageCounter: i32 = 0;\n\n// wave-sequence position (advances over time, shared by all voices for a\n// coherent evolving pad)\nlet seqPhase: f32 = 0.0;   // 0..NUM_WAVES, wraps; integer part selects rotation\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n\n  // --- generate the four single-cycle corner waves (in code) ---------\n  for (let i = 0; i < TABLE_SIZE; i++) {\n    const t: f32 = f32(i) / f32(TABLE_SIZE);     // 0..1\n    const ph: f32 = TWO_PI * t;\n\n    // wave 0: pure sine (mellow)\n    waves[0 * TABLE_SIZE + i] = f32(Mathf.sin(ph));\n\n    // wave 1: triangle (soft hollow)\n    let tri: f32 = 4.0 * (t < 0.5 ? t : 1.0 - t) - 1.0;\n    waves[1 * TABLE_SIZE + i] = tri;\n\n    // wave 2: band-limited-ish saw via partial sum (bright)\n    let saw: f32 = 0.0;\n    for (let k = 1; k <= 8; k++) {\n      saw += f32(Mathf.sin(ph * f32(k))) / f32(k);\n    }\n    waves[2 * TABLE_SIZE + i] = saw * 0.55;\n\n    // wave 3: odd-harmonic square/pulse via partial sum (vocal/reedy)\n    let sq: f32 = 0.0;\n    for (let k = 1; k <= 9; k += 2) {\n      sq += f32(Mathf.sin(ph * f32(k))) / f32(k);\n    }\n    waves[3 * TABLE_SIZE + i] = sq * 0.85;\n  }\n\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhaseA[v] = 0.0; vPhaseB[v] = 0.0;\n    vEnv[v] = 0.0; vStage[v] = 0;\n    vLp[v] = 0.0; vBp[v] = 0.0;\n  }\n  ageCounter = 0;\n  seqPhase = 0.0;\n\n  params[P_VECX]    = 0.5;\n  params[P_VECY]    = 0.5;\n  params[P_SEQRATE] = 0.3;\n  params[P_CUTOFF]  = 0.6;\n  params[P_ATTACK]  = 0.05;\n  params[P_RELEASE] = 0.4;\n  params[P_DETUNE]  = 0.25;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linear-interpolated single-cycle table read for wave w at phase p (0..1)\n@inline function readWave(w: i32, p: f32): f32 {\n  const fp: f32 = p * f32(TABLE_SIZE);\n  const i0: i32 = i32(fp) & TABLE_MASK;\n  const i1: i32 = (i0 + 1) & TABLE_MASK;\n  const fr: f32 = fp - f32(i32(fp));\n  const base: i32 = w * TABLE_SIZE;\n  const a: f32 = waves[base + i0];\n  const b: f32 = waves[base + i1];\n  return a + (b - a) * fr;\n}\n\n// bilinear vector mix of the four corner waves at phase p.\n// corners: 0=bottom-left, 2=bottom-right, 1=top-left, 3=top-right.\n// rot rotates the corner assignment so the wave-sequence steps timbre.\n@inline function vectorSample(p: f32, x: f32, y: f32, rot: i32): f32 {\n  // pick corner waves with a rotating offset (the wave-sequence step)\n  const wBL: i32 = (0 + rot) & 3;\n  const wBR: i32 = (2 + rot) & 3;\n  const wTL: i32 = (1 + rot) & 3;\n  const wTR: i32 = (3 + rot) & 3;\n\n  const sBL: f32 = readWave(wBL, p);\n  const sBR: f32 = readWave(wBR, p);\n  const sTL: f32 = readWave(wTL, p);\n  const sTR: f32 = readWave(wTR, p);\n\n  const bottom: f32 = sBL + (sBR - sBL) * x;\n  const top: f32    = sTL + (sTR - sTL) * x;\n  return bottom + (top - bottom) * y;\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vStage[slot]  = 1;   // attack\n  vEnv[slot]    = 0.0;\n  vPhaseA[slot] = 0.0;\n  vPhaseB[slot] = 0.13;  // slight offset so detuned pair beats from the start\n  vLp[slot]     = 0.0;\n  vBp[slot]     = 0.0;\n  vAge[slot]    = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3;  // release\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const vecX: f32 = clampf(params[P_VECX], 0.0, 1.0);\n  const vecY: f32 = clampf(params[P_VECY], 0.0, 1.0);\n  const seqN: f32 = clampf(params[P_SEQRATE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0) * 2.0;\n  const relS: f32 = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 3.0;\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune in semitone fraction -> beating between the osc pair\n  const detSemi: f32 = clampf(params[P_DETUNE], 0.0, 1.0) * 0.4;\n  const ratioUp: f32   = f32(Mathf.pow(2.0, detSemi / 12.0));\n  const ratioDown: f32 = f32(Mathf.pow(2.0, -detSemi / 12.0));\n\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 1.1;\n\n  // base cutoff in Hz, exponential 80 Hz .. ~15 kHz\n  const baseHz: f32 = 80.0 * f32(Mathf.pow(180.0, cutoffN));\n\n  // wave-sequence step rate: 0 -> very slow (~0.05 steps/s), 1 -> ~12 steps/s\n  const stepsPerSec: f32 = 0.05 + seqN * seqN * 12.0;\n  const seqInc: f32 = stepsPerSec / sr;\n  // sequence depth scales the pad orbit with the rate, so 0 = static timbre\n  const seqAmt: f32 = seqN;\n\n  // headroom for summed voices\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    // advance the shared wave-sequence position\n    seqPhase += seqInc;\n    while (seqPhase >= f32(NUM_WAVES)) seqPhase -= f32(NUM_WAVES);\n    const rot: i32 = i32(seqPhase) & 3;\n    // smooth crossfade between this step and the next for click-free stepping\n    const stepFrac: f32 = seqPhase - f32(i32(seqPhase));\n\n    // the wave-sequence also walks the vector position around the pad so the\n    // timbre evolves even when the joystick sits dead-centre. A small circular\n    // orbit keeps it within bounds and guarantees an audible step animation.\n    const ang: f32 = (seqPhase / f32(NUM_WAVES)) * TWO_PI;\n    const orbit: f32 = 0.35 * seqAmt;\n    const seqX: f32 = clampf(vecX + orbit * f32(Mathf.cos(ang)), 0.0, 1.0);\n    const seqY: f32 = clampf(vecY + orbit * f32(Mathf.sin(ang)), 0.0, 1.0);\n\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope (A / sustain / R) -----------------\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {            // attack\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {     // sustain (held)\n        env = 1.0;\n      } else if (stg == 3) {     // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- two detuned vector oscillators -----------------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const incA: f32 = baseInc * ratioDown;\n      const incB: f32 = baseInc * ratioUp;\n\n      let pA: f32 = vPhaseA[v];\n      pA += incA; if (pA >= 1.0) pA -= 1.0;\n      vPhaseA[v] = pA;\n\n      let pB: f32 = vPhaseB[v];\n      pB += incB; if (pB >= 1.0) pB -= 1.0;\n      vPhaseB[v] = pB;\n\n      // vector mix at the current sequence step, crossfaded into the next.\n      // seqX/seqY orbit the joystick over time so the sequence-rate animates it.\n      const aCur: f32 = vectorSample(pA, seqX, seqY, rot);\n      const aNxt: f32 = vectorSample(pA, seqX, seqY, (rot + 1) & 3);\n      const oscA: f32 = aCur + (aNxt - aCur) * stepFrac;\n\n      const bCur: f32 = vectorSample(pB, seqX, seqY, rot);\n      const bNxt: f32 = vectorSample(pB, seqX, seqY, (rot + 1) & 3);\n      const oscB: f32 = bCur + (bNxt - bCur) * stepFrac;\n\n      let osc: f32 = (oscA + oscB) * 0.5;\n\n      // ---- resonant 2-pole-ish low-pass (state-variable lite) ---\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * baseHz / sr));\n      if (g > 0.99) g = 0.99;\n      const res: f32 = 1.2;  // gentle fixed resonance for character\n      let lp: f32 = vLp[v];\n      let bp: f32 = vBp[v];\n      const hp: f32 = osc - lp - res * bp;\n      bp += g * hp;\n      lp += g * bp;\n      vBp[v] = bp;\n      vLp[v] = lp;\n\n      let voice: f32 = lp * env * vVel[v];\n      outL += voice;\n    }\n\n    // ---- sum + soft saturate ------------------------------------\n    let mix: f32 = outL * voiceScale * level;\n    mix = f32(Mathf.tanh(mix));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000075000
}