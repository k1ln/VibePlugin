  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n  :root{--ac:#54b0ff;--ac2:#80c8ff}\n  *{box-sizing:border-box}\n  body{margin:0;min-height:100vh;font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#e7eef6;\n    background:radial-gradient(120% 90% at 50% -10%,#1b2230 0%,#0a0d13 60%,#06080c 100%);\n    display:flex;align-items:center;justify-content:center;padding:22px;overflow:hidden}\n  .panel{position:relative;width:100%;max-width:560px;border-radius:20px;padding:22px 24px 18px;\n    background:linear-gradient(160deg,rgba(31,38,52,.86),rgba(13,17,24,.92));\n    border:1px solid rgba(255,255,255,.08);\n    box-shadow:0 24px 60px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.06)}\n  .panel::before{content:\"\";position:absolute;inset:-40%;z-index:0;pointer-events:none;\n    background:radial-gradient(closest-side,color-mix(in srgb,var(--ac) 22%,transparent),transparent);\n    filter:blur(20px);animation:drift 9s ease-in-out infinite alternate}\n  @keyframes drift{from{transform:translate(-12%,-8%)}to{transform:translate(12%,8%)}}\n  .hd{position:relative;z-index:1;display:flex;align-items:baseline;gap:10px;margin-bottom:4px}\n  h1{font-size:18px;margin:0;letter-spacing:.06em;font-weight:700;\n    background:linear-gradient(90deg,var(--ac),var(--ac2));-webkit-background-clip:text;background-clip:text;color:transparent}\n  .badge{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#8da0bd;\n    border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:2px 8px}\n  .grid{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:14px 10px;justify-content:center;margin:16px 0 6px}\n  .knob{width:96px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:ns-resize;user-select:none;touch-action:none}\n  .dial{--n:0;position:relative;width:84px;height:84px;border-radius:50%;\n    background:conic-gradient(from 225deg,var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.09) calc(var(--n)*270deg) 270deg,transparent 270deg);\n    filter:drop-shadow(0 0 7px color-mix(in srgb,var(--ac) 55%,transparent))}\n  .cap{position:absolute;top:11px;left:11px;width:62px;height:62px;border-radius:50%;\n    background:radial-gradient(circle at 50% 32%,#2c3546,#0f131b 72%);\n    box-shadow:inset 0 2px 7px rgba(0,0,0,.65),inset 0 -1px 0 rgba(255,255,255,.05)}\n  .ptr{position:absolute;top:7px;left:50%;width:3px;height:26px;margin-left:-1.5px;border-radius:2px;\n    background:var(--ac);box-shadow:0 0 7px var(--ac);transform-origin:50% 35px;\n    transform:rotate(calc((var(--n) - 0.5) * 270deg))}\n  .nm{font-size:11px;letter-spacing:.06em;color:#aeb9cc;text-transform:uppercase}\n  .val{font-size:12px;color:#fff;font-variant-numeric:tabular-nums;font-weight:600}\n  .ft{position:relative;z-index:1;font-size:11px;line-height:1.5;color:#7c8aa3;margin-top:8px;\n    border-top:1px solid rgba(255,255,255,.06);padding-top:10px}\n  </style></head><body>\n  <div class=\"panel\">\n    <div class=\"hd\"><h1>Classic Beats</h1><span class=\"badge\">8 controls</span></div>\n    <div class=\"grid\">\n      <div class=\"knob\" data-i=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.8\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Level</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.9\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Kick</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.8\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Snare</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"0.6\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Hat</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"4\" data-min=\"0\" data-max=\"1\" data-def=\"0.7\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Clap</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"5\" data-min=\"0\" data-max=\"1\" data-def=\"0.4\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Tone</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"6\" data-min=\"0\" data-max=\"1\" data-def=\"0.7\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Decay</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"7\" data-min=\"0\" data-max=\"1\" data-def=\"0.2\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Drive</div><div class=\"val\"></div>\n      </div>\n    </div>\n    <div class=\"ft\">A four-voice sample-based drum machine in the spirit of the early-'80s sampled rhythm boxes. Real kick, snare, closed hi-hat and clap one-shots — all CC0 / public-domain recordings — are baked into the plugin and triggered polyphonically, with each incoming MIDI note mapped to a voice (note number modulo four) so every key plays a hit. Per-voice levels plus Tone, Decay and Drive shape the groove.</div>\n  </div>\n  <script>\n  (function(){\n    function fmt(v,step){ var d=step>=1?0:(step>=0.1?1:(step>=0.01?2:3)); return (+v).toFixed(d); }\n    function setup(k){\n      var i=+k.dataset.i, mn=+k.dataset.min, mx=+k.dataset.max, def=+k.dataset.def, step=+k.dataset.step||0.001;\n      var val=def, dial=k.querySelector('.dial'), out=k.querySelector('.val');\n      function norm(){ return (val-mn)/(mx-mn||1); }\n      function paint(){ dial.style.setProperty('--n', norm()); out.textContent=fmt(val,step);\n        if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,val); }\n      function setN(n){ n=n<0?0:(n>1?1:n); var v=mn+(mx-mn)*n; v=Math.round(v/step)*step; val=v; paint(); }\n      k.addEventListener('pointerdown',function(e){ k._d=1; k._y=e.clientY; k._n=norm(); k.setPointerCapture(e.pointerId); e.preventDefault(); });\n      k.addEventListener('pointermove',function(e){ if(!k._d)return; setN(k._n+(k._y-e.clientY)/220); });\n      k.addEventListener('pointerup',function(){ k._d=0; });\n      k.addEventListener('pointercancel',function(){ k._d=0; });\n      k.addEventListener('dblclick',function(){ val=def; paint(); });\n      k.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.02:-0.02)); },{passive:false});\n      paint();\n    }\n    function ready(){ var ks=document.querySelectorAll('.knob'); for(var j=0;j<ks.length;j++) setup(ks[j]); }\n    if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n  })();\n  </script>\n  </body></html>",
  "assembly": "// Classic Beats — a 4-voice sample-based drum machine. The four percussion\n// one-shots (kick, snare, closed hat, clap) are CC0 / public-domain recordings\n// baked into this module as base64 Int16-LE mono PCM @ 22050 Hz and decoded into\n// f32 buffers at init(). Incoming MIDI notes are mapped to a voice by note number\n// modulo 4, so every note triggers a percussion hit. Self-contained: no runtime\n// file access. (Decoder lifted from factory/tools/SAMPLE_TEMPLATE.ts.)\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// --- embedded samples (base64 of Int16-LE mono PCM @ 22050 Hz) ---\nconst SAMPLE_SR: f32 = 22050.0;\nconst B64_KICK:  string = \"\";\nconst B64_SNARE: string = \"\";\nconst B64_HAT:   string = \"\";\nconst B64_CLAP:  string = \"\";\n\nconst NVOICES: i32 = 4;                 // kick, snare, hat, clap\nconst CAP_KICK:  i32 = 6546;\nconst CAP_SNARE: i32 = 12136;\nconst CAP_HAT:   i32 = 4859;\nconst CAP_CLAP:  i32 = 9269;\n\nconst sKick:  StaticArray<f32> = new StaticArray<f32>(CAP_KICK);\nconst sSnare: StaticArray<f32> = new StaticArray<f32>(CAP_SNARE);\nconst sHat:   StaticArray<f32> = new StaticArray<f32>(CAP_HAT);\nconst sClap:  StaticArray<f32> = new StaticArray<f32>(CAP_CLAP);\nconst lenKick:  StaticArray<i32> = new StaticArray<i32>(1);\nconst lenSnare: StaticArray<i32> = new StaticArray<i32>(1);\nconst lenHat:   StaticArray<i32> = new StaticArray<i32>(1);\nconst lenClap:  StaticArray<i32> = new StaticArray<i32>(1);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- polyphonic one-shot voice pool (overlapping hits sum) ---\nconst POLY: i32 = 12;\nconst vActive: StaticArray<i32> = new StaticArray<i32>(POLY); // 0/1\nconst vVoice:  StaticArray<i32> = new StaticArray<i32>(POLY); // which drum (0..3)\nconst vPos:    StaticArray<f32> = new StaticArray<f32>(POLY); // read head in sample frames\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(POLY); // velocity gain\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(POLY); // elapsed seconds (for decay)\nlet vNext: i32 = 0;\n\n// hat/clap tone filter state (per voice, 1-pole high-pass for the Tone control)\nconst vHp: StaticArray<f32> = new StaticArray<f32>(POLY);\n\n// parameters\nconst P_LEVEL: i32 = 0;   // master out 0..1\nconst P_KICK:  i32 = 1;   // kick level 0..1\nconst P_SNARE: i32 = 2;   // snare level 0..1\nconst P_HAT:   i32 = 3;   // hat level 0..1\nconst P_CLAP:  i32 = 4;   // clap level 0..1\nconst P_TONE:  i32 = 5;   // 0..1 high-pass brightness on hat+clap\nconst P_DECAY: i32 = 6;   // 0..1 hit length / fade-out\nconst P_DRIVE: i32 = 7;   // 0..1 soft-clip drive (analog crunch)\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\n\nfunction decodeInto(s: string, dst: StaticArray<f32>, cap: i32): i32 {\n  const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else {\n        let val = (byte << 8) | lo;\n        if (val >= 32768) val -= 65536;\n        if (si < cap) { dst[si] = f32(val) / 32768.0; si++; }\n        lo = -1;\n      }\n    }\n  }\n  return si;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < POLY; i++) {\n    vActive[i] = 0; vVoice[i] = 0; vPos[i] = 0.0; vAmp[i] = 0.0; vEnv[i] = 0.0; vHp[i] = 0.0;\n  }\n  vNext = 0;\n  params[P_LEVEL] = 0.8;\n  params[P_KICK]  = 0.9;\n  params[P_SNARE] = 0.8;\n  params[P_HAT]   = 0.6;\n  params[P_CLAP]  = 0.7;\n  params[P_TONE]  = 0.4;\n  params[P_DECAY] = 0.7;\n  params[P_DRIVE] = 0.2;\n  lenKick[0]  = decodeInto(B64_KICK,  sKick,  CAP_KICK);\n  lenSnare[0] = decodeInto(B64_SNARE, sSnare, CAP_SNARE);\n  lenHat[0]   = decodeInto(B64_HAT,   sHat,   CAP_HAT);\n  lenClap[0]  = decodeInto(B64_CLAP,  sClap,  CAP_CLAP);\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function sampleAt(voice: i32, pos: f32): f32 {\n  const ip: i32 = i32(pos);\n  let len: i32 = 0;\n  if (voice == 0) len = lenKick[0];\n  else if (voice == 1) len = lenSnare[0];\n  else if (voice == 2) len = lenHat[0];\n  else len = lenClap[0];\n  if (ip + 1 >= len) return 0.0;\n  const fr: f32 = pos - f32(ip);\n  if (voice == 0) return sKick[ip]  * (1.0 - fr) + sKick[ip + 1]  * fr;\n  if (voice == 1) return sSnare[ip] * (1.0 - fr) + sSnare[ip + 1] * fr;\n  if (voice == 2) return sHat[ip]   * (1.0 - fr) + sHat[ip + 1]   * fr;\n  return sClap[ip] * (1.0 - fr) + sClap[ip + 1] * fr;\n}\n\n@inline function voiceLen(voice: i32): i32 {\n  if (voice == 0) return lenKick[0];\n  if (voice == 1) return lenSnare[0];\n  if (voice == 2) return lenHat[0];\n  return lenClap[0];\n}\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // derive MIDI note from frequency, map note -> drum voice (note % NVOICES)\n  const note: i32 = i32(Mathf.round(69.0 + 12.0 * Mathf.log2(f / 440.0)));\n  let voice: i32 = note % NVOICES;\n  if (voice < 0) voice += NVOICES;\n  const s: i32 = vNext;\n  vNext = (vNext + 1) % POLY;\n  vActive[s] = 1;\n  vVoice[s]  = voice;\n  vPos[s]    = 0.0;\n  vAmp[s]    = v > 0.0 ? v : 1.0;\n  vEnv[s]    = 0.0;\n  vHp[s]     = 0.0;\n}\n\nexport function noteOff(id: i32): void { /* one-shot percussion; ignore */ }\n\nexport function process(n: i32): void {\n  const master: f32 = params[P_LEVEL];\n  const lvlKick:  f32 = params[P_KICK];\n  const lvlSnare: f32 = params[P_SNARE];\n  const lvlHat:   f32 = params[P_HAT];\n  const lvlClap:  f32 = params[P_CLAP];\n  const tone:  f32 = params[P_TONE];        // 0..1 high-pass amount on hat+clap\n  const decay: f32 = params[P_DECAY];       // 0..1 -> hit length scaling\n  const drive: f32 = params[P_DRIVE];       // 0..1 soft-clip\n\n  const step: f32 = SAMPLE_SR / sampleRate; // sample-rate-correct playback\n  // decay shapes a fade applied across the played one-shot. short decay = punchier.\n  const decaySecs: f32 = 0.06 + decay * 1.2;\n  const hpCoef: f32 = 0.5 + 0.49 * tone;    // 1-pole HP feedback for Tone\n  const driveAmt: f32 = 1.0 + drive * 8.0;\n  const driveComp: f32 = 1.0 / (1.0 + drive * 1.6);\n\n  for (let fI = 0; fI < n; fI++) {\n    let mix: f32 = 0.0;\n    for (let p = 0; p < POLY; p++) {\n      if (vActive[p] == 0) continue;\n      const voice: i32 = vVoice[p];\n      const pos: f32 = vPos[p];\n      if (i32(pos) + 1 >= voiceLen(voice)) { vActive[p] = 0; continue; }\n      let s: f32 = sampleAt(voice, pos);\n\n      // per-voice level\n      let vl: f32 = lvlKick;\n      if (voice == 1) vl = lvlSnare;\n      else if (voice == 2) vl = lvlHat;\n      else if (voice == 3) vl = lvlClap;\n\n      // Tone: high-pass brighten on hat (2) and clap (3)\n      if (voice >= 2) {\n        const hp: f32 = s - vHp[p];\n        vHp[p] = vHp[p] + (1.0 - hpCoef) * hp;\n        s = s * (1.0 - tone) + hp * tone;\n      }\n\n      // amplitude envelope (exp fade so Decay always audibly affects the hit)\n      const env: f32 = f32(Mathf.exp(-vEnv[p] / decaySecs));\n      mix += s * vl * vAmp[p] * env;\n\n      vPos[p] = pos + step;\n      vEnv[p] = vEnv[p] + 1.0 / sampleRate;\n    }\n\n    // analog-style soft saturation (Drive), then master level\n    let out: f32 = mix * master;\n    if (drive > 0.0001) {\n      out = f32(Mathf.tanh(out * driveAmt)) * driveComp;\n    }\n    // safety clip\n    if (out > 1.0) out = 1.0;\n    else if (out < -1.0) out = -1.0;\n\n    outBuf[fI] = out;\n    outBuf[MAX_FRAMES + fI] = out;\n  }\n}\n",
  "publishedAt": 1751000030000
}