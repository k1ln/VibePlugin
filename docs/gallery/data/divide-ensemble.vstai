  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Divide Ensemble</title>\n<style>\n  :root{ --acc:#ffb86a; --acc2:#7ad0c4; --bg0:#0a0905; --bg1:#171208; --ink:#f3ecdf; --dim:#9a8a70; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#2a2114 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#2a2113,#0d0a06); border:1px solid rgba(255,184,106,.18);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,235,200,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.14em; font-size:20px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:92px; border-radius:9px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#120d06,#171208); border:1px solid rgba(255,184,106,.15); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,210,160,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,184,106,.6)); }\n  .pcap{ fill:#150f07; stroke:rgba(255,184,106,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,184,106,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,184,106,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">DIVIDE&nbsp;ENSEMBLE</span><span class=\"sub\">string · organ machine</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">ENSEMBLE</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Strings\",idx:0,def:0.7},{name:\"Organ\",idx:1,def:0.4},{name:\"Attack\",idx:2,def:0.3},{name:\"Release\",idx:3,def:0.5},{name:\"Ensemble\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffb86a\"/><stop offset=\"1\" stop-color=\"#7ad0c4\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle>'+\n      '<line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H); var str=vals[0], org=vals[1], ens=vals[4]; var mid=H*0.55;\n    // shimmer\n    ctx.globalAlpha=0.1+ens*0.16; ctx.fillStyle=\"rgba(255,184,106,1)\";\n    for(var sx=0;sx<6;sx++){ var px=(ts/45+sx*130)%(W+60)-30; ctx.fillRect(px,0,1.3,H); } ctx.globalAlpha=1;\n    function wave(saw,amp,col,off,sp){ ctx.beginPath();\n      for(var x=0;x<=W;x+=2){ var t=x/W; var ph=(t*4+ts/sp+off); var y= saw? (2*(ph-Math.floor(ph+0.5))) : (Math.sin(ph*Math.PI*2)>0?0.7:-0.7);\n        var sw=0.6+0.4*Math.sin(ts/950+off); ctx.lineTo(x, mid + y*amp*sw); }\n      ctx.strokeStyle=col; ctx.lineWidth=2; ctx.shadowColor=col; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0; }\n    wave(true, 14*str+2, \"rgba(255,184,106,\"+(0.5+0.5*str)+\")\", 0, 880);    // strings (saw)\n    wave(false, 11*org+1, \"rgba(122,208,196,\"+(0.4+0.6*org)+\")\", 1.5, 700); // organ (square)\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DIVIDE ENSEMBLE — a divide-down STRING + ORGAN machine (Roland RS-09\n//  / Logan String Melody lineage). Distinct from the lush Solina/Crumar\n//  string ensembles: it blends a STRINGS voice (sawtooth) and an ORGAN\n//  voice (square, divide-down) per key, with slow attack/release and a\n//  wide ENSEMBLE chorus. Fully polyphonic (12 voices). Controls: Strings,\n//  Organ, Attack, Release, Ensemble, Level. No samples, no host imports,\n//  no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 12;\nconst CH_LEN: i32 = 4096;\nconst CH_MASK: i32 = CH_LEN - 1;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vP1: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vP2: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\n\nconst chL: StaticArray<f32> = new StaticArray<f32>(CH_LEN);\nconst chR: StaticArray<f32> = new StaticArray<f32>(CH_LEN);\nlet chW: i32 = 0; let chPh: f32 = 0.0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_STR: i32 = 0;\nconst P_ORG: i32 = 1;\nconst P_ATK: i32 = 2;\nconst P_REL: i32 = 3;\nconst P_ENS: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0; chW = 0; chPh = 0.0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vP1[i] = 0.0; vP2[i] = 0.0; vAmp[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vNote[i] = -1; }\n  for (let i = 0; i < CH_LEN; i++) { chL[i] = 0.0; chR[i] = 0.0; }\n  params[P_STR] = 0.7; params[P_ORG] = 0.4; params[P_ATK] = 0.3; params[P_REL] = 0.5; params[P_ENS] = 0.6; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vP1[slot] = 0.0; vP2[slot] = 0.0; vAmp[slot] = 0.0; vSt[slot] = 1; vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0); vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const strN: f32 = clampf(params[P_STR], 0.0, 1.0);\n  const orgN: f32 = clampf(params[P_ORG], 0.0, 1.0);\n  const atkN: f32 = clampf(params[P_ATK], 0.0, 1.0);\n  const relN: f32 = clampf(params[P_REL], 0.0, 1.0);\n  const ensN: f32 = clampf(params[P_ENS], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / ((0.01 + atkN * atkN * 1.2) * sampleRate);\n  const relSec: f32 = 0.05 + relN * relN * 2.0;\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relSec * sampleRate)));\n  const chDepth: f32 = (0.4 + ensN * 0.6) * 0.006 * sampleRate;\n  const chBase: f32 = 0.008 * sampleRate;\n  const chMix: f32 = 0.3 + ensN * 0.6;\n  const norm: f32 = 1.0 / (strN + orgN + 0.2);\n  const out: f32 = level * 0.42;\n\n  for (let i = 0; i < n; i++) {\n    let mono: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      let p1: f32 = vP1[s] + fr / sampleRate; if (p1 >= 1.0) p1 -= 1.0; vP1[s] = p1;\n      let p2: f32 = vP2[s] + fr / sampleRate; if (p2 >= 1.0) p2 -= 1.0; vP2[s] = p2;\n      const saw: f32 = p1 * 2.0 - 1.0;          // strings\n      const sq: f32 = p2 < 0.5 ? 0.7 : -0.7;    // organ (divide-down square)\n      const v: f32 = (saw * strN + sq * orgN) * norm;\n      mono += v * vAmp[s] * vVel[s];\n    }\n    // 3-voice ensemble chorus into stereo\n    chL[chW] = mono; chR[chW] = mono;\n    chPh += 0.9 / sampleRate * 6.2831853; if (chPh > 6.2831853) chPh -= 6.2831853;\n    const d1: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh)));\n    const d2: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh + 2.094)));\n    const d3: f32 = chBase + chDepth * (0.5 + 0.5 * f32(Mathf.sin(chPh + 4.188)));\n    const r1: f32 = f32(chW) - d1; let i1: i32 = i32(r1); const fa: f32 = r1 - f32(i1);\n    const r2: f32 = f32(chW) - d2; let i2: i32 = i32(r2); const fbb: f32 = r2 - f32(i2);\n    const r3: f32 = f32(chW) - d3; let i3: i32 = i32(r3); const fc: f32 = r3 - f32(i3);\n    const c1: f32 = chL[i1 & CH_MASK] + (chL[(i1 + 1) & CH_MASK] - chL[i1 & CH_MASK]) * fa;\n    const c2: f32 = chL[i2 & CH_MASK] + (chL[(i2 + 1) & CH_MASK] - chL[i2 & CH_MASK]) * fbb;\n    const c3: f32 = chR[i3 & CH_MASK] + (chR[(i3 + 1) & CH_MASK] - chR[i3 & CH_MASK]) * fc;\n    chW = (chW + 1) & CH_MASK;\n    let l: f32 = (mono + (c1 + c3) * 0.5 * chMix) * out;\n    let r: f32 = (mono + (c2 + c3) * 0.5 * chMix) * out;\n    if (l > 1.4) l = 1.4; else if (l < -1.4) l = -1.4;\n    if (r > 1.4) r = 1.4; else if (r < -1.4) r = -1.4;\n    outBuf[i] = l; outBuf[MAX_FRAMES + i] = r;\n  }\n}\n",
  "publishedAt": 1751000161000
}