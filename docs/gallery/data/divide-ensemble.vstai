      "name": "Organ",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Attack",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Release",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Ensemble",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
