{
  "format": 1,
  "name": "Clip Stage",
  "isInstrument": false,
  "explanation": "A clean, transparent soft-clip saturator and drive stage — built for warmth, glue and gentle level control rather than grind. A makeup-compensated Drive feeds a selectable transfer curve: DIODE gives a symmetric soft knee with odd harmonics, while TUBE adds a small bias for asymmetric, even-harmonic warmth (an internal DC blocker removes the resulting offset). A subtle Tone tilt opens or darkens the top, an output Trim sets level, and a parallel Mix blends the saturated signal back against the dry. Controls: Drive, Curve (diode/tube), Tone, Trim and Mix.",
  "params": [
    {
      "name": "Drive",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Curve",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Trim",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Clip Stage</title>\n<style>\n  :root{\n    --accent:#ffd86a;\n    --accent2:#ff9a5a;\n    --cream:#f4ead2;\n    --ink:#2b2317;\n    --panel:#1b1610;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:'Segoe UI',-apple-system,system-ui,sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #3a2f1d 0%, #221b12 45%, #14100b 100%);\n    color:var(--cream);\n    display:flex;align-items:center;justify-content:center;\n    overflow:hidden;\n  }\n\n  .module{\n    position:relative;\n    width:560px;\n    border-radius:20px;\n    padding:22px 24px 24px;\n    background:\n      linear-gradient(180deg,#efe4c8 0%, #e7d8b4 100%);\n    box-shadow:\n      0 30px 60px -20px rgba(0,0,0,.7),\n      0 2px 0 rgba(255,255,255,.55) inset,\n      0 -2px 0 rgba(120,90,40,.35) inset;\n    color:var(--ink);\n    overflow:hidden;\n  }\n  /* warm brushed sheen */\n  .module::before{\n    content:\"\";position:absolute;inset:0;border-radius:20px;pointer-events:none;\n    background:\n      repeating-linear-gradient(90deg, rgba(255,255,255,.05) 0 2px, rgba(150,120,60,.04) 2px 4px);\n    mix-blend-mode:overlay;opacity:.5;\n  }\n  /* corner screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff8e6, #9a824c 70%, #5c4a22);\n    box-shadow:0 1px 2px rgba(0,0,0,.4), 0 0 0 2px rgba(255,255,255,.25) inset}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:50%;\n    background:linear-gradient(45deg,transparent 44%, rgba(70,50,20,.6) 46% 54%, transparent 56%)}\n  .screw.tl{top:10px;left:10px}.screw.tr{top:10px;right:10px}\n  .screw.bl{bottom:10px;left:10px}.screw.br{bottom:10px;right:10px}\n\n  header{display:flex;align-items:flex-end;justify-content:space-between;\n    padding:0 6px 14px;border-bottom:1px solid rgba(120,90,40,.3);margin-bottom:16px}\n  .brand{display:flex;flex-direction:column;gap:2px}\n  .brand .name{font-size:21px;font-weight:800;letter-spacing:2px;\n    color:#3a2f1d;text-shadow:0 1px 0 rgba(255,255,255,.6)}\n  .brand .sub{font-size:9.5px;letter-spacing:3px;font-weight:600;color:#8a6f3c;text-transform:uppercase}\n  .pilot{display:flex;align-items:center;gap:8px;font-size:10px;letter-spacing:2px;color:#7a6133;font-weight:600}\n  .lamp{width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff1c2, var(--accent) 55%, #b8801f);\n    box-shadow:0 0 10px 1px rgba(255,180,60,.8);animation:pulse 2.6s ease-in-out infinite}\n  @keyframes pulse{0%,100%{box-shadow:0 0 7px 0 rgba(255,180,60,.55);opacity:.85}\n    50%{box-shadow:0 0 16px 3px rgba(255,180,60,.95);opacity:1}}\n\n  /* ---- transfer curve display ---- */\n  .scope{\n    position:relative;border-radius:12px;overflow:hidden;\n    background:linear-gradient(180deg,#171109,#0c0805);\n    box-shadow:0 2px 8px rgba(0,0,0,.5) inset, 0 1px 0 rgba(255,255,255,.4);\n    padding:0;margin-bottom:18px;height:170px;\n  }\n  .scope svg{display:block;width:100%;height:100%}\n  .scanline{animation:scan 4.5s linear infinite}\n  @keyframes scan{0%{transform:translateY(-2px)}100%{transform:translateY(172px)}}\n  .scope .badge{position:absolute;top:9px;left:11px;font-size:9px;letter-spacing:2px;\n    color:#c8a85a;font-weight:700;text-transform:uppercase;opacity:.8}\n  .scope .readout{position:absolute;top:9px;right:11px;font-size:10px;letter-spacing:1px;\n    color:var(--accent);font-weight:700;font-variant-numeric:tabular-nums;\n    text-shadow:0 0 8px rgba(255,200,90,.6)}\n\n  /* ---- controls row ---- */\n  .controls{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}\n  .knob-wrap{display:flex;flex-direction:column;align-items:center;gap:7px;width:84px}\n  .knob{position:relative;width:66px;height:66px;cursor:ns-resize;touch-action:none}\n  .knob svg{display:block;overflow:visible}\n  .knob .cap{filter:drop-shadow(0 3px 4px rgba(0,0,0,.4))}\n  .klabel{font-size:10px;letter-spacing:1.5px;font-weight:700;color:#6e5830;text-transform:uppercase}\n  .kval{font-size:10.5px;font-weight:700;color:#3a2f1d;font-variant-numeric:tabular-nums;\n    padding:2px 7px;border-radius:6px;background:rgba(120,90,40,.12);min-width:42px;text-align:center}\n\n  /* ---- curve toggle ---- */\n  .toggle-wrap{display:flex;flex-direction:column;align-items:center;gap:7px;width:96px}\n  .toggle{position:relative;width:90px;height:30px;border-radius:16px;cursor:pointer;\n    background:linear-gradient(180deg,#221a10,#100c07);\n    box-shadow:0 2px 5px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.35);\n    display:flex;align-items:center;font-size:9.5px;font-weight:800;letter-spacing:1px}\n  .toggle span{flex:1;text-align:center;z-index:2;transition:color .25s;color:#7a6133}\n  .toggle span.on{color:#1b1306}\n  .toggle .slider{position:absolute;top:3px;left:3px;width:42px;height:24px;border-radius:13px;\n    background:linear-gradient(180deg,var(--accent),var(--accent2));\n    box-shadow:0 1px 3px rgba(0,0,0,.5),0 0 12px rgba(255,180,70,.5);\n    transition:left .28s cubic-bezier(.5,1.6,.4,1)}\n  .toggle.tube .slider{left:45px}\n\n  /* ---- output meter ---- */\n  .meter-wrap{display:flex;flex-direction:column;align-items:center;gap:7px;width:50px}\n  .meter{position:relative;width:20px;height:66px;border-radius:5px;overflow:hidden;\n    background:linear-gradient(180deg,#171109,#0a0704);\n    box-shadow:0 2px 5px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.35)}\n  .meter .fill{position:absolute;left:0;right:0;bottom:0;height:0%;\n    background:linear-gradient(0deg,#5fd07a 0%, var(--accent) 62%, var(--accent2) 88%, #ff5a4a 100%);\n    transition:height .07s linear}\n  .meter .ticks{position:absolute;inset:0;pointer-events:none;\n    background:repeating-linear-gradient(0deg,transparent 0 10px,rgba(0,0,0,.35) 10px 11px)}\n</style>\n</head>\n<body>\n  <div class=\"module\">\n    <i class=\"screw tl\"></i><i class=\"screw tr\"></i><i class=\"screw bl\"></i><i class=\"screw br\"></i>\n\n    <header>\n      <div class=\"brand\">\n        <div class=\"name\">CLIP&nbsp;STAGE</div>\n        <div class=\"sub\">transparent saturator</div>\n      </div>\n      <div class=\"pilot\"><span id=\"modeTxt\">DIODE</span><span class=\"lamp\"></span></div>\n    </header>\n\n    <div class=\"scope\">\n      <span class=\"badge\">transfer curve</span>\n      <span class=\"readout\" id=\"readout\">+0.0 dB</span>\n      <svg viewBox=\"0 0 520 170\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"curveFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ffd86a\" stop-opacity=\"0.28\"/>\n            <stop offset=\"1\" stop-color=\"#ff9a5a\" stop-opacity=\"0.02\"/>\n          </linearGradient>\n          <linearGradient id=\"curveLine\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0\" stop-color=\"#ff9a5a\"/>\n            <stop offset=\"0.5\" stop-color=\"#ffd86a\"/>\n            <stop offset=\"1\" stop-color=\"#ff9a5a\"/>\n          </linearGradient>\n          <filter id=\"glow\"><feGaussianBlur stdDeviation=\"2.2\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n        </defs>\n        <!-- grid -->\n        <g stroke=\"rgba(200,168,90,0.13)\" stroke-width=\"1\">\n          <line x1=\"0\" y1=\"42.5\" x2=\"520\" y2=\"42.5\"/>\n          <line x1=\"0\" y1=\"85\" x2=\"520\" y2=\"85\"/>\n          <line x1=\"0\" y1=\"127.5\" x2=\"520\" y2=\"127.5\"/>\n          <line x1=\"130\" y1=\"0\" x2=\"130\" y2=\"170\"/>\n          <line x1=\"260\" y1=\"0\" x2=\"260\" y2=\"170\"/>\n          <line x1=\"390\" y1=\"0\" x2=\"390\" y2=\"170\"/>\n        </g>\n        <!-- unity reference (diagonal) -->\n        <line x1=\"0\" y1=\"170\" x2=\"520\" y2=\"0\" stroke=\"rgba(255,255,255,0.12)\" stroke-width=\"1\" stroke-dasharray=\"4 5\"/>\n        <path id=\"curveArea\" fill=\"url(#curveFill)\"/>\n        <path id=\"curvePath\" fill=\"none\" stroke=\"url(#curveLine)\" stroke-width=\"2.6\"\n              stroke-linecap=\"round\" filter=\"url(#glow)\"/>\n        <circle id=\"dot\" r=\"4\" fill=\"#fff3cf\" stroke=\"#ff9a5a\" stroke-width=\"1.5\"\n                style=\"filter:drop-shadow(0 0 6px rgba(255,200,90,.9))\"/>\n        <line class=\"scanline\" x1=\"0\" y1=\"0\" x2=\"520\" y2=\"0\"\n              stroke=\"rgba(255,216,106,0.12)\" stroke-width=\"2\"/>\n      </svg>\n    </div>\n\n    <div class=\"controls\">\n      <div class=\"knob-wrap\" data-knob=\"0\">\n        <div class=\"knob\"></div>\n        <div class=\"klabel\">Drive</div>\n        <div class=\"kval\">—</div>\n      </div>\n\n      <div class=\"toggle-wrap\">\n        <div class=\"toggle\" id=\"curveToggle\">\n          <span class=\"on\">DIODE</span><span>TUBE</span>\n          <div class=\"slider\"></div>\n        </div>\n        <div class=\"klabel\">Curve</div>\n      </div>\n\n      <div class=\"knob-wrap\" data-knob=\"2\">\n        <div class=\"knob\"></div>\n        <div class=\"klabel\">Tone</div>\n        <div class=\"kval\">—</div>\n      </div>\n\n      <div class=\"knob-wrap\" data-knob=\"3\">\n        <div class=\"knob\"></div>\n        <div class=\"klabel\">Trim</div>\n        <div class=\"kval\">—</div>\n      </div>\n\n      <div class=\"knob-wrap\" data-knob=\"4\">\n        <div class=\"knob\"></div>\n        <div class=\"klabel\">Mix</div>\n        <div class=\"kval\">—</div>\n      </div>\n\n      <div class=\"meter-wrap\">\n        <div class=\"meter\"><div class=\"fill\" id=\"meterFill\"></div><div class=\"ticks\"></div></div>\n        <div class=\"klabel\">Out</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- param model (index, default match spec.json) ----\n  var PARAMS = {\n    0:{name:\"Drive\", def:0.40},\n    1:{name:\"Curve\", def:0,    step:1, max:1},\n    2:{name:\"Tone\",  def:0.60},\n    3:{name:\"Trim\",  def:0.65},\n    4:{name:\"Mix\",   def:1.00}\n  };\n  var state = {0:0.40, 1:0, 2:0.60, 3:0.65, 4:1.00};\n\n  function send(i,v){\n    if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n\n  // ---- value formatting per param ----\n  function fmt(i){\n    var v = state[i];\n    if(i===0) return Math.round(v*100)+\"%\";            // drive\n    if(i===2) return Math.round(v*100)+\"%\";            // tone\n    if(i===3){ var db = (v*1.5); db = db<=0?-60:20*Math.log10(db);\n               return (db>=0?\"+\":\"\")+db.toFixed(1)+\" dB\"; }\n    if(i===4) return Math.round(v*100)+\"%\";            // mix\n    return v.toFixed(2);\n  }\n\n  // ====================================================================\n  //  KNOBS — custom SVG, draggable (ns), double-click reset\n  // ====================================================================\n  var ARC_A0 = -135, ARC_A1 = 135; // degrees sweep\n  function knobSVG(){\n    var ns=\"http://www.w3.org/2000/svg\";\n    var svg=document.createElementNS(ns,\"svg\");\n    svg.setAttribute(\"viewBox\",\"0 0 66 66\");svg.setAttribute(\"width\",\"66\");svg.setAttribute(\"height\",\"66\");\n    svg.innerHTML =\n      '<defs>'+\n        '<radialGradient id=\"kc\" cx=\"38%\" cy=\"30%\" r=\"75%\">'+\n          '<stop offset=\"0\" stop-color=\"#fff7e2\"/><stop offset=\"0.55\" stop-color=\"#e7d3a4\"/>'+\n          '<stop offset=\"1\" stop-color=\"#b89a5c\"/></radialGradient>'+\n      '</defs>'+\n      '<circle cx=\"33\" cy=\"33\" r=\"30\" fill=\"none\" stroke=\"rgba(80,60,25,.25)\" stroke-width=\"4\"/>'+\n      '<circle class=\"track\" cx=\"33\" cy=\"33\" r=\"30\" fill=\"none\" stroke=\"rgba(80,60,25,.18)\" stroke-width=\"4\"'+\n        ' stroke-linecap=\"round\"/>'+\n      '<circle class=\"arc\" cx=\"33\" cy=\"33\" r=\"30\" fill=\"none\" stroke=\"#ffce5e\" stroke-width=\"4\"'+\n        ' stroke-linecap=\"round\" style=\"filter:drop-shadow(0 0 4px rgba(255,190,70,.7))\"/>'+\n      '<circle class=\"cap\" cx=\"33\" cy=\"33\" r=\"22\" fill=\"url(#kc)\" stroke=\"#9a824c\" stroke-width=\"1\"/>'+\n      '<line class=\"ptr\" x1=\"33\" y1=\"33\" x2=\"33\" y2=\"16\" stroke=\"#5c4a22\" stroke-width=\"3\" stroke-linecap=\"round\"/>';\n    return svg;\n  }\n  var R=30, C=2*Math.PI*R, ARC_LEN=(270/360)*C;\n\n  function renderKnob(el, frac){\n    var arc=el.querySelector(\".arc\"), track=el.querySelector(\".track\"), ptr=el.querySelector(\".ptr\");\n    track.setAttribute(\"stroke-dasharray\", ARC_LEN+\" \"+C);\n    track.setAttribute(\"transform\",\"rotate(135 33 33)\");\n    arc.setAttribute(\"stroke-dasharray\", (ARC_LEN*frac)+\" \"+C);\n    arc.setAttribute(\"transform\",\"rotate(135 33 33)\");\n    var ang = ARC_A0 + frac*(ARC_A1-ARC_A0);\n    ptr.setAttribute(\"transform\",\"rotate(\"+ang+\" 33 33)\");\n  }\n\n  document.querySelectorAll(\".knob-wrap\").forEach(function(wrap){\n    var idx = parseInt(wrap.getAttribute(\"data-knob\"),10);\n    var holder = wrap.querySelector(\".knob\");\n    var valEl = wrap.querySelector(\".kval\");\n    var svg = knobSVG();\n    holder.appendChild(svg);\n\n    function refresh(){\n      renderKnob(svg, state[idx]);\n      valEl.textContent = fmt(idx);\n    }\n    function set(v, push){\n      v = Math.max(0, Math.min(1, v));\n      state[idx]=v;\n      refresh();\n      if(push) send(idx, v);\n      scheduleScope();\n    }\n\n    // drag\n    var dragging=false, lastY=0;\n    holder.addEventListener(\"pointerdown\", function(e){\n      dragging=true; lastY=e.clientY; holder.setPointerCapture(e.pointerId);\n      svg.querySelector(\".cap\").style.filter=\"drop-shadow(0 0 8px rgba(255,200,90,.6))\";\n      e.preventDefault();\n    });\n    holder.addEventListener(\"pointermove\", function(e){\n      if(!dragging) return;\n      var dy = lastY - e.clientY; lastY=e.clientY;\n      var fine = e.shiftKey?0.25:1;\n      set(state[idx] + dy*0.005*fine, true);\n    });\n    function end(){ dragging=false; svg.querySelector(\".cap\").style.filter=\"\"; }\n    holder.addEventListener(\"pointerup\", end);\n    holder.addEventListener(\"pointercancel\", end);\n    // double-click reset\n    holder.addEventListener(\"dblclick\", function(){ set(PARAMS[idx].def, true); });\n\n    wrap._set=set; wrap._refresh=refresh;\n    refresh();\n  });\n\n  // ====================================================================\n  //  CURVE TOGGLE (stepped 0/1)\n  // ====================================================================\n  var toggle = document.getElementById(\"curveToggle\");\n  var spans = toggle.querySelectorAll(\"span\");\n  var modeTxt = document.getElementById(\"modeTxt\");\n  function applyCurve(v, push){\n    state[1] = v?1:0;\n    toggle.classList.toggle(\"tube\", state[1]===1);\n    spans[0].classList.toggle(\"on\", state[1]===0);\n    spans[1].classList.toggle(\"on\", state[1]===1);\n    modeTxt.textContent = state[1]===1 ? \"TUBE\" : \"DIODE\";\n    if(push) send(1, state[1]);\n    scheduleScope();\n  }\n  toggle.addEventListener(\"click\", function(){ applyCurve(state[1]===1?0:1, true); });\n  toggle.addEventListener(\"dblclick\", function(e){ e.preventDefault(); applyCurve(PARAMS[1].def, true); });\n\n  // ====================================================================\n  //  TRANSFER CURVE — mirrors the DSP math so the graph is truthful\n  // ====================================================================\n  var curvePath = document.getElementById(\"curvePath\");\n  var curveArea = document.getElementById(\"curveArea\");\n  var dot = document.getElementById(\"dot\");\n  var readout = document.getElementById(\"readout\");\n  var meterFill = document.getElementById(\"meterFill\");\n  var W=520, H=170;\n\n  function tanh(x){ if(x>20)return 1; if(x<-20)return -1;\n    var e=Math.exp(2*x); return (e-1)/(e+1); }\n\n  function shape(x, drive, comp, isTube){\n    var pre = x*drive, y;\n    if(isTube){ var bias=0.18; y = tanh(pre+bias) - tanh(bias); }\n    else { y = tanh(pre); }\n    return y*comp;\n  }\n\n  var scopeQueued=false;\n  function scheduleScope(){ if(scopeQueued)return; scopeQueued=true; requestAnimationFrame(drawScope); }\n\n  function drawScope(){\n    scopeQueued=false;\n    var driveN=state[0], isTube=state[1]===1, trim=state[3]*1.5, mix=state[4];\n    var drive=1+driveN*11, comp=1/Math.sqrt(drive);\n\n    var d=\"\", a=\"M0 \"+H, N=90, lastX=0,lastY=0;\n    for(var k=0;k<=N;k++){\n      var t=k/N;                       // 0..1\n      var xin=(t*2-1);                 // -1..1 input\n      var wet=shape(xin, drive, comp, isTube)*trim;\n      var yout=xin*(1-mix)+wet*mix;\n      var px=t*W;\n      var py=H/2 - yout*(H/2-6);\n      py=Math.max(2,Math.min(H-2,py));\n      d += (k===0?\"M\":\"L\")+px.toFixed(1)+\" \"+py.toFixed(1);\n      a += \"L\"+px.toFixed(1)+\" \"+py.toFixed(1);\n      lastX=px; lastY=py;\n    }\n    a += \"L\"+W+\" \"+H+\"Z\";\n    curvePath.setAttribute(\"d\", d);\n    curveArea.setAttribute(\"d\", a);\n\n    // moving dot at a representative ~+drive operating point\n    var probe=0.6;\n    var wetP=shape(probe, drive, comp, isTube)*trim;\n    var outP=probe*(1-mix)+wetP*mix;\n    dot.setAttribute(\"cx\", (((probe+1)/2)*W).toFixed(1));\n    dot.setAttribute(\"cy\", (H/2 - outP*(H/2-6)).toFixed(1));\n\n    // gain readout = output level at probe vs input (dB)\n    var g = Math.abs(outP)/probe;\n    var db = g<=0.0001?-60:20*Math.log10(g);\n    readout.textContent = (db>=0?\"+\":\"\")+db.toFixed(1)+\" dB\";\n\n    // meter target = peak of |out| over sweep\n    var peak=Math.abs(lastY); // placeholder, compute true peak below\n    peak=0;\n    for(var s=0;s<=40;s++){\n      var xx=(s/40)*2-1, ww=shape(xx,drive,comp,isTube)*trim;\n      var oo=Math.abs(xx*(1-mix)+ww*mix);\n      if(oo>peak)peak=oo;\n    }\n    meterTarget=Math.min(1,peak);\n  }\n\n  // animated meter eases toward target\n  var meterTarget=0, meterVal=0;\n  (function meterLoop(){\n    meterVal += (meterTarget - meterVal)*0.12;\n    meterFill.style.height=(meterVal*100).toFixed(1)+\"%\";\n    requestAnimationFrame(meterLoop);\n  })();\n\n  // ====================================================================\n  //  READY / INIT\n  // ====================================================================\n  function ready(){\n    // init host to defaults\n    for(var i in PARAMS){ send(parseInt(i,10), state[i]); }\n    document.querySelectorAll(\".knob-wrap\").forEach(function(w){ w._refresh(); });\n    applyCurve(state[1], false);\n    drawScope();\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CLIP STAGE — transparent analog-style soft-clip saturator / drive\n//  A gentle, MUSICAL clipping stage for warmth, glue and level control —\n//  NOT a fuzz. A makeup-compensated drive feeds a selectable transfer\n//  curve: DIODE (symmetric soft knee, odd harmonics) or TUBE (asymmetric\n//  bias, adds even harmonics). A subtle post Tone tilt, an output Trim and\n//  a parallel Mix round it out. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker (removes tube bias offset)\nconst dcPrev:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst toneState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone one-pole\n\nconst P_DRIVE: i32 = 0; // 0..1  -> input gain 1..12 (gentle, makeup-compensated)\nconst P_CURVE: i32 = 1; // 0..1  -> stepped 0=diode (soft) , 1=tube (asymmetric)\nconst P_TONE:  i32 = 2; // 0..1  -> spectral tilt: dark <-> open (one-pole LP morph)\nconst P_TRIM:  i32 = 3; // 0..1  -> output trim 0..1.5\nconst P_MIX:   i32 = 4; // 0..1  -> dry/wet (parallel saturation)\n\nconst PI: f32 = 3.14159265;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) { dcState[c] = 0.0; dcPrev[c] = 0.0; toneState[c] = 0.0; }\n  params[P_DRIVE] = 0.4;\n  params[P_CURVE] = 0.0;\n  params[P_TONE]  = 0.6;\n  params[P_TRIM]  = 0.65;\n  params[P_MIX]   = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// DIODE: smooth symmetric soft-clip via tanh — transparent, odd harmonics,\n// bounded to ±1. Gentle knee keeps it musical rather than grindy.\n@inline function diodeClip(x: f32): f32 {\n  return f32(Mathf.tanh(x));\n}\n\n// TUBE: asymmetric soft-clip. A small positive bias is added before a\n// tanh-like saturator so the curve compresses one side harder than the\n// other — this introduces 2nd-order (even) harmonics for the warm tube\n// character. The DC blocker downstream removes the resulting offset.\n@inline function tubeClip(x: f32): f32 {\n  const bias: f32 = 0.18;\n  const xb: f32 = x + bias;\n  // saturate\n  const s: f32 = f32(Mathf.tanh(xb));\n  // re-reference around the biased operating point so silence stays ~silent\n  const sb: f32 = f32(Mathf.tanh(bias));\n  return s - sb;\n}\n\nexport function process(n: i32): void {\n  const driveN: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  // stepped selector: 0 -> diode, 1 -> tube\n  const curve: i32 = params[P_CURVE] >= 0.5 ? 1 : 0;\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const trim:  f32 = clampf(params[P_TRIM], 0.0, 1.0) * 1.5;\n  const mix:   f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // gentle drive: 1..12x input gain (transparent range, never fuzz)\n  const drive: f32 = 1.0 + driveN * 11.0;\n  // makeup compensation: as drive rises the clipper compresses, so we\n  // scale back to keep perceived level roughly constant (level control,\n  // not a volume knob). sqrt keeps it musical.\n  const comp: f32 = 1.0 / f32(Mathf.sqrt(drive));\n\n  // post tone: one-pole low-pass morphing 1.2 kHz (dark) .. 18 kHz (open)\n  const toneHz: f32 = 1200.0 + toneN * toneN * 16800.0;\n  const cTone: f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * PI * toneHz / sampleRate)), 0.0, 1.0);\n\n  // DC blocker coefficient (~10 Hz)\n  const r: f32 = f32(Mathf.exp(-2.0 * PI * 10.0 / sampleRate));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let dPrev: f32 = dcPrev[c];\n    let dState: f32 = dcState[c];\n    let tn: f32 = toneState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n      const pre: f32 = x * drive;\n\n      let shaped: f32 = curve == 1 ? tubeClip(pre) : diodeClip(pre);\n      shaped = shaped * comp;\n\n      // DC blocker (high-pass at ~10 Hz) — removes tube bias offset\n      const dOut: f32 = shaped - dPrev + r * dState;\n      dPrev = shaped;\n      dState = dOut;\n\n      // post tone shaping\n      tn = tn + cTone * (dOut - tn);\n\n      const wet: f32 = tn * trim;\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    dcPrev[c] = dPrev;\n    dcState[c] = dState;\n    toneState[c] = tn;\n  }\n}\n",
  "publishedAt": 1751000141000
}