{
  "format": 1,
  "name": "Room Print",
  "isInstrument": false,
  "explanation": "A convolution reverb that prints your sound into a real, measured acoustic space. A genuine room impulse response is baked into the plugin and convolved with the input in the time domain, so the reverb is the true fingerprint of a physical room rather than an algorithm. Controls: dry/wet Mix, Size (how much of the tail is used), Pre-Delay, Tone (high-frequency damping of the tail) and stereo Width. Impulse response: Adventure Kid 'AK-SROOMS' small-room IR, licensed CC BY 4.0.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Size",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Pre-Delay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.12
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Width",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.9
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Room Print</title>\n<style>\n  :root{ --acc:#5ad1c4; --acc2:#7a8cff; --bg0:#070b10; --bg1:#0e1620; --ink:#cfe8ea; --dim:#5d7480; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{\n    font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#13202b 0%,var(--bg1) 40%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%;\n  }\n  .unit{\n    width:min(94vw,760px); border-radius:20px; padding:20px 22px 24px;\n    background:linear-gradient(160deg,rgba(30,46,60,.72),rgba(10,16,22,.86));\n    border:1px solid rgba(120,200,210,.16);\n    box-shadow:0 24px 70px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05);\n    backdrop-filter:blur(6px); position:relative; overflow:hidden;\n  }\n  .unit::before{ /* aura sweep */\n    content:\"\"; position:absolute; inset:-40% -10%; pointer-events:none;\n    background:radial-gradient(40% 50% at 20% 0%,rgba(90,209,196,.10),transparent 60%),\n               radial-gradient(40% 60% at 100% 30%,rgba(122,140,255,.10),transparent 60%);\n    animation:drift 14s ease-in-out infinite alternate;\n  }\n  @keyframes drift{ from{ transform:translate(-2%,-1%);} to{ transform:translate(3%,2%);} }\n  header{ display:flex; align-items:baseline; gap:12px; margin-bottom:14px; position:relative; z-index:2; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:11px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc);\n    box-shadow:0 0 10px var(--acc),0 0 20px var(--acc); animation:pulse 2.4s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.45; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n\n  .stage{ display:grid; grid-template-columns:1fr; gap:14px; position:relative; z-index:2; }\n  .room{ position:relative; height:188px; border-radius:14px; overflow:hidden;\n    background:linear-gradient(180deg,#0a131b,#0c1822); border:1px solid rgba(120,200,210,.14);\n    box-shadow:inset 0 2px 24px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .irlabel{ position:absolute; left:12px; top:9px; font-size:10px; letter-spacing:.24em; color:var(--dim); z-index:3; }\n  .irlabel b{ color:var(--acc); font-weight:600; }\n\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; margin-top:4px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:7px; padding:8px 4px 4px; cursor:ns-resize; position:relative; }\n  .dial{ width:78px; height:78px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(150,190,200,.14); stroke-width:7; stroke-linecap:round; }\n  .fill{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round;\n    filter:drop-shadow(0 0 5px rgba(90,209,196,.6)); transition:stroke-dashoffset .05s linear; }\n  .cap{ fill:radial-gradient(#16242e,#0a1218); }\n  .pointer{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .pcap{ fill:#0c151c; stroke:rgba(120,200,210,.25); stroke-width:1; }\n  .name{ font-size:10px; letter-spacing:.16em; text-transform:uppercase; color:var(--dim); }\n  .val{ font-size:12px; font-variant-numeric:tabular-nums; color:var(--ink);\n    background:rgba(90,209,196,.08); padding:1px 8px; border-radius:8px; border:1px solid rgba(90,209,196,.18); }\n  .knob:hover .name{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <span class=\"logo\">ROOM&nbsp;PRINT</span>\n      <span class=\"sub\">convolution reverb</span>\n      <span class=\"led\"></span>\n    </header>\n    <div class=\"stage\">\n      <div class=\"room\">\n        <div class=\"irlabel\">REAL&nbsp;ROOM&nbsp;IR &nbsp;·&nbsp; <b id=\"szlbl\">tail 65%</b></div>\n        <canvas id=\"cv\"></canvas>\n      </div>\n      <div class=\"knobs\" id=\"knobs\"></div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n  var PARAMS=[\n    {name:\"Mix\",  idx:0, def:0.30},\n    {name:\"Size\", idx:1, def:0.65},\n    {name:\"Pre\",  idx:2, def:0.12},\n    {name:\"Tone\", idx:3, def:0.60},\n    {name:\"Width\",idx:4, def:0.90}\n  ];\n  var vals=PARAMS.map(function(p){return p.def;});\n  var host=null;\n  function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n\n  // ---- knobs ----\n  var R=34, C=2*Math.PI*R, A0=-135, A1=135;\n  function fmt(p,v){ if(p.name===\"Mix\"||p.name===\"Width\") return Math.round(v*100)+\"%\";\n    if(p.name===\"Pre\") return Math.round(v*100)+\" ms\"; if(p.name===\"Size\") return Math.round(v*100)+\"%\";\n    return Math.round(v*100)+\"%\"; }\n  var wrap=document.getElementById(\"knobs\");\n  var knobs=PARAMS.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML=\n      '<div class=\"dial\"><svg viewBox=\"0 0 90 90\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n      '<stop offset=\"0\" stop-color=\"#5ad1c4\"/><stop offset=\"1\" stop-color=\"#7a8cff\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"45\" cy=\"45\" r=\"34\"></circle>'+\n      '<circle class=\"fill\" cx=\"45\" cy=\"45\" r=\"34\" transform=\"rotate(135 45 45)\" '+\n      'stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"45\" cy=\"45\" r=\"22\"></circle>'+\n      '<line class=\"pointer\" x1=\"45\" y1=\"45\" x2=\"45\" y2=\"27\"></line>'+\n      '</svg></div>'+\n      '<span class=\"name\">'+p.name+'</span><span class=\"val\"></span>';\n    wrap.appendChild(el);\n    var fill=el.querySelector(\".fill\"), ptr=el.querySelector(\".pointer\"), val=el.querySelector(\".val\");\n    function render(v){\n      var sweep=(A1-A0)/360; fill.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180;\n      ptr.setAttribute(\"x2\",(45+Math.sin(ang)*18).toFixed(2));\n      ptr.setAttribute(\"y2\",(45-Math.cos(ang)*18).toFixed(2));\n      val.textContent=fmt(p,v);\n    }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return;\n      var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/180));\n      vals[p.idx]=nv; render(nv); send(p.idx,nv); if(p.idx===1) sizeLbl(nv); });\n    el.addEventListener(\"pointerup\",function(e){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); if(p.idx===1) sizeLbl(p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  function sizeLbl(v){ var e=document.getElementById(\"szlbl\"); if(e) e.textContent=\"tail \"+Math.round(v*100)+\"%\"; }\n\n  // ---- animated room: a source emits rays that reflect off the walls and fade ----\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n\n  var rays=[];\n  function pad(){ return 16 + (1-vals[1])*0; }\n  function emit(){\n    var n=7+Math.round(vals[0]*6);\n    for(var i=0;i<n;i++){\n      var a=Math.random()*Math.PI*2;\n      rays.push({x:W*0.5,y:H*0.56,vx:Math.cos(a),vy:Math.sin(a),life:1,bounces:0});\n    }\n  }\n  var t0=0, acc=0;\n  function frame(ts){\n    if(!t0)t0=ts; var dt=Math.min(50,ts-t0); t0=ts; acc+=dt;\n    // room rect grows a touch with Size\n    var m=14, rw=W-2*m, rh=H-2*m, rx=m, ry=m;\n    var sz=0.6+vals[1]*0.4;\n    var ix=rx+rw*(1-sz)/2, iy=ry+rh*(1-sz)/2, iw=rw*sz, ih=rh*sz;\n    ctx.clearRect(0,0,W,H);\n    // floor grid\n    ctx.save(); ctx.globalAlpha=0.5; ctx.strokeStyle=\"rgba(90,160,170,0.10)\"; ctx.lineWidth=1;\n    for(var gx=0;gx<=8;gx++){ var X=ix+iw*gx/8; ctx.beginPath(); ctx.moveTo(X,iy); ctx.lineTo(X,iy+ih); ctx.stroke(); }\n    for(var gy=0;gy<=5;gy++){ var Y=iy+ih*gy/5; ctx.beginPath(); ctx.moveTo(ix,Y); ctx.lineTo(ix+iw,Y); ctx.stroke(); }\n    ctx.restore();\n    // walls\n    ctx.strokeStyle=\"rgba(122,140,255,0.45)\"; ctx.lineWidth=2;\n    ctx.shadowColor=\"rgba(122,140,255,0.5)\"; ctx.shadowBlur=12; ctx.strokeRect(ix,iy,iw,ih); ctx.shadowBlur=0;\n\n    var speed=0.06+vals[1]*0.06;\n    var preDelay=vals[2];\n    if(acc>(120 - vals[0]*60)){ acc=0; emit(); }\n    var damp=0.55+vals[3]*0.4; // tone -> ray persistence colouring\n    for(var i=rays.length-1;i>=0;i--){\n      var r=rays[i];\n      r.x+=r.vx*speed*dt*2.2; r.y+=r.vy*speed*dt*2.2;\n      // reflect off inner room walls\n      if(r.x<ix){ r.x=ix; r.vx=-r.vx; r.bounces++; r.life*=0.82; }\n      else if(r.x>ix+iw){ r.x=ix+iw; r.vx=-r.vx; r.bounces++; r.life*=0.82; }\n      if(r.y<iy){ r.y=iy; r.vy=-r.vy; r.bounces++; r.life*=0.82; }\n      else if(r.y>iy+ih){ r.y=iy+ih; r.vy=-r.vy; r.bounces++; r.life*=0.82; }\n      r.life-=0.0016*dt*(2-vals[1]);\n      if(r.life<=0){ rays.splice(i,1); continue; }\n      var al=r.life*0.9;\n      var col= r.bounces? (180+ (1-damp)*40) : 200;\n      ctx.beginPath();\n      ctx.fillStyle=\"rgba(\"+Math.round(90+ (1-vals[3])*40)+\",\"+Math.round(200*damp+30)+\",\"+Math.round(196)+\",\"+al+\")\";\n      ctx.arc(r.x,r.y,1.7+r.life*1.4,0,Math.PI*2); ctx.fill();\n    }\n    // source\n    var pulse=0.6+0.4*Math.sin(ts/240);\n    ctx.beginPath(); ctx.fillStyle=\"rgba(90,209,196,\"+(0.5+0.5*pulse)+\")\";\n    ctx.shadowColor=\"#5ad1c4\"; ctx.shadowBlur=18; ctx.arc(W*0.5,H*0.56,3.4+pulse*2,0,Math.PI*2); ctx.fill(); ctx.shadowBlur=0;\n    // pre-delay ring\n    if(preDelay>0.02){ ctx.beginPath(); ctx.strokeStyle=\"rgba(122,140,255,\"+(0.25*preDelay+0.1)+\")\"; ctx.lineWidth=1.5;\n      ctx.arc(W*0.5,H*0.56,8+preDelay*46*(0.5+0.5*Math.sin(ts/500)),0,Math.PI*2); ctx.stroke(); }\n    // IR decay strip (bottom)\n    var by=H-9, bx0=ix, bw=iw;\n    for(var b=0;b<46;b++){\n      var fr=b/46; var env=Math.exp(-fr*(3.4-vals[1]*2.4))*(0.4+0.6*Math.abs(Math.sin(fr*30+ts/300)));\n      var hgt=env*(7+vals[0]*16);\n      ctx.fillStyle=\"rgba(90,209,196,\"+(0.25+env*0.5)+\")\";\n      ctx.fillRect(bx0+bw*fr, by-hgt, bw/52, hgt);\n    }\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- host wiring ----\n  function boot(){\n    host=window.vstai||null;\n    PARAMS.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); });\n  }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } }\n  else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// Room Print — convolution reverb. A REAL measured small-room impulse response\n// (Adventure Kid \"AK-SROOMS\", CC BY 4.0 — see README) is baked in as base64\n// Int16-LE PCM @ 22050 Hz, decoded at init() and resampled to the host rate,\n// then convolved with the input in the time domain. Pure algorithm, no host\n// imports, no allocation inside process() (all StaticArrays at module scope).\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_TAPS: i32 = 6144;          // convolution length cap (at host rate)\nconst HIST_LEN: i32 = 16384;         // power-of-two ring >= MAX_TAPS + predelay\nconst HIST_MASK: i32 = HIST_LEN - 1;\nconst IR_RAW_RATE: f32 = 22050.0;    // rate the embedded IR was stored at\nconst IR_RAW_CAP: i32 = 8192;        // decoded raw-IR cap\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst irRaw: StaticArray<f32> = new StaticArray<f32>(IR_RAW_CAP);\nconst ir:    StaticArray<f32> = new StaticArray<f32>(MAX_TAPS);\nconst histL: StaticArray<f32> = new StaticArray<f32>(HIST_LEN);\nconst histR: StaticArray<f32> = new StaticArray<f32>(HIST_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\nlet irRawLen: i32 = 0;\nlet irLen: i32 = 0;          // resampled + capped length\nlet writePos: i32 = 0;\nlet lpL: f32 = 0.0;\nlet lpR: f32 = 0.0;\n\n// --- embedded impulse response (base64 of Int16-LE mono PCM @ 22050 Hz) ---\nconst IR_B64: string = \"\";\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;        // A-Z -> 0..25\n  if (c >= 97 && c <= 122) return c - 71;        // a-z -> 26..51\n  if (c >= 48 && c <= 57)  return c + 4;         // 0-9 -> 52..61\n  if (c == 43) return 62;                        // +\n  if (c == 47) return 63;                        // /\n  return -1;                                     // '=' / padding\n}\n\nfunction decodeIR(): void {\n  const s = IR_B64;\n  const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else {\n        let val = (byte << 8) | lo;              // Int16 LE\n        if (val >= 32768) val -= 65536;\n        if (si < IR_RAW_CAP) { irRaw[si] = f32(val) / 32768.0; si++; }\n        lo = -1;\n      }\n    }\n  }\n  irRawLen = si;\n}\n\nfunction buildIR(): void {\n  // resample raw IR (IR_RAW_RATE) -> host sampleRate, linear interp, cap MAX_TAPS\n  const ratio: f32 = IR_RAW_RATE / sampleRate;   // raw samples advanced per host sample\n  let n: i32 = i32(f32(irRawLen) / ratio);\n  if (n > MAX_TAPS) n = MAX_TAPS;\n  if (n < 1) n = 1;\n  for (let k = 0; k < n; k++) {\n    const sp: f32 = f32(k) * ratio;\n    const i0: i32 = i32(sp);\n    const fr: f32 = sp - f32(i0);\n    const a: f32 = i0 < irRawLen ? irRaw[i0] : 0.0;\n    const b: f32 = (i0 + 1) < irRawLen ? irRaw[i0 + 1] : 0.0;\n    ir[k] = a + (b - a) * fr;\n  }\n  irLen = n;\n  // energy-normalise so the wet path sits near unity, then a musical trim\n  let e: f32 = 0.0;\n  for (let k = 0; k < irLen; k++) e += ir[k] * ir[k];\n  let g: f32 = e > 0.000001 ? (f32(1.0) / Mathf.sqrt(e)) : 1.0;\n  g *= 0.85;\n  for (let k = 0; k < irLen; k++) ir[k] *= g;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0; lpL = 0.0; lpR = 0.0;\n  for (let i = 0; i < HIST_LEN; i++) { histL[i] = 0.0; histR[i] = 0.0; }\n  params[0] = 0.30;   // Mix\n  params[1] = 0.65;   // Size (decay length)\n  params[2] = 0.12;   // Pre-Delay\n  params[3] = 0.60;   // Tone\n  params[4] = 0.90;   // Width\n  decodeIR();\n  buildIR();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const mix: f32  = params[0];\n  const size: f32 = params[1];\n  const pdel: f32 = params[2];\n  const tone: f32 = params[3];\n  const width: f32 = params[4];\n\n  let taps: i32 = i32(f32(irLen) * (0.12 + 0.88 * size));\n  if (taps < 1) taps = 1;\n  if (taps > irLen) taps = irLen;\n  let pd: i32 = i32(pdel * 0.10 * sampleRate);          // up to ~100 ms pre-delay\n  if (pd < 0) pd = 0;\n  const pdMax: i32 = HIST_LEN - MAX_TAPS - 1;\n  if (pd > pdMax) pd = pdMax;\n  const lpco: f32 = 0.04 + 0.95 * tone;                 // bright tone -> high cutoff\n  const stereo: i32 = channels > 1 ? 1 : 0;\n  const wet: f32 = mix;\n  const dry: f32 = 1.0 - mix;\n\n  for (let f = 0; f < n; f++) {\n    const xl: f32 = inBuf[f];\n    const xr: f32 = stereo ? inBuf[MAX_FRAMES + f] : xl;\n    histL[writePos] = xl;\n    histR[writePos] = xr;\n    const base: i32 = (writePos - pd) & HIST_MASK;\n    let yl: f32 = 0.0;\n    let yr: f32 = 0.0;\n    for (let k = 0; k < taps; k++) {\n      const c: f32 = ir[k];\n      const idx: i32 = (base - k) & HIST_MASK;\n      yl += histL[idx] * c;\n      yr += histR[idx] * c;\n    }\n    lpL += (yl - lpL) * lpco;\n    lpR += (yr - lpR) * lpco;\n    let wl: f32 = lpL;\n    let wr: f32 = lpR;\n    const mid: f32 = (wl + wr) * 0.5;\n    wl = mid + (wl - mid) * width;\n    wr = mid + (wr - mid) * width;\n    let ol: f32 = xl * dry + wl * wet;\n    let orr: f32 = xr * dry + wr * wet;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[f] = ol;\n    if (stereo) outBuf[MAX_FRAMES + f] = orr;\n    writePos = (writePos + 1) & HIST_MASK;\n  }\n}\n",
  "publishedAt": 1751000127000
}