{
  "format": 1,
  "name": "Sem Voice",
  "isInstrument": true,
  "explanation": "A warm SEM-lineage duophonic synth voice. Two detuned oscillators (a saw and a variable-width pulse) feed a 12 dB/oct state-variable filter whose response morphs continuously from low-pass, through a notch, to high-pass via the Mode control. The filter has its own resonance and a decay envelope; Env Amount sets how far the cutoff sweeps, Detune thickens the two oscillators and opens the pulse, Decay shapes both the filter sweep and the amp tail, and Level sets output. The smooth low-pass -> notch -> high-pass sweep is the signature vocal, growling character.",
  "params": [
    {
      "name": "Mode",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Env Amount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Sem Voice</title>\n<style>\n  :root{\n    --acc:#e8c27a;     /* amber */\n    --acc2:#7ad0ff;    /* sky blue */\n    --amber-dim:#9c7a3e;\n    --cream0:#f4ecdc;\n    --cream1:#e8ddc6;\n    --cream2:#d8cbac;\n    --ink:#2a2218;\n    --chrome0:#fbfdff;\n    --chrome1:#b9c2cb;\n    --chrome2:#79848e;\n    --chrome3:#454d54;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}\n  html,body{height:100%}\n  body{\n    background:radial-gradient(130% 100% at 50% -15%,#3a342a 0%,#211d16 50%,#100d09 100%);\n    color:var(--ink);\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    overflow:hidden;display:flex;align-items:center;justify-content:center;\n    letter-spacing:.02em;\n  }\n\n  /* ============ THE PANEL ============ */\n  .panel{\n    position:relative;width:790px;height:466px;border-radius:16px;padding:20px 24px 22px;\n    background:\n      linear-gradient(180deg,#fff8ec 0%,#efe5cf 5%,#e3d6ba 8%,#ddd0b2 50%,#cdbf9c 93%,#bbac86 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.8) inset,\n      0 -2px 8px rgba(120,95,55,.35) inset,\n      0 34px 70px rgba(0,0,0,.6),\n      0 2px 0 #8a7a55;\n    overflow:hidden;\n  }\n  /* subtle paper grain */\n  .panel::before{\n    content:\"\";position:absolute;inset:0;border-radius:16px;pointer-events:none;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.05) 0 2px,rgba(110,85,45,.045) 2px 4px);\n    mix-blend-mode:overlay;opacity:.7;\n  }\n  /* slow warm sheen */\n  .panel::after{\n    content:\"\";position:absolute;top:0;left:-45%;width:38%;height:100%;\n    background:linear-gradient(105deg,transparent,rgba(255,255,255,.35),transparent);\n    transform:skewX(-18deg);pointer-events:none;animation:sheen 9s ease-in-out infinite;\n  }\n  @keyframes sheen{0%,70%{left:-50%}88%{left:135%}100%{left:135%}}\n\n  /* chrome bezel screws */\n  .screw{position:absolute;width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 28%,#fff,#c2cad1 50%,#5e676e 100%);\n    box-shadow:0 1px 1px rgba(0,0,0,.45),0 0 0 1px rgba(70,40,10,.35);}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#3a4147 44% 56%,transparent 56%);transform:rotate(35deg)}\n  .screw.tl{top:10px;left:10px}.screw.tr{top:10px;right:10px}\n  .screw.bl{bottom:10px;left:10px}.screw.br{bottom:10px;right:10px}\n\n  /* ============ HEADER ============ */\n  .head{display:flex;align-items:flex-end;justify-content:space-between;margin:0 8px 14px}\n  .brand{display:flex;flex-direction:column;line-height:1}\n  .brand .sub{font-size:9px;letter-spacing:.46em;color:#8a6f3c;font-weight:800;margin-bottom:6px;text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(255,255,255,.7)}\n  .brand .name{font-size:31px;font-weight:800;letter-spacing:.01em;color:#2a2014;\n    text-shadow:0 1px 0 rgba(255,255,255,.7),0 -1px 1px rgba(80,55,20,.25)}\n  .brand .name b{color:var(--amber-dim);\n    text-shadow:0 0 10px rgba(232,194,122,.6),0 1px 0 rgba(255,255,255,.6)}\n  .badge{display:flex;flex-direction:column;align-items:flex-end;gap:4px}\n  .badge .chip{font-size:8px;letter-spacing:.28em;font-weight:800;color:#5b4a2a;\n    border:1px solid #a8916a;border-radius:20px;padding:3px 10px;\n    background:linear-gradient(180deg,#f3ead6,#dac9a4);\n    box-shadow:0 1px 0 rgba(255,255,255,.6) inset,0 1px 2px rgba(80,55,20,.2)}\n  .badge .voices{font-size:8px;letter-spacing:.2em;color:#7a6537;font-weight:700}\n\n  /* ============ MAIN STAGE ============ */\n  .stage{display:flex;gap:20px;align-items:stretch;margin:0 6px}\n\n  /* --- the big MODE morph dial + response window --- */\n  .morph{\n    position:relative;width:330px;border-radius:13px;padding:14px;\n    background:linear-gradient(180deg,#1d2024,#0c0e10);\n    box-shadow:0 2px 6px rgba(0,0,0,.55) inset,0 1px 0 rgba(255,255,255,.5),0 0 0 1px rgba(60,40,10,.4);\n  }\n  .scopeWrap{position:relative;width:302px;height:150px;border-radius:9px;overflow:hidden;\n    background:linear-gradient(180deg,#0a1418,#050a0c);\n    box-shadow:0 2px 5px rgba(0,0,0,.7) inset;border:1px solid #1c2226;}\n  .scopeWrap canvas{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .scope-grid{position:absolute;inset:0;pointer-events:none;\n    background:\n      repeating-linear-gradient(0deg,rgba(122,208,255,.06) 0 1px,transparent 1px 18px),\n      repeating-linear-gradient(90deg,rgba(122,208,255,.06) 0 1px,transparent 1px 22px);}\n  .scope-glass{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(130% 80% at 50% 0%,rgba(232,194,122,.12),transparent 62%)}\n  .scope-tags{position:absolute;inset:0;pointer-events:none;font-size:8px;font-weight:800;letter-spacing:.14em}\n  .scope-tags span{position:absolute;color:#5e7686;text-shadow:0 0 5px rgba(122,208,255,.4)}\n  .scope-tags .lp{left:8px;bottom:6px}\n  .scope-tags .ntc{left:50%;transform:translateX(-50%);bottom:6px}\n  .scope-tags .hp{right:8px;bottom:6px}\n  .scope-tags .modeName{top:7px;left:8px;color:var(--acc);font-size:10px;letter-spacing:.18em;\n    text-shadow:0 0 7px rgba(232,194,122,.7)}\n\n  /* the dial itself */\n  .dialBox{display:flex;align-items:center;gap:14px;margin-top:13px}\n  .bigdial{position:relative;width:108px;height:108px;cursor:ns-resize;touch-action:none;flex:0 0 auto}\n  .bigdial svg{display:block;width:108px;height:108px;overflow:visible}\n  .bigdial .cap{filter:drop-shadow(0 4px 6px rgba(0,0,0,.6))}\n  .bigdial:hover .bigGlow,.bigdial.dragging .bigGlow{opacity:1}\n  .bigGlow{transition:opacity .25s;opacity:.4}\n  .modeMeta{flex:1;display:flex;flex-direction:column;gap:6px}\n  .modeMeta .ml{font-size:9px;letter-spacing:.3em;color:#7fd0ff;font-weight:800;text-transform:uppercase}\n  .modeMeta .mv{font-size:22px;font-weight:800;color:#f2e6cf;letter-spacing:.02em;\n    text-shadow:0 0 9px rgba(232,194,122,.45)}\n  .modeMeta .mdesc{font-size:9px;color:#9bb6c6;letter-spacing:.05em;line-height:1.35}\n  .modeMeta .mhint{font-size:7.5px;color:#5d6f7c;letter-spacing:.12em;margin-top:2px}\n\n  /* --- knob rack (the smaller controls) --- */\n  .rack{flex:1;display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:1fr;gap:10px 6px;\n    padding:8px 6px;border-radius:13px;\n    background:linear-gradient(180deg,rgba(255,253,247,.55),rgba(206,191,156,.4));\n    box-shadow:0 1px 0 rgba(255,255,255,.6) inset,0 -2px 5px rgba(120,95,55,.18) inset,0 0 0 1px rgba(120,95,55,.25);}\n  .cell{display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px}\n  .label{font-size:8px;letter-spacing:.16em;text-transform:uppercase;color:#5b4a2a;font-weight:800;\n    text-shadow:0 1px 0 rgba(255,255,255,.6)}\n  .knob{position:relative;width:58px;height:58px;cursor:ns-resize;touch-action:none}\n  .knob svg{display:block;width:58px;height:58px;overflow:visible}\n  .knob .cap{filter:drop-shadow(0 3px 4px rgba(0,0,0,.45))}\n  .knob:hover .ringGlow,.knob.dragging .ringGlow{opacity:1}\n  .ringGlow{transition:opacity .2s;opacity:.3}\n  .vbox{font-size:9.5px;font-weight:800;color:#2a2014;\n    background:linear-gradient(180deg,#f6e8c6,#e3cf9c);\n    border:1px solid #a8916a;border-radius:4px;padding:1px 7px;min-width:44px;text-align:center;\n    box-shadow:0 1px 0 rgba(255,255,255,.6) inset,0 1px 2px rgba(80,55,20,.25);}\n\n  .credit{position:absolute;bottom:7px;left:50%;transform:translateX(-50%);font-size:7px;letter-spacing:.36em;\n    color:#7a6537;font-weight:800;text-shadow:0 1px 0 rgba(255,255,255,.5)}\n</style>\n</head>\n<body>\n  <div class=\"panel\" id=\"panel\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <span class=\"sub\">multimode &middot; state-variable voice</span>\n        <span class=\"name\">Sem<b>Voice</b></span>\n      </div>\n      <div class=\"badge\">\n        <span class=\"chip\">DUO &middot; 2 VOICE</span>\n        <span class=\"voices\">12&nbsp;dB/OCT &middot; SVF</span>\n      </div>\n    </div>\n\n    <div class=\"stage\">\n      <!-- big morph dial + filter response window -->\n      <div class=\"morph\">\n        <div class=\"scopeWrap\">\n          <canvas id=\"scope\" width=\"604\" height=\"300\"></canvas>\n          <div class=\"scope-grid\"></div>\n          <div class=\"scope-glass\"></div>\n          <div class=\"scope-tags\">\n            <span class=\"modeName\" id=\"modeName\">LOW&middot;PASS</span>\n            <span class=\"lp\">LP</span><span class=\"ntc\">NOTCH</span><span class=\"hp\">HP</span>\n          </div>\n        </div>\n        <div class=\"dialBox\">\n          <div class=\"bigdial\" id=\"bigdial\" title=\"MODE &mdash; drag to morph LP &rarr; notch &rarr; HP &middot; double-click resets\"></div>\n          <div class=\"modeMeta\">\n            <span class=\"ml\">Mode</span>\n            <span class=\"mv\" id=\"modeVal\">LP</span>\n            <span class=\"mdesc\" id=\"modeDesc\">low-pass &mdash; warm and round</span>\n            <span class=\"mhint\">drag &middot; dbl-click resets</span>\n          </div>\n        </div>\n      </div>\n\n      <!-- knob rack -->\n      <div class=\"rack\" id=\"rack\"></div>\n    </div>\n\n    <div class=\"credit\">SEM VOICE &middot; AMERICAN MONO</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  var ACC=\"#e8c27a\", ACC2=\"#7ad0ff\";\n  // ---- params straight from spec.json ----\n  var PARAMS=[\n    {name:\"Mode\",       index:0, min:0, max:1, def:0.00, fmt:\"mode\"},\n    {name:\"Cutoff\",     index:1, min:0, max:1, def:0.45, fmt:\"hz\"},\n    {name:\"Resonance\",  index:2, min:0, max:1, def:0.45, fmt:\"pct\"},\n    {name:\"Env Amount\", index:3, min:0, max:1, def:0.60, fmt:\"pct\"},\n    {name:\"Detune\",     index:4, min:0, max:1, def:0.35, fmt:\"cent\"},\n    {name:\"Decay\",      index:5, min:0, max:1, def:0.50, fmt:\"ms\"},\n    {name:\"Level\",      index:6, min:0, max:1, def:0.80, fmt:\"pct\"}\n  ];\n  // smaller knobs shown in the rack (Mode handled by the big dial)\n  var RACK=[1,2,3,4,5,6];\n\n  function clamp(v,a,b){return v<a?a:v>b?b:v;}\n  function norm(p,v){return (v-p.min)/(p.max-p.min);}\n  function fmtVal(p,v){\n    var n=norm(p,v);\n    if(p.fmt===\"pct\")  return Math.round(n*100)+\"%\";\n    if(p.fmt===\"hz\"){ var hz=90*Math.exp(n*4.71); return hz<1000?Math.round(hz)+\"Hz\":(hz/1000).toFixed(1)+\"k\"; }\n    if(p.fmt===\"ms\")  return Math.round(40+n*n*1360)+\"ms\";\n    if(p.fmt===\"cent\")return \"+\"+Math.round(n*24)+\"¢\";\n    if(p.fmt===\"mode\")return modeLabel(n).short;\n    return n.toFixed(2);\n  }\n  function modeLabel(n){\n    if(n<0.04) return {short:\"LP\",  name:\"LOW·PASS\",  desc:\"low-pass — warm and round\"};\n    if(n<0.46) return {short:Math.round(n*100)+\"%\", name:\"LP → NOTCH\", desc:\"low-pass thinning toward the notch\"};\n    if(n<0.54) return {short:\"NOTCH\", name:\"NOTCH\", desc:\"notch — hollow, vocal scoop\"};\n    if(n<0.96) return {short:Math.round(n*100)+\"%\", name:\"NOTCH → HP\", desc:\"opening up into high-pass\"};\n    return {short:\"HP\", name:\"HIGH·PASS\", desc:\"high-pass — thin and airy\"};\n  }\n\n  // live shared state\n  var STATE={};\n  PARAMS.forEach(function(p){STATE[p.index]=p.def;});\n\n  var host=window.vstai||null;\n  function send(i,v){ if(host&&host.setParam) host.setParam(i,v); }\n\n  var ns=\"http://www.w3.org/2000/svg\";\n\n  // ============ shared SVG defs ============\n  function ensureDefs(svg){\n    if(document.getElementById(\"kdefs\")) return;\n    var defs=document.createElementNS(ns,\"defs\"); defs.setAttribute(\"id\",\"kdefs\");\n    defs.innerHTML=\n      '<radialGradient id=\"cap\" cx=\"36%\" cy=\"28%\" r=\"82%\">'+\n        '<stop offset=\"0%\" stop-color=\"#eef2f6\"/><stop offset=\"42%\" stop-color=\"#aab3bb\"/>'+\n        '<stop offset=\"100%\" stop-color=\"#3b4248\"/></radialGradient>'+\n      '<radialGradient id=\"capBig\" cx=\"36%\" cy=\"26%\" r=\"84%\">'+\n        '<stop offset=\"0%\" stop-color=\"#fbfdff\"/><stop offset=\"38%\" stop-color=\"#c4ccd3\"/>'+\n        '<stop offset=\"72%\" stop-color=\"#7a838b\"/><stop offset=\"100%\" stop-color=\"#2c3236\"/></radialGradient>'+\n      '<linearGradient id=\"grad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n        '<stop offset=\"0%\" stop-color=\"'+ACC2+'\"/><stop offset=\"100%\" stop-color=\"'+ACC+'\"/></linearGradient>'+\n      '<linearGradient id=\"gradBig\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n        '<stop offset=\"0%\" stop-color=\"'+ACC2+'\"/><stop offset=\"50%\" stop-color=\"#cfe6f2\"/><stop offset=\"100%\" stop-color=\"'+ACC+'\"/></linearGradient>'+\n      '<filter id=\"blur\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\"><feGaussianBlur stdDeviation=\"2.6\"/></filter>'+\n      '<filter id=\"nglow\" x=\"-90%\" y=\"-90%\" width=\"280%\" height=\"280%\"><feGaussianBlur stdDeviation=\"1.2\" result=\"b\"/>'+\n        '<feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>';\n    svg.appendChild(defs);\n  }\n\n  // arc helpers\n  function pt(cx,cy,deg,rr){var a=(deg-90)*Math.PI/180;return [cx+Math.cos(a)*rr, cy+Math.sin(a)*rr];}\n  function arc(cx,cy,a0,a1,rr){\n    var s=pt(cx,cy,a0,rr),e=pt(cx,cy,a1,rr),large=(a1-a0)>180?1:0;\n    return \"M\"+s[0]+\" \"+s[1]+\" A\"+rr+\" \"+rr+\" 0 \"+large+\" 1 \"+e[0]+\" \"+e[1];\n  }\n\n  // ============ generic dial builder ============\n  function makeDial(host,p,opts){\n    opts=opts||{};\n    var SIZE=opts.size||58, CX=SIZE/2, CY=SIZE/2+1, R=opts.r||(SIZE*0.40);\n    var SW=opts.sweep||272, start=-(SW/2), end=(SW/2);\n    var capR=opts.capR||(SIZE*0.27);\n    var capGrad=opts.big?\"url(#capBig)\":\"url(#cap)\";\n    var valGrad=opts.big?\"url(#gradBig)\":\"url(#grad)\";\n    var sw=opts.big?5:3.4;\n\n    var svg=document.createElementNS(ns,\"svg\"); svg.setAttribute(\"viewBox\",\"0 0 \"+SIZE+\" \"+SIZE);\n    ensureDefs(svg);\n\n    var glow=document.createElementNS(ns,\"path\"); glow.setAttribute(\"class\",opts.big?\"bigGlow\":\"ringGlow\");\n    glow.setAttribute(\"d\",arc(CX,CY,start,end,R+4)); glow.setAttribute(\"fill\",\"none\");\n    glow.setAttribute(\"stroke\",ACC2); glow.setAttribute(\"stroke-width\",opts.big?3:2);\n    glow.setAttribute(\"stroke-linecap\",\"round\"); glow.setAttribute(\"filter\",\"url(#blur)\"); svg.appendChild(glow);\n\n    var track=document.createElementNS(ns,\"path\");\n    track.setAttribute(\"d\",arc(CX,CY,start,end,R)); track.setAttribute(\"fill\",\"none\");\n    track.setAttribute(\"stroke\",\"#11151a\"); track.setAttribute(\"stroke-width\",sw);\n    track.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(track);\n\n    var val=document.createElementNS(ns,\"path\"); val.setAttribute(\"fill\",\"none\");\n    val.setAttribute(\"stroke\",valGrad); val.setAttribute(\"stroke-width\",sw);\n    val.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(val);\n\n    // tick marks for the big dial (LP / NOTCH / HP)\n    if(opts.big){\n      [start,0,end].forEach(function(d){\n        var a=document.createElementNS(ns,\"line\");\n        var i1=pt(CX,CY,d,R+7),o1=pt(CX,CY,d,R+11);\n        a.setAttribute(\"x1\",i1[0]);a.setAttribute(\"y1\",i1[1]);\n        a.setAttribute(\"x2\",o1[0]);a.setAttribute(\"y2\",o1[1]);\n        a.setAttribute(\"stroke\",\"#9bb6c6\");a.setAttribute(\"stroke-width\",\"1.4\");a.setAttribute(\"stroke-linecap\",\"round\");\n        svg.appendChild(a);\n      });\n    }\n\n    var cap=document.createElementNS(ns,\"circle\"); cap.setAttribute(\"class\",\"cap\");\n    cap.setAttribute(\"cx\",CX); cap.setAttribute(\"cy\",CY); cap.setAttribute(\"r\",capR);\n    cap.setAttribute(\"fill\",capGrad); cap.setAttribute(\"stroke\",\"#23282b\"); cap.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(cap);\n    var rim=document.createElementNS(ns,\"circle\");\n    rim.setAttribute(\"cx\",CX); rim.setAttribute(\"cy\",CY); rim.setAttribute(\"r\",capR);\n    rim.setAttribute(\"fill\",\"none\"); rim.setAttribute(\"stroke\",\"rgba(255,255,255,.22)\"); rim.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(rim);\n\n    var notch=document.createElementNS(ns,\"line\");\n    notch.setAttribute(\"stroke\",ACC); notch.setAttribute(\"stroke-width\",opts.big?3.4:2.6);\n    notch.setAttribute(\"stroke-linecap\",\"round\"); notch.setAttribute(\"filter\",\"url(#nglow)\"); svg.appendChild(notch);\n\n    host.appendChild(svg);\n\n    var cur=p.def;\n    function render(){\n      var nn=norm(p,cur);\n      var ang=start+nn*(end-start);\n      val.setAttribute(\"d\", arc(CX,CY,start, nn<=0.0001?start+0.001:ang, R));\n      glow.setAttribute(\"d\", arc(CX,CY,start, nn<=0.0001?start+0.001:ang, R+4));\n      var inr=pt(CX,CY,ang,capR*0.34), outr=pt(CX,CY,ang,capR*0.92);\n      notch.setAttribute(\"x1\",inr[0]); notch.setAttribute(\"y1\",inr[1]);\n      notch.setAttribute(\"x2\",outr[0]); notch.setAttribute(\"y2\",outr[1]);\n      STATE[p.index]=cur;\n      if(opts.onRender) opts.onRender(cur,nn);\n    }\n    function setVal(v,push){ cur=clamp(v,p.min,p.max); render(); if(push) send(p.index,cur); }\n    render();\n\n    var dragging=false,startY=0,startV=0;\n    function onMove(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=startY-y, span=p.max-p.min, fine=e.shiftKey?0.25:1;\n      setVal(startV+dy/200*span*fine,true); e.preventDefault();\n    }\n    function onUp(){ if(!dragging)return; dragging=false; host.classList.remove(\"dragging\");\n      window.removeEventListener(\"pointermove\",onMove); window.removeEventListener(\"pointerup\",onUp); }\n    host.addEventListener(\"pointerdown\",function(e){\n      dragging=true; host.classList.add(\"dragging\"); startY=e.clientY; startV=cur;\n      window.addEventListener(\"pointermove\",onMove); window.addEventListener(\"pointerup\",onUp); e.preventDefault();\n    });\n    host.addEventListener(\"dblclick\",function(e){ setVal(p.def,true); e.preventDefault(); });\n    host.addEventListener(\"wheel\",function(e){\n      setVal(cur-Math.sign(e.deltaY)*(p.max-p.min)*0.02,true); e.preventDefault();\n    },{passive:false});\n\n    return {set:setVal,get:function(){return cur;}};\n  }\n\n  // ============ big MODE dial ============\n  var modeValEl=document.getElementById(\"modeVal\");\n  var modeDescEl=document.getElementById(\"modeDesc\");\n  var modeNameEl=document.getElementById(\"modeName\");\n  var bigdial=document.getElementById(\"bigdial\");\n  var modeP=PARAMS[0];\n  var modeKnob=makeDial(bigdial,modeP,{size:108,r:43,capR:30,sweep:272,big:true,\n    onRender:function(v,nn){\n      var L=modeLabel(nn);\n      modeValEl.textContent=L.short;\n      modeDescEl.textContent=L.desc;\n      modeNameEl.textContent=L.name;\n    }});\n\n  // ============ rack knobs ============\n  var rack=document.getElementById(\"rack\");\n  var knobs={};\n  RACK.forEach(function(idx){\n    var p=PARAMS[idx];\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var lab=document.createElement(\"div\"); lab.className=\"label\"; lab.textContent=p.name;\n    var kd=document.createElement(\"div\"); kd.className=\"knob\"; kd.title=p.name+\" — drag · dbl-click resets\";\n    var vbox=document.createElement(\"div\"); vbox.className=\"vbox\";\n    cell.appendChild(lab); cell.appendChild(kd); cell.appendChild(vbox); rack.appendChild(cell);\n    var k=makeDial(kd,p,{size:58,r:23,capR:15.5,sweep:272,onRender:function(v){ vbox.textContent=fmtVal(p,v); }});\n    vbox.textContent=fmtVal(p,p.def);\n    knobs[idx]=k;\n  });\n\n  // ============ live filter-response curve ============\n  var scope=document.getElementById(\"scope\");\n  var sctx=scope.getContext(\"2d\");\n  var W=scope.width, H=scope.height;\n  var t0=performance.now(), tAcc=0;\n\n  // map log-frequency 0..1 across width; magnitude 0..1 up the height\n  function svfMag(fNorm, fcNorm, q, mode){\n    // model a 2-pole SVF: lp/bp/hp magnitudes at ratio r = f/fc\n    var r=Math.pow(10,(fNorm-fcNorm)*2.2); // decade ratio\n    var d=q;                                // damping 0..2 (we pass 0.1..2)\n    // |H| for 2nd-order, normalized; classic biquad-ish forms\n    var denom=Math.sqrt(Math.pow(1-r*r,2)+Math.pow(d*r,2));\n    var lp=1/denom;\n    var hp=(r*r)/denom;\n    var bp=(d*r)/denom;\n    // Mode morph: 0 LP -> 0.5 notch(lp+hp) -> 1 HP, with bp honk near notch\n    var wLp,wHp;\n    if(mode<=0.5){ wLp=1; wHp=mode*2; } else { wLp=1-(mode-0.5)*2; wHp=1; }\n    var bpMid=1-Math.abs(mode-0.5)*2;\n    var wBp=bpMid*(0.15+(2-d)/1.85*0.45);\n    return lp*wLp+hp*wHp+bp*wBp;\n  }\n\n  function draw(now){\n    var dt=(now-t0)/1000; t0=now; tAcc+=dt;\n    var mode=STATE[0], cut=STATE[1], reso=STATE[2], envm=STATE[3], dec=STATE[5];\n    var q=2-reso*1.85; // matches DSP damping\n    // animated sweep: the filter env opens cutoff and breathes\n    var breath=0.5+0.5*Math.sin(tAcc*(0.7+(1-dec)*1.4));\n    var fcNorm=clamp(cut+envm*0.30*breath,0.02,0.98);\n\n    sctx.clearRect(0,0,W,H);\n\n    // baseline 0 dB grid line\n    sctx.strokeStyle=\"rgba(122,208,255,.10)\"; sctx.lineWidth=1;\n    sctx.beginPath(); sctx.moveTo(0,H*0.5); sctx.lineTo(W,H*0.5); sctx.stroke();\n\n    // cutoff marker (vertical), glides with the breathing sweep\n    var mx=fcNorm*W;\n    sctx.strokeStyle=\"rgba(232,194,122,.30)\"; sctx.lineWidth=2;\n    sctx.beginPath(); sctx.moveTo(mx,0); sctx.lineTo(mx,H); sctx.stroke();\n\n    // ---- the response curve ----\n    var grad=sctx.createLinearGradient(0,0,W,0);\n    grad.addColorStop(0,ACC2); grad.addColorStop(0.5,\"#cfe6f2\"); grad.addColorStop(1,ACC);\n\n    // filled area under curve\n    sctx.beginPath();\n    var first=true, pts=[];\n    for(var x=0;x<=W;x+=3){\n      var fN=x/W;\n      var mag=svfMag(fN,fcNorm,q,mode);\n      mag=mag/(1+mag*0.55);               // gentle compression so peaks stay on-screen\n      var y=H-(0.10+mag*0.80)*H;\n      pts.push([x,y]);\n      if(first){ sctx.moveTo(x,y); first=false; } else sctx.lineTo(x,y);\n    }\n    sctx.lineTo(W,H); sctx.lineTo(0,H); sctx.closePath();\n    var fill=sctx.createLinearGradient(0,0,0,H);\n    fill.addColorStop(0,\"rgba(232,194,122,.22)\");\n    fill.addColorStop(1,\"rgba(122,208,255,.02)\");\n    sctx.fillStyle=fill; sctx.fill();\n\n    // stroke curve glowing\n    sctx.beginPath();\n    for(var i=0;i<pts.length;i++){ if(i===0) sctx.moveTo(pts[i][0],pts[i][1]); else sctx.lineTo(pts[i][0],pts[i][1]); }\n    sctx.lineWidth=3; sctx.strokeStyle=grad;\n    sctx.shadowColor=ACC; sctx.shadowBlur=10; sctx.stroke(); sctx.shadowBlur=0;\n\n    // a notch dimple highlight: when in notch zone, mark the dip\n    if(mode>0.30&&mode<0.70){\n      var dipX=fcNorm*W, dipMag=svfMag(fcNorm,fcNorm,q,mode);\n      dipMag=dipMag/(1+dipMag*0.55);\n      var dipY=H-(0.10+dipMag*0.80)*H;\n      sctx.fillStyle=\"rgba(122,208,255,\"+(0.5*(1-Math.abs(mode-0.5)*2)+0.2)+\")\";\n      sctx.beginPath(); sctx.arc(dipX,dipY,3.5,0,7); sctx.fill();\n    }\n\n    requestAnimationFrame(draw);\n  }\n  requestAnimationFrame(draw);\n\n  // ============ host wiring ============\n  function ready(){\n    send(modeP.index, modeKnob.get());\n    RACK.forEach(function(idx){ send(PARAMS[idx].index, knobs[idx].get()); });\n  }\n  if(host&&host.onReady) host.onReady(ready); else ready();\n\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SEM VOICE — an SEM-lineage mono/duo synth INSTRUMENT\n//  Two oscillators (a saw and a variable pulse) detuned against each\n//  other feed a 12 dB/oct STATE-VARIABLE FILTER whose response MORPHS\n//  continuously from low-pass through a NOTCH to high-pass via the Mode\n//  control. The filter has resonance and its own decay envelope; that\n//  smooth LP -> notch -> HP sweep is the signature voice. Pure algorithm.\n//\n//  Signal path (2 voices, duophonic, last-two-note priority):\n//    osc1 saw + osc2 pulse (detuned) -> 12 dB state-variable filter\n//    (LP/BP/HP blended by Mode) -> amp env -> level\n//  The SVF cutoff = base cutoff + EnvAmount * filterEnv (its own decay).\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32  = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_MODE:   i32 = 0; // 0..1 : LP(0) -> notch(0.5) -> HP(1) morph\nconst P_CUTOFF: i32 = 1; // 0..1 : base cutoff\nconst P_RESO:   i32 = 2; // 0..1 : resonance\nconst P_ENV:    i32 = 3; // 0..1 : filter envelope amount\nconst P_DETUNE: i32 = 4; // 0..1 : osc2 detune + pulse character\nconst P_DECAY:  i32 = 5; // 0..1 : amp + filter decay time\nconst P_LEVEL:  i32 = 6; // 0..1 : output level\n\n// ---- two voices (duophonic) ----\nconst NV: i32 = 2;\nconst vNote:  StaticArray<i32> = new StaticArray<i32>(NV); // note id (-1 = free)\nconst vGate:  StaticArray<i32> = new StaticArray<i32>(NV);\nconst vFreq:  StaticArray<f32> = new StaticArray<f32>(NV);\nconst vPh1:   StaticArray<f32> = new StaticArray<f32>(NV); // saw phase\nconst vPh2:   StaticArray<f32> = new StaticArray<f32>(NV); // pulse phase\nconst vAEnv:  StaticArray<f32> = new StaticArray<f32>(NV); // amp env\nconst vFEnv:  StaticArray<f32> = new StaticArray<f32>(NV); // filter env\n// per-voice state-variable filter state\nconst vLp:    StaticArray<f32> = new StaticArray<f32>(NV);\nconst vBp:    StaticArray<f32> = new StaticArray<f32>(NV);\n\nlet voiceRR: i32 = 0; // round-robin allocator\n\n// gentle DC blocker on the master output\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NV; v++) {\n    vNote[v] = -1; vGate[v] = 0; vFreq[v] = 0.0;\n    vPh1[v] = 0.0; vPh2[v] = 0.0; vAEnv[v] = 0.0; vFEnv[v] = 0.0;\n    vLp[v] = 0.0; vBp[v] = 0.0;\n  }\n  voiceRR = 0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_MODE]   = 0.0;   // start fully low-pass\n  params[P_CUTOFF] = 0.45;\n  params[P_RESO]   = 0.45;\n  params[P_ENV]    = 0.6;\n  params[P_DETUNE] = 0.35;\n  params[P_DECAY]  = 0.5;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// soft saturator: bounded, smooth, cheap (tames resonance, adds SEM growl)\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// Host passes frequency in Hz. Duophonic with round-robin / last-note steal.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const freq: f32 = f > 0.0 ? f : 0.0001;\n  // prefer a free voice\n  let slot: i32 = -1;\n  for (let i = 0; i < NV; i++) { if (vGate[i] == 0) { slot = i; break; } }\n  if (slot < 0) { slot = voiceRR; voiceRR = (voiceRR + 1) % NV; }\n  vNote[slot] = id;\n  vFreq[slot] = freq;\n  vGate[slot] = 1;\n  vAEnv[slot] = 1.0;   // retrigger amp env (slight click avoided by smoothing)\n  vFEnv[slot] = 1.0;   // retrigger filter env\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NV; i++) {\n    if (vNote[i] == id && vGate[i] != 0) { vGate[i] = 0; vNote[i] = -1; }\n  }\n}\n\nexport function process(n: i32): void {\n  const modeN:   f32 = clampf(params[P_MODE],   0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN:   f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envN:    f32 = clampf(params[P_ENV],    0.0, 1.0);\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const decayN:  f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // ---- Mode morph: LP -> notch -> HP via three blend weights ----\n  // 0.0 = pure LP, 0.5 = notch (LP+HP, no BP), 1.0 = pure HP.\n  // We synthesise notch = lp + hp; band-pass = bp output of the SVF.\n  let wLp: f32; let wHp: f32; let wBp: f32;\n  if (modeN <= 0.5) {\n    // LP -> notch : fade in HP, keep a little BP early for vocal body\n    const t: f32 = modeN * 2.0;            // 0..1\n    wLp = 1.0;\n    wHp = t;\n    wBp = (1.0 - t) * 0.0;                  // BP not used on this side\n  } else {\n    // notch -> HP : fade out LP\n    const t: f32 = (modeN - 0.5) * 2.0;     // 0..1\n    wLp = 1.0 - t;\n    wHp = 1.0;\n    wBp = 0.0;\n  }\n  // tiny BP injection scaled by resonance gives the throaty SEM mid honk,\n  // strongest in the middle (notch) region; purely additive, bounded.\n  const bpMid: f32 = (1.0 - f32(Mathf.abs(modeN - 0.5)) * 2.0); // 1 at notch, 0 at extremes\n  wBp = bpMid * (0.15 + resoN * 0.45);\n\n  // ---- filter-envelope decay: ~40 ms .. ~1.4 s ----\n  const fdecaySec: f32 = 0.04 + decayN * decayN * 1.36;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n  // amp envelope: a touch longer so notes ring out musically\n  const adecaySec: f32 = 0.08 + decayN * decayN * 1.9;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n  // sustain floor while gated (so a held note keeps body); decay rules release\n  const sustain: f32 = 0.55 + decayN * 0.35; // longer decay -> higher sustain\n\n  // ---- base cutoff (exponential, musical): ~90 Hz .. ~10 kHz ----\n  const baseCut: f32 = f32(90.0 * Mathf.exp(cutoffN * 4.71));\n  const sweepSpan: f32 = envN * 9000.0; // Hz added by filter env\n\n  // resonance -> SVF damping (q). higher reso = lower damping = sharper peak.\n  const q: f32 = 2.0 - resoN * 1.85;     // 2.0 (flat) .. 0.15 (sharp)\n\n  // osc2 detune: up to ~ +/- 16 cents-ish plus a slow body; pulse width too.\n  const detRatio: f32 = 1.0 + detuneN * 0.020;        // up to +2%\n  const pulseW: f32 = 0.5 - detuneN * 0.32;           // PWM: 0.5 -> ~0.18\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    let mixL: f32 = 0.0;\n\n    for (let v = 0; v < NV; v++) {\n      // skip fully-dead voices\n      if (vGate[v] == 0 && vAEnv[v] < 0.0003) { continue; }\n\n      // ---- envelopes ----\n      vFEnv[v] *= fenvCoef;\n      if (vGate[v] != 0) {\n        // amp settles toward sustain while held\n        vAEnv[v] = sustain + (vAEnv[v] - sustain) * aenvCoef;\n      } else {\n        vAEnv[v] *= aenvCoef;\n      }\n\n      const f0: f32 = vFreq[v];\n\n      // ---- oscillators ----\n      let inc1: f32 = f0 / sampleRate;\n      if (inc1 < 0.0) inc1 = 0.0; if (inc1 > 0.5) inc1 = 0.5;\n      let inc2: f32 = (f0 * detRatio) / sampleRate;\n      if (inc2 < 0.0) inc2 = 0.0; if (inc2 > 0.5) inc2 = 0.5;\n\n      vPh1[v] += inc1; if (vPh1[v] >= 1.0) vPh1[v] -= 1.0;\n      vPh2[v] += inc2; if (vPh2[v] >= 1.0) vPh2[v] -= 1.0;\n\n      const saw: f32 = vPh1[v] * 2.0 - 1.0;             // osc1 saw\n      const pulse: f32 = vPh2[v] < pulseW ? 1.0 : -1.0; // osc2 variable pulse\n      // mix the two oscillators; detune also raises osc2's presence\n      let osc: f32 = saw * 0.62 + pulse * (0.38 + detuneN * 0.10);\n\n      // ---- per-voice cutoff for this sample ----\n      let cutHz: f32 = baseCut + sweepSpan * vFEnv[v];\n      if (cutHz < 20.0) cutHz = 20.0;\n      if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n      // ---- 12 dB Chamberlin state-variable filter ----\n      // g = 2*sin(pi*fc/fs); keep stable.\n      let g: f32 = f32(2.0 * Mathf.sin(PI * cutHz / sampleRate));\n      if (g > 1.0) g = 1.0;\n\n      let lp: f32 = vLp[v];\n      let bp: f32 = vBp[v];\n      // one pass\n      const hp: f32 = osc - lp - q * bp;\n      bp = bp + g * hp;\n      lp = lp + g * bp;\n      vLp[v] = lp;\n      vBp[v] = bp;\n\n      // ---- Mode morph blend of the three outputs ----\n      // notch = lp + hp ; here we weight lp / hp / bp directly.\n      let filt: f32 = lp * wLp + hp * wHp + bp * wBp;\n      // saturate for analog warmth and to bound resonance\n      filt = satf(filt * 0.9);\n\n      mixL += filt * vAEnv[v];\n    }\n\n    // ---- master ----\n    let s: f32 = mixL * 0.55;            // headroom for 2 voices\n\n    // DC blocker\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s; dcY = y; s = y;\n\n    // level + soft safety\n    s = satf(s * (0.6 + level * 0.9));\n    s *= 0.9;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000104000
}