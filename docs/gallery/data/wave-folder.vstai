{
  "format": 1,
  "name": "Wave Folder",
  "isInstrument": false,
  "explanation": "A west-coast style wavefolder: it drives the signal hard so its peaks fold back on themselves through reflective triangle and sine folds, spawning dense, metallic harmonics instead of flat clipping. Fold sets how many times the wave folds, Symmetry biases the fold axis for even harmonics, and Tone, Output and Mix shape the result.",
  "params": [
    {
      "name": "Fold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Symmetry",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Output",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Wave Folder</title>\n<style>\n  :root {\n    --accent:   #c08cff;\n    --accent2:  #ff8cf0;\n    --panel:    #1a1622;\n    --panel-2:  #221b2e;\n    --metal:    #2a2336;\n    --ink:      #efe7ff;\n    --ink-dim:  #9a8fb5;\n    --jack:     #d9b85a;\n    --jack-rim: #6f5a1f;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: #0c0a12;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  #app {\n    max-width: 720px;\n    margin: 0 auto;\n    padding: 18px 16px 26px;\n  }\n\n  /* ---- the modular panel ---- */\n  .panel {\n    position: relative;\n    border-radius: 16px;\n    padding: 18px 18px 22px;\n    background:\n      radial-gradient(120% 90% at 12% -10%, rgba(192,140,255,0.16), transparent 60%),\n      radial-gradient(120% 90% at 95% 0%, rgba(255,140,240,0.12), transparent 55%),\n      linear-gradient(180deg, var(--panel-2), var(--panel));\n    border: 1px solid rgba(192,140,255,0.22);\n    box-shadow:\n      0 24px 60px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.06),\n      inset 0 -2px 14px rgba(0,0,0,0.5);\n  }\n\n  /* mounting screws at the corners (modular vibe) */\n  .screw {\n    position: absolute;\n    width: 12px; height: 12px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #4a4256, #1a1622 70%);\n    box-shadow: inset 0 1px 1px rgba(255,255,255,0.18), inset 0 -1px 2px #000;\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute;\n    top: 50%; left: 50%;\n    width: 8px; height: 1.5px;\n    background: #0d0a13;\n    transform: translate(-50%,-50%) rotate(35deg);\n    border-radius: 1px;\n  }\n  .screw.tl { top: 8px;  left: 8px; }\n  .screw.tr { top: 8px;  right: 8px; }\n  .screw.bl { bottom: 8px; left: 8px; }\n  .screw.br { bottom: 8px; right: 8px; }\n\n  header {\n    display: flex;\n    align-items: baseline;\n    justify-content: space-between;\n    padding: 2px 6px 12px;\n  }\n  .brand {\n    display: flex;\n    flex-direction: column;\n    gap: 2px;\n  }\n  .brand .kind {\n    font-size: 10px;\n    letter-spacing: 0.36em;\n    text-transform: uppercase;\n    color: var(--accent);\n  }\n  .brand h1 {\n    margin: 0;\n    font-size: 26px;\n    font-weight: 800;\n    letter-spacing: 0.02em;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .modnum {\n    font-size: 10px;\n    letter-spacing: 0.28em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: right;\n    line-height: 1.5;\n  }\n\n  /* ---- the folding scope ---- */\n  .scope-wrap {\n    position: relative;\n    border-radius: 12px;\n    padding: 10px;\n    background: linear-gradient(180deg, #0a0810, #120e1a);\n    border: 1px solid rgba(192,140,255,0.18);\n    box-shadow: inset 0 2px 18px rgba(0,0,0,0.8), inset 0 0 40px rgba(192,140,255,0.05);\n    margin: 0 6px 18px;\n  }\n  .scope-wrap svg { display: block; width: 100%; height: 132px; }\n  .grid line { stroke: rgba(192,140,255,0.10); stroke-width: 1; }\n  .axis { stroke: rgba(192,140,255,0.22); stroke-width: 1; }\n\n  /* ---- control rack ---- */\n  .rack {\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 8px;\n    padding: 4px 6px 0;\n  }\n  @media (max-width: 560px) {\n    .rack { grid-template-columns: repeat(3, 1fr); }\n  }\n\n  .mod {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    padding: 12px 6px 14px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, var(--metal), #1c1726);\n    border: 1px solid rgba(255,255,255,0.05);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 6px 14px rgba(0,0,0,0.4);\n  }\n  .mod .label {\n    font-size: 10px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .mod .value {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    background: rgba(0,0,0,0.4);\n    padding: 2px 8px;\n    border-radius: 6px;\n    min-width: 52px;\n    text-align: center;\n    border: 1px solid rgba(192,140,255,0.16);\n  }\n\n  .knob {\n    width: 72px; height: 72px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob:hover .arc-live { stroke: var(--accent2); }\n\n  /* banana jacks */\n  .jacks {\n    display: flex;\n    gap: 14px;\n    justify-content: center;\n    padding: 12px 0 0;\n    margin-top: 4px;\n  }\n  .jack {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 5px;\n  }\n  .jack .hole {\n    width: 22px; height: 22px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 40% 35%, var(--jack), #8a6f23 70%, #3a2e0e);\n    border: 2px solid var(--jack-rim);\n    box-shadow: inset 0 -2px 4px rgba(0,0,0,0.6), 0 0 0 3px rgba(217,184,90,0.08);\n    position: relative;\n  }\n  .jack .hole::after {\n    content: \"\";\n    position: absolute;\n    inset: 6px;\n    border-radius: 50%;\n    background: radial-gradient(circle, #0c0a12, #2a2210);\n  }\n  .jack.in .hole { background: radial-gradient(circle at 40% 35%, var(--accent), #6a4aa0 70%, #2a1e44); border-color:#3a2a5e; }\n  .jack.out .hole { background: radial-gradient(circle at 40% 35%, var(--accent2), #a04a90 70%, #44183c); border-color:#5e2a52; }\n  .jack span {\n    font-size: 9px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .footer {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 14px 8px 0;\n  }\n</style>\n</head>\n<body>\n<div id=\"app\">\n  <div class=\"panel\">\n    <div class=\"screw tl\"></div><div class=\"screw tr\"></div>\n    <div class=\"screw bl\"></div><div class=\"screw br\"></div>\n\n    <header>\n      <div class=\"brand\">\n        <div class=\"kind\">West-Coast Wavefolder</div>\n        <h1>Wave Folder</h1>\n      </div>\n      <div class=\"modnum\">MOD&nbsp;281<br>FOLD&nbsp;ENGINE</div>\n    </header>\n\n    <div class=\"scope-wrap\">\n      <svg viewBox=\"0 0 600 132\" preserveAspectRatio=\"none\" aria-hidden=\"true\">\n        <g class=\"grid\">\n          <line x1=\"0\" y1=\"33\" x2=\"600\" y2=\"33\"/>\n          <line x1=\"0\" y1=\"99\" x2=\"600\" y2=\"99\"/>\n          <line x1=\"150\" y1=\"0\" x2=\"150\" y2=\"132\"/>\n          <line x1=\"300\" y1=\"0\" x2=\"300\" y2=\"132\"/>\n          <line x1=\"450\" y1=\"0\" x2=\"450\" y2=\"132\"/>\n        </g>\n        <line class=\"axis\" x1=\"0\" y1=\"66\" x2=\"600\" y2=\"66\"/>\n        <defs>\n          <linearGradient id=\"wgrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0\" stop-color=\"#c08cff\"/>\n            <stop offset=\"1\" stop-color=\"#ff8cf0\"/>\n          </linearGradient>\n          <filter id=\"glow\" x=\"-20%\" y=\"-60%\" width=\"140%\" height=\"220%\">\n            <feGaussianBlur stdDeviation=\"2.4\" result=\"b\"/>\n            <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n          </filter>\n        </defs>\n        <path id=\"ghost\" fill=\"none\" stroke=\"rgba(192,140,255,0.18)\" stroke-width=\"1.5\"/>\n        <path id=\"wave\" fill=\"none\" stroke=\"url(#wgrad)\" stroke-width=\"2.4\"\n              stroke-linejoin=\"round\" filter=\"url(#glow)\"/>\n      </svg>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"jacks\">\n      <div class=\"jack in\"><div class=\"hole\"></div><span>In</span></div>\n      <div class=\"jack\"><div class=\"hole\"></div><span>Fold CV</span></div>\n      <div class=\"jack\"><div class=\"hole\"></div><span>Sym CV</span></div>\n      <div class=\"jack out\"><div class=\"hole\"></div><span>Out</span></div>\n    </div>\n\n    <div class=\"footer\">\n      <div class=\"kind\" style=\"font-size:10px;letter-spacing:0.3em;color:var(--ink-dim);text-transform:uppercase;\">Drag&nbsp;·&nbsp;Wheel&nbsp;·&nbsp;Dbl-click&nbsp;resets</div>\n    </div>\n  </div>\n</div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts / spec.json) ----\n  var PARAMS = [\n    { name: \"Fold\",     index: 0, min: 0, max: 1, def: 0.45, fmt: pct },\n    { name: \"Symmetry\", index: 1, min: 0, max: 1, def: 0.50, fmt: sym },\n    { name: \"Tone\",     index: 2, min: 0, max: 1, def: 0.55, fmt: pct },\n    { name: \"Output\",   index: 3, min: 0, max: 1, def: 0.70, fmt: db  },\n    { name: \"Mix\",      index: 4, min: 0, max: 1, def: 1.00, fmt: pct }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function sym(v) {\n    var c = (v - 0.5) * 2;\n    if (Math.abs(c) < 0.01) return \"Center\";\n    return (c > 0 ? \"+\" : \"\") + Math.round(c * 100) + \"%\";\n  }\n  function db(v) {\n    var g = v * 1.2;\n    if (g <= 0.0001) return \"-inf\";\n    var d = 20 * Math.log10(g);\n    return (d >= 0 ? \"+\" : \"\") + d.toFixed(1) + \" dB\";\n  }\n\n  var state = {}; // index -> current normalized value\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- knob builder ----\n  function buildKnob(p) {\n    var ns = \"http://www.w3.org/2000/svg\";\n    var size = 72, cx = size / 2, cy = size / 2, r = 27;\n    var svg = document.createElementNS(ns, \"svg\");\n    svg.setAttribute(\"class\", \"knob\");\n    svg.setAttribute(\"viewBox\", \"0 0 \" + size + \" \" + size);\n\n    // body\n    var grad = document.createElementNS(ns, \"defs\");\n    grad.innerHTML =\n      '<radialGradient id=\"kb' + p.index + '\" cx=\"50%\" cy=\"38%\" r=\"65%\">' +\n        '<stop offset=\"0\" stop-color=\"#3a3248\"/>' +\n        '<stop offset=\"0.7\" stop-color=\"#241d31\"/>' +\n        '<stop offset=\"1\" stop-color=\"#141019\"/>' +\n      '</radialGradient>';\n    svg.appendChild(grad);\n\n    var track = document.createElementNS(ns, \"circle\");\n    track.setAttribute(\"cx\", cx); track.setAttribute(\"cy\", cy);\n    track.setAttribute(\"r\", r);\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(255,255,255,0.06)\");\n    track.setAttribute(\"stroke-width\", \"5\");\n    svg.appendChild(track);\n\n    var arc = document.createElementNS(ns, \"path\");\n    arc.setAttribute(\"class\", \"arc-live\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"var(--accent)\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    arc.style.transition = \"stroke 0.15s\";\n    svg.appendChild(arc);\n\n    var body = document.createElementNS(ns, \"circle\");\n    body.setAttribute(\"cx\", cx); body.setAttribute(\"cy\", cy);\n    body.setAttribute(\"r\", r - 5);\n    body.setAttribute(\"fill\", \"url(#kb\" + p.index + \")\");\n    body.setAttribute(\"stroke\", \"rgba(0,0,0,0.6)\");\n    svg.appendChild(body);\n\n    var notch = document.createElementNS(ns, \"line\");\n    notch.setAttribute(\"stroke\", \"var(--accent2)\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    var ARC0 = -135, ARC1 = 135; // degrees, 0 at top\n    function deg2rad(d) { return (d - 90) * Math.PI / 180; }\n    function describeArc(toDeg) {\n      var a0 = deg2rad(ARC0), a1 = deg2rad(toDeg);\n      var x0 = cx + r * Math.cos(a0), y0 = cy + r * Math.sin(a0);\n      var x1 = cx + r * Math.cos(a1), y1 = cy + r * Math.sin(a1);\n      var large = (toDeg - ARC0) > 180 ? 1 : 0;\n      return \"M \" + x0 + \" \" + y0 + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + x1 + \" \" + y1;\n    }\n\n    function render(v) {\n      var ang = ARC0 + (ARC1 - ARC0) * v;\n      arc.setAttribute(\"d\", describeArc(ang));\n      var a = deg2rad(ang);\n      notch.setAttribute(\"x1\", cx + (r - 16) * Math.cos(a));\n      notch.setAttribute(\"y1\", cy + (r - 16) * Math.sin(a));\n      notch.setAttribute(\"x2\", cx + (r - 7) * Math.cos(a));\n      notch.setAttribute(\"y2\", cy + (r - 7) * Math.sin(a));\n    }\n\n    return { svg: svg, render: render };\n  }\n\n  // ---- control module (knob + label + value) ----\n  function buildModule(p) {\n    var mod = document.createElement(\"div\");\n    mod.className = \"mod\";\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    var k = buildKnob(p);\n\n    var val = document.createElement(\"div\");\n    val.className = \"value\";\n\n    mod.appendChild(label);\n    mod.appendChild(k.svg);\n    mod.appendChild(val);\n\n    function setNorm(v, push) {\n      v = Math.max(0, Math.min(1, v));\n      state[p.index] = v;\n      var real = p.min + (p.max - p.min) * v;\n      k.render(v);\n      val.textContent = p.fmt(real);\n      if (push) pushParam(p.index, real);\n      redrawScope();\n    }\n\n    // --- drag (vertical) ---\n    var dragging = false, lastY = 0, startV = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = state[p.index];\n      k.svg.setPointerCapture && e.pointerId !== undefined && k.svg.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var fine = e.shiftKey ? 0.25 : 1;\n      setNorm(state[p.index] + dy / 180 * fine, true);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    k.svg.addEventListener(\"pointerdown\", onDown);\n    window.addEventListener(\"pointermove\", onMove);\n    window.addEventListener(\"pointerup\", onUp);\n\n    k.svg.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var step = (e.deltaY < 0 ? 1 : -1) * (e.shiftKey ? 0.005 : 0.02);\n      setNorm(state[p.index] + step, true);\n    }, { passive: false });\n\n    k.svg.addEventListener(\"dblclick\", function () {\n      var dn = (p.def - p.min) / (p.max - p.min);\n      setNorm(dn, true);\n    });\n\n    p._setNorm = setNorm;\n    return mod;\n  }\n\n  // ---- the live folding scope ----\n  var wavePath, ghostPath, animPhase = 0;\n  function foldShaper(x, fold, sym, tone, output) {\n    // mirror of the DSP, simplified, for visualisation\n    var drive = 1 + fold * fold * 8;\n    var bias = (sym - 0.5) * 1.6;\n    var sineDepth = 0.35 + fold * 0.65;\n    var s = x * drive + bias;\n    // triangle fold\n    var p = (s + 1) * 0.25;\n    p = p - Math.floor(p);\n    s = Math.abs(p * 4 - 2) - 1;\n    s = Math.sin(s * Math.PI * sineDepth) * 0.9 + s * 0.1;\n    s = Math.max(-1, Math.min(1, s));\n    // crude tone tilt (darken toward 0)\n    s = s * (0.55 + 0.45 * tone);\n    return s * (0.4 + 0.6 * output);\n  }\n\n  function buildPath(scaleAmp, phase) {\n    var fold = state[0], sym = state[1], tone = state[2], out = state[3];\n    var N = 120, W = 600, MIDY = 66, AMP = 54 * scaleAmp;\n    var d = \"\";\n    for (var i = 0; i <= N; i++) {\n      var t = i / N;\n      var x = Math.sin(t * Math.PI * 2 + phase); // input sine\n      var y = foldShaper(x, fold, sym, tone, out);\n      var px = t * W;\n      var py = MIDY - y * AMP;\n      d += (i === 0 ? \"M\" : \"L\") + px.toFixed(1) + \" \" + py.toFixed(1) + \" \";\n    }\n    return d;\n  }\n\n  var scopeDirty = true;\n  function redrawScope() { scopeDirty = true; }\n\n  function tick() {\n    if (!document.hidden) {\n      animPhase += 0.03;\n      if (wavePath) {\n        wavePath.setAttribute(\"d\", buildPath(1, animPhase));\n        ghostPath.setAttribute(\"d\", buildPath(1, animPhase - 0.45));\n      }\n    }\n    requestAnimationFrame(tick);\n  }\n\n  // ---- init ----\n  function init() {\n    var rack = document.getElementById(\"rack\");\n    PARAMS.forEach(function (p) { rack.appendChild(buildModule(p)); });\n\n    wavePath = document.getElementById(\"wave\");\n    ghostPath = document.getElementById(\"ghost\");\n\n    PARAMS.forEach(function (p) {\n      var dn = (p.def - p.min) / (p.max - p.min);\n      p._setNorm(dn, true); // initialise + push default\n    });\n\n    requestAnimationFrame(tick);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  WAVE FOLDER — west-coast style waveshaping wavefolder\n//  Drives the signal hard so peaks FOLD back on themselves instead of\n//  clipping flat. A pre-gain stage pushes the level past unity, an\n//  asymmetric bias (Symmetry) shifts the fold axis, then a chain of\n//  reflective triangle folds plus a final sine fold generate dense,\n//  metallic harmonics. A post tone tilt and output stage shape the\n//  result. The folding bounds the amplitude, so more Fold means more\n//  harmonic complexity, not just more level. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter memory\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker (after fold)\nconst dcPrevIn:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst toneLP:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tone tilt low-pass\n\nconst P_FOLD: i32 = 0;     // 0..1 -> pre-gain / number of folds (1..~9x)\nconst P_SYMMETRY: i32 = 1; // 0..1 -> bias offset, 0.5 = symmetric\nconst P_TONE: i32 = 2;     // 0..1 -> dark..bright tilt\nconst P_OUTPUT: i32 = 3;   // 0..1 -> output level 0..1.2\nconst P_MIX: i32 = 4;      // 0..1 -> dry/wet\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    dcState[c] = 0.0;\n    dcPrevIn[c] = 0.0;\n    toneLP[c] = 0.0;\n  }\n  params[P_FOLD] = 0.45;\n  params[P_SYMMETRY] = 0.5;\n  params[P_TONE] = 0.55;\n  params[P_OUTPUT] = 0.7;\n  params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// Triangle (reflective) fold: maps any real x into a triangle wave in [-1,1].\n// This is the classic wavefolder shape — peaks reflect back instead of clipping.\n@inline function triFold(x: f32): f32 {\n  // period 4: y = |((x+1) mod 4) - 2| - 1, reflected to [-1,1]\n  let p: f32 = (x + 1.0) * 0.25;       // scale so one fold per unit of 2\n  p = p - f32(Mathf.floor(p));          // fractional, [0,1)\n  let t: f32 = f32(Mathf.abs(p * 4.0 - 2.0)) - 1.0; // triangle in [-1,1]\n  return t;\n}\n\nexport function process(n: i32): void {\n  const foldN: f32 = clampf(params[P_FOLD], 0.0, 1.0);\n  const symN: f32 = clampf(params[P_SYMMETRY], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const outN: f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Pre-gain: more fold pushes the signal further past the fold threshold,\n  // adding more reflections (more harmonics). 1x .. ~9x.\n  const drive: f32 = 1.0 + foldN * foldN * 8.0;\n  // Bias shifts the fold axis -> even harmonics / asymmetric character.\n  const bias: f32 = (symN - 0.5) * 1.6;\n  // Final sine-fold depth grows with Fold for a smoother, richer top end.\n  const sineDepth: f32 = 0.35 + foldN * 0.65;\n\n  // Tone: a one-pole low-pass we tilt between (dark) and bypass (bright).\n  const toneHz: f32 = 500.0 + toneN * toneN * 11000.0;\n  let cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  cTone = clampf(cTone, 0.0, 1.0);\n  // Bright blend: mix some of the un-filtered (full harmonic) signal back in.\n  const bright: f32 = toneN;\n\n  // DC blocker coefficient (~10 Hz) — folding with bias adds DC we must remove.\n  const dcR: f32 = f32(1.0 - TWO_PI * 10.0 / sampleRate);\n\n  const out: f32 = outN * 1.2;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let dc: f32 = dcState[c];\n    let dcPi: f32 = dcPrevIn[c];\n    let lp: f32 = toneLP[c];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n\n      // drive past the fold threshold + bias the axis\n      let s: f32 = dry * drive + bias;\n\n      // triangle reflective fold — the core west-coast fold\n      s = triFold(s);\n\n      // a second, sine-based fold adds the smooth metallic upper harmonics;\n      // depth scales with Fold so the timbre keeps evolving as you push it.\n      s = f32(Mathf.sin(s * PI * sineDepth)) * 0.9 + s * 0.1;\n\n      // keep it well bounded\n      s = clampf(s, -1.0, 1.0);\n\n      // remove fold/bias DC offset\n      const hp: f32 = s - dcPi + dcR * dc;\n      dc = hp;\n      dcPi = s;\n\n      // tone: low-pass + bright blend of the full-band folded signal\n      lp = lp + cTone * (hp - lp);\n      const toned: f32 = lp + (hp - lp) * bright;\n\n      const wet: f32 = toned * out;\n      outBuf[base + f] = dry * (1.0 - mix) + wet * mix;\n    }\n\n    dcState[c] = dc;\n    dcPrevIn[c] = dcPi;\n    toneLP[c] = lp;\n  }\n}\n",
  "publishedAt": 1751000053000
}