{
  "format": 1,
  "name": "Fat Mono",
  "isInstrument": true,
  "explanation": "A fat monophonic analog-style synthesizer: three detuned oscillators (two saws + a pulse) summed thick and driven through a 4-pole resonant transistor-ladder low-pass with tanh saturation in the feedback loop. A dedicated filter envelope sweeps the cutoff on every note, with a separate amplitude envelope plus portamento glide for expressive, last-note-priority lead and bass tones.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "FilterEnvAmt",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.08
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Glide",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n:root{\n  --ac:#ff8c42;     /* accent  */\n  --ac2:#ffb454;    /* accent2 */\n  --wood1:#7a4a23; --wood2:#5a3318; --wood3:#43250f;\n  --panel1:#2c2622; --panel2:#16120f; --panel3:#0a0807;\n  --metal1:#cdb89a; --metal2:#8a7656; --ink:#1a140d;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{margin:0;font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#f0e3d2;\n  background:radial-gradient(120% 90% at 50% -10%,#241a13 0%,#100b08 60%,#050302 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px;overflow:hidden}\n\n/* ---- whole instrument: tilted hardware on a stand ---- */\n.synth{position:relative;width:100%;max-width:660px;\n  transform:perspective(1500px) rotateX(7deg);transform-style:preserve-3d;\n  animation:rise 1s cubic-bezier(.2,.8,.2,1) both}\n@keyframes rise{from{opacity:0;transform:perspective(1500px) rotateX(20deg) translateY(34px)}}\n\n/* wood end-cheeks frame the unit */\n.cab{position:relative;display:grid;grid-template-columns:30px 1fr 30px;\n  border-radius:14px 14px 10px 10px;padding:0;\n  box-shadow:0 38px 60px rgba(0,0,0,.65),0 6px 0 #000,inset 0 1px 0 rgba(255,255,255,.05)}\n.cheek{position:relative;border-radius:12px 12px 6px 6px;\n  background:\n    repeating-linear-gradient(178deg,rgba(0,0,0,.16) 0 2px,rgba(255,255,255,.04) 2px 5px,transparent 5px 11px),\n    linear-gradient(100deg,var(--wood1),var(--wood2) 45%,var(--wood3));\n  box-shadow:inset 0 2px 4px rgba(255,225,190,.22),inset 0 -3px 8px rgba(0,0,0,.6),inset -2px 0 5px rgba(0,0,0,.4)}\n.cheek::after{content:\"\";position:absolute;inset:0;border-radius:inherit;\n  background:radial-gradient(120% 60% at 30% 8%,rgba(255,210,160,.25),transparent 55%)}\n.cheek.l{box-shadow:inset 0 2px 4px rgba(255,225,190,.22),inset 0 -3px 8px rgba(0,0,0,.6),inset 2px 0 5px rgba(0,0,0,.4)}\n\n/* the brushed-metal face plate */\n.face{position:relative;overflow:hidden;border-top:1px solid rgba(255,255,255,.08);\n  border-bottom:1px solid rgba(0,0,0,.7);\n  background:\n    repeating-linear-gradient(90deg,rgba(255,255,255,.018) 0 2px,transparent 2px 4px),\n    linear-gradient(168deg,var(--panel1),var(--panel2) 70%,var(--panel3));\n  box-shadow:inset 0 2px 18px rgba(0,0,0,.6)}\n\n/* ---- title strip ---- */\n.head{position:relative;display:flex;align-items:center;gap:12px;padding:13px 20px 11px;\n  border-bottom:1px solid rgba(0,0,0,.6)}\n.head::before{content:\"\";position:absolute;left:0;right:0;bottom:-1px;height:1px;background:rgba(255,225,190,.07)}\n.logo{display:flex;flex-direction:column;line-height:1}\n.brand{font-size:9px;letter-spacing:.45em;color:var(--metal2);text-transform:uppercase;margin-bottom:5px}\n.model{font-size:20px;font-weight:900;letter-spacing:.02em;\n  background:linear-gradient(180deg,#fff6ea,var(--ac2) 55%,var(--ac));\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 1px 0 rgba(0,0,0,.3);filter:drop-shadow(0 1px 2px rgba(0,0,0,.4))}\n.plate{margin-left:auto;display:flex;align-items:center;gap:10px}\n.power{display:flex;align-items:center;gap:7px;font-size:9px;letter-spacing:.2em;color:var(--metal2);text-transform:uppercase}\n.led{width:11px;height:11px;border-radius:50%;background:var(--ac);\n  box-shadow:0 0 10px var(--ac),0 0 22px var(--ac),inset 0 0 3px #fff7;\n  animation:hum 2.6s ease-in-out infinite}\n@keyframes hum{0%,100%{opacity:.6;box-shadow:0 0 5px var(--ac),0 0 10px var(--ac)}\n  50%{opacity:1;box-shadow:0 0 12px var(--ac),0 0 26px var(--ac),0 0 4px #fff inset}}\n.screws{display:flex;gap:7px}\n.screw{width:11px;height:11px;border-radius:50%;\n  background:radial-gradient(circle at 38% 30%,var(--metal1),var(--metal2) 60%,#3a2f1f);\n  box-shadow:inset 0 -1px 2px rgba(0,0,0,.7),0 1px 1px rgba(0,0,0,.6);position:relative}\n.screw::after{content:\"\";position:absolute;inset:0;margin:auto;width:7px;height:1.6px;border-radius:1px;\n  background:rgba(0,0,0,.55);transform:rotate(35deg)}\n\n/* ---- the FAT oscilloscope ---- */\n.scopebay{margin:14px 18px 4px;padding:9px;border-radius:10px;\n  background:linear-gradient(#05140f,#020a07);\n  border:1px solid rgba(0,0,0,.8);\n  box-shadow:inset 0 0 24px rgba(0,0,0,.9),inset 0 0 2px rgba(120,255,200,.15),0 1px 0 rgba(255,255,255,.05)}\n.scope{position:relative;height:104px;border-radius:6px;overflow:hidden;\n  background:\n    repeating-linear-gradient(0deg,transparent 0 15px,rgba(80,255,180,.05) 15px 16px),\n    repeating-linear-gradient(90deg,transparent 0 24px,rgba(80,255,180,.05) 24px 25px),\n    radial-gradient(110% 130% at 50% 50%,#08251a,#020806);\n  box-shadow:inset 0 0 30px rgba(0,0,0,.85)}\n.scope svg{position:absolute;inset:0;width:100%;height:100%}\n.scope .glass{position:absolute;inset:0;pointer-events:none;\n  background:radial-gradient(120% 80% at 50% 0%,rgba(180,255,220,.10),transparent 60%);\n  animation:scan 5s linear infinite}\n@keyframes scan{0%{background-position:0 -10px}100%{background-position:0 110px}}\n.wave{fill:none;stroke:var(--ac2);stroke-width:2.4;stroke-linejoin:round;stroke-linecap:round;\n  filter:drop-shadow(0 0 5px var(--ac)) drop-shadow(0 0 11px color-mix(in srgb,var(--ac) 70%,transparent))}\n.wave.ghost{stroke:var(--ac);opacity:.32;stroke-width:5}\n.scopelbl{position:absolute;top:6px;left:9px;font-size:8px;letter-spacing:.25em;color:rgba(150,255,200,.55);text-transform:uppercase}\n\n/* ---- knob rows on the tilt panel ---- */\n.rows{padding:12px 16px 8px}\n.rowlbl{display:flex;align-items:center;gap:9px;margin:6px 4px 2px;\n  font-size:8.5px;letter-spacing:.32em;color:var(--metal2);text-transform:uppercase}\n.rowlbl::after{content:\"\";flex:1;height:1px;background:linear-gradient(90deg,rgba(255,225,190,.18),transparent)}\n.bank{display:grid;grid-template-columns:repeat(4,1fr);gap:6px}\n\n.cell{position:relative;display:flex;flex-direction:column;align-items:center;gap:7px;\n  padding:11px 4px 9px;border-radius:11px;\n  animation:pop .55s both;animation-delay:var(--d);transition:background .2s}\n.cell:hover{background:rgba(255,210,160,.04)}\n@keyframes pop{from{opacity:0;transform:translateY(12px) scale(.92)}to{opacity:1;transform:none}}\n\n/* chunky moog knob */\n.knob{position:relative;width:82px;height:82px;cursor:ns-resize;user-select:none;touch-action:none}\n.knob svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}\n.ringbg{fill:none;stroke:rgba(0,0,0,.55);stroke-width:5}\n.ringfg{fill:none;stroke:url(#g);stroke-width:5;stroke-linecap:round;\n  filter:drop-shadow(0 0 4px var(--ac));transition:stroke-dasharray .12s cubic-bezier(.2,.8,.2,1)}\n/* the physical cap */\n.cap{position:absolute;top:13px;left:13px;width:56px;height:56px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 22%,#4a4036,#231c14 62%,#0c0907);\n  box-shadow:inset 0 3px 6px rgba(255,220,180,.18),inset 0 -5px 10px rgba(0,0,0,.85),\n    0 4px 8px rgba(0,0,0,.6),0 0 0 2px rgba(0,0,0,.55);\n  transition:transform .12s cubic-bezier(.2,.8,.2,1)}\n.cap::before{content:\"\";position:absolute;inset:9px;border-radius:50%;\n  background:repeating-conic-gradient(from 0deg,#2c241b 0 6deg,#1a140e 6deg 12deg);\n  box-shadow:inset 0 0 6px rgba(0,0,0,.8)}\n.cap::after{content:\"\";position:absolute;inset:0;border-radius:50%;\n  background:radial-gradient(60% 40% at 38% 24%,rgba(255,240,220,.30),transparent 60%)}\n/* pointer line painted onto the cap, rotated by JS via --rot */\n.ptr{position:absolute;top:13px;left:13px;width:56px;height:56px;border-radius:50%;z-index:3;\n  transform:rotate(var(--rot,-135deg));transition:transform .12s cubic-bezier(.2,.8,.2,1)}\n.ptr i{position:absolute;top:3px;left:50%;width:4px;height:16px;margin-left:-2px;border-radius:2px;\n  background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 7px var(--ac),0 0 2px #fff}\n.knob.act .cap{transform:scale(1.04)}\n\n.bub{position:absolute;top:-12px;left:50%;transform:translate(-50%,5px) scale(.8);opacity:0;pointer-events:none;\n  font-size:11px;font-weight:800;color:var(--ink);background:linear-gradient(var(--ac2),var(--ac));\n  padding:2px 8px;border-radius:5px;font-variant-numeric:tabular-nums;z-index:5;\n  box-shadow:0 4px 10px rgba(0,0,0,.5);transition:.15s}\n.cell:hover .bub,.knob.act .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n\n.nm{font-size:9.5px;letter-spacing:.16em;color:#c9b59a;text-transform:uppercase;text-align:center}\n.val{font-size:12px;font-weight:800;color:#fff4e6;font-variant-numeric:tabular-nums;\n  background:rgba(0,0,0,.35);border:1px solid rgba(255,210,160,.12);border-radius:5px;padding:1px 8px;min-width:46px;text-align:center}\n\n.foot{display:flex;align-items:center;gap:10px;padding:9px 22px 13px;font-size:10px;color:#9c8568;\n  border-top:1px solid rgba(0,0,0,.55)}\n.foot::before{content:\"\";position:absolute;left:0;right:0;height:1px;background:rgba(255,225,190,.06);margin-top:-9px}\n.foot b{color:var(--ac2);font-weight:800;letter-spacing:.04em}\n.vu{margin-left:auto;display:flex;gap:3px;align-items:flex-end;height:14px}\n.vu i{width:3px;border-radius:1px;background:var(--metal2);animation:vu 1.1s ease-in-out infinite}\n.vu i:nth-child(1){height:5px;animation-delay:0s}\n.vu i:nth-child(2){height:9px;animation-delay:.12s}\n.vu i:nth-child(3){height:14px;animation-delay:.24s}\n.vu i:nth-child(4){height:8px;animation-delay:.36s}\n.vu i:nth-child(5){height:11px;animation-delay:.48s}\n@keyframes vu{0%,100%{background:var(--metal2);transform:scaleY(.5)}50%{background:var(--ac);transform:scaleY(1)}}\n</style></head><body>\n  <div class=\"synth\">\n    <div class=\"cab\">\n      <div class=\"cheek l\"></div>\n      <div class=\"face\">\n        <div class=\"head\">\n          <div class=\"logo\">\n            <span class=\"brand\">Boutique Analog</span>\n            <span class=\"model\">FAT MONO</span>\n          </div>\n          <div class=\"plate\">\n            <div class=\"power\"><span class=\"led\"></span>ON</div>\n            <div class=\"screws\"><span class=\"screw\"></span><span class=\"screw\"></span></div>\n          </div>\n        </div>\n\n        <div class=\"scopebay\">\n          <div class=\"scope\">\n            <span class=\"scopelbl\">OSC // live</span>\n            <svg viewBox=\"0 0 600 104\" preserveAspectRatio=\"none\">\n              <defs>\n                <linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n                  <stop offset=\"0\" stop-color=\"var(--ac2)\"/><stop offset=\"1\" stop-color=\"var(--ac)\"/>\n                </linearGradient>\n              </defs>\n              <path id=\"wghost\" class=\"wave ghost\" d=\"\"/>\n              <path id=\"wave\" class=\"wave\" d=\"\"/>\n            </svg>\n            <div class=\"glass\"></div>\n          </div>\n        </div>\n\n        <div class=\"rows\">\n          <div class=\"rowlbl\">Oscillators &amp; Voice</div>\n          <div class=\"bank\" id=\"bankA\"></div>\n          <div class=\"rowlbl\">Transistor Ladder Filter &amp; Envelope</div>\n          <div class=\"bank\" id=\"bankB\"></div>\n        </div>\n\n        <div class=\"foot\">\n          <span>3&times; OSC &rarr; <b>4-pole ladder</b> &middot; tanh drive &middot; last-note priority</span>\n          <span class=\"vu\"><i></i><i></i><i></i><i></i><i></i></span>\n        </div>\n      </div>\n      <div class=\"cheek\"></div>\n    </div>\n  </div>\n\n  <script>\n  (function(){\n    // ---- EXACT params from spec.json (re-read) ----\n    var PARAMS=[\n      {name:\"Detune\",       index:0, min:0, max:1, def:0.35},\n      {name:\"Cutoff\",       index:1, min:0, max:1, def:0.45},\n      {name:\"Resonance\",    index:2, min:0, max:1, def:0.55},\n      {name:\"FilterEnvAmt\", index:3, min:0, max:1, def:0.70, label:\"Env Amt\"},\n      {name:\"Attack\",       index:4, min:0, max:1, def:0.08},\n      {name:\"Release\",      index:5, min:0, max:1, def:0.30},\n      {name:\"Glide\",        index:6, min:0, max:1, def:0.25},\n      {name:\"Level\",        index:7, min:0, max:1, def:0.70}\n    ];\n    var BANKS={bankA:[0,1,2,3], bankB:[4,5,6,7]}; // OSC/voice vs filter/env layout\n\n    var R=33, C=41, CIRC=2*Math.PI*R;       // ring geometry for the SVG knob\n    var SWEEP=270;                           // degrees of knob travel\n    var ctrls=[];\n\n    // params are normalised 0..1; show them as a clean 0..100 dial position\n    // (no \"%\" suffix, since these are not literal percentages).\n    function fmt(p,val){ return String(Math.round(val*100)); }\n\n    function makeKnob(p, delay){\n      var cell=document.createElement('div');\n      cell.className='cell'; cell.style.setProperty('--d',delay+'ms');\n      cell.innerHTML=\n        '<div class=\"knob\">'+\n          '<svg viewBox=\"0 0 82 82\">'+\n            '<circle class=\"ringbg\" cx=\"41\" cy=\"41\" r=\"33\"/>'+\n            '<circle class=\"ringfg\" cx=\"41\" cy=\"41\" r=\"33\"/>'+\n          '</svg>'+\n          '<div class=\"cap\"></div>'+\n          '<div class=\"ptr\"><i></i></div>'+\n          '<span class=\"bub\"></span>'+\n        '</div>'+\n        '<div class=\"nm\">'+(p.label||p.name)+'</div>'+\n        '<div class=\"val\"></div>';\n      var knob=cell.querySelector('.knob'),\n          fg=cell.querySelector('.ringfg'),\n          ptr=cell.querySelector('.ptr'),\n          out=cell.querySelector('.val'),\n          bub=cell.querySelector('.bub');\n\n      // ring is drawn from -225deg start over 270deg; rotate the svg so the\n      // gap sits at the bottom.\n      fg.style.transform='rotate(135deg)'; fg.style.transformOrigin='41px 41px';\n      cell.querySelector('.ringbg').style.transform='rotate(135deg)';\n      cell.querySelector('.ringbg').style.transformOrigin='41px 41px';\n      var GAP=CIRC*(SWEEP/360);\n      fg.setAttribute('stroke-dasharray','0 '+CIRC);\n      cell.querySelector('.ringbg').setAttribute('stroke-dasharray',GAP+' '+CIRC);\n\n      var val=p.def;\n      function norm(){ return (val-p.min)/((p.max-p.min)||1); }\n      function paint(){\n        var n=norm();\n        fg.setAttribute('stroke-dasharray',(GAP*n)+' '+CIRC);\n        ptr.style.setProperty('--rot',(-135+SWEEP*n)+'deg');\n        var t=fmt(p,val); out.textContent=t; bub.textContent=t;\n        if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,val);\n      }\n      function setN(n){ n=n<0?0:(n>1?1:n); val=p.min+(p.max-p.min)*n; paint(); }\n\n      knob.addEventListener('pointerdown',function(e){\n        knob._d=1; knob._y=e.clientY; knob._n=norm(); knob.classList.add('act');\n        try{knob.setPointerCapture(e.pointerId);}catch(_){}\n        e.preventDefault();\n      });\n      knob.addEventListener('pointermove',function(e){\n        if(!knob._d)return; setN(knob._n+(knob._y-e.clientY)/220);\n      });\n      function end(){ knob._d=0; knob.classList.remove('act'); }\n      knob.addEventListener('pointerup',end);\n      knob.addEventListener('pointercancel',end);\n      knob.addEventListener('dblclick',function(){ val=p.def; paint(); });\n      knob.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n\n      paint();\n      ctrls.push({p:p, get:norm});\n      return cell;\n    }\n\n    function build(){\n      Object.keys(BANKS).forEach(function(bid){\n        var host=document.getElementById(bid);\n        BANKS[bid].forEach(function(pi,k){ host.appendChild(makeKnob(PARAMS[pi], pi*55)); });\n      });\n      startScope();\n    }\n\n    // ---- the FAT animated oscilloscope -------------------------------\n    // Synthesises the actual voice shape: detuned saws + pulse through a\n    // resonant low-pass envelope, so the trace REACTS to the knobs live.\n    var wave=document.getElementById('wave'), ghost=document.getElementById('wghost');\n    var N=120, W=600, H=104, t=0;\n    function val(i){ var c=ctrls[i]; return c?c.get():PARAMS[i].def; }\n    function startScope(){\n      function saw(ph){ return 2*(ph-Math.floor(ph+0.5)); }\n      function frame(){\n        t+=0.024;\n        var det=val(0), cut=val(1), res=val(2), envA=val(3), level=val(7);\n        // a moving filter-envelope “breath” modulates brightness over time\n        var breath=0.5+0.5*Math.sin(t*0.7);\n        var bright=0.12+ (cut + envA*breath)*1.1;        // harmonic count factor\n        var harm=Math.max(2,Math.round(2+bright*9));\n        var rq=1+res*7;                                   // resonance emphasis\n        var pts=[], gpts=[];\n        var f=2.1+det*1.6;                                // base cycles across screen\n        var d2=det*0.06;                                  // detune spread between osc\n        for(var x=0;x<=N;x++){\n          var u=x/N, ph=u*f, s=0, norm=0;\n          for(var h=1;h<=harm;h++){\n            var amp=1/h;\n            // resonant bump near the (moving) cutoff harmonic\n            var fc=harm*(0.35+0.4*breath);\n            amp*= 1/(1+Math.pow(h/Math.max(1.2,fc),3));   // low-pass roll-off\n            amp*= 1+(rq-1)*Math.exp(-Math.pow((h-fc)/1.4,2)); // resonance peak\n            s+= amp*( Math.sin(2*Math.PI*(h*ph))\n                    + 0.6*Math.sin(2*Math.PI*(h*(ph+d2)))   // detuned osc 2 (saw)\n                    + 0.4*(Math.sin(2*Math.PI*(h*(ph-d2)))) // osc 3 (pulse-ish)\n                    );\n            norm+=amp;\n          }\n          s=s/(norm*2.0);\n          s=Math.tanh(s*(1.4+res*1.6));                   // ladder tanh drive\n          var y=H/2 - s*(H*0.40)*(0.5+level*0.6);\n          var px=(x/N*W).toFixed(1);\n          pts.push((x?'L':'M')+px+' '+y.toFixed(1));\n          gpts.push((x?'L':'M')+px+' '+(H/2-(s)*(H*0.40)*(0.5+level*0.6)).toFixed(1));\n        }\n        wave.setAttribute('d',pts.join(' '));\n        ghost.setAttribute('d',gpts.join(' '));\n        requestAnimationFrame(frame);\n      }\n      requestAnimationFrame(frame);\n    }\n\n    if(window.vstai&&window.vstai.onReady) window.vstai.onReady(build); else build();\n  })();\n  </script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  FAT MONO — fat monophonic analog-style synthesizer (original model)\n//\n//  Behaviour modelled on a classic 3-oscillator transistor-ladder mono synth:\n//    * 3 detuned oscillators (two sawtooth + one pulse), summed thick.\n//    * A 4-pole resonant transistor-ladder low-pass with tanh saturation\n//      inside the feedback loop (the source of the warm, singing character).\n//    * A dedicated filter ADSR (with bipolar amount) that sweeps the cutoff\n//      on every note, plus a separate amplitude ADSR.\n//    * Last-note-priority monophonic voice with portamento / glide.\n//\n//  Pure algorithm, no host imports, no allocation in process(). Every DSP\n//  value is f32 (Mathf.* math) and the output is gain-staged to stay < 1.0.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI:    f32 = 3.14159265358979;\nconst TWOPI: f32 = 6.28318530717959;\n\n// ---- parameter indices ----------------------------------------------\nconst P_DETUNE:  i32 = 0;  // 0..1  -> oscillator spread (fatness)\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RES:     i32 = 2;  // 0..1  -> ladder resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount\nconst P_ATTACK:  i32 = 4;  // 0..1  -> attack time (both envelopes)\nconst P_RELEASE: i32 = 5;  // 0..1  -> release time (both envelopes)\nconst P_GLIDE:   i32 = 6;  // 0..1  -> portamento time\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- engine state ----------------------------------------------------\nlet sampleRate: f32 = 48000.0;\n\n// note / voice\nlet gate:     i32 = 0;     // 1 while a key is held\nlet note:     i32 = -1;    // currently sounding note id (last-note priority)\nlet vel:      f32 = 0.8;   // velocity of the active note (0..1)\nlet targetHz: f32 = 220.0; // pitch we are gliding toward\nlet curHz:    f32 = 110.0; // current (glided) pitch, starts low so glide is audible\n\n// three oscillator phases (0..1)\nlet ph0: f32 = 0.0;\nlet ph1: f32 = 0.33;\nlet ph2: f32 = 0.66;\n\n// amplitude envelope\nlet ampEnv:   f32 = 0.0;\nlet ampStage: i32 = 0;     // 0=idle 1=attack 2=sustain 3=release\n\n// filter envelope\nlet filtEnv:   f32 = 0.0;\nlet filtStage: i32 = 0;\n\n// ladder filter state (4 cascaded one-pole stages)\nlet s0: f32 = 0.0;\nlet s1: f32 = 0.0;\nlet s2: f32 = 0.0;\nlet s3: f32 = 0.0;\n\n// gentle DC blocker on the output\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  gate = 0; note = -1; vel = 0.8;\n  targetHz = 220.0; curHz = 110.0;\n  ph0 = 0.0; ph1 = 0.33; ph2 = 0.66;\n  ampEnv = 0.0; ampStage = 0;\n  filtEnv = 0.0; filtStage = 0;\n  s0 = 0.0; s1 = 0.0; s2 = 0.0; s3 = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_DETUNE]  = 0.35;\n  params[P_CUTOFF]  = 0.45;\n  params[P_RES]     = 0.55;\n  params[P_ENVAMT]  = 0.7;\n  params[P_ATTACK]  = 0.08;\n  params[P_RELEASE] = 0.3;\n  params[P_GLIDE]   = 0.25;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n// Host passes frequency in Hz; last-note-priority monophonic.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  note = id;\n  targetHz = f > 1.0 ? f : 1.0;\n  vel = v > 0.0 ? (v < 1.0 ? v : 1.0) : 0.0;\n  // If the voice was silent, restart pitch from a slightly low value so the\n  // very first note still exhibits an audible glide; otherwise glide from the\n  // pitch we were already at (legato portamento).\n  if (gate == 0 && ampStage == 0) {\n    curHz = targetHz * 0.5;\n  }\n  gate = 1;\n  ampStage = 1;   // (re)trigger attack\n  filtStage = 1;\n}\n\nexport function noteOff(id: i32): void {\n  if (id == note) {\n    gate = 0;\n    ampStage = 3;\n    filtStage = 3;\n  }\n}\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// One-pole \"PolyBLEP\" correction term to tame naive-saw/pulse aliasing at the\n// discontinuity — keeps the tone smooth and analog rather than buzzy/digital.\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    let x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    let x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  // ---- read + condition parameters ----\n  const detune:  f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resN:    f32 = clampf(params[P_RES], 0.0, 1.0);\n  const envAmt:  f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const attackN: f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const releaseN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const glideN:  f32 = clampf(params[P_GLIDE], 0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // Envelope rates: convert 0..1 into per-sample one-pole coefficients.\n  // attack 2 ms .. 1.5 s ; release 8 ms .. 3 s ; decay tied to release-ish.\n  const attackT:  f32 = 0.002 + attackN * attackN * 1.5;\n  const releaseT: f32 = 0.008 + releaseN * releaseN * 3.0;\n  const decayT:   f32 = 0.06 + releaseN * 1.2;     // filter/amp decay to sustain\n  const aCoef: f32 = 1.0 - Mathf.exp(-1.0 / (attackT * sampleRate));\n  const rCoef: f32 = 1.0 - Mathf.exp(-1.0 / (releaseT * sampleRate));\n  const dCoef: f32 = 1.0 - Mathf.exp(-1.0 / (decayT * sampleRate));\n  const sustain: f32 = 0.65;   // sustain level for both envelopes\n\n  // Glide: 0 -> ~1 ms (instant), 1 -> ~0.6 s portamento.\n  const glideT: f32 = 0.001 + glideN * glideN * 0.6;\n  const glCoef: f32 = 1.0 - Mathf.exp(-1.0 / (glideT * sampleRate));\n\n  // Detune spread in cents -> ratio. osc1 down, osc2 up; osc0 reference.\n  const cents: f32 = detune * 18.0;                 // up to ~18 cents\n  const det1: f32 = Mathf.exp(-cents * 0.0005776227);  // 2^(-c/1200)\n  const det2: f32 = Mathf.exp( cents * 0.0005776227);\n  // sub-style third oscillator one octave-ish, lightly detuned for body\n  const det2b: f32 = det2 * 0.5;\n\n  // Resonance feedback amount (ladder). Keep below self-oscillation blowup.\n  const reso: f32 = resN * 4.2;\n  // Resonance robs low end; compensate input gain a touch as reso rises.\n  const resComp: f32 = 1.0 + 0.5 * resN;\n\n  // Output trim. Three oscillators summed → scale down, then user Level.\n  const oscScale: f32 = 0.32;\n  const outGain: f32 = level * 0.9;\n\n  for (let f: i32 = 0; f < n; f++) {\n    // ---- pitch glide ----\n    curHz += glCoef * (targetHz - curHz);\n    let hz: f32 = curHz;\n    if (hz < 1.0) hz = 1.0;\n\n    // ---- amplitude envelope ----\n    if (ampStage == 1) {                 // attack -> 1.0\n      ampEnv += aCoef * (1.02 - ampEnv);\n      if (ampEnv >= 0.999) { ampEnv = 1.0; ampStage = 2; }\n    } else if (ampStage == 2) {          // decay toward sustain (held)\n      ampEnv += dCoef * (sustain - ampEnv);\n    } else if (ampStage == 3) {          // release -> 0\n      ampEnv += rCoef * (0.0 - ampEnv);\n      if (ampEnv < 0.0001) { ampEnv = 0.0; ampStage = 0; }\n    }\n\n    // ---- filter envelope (same shape, separate state) ----\n    if (filtStage == 1) {\n      filtEnv += aCoef * (1.02 - filtEnv);\n      if (filtEnv >= 0.999) { filtEnv = 1.0; filtStage = 2; }\n    } else if (filtStage == 2) {\n      filtEnv += dCoef * (sustain - filtEnv);\n    } else if (filtStage == 3) {\n      filtEnv += rCoef * (0.0 - filtEnv);\n      if (filtEnv < 0.0001) { filtEnv = 0.0; filtStage = 0; }\n    }\n\n    // ---- oscillators ----\n    const dt0: f32 = hz / sampleRate;\n    const dt1: f32 = hz * det1 / sampleRate;\n    const dt2: f32 = hz * det2b / sampleRate;\n\n    ph0 += dt0; if (ph0 >= 1.0) ph0 -= 1.0;\n    ph1 += dt1; if (ph1 >= 1.0) ph1 -= 1.0;\n    ph2 += dt2; if (ph2 >= 1.0) ph2 -= 1.0;\n\n    // osc0: band-limited saw\n    let saw0: f32 = 2.0 * ph0 - 1.0;\n    saw0 -= polyBlep(ph0, dt0);\n    // osc1: band-limited saw (detuned for fatness)\n    let saw1: f32 = 2.0 * ph1 - 1.0;\n    saw1 -= polyBlep(ph1, dt1);\n    // osc2: band-limited pulse (~30% duty) one octave down for weight\n    const duty: f32 = 0.3;\n    let pw: f32 = ph2 < duty ? 1.0 : -1.0;\n    pw += polyBlep(ph2, dt2);\n    let ph2b: f32 = ph2 - duty; if (ph2b < 0.0) ph2b += 1.0;\n    pw -= polyBlep(ph2b, dt2);\n\n    let oscMix: f32 = (saw0 + saw1 * 0.9 + pw * 0.7) * oscScale;\n    oscMix *= resComp;\n\n    // ---- cutoff from base + filter envelope ----\n    // map cutoffN exponentially to ~30 Hz .. ~16 kHz, add env sweep.\n    let cutCtl: f32 = cutoffN + envAmt * filtEnv;\n    cutCtl = clampf(cutCtl, 0.0, 1.0);\n    let fc: f32 = 30.0 * Mathf.exp(cutCtl * 6.55);      // 30 .. ~16k\n    const nyq: f32 = sampleRate * 0.49;\n    if (fc > nyq) fc = nyq;\n    if (fc < 20.0) fc = 20.0;\n\n    // transistor-ladder one-pole coefficient\n    let g: f32 = TWOPI * fc / sampleRate;\n    if (g > 1.0) g = 1.0;\n    const gc: f32 = g * (1.0 - 0.5 * g);   // mild freq pre-warp\n\n    // ---- 4-pole ladder with tanh saturation in the loop ----\n    // feedback from last stage, scaled by resonance\n    let input: f32 = oscMix - reso * s3;\n    // tanh drive in the loop gives the warm, compressing analog character\n    input = tanhf(input);\n    s0 += gc * (input - s0);\n    s1 += gc * (s0 - s1);\n    s2 += gc * (s1 - s2);\n    s3 += gc * (s2 - s3);\n    let lp: f32 = s3;\n\n    // ---- amplitude ----\n    let voice: f32 = lp * ampEnv * vel;\n\n    // DC blocker (R ~ 0.995)\n    let y: f32 = voice - dcX + 0.9975 * dcY;\n    dcX = voice;\n    dcY = y;\n\n    let outS: f32 = tanhf(y * 1.1) * outGain;   // gentle final saturation/limit\n    if (outS > 1.0) outS = 1.0;\n    if (outS < -1.0) outS = -1.0;\n\n    outBuf[f] = outS;                 // left\n    outBuf[MAX_FRAMES + f] = outS;    // right (mono synth)\n  }\n}\n\n// fast f32 tanh approximation (rational Padé), stays in f32 the whole way.\n@inline function tanhf(x: f32): f32 {\n  let v: f32 = x;\n  if (v > 4.0) return 1.0;\n  if (v < -4.0) return -1.0;\n  const x2: f32 = v * v;\n  const num: f32 = v * (135135.0 + x2 * (17325.0 + x2 * (378.0 + x2)));\n  const den: f32 = 135135.0 + x2 * (62370.0 + x2 * (3150.0 + x2 * 28.0));\n  let r: f32 = num / den;\n  if (r > 1.0) r = 1.0;\n  if (r < -1.0) r = -1.0;\n  return r;\n}\n",
  "publishedAt": 1751000016000
}