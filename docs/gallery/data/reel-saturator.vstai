{
  "format": 1,
  "name": "Reel Saturator",
  "isInstrument": false,
  "explanation": "A tape-style saturation and warmth processor. Drive feeds a tanh soft-saturation (oversampled to tame aliasing) that adds even and odd harmonics with gentle program-dependent compression; Warmth rolls off the highs, Bump adds a resonant low head-bump, and a very subtle wow modulation gives tape motion. Controls: Drive, Warmth, Bump, Mix and Output.",
  "params": [
    {
      "name": "Drive",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Warmth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Bump",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --n{syntax:'<number>';inherits:true;initial-value:0}\n:root{--ac:#e0b070;--ac2:#f0d0a0;--drive:0.45;--warmth:0.4;--bump:0.35;--mix:1;--out:0.7}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{min-height:100vh;font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;color:#efe3cf;\n  background:\n    radial-gradient(120% 90% at 50% -10%,#2a2118 0%,#16110b 55%,#0a0805 100%);\n  display:flex;align-items:center;justify-content:center;padding:18px}\n\n/* ===== chassis : a brushed-metal console strip ===== */\n.strip{position:relative;width:100%;max-width:640px;border-radius:16px;overflow:hidden;\n  background:\n    linear-gradient(180deg,#3a322a 0%,#2b241d 8%,#221c16 100%);\n  border:1px solid rgba(0,0,0,.7);\n  box-shadow:0 26px 60px rgba(0,0,0,.65),\n    inset 0 1px 0 rgba(255,236,205,.16),\n    inset 0 -2px 8px rgba(0,0,0,.6),\n    0 0 0 1px rgba(255,255,255,.03)}\n/* fine brushed lines */\n.strip::before{content:\"\";position:absolute;inset:0;z-index:0;pointer-events:none;opacity:.5;\n  background:repeating-linear-gradient(90deg,rgba(255,255,255,.025) 0 1px,transparent 1px 3px);\n  mix-blend-mode:overlay}\n/* warm saturation bloom that breathes with Drive */\n.strip::after{content:\"\";position:absolute;left:50%;top:-30%;width:160%;height:120%;z-index:0;pointer-events:none;\n  transform:translateX(-50%);\n  background:radial-gradient(closest-side,\n    color-mix(in srgb,var(--ac) calc(22% + var(--drive)*48%),transparent),transparent 72%);\n  filter:blur(34px);opacity:calc(.35 + var(--drive)*.5);\n  animation:bloom 6s ease-in-out infinite alternate}\n@keyframes bloom{from{transform:translateX(-50%) scale(1)}to{transform:translateX(-52%) scale(1.08)}}\n\n/* ===== faceplate header : screws + brand ===== */\n.head{position:relative;z-index:2;display:flex;align-items:center;gap:12px;padding:13px 20px 11px;\n  border-bottom:1px solid rgba(0,0,0,.55);\n  background:linear-gradient(180deg,rgba(255,236,205,.07),rgba(0,0,0,0))}\n.screw{width:11px;height:11px;border-radius:50%;flex:none;\n  background:radial-gradient(circle at 38% 32%,#6b5d49,#241d15 75%);\n  box-shadow:inset 0 1px 1px rgba(255,255,255,.25),0 1px 2px rgba(0,0,0,.6)}\n.screw::after{content:\"\";display:block;width:8px;height:1.6px;margin:4.7px auto 0;background:#0c0906;\n  border-radius:2px;transform:rotate(34deg);box-shadow:0 1px 0 rgba(255,255,255,.12)}\n.brand{flex:1;display:flex;flex-direction:column;line-height:1.05}\n.brand b{font-size:18px;font-weight:800;letter-spacing:.04em;\n  background:linear-gradient(180deg,#fff5e6,var(--ac));-webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 1px 0 rgba(0,0,0,.4)}\n.brand small{font-size:9px;letter-spacing:.42em;text-transform:uppercase;color:#9c8767;margin-top:3px}\n.power{display:flex;align-items:center;gap:6px;font-size:8.5px;letter-spacing:.18em;color:#9c8767;text-transform:uppercase}\n.led{width:8px;height:8px;border-radius:50%;background:var(--ac);\n  box-shadow:0 0 8px var(--ac),0 0 2px #fff8ea inset;animation:pulse 2.6s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:.5}50%{opacity:1}}\n\n/* ===== top deck : tape transport + VU meter ===== */\n.deck{position:relative;z-index:2;display:flex;gap:16px;align-items:stretch;padding:18px 20px 6px}\n\n/* -- the tape reel assembly -- */\n.transport{flex:none;width:200px;position:relative;border-radius:12px;padding:14px 10px 10px;\n  background:linear-gradient(160deg,#1c1610,#0e0a06);\n  border:1px solid rgba(0,0,0,.6);box-shadow:inset 0 2px 10px rgba(0,0,0,.7),inset 0 1px 0 rgba(255,236,205,.05)}\n.reels{display:flex;justify-content:space-between;align-items:center;position:relative;height:96px}\n/* the tape path between reels */\n.tapepath{position:absolute;left:48px;right:48px;top:50%;height:14px;transform:translateY(-50%);\n  background:linear-gradient(180deg,#2a2117,#120d08);border-top:1px solid rgba(255,236,205,.07);\n  border-bottom:1px solid rgba(0,0,0,.7);overflow:hidden}\n.tapepath::before{content:\"\";position:absolute;inset:0;\n  background:repeating-linear-gradient(90deg,rgba(224,176,112,.0) 0 8px,rgba(224,176,112,.22) 8px 9px);\n  animation:tape 0.9s linear infinite;\n  animation-duration:calc(1.4s - var(--drive)*1s)}\n@keyframes tape{from{background-position:0 0}to{background-position:40px 0}}\n.reel{position:relative;width:86px;height:86px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 50%,#211910 0 24%,#0c0906 24% 26%,#1a140d 26% 100%);\n  box-shadow:inset 0 0 0 2px rgba(0,0,0,.6),inset 0 4px 14px rgba(0,0,0,.7),0 2px 4px rgba(0,0,0,.5);\n  animation:spin 3s linear infinite;\n  animation-duration:calc(3.6s - var(--drive)*2.6s)}\n.reel.r2{animation-duration:calc(3.7s - var(--drive)*2.6s)}\n@keyframes spin{to{transform:rotate(360deg)}}\n/* three spokes + hub */\n.reel .spoke{position:absolute;left:50%;top:50%;width:9px;height:32px;margin:-16px 0 0 -4.5px;border-radius:4px;\n  background:linear-gradient(180deg,#4a3c2a,#241a10);box-shadow:inset 0 1px 0 rgba(255,236,205,.18),0 1px 2px rgba(0,0,0,.6)}\n.reel .spoke:nth-child(2){transform:rotate(60deg)}\n.reel .spoke:nth-child(3){transform:rotate(120deg)}\n.reel .hub{position:absolute;left:50%;top:50%;width:20px;height:20px;margin:-10px 0 0 -10px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,var(--ac2),#7a5a32 70%,#3a2a18);\n  box-shadow:0 0 8px color-mix(in srgb,var(--ac) 60%,transparent),inset 0 1px 1px rgba(255,255,255,.4)}\n/* amount of tape wound (driven by --out) */\n.reel .tape{position:absolute;border-radius:50%;\n  inset:calc(8px + (1 - var(--out))*22px);\n  background:repeating-radial-gradient(circle,#3a2c1c 0 1.5px,#241a10 1.5px 3px);\n  box-shadow:inset 0 0 6px rgba(0,0,0,.6)}\n\n/* -- VU meter -- */\n.vu{flex:1;min-width:0;position:relative;border-radius:12px;padding:10px 14px 8px;\n  background:linear-gradient(170deg,#efe4c8,#d8c8a3);\n  border:1px solid #4a3c28;box-shadow:inset 0 2px 8px rgba(0,0,0,.35),0 1px 0 rgba(255,255,255,.1);\n  display:flex;flex-direction:column}\n.vu .face{position:relative;flex:1;min-height:96px}\n.vu svg{width:100%;height:100%;display:block;overflow:visible}\n.vu .lbl{position:absolute;top:6px;left:0;right:0;text-align:center;font-size:8px;letter-spacing:.34em;\n  color:#6a5535;text-transform:uppercase}\n.vu .vutxt{position:absolute;right:8px;bottom:2px;font-size:8px;letter-spacing:.2em;color:#7a6038;font-weight:700}\n.needle{transform-box:fill-box;transform-origin:50% 100%;\n  transition:transform .12s cubic-bezier(.3,.8,.3,1)}\n.glassglow{animation:warn 1.4s ease-in-out infinite}\n@keyframes warn{0%,100%{opacity:.0}50%{opacity:.55}}\n\n/* ===== control row : 5 chicken-head knobs ===== */\n.controls{position:relative;z-index:2;display:grid;grid-template-columns:repeat(5,1fr);gap:6px;padding:16px 14px 8px}\n.cell{display:flex;flex-direction:column;align-items:center;gap:8px;padding:10px 2px 8px;border-radius:12px;\n  transition:background .18s,transform .18s;animation:rise .55s both;animation-delay:var(--d)}\n.cell:hover{background:rgba(255,236,205,.04);transform:translateY(-2px)}\n@keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:74px;height:74px;cursor:ns-resize;user-select:none;touch-action:none}\n/* engraved tick ring */\n.ring{position:absolute;inset:-3px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(255,236,205,.30) 0 1deg,transparent 1deg 27deg);\n  -webkit-mask:radial-gradient(circle,transparent 38px,#000 39px,#000 42px,transparent 43px);\n  mask:radial-gradient(circle,transparent 38px,#000 39px,#000 42px,transparent 43px)}\n/* glowing arc that fills with value */\n.arc{position:absolute;inset:1px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac) calc(var(--kn)*270deg),rgba(255,236,205,.07) calc(var(--kn)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(3px + var(--kn)*8px) color-mix(in srgb,var(--ac) 70%,transparent));\n  transition:--kn .14s cubic-bezier(.2,.75,.25,1)}\n/* bakelite chicken-head body */\n.body{position:absolute;inset:10px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 28%,#4f4334,#241b12 72%,#140d08);\n  box-shadow:inset 0 2px 7px rgba(0,0,0,.6),inset 0 -2px 4px rgba(255,236,205,.06),0 2px 5px rgba(0,0,0,.55);\n  transform:rotate(calc((var(--kn) - 0.5)*270deg));transition:transform .14s cubic-bezier(.2,.75,.25,1)}\n/* the chicken-head pointer beak */\n.body::before{content:\"\";position:absolute;left:50%;top:-3px;width:0;height:0;margin-left:-7px;\n  border-left:7px solid transparent;border-right:7px solid transparent;\n  border-bottom:20px solid;border-bottom-color:var(--ac2);\n  filter:drop-shadow(0 0 5px var(--ac));border-radius:2px}\n.body::after{content:\"\";position:absolute;inset:38%;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#5a4a36,#1c140d);box-shadow:inset 0 1px 1px rgba(255,236,205,.2)}\n.bub{position:absolute;top:-13px;left:50%;transform:translate(-50%,4px) scale(.8);opacity:0;pointer-events:none;\n  font-size:11px;font-weight:800;color:#1a0f04;background:var(--ac);padding:2px 7px;border-radius:6px;\n  font-variant-numeric:tabular-nums;box-shadow:0 4px 12px rgba(0,0,0,.5);transition:.15s;white-space:nowrap}\n.cell:hover .bub,.knob.act .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n.nm{font-size:10px;letter-spacing:.16em;color:#c9b386;text-transform:uppercase;font-weight:700}\n.val{font-size:12px;color:#fff6e6;font-variant-numeric:tabular-nums;font-weight:800;\n  text-shadow:0 0 8px color-mix(in srgb,var(--ac) 50%,transparent)}\n\n.foot{position:relative;z-index:2;font-size:10.5px;line-height:1.5;color:#8a7656;\n  border-top:1px solid rgba(0,0,0,.5);margin:6px 20px 0;padding:11px 0 14px}\n.foot::before{content:\"TAPE PATH ▸ \";color:var(--ac);letter-spacing:.12em;font-weight:700}\n</style></head><body>\n<div class=\"strip\">\n  <div class=\"head\">\n    <span class=\"screw\"></span>\n    <div class=\"brand\"><b>REEL SATURATOR</b><small>analog tape &middot; warmth processor</small></div>\n    <div class=\"power\"><span class=\"led\"></span>+48 / VU</div>\n    <span class=\"screw\"></span>\n  </div>\n\n  <div class=\"deck\">\n    <div class=\"transport\">\n      <div class=\"reels\">\n        <div class=\"reel r1\"><i class=\"tape\"></i><i class=\"spoke\"></i><i class=\"spoke\"></i><i class=\"spoke\"></i><i class=\"hub\"></i></div>\n        <div class=\"tapepath\"></div>\n        <div class=\"reel r2\"><i class=\"tape\"></i><i class=\"spoke\"></i><i class=\"spoke\"></i><i class=\"spoke\"></i><i class=\"hub\"></i></div>\n      </div>\n    </div>\n\n    <div class=\"vu\">\n      <div class=\"face\">\n        <div class=\"lbl\">V U &nbsp; meter</div>\n        <svg viewBox=\"0 0 200 110\" preserveAspectRatio=\"xMidYMid meet\">\n          <defs>\n            <linearGradient id=\"scale\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#6a5535\"/><stop offset=\"0.7\" stop-color=\"#6a5535\"/>\n              <stop offset=\"0.7\" stop-color=\"#b8341e\"/><stop offset=\"1\" stop-color=\"#b8341e\"/>\n            </linearGradient>\n          </defs>\n          <!-- arc scale -->\n          <path d=\"M22 100 A 88 88 0 0 1 178 100\" fill=\"none\" stroke=\"rgba(0,0,0,.12)\" stroke-width=\"9\"/>\n          <path d=\"M22 100 A 88 88 0 0 1 178 100\" fill=\"none\" stroke=\"url(#scale)\" stroke-width=\"2.5\"/>\n          <!-- ticks -->\n          <g stroke=\"#5a4628\" stroke-width=\"1.4\">\n            <line x1=\"22\" y1=\"100\" x2=\"30\" y2=\"92\"/>\n            <line x1=\"61\" y1=\"64\" x2=\"66\" y2=\"74\"/>\n            <line x1=\"100\" y1=\"52\" x2=\"100\" y2=\"63\"/>\n            <line x1=\"139\" y1=\"64\" x2=\"134\" y2=\"74\"/>\n            <line x1=\"178\" y1=\"100\" x2=\"170\" y2=\"92\"/>\n          </g>\n          <text x=\"100\" y=\"46\" text-anchor=\"middle\" font-size=\"9\" fill=\"#7a3020\" font-weight=\"700\">0</text>\n          <text x=\"28\" y=\"92\" font-size=\"8\" fill=\"#6a5535\">-20</text>\n          <text x=\"160\" y=\"92\" font-size=\"8\" fill=\"#7a3020\">+3</text>\n          <!-- red overload glow -->\n          <path class=\"glassglow\" d=\"M139 64 A 88 88 0 0 1 178 100\" fill=\"none\" stroke=\"#ff4a2a\" stroke-width=\"3\" opacity=\"0\"/>\n          <!-- needle -->\n          <g class=\"needle\" id=\"needle\">\n            <line x1=\"100\" y1=\"100\" x2=\"100\" y2=\"20\" stroke=\"#1a120a\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n            <line x1=\"100\" y1=\"100\" x2=\"100\" y2=\"20\" stroke=\"#c8341e\" stroke-width=\"1\" stroke-linecap=\"round\"/>\n          </g>\n          <circle cx=\"100\" cy=\"100\" r=\"6\" fill=\"#2a2014\" stroke=\"#6a5535\" stroke-width=\"1\"/>\n        </svg>\n        <div class=\"vutxt\">dB</div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"controls\" id=\"controls\">\n    <div class=\"cell\" style=\"--d:0ms\"   data-i=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.45\" data-step=\"0.001\" data-var=\"--drive\"  data-fmt=\"pct\">\n      <div class=\"knob\"><i class=\"ring\"></i><i class=\"arc\"></i><i class=\"body\"></i><span class=\"bub\"></span></div>\n      <div class=\"nm\">Drive</div><div class=\"val\"></div></div>\n    <div class=\"cell\" style=\"--d:70ms\"  data-i=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.4\"  data-step=\"0.001\" data-var=\"--warmth\" data-fmt=\"pct\">\n      <div class=\"knob\"><i class=\"ring\"></i><i class=\"arc\"></i><i class=\"body\"></i><span class=\"bub\"></span></div>\n      <div class=\"nm\">Warmth</div><div class=\"val\"></div></div>\n    <div class=\"cell\" style=\"--d:140ms\" data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.35\" data-step=\"0.001\" data-var=\"--bump\"   data-fmt=\"pct\">\n      <div class=\"knob\"><i class=\"ring\"></i><i class=\"arc\"></i><i class=\"body\"></i><span class=\"bub\"></span></div>\n      <div class=\"nm\">Bump</div><div class=\"val\"></div></div>\n    <div class=\"cell\" style=\"--d:210ms\" data-i=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"1\"    data-step=\"0.001\" data-var=\"--mix\"    data-fmt=\"pct\">\n      <div class=\"knob\"><i class=\"ring\"></i><i class=\"arc\"></i><i class=\"body\"></i><span class=\"bub\"></span></div>\n      <div class=\"nm\">Mix</div><div class=\"val\"></div></div>\n    <div class=\"cell\" style=\"--d:280ms\" data-i=\"4\" data-min=\"0\" data-max=\"1\" data-def=\"0.7\"  data-step=\"0.001\" data-var=\"--out\"    data-fmt=\"pct\">\n      <div class=\"knob\"><i class=\"ring\"></i><i class=\"arc\"></i><i class=\"body\"></i><span class=\"bub\"></span></div>\n      <div class=\"nm\">Output</div><div class=\"val\"></div></div>\n  </div>\n\n  <div class=\"foot\">15 ips &middot; tanh soft-saturation, head-bump &amp; wow. Drag a knob, double-click to reset.</div>\n</div>\n\n<script>\n(function(){\n  var root=document.documentElement;\n  // live VU drive: blend of drive*mix*output so the needle reacts to the dial\n  var levels={drive:0.45,mix:1,out:0.7};\n\n  function fmtPct(v){ return Math.round(v*100)+'%'; }\n\n  function bindKnob(c){\n    var i=+c.dataset.i, mn=+c.dataset.min, mx=+c.dataset.max, def=+c.dataset.def,\n        step=+c.dataset.step||0.001, cssVar=c.dataset.var;\n    var val=def,\n        knob=c.querySelector('.knob'), arc=c.querySelector('.arc'),\n        body=c.querySelector('.body'), out=c.querySelector('.val'), bub=c.querySelector('.bub');\n    function norm(){ return (val-mn)/((mx-mn)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--kn',n);\n      body.style.setProperty('--kn',n);\n      if(cssVar) root.style.setProperty(cssVar, n.toFixed(3));\n      var t=fmtPct(n);\n      out.textContent=t; bub.textContent=t;\n      if(cssVar==='--drive') levels.drive=n;\n      if(cssVar==='--mix')   levels.mix=n;\n      if(cssVar==='--out')   levels.out=n;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,val);\n    }\n    function setN(n){ n=n<0?0:(n>1?1:n); var v=mn+(mx-mn)*n; v=Math.round(v/step)*step;\n      v=v<mn?mn:(v>mx?mx:v); val=v; paint(); }\n    knob.addEventListener('pointerdown',function(e){ knob._d=1; knob._y=e.clientY; knob._n=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault(); });\n    knob.addEventListener('pointermove',function(e){ if(!knob._d)return; setN(knob._n+(knob._y-e.clientY)/200); });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ val=def; paint(); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.02:-0.02)); },{passive:false});\n    paint();\n  }\n\n  // ===== animated VU needle =====\n  var needle=document.getElementById('needle'), glow=document.querySelector('.glassglow');\n  var disp=0, t0=performance.now();\n  function tick(now){\n    var dt=(now-t0)/1000; t0=now;\n    // simulated programme level: signal energy driven by drive*mix*output + gentle wow\n    var target=levels.drive*0.85*levels.mix*(0.4+levels.out*0.7);\n    var wow=0.05*Math.sin(now/520)+0.03*Math.sin(now/170+1.3);\n    target=Math.max(0,Math.min(1.08, target+ (target>0.05?wow:0)));\n    // ballistic-ish smoothing\n    disp += (target-disp)*Math.min(1,dt*7);\n    // map 0..1.08 -> -45deg .. +52deg\n    var deg=-45 + disp*89;\n    needle.style.transform='rotate('+deg.toFixed(2)+'deg)';\n    if(glow) glow.style.opacity = disp>0.78 ? Math.min(0.6,(disp-0.78)*3).toFixed(2) : 0;\n    requestAnimationFrame(tick);\n  }\n  requestAnimationFrame(tick);\n\n  function ready(){\n    var cells=document.querySelectorAll('.cell');\n    for(var j=0;j<cells.length;j++) bindKnob(cells[j]);\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  REEL SATURATOR — tape-style saturation / warmth processor\n//  Drive feeds a tanh-style soft saturation (2x oversampled to tame\n//  aliasing), wrapped by a low-frequency head-bump resonance and a\n//  gentle high-frequency rolloff (Warmth). A very subtle wow modulates\n//  a fractional delay for tape motion. Adds even/odd harmonics plus a\n//  touch of program-dependent compression. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel state\nconst warmState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // HF rolloff one-pole LP\nconst dcState:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker LP\nconst dcPrev:     StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker prev input\nconst bumpLP:     StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low band extractor\nconst bumpZ:      StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // resonator state z1\nconst bumpZ2:     StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // resonator state z2\nconst envState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // compression envelope\nconst upPrev:     StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // 2x upsample interp prev\n\n// wow delay line (short, fractional). ~30 ms max at 96k => 2880 samples; use 4096.\nconst WOW_LEN: i32 = 4096;\nconst wowBuf:  StaticArray<f32> = new StaticArray<f32>(WOW_LEN * MAX_CHANNELS);\nconst wowPos:  StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nlet wowPhase: f32 = 0.0;   // shared LFO phase (mono modulation keeps stereo coherent)\n\nconst P_DRIVE:  i32 = 0;  // 0..1 -> input gain into saturator\nconst P_WARMTH: i32 = 1;  // 0..1 -> HF rolloff amount (more = darker)\nconst P_BUMP:   i32 = 2;  // 0..1 -> low head-bump amount\nconst P_MIX:    i32 = 3;  // 0..1 dry/wet\nconst P_OUTPUT: i32 = 4;  // 0..1 -> output trim 0..1.5\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    warmState[c] = 0.0; dcState[c] = 0.0; dcPrev[c] = 0.0;\n    bumpLP[c] = 0.0; bumpZ[c] = 0.0; bumpZ2[c] = 0.0;\n    envState[c] = 0.0; upPrev[c] = 0.0; wowPos[c] = 0;\n  }\n  for (let i = 0; i < WOW_LEN * MAX_CHANNELS; i++) wowBuf[i] = 0.0;\n  wowPhase = 0.0;\n  params[P_DRIVE] = 0.45; params[P_WARMTH] = 0.4; params[P_BUMP] = 0.35;\n  params[P_MIX] = 1.0; params[P_OUTPUT] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// tanh-style soft saturation, slightly asymmetric for even harmonics (tape bias)\n@inline function tapeSat(x: f32): f32 {\n  // mild asymmetry: bias shifts the curve so even harmonics appear\n  const b: f32 = x + 0.06;\n  const t: f32 = f32(Mathf.tanh(b)) - f32(Mathf.tanh(0.06)); // remove DC offset of bias\n  return t;\n}\n\nexport function process(n: i32): void {\n  const driveN:  f32 = clampf(params[P_DRIVE],  0.0, 1.0);\n  const warmthN: f32 = clampf(params[P_WARMTH], 0.0, 1.0);\n  const bumpN:   f32 = clampf(params[P_BUMP],   0.0, 1.0);\n  const mix:     f32 = clampf(params[P_MIX],    0.0, 1.0);\n  const outTrim: f32 = clampf(params[P_OUTPUT], 0.0, 1.0) * 1.25;\n\n  // Drive: 1x .. ~12x into the saturator\n  const drive: f32 = 1.0 + driveN * 11.0;\n  // makeup so harder drive doesn't merely get louder; tanh limits to ~1\n  const comp: f32 = 1.0 / (1.0 + driveN * 1.1);\n\n  // Warmth: HF rolloff corner sweeps 18kHz (open) down to ~2.2kHz (dark)\n  const nyq: f32 = sampleRate * 0.5;\n  let warmHz: f32 = 18000.0 - warmthN * 15800.0;\n  if (warmHz > nyq * 0.9) warmHz = nyq * 0.9;\n  if (warmHz < 500.0) warmHz = 500.0;\n  const warmCoef: f32 = f32(1.0 - Mathf.exp(-TWO_PI * warmHz / sampleRate));\n\n  // Bump: a gentle resonant low boost around ~90 Hz (tape head bump)\n  const bumpHz: f32 = 90.0;\n  const w0: f32 = TWO_PI * bumpHz / sampleRate;\n  const cosw: f32 = f32(Mathf.cos(w0));\n  const sinw: f32 = f32(Mathf.sin(w0));\n  // low-band extractor (one-pole LP) to feed the resonator\n  const lowHz: f32 = 220.0;\n  const lowCoef: f32 = f32(1.0 - Mathf.exp(-TWO_PI * lowHz / sampleRate));\n  const bumpAmt: f32 = bumpN * 1.6; // gain of the added low band\n\n  // simple resonant bandpass (biquad) coeffs for the bump, modest Q\n  const Q: f32 = 0.8;\n  const alpha: f32 = sinw / (2.0 * Q);\n  const b0: f32 = alpha;\n  const b2: f32 = -alpha;\n  const a0: f32 = 1.0 + alpha;\n  const a1: f32 = -2.0 * cosw;\n  const a2: f32 = 1.0 - alpha;\n  const inv_a0: f32 = a0 != 0.0 ? 1.0 / a0 : 1.0;\n  const rb0: f32 = b0 * inv_a0;\n  const rb2: f32 = b2 * inv_a0;\n  const ra1: f32 = a1 * inv_a0;\n  const ra2: f32 = a2 * inv_a0;\n\n  // DC blocker coef\n  const dcR: f32 = 0.9985;\n\n  // Wow modulation: ~0.7 Hz, small depth in samples; base delay keeps headroom\n  const wowRate: f32 = 0.7;\n  const wowInc: f32 = TWO_PI * wowRate / sampleRate;\n  const baseDelay: f32 = 0.004 * sampleRate;   // ~4 ms nominal\n  const wowDepth: f32 = 0.0018 * sampleRate;   // ~1.8 ms swing -> subtle wow\n\n  // compression: gentle program-dependent gain reduction after saturation\n  const envAtk: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.005 * sampleRate)));\n  const envRel: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.120 * sampleRate)));\n\n  // oversample-up coefficient (half-band-ish one-pole smoother on upsampled stream)\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const wbase: i32 = c * WOW_LEN;\n\n    let warm: f32 = warmState[c];\n    let dcL: f32 = dcState[c];\n    let dcP: f32 = dcPrev[c];\n    let lpL: f32 = bumpLP[c];\n    let z1: f32 = bumpZ[c];\n    let z2: f32 = bumpZ2[c];\n    let env: f32 = envState[c];\n    let up: f32 = upPrev[c];\n    let wp: i32 = wowPos[c];\n    let phase: f32 = wowPhase; // local copy; channel 0 commits, others read same start\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // ---- input gain into saturator ----\n      const driven: f32 = x * drive;\n\n      // ---- 2x oversampled tape saturation ----\n      // sample A: midpoint between previous and current input (linear interp)\n      const mid: f32 = 0.5 * (up + driven);\n      const sA: f32 = tapeSat(mid);\n      const sB: f32 = tapeSat(driven);\n      up = driven;\n      // decimate: average the two half-rate samples (acts as a cheap LP)\n      let sat: f32 = 0.5 * (sA + sB) * comp;\n\n      // ---- DC blocker (tape bias asymmetry leaves a small DC term) ----\n      const dcOut: f32 = sat - dcP + dcR * dcL;\n      dcP = sat;\n      dcL = dcOut;\n      sat = dcOut;\n\n      // ---- high-frequency rolloff (warmth) ----\n      warm = warm + warmCoef * (sat - warm);\n      let shaped: f32 = warm;\n\n      // ---- low head-bump ----\n      // extract a low band, run through resonant BP, add back\n      lpL = lpL + lowCoef * (shaped - lpL);\n      // resonant bandpass on the low band, transposed direct form II\n      // coeffs: rb0, rb1(=0), rb2, ra1, ra2  (a0 normalised)\n      const bpOut: f32 = rb0 * lpL + z1;\n      z1 = -ra1 * bpOut + z2;        // rb1 == 0\n      z2 = rb2 * lpL - ra2 * bpOut;\n      shaped = shaped + bumpAmt * bpOut;\n\n      // ---- gentle compression (after harmonics) ----\n      const rect: f32 = shaped < 0.0 ? -shaped : shaped;\n      const coef: f32 = rect > env ? envAtk : envRel;\n      env = env + coef * (rect - env);\n      // soft-knee gain reduction above ~0.5\n      let gr: f32 = 1.0;\n      if (env > 0.5) {\n        const over: f32 = env - 0.5;\n        gr = 1.0 / (1.0 + over * 0.6); // mild ratio\n      }\n      shaped = shaped * gr;\n\n      // ---- wow: write to delay, read fractional modulated tap ----\n      wowBuf[wbase + wp] = shaped;\n      const lfo: f32 = f32(Mathf.sin(phase));\n      let dly: f32 = baseDelay + lfo * wowDepth;\n      if (dly < 1.0) dly = 1.0;\n      if (dly > f32(WOW_LEN - 2)) dly = f32(WOW_LEN - 2);\n      let rPos: f32 = f32(wp) - dly;\n      while (rPos < 0.0) rPos += f32(WOW_LEN);\n      const i0: i32 = i32(rPos);\n      const frac: f32 = rPos - f32(i0);\n      let i1: i32 = i0 + 1;\n      if (i1 >= WOW_LEN) i1 -= WOW_LEN;\n      const wowOut: f32 = wowBuf[wbase + i0] * (1.0 - frac) + wowBuf[wbase + i1] * frac;\n\n      wp++;\n      if (wp >= WOW_LEN) wp = 0;\n      phase += wowInc;\n      if (phase >= TWO_PI) phase -= TWO_PI;\n\n      // final safety soft-limiter keeps peaks bounded even fully cranked\n      const lim: f32 = f32(Mathf.tanh(wowOut * 0.85)) * 1.12;\n      const wet: f32 = lim * outTrim;\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    warmState[c] = warm;\n    dcState[c] = dcL;\n    dcPrev[c] = dcP;\n    bumpLP[c] = lpL;\n    bumpZ[c] = z1;\n    bumpZ2[c] = z2;\n    envState[c] = env;\n    upPrev[c] = up;\n    wowPos[c] = wp;\n    // advance shared phase from channel 0's run so both channels stay coherent\n    if (c == 0) wowPhase = phase;\n  }\n}\n",
  "publishedAt": 1751000025000
}