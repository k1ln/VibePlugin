{
  "format": 1,
  "name": "Duo Synth",
  "isInstrument": true,
  "explanation": "A duophonic analog lead synthesizer. Two sawtooth oscillators independently track the two most recent held notes (lowest note -> OSC 1, newest -> OSC 2), so two keys sound as two distinct pitches; a single key locks both oscillators together. An optional hard-sync resets OSC 2 to OSC 1 for a buzzy, formant-rich tone, and the pair feeds a shared resonant 4-pole low-pass swept by one ADSR for a sharp, punchy character. Controls: Detune, Sync, Cutoff, Resonance, Env Amount, Attack, Release and Level.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.18
    },
    {
      "name": "Sync",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Cutoff",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.42
    },
    {
      "name": "Resonance",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "EnvAmt",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Attack",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.05
    },
    {
      "name": "Release",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Duo Synth</title>\n<style>\n  :root{\n    --acc:#d4b04a;          /* gold */\n    --acc-hi:#f5e3a0;       /* bright gold */\n    --acc-dim:#7a6322;      /* dim gold */\n    --panel:#2a2a2a;        /* chassis */\n    --panel-d:#171717;\n    --panel-l:#383838;\n    --slot:#0c0c0c;\n    --ink:#0a0a0a;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}\n  html,body{height:100%}\n  body{\n    background:radial-gradient(130% 100% at 50% -20%, #2c2c2c 0%, #1a1a1a 50%, #050505 100%);\n    color:#cfc7b0;\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    letter-spacing:.02em;\n  }\n\n  /* ===================== CHASSIS ===================== */\n  .panel{\n    position:relative;\n    width:760px;height:432px;\n    border-radius:10px;\n    padding:16px 20px 18px;\n    background:\n      linear-gradient(180deg,#3a3a3a 0%,#262626 4%,#2a2a2a 6%,#222 55%,#1b1b1b 96%,#101010 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.10) inset,\n      0 -2px 8px rgba(0,0,0,.7) inset,\n      0 26px 60px rgba(0,0,0,.7),\n      0 2px 0 #000;\n    overflow:hidden;\n  }\n  /* faint vertical brushed grain */\n  .panel::before{\n    content:\"\";position:absolute;inset:0;border-radius:10px;pointer-events:none;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.022) 0 1px,rgba(0,0,0,.05) 1px 3px);\n    mix-blend-mode:overlay;opacity:.6;\n  }\n  /* gold hairline border */\n  .panel::after{\n    content:\"\";position:absolute;inset:5px;border-radius:7px;pointer-events:none;\n    border:1px solid rgba(212,176,74,.18);\n    box-shadow:0 0 0 1px rgba(0,0,0,.4) inset;\n  }\n  .screw{position:absolute;width:11px;height:11px;border-radius:50%;z-index:5;\n    background:radial-gradient(circle at 35% 30%,#5a5a5a,#2a2a2a 60%,#0c0c0c 100%);\n    box-shadow:0 1px 1px rgba(0,0,0,.7),0 0 0 1px rgba(212,176,74,.12) inset;}\n  .screw::after{content:\"\";position:absolute;inset:2.5px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#000 44% 56%,transparent 56%);transform:rotate(38deg)}\n  .screw.tl{top:8px;left:8px}.screw.tr{top:8px;right:8px}\n  .screw.bl{bottom:8px;left:8px}.screw.br{bottom:8px;right:8px}\n\n  /* ===================== HEADER ===================== */\n  .head{display:flex;align-items:center;justify-content:space-between;margin:0 4px 12px;height:50px}\n  .brand{display:flex;flex-direction:column;line-height:1;position:relative}\n  .brand .sub{font-size:8px;letter-spacing:.46em;color:var(--acc-dim);font-weight:700;margin-bottom:6px;text-transform:uppercase}\n  .brand .name{font-size:27px;font-weight:800;letter-spacing:.02em;color:#e8e0c8;\n    text-shadow:0 1px 0 #000,0 0 1px rgba(0,0,0,.6)}\n  .brand .name b{color:var(--acc);font-weight:800;\n    text-shadow:0 0 10px rgba(212,176,74,.45),0 1px 0 #000}\n  .duo-tag{font-size:7.5px;letter-spacing:.34em;color:#7c7458;margin-top:5px;font-weight:700}\n\n  /* mini dual-voice oscilloscope */\n  .scope{\n    position:relative;width:248px;height:50px;border-radius:5px;\n    background:linear-gradient(180deg,#0a0a0a,#000);\n    border:1px solid #000;\n    box-shadow:0 0 0 1px rgba(212,176,74,.16),0 2px 5px rgba(0,0,0,.7) inset;\n    overflow:hidden;\n  }\n  .scope canvas{position:absolute;inset:0;width:100%;height:100%;display:block}\n  .scope .grid{position:absolute;inset:0;pointer-events:none;\n    background:\n      repeating-linear-gradient(90deg,rgba(212,176,74,.06) 0 1px,transparent 1px 16px),\n      repeating-linear-gradient(0deg,rgba(212,176,74,.06) 0 1px,transparent 1px 12px);}\n  .scope .tag{position:absolute;top:3px;left:6px;font-size:7px;letter-spacing:.18em;\n    color:var(--acc);font-weight:700;text-shadow:0 0 5px rgba(212,176,74,.7)}\n  .scope .tag2{position:absolute;top:3px;right:6px;font-size:7px;letter-spacing:.12em;\n    color:#6a6450;font-weight:700}\n\n  /* ===================== VOICE LANES ===================== */\n  .lanes{display:flex;gap:14px;margin:0 4px 12px}\n  .lane{\n    flex:1;position:relative;border-radius:7px;padding:7px 10px 8px;\n    background:linear-gradient(180deg,#202020,#161616);\n    box-shadow:0 1px 0 rgba(255,255,255,.05) inset,0 2px 5px rgba(0,0,0,.55) inset;\n    border:1px solid #000;\n  }\n  .lane-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:6px}\n  .lane-h .lab{font-size:8px;letter-spacing:.26em;font-weight:800;color:#8a825f}\n  .lane-h .lab b{color:var(--acc)}\n  .vu{display:flex;gap:2px;align-items:center}\n  .vu i{width:3px;height:7px;border-radius:1px;background:#2b2b2b;transition:background .08s,box-shadow .08s}\n  .vu i.on{background:var(--acc);box-shadow:0 0 4px var(--acc)}\n  .vu i.hot{background:var(--acc-hi);box-shadow:0 0 6px var(--acc-hi)}\n  /* moving pitch bar for each voice */\n  .lane-bar{position:relative;height:14px;border-radius:3px;overflow:hidden;\n    background:#0a0a0a;box-shadow:0 1px 2px rgba(0,0,0,.6) inset}\n  .lane-bar i{position:absolute;top:0;bottom:0;width:9px;border-radius:2px;\n    background:linear-gradient(180deg,var(--acc-hi),var(--acc));\n    box-shadow:0 0 8px rgba(212,176,74,.6);\n    transition:left .14s cubic-bezier(.4,1.4,.5,1)}\n\n  /* ===================== SLIDER RACK ===================== */\n  .rack{display:grid;grid-template-columns:repeat(8,1fr);gap:0;padding:4px 2px 0;height:208px}\n  .cell{display:flex;flex-direction:column;align-items:center;justify-content:flex-end;position:relative}\n  .cell:not(:last-child)::after{content:\"\";position:absolute;right:0;top:6px;bottom:30px;width:1px;\n    background:linear-gradient(180deg,transparent,rgba(212,176,74,.10),transparent)}\n  .cap{font-size:7.5px;letter-spacing:.12em;text-transform:uppercase;color:#8a825f;font-weight:800;margin-bottom:6px;text-align:center;height:10px}\n\n  /* the slider track */\n  .sl{position:relative;width:30px;height:138px;cursor:ns-resize;touch-action:none}\n  .sl .slot{position:absolute;left:50%;top:4px;bottom:4px;width:6px;transform:translateX(-50%);\n    border-radius:4px;background:linear-gradient(90deg,#000,#1c1c1c,#000);\n    box-shadow:0 1px 2px rgba(0,0,0,.8) inset,0 0 0 1px rgba(212,176,74,.10)}\n  /* gold tick marks beside the slot */\n  .sl .ticks{position:absolute;left:50%;top:4px;bottom:4px;width:24px;transform:translateX(-50%);pointer-events:none}\n  .sl .ticks i{position:absolute;left:0;right:0;height:1px;background:rgba(212,176,74,.20)}\n  /* glowing fill that rises with value */\n  .sl .fill{position:absolute;left:50%;width:6px;transform:translateX(-50%);bottom:4px;\n    border-radius:4px;background:linear-gradient(180deg,var(--acc-hi),var(--acc) 60%,var(--acc-dim));\n    box-shadow:0 0 8px rgba(212,176,74,.55);}\n  /* the fader cap (cap moves) */\n  .sl .knob{position:absolute;left:50%;width:26px;height:16px;transform:translate(-50%,-50%);\n    border-radius:4px;cursor:grab;\n    background:linear-gradient(180deg,#4a4a4a 0%,#2c2c2c 45%,#1a1a1a 55%,#333 100%);\n    box-shadow:0 2px 4px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.14) inset,0 -1px 0 rgba(0,0,0,.5) inset;\n    border:1px solid #000;transition:box-shadow .15s}\n  /* gold indicator line across the cap */\n  .sl .knob::after{content:\"\";position:absolute;left:3px;right:3px;top:50%;height:2px;transform:translateY(-50%);\n    border-radius:2px;background:var(--acc);box-shadow:0 0 5px var(--acc);opacity:.85;transition:opacity .15s}\n  .sl:hover .knob{box-shadow:0 2px 6px rgba(0,0,0,.7),0 0 10px rgba(212,176,74,.35),0 1px 0 rgba(255,255,255,.18) inset}\n  .sl.drag .knob{cursor:grabbing;box-shadow:0 2px 8px rgba(0,0,0,.8),0 0 16px rgba(212,176,74,.6),0 1px 0 rgba(255,255,255,.2) inset}\n  .sl.drag .knob::after{opacity:1}\n  .sl.drag .fill{box-shadow:0 0 14px rgba(212,176,74,.8)}\n\n  /* value readout */\n  .vbox{margin-top:8px;font-size:9px;font-weight:700;color:var(--acc-hi);\n    background:linear-gradient(180deg,#1a1a1a,#0c0c0c);\n    border:1px solid #000;border-radius:3px;padding:2px 0;min-width:46px;text-align:center;\n    box-shadow:0 0 0 1px rgba(212,176,74,.15),0 1px 2px rgba(0,0,0,.6) inset;\n    text-shadow:0 0 6px rgba(212,176,74,.5);font-variant-numeric:tabular-nums}\n\n  /* SYNC switch (discrete) replaces a fader visually but lives in the rack */\n  .sw{position:relative;width:30px;height:138px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0;cursor:pointer;touch-action:none}\n  .sw .body{position:relative;width:24px;height:70px;border-radius:5px;\n    background:linear-gradient(180deg,#0a0a0a,#1a1a1a);\n    box-shadow:0 1px 2px rgba(0,0,0,.8) inset,0 0 0 1px rgba(212,176,74,.12)}\n  .sw .toggle{position:absolute;left:3px;right:3px;height:30px;border-radius:4px;\n    background:linear-gradient(180deg,#444,#222);border:1px solid #000;\n    box-shadow:0 2px 3px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.12) inset;\n    transition:top .18s cubic-bezier(.5,1.6,.5,1),box-shadow .18s;top:37px}\n  .sw.on .toggle{top:3px;box-shadow:0 2px 6px rgba(0,0,0,.7),0 0 12px rgba(212,176,74,.6),0 1px 0 rgba(255,255,255,.16) inset}\n  .sw .toggle::after{content:\"\";position:absolute;left:4px;right:4px;top:50%;height:2px;transform:translateY(-50%);\n    border-radius:2px;background:#6a6450;transition:background .18s,box-shadow .18s}\n  .sw.on .toggle::after{background:var(--acc);box-shadow:0 0 6px var(--acc)}\n  .sw .marks{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:space-between;padding:6px 0;align-items:center;pointer-events:none}\n  .sw .marks span{font-size:6px;letter-spacing:.1em;color:#6a6450;font-weight:800}\n  .sw.on .marks .u{color:var(--acc)}\n  .sw:not(.on) .marks .d{color:#9a9276}\n\n  .credit{position:absolute;bottom:7px;right:46px;font-size:7px;letter-spacing:.32em;\n    color:#5a543f;font-weight:700}\n  .credit b{color:var(--acc-dim)}\n</style>\n</head>\n<body>\n  <div class=\"panel\" id=\"panel\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <span class=\"sub\">duophonic · analog</span>\n        <span class=\"name\">DUO<b>SYNTH</b></span>\n        <span class=\"duo-tag\">2-VOICE · 2-VCO · 4-POLE VCF</span>\n      </div>\n      <div class=\"scope\">\n        <canvas id=\"scope\" width=\"496\" height=\"100\"></canvas>\n        <div class=\"grid\"></div>\n        <span class=\"tag\" id=\"scTag\">VCO 1+2</span>\n        <span class=\"tag2\" id=\"scTag2\">CUT 042</span>\n      </div>\n    </div>\n\n    <div class=\"lanes\">\n      <div class=\"lane\">\n        <div class=\"lane-h\">\n          <span class=\"lab\">OSC <b>1</b> · LOW NOTE</span>\n          <div class=\"vu\" id=\"vu1\"></div>\n        </div>\n        <div class=\"lane-bar\"><i id=\"bar1\" style=\"left:14%\"></i></div>\n      </div>\n      <div class=\"lane\">\n        <div class=\"lane-h\">\n          <span class=\"lab\">OSC <b>2</b> · NEW NOTE</span>\n          <div class=\"vu\" id=\"vu2\"></div>\n        </div>\n        <div class=\"lane-bar\"><i id=\"bar2\" style=\"left:62%\"></i></div>\n      </div>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n    <div class=\"credit\">VIBE <b>·</b> BOUTIQUE</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  var ACC=\"#d4b04a\", ACC_HI=\"#f5e3a0\";\n\n  // ---- params straight from spec.json (exact indices) ----\n  var PARAMS=[\n    {name:\"Detune\",   index:0, min:0, max:1, def:0.18, fmt:\"semi\"},\n    {name:\"Sync\",     index:1, min:0, max:1, def:0,    fmt:\"sw\"},\n    {name:\"Cutoff\",   index:2, min:0, max:1, def:0.42, fmt:\"hz\"},\n    {name:\"Resonance\",index:3, min:0, max:1, def:0.45, fmt:\"pct\"},\n    {name:\"Env Amt\",  index:4, min:0, max:1, def:0.6,  fmt:\"pct\"},\n    {name:\"Attack\",   index:5, min:0, max:1, def:0.05, fmt:\"ms\"},\n    {name:\"Release\",  index:6, min:0, max:1, def:0.3,  fmt:\"ms\"},\n    {name:\"Level\",    index:7, min:0, max:1, def:0.8,  fmt:\"pct\"}\n  ];\n\n  function clamp(v,a,b){return v<a?a:v>b?b:v;}\n  function fmtVal(p,v){\n    var n=(v-p.min)/(p.max-p.min);\n    switch(p.fmt){\n      case \"pct\": return Math.round(n*100)+\"%\";\n      case \"semi\":return \"+\"+(n*12).toFixed(1)+\"st\";\n      case \"hz\":  return Math.round(30+n*n*11000)+\"Hz\";\n      case \"ms\":  { var ms=Math.round(5+n*n*1900); return ms>=1000?(ms/1000).toFixed(2)+\"s\":ms+\"ms\"; }\n      case \"sw\":  return n>=0.5?\"ON\":\"OFF\";\n      default:    return n.toFixed(2);\n    }\n  }\n\n  var STATE={};\n  PARAMS.forEach(function(p){STATE[p.index]=p.def;});\n\n  var host=window.vstai||null;\n  function send(i,v){ if(host&&host.setParam) host.setParam(i,v); }\n\n  var rack=document.getElementById(\"rack\");\n  var controls=[];\n\n  // ============== SYNC SWITCH (discrete 0/1) ==============\n  function buildSwitch(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var cap=document.createElement(\"div\"); cap.className=\"cap\"; cap.textContent=p.name;\n    var sw=document.createElement(\"div\"); sw.className=\"sw\"; sw.title=\"click to toggle · double-click resets\";\n    sw.innerHTML='<div class=\"body\"><div class=\"marks\"><span class=\"u\">ON</span><span class=\"d\">OFF</span></div><div class=\"toggle\"></div></div>';\n    var vbox=document.createElement(\"div\"); vbox.className=\"vbox\";\n    cell.appendChild(cap); cell.appendChild(sw); cell.appendChild(vbox);\n    rack.appendChild(cell);\n\n    var cur=p.def;\n    function render(){\n      var on=cur>=0.5;\n      sw.classList.toggle(\"on\",on);\n      vbox.textContent=fmtVal(p,cur);\n      STATE[p.index]=cur;\n    }\n    function setVal(v,push){ cur=v>=0.5?1:0; render(); if(push) send(p.index,cur); }\n    render();\n    sw.addEventListener(\"click\",function(e){ setVal(cur>=0.5?0:1,true); e.preventDefault(); });\n    sw.addEventListener(\"dblclick\",function(e){ setVal(p.def,true); e.preventDefault(); e.stopPropagation(); });\n    controls.push({p:p,set:setVal,get:function(){return cur;}});\n  }\n\n  // ============== VERTICAL FADER ==============\n  function buildFader(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var cap=document.createElement(\"div\"); cap.className=\"cap\"; cap.textContent=p.name;\n    var sl=document.createElement(\"div\"); sl.className=\"sl\"; sl.title=\"drag · shift = fine · double-click resets\";\n    var slot=document.createElement(\"div\"); slot.className=\"slot\";\n    var ticks=document.createElement(\"div\"); ticks.className=\"ticks\";\n    for(var t=0;t<=10;t++){ var ti=document.createElement(\"i\"); ti.style.top=(t*10)+\"%\"; ti.style.opacity=(t%5===0)?\".5\":\".22\"; ticks.appendChild(ti); }\n    var fill=document.createElement(\"div\"); fill.className=\"fill\";\n    var knob=document.createElement(\"div\"); knob.className=\"knob\";\n    sl.appendChild(slot); sl.appendChild(ticks); sl.appendChild(fill); sl.appendChild(knob);\n    var vbox=document.createElement(\"div\"); vbox.className=\"vbox\";\n    cell.appendChild(cap); cell.appendChild(sl); cell.appendChild(vbox);\n    rack.appendChild(cell);\n\n    var TRAVEL=130; // px the knob center travels (4px pad top/bottom of 138)\n    var cur=p.def;\n    function render(){\n      var n=(cur-p.min)/(p.max-p.min);\n      var top=4 + (1-n)*TRAVEL; // y of knob center within sl\n      knob.style.top=top+\"px\";\n      fill.style.top=top+\"px\";\n      fill.style.height=(138-4-top)+\"px\";\n      vbox.textContent=fmtVal(p,cur);\n      STATE[p.index]=cur;\n    }\n    function setVal(v,push){ cur=clamp(v,p.min,p.max); render(); if(push) send(p.index,cur); }\n    render();\n\n    var dragging=false,startY=0,startV=0;\n    function onMove(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=startY-y;\n      var fine=e.shiftKey?0.28:1;\n      var span=p.max-p.min;\n      setVal(startV + dy/TRAVEL*span*fine, true);\n      e.preventDefault();\n    }\n    function onUp(){ if(!dragging)return; dragging=false; sl.classList.remove(\"drag\");\n      window.removeEventListener(\"pointermove\",onMove); window.removeEventListener(\"pointerup\",onUp); }\n    sl.addEventListener(\"pointerdown\",function(e){\n      dragging=true; sl.classList.add(\"drag\"); startY=e.clientY; startV=cur;\n      window.addEventListener(\"pointermove\",onMove); window.addEventListener(\"pointerup\",onUp);\n      e.preventDefault();\n    });\n    sl.addEventListener(\"dblclick\",function(e){ setVal(p.def,true); e.preventDefault(); });\n    sl.addEventListener(\"wheel\",function(e){\n      setVal(cur - Math.sign(e.deltaY)*(p.max-p.min)*0.02, true); e.preventDefault();\n    },{passive:false});\n\n    controls.push({p:p,set:setVal,get:function(){return cur;}});\n  }\n\n  PARAMS.forEach(function(p){ if(p.fmt===\"sw\") buildSwitch(p); else buildFader(p); });\n\n  // ============== VU METERS ==============\n  function buildVu(el,count){ var arr=[]; for(var i=0;i<count;i++){ var b=document.createElement(\"i\"); el.appendChild(b); arr.push(b);} return arr; }\n  var vu1=buildVu(document.getElementById(\"vu1\"),7);\n  var vu2=buildVu(document.getElementById(\"vu2\"),7);\n  function setVu(arr,lvl){ for(var i=0;i<arr.length;i++){ var on=(i/arr.length)<lvl; arr[i].className=on?(i>=arr.length-2?\"hot\":\"on\"):\"\"; } }\n\n  // ============== ANIMATION ==============\n  var scope=document.getElementById(\"scope\"), sctx=scope.getContext(\"2d\");\n  var W=scope.width,H=scope.height;\n  var scTag2=document.getElementById(\"scTag2\");\n  var bar1=document.getElementById(\"bar1\"), bar2=document.getElementById(\"bar2\");\n  var t0=performance.now(), phase=0, pitchPhase=0, lastBarT=0;\n\n  function pad3(v){return (\"00\"+Math.round(v*100)).slice(-3);}\n\n  function loop(now){\n    var dt=(now-t0)/1000; t0=now;\n    var detune=STATE[0], sync=STATE[1], cut=STATE[2], reso=STATE[3], envA=STATE[4],\n        atk=STATE[5], rel=STATE[6], lvl=STATE[7];\n\n    scTag2.textContent=\"CUT \"+pad3(cut);\n\n    // animated demo envelope so the panel \"breathes\" like a played note\n    var period=0.6 + atk*1.5 + rel*1.5;\n    phase += dt/period; if(phase>=1) phase-=1;\n    var atkT=clamp(atk*0.45+0.05,0.02,0.5);\n    var demoEnv = phase<atkT ? (phase/atkT) : Math.exp(-(phase-atkT)/(0.12+rel*0.7));\n    demoEnv=clamp(demoEnv,0,1);\n\n    // VU meters track per-voice level (osc2 reflects detune energy)\n    var l1=demoEnv*(0.55+lvl*0.45);\n    var l2=demoEnv*(0.55+lvl*0.45)*(0.7+detune*0.3);\n    setVu(vu1,l1); setVu(vu2,l2);\n\n    // pitch bars wander (decorative voice-tracking); osc2 spreads by detune & locks under sync\n    pitchPhase += dt*0.55;\n    var p1 = 0.5 + Math.sin(pitchPhase)*0.32;\n    var p2 = sync>=0.5 ? p1 : clamp(p1 + 0.10 + detune*0.30, 0.05, 0.92);\n    bar1.style.left=(p1*100).toFixed(1)+\"%\";\n    bar2.style.left=(p2*100).toFixed(1)+\"%\";\n\n    // ---- scope: two saw oscillators through a resonant filter sweep ----\n    sctx.clearRect(0,0,W,H);\n    var cutHz = 0.10 + (cut + envA*demoEnv*(1-cut)); // visual cutoff position\n    var f1=3, f2=3*(1+ (sync>=0.5?0:detune*0.6) ); // osc2 detuned cycles\n    var q=1+reso*9;\n    var amp=(0.28+lvl*0.5);\n\n    var grad=sctx.createLinearGradient(0,0,W,0);\n    grad.addColorStop(0,ACC_HI); grad.addColorStop(1,ACC);\n    sctx.lineWidth=1.6; sctx.strokeStyle=grad;\n    sctx.shadowColor=ACC; sctx.shadowBlur=6;\n    sctx.beginPath();\n    for(var x=0;x<=W;x+=2){\n      var u=x/W;\n      var saw1=2*(((u*f1)+phase)%1)-1;\n      var ph2=sync>=0.5 ? ((u*f1)+phase)%1 : ((u*f2)+phase)%1;\n      var saw2=2*(ph2%1)-1;\n      var osc=(saw1+saw2)*0.5;\n      // resonant ring riding the cutoff\n      var ring=Math.sin(u*f1*Math.PI*2*(1+cutHz*1.2))*Math.exp(-((u*f1)%1)*q*0.5)*reso*demoEnv;\n      var y=(osc*(0.4+cutHz*0.4)+ring*0.5)*amp*(0.4+demoEnv*0.6);\n      var py=H/2 - y*(H*0.42);\n      if(x===0) sctx.moveTo(x,py); else sctx.lineTo(x,py);\n    }\n    sctx.stroke();\n    sctx.shadowBlur=0;\n\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n\n  // ============== HOST WIRING ==============\n  function ready(){ controls.forEach(function(c){ send(c.p.index, c.get()); }); }\n  if(host && host.onReady) host.onReady(ready); else ready();\n\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DUO SYNTH — a duophonic analog instrument\n//  Two sawtooth oscillators that independently track the two most recent\n//  held notes (duophonic allocation: lowest-priority note -> OSC 1, newest\n//  -> OSC 2). With one note held both oscillators lock to it. An optional\n//  hard-sync resets OSC 2's phase to OSC 1 for a buzzy, formant-rich tone.\n//  Both oscillators sum into a shared resonant 4-pole low-pass swept by a\n//  single ADSR (one VCF + one VCA, in the spirit of the classic duo-synth),\n//  giving a sharp, punchy lead. Pure algorithm, no samples, no imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// --- parameter indices ---\nconst P_DETUNE: i32 = 0; // 0..1 -> osc2 spread 0..+12 semitones\nconst P_SYNC:   i32 = 1; // 0/1  -> hard-sync osc2 to osc1\nconst P_CUTOFF: i32 = 2; // 0..1 -> filter base cutoff\nconst P_RES:    i32 = 3; // 0..1 -> filter resonance\nconst P_ENVAMT: i32 = 4; // 0..1 -> how much the envelope opens the filter\nconst P_ATTACK: i32 = 5; // 0..1 -> attack time\nconst P_RELEAS: i32 = 6; // 0..1 -> release time\nconst P_LEVEL:  i32 = 7; // 0..1 -> output level\n\n// --- duophonic note allocation: a tiny held-note stack (most-recent last) ---\nconst MAX_HELD: i32 = 16;\nconst heldIds:  StaticArray<i32> = new StaticArray<i32>(MAX_HELD);\nconst heldHz:   StaticArray<f32> = new StaticArray<f32>(MAX_HELD);\nlet heldCount: i32 = 0;\n\n// --- oscillators ---\nlet phase1: f32 = 0.0;\nlet phase2: f32 = 0.0;\nlet freq1:  f32 = 0.0; // smoothed target Hz for osc 1\nlet freq2:  f32 = 0.0; // smoothed target Hz for osc 2\nlet tgt1:   f32 = 0.0;\nlet tgt2:   f32 = 0.0;\n\n// --- envelope ---\nlet env:   f32 = 0.0;\nlet gate:  i32 = 0;\nlet vel:   f32 = 0.8;\n\n// --- ladder-style 4-pole low-pass state (one shared filter) ---\nlet z1: f32 = 0.0;\nlet z2: f32 = 0.0;\nlet z3: f32 = 0.0;\nlet z4: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  phase1 = 0.0; phase2 = 0.0;\n  freq1 = 0.0; freq2 = 0.0; tgt1 = 0.0; tgt2 = 0.0;\n  env = 0.0; gate = 0; vel = 0.8;\n  z1 = 0.0; z2 = 0.0; z3 = 0.0; z4 = 0.0;\n  heldCount = 0;\n  params[P_DETUNE] = 0.18;\n  params[P_SYNC]   = 0.0;\n  params[P_CUTOFF] = 0.42;\n  params[P_RES]    = 0.45;\n  params[P_ENVAMT] = 0.6;\n  params[P_ATTACK] = 0.05;\n  params[P_RELEAS] = 0.3;\n  params[P_LEVEL]  = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// Duophonic allocation. With the current held-note stack, choose the pitch\n// for each oscillator: OSC 1 = lowest held note, OSC 2 = most-recent (top)\n// held note. With a single note both oscillators track it. Silence (gate 0)\n// is handled by the envelope, not here.\nfunction reallocate(): void {\n  if (heldCount <= 0) { gate = 0; return; }\n\n  // most-recent note = top of stack\n  const topHz: f32 = heldHz[heldCount - 1];\n\n  // lowest held note\n  let loHz: f32 = heldHz[0];\n  for (let i = 1; i < heldCount; i++) {\n    if (heldHz[i] < loHz) loHz = heldHz[i];\n  }\n\n  if (heldCount == 1) {\n    tgt1 = topHz;\n    tgt2 = topHz;\n  } else {\n    tgt1 = loHz;   // OSC 1 holds the lowest note\n    tgt2 = topHz;  // OSC 2 takes the newest note\n  }\n  gate = 1;\n}\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // if this id is already held, drop the old entry first\n  let w: i32 = 0;\n  for (let r = 0; r < heldCount; r++) {\n    if (heldIds[r] != id) {\n      heldIds[w] = heldIds[r];\n      heldHz[w]  = heldHz[r];\n      w++;\n    }\n  }\n  heldCount = w;\n\n  if (heldCount >= MAX_HELD) {\n    // drop the oldest to make room\n    for (let r = 1; r < heldCount; r++) {\n      heldIds[r - 1] = heldIds[r];\n      heldHz[r - 1]  = heldHz[r];\n    }\n    heldCount--;\n  }\n\n  heldIds[heldCount] = id;\n  heldHz[heldCount]  = f > 1.0 ? f : 1.0;\n  heldCount++;\n\n  vel = clampf(v, 0.0, 1.0);\n  if (vel < 0.05) vel = 0.8;\n  reallocate();\n}\n\nexport function noteOff(id: i32): void {\n  let w: i32 = 0;\n  for (let r = 0; r < heldCount; r++) {\n    if (heldIds[r] != id) {\n      heldIds[w] = heldIds[r];\n      heldHz[w]  = heldHz[r];\n      w++;\n    }\n  }\n  heldCount = w;\n  reallocate();\n}\n\nexport function process(n: i32): void {\n  const detune: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const sync:   i32 = params[P_SYNC] >= 0.5 ? 1 : 0;\n  const cutN:   f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resN:   f32 = clampf(params[P_RES], 0.0, 1.0);\n  const envAmt: f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const atkN:   f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const relN:   f32 = clampf(params[P_RELEAS], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // OSC 2 detune: up to +1 octave above its own note (spread the two voices)\n  const detRatio: f32 = f32(Mathf.exp(detune * 0.69314718 * 1.0)); // up to ~ +12 semis\n\n  // envelope rates (per-sample one-pole coefficients)\n  const atkSec: f32 = 0.001 + atkN * atkN * 1.2;          // ~1ms .. ~1.2s\n  const relSec: f32 = 0.005 + relN * relN * 2.0;          // ~5ms .. ~2s\n  const atkC: f32 = f32(1.0 - Mathf.exp(-1.0 / (atkSec * sampleRate)));\n  const relC: f32 = f32(1.0 - Mathf.exp(-1.0 / (relSec * sampleRate)));\n\n  // pitch glide smoothing (very fast — keeps things in tune, kills zipper)\n  const glide: f32 = f32(1.0 - Mathf.exp(-1.0 / (0.004 * sampleRate)));\n\n  // filter resonance feedback (bounded well below self-destruction)\n  const res: f32 = resN * 3.8;\n\n  for (let f = 0; f < n; f++) {\n    // smooth oscillator frequencies toward their allocated targets\n    freq1 += glide * (tgt1 - freq1);\n    freq2 += glide * (tgt2 - freq2);\n\n    // envelope: attack toward vel while gated, release toward 0 when not\n    if (gate == 1) env += atkC * (vel - env);\n    else           env += relC * (0.0 - env);\n    if (env < 0.0) env = 0.0;\n\n    // --- oscillator 1 (saw) ---\n    const inc1: f32 = freq1 / sampleRate;\n    phase1 += inc1;\n    let wrapped1: bool = false;\n    if (phase1 >= 1.0) { phase1 -= 1.0; wrapped1 = true; }\n    const saw1: f32 = phase1 * 2.0 - 1.0;\n\n    // --- oscillator 2 (saw, detuned, optionally hard-synced to osc1) ---\n    const inc2: f32 = (freq2 * detRatio) / sampleRate;\n    phase2 += inc2;\n    if (phase2 >= 1.0) phase2 -= 1.0;\n    if (sync == 1 && wrapped1) phase2 = phase1;  // hard sync reset\n    const saw2: f32 = phase2 * 2.0 - 1.0;\n\n    // mix the two oscillators\n    let mix: f32 = (saw1 + saw2) * 0.5;\n\n    // --- shared resonant 4-pole low-pass (ladder approximation) ---\n    // envelope opens the filter; base cutoff + env modulation\n    const fenv: f32 = cutN + envAmt * env * (1.0 - cutN);\n    let fc: f32 = fenv;\n    if (fc < 0.0) fc = 0.0; if (fc > 1.0) fc = 1.0;\n    // map normalized cutoff to a one-pole coefficient (musical, exp-ish)\n    const cutHz: f32 = 30.0 + fc * fc * 11000.0;\n    let g: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * cutHz / sampleRate));\n    if (g > 0.99) g = 0.99;\n\n    // resonance feedback from the 4th stage\n    let inp: f32 = mix - res * z4;\n    // mild saturation on the feedback path keeps resonance bounded & analog\n    inp = inp - (inp * inp * inp) * 0.16;\n\n    z1 += g * (inp - z1);\n    z2 += g * (z1 - z2);\n    z3 += g * (z2 - z3);\n    z4 += g * (z3 - z4);\n\n    const filtered: f32 = z4;\n\n    let s: f32 = filtered * env * vel * level * 1.6;\n    // final safety clip — keep peak under ~1.0\n    if (s > 1.0) s = 1.0; else if (s < -1.0) s = -1.0;\n\n    outBuf[f] = s;\n    outBuf[MAX_FRAMES + f] = s;\n  }\n}\n",
  "publishedAt": 1751000065000
}