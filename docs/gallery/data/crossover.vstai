{
  "format": 1,
  "name": "Crossover",
  "isInstrument": false,
  "explanation": "A phase-coherent 3-band splitter. Two 4th-order Linkwitz-Riley crossovers divide the signal into low, mid and high bands that sum back flat at unity gain; per-band gain trims let you re-balance the spectrum like a 3-way mixer. Controls: Low Freq, High Freq, Low Gain, Mid Gain, High Gain.",
  "params": [
    {
      "name": "Low Freq",
      "index": 0,
      "min": 40,
      "max": 500,
      "default": 200
    },
    {
      "name": "High Freq",
      "index": 1,
      "min": 800,
      "max": 12000,
      "default": 2000
    },
    {
      "name": "Low Gain",
      "index": 2,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "Mid Gain",
      "index": 3,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "High Gain",
      "index": 4,
      "min": 0,
      "max": 2,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Crossover</title>\n<style>\n  :root {\n    --accent:  #8fb6ff;\n    --accent2: #b0e0ff;\n    --low:     #6e8cff;\n    --mid:     #62d0c8;\n    --high:    #f0b65e;\n    --bg0:     #0a0d16;\n    --bg1:     #11162400;\n    --panel:   #131a2b;\n    --panel2:  #0d1320;\n    --line:    #243149;\n    --txt:     #d7e2f5;\n    --txt-dim: #7c8aa6;\n    --shadow:  rgba(0,0,0,0.55);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    background:\n      radial-gradient(1200px 600px at 50% -10%, #18223a 0%, var(--bg0) 60%),\n      var(--bg0);\n    color: var(--txt);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n    min-height: 100%;\n  }\n\n  body {\n    padding: 18px;\n    display: flex;\n    justify-content: center;\n  }\n\n  .shell {\n    width: 100%;\n    max-width: 760px;\n    background: linear-gradient(180deg, var(--panel) 0%, var(--panel2) 100%);\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    box-shadow:\n      0 30px 70px var(--shadow),\n      inset 0 1px 0 rgba(255,255,255,0.05);\n    overflow: hidden;\n  }\n\n  /* ---------- header ---------- */\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 16px 22px 14px;\n    border-bottom: 1px solid var(--line);\n    background: linear-gradient(180deg, rgba(143,182,255,0.07), transparent);\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .logo {\n    width: 34px; height: 34px;\n    position: relative;\n    filter: drop-shadow(0 0 6px rgba(143,182,255,0.5));\n  }\n  .logo span {\n    position: absolute; left: 50%; top: 0;\n    width: 4px; height: 100%;\n    border-radius: 4px;\n    transform-origin: bottom center;\n  }\n  .logo .l1 { background: var(--low);  transform: translateX(-9px) scaleY(.55); }\n  .logo .l2 { background: var(--mid);  transform: translateX(-1px) scaleY(.9); }\n  .logo .l3 { background: var(--high); transform: translateX(7px)  scaleY(.4); }\n  .logo .l1, .logo .l2, .logo .l3 { animation: logoPulse 2.6s ease-in-out infinite; }\n  .logo .l2 { animation-delay: .25s; }\n  .logo .l3 { animation-delay: .5s; }\n\n  @keyframes logoPulse {\n    0%,100% { opacity:.55; }\n    50%     { opacity:1; }\n  }\n\n  .title { line-height: 1.1; }\n  .title h1 {\n    font-size: 17px; letter-spacing: 3px; font-weight: 700; text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text; background-clip: text; color: transparent;\n  }\n  .title .sub {\n    font-size: 9.5px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--txt-dim); margin-top: 3px;\n  }\n\n  .badge {\n    font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid var(--line);\n    padding: 5px 9px; border-radius: 20px;\n    background: rgba(143,182,255,0.06);\n  }\n\n  /* ---------- spectrum / lanes ---------- */\n  .scope {\n    position: relative;\n    height: 180px;\n    margin: 16px 16px 0;\n    border-radius: 12px;\n    background:\n      linear-gradient(180deg, #0c1322, #070b14);\n    border: 1px solid var(--line);\n    box-shadow: inset 0 2px 14px rgba(0,0,0,0.6);\n    overflow: hidden;\n  }\n  .scope svg { display: block; width: 100%; height: 100%; }\n\n  .grid line { stroke: rgba(255,255,255,0.045); stroke-width: 1; }\n\n  .lane-label {\n    font-size: 9px; letter-spacing: 2px; text-transform: uppercase;\n    fill: var(--txt-dim);\n  }\n\n  .xover-handle {\n    cursor: ew-resize;\n  }\n  .xover-line {\n    stroke-dasharray: 4 4;\n    stroke-width: 1.5;\n  }\n\n  /* moving energy particles */\n  .flow {\n    animation: flow 1.9s linear infinite;\n  }\n  @keyframes flow {\n    from { stroke-dashoffset: 0; }\n    to   { stroke-dashoffset: -28; }\n  }\n\n  /* ---------- band strips ---------- */\n  .bands {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 12px;\n    padding: 16px;\n  }\n\n  .band {\n    position: relative;\n    border-radius: 12px;\n    padding: 14px 14px 16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.18));\n    border: 1px solid var(--line);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04), 0 8px 18px rgba(0,0,0,0.35);\n    overflow: hidden;\n  }\n  .band::before {\n    content: \"\";\n    position: absolute; top: 0; left: 0; right: 0; height: 3px;\n    background: var(--c);\n    box-shadow: 0 0 14px var(--c);\n  }\n  .band.low  { --c: var(--low); }\n  .band.mid  { --c: var(--mid); }\n  .band.high { --c: var(--high); }\n\n  .band h3 {\n    font-size: 10px; letter-spacing: 2.5px; text-transform: uppercase;\n    color: var(--txt-dim); margin-bottom: 12px;\n    display: flex; align-items: center; gap: 7px;\n  }\n  .band h3 .dot {\n    width: 7px; height: 7px; border-radius: 50%;\n    background: var(--c); box-shadow: 0 0 8px var(--c);\n  }\n\n  .band-body { display: flex; gap: 14px; align-items: center; }\n\n  /* per-band meter */\n  .meter {\n    width: 10px; height: 110px;\n    border-radius: 6px;\n    background: #070b14;\n    border: 1px solid var(--line);\n    position: relative; overflow: hidden;\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.7);\n    flex: none;\n  }\n  .meter .fill {\n    position: absolute; left: 0; right: 0; bottom: 0;\n    height: 0%;\n    background: linear-gradient(180deg, #fff6, var(--c));\n    box-shadow: 0 0 12px var(--c);\n    transition: height .08s linear;\n  }\n\n  .knob-wrap { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 7px; }\n\n  .knob {\n    width: 84px; height: 84px; position: relative;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { width: 100%; height: 100%; overflow: visible; }\n  .knob .track { stroke: #1d2740; stroke-width: 7; fill: none; }\n  .knob .arc   { stroke: var(--c); stroke-width: 7; fill: none;\n                 stroke-linecap: round; filter: drop-shadow(0 0 5px var(--c)); }\n  .knob .face  { fill: url(#knobGrad); stroke: #2a3established; }\n  .knob .pointer { stroke: var(--c); stroke-width: 3; stroke-linecap: round;\n                   filter: drop-shadow(0 0 4px var(--c)); }\n  .knob.dragging .arc { stroke-width: 8.5; }\n\n  .readout { text-align: center; }\n  .readout .val {\n    font-size: 15px; font-weight: 600;\n    font-variant-numeric: tabular-nums;\n    color: var(--txt);\n  }\n  .readout .unit {\n    font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase;\n    color: var(--txt-dim);\n  }\n\n  /* ---------- crossover frequency row ---------- */\n  .freqs {\n    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;\n    padding: 0 16px 18px;\n  }\n  .freq {\n    border-radius: 12px;\n    padding: 13px 16px;\n    background: linear-gradient(180deg, rgba(143,182,255,0.05), rgba(0,0,0,0.15));\n    border: 1px solid var(--line);\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);\n  }\n  .freq .flabel {\n    display: flex; justify-content: space-between; align-items: baseline;\n    margin-bottom: 9px;\n  }\n  .freq .flabel .name {\n    font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--txt-dim);\n  }\n  .freq .flabel .fval {\n    font-size: 14px; font-weight: 600; font-variant-numeric: tabular-nums; color: var(--accent2);\n  }\n  .fader {\n    position: relative; height: 26px; border-radius: 8px;\n    background: #070b14; border: 1px solid var(--line);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.7);\n    cursor: ew-resize; touch-action: none; overflow: hidden;\n  }\n  .fader .ffill {\n    position: absolute; left: 0; top: 0; bottom: 0; width: 50%;\n    background: linear-gradient(90deg, rgba(143,182,255,0.15), rgba(176,224,255,0.4));\n  }\n  .fader .fcap {\n    position: absolute; top: 50%; left: 50%;\n    width: 6px; height: 70%;\n    transform: translate(-50%, -50%);\n    border-radius: 3px;\n    background: linear-gradient(180deg, #fff, var(--accent));\n    box-shadow: 0 0 10px var(--accent), 0 2px 4px rgba(0,0,0,0.6);\n  }\n\n  footer {\n    padding: 11px 22px 16px;\n    border-top: 1px solid var(--line);\n    display: flex; justify-content: space-between; align-items: center;\n    font-size: 9px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--txt-dim);\n  }\n  footer .hint { color: #5a677f; text-transform: none; letter-spacing: .3px; font-size: 10px; }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"logo\"><span class=\"l1\"></span><span class=\"l2\"></span><span class=\"l3\"></span></div>\n        <div class=\"title\">\n          <h1>Crossover</h1>\n          <div class=\"sub\">Linkwitz · Riley &nbsp;3-Band Splitter</div>\n        </div>\n      </div>\n      <div class=\"badge\">Phase Coherent</div>\n    </header>\n\n    <!-- spectrum scope with coloured lanes + draggable crossover handles -->\n    <div class=\"scope\">\n      <svg id=\"scope\" viewBox=\"0 0 700 180\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"lowFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"var(--low)\" stop-opacity=\"0.55\"/>\n            <stop offset=\"1\" stop-color=\"var(--low)\" stop-opacity=\"0.04\"/>\n          </linearGradient>\n          <linearGradient id=\"midFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"var(--mid)\" stop-opacity=\"0.55\"/>\n            <stop offset=\"1\" stop-color=\"var(--mid)\" stop-opacity=\"0.04\"/>\n          </linearGradient>\n          <linearGradient id=\"highFill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"var(--high)\" stop-opacity=\"0.55\"/>\n            <stop offset=\"1\" stop-color=\"var(--high)\" stop-opacity=\"0.04\"/>\n          </linearGradient>\n        </defs>\n\n        <g class=\"grid\" id=\"grid\"></g>\n\n        <!-- filled band areas -->\n        <path id=\"lowArea\"  fill=\"url(#lowFill)\"  d=\"\"/>\n        <path id=\"midArea\"  fill=\"url(#midFill)\"  d=\"\"/>\n        <path id=\"highArea\" fill=\"url(#highFill)\" d=\"\"/>\n\n        <!-- band response outlines -->\n        <path id=\"lowCurve\"  fill=\"none\" stroke=\"var(--low)\"  stroke-width=\"2\" class=\"flow\" stroke-dasharray=\"3 25\"/>\n        <path id=\"midCurve\"  fill=\"none\" stroke=\"var(--mid)\"  stroke-width=\"2\" class=\"flow\" stroke-dasharray=\"3 25\"/>\n        <path id=\"highCurve\" fill=\"none\" stroke=\"var(--high)\" stroke-width=\"2\" class=\"flow\" stroke-dasharray=\"3 25\"/>\n\n        <!-- crossover handles -->\n        <g id=\"xoverLo\" class=\"xover-handle\">\n          <line class=\"xover-line\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"180\" stroke=\"var(--accent)\"/>\n          <rect x=\"-8\" y=\"74\" width=\"16\" height=\"32\" rx=\"4\" fill=\"var(--panel)\" stroke=\"var(--accent)\"/>\n          <line x1=\"-3\" y1=\"82\" x2=\"-3\" y2=\"98\" stroke=\"var(--accent)\" stroke-width=\"1\"/>\n          <line x1=\"3\"  y1=\"82\" x2=\"3\"  y2=\"98\" stroke=\"var(--accent)\" stroke-width=\"1\"/>\n        </g>\n        <g id=\"xoverHi\" class=\"xover-handle\">\n          <line class=\"xover-line\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"180\" stroke=\"var(--accent2)\"/>\n          <rect x=\"-8\" y=\"74\" width=\"16\" height=\"32\" rx=\"4\" fill=\"var(--panel)\" stroke=\"var(--accent2)\"/>\n          <line x1=\"-3\" y1=\"82\" x2=\"-3\" y2=\"98\" stroke=\"var(--accent2)\" stroke-width=\"1\"/>\n          <line x1=\"3\"  y1=\"82\" x2=\"3\"  y2=\"98\" stroke=\"var(--accent2)\" stroke-width=\"1\"/>\n        </g>\n\n        <text class=\"lane-label\" id=\"lblLow\"  x=\"0\" y=\"166\">Low</text>\n        <text class=\"lane-label\" id=\"lblMid\"  x=\"0\" y=\"166\" text-anchor=\"middle\">Mid</text>\n        <text class=\"lane-label\" id=\"lblHigh\" x=\"0\" y=\"166\" text-anchor=\"end\">High</text>\n      </svg>\n    </div>\n\n    <!-- per-band gain strips -->\n    <div class=\"bands\">\n      <div class=\"band low\">\n        <h3><span class=\"dot\"></span>Low Gain</h3>\n        <div class=\"band-body\">\n          <div class=\"meter\"><div class=\"fill\" id=\"mLow\"></div></div>\n          <div class=\"knob-wrap\">\n            <div class=\"knob\" id=\"kLow\" data-idx=\"2\"></div>\n            <div class=\"readout\"><div class=\"val\" id=\"vLow\">0.0</div><div class=\"unit\">dB</div></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"band mid\">\n        <h3><span class=\"dot\"></span>Mid Gain</h3>\n        <div class=\"band-body\">\n          <div class=\"meter\"><div class=\"fill\" id=\"mMid\"></div></div>\n          <div class=\"knob-wrap\">\n            <div class=\"knob\" id=\"kMid\" data-idx=\"3\"></div>\n            <div class=\"readout\"><div class=\"val\" id=\"vMid\">0.0</div><div class=\"unit\">dB</div></div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"band high\">\n        <h3><span class=\"dot\"></span>High Gain</h3>\n        <div class=\"band-body\">\n          <div class=\"meter\"><div class=\"fill\" id=\"mHigh\"></div></div>\n          <div class=\"knob-wrap\">\n            <div class=\"knob\" id=\"kHigh\" data-idx=\"4\"></div>\n            <div class=\"readout\"><div class=\"val\" id=\"vHigh\">0.0</div><div class=\"unit\">dB</div></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <!-- crossover frequency faders -->\n    <div class=\"freqs\">\n      <div class=\"freq\">\n        <div class=\"flabel\"><span class=\"name\">Low / Mid Split</span><span class=\"fval\" id=\"fvLo\">200 Hz</span></div>\n        <div class=\"fader\" id=\"fLo\" data-idx=\"0\"><div class=\"ffill\" id=\"ffLo\"></div><div class=\"fcap\" id=\"fcLo\"></div></div>\n      </div>\n      <div class=\"freq\">\n        <div class=\"flabel\"><span class=\"name\">Mid / High Split</span><span class=\"fval\" id=\"fvHi\">2.0 kHz</span></div>\n        <div class=\"fader\" id=\"fHi\" data-idx=\"1\"><div class=\"ffill\" id=\"ffHi\"></div><div class=\"fcap\" id=\"fcHi\"></div></div>\n      </div>\n    </div>\n\n    <footer>\n      <span>Crossover · LR4</span>\n      <span class=\"hint\">Drag controls · double-click to reset</span>\n    </footer>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices match spec.json) ----------------------\n  var PARAMS = {\n    lowFreq:  { idx: 0, min: 40,  max: 500,   def: 200,  log: true  },\n    highFreq: { idx: 1, min: 800, max: 12000, def: 2000, log: true  },\n    lowGain:  { idx: 2, min: 0,   max: 2,     def: 1,    log: false },\n    midGain:  { idx: 3, min: 0,   max: 2,     def: 1,    log: false },\n    highGain: { idx: 4, min: 0,   max: 2,     def: 1,    log: false }\n  };\n\n  var state = {\n    lowFreq: 200, highFreq: 2000,\n    lowGain: 1, midGain: 1, highGain: 1\n  };\n\n  // ---- host bridge ----------------------------------------------------\n  function push(idx, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(idx, value);\n    }\n  }\n\n  function clamp(v, lo, hi) { return v < lo ? lo : (v > hi ? hi : v); }\n\n  // map a 0..1 position to a value (linear or log)\n  function fromNorm(p, t) {\n    t = clamp(t, 0, 1);\n    if (p.log) {\n      var lo = Math.log(p.min), hi = Math.log(p.max);\n      return Math.exp(lo + (hi - lo) * t);\n    }\n    return p.min + (p.max - p.min) * t;\n  }\n  function toNorm(p, v) {\n    if (p.log) {\n      var lo = Math.log(p.min), hi = Math.log(p.max);\n      return (Math.log(clamp(v, p.min, p.max)) - lo) / (hi - lo);\n    }\n    return (clamp(v, p.min, p.max) - p.min) / (p.max - p.min);\n  }\n\n  function gainToDb(g) {\n    if (g <= 0.0001) return -60;\n    return 20 * Math.log10(g);\n  }\n  function fmtDb(g) {\n    var d = gainToDb(g);\n    if (d <= -59.5) return \"-inf\";\n    return (d >= 0 ? \"+\" : \"\") + d.toFixed(1);\n  }\n  function fmtHz(hz) {\n    if (hz >= 1000) return (hz / 1000).toFixed(hz >= 9950 ? 0 : 1) + \" kHz\";\n    return Math.round(hz) + \" Hz\";\n  }\n\n  // ====================================================================\n  //  KNOBS (band gains)\n  // ====================================================================\n  var KNOB_R = 33, KNOB_CX = 42, KNOB_CY = 42;\n  var A0 = 135, A1 = 405; // sweep from 135deg to 405deg (270 total), clockwise\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(cx, cy, r, a0, a1) {\n    var s = polar(cx, cy, r, a0), e = polar(cx, cy, r, a1);\n    var large = (a1 - a0) % 360 > 180 ? 1 : 0;\n    return \"M \" + s[0] + \" \" + s[1] + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + e[0] + \" \" + e[1];\n  }\n\n  function buildKnob(el, key) {\n    var p = PARAMS[key];\n    el.innerHTML =\n      '<svg viewBox=\"0 0 84 84\">' +\n        '<defs>' +\n          '<radialGradient id=\"kg_' + key + '\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n            '<stop offset=\"0\" stop-color=\"#1c2740\"/>' +\n            '<stop offset=\"1\" stop-color=\"#0a0f1c\"/>' +\n          '</radialGradient>' +\n        '</defs>' +\n        '<path class=\"track\" d=\"' + arcPath(KNOB_CX, KNOB_CY, KNOB_R, A0, A1) + '\"/>' +\n        '<path class=\"arc\"   d=\"\"/>' +\n        '<circle class=\"face\" cx=\"42\" cy=\"42\" r=\"25\" fill=\"url(#kg_' + key + ')\" stroke=\"#2a3a58\"/>' +\n        '<line class=\"pointer\" x1=\"42\" y1=\"42\" x2=\"42\" y2=\"22\"/>' +\n      '</svg>';\n    var arc = el.querySelector(\".arc\");\n    var ptr = el.querySelector(\".pointer\");\n\n    function render() {\n      var t = toNorm(p, state[key]);\n      var ang = A0 + (A1 - A0) * t;\n      if (t > 0.001) arc.setAttribute(\"d\", arcPath(KNOB_CX, KNOB_CY, KNOB_R, A0, ang));\n      else arc.setAttribute(\"d\", \"\");\n      var pp = polar(KNOB_CX, KNOB_CY, 20, ang);\n      ptr.setAttribute(\"x2\", pp[0]); ptr.setAttribute(\"y2\", pp[1]);\n    }\n\n    var dragging = false, lastY = 0;\n    function setFromDelta(dy) {\n      var t = toNorm(p, state[key]);\n      t = clamp(t - dy / 180, 0, 1);\n      state[key] = fromNorm(p, t);\n      push(p.idx, state[key]);\n      render();\n      refreshReadouts();\n      drawScope();\n    }\n    el.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; lastY = e.clientY; el.classList.add(\"dragging\");\n      el.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    el.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = e.clientY - lastY; lastY = e.clientY;\n      setFromDelta(dy);\n    });\n    function end() { dragging = false; el.classList.remove(\"dragging\"); }\n    el.addEventListener(\"pointerup\", end);\n    el.addEventListener(\"pointercancel\", end);\n    el.addEventListener(\"dblclick\", function () {\n      state[key] = p.def; push(p.idx, state[key]); render(); refreshReadouts(); drawScope();\n    });\n    el.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      var t = toNorm(p, state[key]);\n      t = clamp(t - (e.deltaY > 0 ? 0.02 : -0.02), 0, 1);\n      state[key] = fromNorm(p, t);\n      push(p.idx, state[key]); render(); refreshReadouts(); drawScope();\n    }, { passive: false });\n\n    return { render: render };\n  }\n\n  // ====================================================================\n  //  FADERS (crossover frequencies)\n  // ====================================================================\n  function buildFader(el, key, fillEl, capEl) {\n    var p = PARAMS[key];\n    function render() {\n      var t = toNorm(p, state[key]);\n      fillEl.style.width = (t * 100) + \"%\";\n      capEl.style.left = (t * 100) + \"%\";\n    }\n    var dragging = false;\n    function setFromEvent(e) {\n      var r = el.getBoundingClientRect();\n      var t = clamp((e.clientX - r.left) / r.width, 0, 1);\n      state[key] = fromNorm(p, t);\n      push(p.idx, state[key]);\n      render(); refreshReadouts(); drawScope();\n    }\n    el.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; el.setPointerCapture(e.pointerId); setFromEvent(e); e.preventDefault();\n    });\n    el.addEventListener(\"pointermove\", function (e) { if (dragging) setFromEvent(e); });\n    function end() { dragging = false; }\n    el.addEventListener(\"pointerup\", end);\n    el.addEventListener(\"pointercancel\", end);\n    el.addEventListener(\"dblclick\", function () {\n      state[key] = p.def; push(p.idx, state[key]); render(); refreshReadouts(); drawScope();\n    });\n    return { render: render };\n  }\n\n  // ====================================================================\n  //  READOUTS\n  // ====================================================================\n  var vLow = document.getElementById(\"vLow\");\n  var vMid = document.getElementById(\"vMid\");\n  var vHigh = document.getElementById(\"vHigh\");\n  var fvLo = document.getElementById(\"fvLo\");\n  var fvHi = document.getElementById(\"fvHi\");\n\n  function refreshReadouts() {\n    vLow.textContent  = fmtDb(state.lowGain);\n    vMid.textContent  = fmtDb(state.midGain);\n    vHigh.textContent = fmtDb(state.highGain);\n    fvLo.textContent  = fmtHz(state.lowFreq);\n    fvHi.textContent  = fmtHz(state.highFreq);\n  }\n\n  // ====================================================================\n  //  SCOPE — three coloured band response curves + crossover handles\n  // ====================================================================\n  var SCW = 700, SCH = 180;\n  var FMIN = 20, FMAX = 20000;\n  var lnFmin = Math.log(FMIN), lnFmax = Math.log(FMAX);\n\n  function hzToX(hz) {\n    return ((Math.log(clamp(hz, FMIN, FMAX)) - lnFmin) / (lnFmax - lnFmin)) * SCW;\n  }\n\n  // build log-frequency grid lines once\n  (function buildGrid() {\n    var g = document.getElementById(\"grid\");\n    var marks = [50, 100, 200, 500, 1000, 2000, 5000, 10000];\n    var html = \"\";\n    for (var i = 0; i < marks.length; i++) {\n      var x = hzToX(marks[i]);\n      html += '<line x1=\"' + x + '\" y1=\"0\" x2=\"' + x + '\" y2=\"180\"/>';\n    }\n    for (var y = 30; y < 180; y += 36) {\n      html += '<line x1=\"0\" y1=\"' + y + '\" x2=\"700\" y2=\"' + y + '\"/>';\n    }\n    g.innerHTML = html;\n  })();\n\n  // LR4 magnitude approximations (in dB-ish shape) for the curve drawing.\n  // We don't need exact filter math for the visual — a smooth 24 dB/oct\n  // roll model around each crossover is faithful enough.\n  function lpMag(hz, fc) {\n    var r = hz / fc;\n    return 1 / Math.sqrt(1 + Math.pow(r, 8)); // ~4th order\n  }\n  function hpMag(hz, fc) {\n    var r = fc / hz;\n    return 1 / Math.sqrt(1 + Math.pow(r, 8));\n  }\n\n  var elLowCurve  = document.getElementById(\"lowCurve\");\n  var elMidCurve  = document.getElementById(\"midCurve\");\n  var elHighCurve = document.getElementById(\"highCurve\");\n  var elLowArea   = document.getElementById(\"lowArea\");\n  var elMidArea   = document.getElementById(\"midArea\");\n  var elHighArea  = document.getElementById(\"highArea\");\n  var xLoG = document.getElementById(\"xoverLo\");\n  var xHiG = document.getElementById(\"xoverHi\");\n\n  function buildBand(magFn) {\n    var N = 90;\n    var line = \"\", area = \"M 0 180\";\n    for (var i = 0; i <= N; i++) {\n      var t = i / N;\n      var hz = Math.exp(lnFmin + (lnFmax - lnFmin) * t);\n      var m = magFn(hz);\n      var y = 170 - clamp(m, 0, 1.4) * 120; // 0 at bottom, gain scales up\n      var x = t * SCW;\n      line += (i === 0 ? \"M \" : \"L \") + x.toFixed(1) + \" \" + y.toFixed(1) + \" \";\n      area += \" L \" + x.toFixed(1) + \" \" + y.toFixed(1);\n    }\n    area += \" L 700 180 Z\";\n    return { line: line, area: area };\n  }\n\n  function drawScope() {\n    var lo = state.lowFreq, hi = state.highFreq;\n    var gL = state.lowGain, gM = state.midGain, gH = state.highGain;\n\n    var low  = buildBand(function (hz) { return lpMag(hz, lo) * gL; });\n    var mid  = buildBand(function (hz) { return hpMag(hz, lo) * lpMag(hz, hi) * gM; });\n    var high = buildBand(function (hz) { return hpMag(hz, hi) * gH; });\n\n    elLowCurve.setAttribute(\"d\", low.line);\n    elMidCurve.setAttribute(\"d\", mid.line);\n    elHighCurve.setAttribute(\"d\", high.line);\n    elLowArea.setAttribute(\"d\", low.area);\n    elMidArea.setAttribute(\"d\", mid.area);\n    elHighArea.setAttribute(\"d\", high.area);\n\n    var xLo = hzToX(lo), xHi = hzToX(hi);\n    xLoG.setAttribute(\"transform\", \"translate(\" + xLo + \",0)\");\n    xHiG.setAttribute(\"transform\", \"translate(\" + xHi + \",0)\");\n\n    // position lane labels in the middle of each band\n    document.getElementById(\"lblLow\").setAttribute(\"x\", Math.max(8, xLo * 0.5));\n    document.getElementById(\"lblMid\").setAttribute(\"x\", (xLo + xHi) / 2);\n    document.getElementById(\"lblHigh\").setAttribute(\"x\", Math.min(692, (xHi + SCW) / 2 + 60));\n  }\n\n  // dragging the crossover handles on the scope\n  function makeXoverDrag(g, key) {\n    var p = PARAMS[key];\n    var dragging = false;\n    function setFromEvent(e) {\n      var svg = document.getElementById(\"scope\");\n      var r = svg.getBoundingClientRect();\n      var px = (e.clientX - r.left) / r.width * SCW;\n      var hz = Math.exp(lnFmin + (lnFmax - lnFmin) * clamp(px / SCW, 0, 1));\n      state[key] = clamp(hz, p.min, p.max);\n      push(p.idx, state[key]);\n      drawScope(); refreshReadouts();\n      faders[key === \"lowFreq\" ? \"lo\" : \"hi\"].render();\n    }\n    g.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; g.setPointerCapture(e.pointerId); setFromEvent(e); e.preventDefault();\n    });\n    g.addEventListener(\"pointermove\", function (e) { if (dragging) setFromEvent(e); });\n    function end() { dragging = false; }\n    g.addEventListener(\"pointerup\", end);\n    g.addEventListener(\"pointercancel\", end);\n    g.addEventListener(\"dblclick\", function () {\n      state[key] = p.def; push(p.idx, state[key]); drawScope(); refreshReadouts();\n      faders[key === \"lowFreq\" ? \"lo\" : \"hi\"].render();\n    });\n  }\n\n  // ====================================================================\n  //  ANIMATED METERS — band level driven by gain + a gentle living wobble\n  // ====================================================================\n  var mLow = document.getElementById(\"mLow\");\n  var mMid = document.getElementById(\"mMid\");\n  var mHigh = document.getElementById(\"mHigh\");\n  var phase = 0;\n  var lvl = { low: 0, mid: 0, high: 0 };\n\n  function tick() {\n    if (!document.hidden) {\n      phase += 0.06;\n      // pseudo band energy: a wobble modulated by that band's gain\n      var bL = (0.55 + 0.4 * Math.sin(phase * 1.3)) * state.lowGain;\n      var bM = (0.5 + 0.45 * Math.sin(phase * 1.9 + 1.1)) * state.midGain;\n      var bH = (0.45 + 0.5 * Math.sin(phase * 2.6 + 2.3)) * state.highGain;\n      lvl.low  += (clamp(bL, 0, 1.4) - lvl.low)  * 0.2;\n      lvl.mid  += (clamp(bM, 0, 1.4) - lvl.mid)  * 0.2;\n      lvl.high += (clamp(bH, 0, 1.4) - lvl.high) * 0.2;\n      mLow.style.height  = clamp(lvl.low  / 1.4 * 100, 0, 100) + \"%\";\n      mMid.style.height  = clamp(lvl.mid  / 1.4 * 100, 0, 100) + \"%\";\n      mHigh.style.height = clamp(lvl.high / 1.4 * 100, 0, 100) + \"%\";\n    }\n    requestAnimationFrame(tick);\n  }\n\n  // ====================================================================\n  //  BOOT\n  // ====================================================================\n  var knobs = {};\n  var faders = {};\n\n  function init() {\n    knobs.low  = buildKnob(document.getElementById(\"kLow\"),  \"lowGain\");\n    knobs.mid  = buildKnob(document.getElementById(\"kMid\"),  \"midGain\");\n    knobs.high = buildKnob(document.getElementById(\"kHigh\"), \"highGain\");\n\n    faders.lo = buildFader(document.getElementById(\"fLo\"), \"lowFreq\",\n                           document.getElementById(\"ffLo\"), document.getElementById(\"fcLo\"));\n    faders.hi = buildFader(document.getElementById(\"fHi\"), \"highFreq\",\n                           document.getElementById(\"ffHi\"), document.getElementById(\"fcHi\"));\n\n    makeXoverDrag(xLoG, \"lowFreq\");\n    makeXoverDrag(xHiG, \"highFreq\");\n\n    // render everything + push defaults to the engine\n    knobs.low.render(); knobs.mid.render(); knobs.high.render();\n    faders.lo.render(); faders.hi.render();\n    refreshReadouts();\n    drawScope();\n\n    push(PARAMS.lowFreq.idx,  state.lowFreq);\n    push(PARAMS.highFreq.idx, state.highFreq);\n    push(PARAMS.lowGain.idx,  state.lowGain);\n    push(PARAMS.midGain.idx,  state.midGain);\n    push(PARAMS.highGain.idx, state.highGain);\n\n    requestAnimationFrame(tick);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  CROSSOVER — phase-coherent 3-band splitter (Linkwitz-Riley style)\n//\n//  The signal is split into LOW / MID / HIGH by two 4th-order\n//  Linkwitz-Riley crossovers (each = two cascaded 2nd-order Butterworth\n//  sections), which sum back to a flat, phase-coherent response. Each band\n//  gets its own gain trim, then the three bands are recombined. At unity\n//  gains the output equals the input; lifting or dropping a band gain tilts\n//  the spectral balance like a 3-way mixer. Pure algorithm, no samples.\n//\n//  LR4 detail: a low-pass LR4 = LP2·LP2, a high-pass LR4 = HP2·HP2. To keep\n//  the three bands phase-aligned the standard trick is used: the HIGH band is\n//  derived from the LOW-crossover high-pass, and the MID is the band between\n//  the two crossovers. We also pass the LOW band through the high crossover's\n//  low-pass-complement to keep phase coherent when both crossovers act.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// Parameter indices (MUST match spec.json + the GUI's setParam calls)\nconst P_LOW_FREQ:  i32 = 0; // 40..500 Hz   low/mid split\nconst P_HIGH_FREQ: i32 = 1; // 800..12000 Hz mid/high split\nconst P_LOW_GAIN:  i32 = 2; // 0..2  linear  (-inf..+6 dB)\nconst P_MID_GAIN:  i32 = 3; // 0..2  linear\nconst P_HIGH_GAIN: i32 = 4; // 0..2  linear\n\nconst PI: f32 = 3.14159265358979;\n\n// ---------------------------------------------------------------------\n//  Biquad state. We need, PER CHANNEL, four 2nd-order sections:\n//    A = low crossover  low-pass   (×2 cascade for LR4)\n//    B = low crossover  high-pass  (×2 cascade for LR4)\n//    C = high crossover low-pass   (×2 cascade for LR4)\n//    D = high crossover high-pass  (×2 cascade for LR4)\n//  Each cascade = 2 biquads, so 8 biquads per channel = 16 total.\n//  We store Direct-Form-II transposed states z1,z2 per biquad.\n// ---------------------------------------------------------------------\nconst NSEC: i32 = 8;                       // biquads per channel\nconst z1: StaticArray<f32> = new StaticArray<f32>(NSEC * MAX_CHANNELS);\nconst z2: StaticArray<f32> = new StaticArray<f32>(NSEC * MAX_CHANNELS);\n\n// Coefficients are shared across channels (same cutoff), recomputed when the\n// frequency params move. Two distinct biquad shapes: a low-pass set and a\n// high-pass set, for each of the two crossover frequencies.\nlet loLP_b0: f32 = 0.0; let loLP_b1: f32 = 0.0; let loLP_b2: f32 = 0.0; let loLP_a1: f32 = 0.0; let loLP_a2: f32 = 0.0;\nlet loHP_b0: f32 = 0.0; let loHP_b1: f32 = 0.0; let loHP_b2: f32 = 0.0; let loHP_a1: f32 = 0.0; let loHP_a2: f32 = 0.0;\nlet hiLP_b0: f32 = 0.0; let hiLP_b1: f32 = 0.0; let hiLP_b2: f32 = 0.0; let hiLP_a1: f32 = 0.0; let hiLP_a2: f32 = 0.0;\nlet hiHP_b0: f32 = 0.0; let hiHP_b1: f32 = 0.0; let hiHP_b2: f32 = 0.0; let hiHP_a1: f32 = 0.0; let hiHP_a2: f32 = 0.0;\n\nlet cachedLoFreq: f32 = -1.0;\nlet cachedHiFreq: f32 = -1.0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// Compute a 2nd-order Butterworth low-pass (Q = 1/sqrt(2)) at fc. The pair of\n// cascaded Butterworth low-passes makes a Linkwitz-Riley 4th-order low-pass.\nfunction computeLP(fc: f32): void {\n  const w0: f32  = f32(2.0 * PI * fc / sampleRate);\n  const cw: f32  = f32(Mathf.cos(w0));\n  const sw: f32  = f32(Mathf.sin(w0));\n  const q: f32   = f32(0.70710678);\n  const alpha: f32 = f32(sw / (2.0 * q));\n  const a0: f32  = f32(1.0 + alpha);\n  const inv: f32 = f32(1.0 / a0);\n  loLP_b0 = f32(((1.0 - cw) * 0.5) * inv);\n  loLP_b1 = f32((1.0 - cw) * inv);\n  loLP_b2 = loLP_b0;\n  loLP_a1 = f32((-2.0 * cw) * inv);\n  loLP_a2 = f32((1.0 - alpha) * inv);\n}\n\nfunction computeHP(fc: f32): void {\n  const w0: f32  = f32(2.0 * PI * fc / sampleRate);\n  const cw: f32  = f32(Mathf.cos(w0));\n  const sw: f32  = f32(Mathf.sin(w0));\n  const q: f32   = f32(0.70710678);\n  const alpha: f32 = f32(sw / (2.0 * q));\n  const a0: f32  = f32(1.0 + alpha);\n  const inv: f32 = f32(1.0 / a0);\n  loHP_b0 = f32(((1.0 + cw) * 0.5) * inv);\n  loHP_b1 = f32((-(1.0 + cw)) * inv);\n  loHP_b2 = loHP_b0;\n  loHP_a1 = f32((-2.0 * cw) * inv);\n  loHP_a2 = f32((1.0 - alpha) * inv);\n}\n\n// The above two write into the \"lo*\" globals; we copy them into the hi* set\n// when computing the high crossover. Kept simple to avoid arrays of structs.\nfunction updateCoeffs(loFreq: f32, hiFreq: f32): void {\n  // low crossover\n  computeLP(loFreq);\n  computeHP(loFreq);\n  // high crossover — compute into temporaries by reusing the same routines,\n  // then move them across. Compute HP/LP for hiFreq.\n  const w0: f32  = f32(2.0 * PI * hiFreq / sampleRate);\n  const cw: f32  = f32(Mathf.cos(w0));\n  const sw: f32  = f32(Mathf.sin(w0));\n  const q: f32   = f32(0.70710678);\n  const alpha: f32 = f32(sw / (2.0 * q));\n  const a0: f32  = f32(1.0 + alpha);\n  const inv: f32 = f32(1.0 / a0);\n  hiLP_b0 = f32(((1.0 - cw) * 0.5) * inv);\n  hiLP_b1 = f32((1.0 - cw) * inv);\n  hiLP_b2 = hiLP_b0;\n  hiLP_a1 = f32((-2.0 * cw) * inv);\n  hiLP_a2 = f32((1.0 - alpha) * inv);\n  hiHP_b0 = f32(((1.0 + cw) * 0.5) * inv);\n  hiHP_b1 = f32((-(1.0 + cw)) * inv);\n  hiHP_b2 = hiHP_b0;\n  hiHP_a1 = f32((-2.0 * cw) * inv);\n  hiHP_a2 = f32((1.0 - alpha) * inv);\n}\n\n// One biquad sample, Direct-Form-II transposed, using section index `s`.\n@inline function biquad(x: f32, s: i32,\n                        b0: f32, b1: f32, b2: f32, a1: f32, a2: f32): f32 {\n  const w1: f32 = z1[s];\n  const w2: f32 = z2[s];\n  const y: f32 = f32(b0 * x + w1);\n  z1[s] = f32(b1 * x - a1 * y + w2);\n  z2[s] = f32(b2 * x - a2 * y);\n  return y;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < NSEC * MAX_CHANNELS; i++) { z1[i] = 0.0; z2[i] = 0.0; }\n  params[P_LOW_FREQ]  = 200.0;\n  params[P_HIGH_FREQ] = 2000.0;\n  params[P_LOW_GAIN]  = 1.0;\n  params[P_MID_GAIN]  = 1.0;\n  params[P_HIGH_GAIN] = 1.0;\n  cachedLoFreq = -1.0;\n  cachedHiFreq = -1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  // --- read + clamp params ---\n  let loFreq: f32 = clampf(params[P_LOW_FREQ],  40.0,  500.0);\n  let hiFreq: f32 = clampf(params[P_HIGH_FREQ], 800.0, 12000.0);\n  // keep the two crossovers ordered with a little separation\n  const nyq: f32 = f32(sampleRate * 0.49);\n  if (hiFreq > nyq) hiFreq = nyq;\n  if (loFreq > hiFreq * 0.5) loFreq = hiFreq * 0.5;\n\n  const gLow: f32  = clampf(params[P_LOW_GAIN],  0.0, 2.0);\n  const gMid: f32  = clampf(params[P_MID_GAIN],  0.0, 2.0);\n  const gHigh: f32 = clampf(params[P_HIGH_GAIN], 0.0, 2.0);\n\n  if (loFreq != cachedLoFreq || hiFreq != cachedHiFreq) {\n    updateCoeffs(loFreq, hiFreq);\n    cachedLoFreq = loFreq;\n    cachedHiFreq = hiFreq;\n  }\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const so: i32 = c * NSEC;       // section base for this channel\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // --- LOW crossover: LR4 low-pass (sections 0,1) and high-pass (2,3) ---\n      let lp1: f32 = biquad(x,   so + 0, loLP_b0, loLP_b1, loLP_b2, loLP_a1, loLP_a2);\n      let low: f32 = biquad(lp1, so + 1, loLP_b0, loLP_b1, loLP_b2, loLP_a1, loLP_a2);\n\n      let hp1: f32 = biquad(x,   so + 2, loHP_b0, loHP_b1, loHP_b2, loHP_a1, loHP_a2);\n      let highband: f32 = biquad(hp1, so + 3, loHP_b0, loHP_b1, loHP_b2, loHP_a1, loHP_a2);\n\n      // --- HIGH crossover splits the upper band into MID (LR4 LP) + HIGH (LR4 HP) ---\n      let mlp1: f32 = biquad(highband, so + 4, hiLP_b0, hiLP_b1, hiLP_b2, hiLP_a1, hiLP_a2);\n      let mid: f32  = biquad(mlp1,     so + 5, hiLP_b0, hiLP_b1, hiLP_b2, hiLP_a1, hiLP_a2);\n\n      let hhp1: f32 = biquad(highband, so + 6, hiHP_b0, hiHP_b1, hiHP_b2, hiHP_a1, hiHP_a2);\n      let high: f32 = biquad(hhp1,     so + 7, hiHP_b0, hiHP_b1, hiHP_b2, hiHP_a1, hiHP_a2);\n\n      // --- recombine with per-band gains ---\n      const y: f32 = f32(low * gLow + mid * gMid + high * gHigh);\n      outBuf[base + f] = y;\n    }\n  }\n\n  // if mono source filled only channel 0, mirror to channel 1 when host is stereo\n  if (channels < 2) {\n    // nothing — host reads only `channels`\n  }\n}\n",
