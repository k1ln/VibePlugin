{
  "format": 1,
  "name": "Lattice Verb",
  "isInstrument": false,
  "explanation": "A classic algorithmic reverb built from the textbook Schroeder/Moorer topology: four parallel feedback comb filters with prime delay lengths are summed, each with a one-pole high-frequency damper in its feedback path, then passed through two series allpass diffusers that smear the echoes into a smooth, controllable tail. Controls: Mix, Size (scales the comb delay lengths), Decay (comb feedback / RT60), Damping (HF loss per pass) and Pre-Delay.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Size",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Damping",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Pre-Delay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --ac:#34e0c4;        /* teal accent */\n  --ac2:#6ad6ff;       /* cyan highlight */\n  --panel:#0a1620;\n  --panel2:#06101a;\n  --ink:#dffaf6;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(130% 100% at 50% -10%,#0c2330 0%,#081420 50%,#03080d 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:22px;overflow:auto;\n}\n\n.unit{\n  position:relative;\n  width:min(560px,96vw);\n  border-radius:22px;\n  padding:20px 22px 22px;\n  background:\n    linear-gradient(165deg,#102634 0%,var(--panel) 42%,var(--panel2) 100%);\n  box-shadow:\n    0 40px 90px -24px rgba(0,0,0,.8),\n    0 1px 0 rgba(120,230,255,.14) inset,\n    0 -26px 50px -22px rgba(0,0,0,.6) inset,\n    0 0 0 1px rgba(0,0,0,.5),\n    0 0 0 4px #04101a,\n    0 0 0 5px rgba(80,230,210,.06);\n  animation:rise .7s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(24px) scale(.97)}to{opacity:1;transform:none}}\n\n/* faint engraved circuit texture */\n.unit::before{\n  content:\"\";position:absolute;inset:0;border-radius:22px;pointer-events:none;\n  background:\n    repeating-linear-gradient(90deg,rgba(106,214,255,.025) 0 1px,transparent 1px 26px),\n    radial-gradient(150% 70% at 30% 0%,rgba(120,240,255,.12),transparent 55%);\n  mix-blend-mode:screen;opacity:.55;\n}\n\n/* ===== header ===== */\n.head{position:relative;display:flex;align-items:flex-end;justify-content:space-between;margin:0 2px 14px}\n.brand{font-size:9px;letter-spacing:.42em;color:#7fd9d2;opacity:.7;text-transform:uppercase}\nh1{\n  margin:2px 0 0;font-size:25px;font-weight:900;letter-spacing:.01em;line-height:1;\n  background:linear-gradient(180deg,#eafffb,var(--ac) 55%,#1aa9b9);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  filter:drop-shadow(0 2px 7px rgba(40,200,200,.4));\n}\n.sub{font-size:8.5px;letter-spacing:.26em;color:#76c9d6;opacity:.65;text-transform:uppercase;margin-top:4px}\n.rt{display:flex;flex-direction:column;align-items:flex-end;gap:4px}\n.rtled{display:flex;align-items:center;gap:6px;font-size:7.5px;letter-spacing:.22em;color:#8fe3da;opacity:.75;text-transform:uppercase}\n.rtdot{width:8px;height:8px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#dffff8,var(--ac) 50%,#0a4a44 90%);\n  box-shadow:0 0 10px var(--ac);animation:dotpulse 2.4s ease-in-out infinite}\n@keyframes dotpulse{0%,100%{opacity:.55;box-shadow:0 0 5px var(--ac)}50%{opacity:1;box-shadow:0 0 14px var(--ac)}}\n\n/* ===== the lattice visualiser ===== */\n.viz{\n  position:relative;height:180px;margin:2px 0 18px;border-radius:14px;overflow:hidden;\n  background:\n    radial-gradient(120% 150% at 25% 120%,#06222a,#02080d 72%);\n  box-shadow:0 0 0 1px rgba(0,0,0,.6),\n             0 0 0 2px rgba(106,214,255,.08),\n             inset 0 2px 14px rgba(0,0,0,.85),\n             inset 0 0 44px rgba(52,224,196,.08);\n}\n.viz svg{position:absolute;inset:0;width:100%;height:100%}\n.viz::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:linear-gradient(180deg,rgba(255,255,255,.08),transparent 26%)}\n\n.glow{filter:drop-shadow(0 0 5px var(--ac))}\n/* comb rail base line */\n.rail{stroke:rgba(106,214,255,.16);stroke-width:1.4}\n/* node tick on each comb line (the tapped delay points) */\n.tick{stroke:rgba(106,214,255,.30);stroke-width:1.4}\n/* glowing energy pulse travelling down each comb line */\n.pulse{fill:var(--ac);filter:drop-shadow(0 0 6px var(--ac))}\n/* feedback return arc */\n.fb{fill:none;stroke:var(--ac);stroke-width:1.6;opacity:.5;\n  stroke-dasharray:4 6;animation:fbflow 1.4s linear infinite}\n@keyframes fbflow{to{stroke-dashoffset:-20}}\n/* allpass diffuser rings */\n.apring{fill:none;stroke:var(--ac2);stroke-width:2.2;\n  filter:drop-shadow(0 0 7px var(--ac2));transform-origin:center}\n.apring2{fill:none;stroke:var(--ac);stroke-width:1.4;opacity:.45}\n.ringpulse{animation:ringPulse 2.6s ease-in-out infinite}\n@keyframes ringPulse{0%,100%{opacity:.55;transform:scale(.92)}50%{opacity:1;transform:scale(1.04)}}\n.label{fill:#79d4d8;font:7px ui-sans-serif,sans-serif;letter-spacing:.18em;opacity:.55;text-transform:uppercase}\n.sumline{stroke:var(--ac2);stroke-width:1.6;opacity:.6;filter:drop-shadow(0 0 4px var(--ac2))}\n\n/* ===== knob deck ===== */\n.deck{display:grid;grid-template-columns:repeat(5,1fr);gap:6px 8px;margin:0 2px}\n@media (max-width:430px){.deck{grid-template-columns:repeat(3,1fr)}}\n.pot{display:flex;flex-direction:column;align-items:center;gap:7px;\n  animation:pop .5s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:76px;height:76px;cursor:ns-resize;touch-action:none;user-select:none}\n.arc{position:absolute;inset:2px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac) calc(var(--n)*270deg),rgba(120,200,220,.07) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*8px) var(--ac));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1)}\n.skirt{position:absolute;inset:-2px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(150,230,240,.5) 0 1deg,transparent 1deg 13.846deg);\n  -webkit-mask:radial-gradient(circle,transparent 38px,#000 39px,#000 42px,transparent 43px);\n  mask:radial-gradient(circle,transparent 38px,#000 39px,#000 42px,transparent 43px)}\n.cap{position:absolute;top:11px;left:11px;width:54px;height:54px;border-radius:50%;\n  background:radial-gradient(circle at 50% 28%,#1c3340 0%,#0c1922 60%,#06101a 100%);\n  box-shadow:inset 0 2px 6px rgba(140,220,240,.14),inset 0 -6px 14px rgba(0,0,0,.8),0 4px 10px rgba(0,0,0,.55)}\n.cap::before{content:\"\";position:absolute;inset:6px;border-radius:50%;\n  background:repeating-conic-gradient(#152631 0 9deg,#0a141c 9deg 18deg);opacity:.5}\n.cap::after{content:\"\";position:absolute;inset:13px;border-radius:50%;\n  background:radial-gradient(circle at 50% 30%,#274652,#0c1820);\n  box-shadow:inset 0 1px 2px rgba(150,230,240,.2)}\n.ptr{position:absolute;top:7px;left:50%;width:4px;height:20px;margin-left:-2px;border-radius:3px;\n  background:linear-gradient(var(--ac2),var(--ac));\n  box-shadow:0 0 8px var(--ac),0 0 2px #fff;\n  transform-origin:50% 31px;\n  transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.pname{font-size:9px;font-weight:800;letter-spacing:.16em;color:#06181c;\n  background:linear-gradient(var(--ac2),var(--ac));padding:2px 9px;border-radius:999px;\n  text-transform:uppercase;box-shadow:0 1px 0 rgba(255,255,255,.3) inset,0 2px 5px rgba(0,0,0,.4);white-space:nowrap}\n.pval{font-size:11px;font-weight:800;color:#eafffb;font-variant-numeric:tabular-nums;\n  min-height:13px;text-shadow:0 0 8px rgba(52,224,196,.45)}\n.knob.act .cap{box-shadow:inset 0 2px 6px rgba(140,220,240,.14),inset 0 -6px 14px rgba(0,0,0,.8),0 4px 16px rgba(52,224,196,.55)}\n\n.footer{display:flex;justify-content:space-between;align-items:center;margin:16px 4px 0;\n  font-size:7px;letter-spacing:.18em;color:#5fa8b0;opacity:.5;text-transform:uppercase}\n</style>\n</head>\n<body>\n<div class=\"unit\">\n  <div class=\"head\">\n    <div>\n      <div class=\"brand\">Lattice Series</div>\n      <h1>Lattice Verb</h1>\n      <div class=\"sub\">Schroeder / Moorer Algorithmic Reverb</div>\n    </div>\n    <div class=\"rt\">\n      <div class=\"rtled\"><span class=\"rtdot\"></span><span id=\"rtTxt\">RT 1.4s</span></div>\n      <div class=\"rtled\" style=\"opacity:.5\">Comb x4 &middot; AP x2</div>\n    </div>\n  </div>\n\n  <!-- ===== comb + allpass lattice ===== -->\n  <div class=\"viz\">\n    <svg id=\"svg\" viewBox=\"0 0 560 180\" preserveAspectRatio=\"none\">\n      <!-- comb rails + ticks + pulses built by JS -->\n      <g id=\"combs\"></g>\n      <!-- summing bus -->\n      <line id=\"sumv\" class=\"sumline\" x1=\"372\" y1=\"22\" x2=\"372\" y2=\"158\"/>\n      <!-- series allpass diffuser rings -->\n      <g id=\"rings\">\n        <g transform=\"translate(440,90)\">\n          <circle class=\"apring ringpulse glow\" r=\"30\"/>\n          <circle class=\"apring2 ringpulse\" r=\"20\" style=\"animation-delay:.4s\"/>\n          <text class=\"label\" x=\"0\" y=\"52\" text-anchor=\"middle\">Allpass 1</text>\n        </g>\n        <g transform=\"translate(508,90)\">\n          <circle class=\"apring ringpulse glow\" r=\"24\" style=\"animation-delay:.9s\"/>\n          <circle class=\"apring2 ringpulse\" r=\"15\" style=\"animation-delay:1.2s\"/>\n          <text class=\"label\" x=\"0\" y=\"52\" text-anchor=\"middle\">Allpass 2</text>\n        </g>\n      </g>\n      <text class=\"label\" x=\"14\" y=\"14\">Parallel Comb Bank</text>\n    </svg>\n  </div>\n\n  <!-- ===== knob deck ===== -->\n  <div class=\"deck\" id=\"deck\"></div>\n\n  <div class=\"footer\">\n    <span>Algorithmic Reverb</span>\n    <span>LV-4C2A &middot; 8P7SXGP</span>\n  </div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Mix\",      index:0,min:0,max:1,def:0.35},\n    {name:\"Size\",     index:1,min:0,max:1,def:0.5},\n    {name:\"Decay\",    index:2,min:0,max:1,def:0.6},\n    {name:\"Damping\",  index:3,min:0,max:1,def:0.4},\n    {name:\"Pre-Delay\",index:4,min:0,max:1,def:0.0}\n  ];\n  var state={};\n  var deck=document.getElementById('deck');\n  var combsG=document.getElementById('combs');\n  var rtTxt=document.getElementById('rtTxt');\n\n  // ---- build the four comb rails (parallel lines, prime-ish relative lengths) ----\n  var COMB_REL=[1.557,1.617,1.491,1.422];        // relative prime lengths\n  var rails=[];                                   // {len, ticks[], pulse, baseLen}\n  var X0=92, X1=360, NTICK=7;                      // rail span + ticks\n  for(var i=0;i<4;i++){\n    var y=44+i*30;\n    // rail base line\n    var line=document.createElementNS('http://www.w3.org/2000/svg','line');\n    line.setAttribute('class','rail');\n    line.setAttribute('x1',X0); line.setAttribute('y1',y);\n    line.setAttribute('x2',X1); line.setAttribute('y2',y);\n    combsG.appendChild(line);\n    // feedback return arc (tail end loops back to start — the comb feedback)\n    var fb=document.createElementNS('http://www.w3.org/2000/svg','path');\n    fb.setAttribute('class','fb');\n    var arcH=10+i*2;\n    fb.setAttribute('d','M '+X1+' '+y+' C '+(X1+18)+' '+(y-arcH)+', '+(X0-18)+' '+(y-arcH)+', '+X0+' '+y);\n    combsG.appendChild(fb);\n    // ticks\n    var ticks=[];\n    for(var t=0;t<NTICK;t++){\n      var tx=X0+(X1-X0)*(t/(NTICK-1));\n      var tk=document.createElementNS('http://www.w3.org/2000/svg','line');\n      tk.setAttribute('class','tick');\n      tk.setAttribute('x1',tx); tk.setAttribute('y1',y-4);\n      tk.setAttribute('x2',tx); tk.setAttribute('y2',y+4);\n      combsG.appendChild(tk);\n      ticks.push(tk);\n    }\n    // travelling energy pulse\n    var pl=document.createElementNS('http://www.w3.org/2000/svg','circle');\n    pl.setAttribute('class','pulse');\n    pl.setAttribute('cx',X0); pl.setAttribute('cy',y); pl.setAttribute('r',3.2);\n    combsG.appendChild(pl);\n    // input feed line from left edge into the rail\n    var feed=document.createElementNS('http://www.w3.org/2000/svg','line');\n    feed.setAttribute('class','rail'); feed.setAttribute('x1',14); feed.setAttribute('y1',90);\n    feed.setAttribute('x2',X0); feed.setAttribute('y2',y); feed.setAttribute('opacity','.18');\n    combsG.appendChild(feed);\n    // output tap to sum bus\n    var tap=document.createElementNS('http://www.w3.org/2000/svg','line');\n    tap.setAttribute('class','rail'); tap.setAttribute('x1',X1); tap.setAttribute('y1',y);\n    tap.setAttribute('x2',372); tap.setAttribute('y2',90); tap.setAttribute('opacity','.20');\n    combsG.appendChild(tap);\n\n    rails.push({y:y, x0:X0, x1:X1, pulse:pl, ticks:ticks, rel:COMB_REL[i], phase:Math.random(), pos:Math.random()});\n  }\n\n  // ---- knob builder ----\n  function fmt(p,v){\n    var n=(v-p.min)/((p.max-p.min)||1);\n    if(p.name==='Pre-Delay') return Math.round(n*200)+' ms';\n    if(p.name==='Size'){ var m=Math.round((0.55+n*1.05)*100); return m+'%'; }\n    return Math.round(n*100)+'%';\n  }\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*70)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"skirt\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var ptr=cell.querySelector('.ptr');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n);\n      ptr.style.setProperty('--n',n);\n      val.textContent=fmt(p,v);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(n){ n=n<0?0:n>1?1:n; v=p.min+(p.max-p.min)*n; paint(); }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true; startY=e.clientY; startN=norm();\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?620:210;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault(); setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ---- visualiser reacts to params ----\n  function onChange(){\n    var size =state[1]!=null?state[1]:0.5;\n    var decay=state[2]!=null?state[2]:0.6;\n    var damp =state[3]!=null?state[3]:0.4;\n    // approximate RT60 readout (seconds) — scales with size + decay\n    var rt=(0.4+ (0.55+decay*0.4)*2.6*(0.55+size*1.05));\n    rtTxt.textContent='RT '+rt.toFixed(1)+'s';\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  // ---- animation loop: energy pulses crawl down each comb line; speed = size ----\n  var raf=null;\n  function tick(){\n    var size =state[1]!=null?state[1]:0.5;\n    var decay=state[2]!=null?state[2]:0.6;\n    var damp =state[3]!=null?state[3]:0.4;\n    var span=X1-X0;\n    for(var i=0;i<rails.length;i++){\n      var r=rails[i];\n      // longer comb (longer rel * size) -> slower pulse\n      var lenFac=r.rel*(0.55+size*1.05);\n      var spd=0.010/lenFac;\n      r.pos+=spd;\n      if(r.pos>=1){ r.pos-=1; }\n      var x=r.x0+span*r.pos;\n      r.pulse.setAttribute('cx',x.toFixed(1));\n      // brightness fades as pulse travels (decay) and HF damp dims it further\n      var fade=1-r.pos*(1-(0.55+decay*0.4));\n      var op=Math.max(0.25, fade*(1-damp*0.45));\n      r.pulse.setAttribute('opacity',op.toFixed(2));\n      var rad=2.4+ (decay*2.2)*(1-r.pos*0.5);\n      r.pulse.setAttribute('r',rad.toFixed(1));\n    }\n    raf=requestAnimationFrame(tick);\n  }\n  function startLoop(){ if(!raf) raf=requestAnimationFrame(tick); }\n  function stopLoop(){ if(raf){ cancelAnimationFrame(raf); raf=null; } }\n  document.addEventListener('visibilitychange',function(){\n    if(document.hidden) stopLoop(); else startLoop();\n  });\n\n  function ready(){ onChange(); startLoop(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  LATTICE VERB — classic Schroeder/Moorer algorithmic reverb\n//\n//  The textbook topology (NOT an FDN hall):\n//    - 4 PARALLEL feedback COMB filters with prime delay lengths, summed.\n//      Each comb has a one-pole low-pass in its feedback path for\n//      per-comb high-frequency DAMPING (Moorer's lossy combs).\n//    - The comb sum is then fed through 2 SERIES ALLPASS diffusers to\n//      smear the echoes into a smooth metallic-to-smooth tail.\n//    - A pre-delay line offsets the wet signal before the comb bank.\n//\n//  Params: Mix, Size (scales comb delay lengths), Decay (comb feedback /\n//  RT60), Damping (HF loss per pass), Pre-Delay. Mix=0 -> dry. Feedback is\n//  clamped < 1 so the tail always decays. All state is StaticArray at module\n//  scope; process() allocates nothing.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- delay-line buffer sizes (samples @ up to ~48k, with Size headroom) ----\n// Base comb delays (Schroeder primes, in samples at 44.1k). Size scales these\n// up to ~1.7x, and we add a small per-channel offset for stereo de-correlation,\n// so allocate generously.\nconst NUM_COMBS: i32 = 4;\nconst NUM_ALLPASS: i32 = 2;\n\n// max delay any comb line will ever need (longest base * size * sr-scale + spread)\nconst COMB_MAX: i32 = 4096;   // > 1687 * 1.7 * (48000/44100) + spread\nconst AP_MAX: i32 = 1024;     // allpass lines are short\nconst PRE_MAX: i32 = 9600;    // up to 200 ms pre-delay @ 48k\n\n// comb buffers: [channel][comb][COMB_MAX]\nconst combBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_COMBS * COMB_MAX);\nconst combPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_COMBS);\nconst combLen: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_COMBS);\nconst combDamp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_COMBS); // LP state\n\n// allpass buffers: [channel][ap][AP_MAX]\nconst apBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NUM_ALLPASS * AP_MAX);\nconst apPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_ALLPASS);\nconst apLen: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NUM_ALLPASS);\n\n// pre-delay line: [channel][PRE_MAX]\nconst preBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * PRE_MAX);\nconst prePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\n\n// base comb / allpass delay lengths in samples at 44.1k reference\nconst baseComb: StaticArray<f32> = new StaticArray<f32>(NUM_COMBS);\nconst baseAp:   StaticArray<f32> = new StaticArray<f32>(NUM_ALLPASS);\n// per-channel small spread (samples) so L/R aren't identical\nconst chanSpread: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_MIX:    i32 = 0; // 0..1 dry/wet\nconst P_SIZE:   i32 = 1; // 0..1 -> comb length scale\nconst P_DECAY:  i32 = 2; // 0..1 -> feedback gain / RT60\nconst P_DAMP:   i32 = 3; // 0..1 -> HF loss per pass\nconst P_PRE:    i32 = 4; // 0..1 -> 0..200 ms pre-delay\n\nlet sizeScale: f32 = 1.0;     // resolved each block\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function clampi(x: i32, lo: i32, hi: i32): i32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  // Classic Schroeder comb primes (samples @ 44.1k)\n  baseComb[0] = 1557.0;\n  baseComb[1] = 1617.0;\n  baseComb[2] = 1491.0;\n  baseComb[3] = 1422.0;\n  // Series allpass diffuser delays (samples @ 44.1k)\n  baseAp[0] = 225.0;\n  baseAp[1] = 556.0;\n\n  chanSpread[0] = 0.0;\n  chanSpread[1] = 23.0; // few-sample offset on the right for stereo width\n\n  // clear all delay state\n  for (let i = 0; i < MAX_CHANNELS * NUM_COMBS * COMB_MAX; i++) combBuf[i] = 0.0;\n  for (let i = 0; i < MAX_CHANNELS * NUM_ALLPASS * AP_MAX; i++) apBuf[i] = 0.0;\n  for (let i = 0; i < MAX_CHANNELS * PRE_MAX; i++) preBuf[i] = 0.0;\n  for (let i = 0; i < MAX_CHANNELS * NUM_COMBS; i++) { combPos[i] = 0; combDamp[i] = 0.0; }\n  for (let i = 0; i < MAX_CHANNELS * NUM_ALLPASS; i++) apPos[i] = 0;\n  for (let c = 0; c < MAX_CHANNELS; c++) prePos[c] = 0;\n\n  params[P_MIX] = 0.35;\n  params[P_SIZE] = 0.5;\n  params[P_DECAY] = 0.6;\n  params[P_DAMP] = 0.4;\n  params[P_PRE] = 0.0;\n\n  resolveLengths();\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// Compute integer delay lengths from Size and the engine sample rate.\nfunction resolveLengths(): void {\n  const srScale: f32 = sampleRate / 44100.0;\n  const size: f32 = clampf(params[P_SIZE], 0.0, 1.0);\n  // Size scales comb length from 0.55x .. 1.6x of the reference primes\n  sizeScale = 0.55 + size * 1.05;\n\n  for (let c = 0; c < channels; c++) {\n    for (let k = 0; k < NUM_COMBS; k++) {\n      let len: f32 = baseComb[k] * sizeScale * srScale + chanSpread[c];\n      let li: i32 = clampi(i32(len), 16, COMB_MAX - 1);\n      combLen[c * NUM_COMBS + k] = li;\n    }\n    for (let k = 0; k < NUM_ALLPASS; k++) {\n      let len: f32 = baseAp[k] * srScale + chanSpread[c] * 0.3;\n      let li: i32 = clampi(i32(len), 8, AP_MAX - 1);\n      apLen[c * NUM_ALLPASS + k] = li;\n    }\n  }\n}\n\nexport function process(n: i32): void {\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const decay: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const damp: f32 = clampf(params[P_DAMP], 0.0, 1.0);\n  const preN: f32 = clampf(params[P_PRE], 0.0, 1.0);\n\n  resolveLengths();\n\n  // Feedback gain from decay, hard-clamped < 1 so the tail always decays.\n  // 0 -> short room (~0.7), 1 -> long tail (~0.96).\n  const feedback: f32 = clampf(0.70 + decay * 0.262, 0.0, 0.965);\n\n  // Damping low-pass coefficient: more damp -> lower cutoff -> faster HF loss.\n  // dampCoef is the LP \"keep\" amount of the previous sample.\n  const dampCoef: f32 = clampf(0.05 + damp * 0.85, 0.0, 0.95);\n  const inputGain: f32 = 1.0 - dampCoef; // normalise the one-pole\n\n  // pre-delay in samples (0..200 ms)\n  const preSamplesF: f32 = preN * 0.200 * sampleRate;\n  const preSamples: i32 = clampi(i32(preSamplesF), 0, PRE_MAX - 1);\n\n  // output normalisation: combs sum in parallel -> divide by count, gentle trim\n  const combNorm: f32 = 0.30; // keeps wet peak well under 1.0\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const preBase: i32 = c * PRE_MAX;\n    let pp: i32 = prePos[c];\n\n    for (let f = 0; f < n; f++) {\n      const dry: f32 = inBuf[base + f];\n\n      // ---- pre-delay ----\n      preBuf[preBase + pp] = dry;\n      let rp: i32 = pp - preSamples;\n      if (rp < 0) rp += PRE_MAX;\n      const preOut: f32 = preBuf[preBase + rp];\n      pp++; if (pp >= PRE_MAX) pp = 0;\n\n      // ---- parallel comb bank with per-comb HF damping in feedback ----\n      let combSum: f32 = 0.0;\n      for (let k = 0; k < NUM_COMBS; k++) {\n        const ci: i32 = c * NUM_COMBS + k;\n        const cbBase: i32 = ci * COMB_MAX;\n        const len: i32 = combLen[ci];\n        let pos: i32 = combPos[ci];\n\n        const y: f32 = combBuf[cbBase + pos]; // delayed output\n        combSum += y;\n\n        // one-pole low-pass on the feedback (damping)\n        let lp: f32 = combDamp[ci];\n        lp = f32(y * inputGain + lp * dampCoef);\n        combDamp[ci] = lp;\n\n        // write new sample = input + damped feedback\n        combBuf[cbBase + pos] = f32(preOut + lp * feedback);\n\n        pos++; if (pos >= len) pos = 0;\n        combPos[ci] = pos;\n      }\n      combSum *= combNorm;\n\n      // ---- series allpass diffusers ----\n      let sig: f32 = combSum;\n      for (let k = 0; k < NUM_ALLPASS; k++) {\n        const ai: i32 = c * NUM_ALLPASS + k;\n        const apb: i32 = ai * AP_MAX;\n        const len: i32 = apLen[ai];\n        let pos: i32 = apPos[ai];\n\n        const g: f32 = 0.5; // classic allpass coefficient\n        const bufOut: f32 = apBuf[apb + pos];\n        const inp: f32 = sig;\n        const newBuf: f32 = f32(inp + bufOut * g);\n        const out: f32 = f32(bufOut - newBuf * g);\n        apBuf[apb + pos] = newBuf;\n        sig = out;\n\n        pos++; if (pos >= len) pos = 0;\n        apPos[ai] = pos;\n      }\n\n      const wet: f32 = sig;\n      outBuf[base + f] = f32(dry * (1.0 - mix) + wet * mix);\n    }\n\n    prePos[c] = pp;\n  }\n\n  // if host is mono, mirror to keep stereo sane (only when channels<2 nothing else writes)\n}\n",
  "publishedAt": 1751000087000
}