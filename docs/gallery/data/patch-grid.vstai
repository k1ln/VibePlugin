  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Patch Grid</title>\n<style>\n  :root{ --acc:#7ad090; --acc2:#e0b040; --bg0:#080e09; --bg1:#111c12; --ink:#e8f3e8; --dim:#7a8c7a; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#182c1a 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,780px); border-radius:13px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#132214,#080e09); border:1px solid rgba(122,208,144,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(232,243,232,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .stage{ display:flex; gap:12px; margin-bottom:14px; }\n  .screen{ height:150px; border-radius:9px; overflow:hidden; position:relative; background:linear-gradient(180deg,#0e1a0f,#080f09); border:1px solid rgba(122,208,144,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  .matrix{ width:150px; flex:0 0 150px; } .wave{ flex:1; }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:10px; top:7px; font-size:8.5px; letter-spacing:.2em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:66px; height:66px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(214,232,214,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(122,208,144,.6)); }\n  .pcap{ fill:#0d180e; stroke:rgba(122,208,144,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(122,208,144,.1); padding:1px 7px; border-radius:6px; border:1px solid rgba(122,208,144,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">PATCH&nbsp;GRID</span><span class=\"sub\">matrix modular</span><span class=\"led\"></span></header>\n    <div class=\"stage\">\n      <div class=\"screen matrix\"><div class=\"scrlbl\">PIN&nbsp;MATRIX</div><canvas id=\"mv\"></canvas></div>\n      <div class=\"screen wave\"><div class=\"scrlbl\">RING&nbsp;OUT</div><canvas id=\"wv\"></canvas></div>\n    </div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Osc2\",idx:0,def:0.4},{name:\"Ring\",idx:1,def:0.5},{name:\"Noise\",idx:2,def:0.15},{name:\"Cutoff\",idx:3,def:0.55},{name:\"Decay\",idx:4,def:0.6},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#7ad090\"/><stop offset=\"1\" stop-color=\"#e0b040\"/></linearGradient></defs><circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle><circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle><line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2)); ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  // fixed set of \"patched\" pins (row,col) + which param controls their glow\n  var PINS=[[0,1,1],[1,3,1],[2,0,2],[3,5,1],[4,2,0],[1,6,3],[5,4,0],[6,7,4],[2,5,1],[7,1,3]];\n  function C2(id){ var cv=document.getElementById(id); var ctx=cv.getContext(\"2d\"); var o={cv:cv,ctx:ctx,W:0,H:0,DPR:Math.min(2,window.devicePixelRatio||1)};\n    function rs(){ var r=cv.getBoundingClientRect(); o.W=r.width; o.H=r.height; cv.width=o.W*o.DPR; cv.height=o.H*o.DPR; ctx.setTransform(o.DPR,0,0,o.DPR,0,0); } o.rs=rs; window.addEventListener(\"resize\",rs); rs(); return o; }\n  var mv=C2(\"mv\"), wv=C2(\"wv\");\n  // ---- REAL patch pins: click to route sources into Ring-mod / Noise ----\n  // amber = osc -> ring modulator (Ring), green = noise -> mix (Noise).\n  var routable=[\n    {r:2,c:1,p:1,amt:0.28,on:true},  {r:4,c:3,p:1,amt:0.28,on:true},  {r:6,c:5,p:1,amt:0.28,on:false},\n    {r:0,c:6,p:2,amt:0.18,on:true},  {r:5,c:2,p:2,amt:0.18,on:false}, {r:3,c:7,p:2,amt:0.18,on:false}\n  ];\n  function recomputeGrid(){\n    var ring=0.03, noise=0.0;\n    for(var i=0;i<routable.length;i++){ if(!routable[i].on)continue; if(routable[i].p===1)ring+=routable[i].amt; else noise+=routable[i].amt; }\n    ring=Math.min(1,ring); noise=Math.min(1,noise);\n    vals[1]=ring; vals[2]=noise; send(1,ring); send(2,noise);\n    if(knobs[1])knobs[1].render(ring); if(knobs[2])knobs[2].render(noise);\n  }\n  mv.cv.addEventListener(\"click\",function(e){\n    var rect=mv.cv.getBoundingClientRect(); var cxp=e.clientX-rect.left, cyp=e.clientY-rect.top;\n    var pad=20, gx=(mv.W-pad-8)/8, gy=(mv.H-pad-6)/8; var best=-1, bd=1e9;\n    for(var i=0;i<routable.length;i++){ var x=8+routable[i].c*gx+gx/2, y=pad+routable[i].r*gy+gy/2; var d=(x-cxp)*(x-cxp)+(y-cyp)*(y-cyp); if(d<bd){bd=d;best=i;} }\n    var rad=Math.min(gx,gy)*0.75; if(best>=0 && bd < rad*rad){ routable[best].on=!routable[best].on; recomputeGrid(); }\n  });\n  function frame(ts){\n    // PIN MATRIX 8x8\n    var mc=mv.ctx, W=mv.W, H=mv.H; mc.clearRect(0,0,W,H);\n    var pad=20, gx=(W-pad-8)/8, gy=(H-pad-6)/8;\n    for(var r=0;r<8;r++)for(var c=0;c<8;c++){ var x=8+c*gx+gx/2, y=pad+r*gy+gy/2;\n      mc.fillStyle=\"rgba(122,208,144,0.14)\"; mc.beginPath(); mc.arc(x,y,1.4,0,Math.PI*2); mc.fill(); }\n    for(var k=0;k<PINS.length;k++){ var pn=PINS[k]; var x=8+pn[1]*gx+gx/2, y=pad+pn[0]*gy+gy/2;\n      var lvl=vals[pn[2]]; var pulse=0.5+0.5*Math.sin(ts/500+k);\n      mc.fillStyle=\"#7ad090\"; mc.globalAlpha=0.4+lvl*0.5; mc.shadowColor=\"#7ad090\"; mc.shadowBlur=4+lvl*8*pulse;\n      mc.beginPath(); mc.arc(x,y,2.8+lvl*1.5,0,Math.PI*2); mc.fill(); mc.shadowBlur=0; mc.globalAlpha=1; }\n    // clickable routing pins (amber=ring, green=noise); ring around = seated\n    for(var kk=0;kk<routable.length;kk++){ var rp=routable[kk]; var rx=8+rp.c*gx+gx/2, ry=pad+rp.r*gy+gy/2; var col=rp.p===1?\"#e0b040\":\"#7ad090\";\n      if(rp.on){ mc.fillStyle=col; mc.globalAlpha=0.95; mc.shadowColor=col; mc.shadowBlur=8; mc.beginPath(); mc.arc(rx,ry,4,0,Math.PI*2); mc.fill(); mc.shadowBlur=0;\n        mc.strokeStyle=col; mc.globalAlpha=0.45; mc.lineWidth=1.2; mc.beginPath(); mc.arc(rx,ry,7.5,0,Math.PI*2); mc.stroke(); mc.globalAlpha=1; }\n      else { mc.strokeStyle=col; mc.globalAlpha=0.35; mc.lineWidth=1.3; mc.beginPath(); mc.arc(rx,ry,4,0,Math.PI*2); mc.stroke(); mc.globalAlpha=1; } }\n    // WAVE (ring-mod output)\n    var wc=wv.ctx, SW=wv.W, SH=wv.H; wc.clearRect(0,0,SW,SH); var mid=SH*0.52;\n    var osc2=vals[0], ring=vals[1], noise=vals[2], cut=vals[3];\n    var f2=40*Math.exp(osc2*3.4)/220;   // osc2 ratio relative to display base\n    wc.beginPath();\n    for(var x2=0;x2<=SW;x2+=1.5){ var t=x2/SW*3+ts/900; var o1=(( (t)%1)*2-1); var o2=Math.sin(t*f2*6.2831853);\n      var rr=o1*o2; var v=(o1*(0.5-ring*0.35)+rr*ring*1.2)*(0.4+cut*0.5); v += (Math.sin(t*97)*0.5)*noise*0.6;\n      wc.lineTo(x2, mid - v*(SH*0.30)); }\n    wc.strokeStyle=\"rgba(224,176,64,0.9)\"; wc.lineWidth=1.8; wc.shadowColor=\"#e0b040\"; wc.shadowBlur=6; wc.stroke(); wc.shadowBlur=0;\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); recomputeGrid(); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  PATCH GRID — a patch-matrix modular voice (EMS Synthi 100 lineage).\n//  The Synthi's pin matrix let anything modulate anything; its most\n//  iconic sound is RING MODULATION between a played oscillator and a\n//  free-running one, giving clangorous, inharmonic, bell-and-drone\n//  timbres. Here osc1 tracks the note, OSC2 FREQ sets a free-running\n//  second oscillator (absolute pitch, so the ring product goes\n//  inharmonic), RING sets the ring-mod amount, NOISE adds the Synthi's\n//  coloured noise, all through a resonant low-pass with a decay envelope.\n//  Mono (last-note). Controls: Osc2 Freq, Ring, Noise, Cutoff, Decay, Level.\n//  No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst TAU: f32 = 6.2831853;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet ph1: f32 = 0.0; let ph2: f32 = 0.0;\nlet curFreq: f32 = 220.0; let targetFreq: f32 = 220.0;\nlet gate: i32 = 0; let note: i32 = -1; let amp: f32 = 0.0;\nlet lp: f32 = 0.0; let bp: f32 = 0.0;\nlet rngState: i32 = 135791; let nz: f32 = 0.0;\n\nconst P_OSC2: i32 = 0; const P_RING: i32 = 1; const P_NOISE: i32 = 2; const P_CUTOFF: i32 = 3; const P_DECAY: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  ph1 = 0.0; ph2 = 0.0; curFreq = 220.0; targetFreq = 220.0; gate = 0; note = -1; amp = 0.0; lp = 0.0; bp = 0.0; nz = 0.0;\n  params[P_OSC2] = 0.4; params[P_RING] = 0.5; params[P_NOISE] = 0.15; params[P_CUTOFF] = 0.55; params[P_DECAY] = 0.6; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 220.0;\n  if (gate == 0) curFreq = nf;\n  targetFreq = nf; note = id; gate = 1; amp = clampf(v, 0.1, 1.0);\n}\nexport function noteOff(id: i32): void { if (id == note) gate = 0; }\n\nexport function process(n: i32): void {\n  const osc2N: f32 = clampf(params[P_OSC2], 0.0, 1.0);\n  const ringN: f32 = clampf(params[P_RING], 0.0, 1.0);\n  const noiseN: f32 = clampf(params[P_NOISE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const osc2Freq: f32 = 40.0 * f32(Mathf.exp(osc2N * 3.4));      // ~40..1200 Hz free-running\n  const glide: f32 = f32(Mathf.exp(-1.0 / (0.01 * sampleRate)));\n  const atkInc: f32 = 1.0 / (0.006 * sampleRate);\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / ((0.15 + decayN * 2.5) * sampleRate)));\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.2 * sampleRate)));\n  const baseCut: f32 = 55.0 * f32(Mathf.exp(cutoffN * 5.3));\n  const k: f32 = 1.3;\n  let fc: f32 = baseCut; if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n  const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n  const a1c: f32 = 1.0 / (1.0 + g * (g + k));\n  const inc2: f32 = osc2Freq / sampleRate;\n  const out: f32 = level * 0.6;\n\n  for (let i = 0; i < n; i++) {\n    curFreq = targetFreq + (curFreq - targetFreq) * glide;\n    if (gate != 0) { if (amp < 1.0) { amp += atkInc; if (amp > 1.0) amp = 1.0; } else { amp *= decCoef; } }\n    else { amp *= relCoef; }\n\n    let p1: f32 = ph1 + curFreq / sampleRate; if (p1 >= 1.0) p1 -= 1.0; ph1 = p1;\n    let p2: f32 = ph2 + inc2; if (p2 >= 1.0) p2 -= 1.0; ph2 = p2;\n    const o1: f32 = p1 * 2.0 - 1.0;                    // saw (rich for ring mod)\n    const o2: f32 = f32(Mathf.sin(p2 * TAU));          // sine carrier\n    const ring: f32 = o1 * o2;\n    // coloured noise (one-pole lowpassed)\n    nz += 0.25 * (rnd() - nz);\n    let v: f32 = o1 * (0.5 - ringN * 0.35) + ring * ringN * 1.4 + nz * noiseN * 1.2;\n\n    const hp: f32 = (v - (g + k) * bp - lp) * a1c;\n    const bpN: f32 = g * hp + bp; const lpN: f32 = g * bpN + lp; bp = bpN; lp = lpN;\n    let o: f32 = f32(Mathf.tanh(lpN * amp * out * 1.4));\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751312000000
}