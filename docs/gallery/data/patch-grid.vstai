  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Patch Grid</title>\n<style>\n  :root{ --acc:#7ad090; --acc2:#e0b040; --bg0:#080e09; --bg1:#111c12; --ink:#e8f3e8; --dim:#7a8c7a; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#182c1a 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(96vw,860px); border-radius:13px; padding:15px 20px 18px; position:relative; overflow:hidden; background:linear-gradient(160deg,#132214,#080e09); border:1px solid rgba(122,208,144,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(232,243,232,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:11px; }\n  .logo{ font-weight:800; letter-spacing:.15em; font-size:20px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:9.5px; letter-spacing:.26em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .stage{ display:flex; gap:12px; margin-bottom:13px; }\n  .screen{ height:212px; border-radius:9px; overflow:hidden; position:relative; background:linear-gradient(180deg,#0e1a0f,#080f09); border:1px solid rgba(122,208,144,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  .matrix{ flex:1.55; } .wave{ flex:1; }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:11px; top:8px; font-size:8.5px; letter-spacing:.2em; color:var(--dim); z-index:2; }\n  .hint{ position:absolute; right:10px; bottom:7px; font-size:8px; letter-spacing:.14em; color:rgba(122,208,144,.42); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:5px 6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:4px; padding:3px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:58px; height:58px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(214,232,214,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(122,208,144,.6)); }\n  .pcap{ fill:#0d180e; stroke:rgba(122,208,144,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8px; letter-spacing:.08em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:9.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(122,208,144,.1); padding:1px 6px; border-radius:6px; border:1px solid rgba(122,208,144,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">PATCH&nbsp;GRID</span><span class=\"sub\">ems&nbsp;synthi&nbsp;100&nbsp;&middot;&nbsp;7&times;7&nbsp;pin&nbsp;matrix</span><span class=\"led\"></span></header>\n    <div class=\"stage\">\n      <div class=\"screen matrix\"><span class=\"hint\">click a hole to patch</span><canvas id=\"mv\"></canvas></div>\n      <div class=\"screen wave\"><div class=\"scrlbl\">OUTPUT</div><canvas id=\"wv\"></canvas></div>\n    </div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  // ---- params: 10 module knobs (0..9) + 49 matrix routes (10..58) ----\n  var P=[{name:\"Osc2\",idx:0,def:0.36},{name:\"Osc3\",idx:1,def:0.5},{name:\"Osc4\",idx:2,def:0.2},\n    {name:\"Noise\",idx:3,def:0.35},{name:\"Cutoff\",idx:4,def:0.5},{name:\"Reso\",idx:5,def:0.6},\n    {name:\"Attack\",idx:6,def:0.14},{name:\"Decay\",idx:7,def:0.5},{name:\"Reverb\",idx:8,def:0.22},{name:\"Level\",idx:9,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n\n  // ---- knobs ----\n  var R=31, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 76 76\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#7ad090\"/><stop offset=\"1\" stop-color=\"#e0b040\"/></linearGradient></defs><circle class=\"track\" cx=\"38\" cy=\"38\" r=\"31\"></circle><circle class=\"arc\" cx=\"38\" cy=\"38\" r=\"31\" transform=\"rotate(135 38 38)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"38\" cy=\"38\" r=\"19\"></circle><line class=\"ptr\" x1=\"38\" y1=\"38\" x2=\"38\" y2=\"22\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(38+Math.sin(ang)*15).toFixed(2)); ptr.setAttribute(\"y2\",(38-Math.cos(ang)*15).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n\n  function C2(id){ var cv=document.getElementById(id); var ctx=cv.getContext(\"2d\"); var o={cv:cv,ctx:ctx,W:0,H:0,DPR:Math.min(2,window.devicePixelRatio||1)};\n    function rs(){ var r=cv.getBoundingClientRect(); o.W=r.width; o.H=r.height; cv.width=o.W*o.DPR; cv.height=o.H*o.DPR; ctx.setTransform(o.DPR,0,0,o.DPR,0,0); } o.rs=rs; window.addEventListener(\"resize\",rs); rs(); return o; }\n  var mv=C2(\"mv\"), wv=C2(\"wv\");\n\n  // ================================================================\n  //  EMS SYNTHI-100 PIN MATRIX — 7 sources x 7 destinations, REAL.\n  //  Each hole is param index 10 + src*7 + dst. Click to insert/pull a\n  //  pin; the engine reads every route every sample.\n  // ================================================================\n  var SRC=[\"OSC 1\",\"OSC 2\",\"OSC 3\",\"OSC 4\",\"NOISE\",\"RING\",\"ENV\"];        // rows\n  var DST=[\"1 FM\",\"2 FM\",\"3 FM\",\"4 FM\",\"CUT\",\"F·IN\",\"OUT\"];          // cols\n  var DCOL=[\"#e0b040\",\"#e0a038\",\"#e09038\",\"#e08038\",\"#6aa0e0\",\"#7ad090\",\"#e07050\"]; // per-dest pin colour\n  var AMT_ON=0.8;\n  var DEF={\"0,5\":0.85,\"0,6\":0.25,\"5,6\":0.70,\"4,5\":0.22,\"6,4\":0.60};      // default patch (matches spec)\n  var pin=[], amt=[];\n  for(var s=0;s<7;s++){ pin[s]=[]; amt[s]=[]; for(var d=0;d<7;d++){ var a=DEF[s+\",\"+d]||0; amt[s][d]=a; pin[s][d]=a>0?1:0; } }\n  function midx(s,d){ return 10+s*7+d; }\n  function setPin(s,d,on){ pin[s][d]=on?1:0; amt[s][d]= on ? (amt[s][d]>0?amt[s][d]:AMT_ON) : 0; send(midx(s,d), amt[s][d]); }\n\n  function geo(o){ var lx=50, ty=20, pad=9; return {lx:lx,ty:ty,cw:(o.W-lx-pad)/7, ch:(o.H-ty-pad)/7}; }\n  function hole(o,s,d){ var g=geo(o); return {x:g.lx+d*g.cw+g.cw/2, y:g.ty+s*g.ch+g.ch/2}; }\n  mv.cv.addEventListener(\"click\",function(e){\n    var rect=mv.cv.getBoundingClientRect(); var cx=e.clientX-rect.left, cy=e.clientY-rect.top;\n    var best=null, bd=1e9;\n    for(var s=0;s<7;s++)for(var d=0;d<7;d++){ var p=hole(mv,s,d); var dd=(p.x-cx)*(p.x-cx)+(p.y-cy)*(p.y-cy); if(dd<bd){bd=dd;best={s:s,d:d};} }\n    var g=geo(mv); var rad=Math.min(g.cw,g.ch)*0.6; if(best && bd<rad*rad){ setPin(best.s,best.d,!pin[best.s][best.d]); }\n  });\n\n  // representative live level per source (for pin shimmer + scope)\n  function ratio(v){ return 0.25 + v*3.4; }\n  function frame(ts){\n    // ---------- PIN MATRIX ----------\n    var mc=mv.ctx, W=mv.W, H=mv.H; mc.clearRect(0,0,W,H); var g=geo(mv);\n    mc.textBaseline=\"middle\"; mc.font=\"8px Inter,system-ui,sans-serif\";\n    // column headers + guides\n    mc.textAlign=\"center\";\n    for(var d=0;d<7;d++){ var cx=g.lx+d*g.cw+g.cw/2; mc.globalAlpha=0.92; mc.fillStyle=DCOL[d]; mc.fillText(DST[d],cx,10); mc.globalAlpha=1;\n      mc.strokeStyle=\"rgba(122,208,144,0.055)\"; mc.lineWidth=1; mc.beginPath(); mc.moveTo(cx,g.ty-2); mc.lineTo(cx,H-4); mc.stroke(); }\n    // row labels + guides (lit if the source drives anything)\n    mc.textAlign=\"right\";\n    for(var s=0;s<7;s++){ var cy=g.ty+s*g.ch+g.ch/2; var act=false; for(var dd=0;dd<7;dd++) if(pin[s][dd]) act=true;\n      mc.globalAlpha=act?1:0.7; mc.fillStyle=act?\"#e8f3e8\":\"#7a8c7a\"; mc.fillText(SRC[s],g.lx-8,cy); mc.globalAlpha=1;\n      mc.strokeStyle=act?\"rgba(122,208,144,0.09)\":\"rgba(122,208,144,0.04)\"; mc.beginPath(); mc.moveTo(g.lx-2,cy); mc.lineTo(W-5,cy); mc.stroke(); }\n    // holes + seated pins\n    for(var s2=0;s2<7;s2++)for(var d2=0;d2<7;d2++){ var p=hole(mv,s2,d2);\n      mc.fillStyle=\"rgba(0,0,0,0.5)\"; mc.beginPath(); mc.arc(p.x,p.y,3.3,0,6.2832); mc.fill();\n      mc.strokeStyle=\"rgba(122,208,144,0.22)\"; mc.lineWidth=1; mc.beginPath(); mc.arc(p.x,p.y,3.3,0,6.2832); mc.stroke();\n      if(pin[s2][d2]){ var col=DCOL[d2]; var pulse=0.6+0.4*Math.sin(ts/380+s2*1.4+d2*0.7);\n        mc.shadowColor=col; mc.shadowBlur=8*pulse; mc.globalAlpha=0.95; mc.fillStyle=col; mc.beginPath(); mc.arc(p.x,p.y,4.5,0,6.2832); mc.fill(); mc.shadowBlur=0;\n        mc.globalAlpha=0.7; mc.fillStyle=\"rgba(255,255,255,0.85)\"; mc.beginPath(); mc.arc(p.x-1.4,p.y-1.4,1.2,0,6.2832); mc.fill(); mc.globalAlpha=1; } }\n\n    // ---------- OUTPUT SCOPE (reflects the patch) ----------\n    var wc=wv.ctx, SW=wv.W, SH=wv.H; wc.clearRect(0,0,SW,SH); var mid=SH*0.53;\n    var f2=ratio(vals[0]), f3=ratio(vals[1]), f4=ratio(vals[2]), cut=vals[4], nzc=vals[3];\n    var lpf=0, any=false;\n    wc.beginPath();\n    for(var x=0;x<=SW;x+=1.5){ var t=x/SW*4+ts/820;\n      var o1=((t%1)*2-1), o2=Math.sin(t*f2*6.2831853), o3=(4*Math.abs((t*f3)%1-0.5)-1), o4=((t*f4)%1)<0.5?1:-1;\n      var ring=o1*o2; var nzv=(Math.sin(t*131.7)*0.6+Math.sin(t*57.3)*0.4)*(0.4+nzc*0.9);\n      var src=[o1,o2,o3,o4,nzv,ring,0.6];\n      var sig=0; for(var k=0;k<7;k++){ var w=amt[k][6]+amt[k][5]*0.85; if(w>0){sig+=src[k]*w; any=true;} }\n      lpf += (0.06+cut*0.55)*(sig-lpf);\n      wc.lineTo(x, mid - lpf*(SH*0.30)); }\n    wc.strokeStyle=any?\"rgba(224,176,64,0.92)\":\"rgba(122,140,122,0.5)\"; wc.lineWidth=1.8; wc.shadowColor=\"#e0b040\"; wc.shadowBlur=any?6:0; wc.stroke(); wc.shadowBlur=0;\n    if(!any){ wc.fillStyle=\"rgba(122,140,122,0.6)\"; wc.font=\"9px Inter,sans-serif\"; wc.textAlign=\"center\"; wc.fillText(\"patch a source → OUT / F·IN to hear it\", SW/2, mid+22); }\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n\n  function boot(){ host=window.vstai||null;\n    P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); });\n    for(var s=0;s<7;s++)for(var d=0;d<7;d++) send(midx(s,d), amt[s][d]); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  PATCH GRID — a patch-matrix modular voice pushed toward the EMS\n//  Synthi 100. FOUR oscillators (saw / sine / triangle / pulse), a\n//  coloured noise generator, a ring modulator (OSC1 x OSC2), a\n//  trapezoid envelope and a high-resonance / self-oscillating state\n//  variable filter feed a spring-style reverb and output.\n//\n//  The heart is a REAL 7x7 pin matrix: every source (rows) can be\n//  patched into every destination (columns) with an independent,\n//  automatable amount that the audio engine actually reads each\n//  sample — anything modulates / feeds anything, just like the Synthi.\n//\n//    SOURCES (rows)   : OSC1 OSC2 OSC3 OSC4 NOISE RING ENV\n//    DESTINATIONS(cols): OSC1f OSC2f OSC3f OSC4f CUTOFF FILT-IN OUT\n//\n//  Control columns (OSCnf, CUTOFF) treat the summed bus as a CV;\n//  audio columns (FILT-IN, OUT) sum it as signal. Nothing patched to\n//  FILT-IN / OUT == silence, exactly like a real pin board.\n//\n//  Mono (last-note). No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst TAU: f32 = 6.2831853;\n\nconst NSRC: i32 = 7;    // matrix rows (sources)\nconst NDST: i32 = 7;    // matrix cols (destinations)\nconst NMAT: i32 = 49;   // NSRC * NDST\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\nconst rmat:   StaticArray<f32> = new StaticArray<f32>(NMAT);   // clamped routes for this block\n\n// ---- parameter indices ---------------------------------------------\n// knobs 0..9\nconst P_O2: i32 = 0; const P_O3: i32 = 1; const P_O4: i32 = 2;\nconst P_NOISE: i32 = 3; const P_CUT: i32 = 4; const P_RES: i32 = 5;\nconst P_ATK: i32 = 6; const P_DEC: i32 = 7; const P_REV: i32 = 8; const P_LEVEL: i32 = 9;\nconst P_MAT: i32 = 10;                       // matrix routes 10..58 = P_MAT + src*NDST + dst\n\n// destination column indices\nconst D_O1F: i32 = 0; const D_O2F: i32 = 1; const D_O3F: i32 = 2; const D_O4F: i32 = 3;\nconst D_CUT: i32 = 4; const D_FIN: i32 = 5; const D_OUT: i32 = 6;\n\nlet sampleRate: f32 = 48000.0;\nlet ph1: f32 = 0.0; let ph2: f32 = 0.0; let ph3: f32 = 0.0; let ph4: f32 = 0.0;\nlet curFreq: f32 = 220.0; let targetFreq: f32 = 220.0;\nlet gate: i32 = 0; let note: i32 = -1; let amp: f32 = 0.0; let vel: f32 = 1.0;\nlet lp: f32 = 0.0; let bp: f32 = 0.0;\nlet dcX: f32 = 0.0; let dcY: f32 = 0.0;          // output DC blocker\nlet rngState: i32 = 135791; let nz: f32 = 0.0;\n\n// previous-sample source values (break the modulation feedback loop)\nlet ps1: f32 = 0.0; let ps2: f32 = 0.0; let ps3: f32 = 0.0; let ps4: f32 = 0.0;\nlet ps5: f32 = 0.0; let ps6: f32 = 0.0; let ps7: f32 = 0.0;\n\n// spring-ish reverb (2 combs + 1 allpass, mono)\nconst RVA: i32 = 1621; const RVB: i32 = 1949; const RVP: i32 = 487;\nconst rvaBuf: StaticArray<f32> = new StaticArray<f32>(RVA);\nconst rvbBuf: StaticArray<f32> = new StaticArray<f32>(RVB);\nconst rvpBuf: StaticArray<f32> = new StaticArray<f32>(RVP);\nlet ria: i32 = 0; let rib: i32 = 0; let rip: i32 = 0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n@inline function pow2(x: f32): f32 { return f32(Mathf.pow(2.0, x)); }\n// tune knob -> free-running frequency, ~1.5 Hz (LFO) .. ~2.4 kHz (audio)\n@inline function tuneFreq(t: f32): f32 { return f32(1.5 * Mathf.exp(clampf(t, 0.0, 1.0) * 7.3)); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  ph1 = 0.0; ph2 = 0.0; ph3 = 0.0; ph4 = 0.0;\n  curFreq = 220.0; targetFreq = 220.0; gate = 0; note = -1; amp = 0.0; vel = 1.0; lp = 0.0; bp = 0.0; nz = 0.0; dcX = 0.0; dcY = 0.0;\n  ps1 = 0.0; ps2 = 0.0; ps3 = 0.0; ps4 = 0.0; ps5 = 0.0; ps6 = 0.0; ps7 = 0.0;\n  ria = 0; rib = 0; rip = 0;\n  for (let i = 0; i < RVA; i++) rvaBuf[i] = 0.0;\n  for (let i = 0; i < RVB; i++) rvbBuf[i] = 0.0;\n  for (let i = 0; i < RVP; i++) rvpBuf[i] = 0.0;\n  for (let i = 0; i < MAX_PARAMS; i++) params[i] = 0.0;\n\n  // module knobs\n  params[P_O2] = 0.36; params[P_O3] = 0.5; params[P_O4] = 0.2;\n  params[P_NOISE] = 0.35; params[P_CUT] = 0.5; params[P_RES] = 0.6;\n  params[P_ATK] = 0.14; params[P_DEC] = 0.5; params[P_REV] = 0.22; params[P_LEVEL] = 0.8;\n\n  // default patch — a bright clangorous plucked drone (so it sounds on load)\n  params[P_MAT + 0 * NDST + D_FIN] = 0.85;   // OSC1  -> FILT-IN\n  params[P_MAT + 0 * NDST + D_OUT] = 0.25;   // OSC1  -> OUT (some dry)\n  params[P_MAT + 5 * NDST + D_OUT] = 0.70;   // RING  -> OUT (clang)\n  params[P_MAT + 4 * NDST + D_FIN] = 0.22;   // NOISE -> FILT-IN\n  params[P_MAT + 6 * NDST + D_CUT] = 0.60;   // ENV   -> CUTOFF (filter envelope)\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 59; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 220.0;\n  if (gate == 0) curFreq = nf;\n  targetFreq = nf; note = id; gate = 1; vel = clampf(v, 0.1, 1.0);\n}\nexport function noteOff(id: i32): void { if (id == note) gate = 0; }\n\nexport function process(n: i32): void {\n  // ---- read knobs -------------------------------------------------\n  const noiseN: f32 = clampf(params[P_NOISE], 0.0, 1.0);\n  const cutN: f32   = clampf(params[P_CUT], 0.0, 1.0);\n  const resN: f32   = clampf(params[P_RES], 0.0, 1.0);\n  const atkN: f32   = clampf(params[P_ATK], 0.0, 1.0);\n  const decN: f32   = clampf(params[P_DEC], 0.0, 1.0);\n  const revN: f32   = clampf(params[P_REV], 0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // snapshot the matrix once per block\n  for (let m = 0; m < NMAT; m++) rmat[m] = clampf(params[P_MAT + m], 0.0, 1.0);\n\n  // free-running oscillator base frequencies (OSC1 is keyboard-tracked)\n  const f2b: f32 = tuneFreq(params[P_O2]);\n  const f3b: f32 = tuneFreq(params[P_O3]);\n  const f4b: f32 = tuneFreq(params[P_O4]);\n\n  const glide: f32 = f32(Mathf.exp(-1.0 / (0.008 * sampleRate)));\n  const atkInc: f32 = 1.0 / ((0.002 + atkN * 1.4) * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / ((0.02 + decN * 3.2) * sampleRate)));\n  const baseCut: f32 = 45.0 * f32(Mathf.exp(cutN * 5.4));\n  const kRes: f32 = 1.5 - resN * 1.46;             // -> ~0.04 at full res: near self-oscillation\n  const nyq: f32 = sampleRate * 0.45;\n  const noiseCoef: f32 = 0.02 + noiseN * 0.7;      // colour: brighter as it rises\n  const outScale: f32 = level * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // glide + trapezoid envelope (attack up, sustain, release down)\n    curFreq = targetFreq + (curFreq - targetFreq) * glide;\n    if (gate != 0) { if (amp < 1.0) { amp += atkInc; if (amp > 1.0) amp = 1.0; } }\n    else { amp *= relCoef; }\n\n    // ---- modulation buses from PREVIOUS-sample sources (CV columns) ----\n    const m0: f32 = ps1 * rmat[0 * NDST + D_O1F] + ps2 * rmat[1 * NDST + D_O1F] + ps3 * rmat[2 * NDST + D_O1F] + ps4 * rmat[3 * NDST + D_O1F] + ps5 * rmat[4 * NDST + D_O1F] + ps6 * rmat[5 * NDST + D_O1F] + ps7 * rmat[6 * NDST + D_O1F];\n    const m1: f32 = ps1 * rmat[0 * NDST + D_O2F] + ps2 * rmat[1 * NDST + D_O2F] + ps3 * rmat[2 * NDST + D_O2F] + ps4 * rmat[3 * NDST + D_O2F] + ps5 * rmat[4 * NDST + D_O2F] + ps6 * rmat[5 * NDST + D_O2F] + ps7 * rmat[6 * NDST + D_O2F];\n    const m2: f32 = ps1 * rmat[0 * NDST + D_O3F] + ps2 * rmat[1 * NDST + D_O3F] + ps3 * rmat[2 * NDST + D_O3F] + ps4 * rmat[3 * NDST + D_O3F] + ps5 * rmat[4 * NDST + D_O3F] + ps6 * rmat[5 * NDST + D_O3F] + ps7 * rmat[6 * NDST + D_O3F];\n    const m3: f32 = ps1 * rmat[0 * NDST + D_O4F] + ps2 * rmat[1 * NDST + D_O4F] + ps3 * rmat[2 * NDST + D_O4F] + ps4 * rmat[3 * NDST + D_O4F] + ps5 * rmat[4 * NDST + D_O4F] + ps6 * rmat[5 * NDST + D_O4F] + ps7 * rmat[6 * NDST + D_O4F];\n    const mc: f32 = ps1 * rmat[0 * NDST + D_CUT] + ps2 * rmat[1 * NDST + D_CUT] + ps3 * rmat[2 * NDST + D_CUT] + ps4 * rmat[3 * NDST + D_CUT] + ps5 * rmat[4 * NDST + D_CUT] + ps6 * rmat[5 * NDST + D_CUT] + ps7 * rmat[6 * NDST + D_CUT];\n\n    // ---- oscillators (with matrix FM, +/-2 octaves per bus) ----\n    let f1: f32 = curFreq * pow2(clampf(m0, -2.0, 2.0) * 2.0); if (f1 < 0.02) f1 = 0.02; if (f1 > nyq) f1 = nyq;\n    let f2: f32 = f2b     * pow2(clampf(m1, -2.0, 2.0) * 2.0); if (f2 < 0.02) f2 = 0.02; if (f2 > nyq) f2 = nyq;\n    let f3: f32 = f3b     * pow2(clampf(m2, -2.0, 2.0) * 2.0); if (f3 < 0.02) f3 = 0.02; if (f3 > nyq) f3 = nyq;\n    let f4: f32 = f4b     * pow2(clampf(m3, -2.0, 2.0) * 2.0); if (f4 < 0.02) f4 = 0.02; if (f4 > nyq) f4 = nyq;\n\n    ph1 += f1 / sampleRate; if (ph1 >= 1.0) ph1 -= 1.0;\n    ph2 += f2 / sampleRate; if (ph2 >= 1.0) ph2 -= 1.0;\n    ph3 += f3 / sampleRate; if (ph3 >= 1.0) ph3 -= 1.0;\n    ph4 += f4 / sampleRate; if (ph4 >= 1.0) ph4 -= 1.0;\n\n    const s1: f32 = ph1 * 2.0 - 1.0;                      // OSC1 saw\n    const s2: f32 = f32(Mathf.sin(ph2 * TAU));            // OSC2 sine\n    const s3: f32 = 4.0 * f32(Mathf.abs(ph3 - 0.5)) - 1.0; // OSC3 triangle\n    const s4: f32 = ph4 < 0.5 ? 1.0 : -1.0;              // OSC4 pulse\n    const s5: f32 = s1 * s2;                              // RING = OSC1 x OSC2\n    nz += noiseCoef * (rnd() - nz);\n    const s6: f32 = nz * 1.6;                             // NOISE (coloured)\n    const s7: f32 = amp;                                 // ENV (unipolar 0..1)\n\n    // ---- audio buses from CURRENT sources ----\n    const filtIn: f32 = s1 * rmat[0 * NDST + D_FIN] + s2 * rmat[1 * NDST + D_FIN] + s3 * rmat[2 * NDST + D_FIN] + s4 * rmat[3 * NDST + D_FIN] + s6 * rmat[4 * NDST + D_FIN] + s5 * rmat[5 * NDST + D_FIN] + s7 * rmat[6 * NDST + D_FIN];\n    const outBus: f32 = s1 * rmat[0 * NDST + D_OUT] + s2 * rmat[1 * NDST + D_OUT] + s3 * rmat[2 * NDST + D_OUT] + s4 * rmat[3 * NDST + D_OUT] + s6 * rmat[4 * NDST + D_OUT] + s5 * rmat[5 * NDST + D_OUT] + s7 * rmat[6 * NDST + D_OUT];\n\n    // ---- state-variable low-pass (high-Q / near self-oscillating) ----\n    let fc: f32 = baseCut * pow2(clampf(mc, -2.0, 3.0) * 2.0);\n    if (fc < 20.0) fc = 20.0; if (fc > nyq) fc = nyq;\n    const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n    const a1c: f32 = 1.0 / (1.0 + g * (g + kRes));\n    const hp: f32 = (filtIn - (g + kRes) * bp - lp) * a1c;\n    const bpN: f32 = g * hp + bp; const lpN: f32 = g * bpN + lp; bp = bpN; lp = lpN;\n    let audio: f32 = f32(Mathf.tanh(lpN * 1.2)) + outBus;\n\n    // ---- spring-ish reverb ----\n    const ca: f32 = rvaBuf[ria]; const cb: f32 = rvbBuf[rib];\n    rvaBuf[ria] = audio + ca * 0.80; rvbBuf[rib] = audio + cb * 0.78;\n    ria++; if (ria >= RVA) ria = 0; rib++; if (rib >= RVB) rib = 0;\n    const cs: f32 = (ca + cb) * 0.5;\n    const apv: f32 = rvpBuf[rip]; const apOut: f32 = -0.6 * cs + apv; rvpBuf[rip] = cs + 0.6 * apOut;\n    rip++; if (rip >= RVP) rip = 0;\n    const mixed: f32 = audio + apOut * revN * 0.9;\n\n    const o: f32 = f32(Mathf.tanh(mixed * amp * vel * outScale * 1.7));\n    const dc: f32 = o - dcX + 0.9975 * dcY; dcX = o; dcY = dc;   // remove DC\n    outBuf[i] = dc; outBuf[MAX_FRAMES + i] = dc;\n\n    // remember sources for next sample's modulation\n    ps1 = s1; ps2 = s2; ps3 = s3; ps4 = s4; ps5 = s6; ps6 = s5; ps7 = s7;\n  }\n}\n",
  "publishedAt": 1751313200000
}