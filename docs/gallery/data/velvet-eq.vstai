{
  "format": 1,
  "name": "Velvet EQ",
  "isInstrument": false,
  "explanation": "A passive program equalizer with a vintage tube-EQ character. The low band can boost and attenuate at once — the cut sits just above the boost to carve the famous resonant low end — while the high band adds a broad presence/air peak with a selectable centre plus an independent gentle high-shelf attenuation. Controls: Low Freq, Low Boost, Low Atten, High Boost Freq, High Boost and High Atten.",
  "params": [
    {
      "name": "Low Freq",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Low Boost",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Low Atten",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "High Boost Freq",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "High Boost",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "High Atten",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n/* ============================================================\n   VELVET EQ — a Pultec-style passive program equalizer.\n   Cream + blue vintage faceplate, brushed-steel chicken-head\n   knobs, engraved legends, brass screws, a glowing tube and a\n   velvet seam. Everything inline: CSS + SVG + JS, no assets.\n   ============================================================ */\n:root{\n  --ac:#f0a0ff;          /* spec accent  */\n  --ac2:#c08cff;         /* spec accent2 */\n  --cream:#ede2c8;\n  --cream-d:#d8c9a4;\n  --ink:#1c2a44;         /* vintage navy ink */\n  --ink-soft:#3a4a66;\n  --steel:#cfd6df;\n  --brass:#c9a64a;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{margin:0;display:flex;align-items:center;justify-content:center;padding:22px;\n  font:13px \"Times New Roman\",Georgia,ui-serif,serif;color:var(--ink);\n  background:\n    radial-gradient(120% 90% at 50% -10%,#3a2d52 0%,#1a1326 55%,#0c0712 100%);\n  -webkit-font-smoothing:antialiased;text-rendering:geometricPrecision}\n\n/* ---- the faceplate ---- */\n.unit{position:relative;width:100%;max-width:680px;border-radius:14px;\n  padding:18px 20px 20px;\n  background:\n    linear-gradient(180deg,rgba(255,255,255,.10),rgba(0,0,0,.16)),\n    repeating-linear-gradient(92deg,rgba(0,0,0,.015) 0 2px,rgba(255,255,255,.02) 2px 4px),\n    linear-gradient(160deg,#f3ead2 0%,#e7dabc 42%,#d9c9a3 100%);\n  box-shadow:\n    0 40px 80px rgba(0,0,0,.6),\n    0 4px 0 #b6a47e,\n    0 8px 0 #8f7f5e,\n    inset 0 2px 1px rgba(255,255,255,.55),\n    inset 0 -3px 6px rgba(80,60,30,.35);\n  border:1px solid #b9a87f;\n  animation:lift .7s cubic-bezier(.2,.8,.25,1) both}\n@keyframes lift{from{opacity:0;transform:translateY(24px) scale(.985)}to{opacity:1;transform:none}}\n\n/* subtle paper grain over the whole plate */\n.unit::after{content:\"\";position:absolute;inset:0;border-radius:14px;pointer-events:none;\n  background:radial-gradient(140% 100% at 50% 0,transparent 60%,rgba(60,42,18,.18) 100%);\n  mix-blend-mode:multiply}\n\n/* brass corner screws */\n.screw{position:absolute;width:15px;height:15px;border-radius:50%;z-index:5;\n  background:radial-gradient(circle at 38% 32%,#f6e6b0,#b9892f 60%,#7c5a17 100%);\n  box-shadow:0 1px 2px rgba(0,0,0,.5),inset 0 0 0 1px rgba(255,255,255,.25)}\n.screw::before{content:\"\";position:absolute;inset:3px;border-radius:50%;\n  background:linear-gradient(#a37a26,#7c5a17);\n  box-shadow:inset 0 1px 1px rgba(255,255,255,.4)}\n.screw::after{content:\"\";position:absolute;top:50%;left:18%;right:18%;height:1.6px;margin-top:-.8px;\n  background:rgba(40,26,8,.85);transform:rotate(var(--sl,24deg));border-radius:2px}\n.screw.tl{top:9px;left:9px} .screw.tr{top:9px;right:9px;--sl:-20deg}\n.screw.bl{bottom:9px;left:9px;--sl:-34deg} .screw.br{bottom:9px;right:9px;--sl:14deg}\n\n/* ---- header / nameplate ---- */\n.head{position:relative;z-index:2;display:flex;align-items:center;gap:14px;\n  padding:4px 8px 14px;margin:0 6px 6px;border-bottom:1px double #b09a6e}\n.tube{position:relative;width:34px;height:46px;flex:0 0 auto;border-radius:11px 11px 6px 6px;\n  background:linear-gradient(180deg,rgba(255,255,255,.5),rgba(180,160,120,.15));\n  border:1px solid #b6a47e;box-shadow:inset 0 0 8px rgba(0,0,0,.25)}\n.tube i{position:absolute;left:50%;bottom:7px;width:5px;height:26px;margin-left:-2.5px;border-radius:3px;\n  background:linear-gradient(180deg,#fff5c2,var(--ac));\n  box-shadow:0 0 10px 3px var(--ac),0 0 26px 8px color-mix(in srgb,var(--ac) 55%,transparent);\n  animation:glow 2.6s ease-in-out infinite}\n@keyframes glow{0%,100%{opacity:.55;filter:blur(.2px)}45%{opacity:1;filter:blur(.6px)}60%{opacity:.8}}\n.tube b{position:absolute;left:7px;right:7px;bottom:3px;height:4px;border-radius:0 0 4px 4px;\n  background:#5a4a2c;box-shadow:0 1px 0 rgba(255,255,255,.3)}\n.title{flex:1}\n.title h1{margin:0;font-size:27px;font-weight:700;letter-spacing:.06em;line-height:1;\n  font-family:Georgia,\"Times New Roman\",serif;color:var(--ink);\n  text-shadow:0 1px 0 rgba(255,255,255,.6),0 -1px 0 rgba(0,0,0,.12)}\n.title h1 em{font-style:italic;color:var(--ink-soft);font-weight:600}\n.title .sub{margin-top:3px;font-size:10.5px;letter-spacing:.34em;text-transform:uppercase;\n  color:#7a6a44;font-family:ui-sans-serif,system-ui,sans-serif}\n.model{font-family:ui-sans-serif,system-ui,sans-serif;font-size:9px;letter-spacing:.18em;\n  text-transform:uppercase;color:#6e5e3c;text-align:right;line-height:1.5;\n  border:1px solid #b09a6e;border-radius:5px;padding:5px 8px;background:rgba(255,255,255,.18)}\n.model b{display:block;font-size:11px;letter-spacing:.1em;color:var(--ink)}\n\n/* ---- the two bands ---- */\n.bands{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:14px;\n  padding:6px 4px 2px}\n.band{position:relative;border-radius:11px;padding:14px 12px 16px;\n  background:linear-gradient(180deg,rgba(255,255,255,.16),rgba(120,100,60,.07));\n  box-shadow:inset 0 1px 0 rgba(255,255,255,.5),inset 0 0 0 1px rgba(120,100,60,.22),\n    inset 0 -10px 18px rgba(90,70,30,.10)}\n.band > .legend{display:flex;align-items:center;gap:9px;margin:0 2px 12px;\n  font-family:ui-sans-serif,system-ui,sans-serif;font-size:11px;letter-spacing:.28em;\n  text-transform:uppercase;color:#6c5c38;font-weight:700}\n.legend .ln{flex:1;height:1px;background:linear-gradient(90deg,#b09a6e,transparent)}\n.legend.r .ln{background:linear-gradient(270deg,#b09a6e,transparent)}\n.band .row{display:flex;gap:6px;justify-content:space-around}\n\n/* ---- a knob station ---- */\n.k{display:flex;flex-direction:column;align-items:center;gap:7px;flex:1;min-width:0;\n  animation:pop .55s both;animation-delay:var(--d,0ms)}\n@keyframes pop{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}\n.dialwrap{position:relative;width:90px;height:90px;cursor:grab;touch-action:none;user-select:none}\n.dialwrap.drag{cursor:grabbing}\n.dialwrap svg{display:block;width:100%;height:100%;overflow:visible}\n\n/* the rotating chicken-head pointer group is spun via CSS var */\n.spin{transform-box:fill-box;transform-origin:50% 50%;\n  transform:rotate(calc((var(--n,0) - .5) * 290deg));\n  transition:transform .12s cubic-bezier(.2,.8,.2,1)}\n.dialwrap.drag .spin{transition:none}\n\n.knobcap{filter:drop-shadow(0 6px 6px rgba(0,0,0,.45))}\n.tickactive{stroke:var(--ac);filter:drop-shadow(0 0 3px var(--ac))}\n\n.nm{font-family:ui-sans-serif,system-ui,sans-serif;font-size:9.5px;letter-spacing:.13em;\n  text-transform:uppercase;color:#5e4f30;font-weight:700;text-align:center;line-height:1.2}\n.val{font-family:\"Courier New\",ui-monospace,monospace;font-size:12px;font-weight:700;\n  color:var(--ink);background:linear-gradient(#cdd9e6,#aebccd);\n  border:1px solid #7f93ab;border-radius:4px;padding:1px 8px;min-width:54px;text-align:center;\n  box-shadow:inset 0 1px 2px rgba(0,0,0,.35),inset 0 0 0 1px rgba(255,255,255,.4);\n  letter-spacing:.02em;font-variant-numeric:tabular-nums}\n.dialwrap.drag ~ .val,.k:hover .val{color:#0a1426}\n\n/* footer seam — the \"velvet\" */\n.seam{position:relative;z-index:2;margin:16px 6px 0;height:14px;border-radius:7px;\n  background:\n    repeating-linear-gradient(90deg,rgba(0,0,0,.16) 0 3px,rgba(255,255,255,.05) 3px 6px),\n    linear-gradient(180deg,var(--ac2),color-mix(in srgb,var(--ac) 60%,#2a1640));\n  box-shadow:inset 0 1px 3px rgba(0,0,0,.5),0 1px 0 rgba(255,255,255,.3);\n  overflow:hidden}\n.seam::before{content:\"\";position:absolute;top:0;left:-40%;width:40%;height:100%;\n  background:linear-gradient(90deg,transparent,rgba(255,255,255,.5),transparent);\n  filter:blur(2px);animation:sheen 5.5s ease-in-out infinite}\n@keyframes sheen{0%{left:-40%}55%,100%{left:120%}}\n.tag{position:relative;z-index:2;text-align:center;margin-top:8px;\n  font-family:ui-sans-serif,system-ui,sans-serif;font-size:9px;letter-spacing:.26em;\n  text-transform:uppercase;color:#6e5e3c}\n</style></head><body>\n<div class=\"unit\">\n  <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n  <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n  <div class=\"head\">\n    <div class=\"tube\"><i></i><b></b></div>\n    <div class=\"title\">\n      <h1>Velvet&nbsp;<em>EQ</em></h1>\n      <div class=\"sub\">Passive&nbsp;·&nbsp;Program&nbsp;Equalizer</div>\n    </div>\n    <div class=\"model\">Type<b>VEL&middot;1A</b>6&nbsp;Controls</div>\n  </div>\n\n  <div class=\"bands\" id=\"bands\">\n    <div class=\"band\">\n      <div class=\"legend\"><span>Low&nbsp;Frequency</span><span class=\"ln\"></span></div>\n      <div class=\"row\" id=\"low\"></div>\n    </div>\n    <div class=\"band\">\n      <div class=\"legend r\"><span class=\"ln\"></span><span>High&nbsp;Frequency</span></div>\n      <div class=\"row\" id=\"high\"></div>\n    </div>\n  </div>\n\n  <div class=\"seam\"></div>\n  <div class=\"tag\">Boost &amp; attenuate at once — the Velvet curve</div>\n</div>\n\n<script>\n(function(){\n  // --- param map, re-read straight from spec.json -------------------\n  var PARAMS = [\n    {sec:\"low\",  name:\"Low Freq\",        index:0, min:0, max:1, def:0.3, unit:\"hz\"},\n    {sec:\"low\",  name:\"Low Boost\",       index:1, min:0, max:1, def:0,   unit:\"db\"},\n    {sec:\"low\",  name:\"Low Atten\",       index:2, min:0, max:1, def:0,   unit:\"db\"},\n    {sec:\"high\", name:\"High Boost Freq\", index:3, min:0, max:1, def:0.4, unit:\"khz\"},\n    {sec:\"high\", name:\"High Boost\",      index:4, min:0, max:1, def:0,   unit:\"db\"},\n    {sec:\"high\", name:\"High Atten\",      index:5, min:0, max:1, def:0,   unit:\"db\"}\n  ];\n  // friendly readouts mapped from the normalized 0..1 value (display only;\n  // the host always receives the raw [min,max] value via setParam).\n  var LOWF=[20,30,60,100],  HIGHF=[3,4,5,8,10,12,16];\n  function fmt(p,val){\n    var n=(val-p.min)/((p.max-p.min)||1);\n    if(p.unit===\"hz\"){  return LOWF[Math.min(LOWF.length-1,Math.round(n*(LOWF.length-1)))] + \" Hz\"; }\n    if(p.unit===\"khz\"){ return HIGHF[Math.min(HIGHF.length-1,Math.round(n*(HIGHF.length-1)))] + \" kHz\"; }\n    return (n*10).toFixed(1).replace(/\\.0$/,\"\")+\" dB\";  // 0..+10 / 0..-10 readout\n  }\n\n  var NS=\"http://www.w3.org/2000/svg\";\n  function el(t,a){var e=document.createElementNS(NS,t);for(var k in a)e.setAttribute(k,a[k]);return e;}\n\n  // build the steel chicken-head knob as an SVG\n  function buildSvg(){\n    var svg=el(\"svg\",{viewBox:\"0 0 100 100\"});\n    var g=el(\"defs\",{});\n    svg.appendChild(g);\n\n    // engraved tick ring (static)\n    var N=21, ring=el(\"g\",{});\n    for(var i=0;i<N;i++){\n      var a=(-145 + i*(290/(N-1)))*Math.PI/180;\n      var r1=45, r2=(i===0||i===N-1||i===(N-1)/2)?37:40;\n      var x1=50+Math.cos(a-Math.PI/2)*r1, y1=50+Math.sin(a-Math.PI/2)*r1;\n      var x2=50+Math.cos(a-Math.PI/2)*r2, y2=50+Math.sin(a-Math.PI/2)*r2;\n      ring.appendChild(el(\"line\",{x1:x1,y1:y1,x2:x2,y2:y2,\n        stroke:\"#5e4f30\",\"stroke-width\":(r2<39?1.8:1.1),\"stroke-linecap\":\"round\",opacity:.75}));\n    }\n    svg.appendChild(ring);\n\n    // outer skirt\n    svg.appendChild(el(\"circle\",{cx:50,cy:50,r:33,fill:\"url(#skirt)\"}));\n    // brushed steel cap (rotates)\n    var spin=el(\"g\",{class:\"spin\"});\n    spin.appendChild(el(\"circle\",{cx:50,cy:50,r:30,fill:\"url(#steel)\",class:\"knobcap\"}));\n    spin.appendChild(el(\"circle\",{cx:50,cy:50,r:30,fill:\"none\",stroke:\"#7c8aa0\",\"stroke-width\":1,opacity:.6}));\n    // brushed lines on the cap\n    for(var j=-26;j<=26;j+=3.2){\n      spin.appendChild(el(\"line\",{x1:50-Math.sqrt(900-j*j),y1:50+j,x2:50+Math.sqrt(900-j*j),y2:50+j,\n        stroke:\"rgba(255,255,255,.22)\",\"stroke-width\":.5}));\n    }\n    // the chicken-head pointer (a tapered wedge reaching past the cap)\n    spin.appendChild(el(\"path\",{d:\"M50 14 L57 47 L50 56 L43 47 Z\",fill:\"url(#point)\",\n      stroke:\"#243049\",\"stroke-width\":1,\"stroke-linejoin\":\"round\"}));\n    // tip jewel that glows in the accent\n    spin.appendChild(el(\"circle\",{cx:50,cy:19,r:3,fill:\"var(--ac)\",\n      style:\"filter:drop-shadow(0 0 4px var(--ac))\"}));\n    // hub\n    spin.appendChild(el(\"circle\",{cx:50,cy:50,r:6,fill:\"url(#hub)\",stroke:\"#1b2436\",\"stroke-width\":1}));\n    svg.appendChild(spin);\n\n    // gradient defs\n    g.innerHTML =\n      '<radialGradient id=\"steel\" cx=\"42%\" cy=\"34%\" r=\"75%\">'+\n        '<stop offset=\"0\" stop-color=\"#fbfdff\"/><stop offset=\".45\" stop-color=\"#cdd6e1\"/>'+\n        '<stop offset=\"1\" stop-color=\"#8794a6\"/></radialGradient>'+\n      '<radialGradient id=\"skirt\" cx=\"50%\" cy=\"42%\" r=\"62%\">'+\n        '<stop offset=\"0\" stop-color=\"#2b3650\"/><stop offset=\".7\" stop-color=\"#1b2438\"/>'+\n        '<stop offset=\"1\" stop-color=\"#0d131f\"/></radialGradient>'+\n      '<linearGradient id=\"point\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">'+\n        '<stop offset=\"0\" stop-color=\"#eef3fa\"/><stop offset=\"1\" stop-color=\"#9fb0c8\"/></linearGradient>'+\n      '<radialGradient id=\"hub\" cx=\"40%\" cy=\"35%\" r=\"70%\">'+\n        '<stop offset=\"0\" stop-color=\"#e9eef6\"/><stop offset=\"1\" stop-color=\"#5a6678\"/></radialGradient>';\n    return svg;\n  }\n\n  function mount(p,parent,delay){\n    var k=document.createElement(\"div\"); k.className=\"k\"; k.style.setProperty(\"--d\",delay+\"ms\");\n    var dw=document.createElement(\"div\"); dw.className=\"dialwrap\";\n    dw.appendChild(buildSvg());\n    var nm=document.createElement(\"div\"); nm.className=\"nm\"; nm.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    k.appendChild(dw); k.appendChild(nm); k.appendChild(val); parent.appendChild(k);\n\n    var value=p.def;\n    function norm(){return (value-p.min)/((p.max-p.min)||1);}\n    function paint(){\n      var n=norm(); dw.style.setProperty(\"--n\",n);\n      val.textContent=fmt(p,value);\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,value);\n    }\n    function setN(n){ n=n<0?0:n>1?1:n; value=p.min+(p.max-p.min)*n; paint(); }\n\n    var sy=0, sn=0, dragging=false;\n    dw.addEventListener(\"pointerdown\",function(e){\n      dragging=true; sy=e.clientY; sn=norm(); dw.classList.add(\"drag\");\n      dw.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    dw.addEventListener(\"pointermove\",function(e){\n      if(!dragging)return; var fine=e.shiftKey?700:220;\n      setN(sn+(sy-e.clientY)/fine);\n    });\n    function end(){dragging=false; dw.classList.remove(\"drag\");}\n    dw.addEventListener(\"pointerup\",end);\n    dw.addEventListener(\"pointercancel\",end);\n    dw.addEventListener(\"dblclick\",function(){value=p.def;paint();});\n    dw.addEventListener(\"wheel\",function(e){e.preventDefault();setN(norm()+(e.deltaY<0?.025:-.025));},{passive:false});\n\n    paint();\n  }\n\n  function ready(){\n    var low=document.getElementById(\"low\"), high=document.getElementById(\"high\"), d=0;\n    PARAMS.forEach(function(p){\n      mount(p, p.sec===\"low\"?low:high, d); d+=70;\n    });\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  VELVET EQ — passive program equalizer (vintage tube-EQ behaviour)\n//  A low-frequency band that can BOOST and ATTENUATE at the same time:\n//  the boost is a gentle low shelf, the cut is a low shelf a little above\n//  it, so dialling both gives the classic \"boost with a resonant dip just\n//  above\" curve. A high-frequency PEAK boost with a selectable centre adds\n//  air/presence, and an independent high SHELF attenuation tames the top.\n//  All curves are broad and gentle — built from stable RBJ biquads.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- parameter indices -------------------------------------------------\nconst P_LOW_FREQ:   i32 = 0; // 0..1 -> 20..160 Hz (low band centre)\nconst P_LOW_BOOST:  i32 = 1; // 0..1 -> low shelf boost   0..+14 dB\nconst P_LOW_ATTEN:  i32 = 2; // 0..1 -> low shelf cut     0..-16 dB (just above boost)\nconst P_HBOOST_FRQ: i32 = 3; // 0..1 -> 3..16 kHz (high boost peak centre)\nconst P_HIGH_BOOST: i32 = 4; // 0..1 -> high bell boost   0..+16 dB\nconst P_HIGH_ATTEN: i32 = 5; // 0..1 -> high shelf cut    0..-16 dB\n\nconst NUM_PARAMS: i32 = 6;\n\n// ---- three cascaded biquad stages, stereo state ------------------------\n// stage 0 = low shelf boost, 1 = low shelf cut, 2 = high bell boost,\n// 3 = high shelf cut.\nconst NUM_STAGES: i32 = 4;\n\n// coefficients (normalised, a0 = 1): b0 b1 b2 a1 a2 per stage\nconst b0c: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES);\nconst b1c: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES);\nconst b2c: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES);\nconst a1c: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES);\nconst a2c: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES);\n\n// direct-form-I state: x1 x2 y1 y2 per stage per channel\nconst x1s: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES * MAX_CHANNELS);\nconst x2s: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES * MAX_CHANNELS);\nconst y1s: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES * MAX_CHANNELS);\nconst y2s: StaticArray<f32> = new StaticArray<f32>(NUM_STAGES * MAX_CHANNELS);\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < NUM_STAGES * MAX_CHANNELS; i++) {\n    x1s[i] = 0.0; x2s[i] = 0.0; y1s[i] = 0.0; y2s[i] = 0.0;\n  }\n  for (let s = 0; s < NUM_STAGES; s++) {\n    b0c[s] = 1.0; b1c[s] = 0.0; b2c[s] = 0.0; a1c[s] = 0.0; a2c[s] = 0.0;\n  }\n  params[P_LOW_FREQ]   = 0.3;  // ~60 Hz\n  params[P_LOW_BOOST]  = 0.0;\n  params[P_LOW_ATTEN]  = 0.0;\n  params[P_HBOOST_FRQ] = 0.4;  // ~7 kHz\n  params[P_HIGH_BOOST] = 0.0;\n  params[P_HIGH_ATTEN] = 0.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return NUM_PARAMS; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// ---- RBJ biquad coefficient designers (normalised by a0) --------------\nfunction setLowShelf(stage: i32, freq: f32, gainDb: f32, slope: f32): void {\n  const A: f32 = f32(Mathf.pow(10.0, gainDb / 40.0));\n  let w0: f32 = f32(2.0 * PI * freq / sampleRate);\n  if (w0 > f32(PI * 0.99)) w0 = f32(PI * 0.99);\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  // shelf slope S in (0,1]; alpha guarded\n  let sq: f32 = (A + 1.0 / A) * (1.0 / slope - 1.0) + 2.0;\n  if (sq < 0.0) sq = 0.0;\n  const alpha: f32 = f32(sw / 2.0 * Mathf.sqrt(sq));\n  const tsa: f32 = f32(2.0 * Mathf.sqrt(A) * alpha);\n\n  const b0: f32 = f32(A * ((A + 1.0) - (A - 1.0) * cw + tsa));\n  const b1: f32 = f32(2.0 * A * ((A - 1.0) - (A + 1.0) * cw));\n  const b2: f32 = f32(A * ((A + 1.0) - (A - 1.0) * cw - tsa));\n  const a0: f32 = f32((A + 1.0) + (A - 1.0) * cw + tsa);\n  const a1: f32 = f32(-2.0 * ((A - 1.0) + (A + 1.0) * cw));\n  const a2: f32 = f32((A + 1.0) + (A - 1.0) * cw - tsa);\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n  b0c[stage] = b0 * inv; b1c[stage] = b1 * inv; b2c[stage] = b2 * inv;\n  a1c[stage] = a1 * inv; a2c[stage] = a2 * inv;\n}\n\nfunction setHighShelf(stage: i32, freq: f32, gainDb: f32, slope: f32): void {\n  const A: f32 = f32(Mathf.pow(10.0, gainDb / 40.0));\n  let w0: f32 = f32(2.0 * PI * freq / sampleRate);\n  if (w0 > f32(PI * 0.99)) w0 = f32(PI * 0.99);\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  let sq: f32 = (A + 1.0 / A) * (1.0 / slope - 1.0) + 2.0;\n  if (sq < 0.0) sq = 0.0;\n  const alpha: f32 = f32(sw / 2.0 * Mathf.sqrt(sq));\n  const tsa: f32 = f32(2.0 * Mathf.sqrt(A) * alpha);\n\n  const b0: f32 = f32(A * ((A + 1.0) + (A - 1.0) * cw + tsa));\n  const b1: f32 = f32(-2.0 * A * ((A - 1.0) + (A + 1.0) * cw));\n  const b2: f32 = f32(A * ((A + 1.0) + (A - 1.0) * cw - tsa));\n  const a0: f32 = f32((A + 1.0) - (A - 1.0) * cw + tsa);\n  const a1: f32 = f32(2.0 * ((A - 1.0) - (A + 1.0) * cw));\n  const a2: f32 = f32((A + 1.0) - (A - 1.0) * cw - tsa);\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n  b0c[stage] = b0 * inv; b1c[stage] = b1 * inv; b2c[stage] = b2 * inv;\n  a1c[stage] = a1 * inv; a2c[stage] = a2 * inv;\n}\n\nfunction setPeak(stage: i32, freq: f32, gainDb: f32, q: f32): void {\n  const A: f32 = f32(Mathf.pow(10.0, gainDb / 40.0));\n  let w0: f32 = f32(2.0 * PI * freq / sampleRate);\n  if (w0 > f32(PI * 0.99)) w0 = f32(PI * 0.99);\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const qg: f32 = q > 0.0001 ? q : 0.0001;\n  const alpha: f32 = f32(sw / (2.0 * qg));\n\n  const b0: f32 = f32(1.0 + alpha * A);\n  const b1: f32 = f32(-2.0 * cw);\n  const b2: f32 = f32(1.0 - alpha * A);\n  const a0: f32 = f32(1.0 + alpha / A);\n  const a1: f32 = f32(-2.0 * cw);\n  const a2: f32 = f32(1.0 - alpha / A);\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n  b0c[stage] = b0 * inv; b1c[stage] = b1 * inv; b2c[stage] = b2 * inv;\n  a1c[stage] = a1 * inv; a2c[stage] = a2 * inv;\n}\n\nfunction setBypass(stage: i32): void {\n  b0c[stage] = 1.0; b1c[stage] = 0.0; b2c[stage] = 0.0;\n  a1c[stage] = 0.0; a2c[stage] = 0.0;\n}\n\nexport function process(n: i32): void {\n  // ---- map params to musical ranges ----\n  const lowN:    f32 = clampf(params[P_LOW_FREQ], 0.0, 1.0);\n  const lowFreq: f32 = f32(20.0 + lowN * lowN * 140.0);      // 20..160 Hz\n  const lowBoostDb: f32 = clampf(params[P_LOW_BOOST], 0.0, 1.0) * 14.0;\n  const lowAttenDb: f32 = clampf(params[P_LOW_ATTEN], 0.0, 1.0) * 16.0;\n\n  const hbN:  f32 = clampf(params[P_HBOOST_FRQ], 0.0, 1.0);\n  const hbFreq: f32 = f32(3000.0 + hbN * hbN * 13000.0);     // 3..16 kHz\n  const highBoostDb: f32 = clampf(params[P_HIGH_BOOST], 0.0, 1.0) * 16.0;\n  const highAttenDb: f32 = clampf(params[P_HIGH_ATTEN], 0.0, 1.0) * 16.0;\n\n  // STAGE 0: low shelf BOOST at lowFreq (gentle, broad).\n  if (lowBoostDb > 0.001) setLowShelf(0, lowFreq, lowBoostDb, 0.5);\n  else setBypass(0);\n\n  // STAGE 1: low shelf CUT a little ABOVE the boost — this is the program-EQ\n  // trick: the dip sits just above the bump, giving the resonant low end.\n  const cutFreq: f32 = f32(clampf(lowFreq * 2.2, 30.0, 400.0));\n  if (lowAttenDb > 0.001) setLowShelf(1, cutFreq, -lowAttenDb, 0.55);\n  else setBypass(1);\n\n  // STAGE 2: high PEAK boost (broad bell) at selectable centre.\n  if (highBoostDb > 0.001) setPeak(2, hbFreq, highBoostDb, 0.9);\n  else setBypass(2);\n\n  // STAGE 3: high SHELF attenuation, fixed ~12 kHz, gentle.\n  if (highAttenDb > 0.001) setHighShelf(3, 12000.0, -highAttenDb, 0.5);\n  else setBypass(3);\n\n  // slight makeup compensation so simultaneous boosts don't run hot\n  const totalBoost: f32 = lowBoostDb + highBoostDb;\n  let makeup: f32 = f32(Mathf.pow(10.0, -0.18 * totalBoost / 20.0));\n  if (makeup < 0.25) makeup = 0.25;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    for (let f = 0; f < n; f++) {\n      let s: f32 = inBuf[base + f];\n      // cascade the four biquad stages\n      for (let st = 0; st < NUM_STAGES; st++) {\n        const si: i32 = st * MAX_CHANNELS + c;\n        const x0: f32 = s;\n        const y0: f32 = f32(\n          b0c[st] * x0 + b1c[st] * x1s[si] + b2c[st] * x2s[si]\n          - a1c[st] * y1s[si] - a2c[st] * y2s[si]\n        );\n        x2s[si] = x1s[si]; x1s[si] = x0;\n        y2s[si] = y1s[si]; y1s[si] = y0;\n        s = y0;\n      }\n      let o: f32 = f32(s * makeup);\n      // safety soft limit (transparent until very hot)\n      if (o > 1.6) o = 1.6;\n      else if (o < -1.6) o = -1.6;\n      outBuf[base + f] = o;\n    }\n  }\n}\n",
  "publishedAt": 1751000006000
}