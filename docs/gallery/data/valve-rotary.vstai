{
  "format": 1,
  "name": "Valve Rotary",
  "isInstrument": false,
  "explanation": "A full organ rotary-speaker chain fed by an overdriven tube preamp. A warm valve stage with grid bias adds second-harmonic warmth that grows into a growl as Drive rises, then feeds a twin-rotor rotating speaker: the signal is split into a bass-rotor and a treble horn band, each spun through its own virtual driver for amplitude tremolo plus a short Doppler pitch vibrato. The horn turns faster than the drum in opposite phase, and Speed morphs slow chorale to fast tremolo with inertia so the rotors ramp rather than jump. Controls: Speed, Drive, Depth, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Speed",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.85
    },
    {
      "name": "Drive",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Depth",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Valve Rotary</title>\n<style>\n  :root{\n    --accent:#ffb347;\n    --accent2:#a0764a;\n    --wood1:#5a3a23;\n    --wood2:#3a2415;\n    --wood3:#71492c;\n    --grille:#1a120b;\n    --glow:#ffb347;\n    --spin:1.7s;        /* horn rotation period, driven by Speed */\n    --drive:0.45;       /* tube glow intensity */\n    --depth:0.7;        /* wobble amount */\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none;}\n  html,body{margin:0;height:100%;}\n  body{\n    font-family:\"Avenir Next\",\"Segoe UI\",system-ui,sans-serif;\n    background:\n      radial-gradient(120% 80% at 50% -10%, #2a1d12 0%, #16100a 60%, #0c0805 100%);\n    color:#f3e0c4;\n    display:flex;align-items:center;justify-content:center;\n    min-height:100%;padding:18px;overflow:hidden;\n  }\n  .unit{\n    width:560px;border-radius:18px;position:relative;\n    padding:18px 20px 20px;\n    background:\n      linear-gradient(180deg,#23160d,#160d07);\n    box-shadow:0 30px 60px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,200,140,.08);\n    border:1px solid rgba(0,0,0,.6);\n  }\n  /* ---- header / nameplate ---- */\n  .head{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}\n  .brand{display:flex;flex-direction:column;line-height:1;}\n  .brand .nm{\n    font-weight:800;font-size:22px;letter-spacing:.14em;\n    color:#fff;text-shadow:0 0 14px rgba(255,179,71,.45);\n  }\n  .brand .nm b{color:var(--accent);}\n  .brand .sub{font-size:9.5px;letter-spacing:.32em;color:#b58e63;margin-top:5px;text-transform:uppercase;}\n  .plate{\n    font-size:10px;letter-spacing:.2em;color:#1a120b;\n    background:linear-gradient(180deg,#e8c98e,#b78a4f);\n    padding:5px 11px;border-radius:5px;font-weight:800;\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.5),0 2px 5px rgba(0,0,0,.5);\n  }\n\n  /* ===== the cabinet ===== */\n  .cab{\n    position:relative;height:236px;border-radius:14px;overflow:hidden;\n    background:\n      repeating-linear-gradient(96deg,\n        var(--wood2) 0px, var(--wood3) 7px, var(--wood1) 13px, var(--wood2) 20px),\n      linear-gradient(180deg,#6b4427,#3a2415);\n    box-shadow:inset 0 0 36px rgba(0,0,0,.7), 0 4px 14px rgba(0,0,0,.5);\n    border:3px solid #2a1809;\n    padding:14px;\n    display:flex;gap:14px;\n  }\n  .cab::after{ /* lacquer sheen */\n    content:\"\";position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(115deg,rgba(255,235,200,.10) 0%,transparent 28%,transparent 72%,rgba(0,0,0,.22) 100%);\n  }\n\n  /* upper louvre = horn rotor compartment / lower = bass drum */\n  .bay{\n    position:relative;flex:1;border-radius:9px;overflow:hidden;\n    background:\n      radial-gradient(circle at 50% 42%, #2c2114, #120c06 75%);\n    box-shadow:inset 0 0 22px rgba(0,0,0,.85), inset 0 0 0 2px rgba(0,0,0,.5);\n  }\n  /* horizontal grille slats */\n  .grille{\n    position:absolute;inset:0;pointer-events:none;z-index:6;\n    background:repeating-linear-gradient(0deg,\n      rgba(0,0,0,.0) 0px, rgba(0,0,0,.0) 5px,\n      rgba(10,7,4,.78) 5px, rgba(10,7,4,.78) 8px);\n  }\n  .grille::before{ /* cloth weave */\n    content:\"\";position:absolute;inset:0;opacity:.4;\n    background:\n      repeating-linear-gradient(90deg,rgba(0,0,0,.35) 0 1px,transparent 1px 3px);\n  }\n\n  /* ---- spinning HORN rotor (top bay) ---- */\n  .horn-stage{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:3;}\n  .horn-rot{\n    width:150px;height:150px;position:relative;\n    transform-style:preserve-3d;\n    animation:spin var(--spin) linear infinite;\n  }\n  /* the dual horn — two trumpets back to back */\n  .horn{\n    position:absolute;top:50%;left:50%;width:78px;height:30px;\n    transform-origin:left center;\n    border-radius:0 60% 60% 0 / 0 50% 50% 0;\n    background:linear-gradient(180deg,#ffce8a,#c98a3f 55%,#7c4f23);\n    box-shadow:0 0 16px rgba(255,179,71,.55), inset 0 2px 4px rgba(255,255,255,.4), inset 0 -3px 6px rgba(0,0,0,.4);\n  }\n  .horn.a{transform:translate(-2px,-50%) rotate(0deg) scaleX(1);}\n  .horn.b{transform:translate(-2px,-50%) rotate(180deg) scaleX(1);}\n  .horn-hub{\n    position:absolute;top:50%;left:50%;width:22px;height:22px;\n    transform:translate(-50%,-50%);border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff2d8,#9c6a32 70%,#3a2412);\n    box-shadow:0 0 10px rgba(255,179,71,.6),inset 0 -2px 3px rgba(0,0,0,.5);\n    z-index:2;\n  }\n  /* motion-blur swirl behind the horn */\n  .swirl{\n    position:absolute;top:50%;left:50%;width:168px;height:168px;\n    transform:translate(-50%,-50%);border-radius:50%;\n    background:conic-gradient(from 0deg,\n      rgba(255,179,71,.0),rgba(255,179,71,.30),rgba(255,179,71,.0) 40%,\n      rgba(255,179,71,.22),rgba(255,179,71,.0) 80%);\n    filter:blur(7px);opacity:.85;z-index:1;\n    animation:spin calc(var(--spin) * .85) linear infinite;\n  }\n\n  /* ---- spinning BASS rotor (bottom bay) ---- */\n  .drum-stage{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;z-index:3;}\n  .drum-rot{\n    width:188px;height:118px;position:relative;\n    animation:spin calc(var(--spin) * 1.16) linear infinite reverse;\n  }\n  .drum{\n    position:absolute;top:50%;left:50%;width:182px;height:62px;\n    transform:translate(-50%,-50%);border-radius:50%;\n    background:\n      linear-gradient(90deg,#1c130a 0%,#5a3c20 18%,#caa066 50%,#5a3c20 82%,#1c130a 100%);\n    box-shadow:inset 0 4px 10px rgba(255,220,170,.25),inset 0 -6px 12px rgba(0,0,0,.6),0 0 18px rgba(0,0,0,.5);\n  }\n  .drum-port{ /* the scoop opening */\n    position:absolute;top:50%;left:14px;width:54px;height:40px;\n    transform:translateY(-50%);border-radius:50% 8px 8px 50%;\n    background:radial-gradient(circle at 70% 50%,#3a2614,#0d0804);\n    box-shadow:inset 0 0 12px rgba(0,0,0,.9);\n  }\n\n  /* ---- glowing overdriven TUBE behind the grille (top bay) ---- */\n  .tube{\n    position:absolute;right:12px;top:50%;transform:translateY(-50%);\n    width:30px;height:96px;border-radius:14px;z-index:2;\n    background:linear-gradient(180deg,rgba(60,40,24,.5),rgba(20,12,6,.6));\n    border:1px solid rgba(255,200,140,.18);\n    box-shadow:inset 0 0 14px rgba(0,0,0,.6);\n    overflow:hidden;\n  }\n  .tube .filament{\n    position:absolute;left:50%;top:14px;bottom:14px;width:5px;\n    transform:translateX(-50%);border-radius:3px;\n    background:linear-gradient(180deg,#fff,var(--accent),#ff7a1e);\n    box-shadow:0 0 calc(8px + var(--drive)*26px) calc(2px + var(--drive)*9px) rgba(255,150,50,calc(.35 + var(--drive)*.6));\n    opacity:calc(.4 + var(--drive)*.6);\n    animation:flicker calc(.18s + (1 - var(--drive))*.5s) ease-in-out infinite alternate;\n  }\n  .tube .heat{\n    position:absolute;inset:0;border-radius:14px;\n    background:radial-gradient(circle at 50% 50%,rgba(255,140,40,calc(var(--drive)*.55)),transparent 70%);\n  }\n\n  /* ---- mic + status dot ---- */\n  .badge{\n    position:absolute;left:10px;bottom:8px;z-index:7;font-size:8px;letter-spacing:.18em;\n    color:rgba(255,210,160,.55);text-transform:uppercase;\n  }\n\n  /* ===== control deck ===== */\n  .deck{\n    display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-top:16px;\n  }\n  .pot{display:flex;flex-direction:column;align-items:center;gap:7px;\n    opacity:0;transform:translateY(8px);animation:rise .5s ease forwards;animation-delay:var(--d);}\n  .knob{\n    width:74px;height:74px;border-radius:50%;position:relative;cursor:grab;outline:none;\n    touch-action:none;\n    transition:transform .12s ease;\n  }\n  .knob:active{cursor:grabbing;}\n  .knob.act{transform:scale(1.06);}\n  .knob .skirt{\n    position:absolute;inset:0;border-radius:50%;\n    background:\n      radial-gradient(circle at 38% 32%,#4a3320,#241509 70%);\n    box-shadow:0 6px 14px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,210,150,.18);\n  }\n  .knob .arc{\n    position:absolute;inset:-6px;border-radius:50%;\n    background:conic-gradient(from 130deg,\n      var(--accent) 0turn,\n      var(--accent2) calc(var(--n)*0.72turn),\n      rgba(255,255,255,.06) calc(var(--n)*0.72turn),\n      rgba(255,255,255,.06) 0.72turn,\n      transparent 0.72turn);\n    -webkit-mask:radial-gradient(circle, transparent 33px, #000 34px, #000 38px, transparent 39px);\n    mask:radial-gradient(circle, transparent 33px, #000 34px, #000 38px, transparent 39px);\n    filter:drop-shadow(0 0 5px rgba(255,179,71,.5));\n  }\n  .knob .cap{\n    position:absolute;inset:13px;border-radius:50%;\n    background:\n      radial-gradient(circle at 40% 30%,#7a542e,#3a2412 72%);\n    box-shadow:inset 0 2px 4px rgba(255,220,170,.25),inset 0 -4px 8px rgba(0,0,0,.6);\n  }\n  .knob .ptr{\n    position:absolute;left:50%;top:50%;width:3px;height:24px;border-radius:2px;\n    background:linear-gradient(180deg,var(--accent),#fff);\n    transform-origin:50% 100%;\n    transform:translate(-50%,-100%) rotate(calc((var(--n)*260deg) - 130deg));\n    box-shadow:0 0 7px rgba(255,179,71,.8);\n  }\n  .pname{font-size:10px;letter-spacing:.22em;color:#d9b483;text-transform:uppercase;}\n  .pval{font-size:11px;font-weight:700;color:var(--accent);font-variant-numeric:tabular-nums;\n    text-shadow:0 0 8px rgba(255,179,71,.4);}\n\n  /* speed rocker — visual chorale/tremolo indicator */\n  .foot{display:flex;align-items:center;justify-content:center;gap:14px;margin-top:12px;font-size:9px;letter-spacing:.2em;color:#8d6a45;text-transform:uppercase;}\n  .foot .lamp{width:9px;height:9px;border-radius:50%;background:#3a2614;box-shadow:inset 0 0 3px #000;}\n  .foot .lamp.on{background:var(--accent);box-shadow:0 0 9px var(--accent);}\n\n  @keyframes spin{to{transform:rotate(360deg);}}\n  .horn-rot{animation-name:spin;}\n  @keyframes rise{to{opacity:1;transform:none;}}\n  @keyframes flicker{\n    0%{opacity:calc(.35 + var(--drive)*.55);}\n    100%{opacity:calc(.55 + var(--drive)*.45);}\n  }\n  /* subtle whole-cab wobble scales with Depth */\n  .cab{animation:wob calc(var(--spin)*1) ease-in-out infinite;}\n  @keyframes wob{\n    0%,100%{transform:translateX(calc(var(--depth)*-1.5px));}\n    50%{transform:translateX(calc(var(--depth)*1.5px));}\n  }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"nm\">VALVE <b>ROTARY</b></div>\n        <div class=\"sub\">Tube Preamp · Rotating Speaker</div>\n      </div>\n      <div class=\"plate\">147&nbsp;·&nbsp;TWIN&nbsp;ROTOR</div>\n    </div>\n\n    <div class=\"cab\">\n      <!-- TOP bay: horn rotor + glowing tube -->\n      <div class=\"bay\">\n        <div class=\"horn-stage\">\n          <div class=\"swirl\"></div>\n          <div class=\"horn-rot\">\n            <span class=\"horn a\"></span>\n            <span class=\"horn b\"></span>\n            <span class=\"horn-hub\"></span>\n          </div>\n        </div>\n        <div class=\"tube\"><span class=\"filament\"></span><span class=\"heat\"></span></div>\n        <div class=\"grille\"></div>\n        <div class=\"badge\">Horn 800Hz↑</div>\n      </div>\n      <!-- BOTTOM-style bay rendered to the right: bass drum -->\n      <div class=\"bay\">\n        <div class=\"drum-stage\">\n          <div class=\"drum-rot\">\n            <span class=\"drum\"></span>\n            <span class=\"drum-port\"></span>\n          </div>\n        </div>\n        <div class=\"grille\"></div>\n        <div class=\"badge\">Bass Rotor</div>\n      </div>\n    </div>\n\n    <div class=\"deck\" id=\"deck\"></div>\n\n    <div class=\"foot\">\n      <span class=\"lamp\" id=\"lampSlow\"></span> Chorale\n      <span style=\"opacity:.4\">— ramp —</span>\n      Tremolo <span class=\"lamp\" id=\"lampFast\"></span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Speed\",index:0,min:0,max:1,def:0.85},\n    {name:\"Drive\",index:1,min:0,max:1,def:0.45},\n    {name:\"Depth\",index:2,min:0,max:1,def:0.7},\n    {name:\"Tone\", index:3,min:0,max:1,def:0.55},\n    {name:\"Mix\",  index:4,min:0,max:1,def:1}\n  ];\n  var state={};\n  var root=document.documentElement.style;\n  var deck=document.getElementById('deck');\n  var lampSlow=document.getElementById('lampSlow');\n  var lampFast=document.getElementById('lampFast');\n\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n\n  function applyVisuals(){\n    var speed=state[0]!=null?state[0]:0.85;\n    var drive=state[1]!=null?state[1]:0.45;\n    var depth=state[2]!=null?state[2]:0.7;\n    // rotor period: slow ~2.6s (chorale) -> fast ~0.45s (tremolo)\n    var period=2.6 - speed*2.15;\n    root.setProperty('--spin', period.toFixed(3)+'s');\n    root.setProperty('--drive', drive.toFixed(3));\n    root.setProperty('--depth', depth.toFixed(3));\n    lampSlow.classList.toggle('on', speed<0.4);\n    lampFast.classList.toggle('on', speed>0.6);\n  }\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*70)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\" role=\"slider\" aria-label=\"'+p.name+'\">'+\n        '<i class=\"skirt\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      knob.style.setProperty('--n',n);\n      val.textContent=pct(n);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      applyVisuals();\n    }\n    function setNorm(n){\n      n=n<0?0:n>1?1:n;\n      v=p.min+(p.max-p.min)*n;\n      paint();\n    }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true;startY=e.clientY;startN=norm();\n      knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?600:200;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){ drag=false;knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def;paint(); });\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ applyVisuals(); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VALVE ROTARY — overdriven tube preamp into a rotating-speaker chain\n//  The full gritty organ chain: a warm TUBE PREAMP (asymmetric soft-clip\n//  with grid bias + a little second-harmonic warmth) that can be pushed\n//  from clean into growling overdrive, FEEDING a twin-rotor rotating\n//  speaker. The signal is split into a bass-rotor (drum) band and a\n//  treble horn band; each spins through its own virtual driver producing\n//  amplitude tremolo PLUS a short Doppler pitch vibrato via a modulated\n//  delay line. Horn spins faster than the drum, in opposite phase. A\n//  Speed control morphs slow (chorale) <-> fast (tremolo) and the rotor\n//  rates RAMP with inertia — they never jump — so the swirl audibly\n//  accelerates and decelerates. Two virtual mics build the stereo image.\n//  Distinct from the clean Rotary Cabinet: here a saturating valve stage\n//  sits IN FRONT of the rotors, so the swirl rides on top of the grit.\n//  Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\n// ---- parameter map (indices MUST match spec.json) --------------------\nconst P_SPEED: i32 = 0;  // 0..1  -> slow (chorale) .. fast (tremolo), ramped\nconst P_DRIVE: i32 = 1;  // 0..1  -> tube preamp grit (clean .. growling)\nconst P_DEPTH: i32 = 2;  // 0..1  -> amount of Doppler vibrato + AM tremolo\nconst P_TONE:  i32 = 3;  // 0..1  -> dark .. bright (post tube tilt)\nconst P_MIX:   i32 = 4;  // 0..1  -> dry/wet\n\n// ---- target rotor rates (Hz) -----------------------------------------\nconst HORN_SLOW: f32 = 0.80;\nconst HORN_FAST: f32 = 6.90;\nconst DRUM_SLOW: f32 = 0.65;\nconst DRUM_FAST: f32 = 5.90;\n\n// ---- modulated delay lines for the Doppler vibrato -------------------\nconst DELAY_LEN: i32 = 2048;            // > 12 ms @ 48k\nconst hornDelay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst drumDelay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nlet dWrite: i32 = 0;\n\n// ---- crossover state (2x one-pole = ~12 dB/oct) ----------------------\nconst lpA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lpB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// ---- tube preamp filter state ----------------------------------------\nlet preHP: f32 = 0.0;    // pre-clip DC/low blocker\nlet toneLP: f32 = 0.0;   // post-tube tone tilt low-pass\nlet dcBlock: f32 = 0.0;  // remove the bias DC after asymmetric clip\nlet dcPrev: f32 = 0.0;\n\n// ---- rotor phase + smoothed (inertial) rate state --------------------\nlet hornPhase: f32 = 0.0;\nlet drumPhase: f32 = 0.25;\nlet hornRate:  f32 = HORN_SLOW;\nlet drumRate:  f32 = DRUM_SLOW;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// asymmetric valve-style saturation: a tanh-ish soft clip with grid bias\n// so positive and negative excursions clip differently -> 2nd harmonic\n// warmth that grows into a growl as drive rises.\n@inline function valve(x: f32): f32 {\n  // grid bias shifts the operating point; clamp keeps it bounded\n  const b: f32 = x + 0.18;\n  // rational tanh approximation, cheap and smooth, saturates to ~±1\n  const c: f32 = clampf(b, -3.0, 3.0);\n  const num: f32 = c * (27.0 + c * c);\n  const den: f32 = 27.0 + 9.0 * c * c;\n  return num / den;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  for (let c = 0; c < MAX_CHANNELS; c++) { lpA[c] = 0.0; lpB[c] = 0.0; }\n  for (let i = 0; i < DELAY_LEN; i++) { hornDelay[i] = 0.0; drumDelay[i] = 0.0; }\n  dWrite = 0;\n  preHP = 0.0; toneLP = 0.0; dcBlock = 0.0; dcPrev = 0.0;\n  hornPhase = 0.0;\n  drumPhase = 0.25;\n  hornRate = HORN_SLOW;\n  drumRate = DRUM_SLOW;\n\n  params[P_SPEED] = 0.85;  // start near fast so the spin-up ramp is obvious\n  params[P_DRIVE] = 0.45;\n  params[P_DEPTH] = 0.7;\n  params[P_TONE]  = 0.55;\n  params[P_MIX]   = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// fractional read from a delay line, `back` samples behind the write head\n@inline function tapDelay(line: StaticArray<f32>, back: f32): f32 {\n  let bk: f32 = back;\n  if (bk < 1.0) bk = 1.0;\n  if (bk > f32(DELAY_LEN - 2)) bk = f32(DELAY_LEN - 2);\n  let rp: f32 = f32(dWrite) - bk;\n  if (rp < 0.0) rp += f32(DELAY_LEN);\n  if (rp < 0.0) rp = 0.0;\n  let i0: i32 = i32(rp);\n  if (i0 < 0) i0 = 0;\n  if (i0 >= DELAY_LEN) i0 = DELAY_LEN - 1;\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 -= DELAY_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const speed: f32 = clampf(params[P_SPEED], 0.0, 1.0);\n  const drive: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const depth: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE],  0.0, 1.0);\n  const mix:   f32 = clampf(params[P_MIX],   0.0, 1.0);\n\n  // --- tube preamp drive: 1..18x into the valve, gain-compensated -----\n  const preGain: f32 = 1.0 + drive * drive * 17.0;\n  const comp: f32 = 1.0 / f32(Mathf.sqrt(1.0 + drive * 2.4));   // tame loudness\n\n  // pre-clip HP ~70 Hz so the bass rotor doesn't get muddy in the valve\n  const cHP: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 70.0 / sampleRate));\n  // post-tube tone tilt: 1.2 kHz (dark) .. 9 kHz (bright)\n  const toneHz: f32 = 1200.0 + toneN * toneN * 7800.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  // DC blocker coefficient (removes the asymmetric bias offset)\n  const dcR: f32 = f32(1.0 - TWO_PI * 12.0 / sampleRate);\n\n  // --- target rotor rates from Speed (linear morph slow<->fast) -------\n  const hornTarget: f32 = HORN_SLOW + (HORN_FAST - HORN_SLOW) * speed;\n  const drumTarget: f32 = DRUM_SLOW + (DRUM_FAST - DRUM_SLOW) * speed;\n\n  // --- inertia: fixed authentic ramp (~0.9 s horn, heavier drum) ------\n  const rampSec: f32 = 0.9;\n  const hornGlide: f32 = f32(1.0 - Mathf.exp(-1.0 / (rampSec * sampleRate)));\n  const drumGlide: f32 = f32(1.0 - Mathf.exp(-1.0 / (rampSec * 1.7 * sampleRate)));\n\n  // --- crossover coefficient (~760 Hz horn/drum split) ----------------\n  const xc: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 760.0 / sampleRate));\n\n  // --- Doppler delay swing (samples). Depth scales the excursion. -----\n  const hornSwing: f32 = depth * 0.0019 * sampleRate;  // up to ~1.9 ms each way\n  const drumSwing: f32 = depth * 0.0011 * sampleRate;  // up to ~1.1 ms each way\n  const baseDelay: f32 = 0.004 * sampleRate;           // 4 ms standing delay\n\n  // --- amplitude tremolo depth ---------------------------------------\n  const amDepth: f32 = depth * 0.55;\n\n  const inc: f32 = TWO_PI / sampleRate;\n\n  let hp: f32 = hornPhase;\n  let dp: f32 = drumPhase;\n  let hr: f32 = hornRate;\n  let dr: f32 = drumRate;\n  let pHP: f32 = preHP;\n  let tLP: f32 = toneLP;\n  let dcb: f32 = dcBlock;\n  let dcp: f32 = dcPrev;\n\n  for (let f = 0; f < n; f++) {\n    // --- glide rotor rates toward target (inertia) ---\n    hr += hornGlide * (hornTarget - hr);\n    dr += drumGlide * (drumTarget - dr);\n\n    // --- advance rotor phases ---\n    hp += inc * hr; if (hp >= TWO_PI) hp -= TWO_PI;\n    dp += inc * dr; if (dp >= TWO_PI) dp -= TWO_PI;\n\n    // --- mono input feed (a rotary cab is one driver chain) ---\n    const xl: f32 = inBuf[f];\n    const xr: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : xl;\n    const mono: f32 = (xl + xr) * 0.5;\n\n    // ============ TUBE PREAMP STAGE ============\n    pHP = pHP + cHP * (mono - pHP);\n    const clean: f32 = mono - pHP;             // high-passed into the valve\n    const driven: f32 = valve(clean * preGain) * comp;\n    // DC block to remove the asymmetric bias offset\n    const blocked: f32 = driven - dcp + dcR * dcb;\n    dcp = driven;\n    dcb = blocked;\n    // post-tube tone tilt\n    tLP = tLP + cTone * (blocked - tLP);\n    // blend a touch of the brightened top back for sparkle\n    const pre: f32 = tLP + (blocked - tLP) * 0.35;\n\n    // ============ ROTARY SPEAKER STAGE ============\n    // 2-pole crossover split of the preamp output\n    let la: f32 = lpA[0]; let lb: f32 = lpB[0];\n    la = la + xc * (pre - la);\n    lb = lb + xc * (la - lb);\n    lpA[0] = la; lpB[0] = lb;\n    const low: f32 = lb;            // bass rotor band\n    const high: f32 = pre - lb;     // horn band\n\n    // write bands into delay lines\n    hornDelay[dWrite] = high;\n    drumDelay[dWrite] = low;\n\n    // Doppler taps swing with rotor phase\n    const hSin: f32 = Mathf.sin(hp);\n    const hCos: f32 = Mathf.cos(hp);\n    const dSin: f32 = Mathf.sin(dp);\n    const dCos: f32 = Mathf.cos(dp);\n\n    const hornBack: f32 = baseDelay + hornSwing * (1.0 + hSin);\n    const drumBack: f32 = baseDelay + drumSwing * (1.0 + dSin);\n\n    const hornWet: f32 = tapDelay(hornDelay, hornBack);\n    const drumWet: f32 = tapDelay(drumDelay, drumBack);\n\n    // amplitude tremolo (driver facing the mic = louder)\n    const hornAM: f32 = 1.0 - amDepth * (0.5 - 0.5 * hCos);\n    const drumAM: f32 = 1.0 - (amDepth * 0.7) * (0.5 - 0.5 * dCos);\n\n    const hornS: f32 = hornWet * hornAM;\n    const drumS: f32 = drumWet * drumAM;\n\n    // two virtual mics: horn & drum pan in opposition -> swirling image\n    const hornPan: f32 = 0.85 * hCos;\n    const drumPan: f32 = -0.65 * dCos;\n\n    const hornL: f32 = hornS * (0.5 - 0.5 * hornPan);\n    const hornR: f32 = hornS * (0.5 + 0.5 * hornPan);\n    const drumL: f32 = drumS * (0.5 - 0.5 * drumPan);\n    const drumR: f32 = drumS * (0.5 + 0.5 * drumPan);\n\n    let wetL: f32 = (hornL + drumL) * 1.4;\n    let wetR: f32 = (hornR + drumR) * 1.4;\n\n    // dry/wet\n    const outL: f32 = xl * (1.0 - mix) + wetL * mix;\n    const outR: f32 = xr * (1.0 - mix) + wetR * mix;\n\n    outBuf[f] = clampf(outL, -0.98, 0.98);\n    outBuf[MAX_FRAMES + f] = clampf(outR, -0.98, 0.98);\n\n    dWrite++; if (dWrite >= DELAY_LEN) dWrite = 0;\n  }\n\n  hornPhase = hp;\n  drumPhase = dp;\n  hornRate = hr;\n  drumRate = dr;\n  preHP = pHP;\n  toneLP = tLP;\n  dcBlock = dcb;\n  dcPrev = dcp;\n}\n",
  "publishedAt": 1751000137000
}