{
  "format": 1,
  "name": "Jove Eight",
  "isInstrument": true,
  "explanation": "A lush eight-voice analog-style polyphonic synthesizer in the flagship-poly lineage. Each voice stacks TWO oscillators (a band-limited saw and a variable-width pulse with slow PWM) plus a sub-oscillator one octave down, spread by a subtle unison detune for the big stacked-string-pad character. The mixed oscillators feed a resonant 24 dB/oct low-pass driven by its own envelope (Cutoff, Env Amount, Resonance), then an amplitude envelope. Chords ring with independent contours. Controls: Cutoff, Resonance, Env Amount, PW, Detune, Attack, Release and Level.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "EnvAmount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "PW",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.32
    },
    {
      "name": "Attack",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.08
    },
    {
      "name": "Release",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Jove Eight</title><style>\n@property --sweep{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --ac:#6a8cff; --ac2:#b06aff;\n  --panel0:#171436; --panel1:#241a52; --panel2:#0c0a22;\n  --ink:#dfe4ff; --dim:#8b91c8; --line:rgba(150,160,255,.16);\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:12px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:var(--ink);\n  background:radial-gradient(130% 110% at 50% -20%,#1a163d 0%,#0a0820 55%,#05040f 100%);\n  display:flex;align-items:center;justify-content:center;padding:16px;\n  -webkit-font-smoothing:antialiased;overflow:hidden;\n}\n\n/* ============ flagship chassis ============ */\n.synth{\n  position:relative;width:100%;max-width:820px;border-radius:16px;padding:2px;\n  background:linear-gradient(150deg,#3a3170,#171338 60%,#0c0a22);\n  box-shadow:0 40px 90px rgba(0,0,0,.65),0 2px 0 rgba(180,190,255,.10) inset,0 -3px 16px rgba(0,0,0,.6) inset;\n  animation:rise .8s cubic-bezier(.2,.85,.2,1) both;\n  overflow:hidden;\n}\n@keyframes rise{from{opacity:0;transform:translateY(26px) scale(.98)}to{opacity:1;transform:none}}\n.surface{\n  position:relative;border-radius:14px;overflow:hidden;\n  background:linear-gradient(180deg,var(--panel1) 0%,var(--panel0) 46%,var(--panel2) 100%);\n  box-shadow:0 1px 0 rgba(180,190,255,.14) inset,0 0 0 1px rgba(120,130,255,.12);\n}\n\n/* ---- aurora / starfield backdrop ---- */\n.aurora{position:absolute;inset:0;z-index:0;pointer-events:none;overflow:hidden}\n.aurora::before{\n  content:\"\";position:absolute;inset:-30% -10%;\n  background:\n    radial-gradient(40% 30% at 22% 20%,rgba(106,140,255,.30),transparent 70%),\n    radial-gradient(45% 32% at 78% 12%,rgba(176,106,255,.26),transparent 72%),\n    radial-gradient(60% 40% at 50% 110%,rgba(106,140,255,.18),transparent 70%);\n  filter:blur(8px);\n  animation:drift 14s ease-in-out infinite alternate;\n}\n@keyframes drift{0%{transform:translate3d(-4%,-2%,0) rotate(-2deg)}100%{transform:translate3d(4%,3%,0) rotate(2deg)}}\n.aurora .sweep{\n  position:absolute;top:0;bottom:0;width:38%;left:-40%;\n  background:linear-gradient(100deg,transparent,rgba(190,200,255,.10) 40%,rgba(220,210,255,.18) 50%,transparent);\n  filter:blur(2px);\n  animation:scan 7s linear infinite;\n}\n@keyframes scan{0%{left:-40%}100%{left:130%}}\n.stars{position:absolute;inset:0;opacity:.55}\n.stars i{position:absolute;width:2px;height:2px;border-radius:50%;background:#cfd6ff;\n  box-shadow:0 0 5px #aab4ff;animation:tw 3.4s ease-in-out infinite}\n@keyframes tw{0%,100%{opacity:.18;transform:scale(.7)}50%{opacity:.95;transform:scale(1.15)}}\n\n/* ---- header / brand ---- */\n.head{position:relative;z-index:3;display:flex;align-items:flex-end;gap:16px;\n  padding:18px 24px 14px;border-bottom:1px solid var(--line)}\n.brand{display:flex;flex-direction:column;line-height:1}\n.brand .mk{font-size:9px;letter-spacing:.46em;color:var(--dim);font-weight:800;text-transform:uppercase}\n.brand h1{margin:5px 0 0;font-size:27px;font-weight:900;letter-spacing:.06em;\n  background:linear-gradient(92deg,var(--ac),var(--ac2));-webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 0 22px rgba(140,140,255,.35)}\n.brand .tag{font-size:9px;letter-spacing:.34em;color:var(--dim);text-transform:uppercase;margin-top:5px}\n\n/* ---- 8 voltage voice-bars ---- */\n.voices{margin-left:auto;display:flex;flex-direction:column;align-items:flex-end;gap:8px}\n.voices .vlbl{font-size:8px;letter-spacing:.4em;color:var(--dim);text-transform:uppercase;font-weight:800}\n.bank{display:flex;gap:7px;padding:9px 11px;border-radius:11px;\n  background:linear-gradient(180deg,#0c0a26,#06051a);\n  box-shadow:0 1px 0 rgba(160,170,255,.10) inset,0 -2px 7px rgba(0,0,0,.6) inset,0 3px 9px rgba(0,0,0,.45)}\n.vbar{position:relative;width:9px;height:42px;border-radius:5px;overflow:hidden;\n  background:linear-gradient(180deg,#1a1740,#0a0824);\n  box-shadow:0 1px 1px rgba(0,0,0,.6) inset,0 1px 0 rgba(160,170,255,.08)}\n.vbar .fill{position:absolute;left:1px;right:1px;bottom:1px;height:18%;border-radius:4px;\n  background:linear-gradient(180deg,var(--ac2),var(--ac));\n  box-shadow:0 0 9px var(--ac),0 0 16px var(--ac2);\n  transition:height .14s cubic-bezier(.3,1,.4,1),opacity .3s;opacity:.35}\n.vbar.lit .fill{opacity:1}\n\n/* ---- main body grid ---- */\n.body{position:relative;z-index:3;padding:20px 24px 22px;\n  display:grid;grid-template-columns:repeat(8,1fr);gap:16px 18px}\n.sect{grid-column:span 2;display:flex;flex-direction:column;gap:13px}\n.sect.osc{grid-column:span 2}\n.sect.flt{grid-column:span 3}\n.sect.amp{grid-column:span 3}\n.shdr{font-size:8.5px;letter-spacing:.34em;color:var(--dim);text-transform:uppercase;font-weight:800;\n  display:flex;align-items:center;gap:8px}\n.shdr::after{content:\"\";flex:1;height:1px;background:linear-gradient(90deg,var(--line),transparent)}\n.row{display:flex;gap:18px;flex-wrap:wrap}\n\n/* ============ slider control ============ */\n.ctl{display:flex;flex-direction:column;align-items:center;gap:7px;user-select:none;width:58px}\n.ctl .name{font-size:9px;letter-spacing:.16em;color:var(--dim);text-transform:uppercase;font-weight:700}\n.ctl .val{font-size:10px;font-weight:800;color:var(--ink);font-variant-numeric:tabular-nums;\n  text-shadow:0 0 8px rgba(120,140,255,.4)}\n.slider{position:relative;width:30px;height:124px;border-radius:9px;cursor:ns-resize;touch-action:none;\n  background:linear-gradient(180deg,#0c0a26,#070518);\n  box-shadow:0 1px 0 rgba(160,170,255,.10) inset,0 -2px 6px rgba(0,0,0,.6) inset,0 2px 6px rgba(0,0,0,.4)}\n.slider .track{position:absolute;left:50%;top:9px;bottom:9px;width:4px;transform:translateX(-50%);border-radius:3px;\n  background:linear-gradient(180deg,#1c1948,#0a0824);overflow:hidden}\n.slider .lit{position:absolute;left:0;right:0;bottom:0;border-radius:3px;\n  background:linear-gradient(180deg,var(--ac2),var(--ac));\n  box-shadow:0 0 8px var(--ac),0 0 14px var(--ac2)}\n.slider .cap{position:absolute;left:50%;width:24px;height:13px;transform:translate(-50%,50%);border-radius:4px;\n  background:linear-gradient(180deg,#e8ecff,#9aa6e6);\n  box-shadow:0 2px 5px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.4) inset,0 0 12px rgba(130,150,255,.5);\n  transition:box-shadow .15s}\n.slider .cap::after{content:\"\";position:absolute;left:4px;right:4px;top:50%;height:2px;transform:translateY(-50%);\n  border-radius:2px;background:rgba(40,40,90,.55)}\n.slider:hover .cap{box-shadow:0 2px 6px rgba(0,0,0,.55),0 0 0 1px rgba(255,255,255,.6) inset,0 0 18px rgba(150,170,255,.8)}\n.slider.drag .cap{box-shadow:0 2px 7px rgba(0,0,0,.6),0 0 0 1px #fff inset,0 0 22px var(--ac)}\n.slider.drag{box-shadow:0 1px 0 rgba(160,170,255,.10) inset,0 -2px 6px rgba(0,0,0,.6) inset,0 0 16px rgba(106,140,255,.4)}\n\n/* tick marks on the rail */\n.slider .ticks{position:absolute;right:3px;top:9px;bottom:9px;width:6px;display:flex;flex-direction:column;justify-content:space-between}\n.slider .ticks i{height:1px;background:rgba(170,180,255,.22)}\n\n/* footer */\n.foot{position:relative;z-index:3;display:flex;align-items:center;gap:10px;\n  padding:10px 24px 16px;border-top:1px solid var(--line);color:var(--dim);font-size:9px;letter-spacing:.22em;text-transform:uppercase}\n.foot .dot{width:7px;height:7px;border-radius:50%;background:var(--ac);box-shadow:0 0 9px var(--ac);\n  animation:pulse 2.4s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:.5;transform:scale(.85)}50%{opacity:1;transform:scale(1.1)}}\n.foot .sp{margin-left:auto}\n</style></head>\n<body>\n<div class=\"synth\"><div class=\"surface\">\n  <div class=\"aurora\"><div class=\"sweep\"></div><div class=\"stars\" id=\"stars\"></div></div>\n\n  <div class=\"head\">\n    <div class=\"brand\">\n      <div class=\"mk\">Polyphonic Voltage Synthesizer</div>\n      <h1>JOVE EIGHT</h1>\n      <div class=\"tag\">Eight Voice · Dual Osc · Sub</div>\n    </div>\n    <div class=\"voices\">\n      <div class=\"vlbl\">Voices</div>\n      <div class=\"bank\" id=\"bank\"></div>\n    </div>\n  </div>\n\n  <div class=\"body\" id=\"body\">\n    <div class=\"sect osc\">\n      <div class=\"shdr\">Oscillators</div>\n      <div class=\"row\" id=\"r-osc\"></div>\n    </div>\n    <div class=\"sect flt\">\n      <div class=\"shdr\">Filter</div>\n      <div class=\"row\" id=\"r-flt\"></div>\n    </div>\n    <div class=\"sect amp\">\n      <div class=\"shdr\">Envelope · Output</div>\n      <div class=\"row\" id=\"r-amp\"></div>\n    </div>\n  </div>\n\n  <div class=\"foot\"><span class=\"dot\"></span> Analog Poly Engine\n    <span class=\"sp\">Drag · Double-click resets</span></div>\n</div></div>\n\n<script>\n(function(){\n  // ---- param model (indices match assembly.ts / spec.json) ----\n  var PARAMS = [\n    {name:\"Cutoff\",    index:0, def:0.5,  grp:\"flt\"},\n    {name:\"Resonance\", index:1, def:0.3,  grp:\"flt\"},\n    {name:\"Env Amt\",   index:2, def:0.55, grp:\"flt\"},\n    {name:\"PW\",        index:3, def:0.35, grp:\"osc\"},\n    {name:\"Detune\",    index:4, def:0.32, grp:\"osc\"},\n    {name:\"Attack\",    index:5, def:0.08, grp:\"amp\"},\n    {name:\"Release\",   index:6, def:0.4,  grp:\"amp\"},\n    {name:\"Level\",     index:7, def:0.7,  grp:\"amp\"}\n  ];\n  var vals = {};\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmt(v){ return Math.round(v*100)+\"%\"; }\n\n  // ---- build starfield ----\n  var stars=document.getElementById(\"stars\");\n  for(var s=0;s<46;s++){\n    var st=document.createElement(\"i\");\n    st.style.left=(Math.random()*100)+\"%\";\n    st.style.top=(Math.random()*100)+\"%\";\n    st.style.animationDelay=(Math.random()*3.4)+\"s\";\n    stars.appendChild(st);\n  }\n\n  // ---- build 8 voice bars ----\n  var bank=document.getElementById(\"bank\"); var bars=[];\n  for(var b=0;b<8;b++){\n    var bb=document.createElement(\"div\"); bb.className=\"vbar\";\n    var fl=document.createElement(\"div\"); fl.className=\"fill\"; bb.appendChild(fl);\n    bank.appendChild(bb); bars.push({el:bb,fill:fl});\n  }\n\n  // ---- build a slider control ----\n  function makeCtl(p){\n    var wrap=document.createElement(\"div\"); wrap.className=\"ctl\";\n    var name=document.createElement(\"div\"); name.className=\"name\"; name.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    var sl=document.createElement(\"div\"); sl.className=\"slider\";\n    var tr=document.createElement(\"div\"); tr.className=\"track\";\n    var lit=document.createElement(\"div\"); lit.className=\"lit\"; tr.appendChild(lit);\n    var ticks=document.createElement(\"div\"); ticks.className=\"ticks\";\n    for(var t=0;t<7;t++) ticks.appendChild(document.createElement(\"i\"));\n    var cap=document.createElement(\"div\"); cap.className=\"cap\";\n    sl.appendChild(tr); sl.appendChild(ticks); sl.appendChild(cap);\n    wrap.appendChild(name); wrap.appendChild(sl); wrap.appendChild(val);\n\n    function render(v){\n      vals[p.index]=v;\n      var pct=Math.max(0,Math.min(1,v));\n      lit.style.height=(pct*100)+\"%\";\n      // cap travels along the rail (track inset 9px top/bottom -> usable ~106px)\n      var H=124, pad=9, usable=H-pad*2;\n      cap.style.bottom=(pad+pct*usable)+\"px\";\n      cap.style.top=\"auto\";\n      val.textContent=fmt(pct);\n    }\n    function set(v,doSend){ v=Math.max(0,Math.min(1,v)); render(v); if(doSend!==false) send(p.index,v); }\n\n    // drag interaction\n    var dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true; sl.classList.add(\"drag\");\n      startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startV=vals[p.index];\n      e.preventDefault();\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/130;            // upward = increase\n      set(startV+dv);\n      e.preventDefault();\n    }\n    function up(){ dragging=false; sl.classList.remove(\"drag\"); }\n    sl.addEventListener(\"mousedown\",down);\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"mouseup\",up);\n    sl.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"touchend\",up);\n    // double-click reset\n    sl.addEventListener(\"dblclick\",function(){ set(p.def); });\n\n    p._set=set;\n    document.getElementById(\"r-\"+p.grp).appendChild(wrap);\n    set(p.def,false); // init visual to default (send happens in ready())\n  }\n\n  PARAMS.forEach(makeCtl);\n\n  // ---- ready: push all defaults to host, start voice animation ----\n  function ready(){\n    PARAMS.forEach(function(p){ send(p.index, p.def); });\n    // ambient voice-bar shimmer driven by Detune + Cutoff for life\n    var t=0;\n    setInterval(function(){\n      t+=0.08;\n      var cut=vals[0]!=null?vals[0]:0.5;\n      var det=vals[4]!=null?vals[4]:0.3;\n      for(var i=0;i<8;i++){\n        var ph=t+i*0.7;\n        var amp=0.2+0.8*cut*(0.5+0.5*Math.sin(ph + det*6*Math.sin(ph*0.31)));\n        amp=Math.max(0.12,Math.min(1,amp));\n        bars[i].fill.style.height=(amp*100)+\"%\";\n        if(amp>0.55) bars[i].el.classList.add(\"lit\"); else bars[i].el.classList.remove(\"lit\");\n      }\n    },90);\n  }\n\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  JOVE EIGHT — a lush 8-voice analog poly synthesizer instrument in the\n//  flagship-poly lineage. Each of the eight voices runs TWO oscillators\n//  (a band-limited saw + a variable-width pulse with PWM) plus a sub-\n//  oscillator one octave down, all spread by a subtle unison/detune for\n//  the big stacked-string-pad character. The mixed oscillators feed a\n//  resonant 24 dB/oct (4-pole) low-pass driven by its OWN ADSR contour\n//  (Cutoff + Env Amount + Resonance), then an amplitude ADSR. Voices are\n//  allocated per noteId so chords ring with independent contours.\n//  Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:  i32 = 0;  // 0..1  -> base filter cutoff (exp)\nconst P_RESO:    i32 = 1;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 2;  // 0..1  -> filter envelope amount (octaves)\nconst P_PW:      i32 = 3;  // 0..1  -> pulse width + PWM depth\nconst P_DETUNE:  i32 = 4;  // 0..1  -> unison/osc detune spread\nconst P_ATTACK:  i32 = 5;  // 0..1  -> seconds (shared amp+filter atk)\nconst P_RELEASE: i32 = 6;  // 0..1  -> seconds (shared amp+filter rel)\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:     StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vDrift:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // per-voice unison offset (-1..1)\n\n// oscillator phases: saw, pulse, sub\nconst vPhSaw:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhPul:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhSub:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vLfo:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // PWM lfo phase\n\n// amplitude envelope\nconst vAEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 sus 4 rel\n// filter envelope\nconst vFEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// ladder filter state (4 one-pole stages per voice -> 24 dB/oct)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    // fixed per-voice unison spread, symmetric around zero\n    vDrift[v] = (f32(v) - 3.5) / 3.5;            // -1 .. +1\n    vPhSaw[v] = 0.0; vPhPul[v] = 0.0; vPhSub[v] = 0.0; vLfo[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_CUTOFF]  = 0.5;\n  params[P_RESO]    = 0.3;\n  params[P_ENVAMT]  = 0.55;\n  params[P_PW]      = 0.35;\n  params[P_DETUNE]  = 0.32;\n  params[P_ATTACK]  = 0.08;\n  params[P_RELEASE] = 0.4;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // prefer a free voice, else steal the oldest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  // offset start phases so the stacked oscillators don't phase-lock\n  vPhSaw[slot] = 0.0;\n  vPhPul[slot] = 0.25;\n  vPhSub[slot] = 0.5;\n  vLfo[slot]   = f32(slot) * 0.13;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const pwN: f32     = clampf(params[P_PW], 0.0, 1.0);\n  const detune: f32  = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 2.0;\n  const relS: f32 = 0.01  + clampf(params[P_RELEASE], 0.0, 1.0) * 3.0;\n  // fixed musical decay + sustain for the classic poly contour\n  const decS: f32 = 0.6;\n  const susL: f32 = 0.78;\n\n  // per-sample envelope rates (linear)\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // unison detune spread: up to ~ +/-0.22 semitone across voices\n  const detSemi: f32 = detune * 0.22;\n\n  // pulse width: 0.5 (square) down to ~0.08 (thin); PWM depth scales too\n  const basePW: f32 = 0.5 - pwN * 0.42;\n  const pwmDepth: f32 = 0.04 + pwN * 0.14;\n  const pwmRate: f32 = 0.6;                 // Hz, slow PWM shimmer\n  const lfoInc: f32 = pwmRate / sr;\n\n  // base cutoff in Hz, exponential 50 Hz .. ~16 kHz\n  const baseHz: f32 = 50.0 * f32(Mathf.pow(320.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6.5 octaves\n  const envOct: f32 = envAmt * 6.5;\n  // resonance feedback 0..~3.8\n  const reso: f32 = resoN * 3.8;\n\n  // headroom: 8 voices summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.42;\n  const outGain: f32 = level * 1.05;\n\n  for (let f = 0; f < n; f++) {\n    let mixL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude ADSR ---------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // decay\n        aenv -= decRate * (1.0 - susL);\n        if (aenv <= susL) { aenv = susL; astg = 3; }\n      } else if (astg == 3) {     // sustain\n        aenv = susL;\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      // voice finished?\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter ADSR ------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * (1.0 - susL);\n        if (fenv <= susL) { fenv = susL; fstg = 3; }\n      } else if (fstg == 3) {\n        fenv = susL;\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- per-voice unison detune ------------------------------\n      const semis: f32 = detSemi * vDrift[v];\n      const ratio: f32 = f32(Mathf.pow(2.0, semis / 12.0));\n      const baseInc: f32 = (vFreq[v] * ratio) / sr;\n\n      // ---- slow PWM lfo -----------------------------------------\n      let lfo: f32 = vLfo[v];\n      lfo += lfoInc; if (lfo >= 1.0) lfo -= 1.0;\n      vLfo[v] = lfo;\n      const pwm: f32 = f32(Mathf.sin(TWO_PI * lfo)) * pwmDepth;\n      let pw: f32 = basePW + pwm;\n      if (pw < 0.05) pw = 0.05;\n      if (pw > 0.95) pw = 0.95;\n\n      // ---- saw oscillator ---------------------------------------\n      let ps: f32 = vPhSaw[v];\n      ps += baseInc; if (ps >= 1.0) ps -= 1.0;\n      let saw: f32 = 2.0 * ps - 1.0;\n      saw -= polyBlep(ps, baseInc);\n      vPhSaw[v] = ps;\n\n      // ---- variable-width pulse oscillator ----------------------\n      let pp: f32 = vPhPul[v];\n      pp += baseInc; if (pp >= 1.0) pp -= 1.0;\n      let pul: f32 = pp < pw ? 1.0 : -1.0;\n      pul += polyBlep(pp, baseInc);\n      let ppb: f32 = pp + (1.0 - pw);\n      if (ppb >= 1.0) ppb -= 1.0;\n      pul -= polyBlep(ppb, baseInc);\n      vPhPul[v] = pp;\n\n      // ---- sub oscillator (one octave down, square) -------------\n      const subInc: f32 = baseInc * 0.5;\n      let pb: f32 = vPhSub[v];\n      pb += subInc; if (pb >= 1.0) pb -= 1.0;\n      let sub: f32 = pb < 0.5 ? 1.0 : -1.0;\n      sub += polyBlep(pb, subInc);\n      let pbb: f32 = pb + 0.5;\n      if (pbb >= 1.0) pbb -= 1.0;\n      sub -= polyBlep(pbb, subInc);\n      vPhSub[v] = pb;\n\n      // mix oscillators (saw body + pulse edge + sub weight)\n      let osc: f32 = saw * 0.55 + pul * 0.40 + sub * 0.30;\n\n      // ---- resonant 4-pole (24 dB/oct) low-pass -----------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      // resonance feedback from last stage; tanh keeps it stable\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      mixL += s3 * aenv * vVel[v];\n    }\n\n    // ---- sum + soft saturate for analog glue --------------------\n    let out: f32 = mixL * voiceScale * outGain;\n    out = f32(Mathf.tanh(out * 1.15));\n\n    outBuf[f] = out;\n    outBuf[MAX_FRAMES + f] = out;\n  }\n}\n",
  "publishedAt": 1751000089000
}