{
  "format": 1,
  "name": "Air Exciter",
  "isInstrument": false,
  "explanation": "A psychoacoustic harmonic exciter that adds air and presence. It splits off the upper band, runs it through an asymmetric soft-saturator to synthesise new high-frequency harmonics that were not in the dry signal, brightens that stream with an Air tilt, and blends a controlled amount back on top of the untouched dry path. Controls: Tune, Amount, Air and Mix.",
  "params": [
    {
      "name": "Tune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Amount",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Air",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Air Exciter</title>\n<style>\n  :root {\n    --accent: #bfe3ff;\n    --accent2: #e6f0ff;\n    --ink: #eaf4ff;\n    --dim: #7d93ad;\n    --panel: #0c1722;\n    --panel2: #122433;\n    --glow: rgba(191, 227, 255, 0.55);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    height: 100%;\n    background: #060d14;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n    overflow: auto;\n  }\n\n  /* ----- the panel ----- */\n  .shell {\n    position: relative;\n    width: min(560px, 96vw);\n    border-radius: 22px;\n    padding: 26px 28px 30px;\n    background:\n      radial-gradient(130% 90% at 50% -10%, rgba(191,227,255,0.16), transparent 55%),\n      linear-gradient(180deg, #14283a 0%, #0b1622 48%, #08111a 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.07) inset,\n      0 -30px 60px -40px rgba(191,227,255,0.25) inset,\n      0 30px 80px -30px rgba(0,0,0,0.85),\n      0 0 0 1px rgba(120,170,210,0.10);\n    overflow: hidden;\n  }\n\n  /* faint scanline / sheen texture */\n  .shell::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      repeating-linear-gradient(180deg, rgba(255,255,255,0.018) 0 1px, transparent 1px 3px);\n    pointer-events: none;\n    mix-blend-mode: screen;\n    opacity: 0.6;\n  }\n\n  /* ----- particle field rising behind the controls ----- */\n  .field {\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    overflow: hidden;\n    z-index: 0;\n  }\n  .spark {\n    position: absolute;\n    bottom: -8px;\n    width: 4px;\n    height: 4px;\n    border-radius: 50%;\n    background: radial-gradient(circle, var(--accent2), var(--accent) 40%, transparent 70%);\n    filter: drop-shadow(0 0 5px var(--glow));\n    opacity: 0;\n    animation: rise linear infinite;\n  }\n  @keyframes rise {\n    0%   { transform: translateY(0) scale(0.5); opacity: 0; }\n    12%  { opacity: 0.9; }\n    70%  { opacity: 0.7; }\n    100% { transform: translateY(-340px) scale(1.1); opacity: 0; }\n  }\n\n  .content { position: relative; z-index: 2; }\n\n  /* ----- header ----- */\n  header {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    margin-bottom: 22px;\n  }\n  .mark {\n    width: 46px; height: 46px;\n    flex: 0 0 auto;\n    filter: drop-shadow(0 0 8px var(--glow));\n  }\n  .titles h1 {\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles p {\n    margin-top: 3px;\n    font-size: 10px;\n    letter-spacing: 3.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  /* live shimmer meter strip */\n  .shimmer {\n    margin: 0 0 22px;\n    height: 30px;\n    border-radius: 9px;\n    background: linear-gradient(180deg, #081420, #0a1a28);\n    box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 6px 14px -8px #000 inset;\n    overflow: hidden;\n    position: relative;\n  }\n  .shimmer canvas { display: block; width: 100%; height: 100%; }\n\n  /* ----- knob grid ----- */\n  .knobs {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n  }\n  @media (max-width: 440px) {\n    .knobs { grid-template-columns: repeat(2, 1fr); gap: 18px; }\n  }\n\n  .cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 14px 6px 12px;\n    border-radius: 16px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.035), rgba(255,255,255,0.01));\n    box-shadow: 0 1px 0 rgba(255,255,255,0.05) inset, 0 10px 24px -18px #000;\n    transition: box-shadow 0.25s, transform 0.15s;\n  }\n  .cell:hover { transform: translateY(-2px); }\n  .cell.live {\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.07) inset,\n      0 0 0 1px rgba(191,227,255,0.35),\n      0 0 26px -4px var(--glow);\n  }\n\n  .knob {\n    position: relative;\n    width: 92px; height: 92px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; overflow: visible; }\n\n  .label {\n    margin-top: 12px;\n    font-size: 10.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n  .val {\n    margin-top: 4px;\n    font-size: 14px;\n    font-weight: 600;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent2);\n    text-shadow: 0 0 10px rgba(191,227,255,0.25);\n  }\n\n  .foot {\n    margin-top: 20px;\n    text-align: center;\n    font-size: 9.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: #43586d;\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"field\" id=\"field\"></div>\n    <div class=\"content\">\n      <header>\n        <svg class=\"mark\" viewBox=\"0 0 48 48\" fill=\"none\">\n          <defs>\n            <radialGradient id=\"g\" cx=\"50%\" cy=\"35%\" r=\"70%\">\n              <stop offset=\"0%\" stop-color=\"#e6f0ff\"/>\n              <stop offset=\"100%\" stop-color=\"#5fa8d8\"/>\n            </radialGradient>\n          </defs>\n          <path d=\"M24 3 L28 20 L45 24 L28 28 L24 45 L20 28 L3 24 L20 20 Z\"\n                fill=\"url(#g)\" opacity=\"0.95\"/>\n          <circle cx=\"38\" cy=\"11\" r=\"2.2\" fill=\"#e6f0ff\"/>\n          <circle cx=\"10\" cy=\"36\" r=\"1.6\" fill=\"#bfe3ff\" opacity=\"0.8\"/>\n        </svg>\n        <div class=\"titles\">\n          <h1>Air Exciter</h1>\n          <p>Harmonic Presence Generator</p>\n        </div>\n      </header>\n\n      <div class=\"shimmer\"><canvas id=\"viz\"></canvas></div>\n\n      <div class=\"knobs\" id=\"knobs\"></div>\n\n      <div class=\"foot\">Drag vertically · double-click to reset</div>\n    </div>\n  </div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  const PARAMS = [\n    { index: 0, name: \"Tune\",   min: 0, max: 1, def: 0.45, fmt: tuneFmt },\n    { index: 1, name: \"Amount\", min: 0, max: 1, def: 0.5,  fmt: pctFmt },\n    { index: 2, name: \"Air\",    min: 0, max: 1, def: 0.5,  fmt: pctFmt },\n    { index: 3, name: \"Mix\",    min: 0, max: 1, def: 1.0,  fmt: pctFmt }\n  ];\n\n  function pctFmt(v) { return Math.round(v * 100) + \"%\"; }\n  function tuneFmt(v) {\n    // mirror the DSP mapping: 1200 + v^2 * 7800 Hz\n    const hz = 1200 + v * v * 7800;\n    return hz >= 1000 ? (hz / 1000).toFixed(2) + \" kHz\" : Math.round(hz) + \" Hz\";\n  }\n\n  const norm = (p, v) => (v - p.min) / (p.max - p.min);\n  const denorm = (p, t) => p.min + t * (p.max - p.min);\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- build a knob ----\n  const ARC0 = -135, ARC1 = 135; // degrees\n  const R = 34, CX = 46, CY = 46;\n\n  function polar(cx, cy, r, deg) {\n    const a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(r, a0, a1) {\n    const [x0, y0] = polar(CX, CY, r, a0);\n    const [x1, y1] = polar(CX, CY, r, a1);\n    const large = (a1 - a0) > 180 ? 1 : 0;\n    return `M ${x0.toFixed(2)} ${y0.toFixed(2)} A ${r} ${r} 0 ${large} 1 ${x1.toFixed(2)} ${y1.toFixed(2)}`;\n  }\n\n  const controls = [];\n  const knobsEl = document.getElementById(\"knobs\");\n\n  PARAMS.forEach((p) => {\n    const cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    const knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.innerHTML = `\n      <svg viewBox=\"0 0 92 92\">\n        <defs>\n          <radialGradient id=\"body${p.index}\" cx=\"50%\" cy=\"38%\" r=\"65%\">\n            <stop offset=\"0%\" stop-color=\"#1d3346\"/>\n            <stop offset=\"60%\" stop-color=\"#0e1f2d\"/>\n            <stop offset=\"100%\" stop-color=\"#081119\"/>\n          </radialGradient>\n          <linearGradient id=\"rim${p.index}\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"rgba(191,227,255,0.55)\"/>\n            <stop offset=\"100%\" stop-color=\"rgba(0,0,0,0.4)\"/>\n          </linearGradient>\n        </defs>\n        <path d=\"${arcPath(R + 6, ARC0, ARC1)}\" stroke=\"#0a151f\" stroke-width=\"5\"\n              fill=\"none\" stroke-linecap=\"round\"/>\n        <path class=\"track\" d=\"${arcPath(R + 6, ARC0, ARC1)}\" stroke=\"#16293a\"\n              stroke-width=\"3\" fill=\"none\" stroke-linecap=\"round\"/>\n        <path class=\"fill\" d=\"\" stroke=\"var(--accent)\" stroke-width=\"3.4\"\n              fill=\"none\" stroke-linecap=\"round\"\n              style=\"filter: drop-shadow(0 0 5px var(--glow));\"/>\n        <circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R}\" fill=\"url(#body${p.index})\"\n                stroke=\"url(#rim${p.index})\" stroke-width=\"1.4\"/>\n        <circle cx=\"${CX}\" cy=\"${CY}\" r=\"${R - 3}\" fill=\"none\"\n                stroke=\"rgba(255,255,255,0.04)\" stroke-width=\"1\"/>\n        <line class=\"pointer\" x1=\"${CX}\" y1=\"${CY}\" x2=\"${CX}\" y2=\"${CY - R + 7}\"\n              stroke=\"var(--accent2)\" stroke-width=\"2.6\" stroke-linecap=\"round\"\n              style=\"filter: drop-shadow(0 0 4px var(--glow));\"/>\n        <circle cx=\"${CX}\" cy=\"${CY}\" r=\"2.6\" fill=\"#bfe3ff\"/>\n      </svg>`;\n\n    const label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    const val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(knob);\n    cell.appendChild(label);\n    cell.appendChild(val);\n    knobsEl.appendChild(cell);\n\n    const ctrl = {\n      p, cell, knob, val,\n      fill: knob.querySelector(\".fill\"),\n      pointer: knob.querySelector(\".pointer\"),\n      t: norm(p, p.def)\n    };\n    controls.push(ctrl);\n\n    function render() {\n      const t = ctrl.t;\n      const ang = ARC0 + t * (ARC1 - ARC0);\n      ctrl.fill.setAttribute(\"d\", t > 0.001 ? arcPath(R + 6, ARC0, ang) : \"\");\n      ctrl.pointer.setAttribute(\"transform\", `rotate(${ang} ${CX} ${CY})`);\n      const real = denorm(p, t);\n      ctrl.val.textContent = p.fmt(real);\n    }\n    function commit() { render(); pushParam(p.index, denorm(p, ctrl.t)); }\n    ctrl.render = render;\n    ctrl.commit = commit;\n\n    // ---- drag interaction (vertical) ----\n    let dragging = false, lastY = 0;\n\n    function onDown(e) {\n      dragging = true;\n      cell.classList.add(\"live\");\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      const y = (e.touches ? e.touches[0].clientY : e.clientY);\n      const dy = lastY - y;\n      lastY = y;\n      const fine = e.shiftKey ? 0.25 : 1;\n      ctrl.t = Math.min(1, Math.max(0, ctrl.t + (dy / 200) * fine));\n      commit();\n      e.preventDefault();\n    }\n    function onUp() {\n      if (!dragging) return;\n      dragging = false;\n      cell.classList.remove(\"live\");\n    }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    knob.addEventListener(\"wheel\", (e) => {\n      const fine = e.shiftKey ? 0.25 : 1;\n      ctrl.t = Math.min(1, Math.max(0, ctrl.t - Math.sign(e.deltaY) * 0.03 * fine));\n      commit();\n      e.preventDefault();\n    }, { passive: false });\n\n    knob.addEventListener(\"dblclick\", () => {\n      ctrl.t = norm(p, p.def);\n      cell.classList.add(\"live\");\n      commit();\n      setTimeout(() => cell.classList.remove(\"live\"), 220);\n    });\n\n    render();\n  });\n\n  // ---- initialise all params to defaults on the engine ----\n  function init() {\n    controls.forEach((c) => pushParam(c.p.index, denorm(c.p, c.t)));\n  }\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(init);\n  } else {\n    init();\n  }\n\n  // ---- rising-sparkle particle field ----\n  const field = document.getElementById(\"field\");\n  for (let i = 0; i < 26; i++) {\n    const s = document.createElement(\"div\");\n    s.className = \"spark\";\n    s.style.left = Math.random() * 100 + \"%\";\n    const dur = 4 + Math.random() * 6;\n    s.style.animationDuration = dur + \"s\";\n    s.style.animationDelay = (-Math.random() * dur) + \"s\";\n    const sz = 2 + Math.random() * 4;\n    s.style.width = sz + \"px\";\n    s.style.height = sz + \"px\";\n    field.appendChild(s);\n  }\n\n  // ---- live shimmer visualiser (driven by Amount + Air) ----\n  const viz = document.getElementById(\"viz\");\n  const vctx = viz.getContext(\"2d\");\n  let phase = 0;\n\n  function amountVal() {\n    const a = controls.find((c) => c.p.name === \"Amount\");\n    return a ? a.t : 0.5;\n  }\n  function airVal() {\n    const a = controls.find((c) => c.p.name === \"Air\");\n    return a ? a.t : 0.5;\n  }\n\n  function resizeViz() {\n    const r = viz.getBoundingClientRect();\n    const dpr = window.devicePixelRatio || 1;\n    viz.width = Math.max(1, r.width * dpr);\n    viz.height = Math.max(1, r.height * dpr);\n    vctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n\n  function drawViz() {\n    if (document.hidden) { requestAnimationFrame(drawViz); return; }\n    const r = viz.getBoundingClientRect();\n    const w = r.width, h = r.height;\n    vctx.clearRect(0, 0, w, h);\n\n    const amt = amountVal();\n    const air = airVal();\n    phase += 0.04 + air * 0.05;\n\n    // layered shimmer: higher Air = more high-frequency ripples; Amount = height\n    vctx.lineWidth = 1.6;\n    for (let layer = 0; layer < 3; layer++) {\n      const alpha = 0.25 + layer * 0.22;\n      vctx.strokeStyle = `rgba(191, 227, 255, ${alpha * (0.4 + amt * 0.6)})`;\n      vctx.beginPath();\n      const freq = 6 + layer * 6 + air * 22;\n      const amp = (h * 0.32) * (0.3 + amt * 0.7) * (1 - layer * 0.22);\n      for (let x = 0; x <= w; x += 3) {\n        const t = x / w;\n        const y = h / 2\n          + Math.sin(t * freq + phase + layer) * amp\n          * Math.sin(t * Math.PI); // taper at the edges\n        if (x === 0) vctx.moveTo(x, y); else vctx.lineTo(x, y);\n      }\n      vctx.stroke();\n    }\n    requestAnimationFrame(drawViz);\n  }\n\n  window.addEventListener(\"resize\", resizeViz);\n  resizeViz();\n  requestAnimationFrame(drawViz);\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  AIR EXCITER — psychoacoustic high-frequency harmonic exciter\n//\n//  An \"aural exciter\": it isolates the upper band of the signal with a\n//  high-pass, runs it through an asymmetric soft-saturator to synthesise\n//  NEW high-order harmonics that were not present in the dry signal, then\n//  brightens that harmonic stream (\"Air\") and blends a controlled amount\n//  back on top of the untouched dry path. The result adds sparkle, sheen\n//  and presence without simply boosting existing treble.\n//\n//  Signal flow per channel:\n//    dry ──────────────────────────────────────────┐\n//    in ─► [HP @ Tune] ─► [drive + soft-clip] ─► [HP again] ─► [Air shelf]\n//                                                       └─► * Amount ─► (+) ─► Mix ─► out\n//\n//  Params:  Tune (HF corner)  Amount (harmonic level)  Air (top-end tilt)  Mix\n//  Pure algorithm, allocation-free, f32 throughout, output bounded < 1.0.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// one-pole low-pass states used to derive the high-pass bands (x - lp)\nconst hpA: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-saturation band split\nconst hpB: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post-saturation harmonic split\nconst airS: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // air high-shelf state\nconst dcS:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker on harmonics\n\nconst P_TUNE:   i32 = 0; // 0..1 -> HF corner 1.2k..9k Hz\nconst P_AMOUNT: i32 = 1; // 0..1 -> harmonic blend level\nconst P_AIR:    i32 = 2; // 0..1 -> extra top-end tilt on the harmonics\nconst P_MIX:    i32 = 3; // 0..1 -> dry/wet of the whole effect\n\nconst PI: f32 = 3.14159265358979;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    hpA[c] = 0.0; hpB[c] = 0.0; airS[c] = 0.0; dcS[c] = 0.0;\n  }\n  params[P_TUNE] = 0.45;\n  params[P_AMOUNT] = 0.5;\n  params[P_AIR] = 0.5;\n  params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// one-pole low-pass coefficient for a given corner frequency\n@inline function lpCoeff(hz: f32): f32 {\n  let c: f32 = f32(1.0 - Mathf.exp(-2.0 * PI * hz / sampleRate));\n  return clampf(c, 0.0001, 0.999);\n}\n\n// asymmetric soft saturator — the asymmetry generates BOTH even and odd\n// harmonics (purely odd shaping would only thicken, not \"excite\"); tanh-like\n// curve keeps it smooth and bounded.\n@inline function exciteShape(x: f32): f32 {\n  // bias adds 2nd-order content; tanh approximation via rational function\n  const b: f32 = x + 0.18;\n  const t: f32 = b / f32(1.0 + Mathf.abs(b) * 0.85);\n  // remove the DC the bias introduced (steady-state of the shaper at x=0)\n  const t0: f32 = 0.18 / f32(1.0 + 0.18 * 0.85);\n  return t - t0;\n}\n\nexport function process(n: i32): void {\n  const tune: f32 = clampf(params[P_TUNE], 0.0, 1.0);\n  const amount: f32 = clampf(params[P_AMOUNT], 0.0, 1.0);\n  const air: f32 = clampf(params[P_AIR], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // HF corner: 1.2 kHz .. 9 kHz (clamped under Nyquist for low sample rates)\n  let corner: f32 = 1200.0 + tune * tune * 7800.0;\n  const nyq: f32 = sampleRate * 0.45;\n  if (corner > nyq) corner = nyq;\n  const cA: f32 = lpCoeff(corner);\n  // second split a little higher so we keep the freshly-made harmonics, not the fundamental band\n  const cB: f32 = lpCoeff(clampf(corner * 1.4, 0.0, nyq));\n\n  // Air = a bright high-shelf tilt on the harmonic stream. Higher air -> let\n  // more of the very top through (smaller LP -> more high content retained).\n  const airHz: f32 = clampf(corner * (1.5 + air * 4.0), 0.0, nyq);\n  const cAir: f32 = lpCoeff(airHz);\n  const airMix: f32 = 0.35 + air * 0.65; // how much high-passed sparkle vs body\n\n  // drive into the shaper scales with Amount so the knob also changes timbre,\n  // not just level — more amount = richer/denser harmonics.\n  const drive: f32 = 2.0 + amount * 10.0;\n  // harmonic make-up level, gain-compensated so it stays subtle and bounded\n  const hLevel: f32 = amount * 0.9;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let lpa: f32 = hpA[c];\n    let lpb: f32 = hpB[c];\n    let lpAir: f32 = airS[c];\n    let dcZ: f32 = dcS[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // 1) isolate the upper band\n      lpa = lpa + cA * (x - lpa);\n      const high: f32 = x - lpa;\n\n      // 2) generate harmonics by saturating the driven upper band\n      let harm: f32 = exciteShape(high * drive);\n\n      // 3) keep only the high-frequency harmonic content (drop low-order fundamentals)\n      lpb = lpb + cB * (harm - lpb);\n      harm = harm - lpb;\n\n      // 4) DC blocker: track the slow-moving mean and subtract it so the\n      //    asymmetric shaper can't drift the harmonic stream off-centre.\n      dcZ = dcZ + 0.0006 * (harm - dcZ);\n      const h2: f32 = harm - dcZ;\n\n      // 5) Air tilt — emphasise the very top of the harmonic stream\n      lpAir = lpAir + cAir * (h2 - lpAir);\n      const sparkle: f32 = h2 - lpAir;          // the brightest layer\n      const excited: f32 = (1.0 - airMix) * h2 + airMix * sparkle;\n\n      // 6) blend the synthesised air on top of the untouched dry signal\n      const wet: f32 = x + excited * hLevel;\n      let y: f32 = x * (1.0 - mix) + wet * mix;\n\n      // safety clamp — keep peaks bounded well under full-scale\n      y = clampf(y, -0.999, 0.999);\n      outBuf[base + f] = y;\n    }\n\n    hpA[c] = lpa;\n    hpB[c] = lpb;\n    airS[c] = lpAir;\n    dcS[c] = dcZ;\n  }\n}\n",
  "publishedAt": 1751000054000
}