{
  "format": 1,
  "name": "West Cell",
  "isInstrument": true,
  "explanation": "A west-coast complex-oscillator voice. A modulator sine cross-modulates (through-zero FM) a primary sine, then the result is driven into a series wavefolder that creases the wave and multiplies its harmonics, and finally a low-pass gate (a combined filter+amp) plucks the tone with a single fast control envelope for bongo/marimba/clang transients. Pitch tracks, plays chords, and stays bounded. Controls: Timbre, Fold, Gate Decay, Tone and Level.",
  "params": [
    {
      "name": "Timbre",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Fold",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Gate Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Level",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>West Cell</title>\n<style>\n  :root{\n    --accent:#ffd24a;\n    --accent2:#ff5fa2;\n    --cream:#f4ecd8;\n    --cream2:#e9dcc0;\n    --panel:#1c1712;\n    --ink:#2a221a;\n    --jack:#2b2620;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:\"Avenir Next\",\"Segoe UI\",system-ui,sans-serif;\n    color:var(--ink);\n    background:\n      radial-gradient(120% 90% at 18% 8%, #fff6e0 0%, var(--cream) 38%, var(--cream2) 100%);\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n  }\n  /* sunburst behind the panel */\n  body::before{\n    content:\"\";position:fixed;inset:-30%;z-index:0;\n    background:\n      conic-gradient(from 0deg at 50% 42%,\n        rgba(255,210,74,.16) 0deg, rgba(255,95,162,.05) 18deg,\n        rgba(255,210,74,.16) 36deg, rgba(255,95,162,.05) 54deg,\n        rgba(255,210,74,.16) 72deg, rgba(255,95,162,.05) 90deg,\n        rgba(255,210,74,.16) 108deg, rgba(255,95,162,.05) 126deg,\n        rgba(255,210,74,.16) 144deg, rgba(255,95,162,.05) 162deg,\n        rgba(255,210,74,.16) 180deg, rgba(255,95,162,.05) 198deg,\n        rgba(255,210,74,.16) 216deg, rgba(255,95,162,.05) 234deg,\n        rgba(255,210,74,.16) 252deg, rgba(255,95,162,.05) 270deg,\n        rgba(255,210,74,.16) 288deg, rgba(255,95,162,.05) 306deg,\n        rgba(255,210,74,.16) 324deg, rgba(255,95,162,.05) 342deg,\n        rgba(255,210,74,.16) 360deg);\n    animation:spin 60s linear infinite;\n    pointer-events:none;\n  }\n  @keyframes spin{to{transform:rotate(360deg);}}\n\n  .module{\n    position:relative;z-index:1;\n    width:760px;max-width:96vw;\n    background:linear-gradient(180deg,#fbf3df,#ece0c4);\n    border-radius:14px;\n    padding:22px 26px 26px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.8) inset,\n      0 -3px 10px rgba(120,90,40,.18) inset,\n      0 26px 60px rgba(60,40,10,.42),\n      0 4px 0 #b89a62;\n    border:1px solid #d9c79a;\n  }\n  /* mounting screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff,#b59c6a 70%,#7d6840);\n    box-shadow:0 1px 2px rgba(0,0,0,.4);}\n  .screw::after{content:\"\";position:absolute;inset:4px;border-top:1.5px solid rgba(60,40,10,.5);transform:rotate(40deg);}\n  .screw.tl{top:9px;left:9px}.screw.tr{top:9px;right:9px}\n  .screw.bl{bottom:9px;left:9px}.screw.br{bottom:9px;right:9px}\n\n  header{display:flex;align-items:baseline;gap:14px;margin:2px 6px 16px;}\n  .brand{font-weight:800;font-size:26px;letter-spacing:1.5px;\n    background:linear-gradient(90deg,var(--accent2),var(--accent));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n    text-shadow:0 1px 0 rgba(255,255,255,.4);}\n  .sub{font-size:11px;letter-spacing:3px;text-transform:uppercase;color:#9c8456;font-weight:600;}\n  .lamp{margin-left:auto;width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff7cc,var(--accent) 60%,#c79a18);\n    box-shadow:0 0 10px var(--accent),0 0 22px rgba(255,210,74,.5);\n    animation:pulse 1.6s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{opacity:.55;box-shadow:0 0 6px var(--accent);}50%{opacity:1;box-shadow:0 0 16px var(--accent),0 0 30px rgba(255,210,74,.6);}}\n\n  .stage{\n    display:grid;grid-template-columns:1.15fr 1fr;gap:18px;margin-bottom:18px;\n  }\n  .scope{\n    background:radial-gradient(120% 120% at 40% 20%,#241d15,#0e0b07);\n    border-radius:10px;padding:10px;border:1px solid #3a2f20;\n    box-shadow:0 2px 8px rgba(0,0,0,.45) inset;position:relative;overflow:hidden;\n  }\n  .scope-label{position:absolute;top:8px;left:12px;font-size:9px;letter-spacing:2px;\n    color:#7c6a44;text-transform:uppercase;z-index:2;}\n  svg{display:block;width:100%;height:100%;}\n\n  /* patch panel with banana jacks */\n  .patch{\n    background:linear-gradient(180deg,#efe3c6,#ddccA0);\n    border-radius:10px;border:1px solid #cdb887;\n    padding:12px 14px;display:flex;flex-direction:column;gap:9px;\n    box-shadow:0 1px 0 rgba(255,255,255,.6) inset;\n  }\n  .patch-title{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:#9c8456;font-weight:700;margin-bottom:1px;}\n  .jrow{display:flex;align-items:center;gap:10px;}\n  .jack{width:22px;height:22px;border-radius:50%;flex:0 0 auto;position:relative;\n    background:radial-gradient(circle at 38% 32%,#5a5044,#211d16 72%);\n    box-shadow:0 1px 2px rgba(0,0,0,.5),0 0 0 3px #c9b685,0 0 0 4px #a8915f;}\n  .jack i{position:absolute;inset:7px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#fff5cc,var(--jc,#ffd24a) 70%,#000 130%);}\n  .jrow span{font-size:11px;color:#5a4a30;font-weight:600;}\n  /* animated patch cables drawn as SVG overlay */\n  .cables{position:absolute;inset:0;pointer-events:none;z-index:3;}\n\n  .controls{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;}\n  .knobwrap{display:flex;flex-direction:column;align-items:center;gap:7px;}\n  .knob{\n    --val:0;\n    width:84px;height:84px;border-radius:50%;position:relative;cursor:grab;\n    background:\n      radial-gradient(circle at 38% 30%,#fff6e2,#e7d6ad 55%,#c8b078 100%);\n    box-shadow:\n      0 2px 4px rgba(0,0,0,.35),\n      0 6px 14px rgba(70,45,10,.3),\n      0 0 0 5px #d8c594,\n      0 0 0 6px #b89a62;\n    transition:box-shadow .2s;\n  }\n  .knob:active{cursor:grabbing;}\n  .knob:hover{box-shadow:0 2px 4px rgba(0,0,0,.35),0 8px 18px rgba(70,45,10,.35),0 0 0 5px var(--accent),0 0 0 6px #b89a62,0 0 18px rgba(255,210,74,.45);}\n  /* the rotating indicator group */\n  .dial{position:absolute;inset:0;border-radius:50%;\n    transform:rotate(calc(-135deg + var(--val) * 270deg));\n    transition:transform .05s linear;}\n  .dial .ptr{position:absolute;left:50%;top:7px;width:4px;height:30px;margin-left:-2px;border-radius:3px;\n    background:linear-gradient(180deg,var(--accent2),#7a2a4a);box-shadow:0 0 6px rgba(255,95,162,.6);}\n  .dial .cap{position:absolute;left:50%;top:50%;width:30px;height:30px;margin:-15px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#fff,#d8c08a);box-shadow:0 1px 2px rgba(0,0,0,.3) inset;}\n  /* arc track */\n  .arc{position:absolute;inset:-12px;}\n  .knob-name{font-size:11px;font-weight:700;letter-spacing:.5px;color:#5a4a30;text-transform:uppercase;}\n  .knob-val{font-size:11px;font-weight:600;color:var(--accent2);font-variant-numeric:tabular-nums;}\n\n  .foot{margin-top:16px;display:flex;align-items:center;gap:10px;font-size:10px;color:#9c8456;letter-spacing:1px;}\n  .foot .dot{width:7px;height:7px;border-radius:50%;background:var(--accent2);box-shadow:0 0 8px var(--accent2);}\n  .hint{margin-left:auto;font-size:9px;color:#b09c6e;letter-spacing:.5px;}\n</style>\n</head>\n<body>\n  <div class=\"module\">\n    <div class=\"screw tl\"></div><div class=\"screw tr\"></div>\n    <div class=\"screw bl\"></div><div class=\"screw br\"></div>\n\n    <header>\n      <div class=\"brand\">WEST CELL</div>\n      <div class=\"sub\">Complex&nbsp;Osc · Folder · Low-Pass&nbsp;Gate</div>\n      <div class=\"lamp\"></div>\n    </header>\n\n    <div class=\"stage\">\n      <div class=\"scope\">\n        <div class=\"scope-label\">Wavefolder</div>\n        <svg viewBox=\"0 0 360 170\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"fg\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#ff5fa2\"/>\n              <stop offset=\"1\" stop-color=\"#ffd24a\"/>\n            </linearGradient>\n            <filter id=\"glow\"><feGaussianBlur stdDeviation=\"2.2\" result=\"b\"/>\n              <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>\n          </defs>\n          <line x1=\"0\" y1=\"85\" x2=\"360\" y2=\"85\" stroke=\"#3a2f20\" stroke-width=\"1\"/>\n          <path id=\"foldPath\" fill=\"none\" stroke=\"url(#fg)\" stroke-width=\"2.4\" filter=\"url(#glow)\"/>\n          <!-- LPG pluck ripple -->\n          <circle id=\"ripple\" cx=\"40\" cy=\"85\" r=\"4\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"2\" opacity=\"0\"/>\n        </svg>\n      </div>\n\n      <div class=\"patch\" style=\"position:relative\">\n        <div class=\"patch-title\">Patch&nbsp;Bay</div>\n        <div class=\"jrow\"><span class=\"jack\" style=\"--jc:#ff5fa2\"><i></i></span><span>Primary&nbsp;Osc</span></div>\n        <div class=\"jrow\"><span class=\"jack\" style=\"--jc:#ffd24a\"><i></i></span><span>Modulator</span></div>\n        <div class=\"jrow\"><span class=\"jack\" style=\"--jc:#ff5fa2\"><i></i></span><span>Folder&nbsp;In</span></div>\n        <div class=\"jrow\"><span class=\"jack\" style=\"--jc:#ffd24a\"><i></i></span><span>LPG&nbsp;Control</span></div>\n        <div class=\"jrow\"><span class=\"jack\" style=\"--jc:#ff5fa2\"><i></i></span><span>Voice&nbsp;Out</span></div>\n        <svg class=\"cables\" viewBox=\"0 0 320 230\" preserveAspectRatio=\"none\">\n          <path id=\"cable1\" fill=\"none\" stroke=\"#ff5fa2\" stroke-width=\"3.5\" stroke-linecap=\"round\" opacity=\".85\"/>\n          <path id=\"cable2\" fill=\"none\" stroke=\"#ffd24a\" stroke-width=\"3.5\" stroke-linecap=\"round\" opacity=\".85\"/>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n\n    <div class=\"foot\">\n      <span class=\"dot\"></span><span>WEST&nbsp;COAST&nbsp;VOICE — pluck the gate, fold the wave</span>\n      <span class=\"hint\">drag knobs · double-click to reset</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  // ---- param model (indices MUST match assembly.ts / spec.json) ----\n  var PARAMS = [\n    { name:\"Timbre\",     index:0, min:0, max:1, def:0.4  },\n    { name:\"Fold\",       index:1, min:0, max:1, def:0.45 },\n    { name:\"Gate Decay\", index:2, min:0, max:1, def:0.5  },\n    { name:\"Tone\",       index:3, min:0, max:1, def:0.55 },\n    { name:\"Level\",      index:4, min:0, max:1, def:0.7  }\n  ];\n  var values = PARAMS.map(function(p){ return p.def; });\n\n  function send(i, v){\n    try{\n      if (window.vstai && typeof window.vstai.setParam === \"function\")\n        window.vstai.setParam(i, v);\n    }catch(e){}\n  }\n\n  // ---- build knobs ----\n  var root = document.getElementById(\"controls\");\n  function fmt(v){ return Math.round(v*100); }\n\n  PARAMS.forEach(function(p, idx){\n    var wrap = document.createElement(\"div\"); wrap.className=\"knobwrap\";\n    var knob = document.createElement(\"div\"); knob.className=\"knob\";\n    knob.innerHTML =\n      '<svg class=\"arc\" viewBox=\"0 0 108 108\">'+\n        '<path d=\"M16 92 A 46 46 0 1 1 92 92\" fill=\"none\" stroke=\"#cdb887\" stroke-width=\"5\" stroke-linecap=\"round\"/>'+\n        '<path class=\"arcfill\" d=\"M16 92 A 46 46 0 1 1 92 92\" fill=\"none\" stroke=\"url(#fg2_'+idx+')\" stroke-width=\"5\" stroke-linecap=\"round\" pathLength=\"100\" stroke-dasharray=\"100\" stroke-dashoffset=\"100\"/>'+\n        '<defs><linearGradient id=\"fg2_'+idx+'\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n        '<stop offset=\"0\" stop-color=\"#ff5fa2\"/><stop offset=\"1\" stop-color=\"#ffd24a\"/></linearGradient></defs>'+\n      '</svg>'+\n      '<div class=\"dial\"><div class=\"ptr\"></div><div class=\"cap\"></div></div>';\n    var name = document.createElement(\"div\"); name.className=\"knob-name\"; name.textContent=p.name;\n    var val  = document.createElement(\"div\"); val.className=\"knob-val\";\n\n    wrap.appendChild(knob); wrap.appendChild(name); wrap.appendChild(val);\n    root.appendChild(wrap);\n\n    var arcfill = knob.querySelector(\".arcfill\");\n\n    function norm(v){ return (v - p.min) / (p.max - p.min); }\n    function render(){\n      var nv = norm(values[idx]);\n      knob.style.setProperty(\"--val\", nv);\n      arcfill.style.strokeDashoffset = (100 - nv*100).toFixed(2);\n      val.textContent = fmt(nv);\n    }\n    function set(v, push){\n      v = Math.max(p.min, Math.min(p.max, v));\n      values[idx] = v;\n      render();\n      if (push !== false) send(p.index, v);\n      updateVis();\n    }\n\n    // ---- drag interaction (vertical) ----\n    var dragging=false, startY=0, startV=0;\n    knob.addEventListener(\"mousedown\", function(e){\n      dragging=true; startY=e.clientY; startV=values[idx];\n      document.body.style.cursor=\"grabbing\"; e.preventDefault();\n    });\n    window.addEventListener(\"mousemove\", function(e){\n      if(!dragging) return;\n      var dy = startY - e.clientY;\n      var range = p.max - p.min;\n      set(startV + (dy/180)*range);\n    });\n    window.addEventListener(\"mouseup\", function(){\n      if(dragging){ dragging=false; document.body.style.cursor=\"\"; }\n    });\n    knob.addEventListener(\"dblclick\", function(){ set(p.def); });\n    // wheel fine-tune\n    knob.addEventListener(\"wheel\", function(e){\n      e.preventDefault();\n      set(values[idx] - Math.sign(e.deltaY)*0.02*(p.max-p.min));\n    }, {passive:false});\n\n    p._render = render;\n    render();\n  });\n\n  // ---- PATCH BAY: make the banana jacks real vertical-drag controls ----\n  // Each jack patches a stage and IS a control: drag = set its parameter,\n  // dbl-click = default, wheel = fine. Mirrors the knobs so the patch bay\n  // actually does something.\n  (function(){\n    var jackEls = Array.prototype.slice.call(document.querySelectorAll(\".jack\"));\n    var JMAP = [3, 0, 1, 2, 4]; // Primary Osc->Tone, Modulator->Timbre, Folder In->Fold, LPG->Gate Decay, Voice Out->Level\n    function applyParam(idx, v){\n      var p = PARAMS[idx]; v = Math.max(p.min, Math.min(p.max, v));\n      values[idx] = v; if (p._render) p._render(); send(p.index, v);\n      if (typeof updateVis === \"function\") updateVis(); renderJacks();\n    }\n    function renderJacks(){\n      jackEls.forEach(function(j, k){ var pi = JMAP[k]; if (pi == null) return; var nv = values[pi];\n        var inner = j.querySelector(\"i\"); if (inner) inner.style.opacity = (0.25 + 0.75*nv).toFixed(2);\n        j.style.boxShadow = \"0 0 \" + (2 + nv*11).toFixed(1) + \"px var(--jc)\";\n      });\n    }\n    jackEls.forEach(function(j, k){\n      var pi = JMAP[k]; if (pi == null) return;\n      j.style.cursor = \"ns-resize\"; j.title = \"drag: \" + PARAMS[pi].name;\n      var dragging=false, startY=0, startV=0;\n      j.addEventListener(\"mousedown\", function(e){ dragging=true; startY=e.clientY; startV=values[pi]; document.body.style.cursor=\"grabbing\"; e.preventDefault(); });\n      window.addEventListener(\"mousemove\", function(e){ if(!dragging)return; applyParam(pi, startV + (startY-e.clientY)/180); });\n      window.addEventListener(\"mouseup\", function(){ if(dragging){ dragging=false; document.body.style.cursor=\"\"; } });\n      j.addEventListener(\"click\", function(){ /* click nudges up a touch for discoverability */ applyParam(pi, values[pi] + 0.08 > 1 ? PARAMS[pi].def : values[pi] + 0.08); });\n      j.addEventListener(\"dblclick\", function(){ applyParam(pi, PARAMS[pi].def); });\n      j.addEventListener(\"wheel\", function(e){ e.preventDefault(); applyParam(pi, values[pi] - Math.sign(e.deltaY)*0.02); }, {passive:false});\n    });\n    renderJacks();\n  })();\n\n  // ---- live visualisation: wavefolder curve + patch cables + ripple ----\n  var foldPath = document.getElementById(\"foldPath\");\n  var ripple   = document.getElementById(\"ripple\");\n  var cable1   = document.getElementById(\"cable1\");\n  var cable2   = document.getElementById(\"cable2\");\n  var t = 0;\n\n  function buildFoldPath(){\n    var timbre = values[0], fold = values[1], tone = values[3];\n    var drive = 1 + fold*fold*6;\n    var depth = timbre*5;\n    var N = 180, W=360, H=170, mid=85, amp=58*(0.5+tone*0.5);\n    var d = \"\";\n    for (var i=0;i<=N;i++){\n      var x = i/N;\n      var phase = x*Math.PI*2;\n      // complex osc: modulator FM the primary\n      var s = Math.sin(phase + Math.sin(phase*1.41 + t*0.6)*depth);\n      // wavefolder (matches the DSP shape)\n      var dr = s*drive;\n      var fo = Math.sin(dr) + 0.5*Math.sin(dr*2);\n      fo *= 0.7/(0.6+fold*0.9);\n      var px = x*W;\n      var py = mid - fo*amp;\n      d += (i===0?\"M\":\"L\") + px.toFixed(1) + \" \" + py.toFixed(1) + \" \";\n    }\n    foldPath.setAttribute(\"d\", d);\n  }\n\n  function buildCables(){\n    // gentle drooping patch cables that sway with Timbre / Fold\n    var sag1 = 30 + values[0]*40;\n    var sag2 = 30 + values[1]*40;\n    var sway = Math.sin(t*0.8)*6;\n    cable1.setAttribute(\"d\",\"M14 24 C \"+(90+sway)+\" \"+(24+sag1)+\", 230 \"+(110-sag1*0.3)+\", 306 196\");\n    cable2.setAttribute(\"d\",\"M14 70 C \"+(110-sway)+\" \"+(70+sag2)+\", 210 \"+(150-sag2*0.3)+\", 306 24\");\n  }\n\n  function updateVis(){ buildFoldPath(); buildCables(); }\n\n  // LPG pluck ripple keyed to Gate Decay — periodic \"ping\"\n  var lastPing=0;\n  function loop(ts){\n    t += 0.016;\n    buildFoldPath();\n    buildCables();\n\n    var decay = values[2];\n    var period = 600 + decay*1600; // ms between pings, longer decay = slower\n    if (ts - lastPing > period){\n      lastPing = ts;\n      ripple.setAttribute(\"opacity\",\"0.9\");\n      ripple.setAttribute(\"r\",\"4\");\n      ripple._start = ts;\n    }\n    if (ripple._start){\n      var age = (ts - ripple._start)/1000;\n      var life = 0.25 + decay*1.6;\n      var k = age/life;\n      if (k >= 1){ ripple.setAttribute(\"opacity\",\"0\"); ripple._start=0; }\n      else {\n        ripple.setAttribute(\"r\", (4 + k*180).toFixed(1));\n        ripple.setAttribute(\"opacity\", (0.9*(1-k)).toFixed(3));\n      }\n    }\n    requestAnimationFrame(loop);\n  }\n\n  function start(){\n    // push every default to the host so DSP matches the displayed state\n    PARAMS.forEach(function(p,i){ send(p.index, values[i]); });\n    updateVis();\n    requestAnimationFrame(loop);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  WEST CELL — a west-coast (Buchla-lineage) complex-oscillator voice\n//\n//  A totally different synthesis path from subtractive: instead of a\n//  harmonic-rich oscillator carved by a filter, harmonics are GENERATED\n//  on the way up.\n//\n//    1) COMPLEX OSCILLATOR: a modulator sine cross-modulates (through-zero\n//       FM / timbre modulation) a primary sine. Timbre sets the modulation\n//       depth, sweeping the primary from a pure tone into a clangorous,\n//       inharmonic-leaning spectrum.\n//    2) WAVEFOLDER: the complex-osc output is driven into a series of\n//       sine-folding stages. As Fold rises the wave creases back on itself,\n//       multiplying the harmonic content (the classic \"more is more\" west\n//       coast timbre).\n//    3) LOW-PASS GATE (LPG): a combined VCF + VCA that \"plucks\". A single\n//       fast-decaying control envelope simultaneously closes a one-pole\n//       low-pass (darkening as it falls) and ducks the amplitude, giving\n//       the bongo / marimba / clang transient that defines the lineage.\n//\n//  Polyphonic (16 voices). Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_VOICES: i32 = 16;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831853071795864769;\nconst PI: f32 = 3.14159265358979323846;\n\n// ---- per-voice state (parallel StaticArrays, no allocation in process) ----\nconst vActive:  StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = slot in use (still ringing)\nconst vNote:    StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // note id\nconst vCarPh:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // primary phase (radians)\nconst vModPh:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // modulator phase (radians)\nconst vFreq:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // primary Hz\nconst vVel:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // 0..1\nconst vEnv:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // LPG control envelope (0..1)\nconst vLpg:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // LPG low-pass one-pole state\nconst vAge:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // for voice-steal LRU\n\nlet ageCounter: f32 = 0.0;\n\n// ---- parameter indices (MUST match spec.json) ----\nconst P_TIMBRE:    i32 = 0; // cross-mod (FM/timbre) amount     (0 .. 1)\nconst P_FOLD:      i32 = 1; // wavefolding drive                (0 .. 1)\nconst P_GATEDECAY: i32 = 2; // LPG pluck length                 (0 .. 1)\nconst P_TONE:      i32 = 3; // LPG brightness (open-ness)       (0 .. 1)\nconst P_LEVEL:     i32 = 4; // output level                     (0 .. 1)\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    vActive[v] = 0; vNote[v] = -1;\n    vCarPh[v] = 0.0; vModPh[v] = 0.0; vFreq[v] = 0.0;\n    vVel[v] = 0.0; vEnv[v] = 0.0; vLpg[v] = 0.0; vAge[v] = 0.0;\n  }\n  ageCounter = 0.0;\n  params[P_TIMBRE]    = 0.4;\n  params[P_FOLD]      = 0.45;\n  params[P_GATEDECAY] = 0.5;\n  params[P_TONE]      = 0.55;\n  params[P_LEVEL]     = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- note handling: each note retriggers the LPG pluck ----\nexport function noteOn(id: i32, freq: f32, velocity: f32): void {\n  if (freq <= 0.0) freq = 1.0;\n  // reuse a voice already playing this id, else a free slot, else steal oldest\n  let slot: i32 = -1;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) { slot = v; break; }\n  }\n  if (slot < 0) {\n    for (let v = 0; v < MAX_VOICES; v++) {\n      if (vActive[v] == 0) { slot = v; break; }\n    }\n  }\n  if (slot < 0) {\n    let oldest: f32 = vAge[0]; slot = 0;\n    for (let v = 1; v < MAX_VOICES; v++) {\n      if (vAge[v] < oldest) { oldest = vAge[v]; slot = v; }\n    }\n  }\n  ageCounter += 1.0;\n  vActive[slot] = 1;\n  vNote[slot]   = id;\n  vFreq[slot]   = freq;\n  vVel[slot]    = clampf(velocity, 0.0, 1.0);\n  vCarPh[slot]  = 0.0;\n  vModPh[slot]  = 0.0;\n  vEnv[slot]    = 1.0;   // strike: control envelope jumps to full, then decays\n  vLpg[slot]    = 0.0;\n  vAge[slot]    = ageCounter;\n}\n\n// West-coast LPGs ring out — note-off doesn't hard-stop; the pluck envelope\n// is one-shot. We keep the slot alive until the envelope has decayed, so a\n// release simply lets the natural decay finish. (gate is implicit.)\nexport function noteOff(id: i32): void {\n  // no-op: the percussive LPG envelope governs the tail\n}\n\nexport function process(n: i32): void {\n  // ---- resolve params once per block ----\n  const timbreN: f32 = clampf(params[P_TIMBRE], 0.0, 1.0);\n  const foldN: f32   = clampf(params[P_FOLD], 0.0, 1.0);\n  const decayN: f32  = clampf(params[P_GATEDECAY], 0.0, 1.0);\n  const toneN: f32   = clampf(params[P_TONE], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0) * 0.8;\n\n  // cross-mod (timbre) depth: how far the modulator pushes the primary phase.\n  // 0 = pure sine; up to ~5 radians = dense clangorous spectrum.\n  const timbreDepth: f32 = timbreN * 5.0;\n  // modulator runs at a fixed slightly-inharmonic ratio for the metallic\n  // west-coast character (not a clean integer).\n  const modRatio: f32 = 1.41;\n\n  // wavefolder drive: 1 (no fold) .. ~7 (heavily creased, many harmonics)\n  const foldDrive: f32 = 1.0 + foldN * foldN * 6.0;\n  // makeup so loud folding doesn't simply get louder\n  const foldComp: f32 = 1.0 / (0.6 + foldN * 0.9);\n\n  // LPG control envelope decay: 40 ms (snappy bongo) .. 2.2 s (long marimba/chime)\n  const decaySec: f32 = 0.04 + decayN * decayN * 2.16;\n  const envCoef: f32 = f32(Mathf.exp(-1.0 / (decaySec * sampleRate)));\n\n  // LPG low-pass: Tone sets how bright it can open; the per-sample cutoff is\n  // additionally pulled DOWN as the control envelope falls (vactrol behaviour).\n  const maxCutHz: f32 = 400.0 + toneN * toneN * 11000.0;\n  const minCutHz: f32 = 120.0;\n  const invSr: f32 = 1.0 / sampleRate;\n\n  // ---- clear output block ----\n  for (let f = 0; f < n; f++) {\n    outBuf[f] = 0.0;\n    outBuf[MAX_FRAMES + f] = 0.0;\n  }\n\n  // ---- render each active voice (mono sum, copied to both channels) ----\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] == 0) continue;\n\n    const f0: f32 = vFreq[v];\n    const carInc: f32 = TWO_PI * f0 * invSr;\n    const modInc: f32 = TWO_PI * f0 * modRatio * invSr;\n    const vel: f32 = vVel[v];\n    // harder hits open the LPG brighter and fold a touch harder (dynamic timbre)\n    const velCut: f32 = 0.55 + vel * 0.45;\n    const velFold: f32 = 0.8 + vel * 0.3;\n\n    let carPh: f32 = vCarPh[v];\n    let modPh: f32 = vModPh[v];\n    let envL:  f32 = vEnv[v];\n    let lpg:   f32 = vLpg[v];\n\n    for (let f = 0; f < n; f++) {\n      // control envelope (one-shot exponential decay = the \"pluck\")\n      envL *= envCoef;\n\n      // --- complex oscillator: modulator phase-modulates the primary ---\n      const modOut: f32 = Mathf.sin(modPh) * timbreDepth;\n      let s: f32 = Mathf.sin(carPh + modOut);\n\n      // --- wavefolder: drive then fold via sine (each crease adds harmonics) ---\n      // velocity nudges fold so dynamics change the spectrum, not just volume.\n      const driven: f32 = s * foldDrive * velFold;\n      // two-stage sine fold: sin(x) folds, the second stage sharpens the creases\n      let folded: f32 = Mathf.sin(driven);\n      folded = folded + 0.5 * Mathf.sin(driven * 2.0 + folded);\n      folded *= foldComp * 0.7;\n\n      // --- low-pass gate: cutoff tracks the control envelope (vactrol) ---\n      let cut: f32 = minCutHz + (maxCutHz - minCutHz) * envL * velCut;\n      if (cut > sampleRate * 0.45) cut = sampleRate * 0.45;\n      const g: f32 = f32(1.0 - Mathf.exp(-TWO_PI * cut * invSr));\n      lpg += g * (folded - lpg);\n\n      // VCA part of the LPG: the same envelope ducks the amplitude\n      const out: f32 = lpg * envL * vel;\n\n      outBuf[f] += out;\n\n      carPh += carInc; if (carPh >= TWO_PI) carPh -= TWO_PI;\n      modPh += modInc; if (modPh >= TWO_PI) modPh -= TWO_PI;\n    }\n\n    vCarPh[v] = carPh;\n    vModPh[v] = modPh;\n    vEnv[v]   = envL;\n    vLpg[v]   = lpg;\n\n    // retire the voice once the pluck has fully decayed\n    if (envL < 0.00008) {\n      vActive[v] = 0; vNote[v] = -1;\n    }\n  }\n\n  // ---- output level + gentle soft safety limit, copy mono to stereo ----\n  for (let f = 0; f < n; f++) {\n    let s: f32 = outBuf[f] * level;\n    if (s > 1.2) s = 1.2; else if (s < -1.2) s = -1.2;\n    s = f32(s - 0.16666667 * s * s * s); // soft knee, peak < 1.0\n    outBuf[f] = s;\n    outBuf[MAX_FRAMES + f] = s;\n  }\n}\n",
  "publishedAt": 1751000096000
}