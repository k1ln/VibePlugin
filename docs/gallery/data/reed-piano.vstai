{
  "format": 1,
  "name": "Reed Piano",
  "isInstrument": true,
  "explanation": "A polyphonic electric reed-piano instrument modelled on the warm 60s struck-steel-reed school pianos. Each voice is a hollow reed-tone oscillator run through an asymmetric soft clipper whose drive tracks velocity and a fast 'bark' envelope, so hard hits growl and bark on the attack then mellow into a hollow sustain — distinct from a tine Rhodes. A snappy amp envelope with adjustable body decay, a one-pole tone tilt and a built-in sine tremolo finish the voice. Up to 12 voices, so chords ring out. Controls: Bark, Decay, Tone, Tremolo Depth, Tremolo Rate and Level.",
  "params": [
    {
      "name": "Bark",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Decay",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tremolo Depth",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Tremolo Rate",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Reed Piano</title>\n<style>\n  :root{\n    --ac:#8ad0a0; --ac2:#d0e8b0;\n    --face1:#7fae84; --face2:#5e8d68; --face3:#456b50;\n    --wood1:#7a4a2c; --wood2:#5a3318; --wood3:#3c2110;\n    --cream:#efe8cf; --ink:#243027;\n    --reed:#cfd6c4; --reed-hi:#f3f6e6;\n  }\n  *{box-sizing:border-box}\n  html,body{height:100%}\n  body{\n    margin:0; padding:18px;\n    font:13px ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,sans-serif;\n    color:var(--ink);\n    background:radial-gradient(130% 100% at 50% -15%,#2c3a30,#141d18 60%,#0a0f0c 100%);\n    display:flex; align-items:center; justify-content:center;\n    -webkit-font-smoothing:antialiased;\n  }\n\n  /* ============ the cabinet ============ */\n  .cab{\n    position:relative; width:100%; max-width:660px;\n    border-radius:16px;\n    background:\n      linear-gradient(180deg,var(--wood1),var(--wood2) 55%,var(--wood3));\n    padding:14px;\n    box-shadow:\n      0 40px 90px rgba(0,0,0,.6),\n      0 2px 0 rgba(255,255,255,.08) inset,\n      0 -20px 50px rgba(0,0,0,.45) inset;\n    border:1px solid #1c0f06;\n  }\n  /* wood grain on the cabinet edge */\n  .cab::before{\n    content:\"\"; position:absolute; inset:0; border-radius:16px; pointer-events:none; opacity:.4;\n    background:\n      repeating-linear-gradient(92deg,rgba(0,0,0,.16) 0 2px,transparent 2px 9px),\n      repeating-linear-gradient(88deg,rgba(255,255,255,.04) 0 1px,transparent 1px 14px);\n    mix-blend-mode:overlay;\n  }\n  .screw{position:absolute;width:12px;height:12px;border-radius:50%;z-index:8;\n    background:radial-gradient(circle at 38% 32%,#d8c79a,#7a5a30 70%);\n    box-shadow:0 1px 2px rgba(0,0,0,.7),0 0 0 1px #2a1a0c inset}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(120deg,transparent 44%,#3c2812 44% 56%,transparent 56%)}\n  .screw.tl{top:7px;left:7px} .screw.tr{top:7px;right:7px}\n  .screw.bl{bottom:7px;left:7px} .screw.br{bottom:7px;right:7px}\n\n  /* ============ the green faceplate ============ */\n  .face{\n    position:relative; z-index:2; border-radius:10px; overflow:hidden;\n    background:\n      radial-gradient(120% 80% at 30% 0%,#86b88c,transparent 60%),\n      linear-gradient(180deg,var(--face1),var(--face2) 60%,var(--face3));\n    border:1px solid #2c4634;\n    box-shadow:0 2px 0 rgba(255,255,255,.12) inset,0 -10px 30px rgba(0,0,0,.3) inset;\n  }\n  /* crackle / hammertone speckle on the faceplate */\n  .face::before{\n    content:\"\"; position:absolute; inset:0; pointer-events:none; opacity:.18;\n    background:\n      radial-gradient(rgba(255,255,255,.5) .6px,transparent .8px) 0 0/7px 7px,\n      radial-gradient(rgba(0,0,0,.35) .6px,transparent .8px) 3px 4px/9px 9px;\n  }\n\n  /* ---- header / brand ---- */\n  .head{position:relative;z-index:3;display:flex;align-items:center;gap:14px;\n    padding:14px 20px 10px}\n  .badge{flex:none;width:46px;height:46px;border-radius:8px;\n    background:linear-gradient(180deg,#f4eed6,#cdbf94);\n    border:1px solid #8a7a4c;\n    box-shadow:0 2px 5px rgba(0,0,0,.35),0 1px 0 rgba(255,255,255,.6) inset;\n    display:flex;align-items:center;justify-content:center}\n  .badge svg{width:30px;height:30px}\n  .brand{flex:1;line-height:1.05}\n  .brand .mk{font-size:8.5px;letter-spacing:.4em;color:#284332;text-transform:uppercase;opacity:.85}\n  .brand h1{margin:2px 0 0;font-size:25px;font-weight:800;letter-spacing:.12em;\n    color:var(--cream);\n    text-shadow:0 1px 0 rgba(0,0,0,.35),0 0 16px rgba(208,232,176,.25)}\n  .model{font-size:8px;letter-spacing:.3em;color:var(--cream);text-transform:uppercase;\n    border:1px solid #2c4634;border-radius:5px;padding:5px 9px;\n    background:linear-gradient(180deg,rgba(0,0,0,.18),rgba(0,0,0,.32));\n    box-shadow:0 1px 0 rgba(255,255,255,.12) inset}\n\n  /* ---- the swaying tremolo lamp ---- */\n  .lamp{position:relative;flex:none;width:30px;height:46px}\n  .lamp .glow{position:absolute;left:50%;top:6px;width:18px;height:18px;margin-left:-9px;border-radius:50%;\n    background:radial-gradient(circle at 45% 40%,#fff3c0,var(--ac2) 45%,#7fae84 80%);\n    box-shadow:0 0 14px var(--ac2),0 0 28px rgba(208,232,176,.5);\n    transform-origin:50% 160%;\n    animation:sway 1.6s ease-in-out infinite}\n  .lamp .glow.fast{animation-duration:.7s}\n  @keyframes sway{0%,100%{transform:rotate(-13deg);filter:brightness(.8)}\n    50%{transform:rotate(13deg);filter:brightness(1.35)}}\n  .lamp .stem{position:absolute;left:50%;top:22px;width:2px;height:18px;margin-left:-1px;\n    background:linear-gradient(#caa,#864);border-radius:1px}\n\n  /* ============ the reed bank (animated SVG) ============ */\n  .reeds{position:relative;z-index:3;margin:4px 20px 6px;padding:12px 14px 10px;\n    border-radius:8px;\n    background:linear-gradient(180deg,#2a3a2e,#1b271f);\n    border:1px solid #14201a;\n    box-shadow:0 3px 12px rgba(0,0,0,.5) inset,0 1px 0 rgba(255,255,255,.06)}\n  .reeds .cap{font-size:8px;letter-spacing:.34em;color:#9bbf9f;text-transform:uppercase;margin-bottom:4px}\n  .reeds svg{display:block;width:100%;height:86px}\n  .barbox{fill:url(#barg)}\n  .reedwire{stroke:var(--reed);stroke-width:2.2;stroke-linecap:round;fill:none;\n    filter:drop-shadow(0 0 2px rgba(243,246,230,.35))}\n  .reedtip{fill:var(--reed-hi)}\n  .hammer{fill:#caa37a;stroke:#6a4a28;stroke-width:1}\n\n  /* ============ control deck ============ */\n  .deck{position:relative;z-index:3;display:grid;\n    grid-template-columns:repeat(6,1fr);gap:10px 8px;\n    padding:10px 18px 6px}\n  .ctl{position:relative;display:flex;flex-direction:column;align-items:center;gap:7px;\n    padding:11px 4px 11px;border-radius:10px;\n    background:linear-gradient(180deg,rgba(255,255,255,.07),rgba(0,0,0,.14));\n    border:1px solid #2c4634;\n    box-shadow:0 1px 0 rgba(255,255,255,.14) inset,0 5px 12px rgba(0,0,0,.28);\n    animation:rise .5s both;animation-delay:var(--d)}\n  @keyframes rise{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:none}}\n  .ctl:hover{background:linear-gradient(180deg,rgba(255,255,255,.12),rgba(0,0,0,.12))}\n\n  /* knob — bakelite cap with a value arc */\n  .knob{position:relative;width:54px;height:54px;cursor:ns-resize;touch-action:none;user-select:none}\n  .knob .ring{position:absolute;inset:0;border-radius:50%;\n    background:conic-gradient(from 220deg,\n      var(--ac) calc(var(--n,0)*280deg),\n      rgba(20,32,24,.65) calc(var(--n,0)*280deg) 280deg,\n      transparent 280deg);\n    filter:drop-shadow(0 0 calc(2px + var(--n,0)*7px) color-mix(in srgb,var(--ac) 70%,transparent));\n    transition:filter .15s ease}\n  .knob .cap{position:absolute;inset:6px;border-radius:50%;\n    background:\n      radial-gradient(circle at 50% 26%,#3a4d40,#16221b 74%);\n    box-shadow:0 3px 8px rgba(0,0,0,.55) inset,0 -1px 0 rgba(255,255,255,.08) inset,0 1px 2px rgba(0,0,0,.6)}\n  .knob .pip{position:absolute;left:50%;top:5px;width:3px;height:15px;margin-left:-1.5px;border-radius:2px;\n    background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 7px var(--ac);\n    transform-origin:50% 22px;\n    transform:rotate(calc((var(--n,0) - 0.5) * 280deg));\n    transition:transform .14s cubic-bezier(.2,.8,.25,1)}\n  .knob.live .ring,.knob.live .pip{transition:none}\n  .knob.act .cap{box-shadow:0 4px 12px rgba(0,0,0,.7) inset,0 0 0 1px var(--ac) inset}\n\n  .ctl .nm{font-size:8.5px;letter-spacing:.12em;color:var(--cream);text-transform:uppercase;text-align:center;\n    text-shadow:0 1px 0 rgba(0,0,0,.3)}\n  .ctl .vv{font-size:11px;font-weight:700;color:var(--ac2);font-variant-numeric:tabular-nums;\n    text-shadow:0 0 7px rgba(208,232,176,.4)}\n\n  /* ============ keyboard ============ */\n  .kbwrap{position:relative;z-index:3;margin:6px 14px 4px;padding:10px;\n    border-radius:8px;background:linear-gradient(180deg,#1b120a,#0e0905);\n    box-shadow:0 4px 12px rgba(0,0,0,.5) inset}\n  .keys{position:relative;display:flex;height:104px;border-radius:5px;overflow:hidden;\n    box-shadow:0 2px 6px rgba(0,0,0,.5)}\n  .key{position:relative;flex:1;cursor:pointer;touch-action:none}\n  .key.w{background:linear-gradient(180deg,#fdfbf2,#ddd7c4);\n    border-right:1px solid #b8b2a0;border-radius:0 0 4px 4px}\n  .key.w:last-child{border-right:none}\n  .key.w.dn{background:linear-gradient(180deg,#cfe6cf,#a9d0a9);\n    box-shadow:0 -2px 6px rgba(138,208,160,.5) inset}\n  .key.b{position:absolute;top:0;width:6.2%;height:62%;z-index:4;\n    background:linear-gradient(180deg,#2a322c,#0d130f);border-radius:0 0 3px 3px;\n    box-shadow:0 3px 5px rgba(0,0,0,.6),0 -1px 0 rgba(255,255,255,.06) inset}\n  .key.b.dn{background:linear-gradient(180deg,#4a7a55,#274d31);\n    box-shadow:0 0 10px rgba(138,208,160,.6)}\n  .hint{margin-top:7px;font-size:8.5px;letter-spacing:.16em;color:#9bbf9f;text-transform:uppercase;text-align:center;opacity:.8}\n\n  .foot{position:relative;z-index:3;margin:6px 20px 2px;padding-top:8px;\n    display:flex;justify-content:space-between;align-items:center;\n    font-size:8px;letter-spacing:.22em;color:#274332;text-transform:uppercase}\n\n  @media(max-width:540px){.deck{grid-template-columns:repeat(3,1fr)}}\n</style>\n</head>\n<body>\n  <div class=\"cab\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"face\">\n      <div class=\"head\">\n        <div class=\"badge\">\n          <svg viewBox=\"0 0 30 30\">\n            <rect x=\"4\" y=\"6\" width=\"22\" height=\"3\" rx=\"1.5\" fill=\"#5a3318\"/>\n            <rect x=\"6\" y=\"9\" width=\"2\" height=\"14\" rx=\"1\" fill=\"#7a4a2c\"/>\n            <rect x=\"11\" y=\"9\" width=\"2\" height=\"17\" rx=\"1\" fill=\"#7a4a2c\"/>\n            <rect x=\"16\" y=\"9\" width=\"2\" height=\"13\" rx=\"1\" fill=\"#7a4a2c\"/>\n            <rect x=\"21\" y=\"9\" width=\"2\" height=\"16\" rx=\"1\" fill=\"#7a4a2c\"/>\n          </svg>\n        </div>\n        <div class=\"brand\">\n          <div class=\"mk\">Electric Reed Piano</div>\n          <h1>REED&nbsp;PIANO</h1>\n        </div>\n        <div class=\"lamp\"><span class=\"glow\" id=\"lampGlow\"></span><span class=\"stem\"></span></div>\n        <span class=\"model\">200&middot;A</span>\n      </div>\n\n      <!-- ANIMATED REED BANK -->\n      <div class=\"reeds\">\n        <div class=\"cap\">Reed Bank &mdash; struck steel</div>\n        <svg id=\"reedSvg\" viewBox=\"0 0 620 86\" preserveAspectRatio=\"none\">\n          <defs>\n            <linearGradient id=\"barg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#3a4d40\"/><stop offset=\"1\" stop-color=\"#1b271f\"/>\n            </linearGradient>\n          </defs>\n          <!-- mounting bar the reeds clamp to -->\n          <rect class=\"barbox\" x=\"0\" y=\"68\" width=\"620\" height=\"14\" rx=\"3\"/>\n          <g id=\"reedGroup\"></g>\n        </svg>\n      </div>\n\n      <!-- CONTROL DECK -->\n      <div class=\"deck\" id=\"deck\"></div>\n\n      <!-- KEYBOARD -->\n      <div class=\"kbwrap\">\n        <div class=\"keys\" id=\"keys\"></div>\n        <div class=\"hint\">Click keys or play A&ndash;K &middot; drag knobs &middot; double-click to reset</div>\n      </div>\n\n      <div class=\"foot\">\n        <span>12&nbsp;Voice&nbsp;Poly</span>\n        <span>Vibrato &middot; Reed &middot; Tone</span>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- param map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name:\"Bark\",      index:0, min:0, max:1, def:0.55, fmt:pct },\n    { name:\"Decay\",     index:1, min:0, max:1, def:0.55, fmt:secFmt },\n    { name:\"Tone\",      index:2, min:0, max:1, def:0.5,  fmt:hzFmt },\n    { name:\"Trem Dpt\",  index:3, min:0, max:1, def:0.35, fmt:pct },\n    { name:\"Trem Rate\", index:4, min:0, max:1, def:0.4,  fmt:rateFmt },\n    { name:\"Level\",     index:5, min:0, max:1, def:0.7,  fmt:dbFmt }\n  ];\n\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n  function secFmt(v){ var s=0.6+v*v*5.4; return s.toFixed(2)+\"s\"; }\n  function hzFmt(v){ var f=700+v*v*6300; return f>=1000?(f/1000).toFixed(1)+\"k\":Math.round(f)+\"Hz\"; }\n  function rateFmt(v){ return (3+v*6).toFixed(1)+\"Hz\"; }\n  function dbFmt(v){ if(v<=0.0001) return \"-INF\"; var db=20*Math.log10(v); return (db>=0?\"+\":\"\")+db.toFixed(1)+\"dB\"; }\n\n  // ---- host bridge (guard undefined) ----\n  function setParam(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function noteOnH(n,vel){ if(window.vstai&&window.vstai.noteOn) window.vstai.noteOn(n,vel); }\n  function noteOffH(n){ if(window.vstai&&window.vstai.noteOff) window.vstai.noteOff(n); }\n\n  var state = PARAMS.map(function(p){ return p.def; });\n  function nz(p,v){ return (v-p.min)/((p.max-p.min)||1); }\n\n  // ===================================================================\n  //  REED BANK — build N reeds; animate the struck ones vibrating\n  // ===================================================================\n  var REEDN = 22;\n  var reedGroup = document.getElementById(\"reedGroup\");\n  var reeds = [];\n  for(var r=0;r<REEDN;r++){\n    var x = 18 + r*(584/(REEDN-1));\n    var len = 56 - (r/REEDN)*34;            // higher reeds are shorter\n    var path = document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n    path.setAttribute(\"class\",\"reedwire\");\n    var tip = document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n    tip.setAttribute(\"class\",\"reedtip\"); tip.setAttribute(\"r\",\"2.6\");\n    reedGroup.appendChild(path); reedGroup.appendChild(tip);\n    reeds.push({ x:x, len:len, base:68, amp:0, phase:Math.random()*6.28, path:path, tip:tip });\n  }\n\n  // active note -> reed mapping so played notes excite specific reeds\n  var noteReed = {};\n  function exciteReed(note,vel){\n    var idx = ((note % REEDN) + REEDN) % REEDN;\n    reeds[idx].amp = Math.min(1, 0.55 + vel*0.6);\n    noteReed[note] = idx;\n  }\n  function relaxReed(note){ delete noteReed[note]; }\n\n  // ===================================================================\n  //  KNOBS / control deck\n  // ===================================================================\n  var deck = document.getElementById(\"deck\");\n  PARAMS.forEach(function(p,i){\n    var ctl = document.createElement(\"div\");\n    ctl.className = \"ctl\";\n    ctl.style.setProperty(\"--d\",(i*55)+\"ms\");\n    ctl.innerHTML =\n      '<div class=\"knob\"><div class=\"ring\"></div><div class=\"cap\"></div><div class=\"pip\"></div></div>'+\n      '<div class=\"nm\">'+p.name+'</div><div class=\"vv\"></div>';\n    deck.appendChild(ctl);\n\n    var knob = ctl.querySelector(\".knob\");\n    var vv = ctl.querySelector(\".vv\");\n\n    function paint(){\n      var n = nz(p,state[i]);\n      knob.style.setProperty(\"--n\", n);\n      vv.textContent = p.fmt(n);\n    }\n    function set(n){\n      n = n<0?0:(n>1?1:n);\n      state[i] = p.min+(p.max-p.min)*n;\n      paint(); setParam(p.index,state[i]);\n      reactGlobals();\n    }\n    function reset(){ state[i]=p.def; paint(); setParam(p.index,state[i]); reactGlobals(); }\n\n    var dragY=0, dragN=0, dragging=false;\n    knob.addEventListener(\"pointerdown\",function(e){\n      dragging=true; dragY=e.clientY; dragN=nz(p,state[i]);\n      knob.classList.add(\"act\",\"live\"); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener(\"pointermove\",function(e){\n      if(!dragging) return;\n      set(dragN + (dragY-e.clientY)/180);\n    });\n    function end(){ dragging=false; knob.classList.remove(\"act\",\"live\"); }\n    knob.addEventListener(\"pointerup\",end);\n    knob.addEventListener(\"pointercancel\",end);\n    knob.addEventListener(\"dblclick\",reset);\n    knob.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      set(nz(p,state[i]) + (e.deltaY<0?0.03:-0.03));\n    },{passive:false});\n\n    p._paint = paint;\n  });\n\n  // ---- globals that the reed bank + lamp react to ----\n  var lampGlow = document.getElementById(\"lampGlow\");\n  function reactGlobals(){\n    var rate = nz(PARAMS[4],state[4]);   // tremolo rate\n    var depth = nz(PARAMS[3],state[3]);  // tremolo depth\n    // lamp sways faster with rate, brighter with depth\n    var dur = (1.9 - rate*1.3).toFixed(2);\n    lampGlow.style.animationDuration = dur+\"s\";\n    lampGlow.style.opacity = (0.45 + depth*0.55).toFixed(2);\n  }\n\n  // ===================================================================\n  //  KEYBOARD — two octaves, click + computer keys\n  // ===================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var START = 48;        // C3\n  var OCT = 2;\n  var WHITE = [0,2,4,5,7,9,11];\n  var isBlack = {1:1,3:1,6:1,8:1,10:1};\n  var keyEls = {};       // midi -> element\n  var whiteCount = OCT*7 + 1;\n\n  // build white keys first\n  var whiteNotes = [];\n  for(var o=0;o<=OCT;o++){\n    for(var wi=0; wi<WHITE.length; wi++){\n      var nn = START + o*12 + WHITE[wi];\n      if(whiteNotes.length>=whiteCount) break;\n      whiteNotes.push(nn);\n    }\n  }\n  whiteNotes.forEach(function(nn){\n    var k = document.createElement(\"div\");\n    k.className = \"key w\"; k.dataset.note = nn;\n    keysEl.appendChild(k); keyEls[nn]=k;\n  });\n  // black keys positioned over the gaps\n  var wWidth = 100/whiteNotes.length;\n  whiteNotes.forEach(function(nn,wIdx){\n    var rel = nn % 12;\n    // a black key sits to the right of white notes with a sharp above\n    if(rel===0||rel===2||rel===5||rel===7||rel===9){\n      var bn = nn+1;\n      if(isBlack[bn%12]){\n        var b = document.createElement(\"div\");\n        b.className=\"key b\"; b.dataset.note=bn;\n        b.style.left = ((wIdx+1)*wWidth - 3.1)+\"%\";\n        keysEl.appendChild(b); keyEls[bn]=b;\n      }\n    }\n  });\n\n  var down = {};\n  function press(note,vel){\n    if(down[note]) return;\n    down[note]=true;\n    var el=keyEls[note]; if(el) el.classList.add(\"dn\");\n    noteOnH(note, vel||0.85);\n    exciteReed(note, vel||0.85);\n  }\n  function release(note){\n    if(!down[note]) return;\n    delete down[note];\n    var el=keyEls[note]; if(el) el.classList.remove(\"dn\");\n    noteOffH(note);\n    relaxReed(note);\n  }\n\n  // pointer interaction on keys (with glide)\n  var pointerDown=false;\n  function noteFromEvent(e){\n    var el=document.elementFromPoint(e.clientX,e.clientY);\n    if(el && el.dataset && el.dataset.note) return +el.dataset.note;\n    return null;\n  }\n  keysEl.addEventListener(\"pointerdown\",function(e){\n    pointerDown=true; var n=noteFromEvent(e);\n    if(n!=null){ press(n); keysEl.setPointerCapture(e.pointerId); }\n    e.preventDefault();\n  });\n  keysEl.addEventListener(\"pointermove\",function(e){\n    if(!pointerDown) return;\n    var n=noteFromEvent(e);\n    for(var held in down){ if(+held!==n) release(+held); }\n    if(n!=null) press(n);\n  });\n  function upAll(){ pointerDown=false; for(var held in down) release(+held); }\n  keysEl.addEventListener(\"pointerup\",upAll);\n  keysEl.addEventListener(\"pointercancel\",upAll);\n\n  // computer keyboard A..K (white) + W E T Y U (black)\n  var KEYMAP = { a:48,w:49,s:50,e:51,d:52,f:53,t:54,g:55,y:56,h:57,u:58,j:59,k:60 };\n  window.addEventListener(\"keydown\",function(e){\n    if(e.repeat) return;\n    var n=KEYMAP[e.key.toLowerCase()];\n    if(n!=null){ press(n); }\n  });\n  window.addEventListener(\"keyup\",function(e){\n    var n=KEYMAP[e.key.toLowerCase()];\n    if(n!=null){ release(n); }\n  });\n\n  // ===================================================================\n  //  ANIMATION LOOP — reeds vibrate; struck reeds swing wider then decay\n  // ===================================================================\n  var t0=performance.now();\n  function frame(now){\n    requestAnimationFrame(frame);\n    if(document.hidden) return;\n    var dt=(now-t0)*0.001;\n    var depth = nz(PARAMS[3],state[3]);\n    var rate = nz(PARAMS[4],state[4]);\n    var tremHz = 3 + rate*6;\n    var tone = nz(PARAMS[2],state[2]);\n    // global tremolo modulation factor (0..1) applied to all reed swing\n    var trem = 1 - depth*(0.5 - 0.5*Math.sin(dt*tremHz*6.283));\n\n    for(var i=0;i<reeds.length;i++){\n      var rd=reeds[i];\n      // decay any excited reed back to a gentle idle shimmer\n      var idle = 0.06 + tone*0.05;\n      if(rd.amp>idle){ rd.amp += (idle-rd.amp)*0.018; }\n      else { rd.amp = idle; }\n      // each reed vibrates at a rate scaled to its pitch\n      var vib = Math.sin(dt*(14 + i*1.1) + rd.phase);\n      var swing = rd.amp * vib * (10 + (1-i/reeds.length)*8) * trem;\n      var tipX = rd.x + swing;\n      var topY = rd.base - rd.len;\n      // a curved reed: quadratic bezier from clamp to swinging tip\n      var ctrlX = rd.x + swing*0.45;\n      var ctrlY = rd.base - rd.len*0.55;\n      rd.path.setAttribute(\"d\",\"M\"+rd.x.toFixed(1)+\" \"+rd.base+\" Q\"+ctrlX.toFixed(1)+\" \"+ctrlY.toFixed(1)+\" \"+tipX.toFixed(1)+\" \"+topY.toFixed(1));\n      rd.tip.setAttribute(\"cx\",tipX.toFixed(1));\n      rd.tip.setAttribute(\"cy\",topY.toFixed(1));\n      var lit = Math.min(1, rd.amp*1.4);\n      rd.tip.style.opacity = (0.4+lit*0.6).toFixed(2);\n      rd.path.style.stroke = lit>0.5 ? \"var(--ac2)\" : \"var(--reed)\";\n    }\n  }\n  requestAnimationFrame(frame);\n\n  // ---- init ----\n  function ready(){\n    PARAMS.forEach(function(p,i){ p._paint(); setParam(p.index,state[i]); });\n    reactGlobals();\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  REED PIANO — polyphonic electric reed-piano instrument\n//  Models a struck-steel-reed electric piano (the warm 60s school-piano\n//  voice): a reed tone with a hollow, slightly hard/barky attack and a\n//  built-in tremolo. Distinct from a tine Rhodes — here the body is a\n//  reed-like blend of odd-ish partials run through an ASYMMETRIC soft\n//  clipper whose drive tracks both velocity and a fast \"bark\" envelope,\n//  so hard hits growl and bark on the attack then mellow into a hollow\n//  sustain. A per-voice amp envelope (snappy attack + decay/release) and\n//  a one-pole tone low-pass finish each voice; a global sine tremolo\n//  (amplitude modulation) wobbles the whole instrument.\n//  Pure algorithm — no samples, no host imports, no allocation in process.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_VOICES: i32 = 12;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831853071795864769;\nconst PI:     f32 = 3.1415926535897932385;\n\n// ---- per-voice state (parallel StaticArrays, no allocation in process) ----\nconst vActive: StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = in use\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // 1 = key held\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(MAX_VOICES); // note id\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // reed phase (radians)\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // fundamental Hz\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // 0..1\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // current amp-env level\nconst vBark:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // fast bark env (0..1, decays)\nconst vAge:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // voice-steal LRU\nconst vTone:   StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // per-voice tone LP state\nconst vDc:     StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // DC blocker state (asym clip)\nconst vDcX:    StaticArray<f32> = new StaticArray<f32>(MAX_VOICES); // DC blocker prev input\n\nlet ageCounter: f32 = 0.0;\nlet tremPhase:  f32 = 0.0; // global tremolo LFO phase (radians)\n\n// ---- parameter indices (MUST match spec.json) ----\nconst P_BARK:   i32 = 0; // attack drive / hardness of the bark   (0..1)\nconst P_DECAY:  i32 = 1; // body decay time while held            (0..1)\nconst P_TONE:   i32 = 2; // tone tilt low-pass cutoff             (0..1)\nconst P_TREMD:  i32 = 3; // tremolo depth                         (0..1)\nconst P_TREMR:  i32 = 4; // tremolo rate                          (0..1)\nconst P_LEVEL:  i32 = 5; // output level                          (0..1)\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    vPhase[v] = 0.0; vFreq[v] = 0.0; vVel[v] = 0.0;\n    vAmp[v] = 0.0; vBark[v] = 0.0; vAge[v] = 0.0;\n    vTone[v] = 0.0; vDc[v] = 0.0; vDcX[v] = 0.0;\n  }\n  ageCounter = 0.0;\n  tremPhase = 0.0;\n  params[P_BARK]  = 0.55;\n  params[P_DECAY] = 0.55;\n  params[P_TONE]  = 0.5;\n  params[P_TREMD] = 0.35;\n  params[P_TREMR] = 0.4;\n  params[P_LEVEL] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Asymmetric soft clipper — the classic reed \"bark\". Positive and negative\n// halves saturate differently (tanh-ish via a rational approx) so even\n// harmonics appear, giving the hollow, hard-edged growl on hard hits.\n@inline function asymShape(x: f32, drive: f32): f32 {\n  const a: f32 = x * drive;\n  // bias the positive lobe harder than the negative -> asymmetry -> even harmonics\n  const pos: f32 = a / (1.0 + a * a);            // soft, rounds toward ±0.5\n  const neg: f32 = a / (1.0 + 0.45 * a * a);     // less compressed -> sharper\n  const y: f32 = a >= 0.0 ? pos : neg;\n  return y * 1.6;\n}\n\n// ---- note handling: find a free (or oldest) voice ----\nexport function noteOn(id: i32, freq: f32, velocity: f32): void {\n  if (freq <= 0.0) freq = 1.0;\n  let slot: i32 = -1;\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) { slot = v; break; }\n  }\n  if (slot < 0) {\n    for (let v = 0; v < MAX_VOICES; v++) {\n      if (vActive[v] == 0) { slot = v; break; }\n    }\n  }\n  if (slot < 0) {\n    let oldest: f32 = vAge[0]; slot = 0;\n    for (let v = 1; v < MAX_VOICES; v++) {\n      if (vAge[v] < oldest) { oldest = vAge[v]; slot = v; }\n    }\n  }\n  ageCounter += 1.0;\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vNote[slot]   = id;\n  vFreq[slot]   = freq;\n  vVel[slot]    = clampf(velocity, 0.0, 1.0);\n  vPhase[slot]  = 0.0;\n  vAmp[slot]    = 0.0;\n  vBark[slot]   = 1.0;   // bark env starts hot, decays fast -> hard attack, mellow sustain\n  vAge[slot]    = ageCounter;\n  vTone[slot]   = 0.0;\n  vDc[slot]     = 0.0;\n  vDcX[slot]    = 0.0;\n}\n\nexport function noteOff(id: i32): void {\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] != 0 && vNote[v] == id) vGate[v] = 0;\n  }\n}\n\nexport function process(n: i32): void {\n  // ---- resolve params once per block ----\n  const barkN:  f32 = clampf(params[P_BARK],  0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE],  0.0, 1.0);\n  const tremD:  f32 = clampf(params[P_TREMD], 0.0, 1.0);\n  const tremR:  f32 = clampf(params[P_TREMR], 0.0, 1.0);\n  const level:  f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 0.9;\n\n  const invSr: f32 = 1.0 / sampleRate;\n\n  // amp attack: fast, reed-like (1.5 ms .. 8 ms) — always snappy\n  const attackSec: f32 = 0.0015 + (1.0 - barkN) * 0.0065;\n  const attackCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / (attackSec * sampleRate)));\n\n  // body decay while held: 0.6 s .. 6 s\n  const decSec: f32 = 0.6 + decayN * decayN * 5.4;\n  const decCoef: f32 = f32(Mathf.exp(-1.0 / (decSec * sampleRate)));\n  // release after note-off: a fraction of the held decay, min ~0.12 s\n  const relSec: f32 = 0.12 + decayN * 0.9;\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (relSec * sampleRate)));\n\n  // bark envelope decay: the hard edge mellows in 18 ms .. 80 ms.\n  // More Bark = a touch longer growl before it settles.\n  const barkSec: f32 = 0.018 + barkN * 0.062;\n  const barkCoef: f32 = f32(Mathf.exp(-1.0 / (barkSec * sampleRate)));\n\n  // peak asymmetric drive from Bark (1.2 .. ~9)\n  const peakDrive: f32 = 1.2 + barkN * 7.8;\n\n  // tone low-pass cutoff: 700 Hz .. 7 kHz (mellow .. open)\n  let toneHz: f32 = 700.0 + toneN * toneN * 6300.0;\n  if (toneHz > sampleRate * 0.45) toneHz = sampleRate * 0.45;\n  let toneCoef: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  toneCoef = clampf(toneCoef, 0.0, 1.0);\n\n  // tremolo: 3 Hz .. 9 Hz, depth 0..0.9 of amplitude\n  const tremHz: f32 = 3.0 + tremR * 6.0;\n  const tremInc: f32 = TWO_PI * tremHz * invSr;\n  const tremDepth: f32 = tremD * 0.9;\n\n  // DC-blocker pole (asymmetric shaping adds DC offset we must remove)\n  const dcR: f32 = 0.9985;\n\n  // ---- clear output block ----\n  for (let f = 0; f < n; f++) {\n    outBuf[f] = 0.0;\n    outBuf[MAX_FRAMES + f] = 0.0;\n  }\n\n  // ---- render each active voice (mono sum, copied to both channels) ----\n  for (let v = 0; v < MAX_VOICES; v++) {\n    if (vActive[v] == 0) continue;\n\n    const f0: f32 = vFreq[v];\n    const inc: f32 = TWO_PI * f0 * invSr;\n    const vel: f32 = vVel[v];\n    const ampTarget: f32 = 0.25 + vel * 0.75; // velocity sets sustain level\n    const gate: i32 = vGate[v];\n\n    let phase: f32 = vPhase[v];\n    let amp: f32 = vAmp[v];\n    let bark: f32 = vBark[v];\n    let tone: f32 = vTone[v];\n    let dc: f32 = vDc[v];\n    let dcX: f32 = vDcX[v];\n    let reachedAttack: bool = amp >= ampTarget * 0.999;\n\n    for (let f = 0; f < n; f++) {\n      // bark envelope decays toward 0 -> attack drive collapses to a mellow body\n      bark *= barkCoef;\n\n      // amp envelope: snappy attack to target, then decay (held) / release (off)\n      if (gate != 0 && !reachedAttack) {\n        amp += attackCoef * (ampTarget - amp);\n        if (amp >= ampTarget * 0.999) { amp = ampTarget; reachedAttack = true; }\n      } else if (gate != 0) {\n        amp *= decCoef;\n      } else {\n        amp *= relCoef;\n      }\n\n      // ---- reed tone: a hollow blend of partials (fundamental + odd-ish stack) ----\n      const s1: f32 = Mathf.sin(phase);\n      const s2: f32 = Mathf.sin(phase * 2.0);\n      const s3: f32 = Mathf.sin(phase * 3.0);\n      const s4: f32 = Mathf.sin(phase * 4.0);\n      // hollow reed: strong fundamental, present 3rd, scooped 2nd, a little 4th\n      let reed: f32 = s1 + 0.22 * s2 + 0.55 * s3 + 0.18 * s4;\n      reed *= 0.55;\n\n      // asymmetric bark drive: harder on the attack (velocity + bark env),\n      // mellowing as the bark env decays toward the clean reed body.\n      const drive: f32 = 1.0 + (peakDrive - 1.0) * bark * (0.4 + 0.6 * vel);\n      let shaped: f32 = asymShape(reed, drive);\n\n      // DC blocker (asymmetry introduces DC) — high-pass at ~few Hz\n      const hp: f32 = shaped - dcX + dcR * dc;\n      dcX = shaped;\n      dc = hp;\n\n      // per-voice tone low-pass (mellow body, opens with Tone)\n      tone += toneCoef * (hp - tone);\n\n      const voiceOut: f32 = tone * amp;\n      outBuf[f] += voiceOut;\n\n      phase += inc; if (phase >= TWO_PI) phase -= TWO_PI;\n    }\n\n    vPhase[v] = phase;\n    vAmp[v] = amp;\n    vBark[v] = bark;\n    vTone[v] = tone;\n    vDc[v] = dc;\n    vDcX[v] = dcX;\n\n    // retire voice once faded and key released\n    if (gate == 0 && amp < 0.00008) {\n      vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n    }\n  }\n\n  // ---- global tremolo + output level + soft safety clip, mono->stereo ----\n  for (let f = 0; f < n; f++) {\n    // sine tremolo modulating amplitude (1 at trough.. )\n    const lfo: f32 = Mathf.sin(tremPhase);\n    const trem: f32 = 1.0 - tremDepth * (0.5 - 0.5 * lfo); // 1.0 .. (1-depth)\n    tremPhase += tremInc; if (tremPhase >= TWO_PI) tremPhase -= TWO_PI;\n\n    let s: f32 = outBuf[f] * level * trem;\n    // gentle soft clip keeps dense chords < 1.0\n    if (s > 1.4) s = 1.4; else if (s < -1.4) s = -1.4;\n    s = f32(s - 0.14285714 * s * s * s);\n    outBuf[f] = s;\n    outBuf[MAX_FRAMES + f] = s;\n  }\n}\n",
  "publishedAt": 1751000083000
}