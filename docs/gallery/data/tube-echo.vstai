{
  "format": 1,
  "name": "Tube Echo",
  "isInstrument": false,
  "explanation": "A single-head tape echo with tube-preamp warmth. One record/play tape head provides a single delayed repeat fed back on itself; a tube preamp stage adds the signature warm saturation that colours the signal even at 100% dry. Each repeat is gently darkened by tape HF loss, softly saturated, and pitch-wandered by slow wow and faster flutter. Feedback can build toward bounded self-oscillation. Controls: Time, Feedback, Drive (preamp warmth), Tone (repeat darkening) and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Drive",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Tube Echo</title>\n<style>\n  :root{\n    --accent:#ff9a3d;\n    --accent2:#ffd86a;\n    --tan:#caa472;\n    --tan-d:#a07b48;\n    --cream:#efe3c6;\n    --panel:#1c1611;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;user-select:none;-webkit-user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:radial-gradient(120% 120% at 50% 0%,#2a201a 0%,#100b07 70%);\n    color:#f4e9d2;\n    display:flex;align-items:center;justify-content:center;\n    overflow:hidden;\n  }\n\n  /* ---------------- chassis ---------------- */\n  .unit{\n    position:relative;\n    width:560px;\n    border-radius:18px;\n    padding:22px 26px 26px;\n    background:\n      linear-gradient(180deg,#d8b886 0%,#c19a64 45%,#a87f4b 100%);\n    box-shadow:\n      0 30px 60px rgba(0,0,0,.6),\n      inset 0 2px 0 rgba(255,255,255,.35),\n      inset 0 -4px 12px rgba(0,0,0,.4);\n    border:1px solid #7d5c34;\n  }\n  /* brushed-metal sheen overlay */\n  .unit:before{\n    content:\"\";position:absolute;inset:0;border-radius:18px;\n    background:repeating-linear-gradient(90deg,rgba(255,255,255,.04) 0 2px,rgba(0,0,0,.03) 2px 4px);\n    pointer-events:none;mix-blend-mode:overlay;\n  }\n  /* corner screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#f3e6c8,#8b6c3e 70%,#5c4426);\n    box-shadow:inset 0 0 0 1px rgba(0,0,0,.3),0 1px 1px rgba(0,0,0,.4);}\n  .screw:after{content:\"\";position:absolute;inset:3px;border-top:2px solid rgba(60,40,15,.7);transform:rotate(35deg);}\n  .screw.tl{top:9px;left:9px}.screw.tr{top:9px;right:9px}\n  .screw.bl{bottom:9px;left:9px}.screw.br{bottom:9px;right:9px}\n\n  .brand{\n    display:flex;align-items:baseline;gap:10px;margin:2px 4px 16px;\n  }\n  .brand h1{\n    font-size:21px;letter-spacing:3px;font-weight:800;\n    color:#3a2a16;text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(255,255,255,.45);\n  }\n  .brand .sub{\n    font-size:9px;letter-spacing:4px;color:#5e4524;text-transform:uppercase;\n    border:1px solid rgba(60,40,15,.4);padding:2px 7px;border-radius:4px;\n  }\n\n  /* ---------------- top deck: reel + tube + VU ---------------- */\n  .deck{\n    display:flex;gap:18px;align-items:stretch;\n    background:linear-gradient(180deg,#241b12,#15100b);\n    border-radius:12px;padding:16px;\n    box-shadow:inset 0 3px 10px rgba(0,0,0,.7),0 1px 0 rgba(255,255,255,.15);\n    border:1px solid #5c4326;\n  }\n\n  /* spinning reel */\n  .reel-wrap{position:relative;width:150px;height:150px;flex:0 0 auto;}\n  .reel{\n    width:150px;height:150px;\n    animation:spin 4s linear infinite;\n    transform-origin:50% 50%;\n  }\n  @keyframes spin{to{transform:rotate(360deg);}}\n\n  /* glowing tube */\n  .tube-col{flex:0 0 70px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;}\n  .tube{\n    position:relative;width:46px;height:96px;border-radius:23px 23px 10px 10px;\n    background:linear-gradient(180deg,rgba(255,230,180,.18),rgba(120,80,30,.25));\n    border:1px solid rgba(255,210,150,.35);\n    overflow:hidden;\n    box-shadow:0 0 18px rgba(255,150,60,.25), inset 0 0 20px rgba(0,0,0,.4);\n  }\n  .filament{\n    position:absolute;left:50%;bottom:10px;width:6px;height:60px;\n    transform:translateX(-50%);\n    background:linear-gradient(180deg,#fff2c0,#ff8a2a);\n    border-radius:3px;\n    filter:blur(1px);\n    box-shadow:0 0 14px 4px rgba(255,140,40,.9);\n    animation:flick 2.6s ease-in-out infinite;\n  }\n  .glowpool{\n    position:absolute;inset:0;border-radius:inherit;\n    background:radial-gradient(circle at 50% 78%,rgba(255,150,50,.55),transparent 65%);\n    animation:flick 2.6s ease-in-out infinite;\n  }\n  @keyframes flick{0%,100%{opacity:.78}45%{opacity:1}60%{opacity:.86}}\n  .tube-base{width:34px;height:12px;border-radius:0 0 6px 6px;background:linear-gradient(#3a2c1a,#1d150c);box-shadow:inset 0 1px 1px rgba(255,255,255,.15);}\n\n  /* VU + transport (right of deck) */\n  .meta{flex:1;display:flex;flex-direction:column;gap:10px;min-width:0;}\n  .vu{\n    position:relative;height:64px;border-radius:8px;\n    background:radial-gradient(120% 160% at 50% 0%,#f3e6c2,#d7c191);\n    border:1px solid #8a6c3e;overflow:hidden;\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.35);\n  }\n  .vu-glow{\n    position:absolute;inset:0;\n    background:radial-gradient(60% 120% at var(--vux,50%) 110%,rgba(255,140,40,.65),transparent 60%);\n    transition:none;\n  }\n  .needle{\n    position:absolute;left:50%;bottom:6px;width:2px;height:50px;\n    background:linear-gradient(#3a2a14,#b5421f);transform-origin:50% 100%;\n    transform:rotate(0deg);\n    box-shadow:0 0 4px rgba(0,0,0,.4);\n  }\n  .vu-arc{position:absolute;inset:0;}\n  .vu-label{position:absolute;top:5px;left:0;right:0;text-align:center;font-size:8px;letter-spacing:3px;color:#6a4f28;}\n\n  /* playback head slider track */\n  .headtrack{\n    position:relative;height:26px;border-radius:6px;\n    background:linear-gradient(#15100a,#241a10);\n    border:1px solid #5c4326;overflow:hidden;\n  }\n  .tapeline{position:absolute;top:50%;left:6px;right:6px;height:6px;transform:translateY(-50%);\n    background:linear-gradient(90deg,#3a2c1d,#5a4327,#3a2c1d);border-radius:3px;\n    box-shadow:inset 0 1px 1px rgba(0,0,0,.5);}\n  .tapeline:after{content:\"\";position:absolute;inset:0;\n    background:repeating-linear-gradient(90deg,rgba(255,200,140,.12) 0 8px,transparent 8px 16px);\n    animation:tapescroll 1.1s linear infinite;}\n  @keyframes tapescroll{to{background-position:32px 0;}}\n  .phead{\n    position:absolute;top:1px;bottom:1px;width:16px;border-radius:3px;\n    background:linear-gradient(180deg,#d9d9df,#7d7d86 60%,#42424a);\n    box-shadow:0 0 8px rgba(255,154,61,.6),inset 0 1px 1px rgba(255,255,255,.5);\n    left:30%;transform:translateX(-50%);\n  }\n  .phead:after{content:\"\";position:absolute;left:50%;top:3px;bottom:3px;width:2px;transform:translateX(-50%);\n    background:#2a2a30;border-radius:1px;}\n\n  /* ---------------- knob row ---------------- */\n  .controls{\n    display:flex;justify-content:space-between;gap:10px;margin-top:18px;\n    padding:14px 8px 6px;\n  }\n  .ctrl{display:flex;flex-direction:column;align-items:center;gap:7px;flex:1;}\n  .knob{\n    position:relative;width:74px;height:74px;border-radius:50%;\n    cursor:grab;\n    background:\n      radial-gradient(circle at 38% 32%,#4a4038,#241c14 65%,#120c07);\n    box-shadow:\n      0 6px 14px rgba(0,0,0,.55),\n      inset 0 2px 3px rgba(255,255,255,.18),\n      inset 0 -4px 8px rgba(0,0,0,.6);\n    border:1px solid #6a4f2c;\n  }\n  .knob:active{cursor:grabbing;}\n  .knob .cap{\n    position:absolute;inset:11px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#3b322a,#1a130c);\n    box-shadow:inset 0 1px 2px rgba(255,255,255,.12);\n  }\n  /* indicator notch (rotates) */\n  .knob .ind{\n    position:absolute;left:50%;top:6px;width:4px;height:20px;border-radius:2px;\n    transform-origin:50% 31px;\n    background:linear-gradient(var(--accent2),var(--accent));\n    box-shadow:0 0 8px rgba(255,154,61,.85);\n    transform:translateX(-50%) rotate(0deg);\n  }\n  /* tick ring */\n  .knob .ring{position:absolute;inset:-6px;border-radius:50%;pointer-events:none;}\n  .lbl{font-size:10px;letter-spacing:2px;text-transform:uppercase;color:#2d2012;font-weight:700;text-shadow:0 1px 0 rgba(255,255,255,.35);}\n  .val{font-size:11px;font-variant-numeric:tabular-nums;color:#3a2a14;\n    background:rgba(255,245,220,.55);border-radius:4px;padding:1px 7px;min-width:54px;text-align:center;\n    box-shadow:inset 0 1px 2px rgba(0,0,0,.2);}\n\n  .footnote{margin:14px 4px 0;font-size:8px;letter-spacing:2px;color:#5e4524;text-align:center;text-transform:uppercase;}\n</style>\n</head>\n<body>\n  <div class=\"unit\" id=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"brand\">\n      <h1>Tube&nbsp;Echo</h1>\n      <span class=\"sub\">Tape Delay · Tube Preamp</span>\n    </div>\n\n    <div class=\"deck\">\n      <!-- spinning reel -->\n      <div class=\"reel-wrap\">\n        <svg class=\"reel\" id=\"reelSvg\" viewBox=\"0 0 150 150\" aria-hidden=\"true\">\n          <defs>\n            <radialGradient id=\"tapeGrad\" cx=\"50%\" cy=\"42%\" r=\"60%\">\n              <stop offset=\"0%\" stop-color=\"#5a4226\"/>\n              <stop offset=\"55%\" stop-color=\"#36281a\"/>\n              <stop offset=\"100%\" stop-color=\"#1d150d\"/>\n            </radialGradient>\n            <radialGradient id=\"hubGrad\" cx=\"40%\" cy=\"35%\" r=\"70%\">\n              <stop offset=\"0%\" stop-color=\"#f2e7c8\"/>\n              <stop offset=\"60%\" stop-color=\"#c7a268\"/>\n              <stop offset=\"100%\" stop-color=\"#7d5c34\"/>\n            </radialGradient>\n          </defs>\n          <!-- tape pack -->\n          <circle cx=\"75\" cy=\"75\" r=\"70\" fill=\"url(#tapeGrad)\"/>\n          <!-- tape striations -->\n          <g stroke=\"rgba(255,210,150,.07)\" stroke-width=\"1\" fill=\"none\">\n            <circle cx=\"75\" cy=\"75\" r=\"62\"/><circle cx=\"75\" cy=\"75\" r=\"54\"/>\n            <circle cx=\"75\" cy=\"75\" r=\"46\"/><circle cx=\"75\" cy=\"75\" r=\"38\"/>\n          </g>\n          <!-- flange / hub -->\n          <circle cx=\"75\" cy=\"75\" r=\"34\" fill=\"url(#hubGrad)\" stroke=\"#5c4326\" stroke-width=\"1.5\"/>\n          <!-- spokes (3 holes) -->\n          <g fill=\"#1d150d\">\n            <circle cx=\"75\" cy=\"50\" r=\"7\"/>\n            <circle cx=\"96\" cy=\"87\" r=\"7\"/>\n            <circle cx=\"54\" cy=\"87\" r=\"7\"/>\n          </g>\n          <circle cx=\"75\" cy=\"75\" r=\"8\" fill=\"#2a1f12\" stroke=\"#8a6c3e\" stroke-width=\"1.5\"/>\n        </svg>\n      </div>\n\n      <!-- glowing tube -->\n      <div class=\"tube-col\">\n        <div class=\"tube\">\n          <div class=\"glowpool\"></div>\n          <div class=\"filament\"></div>\n        </div>\n        <div class=\"tube-base\"></div>\n      </div>\n\n      <!-- VU + transport -->\n      <div class=\"meta\">\n        <div class=\"vu\">\n          <div class=\"vu-glow\" id=\"vuGlow\"></div>\n          <div class=\"vu-label\">REC LEVEL</div>\n          <svg class=\"vu-arc\" viewBox=\"0 0 240 70\" preserveAspectRatio=\"none\">\n            <path d=\"M20 64 A110 110 0 0 1 220 64\" fill=\"none\" stroke=\"rgba(90,66,32,.5)\" stroke-width=\"1.5\"/>\n            <path d=\"M150 14 A150 150 0 0 1 222 60\" fill=\"none\" stroke=\"rgba(180,66,31,.6)\" stroke-width=\"2\"/>\n          </svg>\n          <div class=\"needle\" id=\"vuNeedle\"></div>\n        </div>\n        <div class=\"headtrack\">\n          <div class=\"tapeline\"></div>\n          <div class=\"phead\" id=\"phead\"></div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n\n    <div class=\"footnote\">Single-Head Tape · Wow &amp; Flutter · Bounded Self-Oscillation</div>\n  </div>\n\n<script>\n(function(){\n  // ---- host bridge --------------------------------------------------\n  var host = (typeof window!==\"undefined\" && window.vstai) ? window.vstai : null;\n  function setParam(i,v){ if(host && host.setParam) host.setParam(i,v); }\n\n  // ---- param model --------------------------------------------------\n  // map 0..1 -> display string\n  var PARAMS = [\n    { name:\"Time\",     def:0.35, fmt:function(v){ return (40+v*860).toFixed(0)+\" ms\"; } },\n    { name:\"Feedback\", def:0.40, fmt:function(v){ return (v*100).toFixed(0)+\" %\"; } },\n    { name:\"Drive\",    def:0.40, fmt:function(v){ return (v*100).toFixed(0)+\" %\"; } },\n    { name:\"Tone\",     def:0.50, fmt:function(v){ return v<0.5 ? \"dark \"+((0.5-v)*200).toFixed(0) : \"bright \"+((v-0.5)*200).toFixed(0); } },\n    { name:\"Mix\",      def:0.40, fmt:function(v){ return (v*100).toFixed(0)+\" %\"; } }\n  ];\n  var state = PARAMS.map(function(p){ return p.def; });\n\n  var controls = document.getElementById(\"controls\");\n  var knobs = [];\n\n  // angle sweep -135..+135 deg\n  function angleFor(v){ return -135 + v*270; }\n\n  function buildTicks(svgNS){\n    // returns SVG tick ring as innerHTML\n    var html = '<svg class=\"ring\" viewBox=\"0 0 100 100\">';\n    for(var i=0;i<=10;i++){\n      var a = (-135 + i*27) * Math.PI/180;\n      var x1 = 50 + Math.sin(a)*46, y1 = 50 - Math.cos(a)*46;\n      var x2 = 50 + Math.sin(a)*41, y2 = 50 - Math.cos(a)*41;\n      var maj = (i%5===0);\n      html += '<line x1=\"'+x1.toFixed(1)+'\" y1=\"'+y1.toFixed(1)+'\" x2=\"'+x2.toFixed(1)+'\" y2=\"'+y2.toFixed(1)+\n              '\" stroke=\"'+(maj?'rgba(255,154,61,.8)':'rgba(120,90,50,.55)')+'\" stroke-width=\"'+(maj?2:1.2)+'\" stroke-linecap=\"round\"/>';\n    }\n    html += '</svg>';\n    return html;\n  }\n\n  PARAMS.forEach(function(p, idx){\n    var ctrl = document.createElement(\"div\"); ctrl.className=\"ctrl\";\n    var knob = document.createElement(\"div\"); knob.className=\"knob\";\n    knob.innerHTML = buildTicks() +\n      '<div class=\"cap\"></div>' +\n      '<div class=\"ind\"></div>';\n    var lbl = document.createElement(\"div\"); lbl.className=\"lbl\"; lbl.textContent = p.name;\n    var val = document.createElement(\"div\"); val.className=\"val\";\n    ctrl.appendChild(knob); ctrl.appendChild(lbl); ctrl.appendChild(val);\n    controls.appendChild(ctrl);\n\n    var ind = knob.querySelector(\".ind\");\n    var rec = { knob:knob, ind:ind, val:val, p:p, idx:idx };\n    knobs.push(rec);\n\n    function render(){\n      var v = state[idx];\n      ind.style.transform = \"translateX(-50%) rotate(\"+angleFor(v)+\"deg)\";\n      val.textContent = p.fmt(v);\n    }\n    rec.render = render;\n\n    // ---- drag interaction ----\n    var dragging=false, startY=0, startV=0;\n    function onDown(e){\n      dragging=true;\n      startY = (e.touches?e.touches[0].clientY:e.clientY);\n      startV = state[idx];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",onMove);\n      window.addEventListener(\"mouseup\",onUp);\n      window.addEventListener(\"touchmove\",onMove,{passive:false});\n      window.addEventListener(\"touchend\",onUp);\n    }\n    function onMove(e){\n      if(!dragging) return;\n      var y = (e.touches?e.touches[0].clientY:e.clientY);\n      var dy = startY - y;\n      var nv = startV + dy/200;\n      if(nv<0)nv=0; if(nv>1)nv=1;\n      state[idx]=nv; render(); setParam(idx,nv); reflectMacros();\n      e.preventDefault();\n    }\n    function onUp(){\n      dragging=false;\n      window.removeEventListener(\"mousemove\",onMove);\n      window.removeEventListener(\"mouseup\",onUp);\n      window.removeEventListener(\"touchmove\",onMove);\n      window.removeEventListener(\"touchend\",onUp);\n    }\n    knob.addEventListener(\"mousedown\",onDown);\n    knob.addEventListener(\"touchstart\",onDown,{passive:false});\n    knob.addEventListener(\"wheel\",function(e){\n      var nv = state[idx] - Math.sign(e.deltaY)*0.03;\n      if(nv<0)nv=0; if(nv>1)nv=1;\n      state[idx]=nv; render(); setParam(idx,nv); reflectMacros();\n      e.preventDefault();\n    },{passive:false});\n    knob.addEventListener(\"dblclick\",function(){\n      state[idx]=p.def; render(); setParam(idx,p.def); reflectMacros();\n    });\n\n    render();\n  });\n\n  // ---- animated meta reflects Time / Drive / Feedback ----\n  var reel = document.getElementById(\"reelSvg\");\n  var vuGlow = document.getElementById(\"vuGlow\");\n  var vuNeedle = document.getElementById(\"vuNeedle\");\n  var phead = document.getElementById(\"phead\");\n  var tube = document.querySelector(\".tube\");\n\n  function reflectMacros(){\n    var time = state[0], fb = state[1], drive = state[2];\n    // reel speed: slower time = faster transport (more reps/sec); 1.2s..6s\n    var dur = (1.4 + time*5.0).toFixed(2);\n    reel.style.animationDuration = dur + \"s\";\n    // playback head position tracks Time across the track\n    phead.style.left = (8 + time*84) + \"%\";\n    // VU driven by Drive (preamp warmth)\n    var lvl = drive*0.8 + fb*0.2;\n    vuGlow.style.setProperty(\"--vux\", (20 + lvl*60) + \"%\");\n    vuNeedle.style.transform = \"rotate(\" + (-50 + lvl*100) + \"deg)\";\n    // tube glow intensity from drive\n    tube.style.boxShadow = \"0 0 \"+(14+drive*26)+\"px rgba(255,150,60,\"+(0.2+drive*0.5)+\"), inset 0 0 20px rgba(0,0,0,.4)\";\n  }\n\n  // gentle idle VU shimmer\n  var t=0;\n  setInterval(function(){\n    t+=0.08;\n    var base = state[2]*0.8 + state[1]*0.2;\n    var shimmer = base + Math.sin(t)*0.05*(0.3+base);\n    if(shimmer<0)shimmer=0; if(shimmer>1)shimmer=1;\n    vuGlow.style.setProperty(\"--vux\",(20+shimmer*60)+\"%\");\n    vuNeedle.style.transform=\"rotate(\"+(-50+shimmer*100)+\"deg)\";\n  },60);\n\n  function initAll(){\n    state.forEach(function(v,i){ setParam(i,v); });\n    knobs.forEach(function(k){ k.render(); });\n    reflectMacros();\n  }\n\n  if(host && host.onReady){ host.onReady(initAll); }\n  else { initAll(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  TUBE ECHO — single-head tape echo with tube-PREAMP warmth\n//  (Echoplex EP-3 lineage, an ORIGINAL design)\n//\n//  Signal: input -> tube preamp warmth/saturation (always on, the famous\n//  EP-3 colour, even at 100% dry) -> a single record/play tape head (one\n//  delay tap) with a feedback loop. Each repeat is darkened (HF tape loss),\n//  soft-saturated on tape, and pitch-wandered by a slow wow + faster flutter\n//  LFO. Feedback can build toward bounded self-oscillation. Pure algorithm.\n//\n//  Params: Time, Feedback, Drive (preamp warmth), Tone (repeat darkening), Mix\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: up to ~1.2s per channel at 48k -> 64k samples is plenty.\nconst DELAY_LEN: i32 = 65536;          // power of two, ~1.36s @48k\nconst DELAY_MASK: i32 = DELAY_LEN - 1;\nconst delay: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel state\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst preLow:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // preamp pre-emph HP state\nconst toneState:StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // repeat darkening LP\nconst dcState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // feedback DC blocker\nconst dcPrev:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst fbSmooth: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // smoothed delay-time read\n\n// modulation phase (shared, mono modulation feels like a single transport)\nlet wowPhase: f32 = 0.0;\nlet flutPhase: f32 = 0.0;\nlet timeSmooth: f32 = 0.0;\n\nconst P_TIME: i32 = 0;     // 0..1 -> 40..900 ms\nconst P_FEEDBACK: i32 = 1; // 0..1 -> 0..1.08 (can self-oscillate, bounded)\nconst P_DRIVE: i32 = 2;    // 0..1 -> preamp warmth\nconst P_TONE: i32 = 3;     // 0..1 -> repeat darkening cutoff\nconst P_MIX: i32 = 4;      // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    writePos[c] = 0; preLow[c] = 0.0; toneState[c] = 0.0;\n    dcState[c] = 0.0; dcPrev[c] = 0.0; fbSmooth[c] = 0.0;\n  }\n  for (let i = 0; i < DELAY_LEN * MAX_CHANNELS; i++) delay[i] = 0.0;\n  wowPhase = 0.0; flutPhase = 0.0; timeSmooth = 0.0;\n  params[P_TIME] = 0.35; params[P_FEEDBACK] = 0.4; params[P_DRIVE] = 0.4;\n  params[P_TONE] = 0.5; params[P_MIX] = 0.4;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Tube-style asymmetric soft saturation. Warm even-harmonic bias + soft knee.\n@inline function tubeSat(x: f32, drive: f32): f32 {\n  const g: f32 = x * drive;\n  // asymmetric: slightly different curvature for +/- gives even harmonics\n  let y: f32;\n  if (g >= 0.0) {\n    y = g / (1.0 + 0.6 * g);\n  } else {\n    y = g / (1.0 - 0.45 * g);\n  }\n  // tanh-like rounding on top for graceful ceiling\n  const t: f32 = clampf(y, -1.6, 1.6);\n  return t - (t * t * t) * f32(0.111111);\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32   = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const driveN: f32= clampf(params[P_DRIVE], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32   = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Delay time 40..900 ms\n  const targetMs: f32 = 40.0 + timeN * 860.0;\n  const targetSamp: f32 = targetMs * 0.001 * sampleRate;\n\n  // Feedback 0..1.08 — bounded but can reach sustained self-oscillation\n  const feedback: f32 = fbN * 1.08;\n\n  // Preamp drive: 1..7 gain into the tube stage; compensate to keep level musical\n  const drive: f32 = 1.0 + driveN * 6.0;\n  const comp: f32 = 1.0 / (1.0 + 0.55 * driveN * 6.0) * 1.7;\n\n  // Repeat darkening: tone closes the LP on the feedback path. 1200..7000 Hz.\n  const toneHz: f32 = 1200.0 + toneN * toneN * 5800.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-PI2 * toneHz / sampleRate));\n\n  // Preamp gentle high-shelf-ish pre-emphasis (subtle ~180Hz tilt) for warmth\n  const cPre: f32 = f32(1.0 - Mathf.exp(-PI2 * 180.0 / sampleRate));\n\n  // Wow ~0.6 Hz, flutter ~6.5 Hz; depth scaled to samples\n  const wowInc: f32 = PI2 * 0.6 / sampleRate;\n  const flutInc: f32 = PI2 * 6.5 / sampleRate;\n  const wowDepth: f32 = 0.0022 * targetSamp + 1.2;   // samples\n  const flutDepth: f32 = 0.0009 * targetSamp + 0.4;  // samples\n\n  // time smoothing coefficient (slew the delay length)\n  const cTime: f32 = 0.0008;\n\n  let wp: f32 = wowPhase;\n  let fpz: f32 = flutPhase;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * DELAY_LEN;\n    let wpos: i32 = writePos[c];\n    let pl: f32 = preLow[c];\n    let tn: f32 = toneState[c];\n    let dcS: f32 = dcState[c];\n    let dcP: f32 = dcPrev[c];\n    let tsm: f32 = (c == 0) ? timeSmooth : fbSmooth[c];\n\n    // re-init smoothing on first run\n    if (tsm <= 0.0) tsm = targetSamp;\n\n    // local copies of modulation phase so both channels stay coherent\n    let lw: f32 = wp;\n    let lf: f32 = fpz;\n\n    for (let f = 0; f < n; f++) {\n      const xin: f32 = inBuf[c * MAX_FRAMES + f];\n\n      // --- Tube preamp warmth (always on, even at 100% dry) ---\n      pl = pl + cPre * (xin - pl);\n      const emph: f32 = xin + 0.25 * (xin - pl); // mild presence lift pre-tube\n      const pre: f32 = tubeSat(emph, drive) * comp;\n\n      // --- modulation: wow + flutter pitch wander ---\n      lw += wowInc; if (lw > PI2) lw -= PI2;\n      lf += flutInc; if (lf > PI2) lf -= PI2;\n      const mod: f32 = wowDepth * f32(Mathf.sin(lw)) + flutDepth * f32(Mathf.sin(lf));\n\n      // smooth delay length toward target\n      tsm += cTime * (targetSamp - tsm);\n      let readPos: f32 = f32(wpos) - (tsm + mod);\n      // wrap\n      while (readPos < 0.0) readPos += f32(DELAY_LEN);\n\n      // fractional read (linear interp)\n      const ri: i32 = i32(readPos);\n      const frac: f32 = readPos - f32(ri);\n      const i0: i32 = ri & DELAY_MASK;\n      const i1: i32 = (ri + 1) & DELAY_MASK;\n      const d0: f32 = delay[base + i0];\n      const d1: f32 = delay[base + i1];\n      const delayed: f32 = d0 + frac * (d1 - d0);\n\n      // --- repeat darkening (HF tape loss on each pass) ---\n      tn = tn + cTone * (delayed - tn);\n\n      // --- feedback DC blocker so self-osc doesn't drift to a rail ---\n      const fbIn: f32 = tn;\n      const dcOut: f32 = fbIn - dcP + 0.9985 * dcS;\n      dcP = fbIn; dcS = dcOut;\n\n      // tape soft-saturate the recirculating signal (keeps self-osc bounded)\n      const recirc: f32 = tubeSat(dcOut * feedback + pre, 1.0);\n\n      // write to head\n      delay[base + (wpos & DELAY_MASK)] = recirc;\n      wpos = (wpos + 1) & DELAY_MASK;\n\n      // --- output: dry is the WARMED preamp signal (so Drive colours dry too),\n      //     wet adds the darkened repeat ---\n      const wet: f32 = tn;\n      const dryOut: f32 = pre; // tube-warmed dry path\n      let outv: f32 = dryOut * (1.0 - mix) + wet * mix;\n      // safety ceiling\n      outv = clampf(outv, -1.2, 1.2);\n      outBuf[c * MAX_FRAMES + f] = outv;\n    }\n\n    writePos[c] = wpos;\n    preLow[c] = pl;\n    toneState[c] = tn;\n    dcState[c] = dcS;\n    dcPrev[c] = dcP;\n    if (c == 0) { timeSmooth = tsm; wp = lw; fpz = lf; }\n    else { fbSmooth[c] = tsm; }\n  }\n\n  wowPhase = wp;\n  flutPhase = fpz;\n}\n",
  "publishedAt": 1751000112000
}