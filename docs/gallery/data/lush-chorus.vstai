{
  "format": 1,
  "name": "Lush Chorus",
  "isInstrument": false,
  "explanation": "A lush bucket-brigade-style stereo chorus. Short modulated delay lines are read with interpolation and driven by two LFOs in quadrature for a wide image; an Intensity control sweeps from a subtle shimmer to a deep, fast ensemble by scaling rate and depth together, while a dark wet-path low-pass mimics the soft tone of an analogue delay line. Controls: Rate, Depth, Intensity, Mix and Width.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Intensity",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Width",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Lush Chorus</title>\n<style>\n/* ============================================================\n   LUSH CHORUS — a liquid bucket-brigade ensemble.\n   Animated water surface, doubled \"voice\" droplets, gentle\n   Juno pastel shimmer. Bespoke vertical-fluid faders + a\n   central tide pool. Every control is hand-built SVG/CSS.\n   ============================================================ */\n:root{\n  --ac:#6ad0ff;          /* aqua */\n  --ac2:#7a8cff;         /* periwinkle */\n  --foam:#d8f4ff;\n  --ink:#dff0fb;\n  --deep:#06121f;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px/1.4 \"Avenir Next\",ui-rounded,\"Segoe UI\",system-ui,-apple-system,sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(120% 90% at 50% -10%, #16344d 0%, #0b2237 42%, #06121f 78%, #030a12 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:18px;overflow:hidden;\n  -webkit-user-select:none;user-select:none;\n}\n\n/* ---- panel ------------------------------------------------ */\n.tank{\n  position:relative;width:100%;max-width:620px;border-radius:26px;\n  padding:0 0 18px;overflow:hidden;\n  background:linear-gradient(168deg,rgba(20,52,76,.92),rgba(7,20,33,.96));\n  border:1px solid rgba(150,220,255,.16);\n  box-shadow:\n    0 40px 90px rgba(0,0,0,.6),\n    inset 0 1px 0 rgba(190,235,255,.18),\n    inset 0 0 0 1px rgba(0,0,0,.35),\n    inset 0 -60px 90px rgba(7,18,30,.55);\n}\n/* slow caustic light slick over everything */\n.tank::before{\n  content:\"\";position:absolute;inset:-30%;z-index:0;pointer-events:none;\n  background:\n    radial-gradient(closest-side at 28% 30%, color-mix(in srgb,var(--ac) 26%,transparent), transparent 70%),\n    radial-gradient(closest-side at 74% 64%, color-mix(in srgb,var(--ac2) 24%,transparent), transparent 70%);\n  filter:blur(34px);\n  animation:slick 17s ease-in-out infinite alternate;\n}\n@keyframes slick{\n  0%{transform:translate(-6%,-4%) scale(1) rotate(0deg)}\n  100%{transform:translate(8%,6%) scale(1.14) rotate(8deg)}\n}\n\n/* ---- header ----------------------------------------------- */\n.cap{\n  position:relative;z-index:2;display:flex;align-items:center;gap:13px;\n  padding:17px 22px 14px;\n  border-bottom:1px solid rgba(150,220,255,.12);\n  background:linear-gradient(180deg,rgba(160,225,255,.07),rgba(160,225,255,0));\n}\n.drop{position:relative;width:26px;height:26px;flex:none}\n.drop svg{width:100%;height:100%;overflow:visible}\n.ttl{flex:1;min-width:0}\n.ttl h1{\n  margin:0;font-size:19px;font-weight:800;letter-spacing:.12em;\n  background:linear-gradient(96deg,var(--foam),var(--ac) 45%,var(--ac2));\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 0 22px rgba(106,208,255,.25);\n}\n.ttl p{margin:2px 0 0;font-size:10px;letter-spacing:.34em;text-transform:uppercase;color:#74a6c4}\n.tag{\n  font-size:9.5px;letter-spacing:.18em;text-transform:uppercase;color:#9fd6f0;\n  border:1px solid rgba(150,220,255,.28);border-radius:999px;padding:4px 11px;\n  background:rgba(106,208,255,.06);white-space:nowrap;\n}\n\n/* ---- body layout ------------------------------------------ */\n.body{\n  position:relative;z-index:2;\n  display:grid;grid-template-columns:1fr 188px 1fr;gap:14px;\n  padding:18px 20px 6px;align-items:stretch;\n}\n@media(max-width:560px){\n  .body{grid-template-columns:1fr 1fr}\n  .pool{grid-column:1 / -1;order:-1}\n}\n\n/* ---- fluid faders (Rate / Depth | Mix / Width) ------------ */\n.bank{display:flex;flex-direction:column;gap:14px}\n.fader{\n  position:relative;display:flex;gap:13px;align-items:stretch;\n  padding:11px 12px;border-radius:18px;\n  background:linear-gradient(160deg,rgba(140,205,240,.05),rgba(8,22,36,.35));\n  border:1px solid rgba(150,220,255,.1);\n  box-shadow:inset 0 1px 0 rgba(190,235,255,.08),0 8px 20px rgba(0,0,0,.28);\n  transition:border-color .25s,transform .25s,box-shadow .25s;\n  animation:rise .6s both;\n}\n.fader:hover{border-color:rgba(150,220,255,.32);transform:translateY(-2px)}\n.fader.live{border-color:var(--ac);box-shadow:inset 0 1px 0 rgba(190,235,255,.1),0 0 26px rgba(106,208,255,.28)}\n@keyframes rise{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}\n\n/* the glass tube + liquid */\n.tube{\n  position:relative;width:34px;flex:none;border-radius:16px;overflow:hidden;cursor:ns-resize;\n  touch-action:none;\n  background:linear-gradient(90deg,rgba(0,0,0,.4),rgba(40,70,95,.25) 40%,rgba(0,0,0,.4));\n  border:1px solid rgba(150,220,255,.2);\n  box-shadow:inset 0 2px 9px rgba(0,0,0,.6),inset -2px 0 4px rgba(190,235,255,.06);\n}\n.liquid{\n  position:absolute;left:0;right:0;bottom:0;height:50%;\n  background:linear-gradient(180deg,\n     color-mix(in srgb,var(--ac) 78%,#fff 0%),\n     color-mix(in srgb,var(--ac) 60%,var(--ac2)) 55%,\n     color-mix(in srgb,var(--ac2) 70%,#06121f) 100%);\n  box-shadow:0 -6px 18px color-mix(in srgb,var(--ac) 55%,transparent);\n  transition:height .12s cubic-bezier(.2,.8,.25,1);\n}\n/* animated wavy meniscus drawn with two offset svg waves */\n.surf{position:absolute;left:-25%;right:-25%;top:-9px;height:14px;pointer-events:none}\n.surf svg{width:100%;height:100%;display:block}\n.surf .w1{fill:color-mix(in srgb,var(--ac) 82%,#fff 18%);opacity:.95;\n  animation:swim 3.6s linear infinite}\n.surf .w2{fill:color-mix(in srgb,var(--ac) 55%,#fff);opacity:.5;\n  animation:swim 5.4s linear infinite reverse}\n@keyframes swim{from{transform:translateX(0)}to{transform:translateX(-25%)}}\n/* glass highlight */\n.tube::after{\n  content:\"\";position:absolute;top:4px;left:5px;width:6px;bottom:4px;border-radius:6px;\n  background:linear-gradient(180deg,rgba(255,255,255,.5),rgba(255,255,255,0));\n  opacity:.5;pointer-events:none;\n}\n/* rising bubbles inside the liquid */\n.tube .bub{position:absolute;bottom:6%;width:5px;height:5px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#fff,color-mix(in srgb,var(--ac) 70%,transparent));\n  opacity:0;pointer-events:none}\n.fader.live .bub{animation:fizz 2.2s ease-in infinite}\n.tube .b1{left:22%;animation-delay:.1s}\n.tube .b2{left:54%;animation-delay:.8s}\n.tube .b3{left:38%;animation-delay:1.5s}\n@keyframes fizz{\n  0%{opacity:0;transform:translateY(0) scale(.6)}\n  18%{opacity:.9}\n  100%{opacity:0;transform:translateY(-46px) scale(1)}\n}\n\n.flabel{flex:1;display:flex;flex-direction:column;justify-content:space-between;min-width:0}\n.flabel .nm{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:#a9d6ef;font-weight:700}\n.flabel .desc{font-size:10px;color:#6e9ab6;line-height:1.35;margin-top:3px}\n.flabel .val{\n  font-size:23px;font-weight:800;font-variant-numeric:tabular-nums;letter-spacing:.01em;\n  color:#eaf8ff;text-shadow:0 0 16px rgba(106,208,255,.4);margin-top:auto;\n}\n.flabel .val small{font-size:11px;font-weight:600;color:#7fb4d2;letter-spacing:.05em;margin-left:3px}\n\n/* ---- central TIDE POOL = Intensity (radial drag) ---------- */\n.pool{\n  position:relative;display:flex;flex-direction:column;align-items:center;gap:10px;\n  padding:14px 10px 12px;border-radius:22px;\n  background:radial-gradient(120% 120% at 50% 26%,rgba(120,200,240,.1),rgba(6,18,30,.5));\n  border:1px solid rgba(150,220,255,.16);\n  box-shadow:inset 0 2px 18px rgba(0,0,0,.5),0 10px 26px rgba(0,0,0,.3);\n  animation:rise .6s both;animation-delay:.12s;\n}\n.pool .nm{font-size:11px;letter-spacing:.2em;text-transform:uppercase;color:#a9d6ef;font-weight:700}\n.disc{\n  position:relative;width:154px;height:154px;border-radius:50%;cursor:grab;touch-action:none;\n  background:radial-gradient(circle at 50% 38%,#14384f,#061523 72%);\n  border:1px solid rgba(150,220,255,.2);\n  box-shadow:inset 0 6px 26px rgba(0,0,0,.66),inset 0 -3px 10px rgba(150,220,255,.06),0 0 0 6px rgba(106,208,255,.05);\n  overflow:hidden;\n}\n.disc.drag{cursor:grabbing}\n.disc svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}\n/* expanding ripple rings — frequency tied to intensity via animation-duration */\n.ring{\n  fill:none;stroke:var(--ac);stroke-width:1.4;transform-origin:50% 50%;\n  animation:ripple var(--rp,3.4s) ease-out infinite;\n}\n.ring.r2{stroke:var(--ac2);animation-delay:calc(var(--rp,3.4s) * .33)}\n.ring.r3{stroke:var(--foam);animation-delay:calc(var(--rp,3.4s) * .66);opacity:.7}\n@keyframes ripple{\n  0%{r:8px;opacity:.9;stroke-width:2.4}\n  100%{r:74px;opacity:0;stroke-width:.3}\n}\n/* doubled voice droplets orbiting — the \"ensemble\" */\n.voices{position:absolute;inset:0;animation:orbit var(--sp,9s) linear infinite}\n.voices.b{animation-direction:reverse;animation-duration:calc(var(--sp,9s) * 1.35)}\n@keyframes orbit{from{transform:rotate(0)}to{transform:rotate(360deg)}}\n.voice{position:absolute;top:8px;left:50%;width:11px;height:11px;margin-left:-5.5px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#fff,var(--ac));\n  box-shadow:0 0 12px var(--ac);}\n.voices.b .voice{background:radial-gradient(circle at 35% 30%,#fff,var(--ac2));box-shadow:0 0 12px var(--ac2)}\n/* core readout */\n.core{\n  position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);\n  display:flex;flex-direction:column;align-items:center;pointer-events:none;\n}\n.core b{font-size:30px;font-weight:800;font-variant-numeric:tabular-nums;color:#f1fbff;\n  text-shadow:0 0 20px rgba(106,208,255,.55)}\n.core span{font-size:9px;letter-spacing:.28em;text-transform:uppercase;color:#7fb4d2;margin-top:1px}\n.poolhint{font-size:10px;color:#6e9ab6;text-align:center;line-height:1.4;max-width:170px}\n\n/* ---- footer ----------------------------------------------- */\n.ft{\n  position:relative;z-index:2;margin:14px 22px 0;padding-top:12px;\n  border-top:1px solid rgba(150,220,255,.1);\n  font-size:11px;line-height:1.55;color:#6e9ab6;\n}\n.ft b{color:#a9d6ef;font-weight:700}\n</style>\n</head>\n<body>\n<div class=\"tank\">\n\n  <div class=\"cap\">\n    <div class=\"drop\">\n      <svg viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n        <defs>\n          <radialGradient id=\"dg\" cx=\"38%\" cy=\"30%\">\n            <stop offset=\"0\" stop-color=\"#eafaff\"/>\n            <stop offset=\"55%\" stop-color=\"var(--ac)\"/>\n            <stop offset=\"100%\" stop-color=\"var(--ac2)\"/>\n          </radialGradient>\n        </defs>\n        <path d=\"M12 1 C12 1 4 11 4 16 a8 8 0 0 0 16 0 C20 11 12 1 12 1Z\" fill=\"url(#dg)\">\n          <animateTransform attributeName=\"transform\" type=\"scale\" values=\"1;1.06;1\" dur=\"3.2s\" repeatCount=\"indefinite\" additive=\"sum\"/>\n        </path>\n        <ellipse cx=\"9.4\" cy=\"13\" rx=\"2\" ry=\"3\" fill=\"#fff\" opacity=\".55\"/>\n      </svg>\n    </div>\n    <div class=\"ttl\">\n      <h1>LUSH&nbsp;CHORUS</h1>\n      <p>liquid bucket-brigade ensemble</p>\n    </div>\n    <span class=\"tag\">5 voices</span>\n  </div>\n\n  <div class=\"body\">\n\n    <!-- LEFT BANK: Rate, Depth -->\n    <div class=\"bank\" id=\"bankL\"></div>\n\n    <!-- CENTER: Intensity tide pool -->\n    <div class=\"pool\">\n      <div class=\"nm\">Intensity</div>\n      <div class=\"disc\" id=\"disc\"\n           data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.4\">\n        <svg viewBox=\"0 0 154 154\" preserveAspectRatio=\"none\">\n          <g style=\"transform:translate(77px,77px)\">\n            <circle class=\"ring r1\" cx=\"0\" cy=\"0\"/>\n            <circle class=\"ring r2\" cx=\"0\" cy=\"0\"/>\n            <circle class=\"ring r3\" cx=\"0\" cy=\"0\"/>\n          </g>\n        </svg>\n        <div class=\"voices a\"><i class=\"voice\"></i></div>\n        <div class=\"voices b\"><i class=\"voice\"></i></div>\n        <div class=\"core\"><b id=\"iVal\">40</b><span>shimmer</span></div>\n      </div>\n      <div class=\"poolhint\">drag out for a deep fast ensemble — in for a subtle shimmer</div>\n    </div>\n\n    <!-- RIGHT BANK: Mix, Width -->\n    <div class=\"bank\" id=\"bankR\"></div>\n\n  </div>\n\n  <div class=\"ft\" id=\"ft\"></div>\n</div>\n\n<!-- a reusable fader template -->\n<template id=\"faderTpl\">\n  <div class=\"fader\" data-i=\"\" data-min=\"\" data-max=\"\" data-def=\"\">\n    <div class=\"tube\">\n      <div class=\"liquid\"></div>\n      <div class=\"surf\">\n        <svg viewBox=\"0 0 100 14\" preserveAspectRatio=\"none\">\n          <path class=\"w1\" d=\"M0 6 Q12 0 25 6 T50 6 T75 6 T100 6 V14 H0 Z\"/>\n          <path class=\"w2\" d=\"M0 7 Q12 13 25 7 T50 7 T75 7 T100 7 V14 H0 Z\"/>\n        </svg>\n      </div>\n      <i class=\"bub b1\"></i><i class=\"bub b2\"></i><i class=\"bub b3\"></i>\n    </div>\n    <div class=\"flabel\">\n      <div>\n        <div class=\"nm\"></div>\n        <div class=\"desc\"></div>\n      </div>\n      <div class=\"val\"><span class=\"num\">0</span><small></small></div>\n    </div>\n  </div>\n</template>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- per-param presentation (units / blurbs) ----\n  var META = {\n    0:{unit:\"Hz\",  desc:\"sweep speed of the modulated delay lines\", map:function(n){return (0.05+n*5.95);}},\n    1:{unit:\"%\",   desc:\"modulation depth of the bucket-brigade\",   map:function(n){return n*100;}},\n    2:{unit:\"%\",   desc:\"\",                                          map:function(n){return n*100;}},\n    3:{unit:\"%\",   desc:\"dry / wet balance of the ensemble\",        map:function(n){return n*100;}},\n    4:{unit:\"%\",   desc:\"stereo spread of the quadrature voices\",   map:function(n){return n*100;}}\n  };\n\n  function setParam(i,v){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(i,v); }\n  function clamp(n){ return n<0?0:(n>1?1:n); }\n  function fmtDisp(i,n){\n    var m=META[i]; var raw=m.map(n);\n    var d = (m.unit===\"Hz\") ? (raw<1?2:1) : 0;\n    return { num: raw.toFixed(d), unit: m.unit };\n  }\n\n  // ================= FADERS =================\n  function buildFader(p){\n    var tpl=document.getElementById('faderTpl').content.cloneNode(true);\n    var el=tpl.querySelector('.fader');\n    el.dataset.i=p.i; el.dataset.min=p.min; el.dataset.max=p.max; el.dataset.def=p.def;\n    el.querySelector('.nm').textContent=p.name;\n    el.querySelector('.desc').textContent=META[p.i].desc;\n    return el;\n  }\n\n  function wireFader(el){\n    var i=+el.dataset.i, mn=+el.dataset.min, mx=+el.dataset.max, def=+el.dataset.def;\n    var tube=el.querySelector('.tube'),\n        liquid=el.querySelector('.liquid'),\n        num=el.querySelector('.num'),\n        small=el.querySelector('small'),\n        surf=el.querySelector('.surf'),\n        w1=el.querySelector('.w1'), w2=el.querySelector('.w2');\n    var val=def, drag=false, startY=0, startN=0;\n\n    function norm(){ return (val-mn)/((mx-mn)||1); }\n    function paint(){\n      var n=norm();\n      liquid.style.height=(6+n*94)+'%';\n      surf.style.bottom='calc('+(6+n*94)+'% - 7px)';\n      // faster waves as Rate/Depth rise\n      var sp=(4.4 - n*2.6);\n      w1.style.animationDuration=sp+'s';\n      w2.style.animationDuration=(sp*1.5)+'s';\n      var disp=fmtDisp(i,n);\n      num.textContent=disp.num; small.textContent=disp.unit;\n      setParam(i,val);\n    }\n    function setN(n){ val=mn+(mx-mn)*clamp(n); paint(); }\n\n    surf.style.position='absolute';\n    surf.style.left='-25%'; surf.style.right='-25%';\n\n    tube.addEventListener('pointerdown',function(e){\n      drag=true; startY=e.clientY; startN=norm();\n      el.classList.add('live'); tube.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    tube.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      setN(startN + (startY-e.clientY)/170);\n    });\n    function end(){ drag=false; el.classList.remove('live'); }\n    tube.addEventListener('pointerup',end);\n    tube.addEventListener('pointercancel',end);\n    tube.addEventListener('dblclick',function(){ val=def; paint(); });\n    tube.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n\n    paint();\n  }\n\n  // ================= TIDE POOL (Intensity) =================\n  function wirePool(){\n    var disc=document.getElementById('disc');\n    var i=+disc.dataset.i, mn=+disc.dataset.min, mx=+disc.dataset.max, def=+disc.dataset.def;\n    var iVal=document.getElementById('iVal');\n    var rings=disc.querySelectorAll('.ring');\n    var voicesA=disc.querySelector('.voices.a'), voicesB=disc.querySelector('.voices.b');\n    var val=def, drag=false;\n\n    function norm(){ return (val-mn)/((mx-mn)||1); }\n    function paint(){\n      var n=norm();\n      iVal.textContent=Math.round(n*100);\n      // ripple cadence: subtle/slow shimmer -> fast deep ensemble\n      var rp=(4.4 - n*3.2)+'s';\n      for(var k=0;k<rings.length;k++) rings[k].style.setProperty('--rp',rp);\n      // orbit speed of doubled voices speeds up with intensity\n      var sp=(11 - n*8.4)+'s';\n      voicesA.style.setProperty('--sp',sp);\n      voicesB.style.setProperty('--sp',sp);\n      // disc glow swells\n      disc.style.boxShadow='inset 0 6px 26px rgba(0,0,0,.66),inset 0 -3px 10px rgba(150,220,255,.06),0 0 '+(4+n*34)+'px rgba(106,208,255,'+(0.12+n*0.4)+')';\n      setParam(i,val);\n    }\n    function setN(n){ val=mn+(mx-mn)*clamp(n); paint(); }\n\n    function fromEvent(e){\n      var r=disc.getBoundingClientRect();\n      var cx=r.left+r.width/2, cy=r.top+r.height/2;\n      var dx=e.clientX-cx, dy=e.clientY-cy;\n      var dist=Math.sqrt(dx*dx+dy*dy);\n      // radial: centre=0, edge=1\n      setN(dist/(r.width/2));\n    }\n    disc.addEventListener('pointerdown',function(e){\n      drag=true; disc.classList.add('drag'); disc.setPointerCapture(e.pointerId);\n      fromEvent(e); e.preventDefault();\n    });\n    disc.addEventListener('pointermove',function(e){ if(drag) fromEvent(e); });\n    function end(){ drag=false; disc.classList.remove('drag'); }\n    disc.addEventListener('pointerup',end);\n    disc.addEventListener('pointercancel',end);\n    disc.addEventListener('dblclick',function(){ val=def; paint(); });\n    disc.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n\n    paint();\n  }\n\n  // ================= READY =================\n  function ready(){\n    // bind by real spec index — Rate0 Depth1 Intensity2 Mix3 Width4\n    var FADERS=[\n      {i:0,name:\"Rate\",  min:0,max:1,def:0.35},\n      {i:1,name:\"Depth\", min:0,max:1,def:0.5 },\n      {i:3,name:\"Mix\",   min:0,max:1,def:0.5 },\n      {i:4,name:\"Width\", min:0,max:1,def:0.8 }\n    ];\n    var bankL=document.getElementById('bankL'), bankR=document.getElementById('bankR');\n    // left = Rate, Depth   right = Mix, Width\n    [FADERS[0],FADERS[1]].forEach(function(p,idx){ var f=buildFader(p); f.style.animationDelay=(0.1+idx*0.08)+'s'; bankL.appendChild(f); });\n    [FADERS[2],FADERS[3]].forEach(function(p,idx){ var f=buildFader(p); f.style.animationDelay=(0.18+idx*0.08)+'s'; bankR.appendChild(f); });\n\n    document.querySelectorAll('.fader').forEach(wireFader);\n    wirePool();\n\n    document.getElementById('ft').innerHTML =\n      '<b>Lush Chorus</b> — twin quadrature LFOs read interpolated delay lines into a wide, doubled image; a dark wet-path low-pass lends the soft analogue tone of a bucket-brigade.';\n  }\n\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  LUSH CHORUS — BBD-style stereo chorus\n//  Short modulated delay lines read with linear interpolation, driven by\n//  two LFOs in quadrature (L/R 90deg apart) for a wide stereo image. An\n//  Intensity/Mode control sweeps the classic subtle -> wide voicing by\n//  scaling both rate and depth. A gentle one-pole low-pass on the delayed\n//  signal mimics the dark, smeared tone of a bucket-brigade line. The dry\n//  path is summed for a thick, animated ensemble. Pure algorithm.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\n// Delay line: base ~1ms + up to ~7ms of sweep -> ~10ms headroom per channel.\n// At 96kHz that is ~960 samples; round up generously.\nconst DLINE: i32 = 2048;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// per-channel modulated delay buffers\nconst delayL: StaticArray<f32> = new StaticArray<f32>(DLINE);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(DLINE);\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\n\n// per-channel BBD-style low-pass state on the wet read\nconst lpState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// LFO phases (radians), one master phase; channels read it 90deg apart\nlet lfoPhase: f32 = 0.0;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst P_RATE: i32 = 0;      // 0..1 -> 0.05..6 Hz\nconst P_DEPTH: i32 = 1;     // 0..1 -> sweep amount\nconst P_INTENSITY: i32 = 2; // 0..1 -> subtle(I) .. wide(II); scales rate+depth+width\nconst P_MIX: i32 = 3;       // 0..1 dry/wet\nconst P_WIDTH: i32 = 4;     // 0..1 stereo spread of the two LFOs\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) { writePos[c] = 0; lpState[c] = 0.0; }\n  for (let i = 0; i < DLINE; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  lfoPhase = 0.0;\n  params[P_RATE] = 0.35;\n  params[P_DEPTH] = 0.5;\n  params[P_INTENSITY] = 0.4;\n  params[P_MIX] = 0.5;\n  params[P_WIDTH] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linearly interpolated read from a delay line, `delay` samples behind write\n@inline function readDelay(buf: StaticArray<f32>, writeIdx: i32, delay: f32): f32 {\n  let d: f32 = delay;\n  if (d < 0.0) d = 0.0;\n  const fd: f32 = f32(f32(writeIdx) - d);\n  // wrap into [0, DLINE)\n  let rp: f32 = fd;\n  while (rp < 0.0) rp += f32(DLINE);\n  const i0: i32 = i32(rp);\n  const frac: f32 = f32(rp - f32(i0));\n  let a: i32 = i0 % DLINE; if (a < 0) a += DLINE;\n  let b: i32 = a + 1; if (b >= DLINE) b -= DLINE;\n  return f32(buf[a] + (buf[b] - buf[a]) * frac);\n}\n\nexport function process(n: i32): void {\n  const rateN: f32 = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const inten: f32 = clampf(params[P_INTENSITY], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n\n  // Intensity sweeps the classic voicing: low = slow & shallow (mode I),\n  // high = faster & deeper (mode II). It biases both rate and depth.\n  const rateBase: f32 = f32(0.05 + rateN * 5.95);          // 0.05..6 Hz\n  const rateHz: f32 = f32(rateBase * (0.6 + inten * 0.9)); // intensity speeds it up\n  const lfoInc: f32 = f32(TWO_PI * rateHz / sampleRate);\n\n  // delay in ms: base ~1.2ms, sweep up to ~6.5ms scaled by depth & intensity\n  const baseMs: f32 = 1.2;\n  const sweepMs: f32 = f32((1.0 + depthN * 5.5) * (0.5 + inten * 0.8));\n  const baseSamp: f32 = f32(baseMs * 0.001 * sampleRate);\n  const sweepSamp: f32 = f32(sweepMs * 0.001 * sampleRate);\n\n  // stereo spread of the two channel LFOs (0 = mono, 1 = 90deg quadrature)\n  const phaseOffset: f32 = f32(widthN * (PI * 0.5));\n\n  // BBD low-pass coefficient (~6 kHz) — softens the wet path\n  const lpHz: f32 = 6000.0;\n  const lpC: f32 = f32(1.0 - Mathf.exp(f32(-TWO_PI * lpHz / sampleRate)));\n\n  // equal-ish wet/dry gain; keep peaks well under 1.0 on broadband beds\n  const dryG: f32 = f32(1.0 - mix * 0.5);\n  const wetG: f32 = f32(mix * 0.9);\n\n  let ph: f32 = lfoPhase;\n\n  for (let f = 0; f < n; f++) {\n    // advance master phase\n    ph += lfoInc;\n    if (ph >= TWO_PI) ph -= TWO_PI;\n\n    // per-channel LFO values in quadrature\n    const lfoL: f32 = f32(Mathf.sin(ph));\n    const lfoR: f32 = f32(Mathf.sin(f32(ph + phaseOffset)));\n\n    // ----- LEFT (channel 0) -----\n    {\n      const xL: f32 = inBuf[0 * MAX_FRAMES + f];\n      let wp: i32 = writePos[0];\n      delayL[wp] = xL;\n      const delSampL: f32 = f32(baseSamp + sweepSamp * 0.5 * (1.0 + lfoL));\n      let wetL: f32 = readDelay(delayL, wp, delSampL);\n      // BBD low-pass smear\n      let s: f32 = lpState[0];\n      s = f32(s + lpC * (wetL - s));\n      lpState[0] = s;\n      wetL = s;\n      outBuf[0 * MAX_FRAMES + f] = f32(xL * dryG + wetL * wetG);\n      wp++; if (wp >= DLINE) wp -= DLINE;\n      writePos[0] = wp;\n    }\n\n    // ----- RIGHT (channel 1) -----\n    if (channels > 1) {\n      const xR: f32 = inBuf[1 * MAX_FRAMES + f];\n      let wp: i32 = writePos[1];\n      delayR[wp] = xR;\n      const delSampR: f32 = f32(baseSamp + sweepSamp * 0.5 * (1.0 + lfoR));\n      let wetR: f32 = readDelay(delayR, wp, delSampR);\n      let s: f32 = lpState[1];\n      s = f32(s + lpC * (wetR - s));\n      lpState[1] = s;\n      wetR = s;\n      outBuf[1 * MAX_FRAMES + f] = f32(xR * dryG + wetR * wetG);\n      wp++; if (wp >= DLINE) wp -= DLINE;\n      writePos[1] = wp;\n    }\n  }\n\n  lfoPhase = ph;\n}\n",
  "publishedAt": 1751000011000
}