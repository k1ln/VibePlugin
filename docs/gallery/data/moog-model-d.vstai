{"format":1,"name":"Model D","isInstrument":true,"explanation":"A Minimoog-style monophonic synthesizer: three anti-aliased oscillators with per-osc octave and detune, a noise source, the classic four-pole resonant ladder filter with drive, independent filter and amplifier ADSR envelopes, and portamento glide. Play it with the keyboard, your computer keys (a–k), or MIDI.","params":[{"name":"Tune","index":0,"min":-12,"max":12,"default":0,"value":0},{"name":"Glide","index":1,"min":0,"max":1,"default":0.05,"value":0.05},{"name":"Osc1 Wave","index":2,"min":0,"max":3,"default":1,"value":1},{"name":"Osc1 Oct","index":3,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Wave","index":4,"min":0,"max":3,"default":1,"value":1},{"name":"Osc2 Oct","index":5,"min":-2,"max":2,"default":0,"value":0},{"name":"Osc2 Detune","index":6,"min":-50,"max":50,"default":7,"value":7},{"name":"Osc3 Wave","index":7,"min":0,"max":3,"default":2,"value":2},{"name":"Osc3 Oct","index":8,"min":-2,"max":2,"default":-1,"value":-1},{"name":"Osc3 Detune","index":9,"min":-50,"max":50,"default":-5,"value":-5},{"name":"Mix Osc1","index":10,"min":0,"max":1,"default":0.9,"value":0.9},{"name":"Mix Osc2","index":11,"min":0,"max":1,"default":0.7,"value":0.7},{"name":"Mix Osc3","index":12,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Noise","index":13,"min":0,"max":1,"default":0.06,"value":0.06},{"name":"Cutoff","index":14,"min":0,"max":1,"default":0.42,"value":0.42},{"name":"Resonance","index":15,"min":0,"max":1,"default":0.55,"value":0.55},{"name":"Filter Env","index":16,"min":0,"max":1,"default":0.6,"value":0.6},{"name":"Filt Atk","index":17,"min":0,"max":1,"default":0.04,"value":0.04},{"name":"Filt Dec","index":18,"min":0,"max":1,"default":0.5,"value":0.5},{"name":"Filt Sus","index":19,"min":0,"max":1,"default":0.25,"value":0.25},{"name":"Filt Rel","index":20,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Atk","index":21,"min":0,"max":1,"default":0.02,"value":0.02},{"name":"Amp Dec","index":22,"min":0,"max":1,"default":0.4,"value":0.4},{"name":"Amp Sus","index":23,"min":0,"max":1,"default":0.8,"value":0.8},{"name":"Amp Rel","index":24,"min":0,"max":1,"default":0.35,"value":0.35},{"name":"Drive","index":25,"min":0,"max":1,"default":0.3,"value":0.3},{"name":"Volume","index":26,"min":0,"max":1,"default":0.8,"value":0.8}],"wasmBase64":"","html":"<!doctype html><html><head><meta charset=\"utf-8\">\n<style>\n  :root{ --panel:#1b1714; --panel2:#241e19; --metal:#d8c9a8; --ink:#2a2118; --amber:#ffb23e;\n         --line:#3a302600; --wood:#5a3a22; }\n  *{box-sizing:border-box}\n  body{margin:0;font:12px ui-sans-serif,system-ui,\"Segoe UI\",sans-serif;color:#eadfce;\n    background:\n      linear-gradient(90deg,var(--wood) 0 14px,#0000 14px calc(100% - 14px),var(--wood) calc(100% - 14px) 100%),\n      radial-gradient(120% 140% at 50% -20%,#2c2620,#16110d 70%);\n    padding:14px 22px 18px;user-select:none;-webkit-user-select:none}\n  h2{font:700 13px ui-sans-serif;letter-spacing:.18em;margin:0 0 10px;color:var(--amber);\n    text-transform:uppercase;display:flex;align-items:center;gap:10px}\n  h2 small{color:#9b8e78;font-weight:600;letter-spacing:.16em}\n  .rack{display:flex;gap:12px;flex-wrap:wrap}\n  .sect{background:linear-gradient(180deg,var(--panel2),var(--panel));border:1px solid #00000060;\n    border-top:1px solid #ffffff10;border-radius:10px;padding:10px 12px 12px;box-shadow:0 6px 18px #0007 inset,0 1px 0 #ffffff08}\n  .sect h3{font:700 10px ui-sans-serif;letter-spacing:.16em;color:#bfb39a;margin:0 0 10px;text-transform:uppercase}\n  .row{display:flex;gap:14px;flex-wrap:wrap;align-items:flex-start}\n  .knob{width:60px;display:flex;flex-direction:column;align-items:center;gap:5px}\n  .dial{width:48px;height:48px;border-radius:50%;cursor:ns-resize;position:relative;\n    background:radial-gradient(60% 60% at 38% 32%,#4a4036,#211b15 70%,#120d09);\n    border:1px solid #000;box-shadow:0 2px 5px #000a,0 1px 0 #ffffff12 inset}\n  .dial::after{content:\"\";position:absolute;left:50%;top:5px;width:2px;height:16px;border-radius:2px;\n    background:var(--amber);transform-origin:50% 19px;transform:translateX(-50%) rotate(var(--rot,-135deg));\n    box-shadow:0 0 6px var(--amber)}\n  .knob label{font:600 9px ui-sans-serif;letter-spacing:.08em;color:#cdc0a8;text-align:center}\n  .knob .val{font:600 9px ui-monospace,monospace;color:#9b8e78}\n  .waves{display:flex;gap:3px;margin-bottom:4px}\n  .waves button{flex:1;background:#171210;border:1px solid #000;color:#9b8e78;border-radius:5px;\n    padding:5px 0;cursor:pointer;font:700 12px ui-monospace}\n  .waves button.on{color:var(--ink);background:linear-gradient(180deg,#ffc662,var(--amber));border-color:#b5781f}\n  .oscname{font:600 9px ui-sans-serif;letter-spacing:.1em;color:#bfb39a;margin-bottom:5px}\n</style></head>\n<body>\n  <h2>Model&nbsp;D <small>· monophonic analog synthesizer</small></h2>\n  <div class=\"rack\" id=\"rack\"></div>\n\n<script>\n// param index → control spec. wave selectors get type:'wave'.\nconst OSC = (n, wIdx, octIdx, detIdx) => ({ type:'osc', name:n, wIdx, octIdx, detIdx });\nconst K = (label, idx, min, max, def, unit, step) => ({ type:'knob', label, idx, min, max, def, unit, step });\n\nconst SECTIONS = [\n  { h:'Oscillator Bank', items:[ OSC('OSC 1',2,3,null), OSC('OSC 2',4,5,6), OSC('OSC 3',7,8,9) ] },\n  { h:'Mixer', items:[ K('Osc 1',10,0,1,0.9), K('Osc 2',11,0,1,0.7), K('Osc 3',12,0,1,0.5), K('Noise',13,0,1,0.06) ] },\n  { h:'Filter — Ladder', items:[ K('Cutoff',14,0,1,0.42), K('Reso',15,0,1,0.55), K('Env',16,0,1,0.6),\n      K('Atk',17,0,1,0.04), K('Dec',18,0,1,0.5), K('Sus',19,0,1,0.25), K('Rel',20,0,1,0.4) ] },\n  { h:'Loudness & Glide', items:[ K('Atk',21,0,1,0.02), K('Dec',22,0,1,0.4), K('Sus',23,0,1,0.8), K('Rel',24,0,1,0.35),\n      K('Drive',25,0,1,0.3), K('Glide',1,0,1,0.05), K('Tune',0,-12,12,0,'st',1), K('Volume',26,0,1,0.8) ] },\n];\nconst WAVES = ['◺','◹','⊓','⊔'];   // tri, saw, square, pulse glyphs\n\nfunction setP(i,v){ if(window.vstai) window.vstai.setParam(i, v); }\n\nfunction knob(spec){\n  const wrap=document.createElement('div'); wrap.className='knob';\n  const dial=document.createElement('div'); dial.className='dial';\n  const lab=document.createElement('label'); lab.textContent=spec.label;\n  const val=document.createElement('div'); val.className='val';\n  wrap.append(dial,lab,val);\n  let v=spec.def;\n  const snap=(x)=> spec.step? Math.round(x/spec.step)*spec.step : x;\n  function apply(send){\n    v=Math.max(spec.min,Math.min(spec.max,snap(v)));\n    const t=(v-spec.min)/(spec.max-spec.min);\n    dial.style.setProperty('--rot',(-135+t*270)+'deg');\n    val.textContent = spec.unit==='st'? (v>0?'+':'')+v.toFixed(0)+'st'\n      : spec.step? v.toFixed(0) : v.toFixed(2);\n    if(send) setP(spec.idx, v);\n  }\n  let dragging=false, lastY=0;\n  const down=(e)=>{ dragging=true; lastY=(e.touches?e.touches[0].clientY:e.clientY); e.preventDefault(); };\n  const move=(e)=>{ if(!dragging)return; const y=(e.touches?e.touches[0].clientY:e.clientY);\n    v += (lastY-y)*(spec.max-spec.min)/180; lastY=y; apply(true); };\n  const up=()=>dragging=false;\n  dial.addEventListener('mousedown',down); dial.addEventListener('touchstart',move,{passive:false});\n  dial.addEventListener('touchstart',down,{passive:false});\n  window.addEventListener('mousemove',move); window.addEventListener('touchmove',move,{passive:false});\n  window.addEventListener('mouseup',up); window.addEventListener('touchend',up);\n  dial.addEventListener('dblclick',()=>{ v=spec.def; apply(true); });\n  apply(true);\n  return wrap;\n}\n\nfunction osc(spec){\n  const col=document.createElement('div');\n  const name=document.createElement('div'); name.className='oscname'; name.textContent=spec.name;\n  const waves=document.createElement('div'); waves.className='waves';\n  const btns=WAVES.map((g,wi)=>{ const b=document.createElement('button'); b.textContent=g;\n    b.onclick=()=>{ setP(spec.wIdx,wi); btns.forEach(x=>x.classList.remove('on')); b.classList.add('on'); }; return b; });\n  // default selection: read sensible defaults (osc1 saw, osc2 saw, osc3 square)\n  const def = spec.wIdx===7?2:1; btns[def].classList.add('on'); setP(spec.wIdx,def);\n  waves.append(...btns);\n  const row=document.createElement('div'); row.className='row';\n  row.append(knob(K('Oct',spec.octIdx,-2,2, spec.octIdx===8?-1:0, '', 1)));\n  if(spec.detIdx!=null) row.append(knob(K('Detune',spec.detIdx,-50,50, spec.detIdx===9?-5:7)));\n  col.append(name,waves,row);\n  return col;\n}\n\nconst rack=document.getElementById('rack');\nfor(const s of SECTIONS){\n  const sect=document.createElement('div'); sect.className='sect';\n  const h=document.createElement('h3'); h.textContent=s.h; sect.append(h);\n  const row=document.createElement('div'); row.className='row';\n  for(const it of s.items) row.append(it.type==='osc'? osc(it) : knob(it));\n  sect.append(row); rack.append(sect);\n}\n</script>\n</body></html>\n","publishedAt":1750000002000}