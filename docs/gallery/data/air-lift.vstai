{
  "format": 1,
  "name": "Air Lift",
  "isInstrument": false,
  "explanation": "An air-band shelving EQ: the silky high-shelf specialist. A gentle, wide AIR high shelf opens and brightens the very top without harshness, with a selectable corner that climbs up into the highs (2.5k / 5k / 10k / 20k / 40k). Beneath it sit a musical LOW shelf and a broad MID bell, plus an OUTPUT trim. All bands are clean, stable biquads — boost-only air with a soft slope so the top lifts instead of spiking. Controls: Air, Air Freq, Low, Mid and Output.",
  "params": [
    {
      "name": "Air",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Air Freq",
      "index": 1,
      "min": 0,
      "max": 4,
      "default": 2
    },
    {
      "name": "Low",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mid",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Air Lift</title>\n<style>\n  :root{\n    --accent:#8fdcff;\n    --accent2:#cdebff;\n    --ink:#10202c;\n    --face:#f3fafe;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;}\n  html,body{height:100%;}\n  body{\n    font-family:'Helvetica Neue',Helvetica,Arial,sans-serif;\n    background:\n      radial-gradient(140% 90% at 50% -10%, #ffffff 0%, #eaf6ff 38%, #d6ecfb 72%, #c3e2f7 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100%;\n    overflow:hidden;\n  }\n\n  /* ===== faceplate ===== */\n  .plate{\n    position:relative;\n    width:560px;\n    border-radius:22px;\n    padding:22px 26px 26px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,.95), rgba(232,246,255,.92));\n    box-shadow:\n      0 24px 60px -20px rgba(40,90,130,.45),\n      0 2px 0 rgba(255,255,255,.9) inset,\n      0 -1px 0 rgba(120,170,200,.25) inset;\n    border:1px solid rgba(180,215,235,.7);\n    overflow:hidden;\n  }\n  /* sparkle field */\n  .sparkles{position:absolute;inset:0;pointer-events:none;z-index:0;}\n  .spk{\n    position:absolute;width:3px;height:3px;border-radius:50%;\n    background:radial-gradient(circle,#fff 0%, var(--accent) 60%, transparent 70%);\n    opacity:0;\n    animation:twinkle 4.5s ease-in-out infinite;\n    filter:drop-shadow(0 0 4px var(--accent));\n  }\n  @keyframes twinkle{\n    0%,100%{opacity:0;transform:scale(.4);}\n    45%{opacity:.9;transform:scale(1.25);}\n    60%{opacity:.5;transform:scale(.9);}\n  }\n\n  .head{position:relative;z-index:2;display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:14px;}\n  .brand{display:flex;align-items:center;gap:12px;}\n  .logo{\n    width:38px;height:38px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #ffffff, var(--accent) 55%, #5fbfe6 100%);\n    box-shadow:0 0 18px rgba(143,220,255,.9), 0 2px 4px rgba(0,0,0,.12);\n    position:relative;\n  }\n  .logo::after{\n    content:\"\";position:absolute;inset:6px;border-radius:50%;\n    border:1.5px solid rgba(255,255,255,.85);\n    animation:halo 3.2s ease-in-out infinite;\n  }\n  @keyframes halo{0%,100%{transform:scale(.7);opacity:.3;}50%{transform:scale(1.15);opacity:.9;}}\n  .title{font-size:26px;font-weight:800;letter-spacing:2px;\n    background:linear-gradient(90deg,#2b6b8f,#5cc0ea,#2b6b8f);\n    -webkit-background-clip:text;background-clip:text;color:transparent;}\n  .sub{font-size:10px;letter-spacing:4px;color:#6fa6c5;text-transform:uppercase;margin-top:1px;}\n\n  /* ===== response graph ===== */\n  .graph{\n    position:relative;z-index:2;\n    height:160px;border-radius:14px;\n    background:\n      linear-gradient(180deg, rgba(255,255,255,.6), rgba(214,238,252,.55));\n    border:1px solid rgba(170,210,235,.7);\n    box-shadow:inset 0 2px 10px rgba(120,170,200,.18);\n    overflow:hidden;margin-bottom:20px;\n  }\n  .graph svg{position:absolute;inset:0;width:100%;height:100%;}\n  .grid line{stroke:rgba(120,170,200,.18);stroke-width:1;}\n  .zeroline{stroke:rgba(90,150,185,.4);stroke-width:1;stroke-dasharray:4 4;}\n  .curveFill{fill:url(#airgrad);opacity:.55;}\n  .curve{fill:none;stroke:url(#stroke);stroke-width:2.4;\n    filter:drop-shadow(0 0 6px rgba(143,220,255,.9));}\n  .scanlbl{font-size:8px;fill:#6fa6c5;letter-spacing:1px;}\n  /* drifting air shimmer band at the very top */\n  .airband{\n    position:absolute;top:0;left:0;right:0;height:46px;pointer-events:none;\n    background:linear-gradient(90deg,\n      transparent, rgba(205,235,255,.0) 20%, rgba(255,255,255,.6) 50%, rgba(205,235,255,0) 80%, transparent);\n    mix-blend-mode:screen;\n    animation:drift 6s linear infinite;\n  }\n  @keyframes drift{0%{transform:translateX(-60%);}100%{transform:translateX(60%);}}\n\n  /* ===== controls ===== */\n  .controls{position:relative;z-index:2;display:flex;align-items:flex-start;justify-content:space-between;gap:8px;}\n  .ctl{display:flex;flex-direction:column;align-items:center;flex:1;}\n  .knobwrap{position:relative;width:78px;height:78px;cursor:ns-resize;}\n  .knob{\n    width:78px;height:78px;border-radius:50%;\n    background:\n      radial-gradient(circle at 38% 32%, #ffffff, #e3f3ff 45%, #bfe2f6 100%);\n    box-shadow:\n      0 6px 14px -4px rgba(60,120,160,.5),\n      0 1px 0 rgba(255,255,255,.9) inset,\n      0 -3px 8px rgba(120,170,200,.25) inset;\n    position:relative;transition:box-shadow .15s;\n  }\n  .knobwrap:hover .knob{box-shadow:\n      0 6px 18px -3px rgba(60,120,160,.6),\n      0 0 16px rgba(143,220,255,.7),\n      0 1px 0 rgba(255,255,255,.95) inset;}\n  .knob::after{\n    content:\"\";position:absolute;left:50%;top:9px;width:3px;height:22px;\n    border-radius:2px;background:linear-gradient(var(--accent),#3aa0cf);\n    transform:translateX(-50%);transform-origin:50% 30px;\n    box-shadow:0 0 6px rgba(143,220,255,.9);\n  }\n  .ring{position:absolute;inset:-6px;}\n  .ring circle{fill:none;stroke-width:3;stroke-linecap:round;}\n  .ringbg{stroke:rgba(150,200,225,.3);}\n  .ringfg{stroke:url(#ringgrad);filter:drop-shadow(0 0 4px rgba(143,220,255,.9));}\n  .lbl{font-size:11px;font-weight:700;letter-spacing:1px;color:#3a7794;margin-top:9px;text-transform:uppercase;}\n  .val{font-size:11px;color:#5a93b3;margin-top:2px;font-variant-numeric:tabular-nums;}\n\n  /* discrete air-freq selector */\n  .selwrap{display:flex;flex-direction:column;align-items:center;flex:1;}\n  .seldial{\n    width:78px;height:78px;border-radius:50%;cursor:ns-resize;position:relative;\n    background:\n      radial-gradient(circle at 38% 32%, #ffffff, #e3f3ff 45%, #bfe2f6 100%);\n    box-shadow:\n      0 6px 14px -4px rgba(60,120,160,.5),\n      0 1px 0 rgba(255,255,255,.9) inset;\n    display:flex;align-items:center;justify-content:center;\n    transition:box-shadow .15s;\n  }\n  .selwrap:hover .seldial{box-shadow:0 0 16px rgba(143,220,255,.7),0 1px 0 rgba(255,255,255,.95) inset;}\n  .seldial .freq{font-size:15px;font-weight:800;color:#2b6b8f;text-shadow:0 0 6px rgba(143,220,255,.6);}\n  .dots{position:absolute;inset:0;}\n  .dots span{position:absolute;width:5px;height:5px;border-radius:50%;\n    background:rgba(150,200,225,.4);left:50%;top:50%;transform-origin:0 0;}\n  .dots span.on{background:var(--accent);box-shadow:0 0 6px var(--accent);}\n</style>\n</head>\n<body>\n  <div class=\"plate\">\n    <div class=\"sparkles\" id=\"sparkles\"></div>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"logo\"></div>\n        <div>\n          <div class=\"title\">AIR LIFT</div>\n          <div class=\"sub\">Air-Band Shelving EQ</div>\n        </div>\n      </div>\n      <div class=\"sub\" style=\"text-align:right\">silky&nbsp;·&nbsp;open&nbsp;·&nbsp;clean</div>\n    </div>\n\n    <div class=\"graph\">\n      <div class=\"airband\"></div>\n      <svg viewBox=\"0 0 520 160\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"airgrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#cdebff\" stop-opacity=\".9\"/>\n            <stop offset=\"100%\" stop-color=\"#8fdcff\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <linearGradient id=\"stroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n            <stop offset=\"0%\" stop-color=\"#5cc0ea\"/>\n            <stop offset=\"55%\" stop-color=\"#8fdcff\"/>\n            <stop offset=\"100%\" stop-color=\"#ffffff\"/>\n          </linearGradient>\n          <linearGradient id=\"ringgrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#8fdcff\"/>\n            <stop offset=\"100%\" stop-color=\"#cdebff\"/>\n          </linearGradient>\n        </defs>\n        <g class=\"grid\" id=\"grid\"></g>\n        <line class=\"zeroline\" id=\"zero\" x1=\"0\" y1=\"80\" x2=\"520\" y2=\"80\"/>\n        <path class=\"curveFill\" id=\"fill\"></path>\n        <path class=\"curve\" id=\"curve\"></path>\n        <text class=\"scanlbl\" x=\"6\" y=\"153\">20Hz</text>\n        <text class=\"scanlbl\" x=\"250\" y=\"153\">1kHz</text>\n        <text class=\"scanlbl\" x=\"468\" y=\"153\">20kHz</text>\n      </svg>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match assembly.ts + spec.json) ----\n  var PARAMS = [\n    { i:0, key:\"air\",  name:\"Air\",      min:0, max:1, def:0.45, kind:\"knob\" },\n    { i:1, key:\"freq\", name:\"Air Freq\", min:0, max:4, def:2,    kind:\"sel\", step:1 },\n    { i:2, key:\"low\",  name:\"Low\",      min:0, max:1, def:0.5,  kind:\"knob\" },\n    { i:3, key:\"mid\",  name:\"Mid\",      min:0, max:1, def:0.5,  kind:\"knob\" },\n    { i:4, key:\"out\",  name:\"Output\",   min:0, max:1, def:0.5,  kind:\"knob\" }\n  ];\n  var FREQS = [2500,5000,10000,20000,40000];\n  var FREQ_LBL = [\"2.5k\",\"5k\",\"10k\",\"20k\",\"40k\"];\n\n  var state = {}; // key -> raw value\n  PARAMS.forEach(function(p){ state[p.key]=p.def; });\n\n  function send(p, val){\n    if(window.vstai && window.vstai.setParam){ window.vstai.setParam(p.i, val); }\n  }\n\n  // ---------- response-curve math (display only, mirrors the DSP shape) ----\n  // map x in 0..1 (log freq 20..20k) -> magnitude in dB\n  function dbToA(db){ return Math.pow(10, db/20); }\n  function freqAt(t){ return 20*Math.pow(1000, t); } // 20 .. 20000\n\n  // simple shelf/bell magnitude approximations for the picture\n  function shelfHi(f, fc, gainDb){\n    var g = dbToA(gainDb);\n    var r = f/fc;\n    // smooth transition; reaches full gain well above fc\n    var t = 1/(1+Math.pow(fc/(f+1e-9), 1.4));\n    return 1 + (g-1)*t;\n  }\n  function shelfLo(f, fc, gainDb){\n    var g = dbToA(gainDb);\n    var t = 1/(1+Math.pow((f+1e-9)/fc, 1.4));\n    return 1 + (g-1)*t;\n  }\n  function bell(f, fc, gainDb, q){\n    var g = dbToA(gainDb);\n    var bw = fc/q;\n    var x = (f-fc)/bw;\n    var shape = 1/(1+x*x);\n    return 1 + (g-1)*shape;\n  }\n\n  function computeMag(f){\n    var airDb = state.air*14;\n    var lowDb = (state.low-0.5)*24;\n    var midDb = (state.mid-0.5)*24;\n    var fc = FREQS[Math.round(state.freq)];\n    var m = 1;\n    m *= shelfLo(f, 120, lowDb);\n    m *= bell(f, 900, midDb, 0.9);\n    m *= shelfHi(f, fc, airDb);\n    return 20*Math.log10(Math.max(1e-4, m));\n  }\n\n  var curve = document.getElementById(\"curve\");\n  var fill  = document.getElementById(\"fill\");\n  var W=520, H=160, MID=80, SCALE=4.2; // px per dB\n\n  function drawCurve(){\n    var d=\"\", df=\"M0,\"+H+\" \";\n    for(var px=0; px<=W; px+=4){\n      var t=px/W;\n      var f=freqAt(t);\n      var db=computeMag(f);\n      var y=MID - db*SCALE;\n      if(y<2)y=2; if(y>H-2)y=H-2;\n      d += (px===0?\"M\":\"L\")+px+\",\"+y.toFixed(1)+\" \";\n      df += \"L\"+px+\",\"+y.toFixed(1)+\" \";\n    }\n    df += \"L\"+W+\",\"+H+\" Z\";\n    curve.setAttribute(\"d\", d);\n    fill.setAttribute(\"d\", df);\n  }\n\n  // grid\n  (function(){\n    var g=document.getElementById(\"grid\"), s=\"\";\n    for(var i=1;i<6;i++){var x=i*(W/6);s+='<line x1=\"'+x+'\" y1=\"0\" x2=\"'+x+'\" y2=\"'+H+'\"/>';}\n    for(var j=1;j<4;j++){var y=j*(H/4);s+='<line x1=\"0\" y1=\"'+y+'\" x2=\"'+W+'\" y2=\"'+y+'\"/>';}\n    g.innerHTML=s;\n  })();\n\n  // ---------- sparkles (denser near the air band / top) ----\n  (function(){\n    var host=document.getElementById(\"sparkles\");\n    for(var i=0;i<26;i++){\n      var s=document.createElement(\"div\");\n      s.className=\"spk\";\n      s.style.left=(Math.random()*100)+\"%\";\n      s.style.top=(Math.pow(Math.random(),1.8)*70)+\"%\"; // bias toward top\n      s.style.animationDelay=(Math.random()*4.5)+\"s\";\n      s.style.animationDuration=(3.5+Math.random()*3)+\"s\";\n      host.appendChild(s);\n    }\n  })();\n\n  // ---------- build controls ----\n  var host=document.getElementById(\"controls\");\n\n  function valLabel(p){\n    if(p.kind===\"sel\"){ return FREQ_LBL[Math.round(state[p.key])]+\"Hz\"; }\n    if(p.key===\"air\"){ return \"+\"+(state.air*14).toFixed(1)+\" dB\"; }\n    if(p.key===\"out\"){\n      var g=state.out<=0.5?state.out*2:1+(state.out-0.5)*2;\n      var db=20*Math.log10(Math.max(1e-4,g));\n      return (db>=0?\"+\":\"\")+db.toFixed(1)+\" dB\";\n    }\n    // low / mid bipolar\n    var d=(state[p.key]-0.5)*24;\n    return (d>=0?\"+\":\"\")+d.toFixed(1)+\" dB\";\n  }\n\n  function makeKnob(p){\n    var wrap=document.createElement(\"div\"); wrap.className=\"ctl\";\n    var kw=document.createElement(\"div\"); kw.className=\"knobwrap\";\n    kw.innerHTML=\n      '<svg class=\"ring\" viewBox=\"0 0 90 90\">'+\n      '<circle class=\"ringbg\" cx=\"45\" cy=\"45\" r=\"40\"/>'+\n      '<circle class=\"ringfg\" cx=\"45\" cy=\"45\" r=\"40\"/></svg>'+\n      '<div class=\"knob\"></div>';\n    var knob=kw.querySelector(\".knob\");\n    var ringfg=kw.querySelector(\".ringfg\");\n    var lbl=document.createElement(\"div\"); lbl.className=\"lbl\"; lbl.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    wrap.appendChild(kw); wrap.appendChild(lbl); wrap.appendChild(val);\n\n    var R=40, C=2*Math.PI*R, ARC=0.75; // 270deg sweep\n    ringfg.style.strokeDasharray=C;\n\n    function paint(){\n      var n=(state[p.key]-p.min)/(p.max-p.min);\n      var ang=-135 + n*270;\n      knob.style.setProperty(\"--a\", ang);\n      knob.querySelector || 0;\n      knob.style.transform=\"rotate(\"+ang+\"deg)\";\n      var dash=C*(1-n*ARC);\n      ringfg.style.strokeDashoffset=dash;\n      ringfg.setAttribute(\"transform\",\"rotate(135 45 45)\");\n      val.textContent=valLabel(p);\n    }\n\n    function setN(n){\n      n=Math.max(0,Math.min(1,n));\n      state[p.key]=p.min+(p.max-p.min)*n;\n      send(p, state[p.key]);\n      paint(); drawCurve();\n    }\n\n    var dragging=false, lastY=0;\n    kw.addEventListener(\"mousedown\",function(e){\n      dragging=true; lastY=e.clientY; e.preventDefault();\n    });\n    window.addEventListener(\"mousemove\",function(e){\n      if(!dragging)return;\n      var dy=lastY-e.clientY; lastY=e.clientY;\n      var n=(state[p.key]-p.min)/(p.max-p.min);\n      setN(n + dy/180);\n    });\n    window.addEventListener(\"mouseup\",function(){dragging=false;});\n    kw.addEventListener(\"dblclick\",function(){\n      state[p.key]=p.def; send(p,state[p.key]); paint(); drawCurve();\n    });\n    kw.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      var n=(state[p.key]-p.min)/(p.max-p.min);\n      setN(n - Math.sign(e.deltaY)*0.04);\n    },{passive:false});\n\n    paint();\n    return wrap;\n  }\n\n  function makeSelector(p){\n    var wrap=document.createElement(\"div\"); wrap.className=\"selwrap\";\n    var dial=document.createElement(\"div\"); dial.className=\"seldial\";\n    var freq=document.createElement(\"div\"); freq.className=\"freq\";\n    var dots=document.createElement(\"div\"); dots.className=\"dots\";\n    dial.appendChild(freq); dial.appendChild(dots);\n    var lbl=document.createElement(\"div\"); lbl.className=\"lbl\"; lbl.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    wrap.appendChild(dial); wrap.appendChild(lbl); wrap.appendChild(val);\n\n    // place 5 dots around top arc\n    for(var k=0;k<5;k++){\n      var sp=document.createElement(\"span\");\n      var a=(-110 + k*55)*Math.PI/180;\n      var r=30;\n      sp.style.transform=\"translate(\"+(Math.cos(a)*r)+\"px,\"+(Math.sin(a)*r)+\"px)\";\n      dots.appendChild(sp);\n    }\n\n    function paint(){\n      var idx=Math.round(state[p.key]);\n      freq.textContent=FREQ_LBL[idx];\n      val.textContent=\"corner\";\n      var sps=dots.querySelectorAll(\"span\");\n      for(var k=0;k<sps.length;k++){ sps[k].className = (k<=idx)?\"on\":\"\"; }\n    }\n    function setIdx(idx){\n      idx=Math.max(0,Math.min(4,idx));\n      state[p.key]=idx; send(p,idx); paint(); drawCurve();\n    }\n\n    var dragging=false, acc=0, lastY=0;\n    dial.addEventListener(\"mousedown\",function(e){dragging=true;lastY=e.clientY;acc=0;e.preventDefault();});\n    window.addEventListener(\"mousemove\",function(e){\n      if(!dragging)return;\n      acc += (lastY-e.clientY); lastY=e.clientY;\n      if(Math.abs(acc)>=26){\n        var step=acc>0?1:-1; acc=0;\n        setIdx(Math.round(state[p.key])+step);\n      }\n    });\n    window.addEventListener(\"mouseup\",function(){dragging=false;});\n    dial.addEventListener(\"dblclick\",function(){ setIdx(p.def); });\n    dial.addEventListener(\"wheel\",function(e){\n      e.preventDefault();\n      setIdx(Math.round(state[p.key]) - Math.sign(e.deltaY));\n    },{passive:false});\n\n    paint();\n    return wrap;\n  }\n\n  PARAMS.forEach(function(p){\n    host.appendChild(p.kind===\"sel\" ? makeSelector(p) : makeKnob(p));\n  });\n\n  function init(){\n    // push every default to the host on load\n    PARAMS.forEach(function(p){ send(p, state[p.key]); });\n    drawCurve();\n  }\n\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(init); else init();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  AIR LIFT — air-band shelving EQ, the silky high-shelf specialist\n//  A clean mastering-grade tilt EQ centred on a very-high \"AIR\" band: a\n//  gentle, WIDE high shelf whose corner can be pushed up into the very top\n//  octaves so it opens and brightens air without any harshness. Beneath it\n//  sit a musical LOW SHELF and a broad MID BELL, plus an OUTPUT trim. All\n//  bands are stable RBJ biquads in Direct-Form I, run in pure f32, with a\n//  deliberately soft shelf slope so the air \"lifts\" rather than spikes.\n//  Pure algorithm, no samples. No allocation in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- parameter indices (must match spec.json + the GUI) --------------\nconst P_AIR:      i32 = 0; // 0..1  -> air high-shelf gain   0..+14 dB\nconst P_AIR_FREQ: i32 = 1; // 0..4  -> air corner selector: 2.5k/5k/10k/20k/40k\nconst P_LOW:      i32 = 2; // 0..1  -> low shelf            -12..+12 dB (corner ~120 Hz)\nconst P_MID:      i32 = 3; // 0..1  -> broad mid bell        -12..+12 dB (~900 Hz, wide)\nconst P_OUTPUT:   i32 = 4; // 0..1  -> output trim           ~ -inf..+6 dB (0.5 = unity)\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- per-channel Direct-Form I biquad state (x1,x2,y1,y2) ----\n// three cascaded bands: 0 = low shelf, 1 = mid bell, 2 = air high shelf\nconst lsX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst lsY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst mdX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst arX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst arX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst arY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst arY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// ---- shared coefficient registers (recomputed once per process block) ----\nlet ls_b0: f32 = 1.0; let ls_b1: f32 = 0.0; let ls_b2: f32 = 0.0;\nlet ls_a1: f32 = 0.0; let ls_a2: f32 = 0.0;\n\nlet md_b0: f32 = 1.0; let md_b1: f32 = 0.0; let md_b2: f32 = 0.0;\nlet md_a1: f32 = 0.0; let md_a2: f32 = 0.0;\n\nlet ar_b0: f32 = 1.0; let ar_b1: f32 = 0.0; let ar_b2: f32 = 0.0;\nlet ar_a1: f32 = 0.0; let ar_a2: f32 = 0.0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lsX1[c] = 0.0; lsX2[c] = 0.0; lsY1[c] = 0.0; lsY2[c] = 0.0;\n    mdX1[c] = 0.0; mdX2[c] = 0.0; mdY1[c] = 0.0; mdY2[c] = 0.0;\n    arX1[c] = 0.0; arX2[c] = 0.0; arY1[c] = 0.0; arY2[c] = 0.0;\n  }\n  params[P_AIR]      = 0.45; // a touch of air\n  params[P_AIR_FREQ] = 2.0;  // 10 kHz corner (the classic air seat)\n  params[P_LOW]      = 0.5;  // flat\n  params[P_MID]      = 0.5;  // flat\n  params[P_OUTPUT]   = 0.5;  // unity\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// dB -> linear amplitude\n@inline function dbToGain(db: f32): f32 {\n  return f32(Mathf.exp(db * 0.11512925)); // ln(10)/20\n}\n\n// ---- coefficient builders (RBJ cookbook, normalised by a0) -----------\n// shelfS controls slope: smaller S = gentler / wider shelf (more \"open\").\nfunction computeLowShelf(f0: f32, dbGain: f32, shelfS: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / shelfS - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) - (A - 1.0) * cw + tsa);\n  const b1: f32 =  2.0 * A * ((A - 1.0) - (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) - (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) + (A - 1.0) * cw + tsa;\n  const a1: f32 = -2.0 *    ((A - 1.0) + (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) + (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  ls_b0 = b0 * inv; ls_b1 = b1 * inv; ls_b2 = b2 * inv;\n  ls_a1 = a1 * inv; ls_a2 = a2 * inv;\n}\n\nfunction computeMidBell(f0: f32, dbGain: f32, q: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw / (2.0 * q);\n\n  const b0: f32 = 1.0 + alpha * A;\n  const b1: f32 = -2.0 * cw;\n  const b2: f32 = 1.0 - alpha * A;\n  const a0: f32 = 1.0 + alpha / A;\n  const a1: f32 = -2.0 * cw;\n  const a2: f32 = 1.0 - alpha / A;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  md_b0 = b0 * inv; md_b1 = b1 * inv; md_b2 = b2 * inv;\n  md_a1 = a1 * inv; md_a2 = a2 * inv;\n}\n\nfunction computeHighShelf(f0: f32, dbGain: f32, shelfS: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / shelfS - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) + (A - 1.0) * cw + tsa);\n  const b1: f32 = -2.0 * A * ((A - 1.0) + (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) + (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) - (A - 1.0) * cw + tsa;\n  const a1: f32 =  2.0 *    ((A - 1.0) - (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) - (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  ar_b0 = b0 * inv; ar_b1 = b1 * inv; ar_b2 = b2 * inv;\n  ar_a1 = a1 * inv; ar_a2 = a2 * inv;\n}\n\nexport function process(n: i32): void {\n  // --- map params to musical ranges -----------------------------------\n  // Air is a boost-only silky high shelf: 0 .. +14 dB.\n  const airDb:  f32 = clampf(params[P_AIR], 0.0, 1.0) * 14.0;\n  // Low / Mid are bipolar: -12 .. +12 dB (0.5 = flat).\n  const lowDb:  f32 = (clampf(params[P_LOW], 0.0, 1.0) - 0.5) * 24.0;\n  const midDb:  f32 = (clampf(params[P_MID], 0.0, 1.0) - 0.5) * 24.0;\n  const outN:   f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n\n  // Air-frequency selector: discrete classic corners up into the highs.\n  // 0=2.5k 1=5k 2=10k 3=20k 4=40k. The two top seats are above audio range,\n  // so the shelf's wide skirt reaches DOWN into the air band — exactly the\n  // \"open the top, no spike\" behaviour of an air-band EQ.\n  let sel: i32 = i32(params[P_AIR_FREQ] + 0.5);\n  if (sel < 0) sel = 0;\n  if (sel > 4) sel = 4;\n  let airHz: f32 = 10000.0;\n  if (sel == 0) airHz = 2500.0;\n  else if (sel == 1) airHz = 5000.0;\n  else if (sel == 2) airHz = 10000.0;\n  else if (sel == 3) airHz = 20000.0;\n  else airHz = 40000.0;\n\n  // Keep every corner safely below Nyquist so the biquad stays stable.\n  const nyq: f32 = sampleRate * 0.49;\n  if (airHz > nyq) airHz = nyq;\n\n  // Fixed musical corners for the other bands.\n  let lowHz: f32 = 120.0;\n  let midHz: f32 = 900.0;\n  if (lowHz < 20.0) lowHz = 20.0;\n  if (midHz > nyq) midHz = nyq;\n\n  // Output trim: 0.5 -> unity, 1 -> +6 dB, 0 -> silence.\n  const outGain: f32 = outN <= 0.5\n    ? outN * 2.0\n    : 1.0 + (outN - 0.5) * 2.0; // up to 2.0x (~+6 dB)\n\n  // Wide, gentle shelves so the air \"lifts\" instead of spiking; broad bell.\n  computeLowShelf(lowHz, lowDb, 0.55);\n  computeMidBell(midHz, midDb, 0.5);   // broad bell (Q ~0.5)\n  computeHighShelf(airHz, airDb, 0.45); // very gentle, wide air shelf\n\n  // Headroom trim so simultaneous big boosts stay below ~1.0 peak.\n  const headroom: f32 = 0.9;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n\n    let lx1: f32 = lsX1[c]; let lx2: f32 = lsX2[c]; let ly1: f32 = lsY1[c]; let ly2: f32 = lsY2[c];\n    let mx1: f32 = mdX1[c]; let mx2: f32 = mdX2[c]; let my1: f32 = mdY1[c]; let my2: f32 = mdY2[c];\n    let hx1: f32 = arX1[c]; let hx2: f32 = arX2[c]; let hy1: f32 = arY1[c]; let hy2: f32 = arY2[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // low shelf\n      let y: f32 = ls_b0 * x + ls_b1 * lx1 + ls_b2 * lx2 - ls_a1 * ly1 - ls_a2 * ly2;\n      lx2 = lx1; lx1 = x; ly2 = ly1; ly1 = y;\n\n      // mid bell\n      const mIn: f32 = y;\n      let ym: f32 = md_b0 * mIn + md_b1 * mx1 + md_b2 * mx2 - md_a1 * my1 - md_a2 * my2;\n      mx2 = mx1; mx1 = mIn; my2 = my1; my1 = ym;\n\n      // air high shelf\n      const hIn: f32 = ym;\n      let yh: f32 = ar_b0 * hIn + ar_b1 * hx1 + ar_b2 * hx2 - ar_a1 * hy1 - ar_a2 * hy2;\n      hx2 = hx1; hx1 = hIn; hy2 = hy1; hy1 = yh;\n\n      // clean output: trim + headroom, hard-bounded so it never clips past 1.\n      const o: f32 = yh * outGain * headroom;\n      outBuf[base + f] = clampf(o, -1.0, 1.0);\n    }\n\n    lsX1[c] = lx1; lsX2[c] = lx2; lsY1[c] = ly1; lsY2[c] = ly2;\n    mdX1[c] = mx1; mdX2[c] = mx2; mdY1[c] = my1; mdY2[c] = my2;\n    arX1[c] = hx1; arX2[c] = hx2; arY1[c] = hy1; arY2[c] = hy2;\n  }\n}\n",
  "publishedAt": 1751000092000
}