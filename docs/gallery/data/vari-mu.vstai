{
  "format": 1,
  "name": "Vari-Mu",
  "isInstrument": false,
  "explanation": "A program-dependent variable-mu tube compressor. As the input pushes harder above the threshold, the gain-reduction tube bends progressively more, so a loud signal is squeezed harder than a quiet one (a soft, rising-ratio knee with no fixed ratio). A slow, level-dependent attack feeds a dual time-constant release for a gentle, natural recovery, and subtle even-order valve harmonics add warmth. Controls: Input, Threshold, Time Constant and Output.",
  "params": [
    {
      "name": "Input",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Threshold",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Time Constant",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Output",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --ac:#ffcf6b;        /* warm amber accent */\n  --ac2:#ff9e6b;       /* orange ember      */\n  --face:#3b2c20;      /* faceplate brown   */\n  --face2:#241913;\n  --brass:#caa24a;\n  --ink:#1a110a;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px \"Times New Roman\",Georgia,ui-serif,serif;\n  color:#f4e4c4;\n  background:\n    radial-gradient(130% 100% at 50% -15%,#3a2a1c 0%,#1a120c 55%,#0a0705 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:22px;overflow:hidden;\n}\n\n/* ===== broadcast chassis ===== */\n.unit{\n  position:relative;\n  width:560px;\n  border-radius:14px;\n  padding:20px 26px 24px;\n  background:\n    linear-gradient(168deg,#4a382a 0%,var(--face) 34%,var(--face2) 100%);\n  box-shadow:\n    0 46px 90px -22px rgba(0,0,0,.8),\n    0 2px 0 rgba(255,230,180,.10) inset,\n    0 -26px 50px -20px rgba(0,0,0,.6) inset,\n    0 0 0 2px #160d07,\n    0 0 0 7px #2a1d12,\n    0 0 0 9px rgba(202,162,74,.35);\n  animation:rise .8s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(28px) scale(.97)}to{opacity:1;transform:none}}\n/* hammered-metal micro texture + top sheen */\n.unit::before{\n  content:\"\";position:absolute;inset:0;border-radius:14px;pointer-events:none;\n  background:\n    repeating-linear-gradient(122deg,rgba(255,255,255,.03) 0 1px,transparent 1px 4px),\n    radial-gradient(150% 60% at 28% -5%,rgba(255,235,190,.14),transparent 55%);\n  mix-blend-mode:screen;opacity:.7;border-radius:14px;\n}\n/* brass corner rivets */\n.rivet{position:absolute;width:15px;height:15px;border-radius:50%;\n  background:radial-gradient(circle at 36% 30%,#ffe7a8,var(--brass) 52%,#6e521d 92%);\n  box-shadow:0 1px 3px rgba(0,0,0,.7),0 0 0 1px rgba(0,0,0,.35) inset,0 0 6px rgba(255,205,107,.3);}\n.rivet.tl{top:11px;left:11px}.rivet.tr{top:11px;right:11px}\n.rivet.bl{bottom:11px;left:11px}.rivet.br{bottom:11px;right:11px}\n\n/* ===== header / brass nameplate ===== */\n.head{position:relative;text-align:center;margin:2px 0 16px}\n.brand{font-size:9px;letter-spacing:.5em;color:#d8b876;opacity:.8;text-transform:uppercase;font-family:ui-sans-serif,system-ui,sans-serif}\nh1{\n  margin:4px 0 0;font-size:30px;font-weight:700;letter-spacing:.06em;line-height:1;\n  font-variant:small-caps;\n  background:linear-gradient(180deg,#fff3d4,var(--ac) 48%,#b8801f);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  filter:drop-shadow(0 2px 5px rgba(60,30,0,.6));\n}\n.sub{font-size:8.5px;letter-spacing:.34em;color:#cfa86a;opacity:.7;text-transform:uppercase;margin-top:5px;font-family:ui-sans-serif,system-ui,sans-serif}\n\n/* ===== top instrument row: tubes + VU meters ===== */\n.top{display:flex;align-items:stretch;justify-content:center;gap:18px;margin:0 4px 18px}\n\n/* glowing vacuum tubes */\n.tubes{display:flex;gap:14px;align-items:flex-end;padding:6px 2px 0}\n.tube{position:relative;width:42px;height:118px}\n.glass{position:absolute;inset:0;border-radius:21px 21px 16px 16px;\n  background:\n    linear-gradient(180deg,rgba(255,245,220,.20),rgba(120,90,50,.08) 40%,rgba(40,26,14,.5));\n  box-shadow:0 0 0 1px rgba(255,225,170,.18) inset,0 6px 14px rgba(0,0,0,.5);\n  overflow:hidden;backdrop-filter:blur(1px);}\n/* the hot filament / plate glow */\n.filament{position:absolute;left:50%;bottom:14px;width:8px;height:74px;margin-left:-4px;border-radius:4px;\n  background:linear-gradient(180deg,#ffd98a,var(--ac2) 60%,#c0521a);\n  box-shadow:0 0 16px 5px var(--ac),0 0 34px 12px rgba(255,158,107,.55);\n  animation:flicker 2.6s ease-in-out infinite;transform-origin:bottom}\n.tube:nth-child(2) .filament{animation-delay:.7s;animation-duration:3.1s}\n@keyframes flicker{\n  0%,100%{opacity:.85;transform:scaleY(1)}\n  18%{opacity:1;transform:scaleY(1.03)}\n  42%{opacity:.78;transform:scaleY(.985)}\n  63%{opacity:.97;transform:scaleY(1.02)}\n  80%{opacity:.82}\n}\n/* internal grid mesh */\n.grid{position:absolute;left:9px;right:9px;top:22px;bottom:20px;border-radius:6px;\n  background:repeating-linear-gradient(0deg,rgba(0,0,0,.35) 0 1px,transparent 1px 5px);\n  opacity:.4}\n/* glass specular highlight */\n.glass::after{content:\"\";position:absolute;top:6px;left:7px;width:11px;height:60px;border-radius:8px;\n  background:linear-gradient(180deg,rgba(255,255,255,.5),transparent);filter:blur(1px);opacity:.6}\n/* socket base */\n.socket{position:absolute;bottom:-7px;left:50%;width:48px;height:18px;margin-left:-24px;border-radius:5px;\n  background:linear-gradient(180deg,#2a2018,#0e0a06);box-shadow:0 4px 8px rgba(0,0,0,.6),0 1px 0 rgba(255,220,160,.12) inset}\n.tlabel{position:absolute;bottom:-22px;left:0;right:0;text-align:center;font-size:7px;letter-spacing:.18em;\n  color:#caa24a;opacity:.7;font-family:ui-sans-serif,system-ui,sans-serif}\n\n/* backlit VU meter */\n.vuwrap{position:relative;width:212px;height:120px;border-radius:10px;\n  background:radial-gradient(120% 130% at 50% 8%,#fff4d6 0%,#f3dca2 45%,#cda85f 100%);\n  box-shadow:0 0 0 2px #1a110a,0 0 0 5px rgba(202,162,74,.4),\n    inset 0 3px 10px rgba(120,70,20,.4),inset 0 -8px 18px rgba(80,40,10,.3),\n    0 0 24px rgba(255,200,110,.12);\n  overflow:hidden}\n.vuwrap::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:linear-gradient(180deg,rgba(255,255,255,.45),transparent 28%);}\n.vuwrap svg{position:absolute;inset:0;width:100%;height:100%}\n.vutitle{position:absolute;top:6px;left:0;right:0;text-align:center;font-size:7.5px;letter-spacing:.28em;\n  color:#7a4f1c;opacity:.85;font-family:ui-sans-serif,system-ui,sans-serif}\n.needle{transform-origin:106px 118px;transition:transform .09s cubic-bezier(.3,.7,.3,1)}\n.glasshine{fill:rgba(255,255,255,.06)}\n\n/* ===== knob deck ===== */\n.deck{display:grid;grid-template-columns:repeat(4,1fr);gap:6px 8px;margin:4px 6px 2px}\n.pot{display:flex;flex-direction:column;align-items:center;gap:8px;\n  animation:pop .55s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:88px;height:88px;cursor:ns-resize;touch-action:none;user-select:none}\n/* tick skirt */\n.skirt{position:absolute;inset:-4px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(255,225,170,.6) 0 1deg,transparent 1deg 11.25deg);\n  -webkit-mask:radial-gradient(circle,transparent 44px,#000 45px,#000 48px,transparent 49px);\n  mask:radial-gradient(circle,transparent 44px,#000 45px,#000 48px,transparent 49px)}\n/* glowing value arc */\n.arc{position:absolute;inset:2px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac2),var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.05) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*9px) var(--ac));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1)}\n/* bakelite cap */\n.cap{position:absolute;top:12px;left:12px;width:64px;height:64px;border-radius:50%;\n  background:\n    radial-gradient(circle at 50% 26%,#5a4634 0%,#2c2016 58%,#15100a 100%);\n  box-shadow:\n    inset 0 2px 6px rgba(255,225,170,.16),\n    inset 0 -7px 16px rgba(0,0,0,.85),\n    0 5px 12px rgba(0,0,0,.6);\n}\n.cap::before{content:\"\";position:absolute;inset:7px;border-radius:50%;\n  background:repeating-conic-gradient(#33271b 0 10deg,#1a130c 10deg 20deg);opacity:.45}\n.cap::after{content:\"\";position:absolute;inset:16px;border-radius:50%;\n  background:radial-gradient(circle at 50% 28%,#6b5236,#1d150d);\n  box-shadow:inset 0 1px 2px rgba(255,225,170,.22)}\n/* brass pointer */\n.ptr{position:absolute;top:7px;left:50%;width:5px;height:24px;margin-left:-2.5px;border-radius:3px;\n  background:linear-gradient(var(--ac),var(--ac2));\n  box-shadow:0 0 9px var(--ac),0 0 2px #fff;\n  transform-origin:50% 37px;\n  transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.pname{font-size:9.5px;font-weight:700;letter-spacing:.14em;color:#1a110a;\n  background:linear-gradient(var(--ac),var(--ac2));padding:3px 11px;border-radius:999px;\n  text-transform:uppercase;box-shadow:0 1px 0 rgba(255,255,255,.35) inset,0 2px 5px rgba(0,0,0,.45);\n  font-family:ui-sans-serif,system-ui,sans-serif;white-space:nowrap}\n.pval{font-size:12px;font-weight:700;color:#ffe6b8;font-variant-numeric:tabular-nums;\n  min-height:14px;text-shadow:0 0 9px rgba(255,158,107,.5);font-family:ui-sans-serif,system-ui,sans-serif}\n.knob.act .cap{box-shadow:inset 0 2px 6px rgba(255,225,170,.16),inset 0 -7px 16px rgba(0,0,0,.85),0 5px 16px rgba(255,158,107,.55)}\n\n/* ===== footer plate ===== */\n.foot{display:flex;align-items:center;justify-content:space-between;margin:16px 8px 0;\n  font-family:ui-sans-serif,system-ui,sans-serif}\n.serial{font-size:7.5px;letter-spacing:.22em;color:#caa24a;opacity:.55}\n.power{display:flex;align-items:center;gap:7px;font-size:8px;letter-spacing:.2em;color:#cfa86a;opacity:.75;text-transform:uppercase}\n.pled{width:11px;height:11px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#fff0cf,var(--ac) 45%,#7a3d10 92%);\n  box-shadow:0 0 12px var(--ac),0 0 4px #fff inset;animation:pwr 2.4s ease-in-out infinite}\n@keyframes pwr{0%,100%{box-shadow:0 0 7px var(--ac),0 0 4px #fff inset;opacity:.85}50%{box-shadow:0 0 16px var(--ac),0 0 6px #fff inset;opacity:1}}\n</style>\n</head>\n<body>\n<div class=\"unit\">\n  <span class=\"rivet tl\"></span><span class=\"rivet tr\"></span>\n  <span class=\"rivet bl\"></span><span class=\"rivet br\"></span>\n\n  <div class=\"head\">\n    <div class=\"brand\">Broadcast Valve Series</div>\n    <h1>Vari-Mu</h1>\n    <div class=\"sub\">Program-Dependent Tube Compressor</div>\n  </div>\n\n  <div class=\"top\">\n    <!-- two glowing vacuum tubes -->\n    <div class=\"tubes\">\n      <div class=\"tube\">\n        <div class=\"glass\"><span class=\"grid\"></span><span class=\"filament\"></span></div>\n        <span class=\"socket\"></span><span class=\"tlabel\">V1</span>\n      </div>\n      <div class=\"tube\">\n        <div class=\"glass\"><span class=\"grid\"></span><span class=\"filament\"></span></div>\n        <span class=\"socket\"></span><span class=\"tlabel\">V2</span>\n      </div>\n    </div>\n\n    <!-- backlit VU meter (gain reduction) -->\n    <div class=\"vuwrap\">\n      <div class=\"vutitle\">GAIN REDUCTION — VU</div>\n      <svg viewBox=\"0 0 212 120\" preserveAspectRatio=\"none\">\n        <!-- arc scale -->\n        <path d=\"M22 96 A92 92 0 0 1 190 96\" fill=\"none\" stroke=\"#7a4f1c\" stroke-width=\"1.4\" opacity=\".6\"/>\n        <path id=\"redarc\" d=\"M120 36 A92 92 0 0 1 190 96\" fill=\"none\" stroke=\"var(--ac2)\" stroke-width=\"3\" opacity=\".8\"/>\n        <!-- ticks -->\n        <g id=\"ticks\" stroke=\"#7a4f1c\" stroke-width=\"1.4\"></g>\n        <text x=\"34\" y=\"60\" font-size=\"8\" fill=\"#7a4f1c\" font-family=\"sans-serif\">0</text>\n        <text x=\"100\" y=\"34\" font-size=\"8\" fill=\"#7a4f1c\" font-family=\"sans-serif\">-3</text>\n        <text x=\"170\" y=\"60\" font-size=\"8\" fill=\"#b8801f\" font-family=\"sans-serif\" font-weight=\"bold\">-10</text>\n        <!-- needle -->\n        <line class=\"needle\" id=\"needle\" x1=\"106\" y1=\"118\" x2=\"106\" y2=\"34\"\n              stroke=\"#2a1a0a\" stroke-width=\"2.4\" stroke-linecap=\"round\"/>\n        <circle cx=\"106\" cy=\"118\" r=\"6\" fill=\"#2a1a0a\" stroke=\"var(--brass)\" stroke-width=\"1.5\"/>\n        <ellipse class=\"glasshine\" cx=\"80\" cy=\"36\" rx=\"70\" ry=\"20\"/>\n      </svg>\n    </div>\n\n    <!-- mirror tubes for symmetry -->\n    <div class=\"tubes\">\n      <div class=\"tube\">\n        <div class=\"glass\"><span class=\"grid\"></span><span class=\"filament\"></span></div>\n        <span class=\"socket\"></span><span class=\"tlabel\">V3</span>\n      </div>\n      <div class=\"tube\">\n        <div class=\"glass\"><span class=\"grid\"></span><span class=\"filament\"></span></div>\n        <span class=\"socket\"></span><span class=\"tlabel\">V4</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"deck\" id=\"deck\"></div>\n\n  <div class=\"foot\">\n    <div class=\"serial\">VM-670 &middot; S/N 8P7SXGP62N</div>\n    <div class=\"power\"><span class=\"pled\"></span>Heaters On</div>\n  </div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Input\",         index:0,min:0,max:1,def:0.5},\n    {name:\"Threshold\",     index:1,min:0,max:1,def:0.5},\n    {name:\"Time Constant\", index:2,min:0,max:1,def:0.4},\n    {name:\"Output\",        index:3,min:0,max:1,def:0.5}\n  ];\n  var state={};\n  var deck=document.getElementById('deck');\n  var needle=document.getElementById('needle');\n\n  function pct(v){ return Math.round(v*100)+\"%\"; }\n\n  // draw VU ticks\n  (function(){\n    var g=document.getElementById('ticks');\n    for(var i=0;i<=10;i++){\n      var a=Math.PI*(1 - i/10);           // 180..0 deg\n      var cx=106, cy=118, r1=84, r2=92;\n      var x1=cx+Math.cos(a)*r1, y1=cy-Math.sin(a)*r1;\n      var x2=cx+Math.cos(a)*r2, y2=cy-Math.sin(a)*r2;\n      var ln=document.createElementNS('http://www.w3.org/2000/svg','line');\n      ln.setAttribute('x1',x1.toFixed(1));ln.setAttribute('y1',y1.toFixed(1));\n      ln.setAttribute('x2',x2.toFixed(1));ln.setAttribute('y2',y2.toFixed(1));\n      if(i>=7){ln.setAttribute('stroke','#b8801f');ln.setAttribute('stroke-width','2');}\n      g.appendChild(ln);\n    }\n  })();\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*75)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"skirt\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var ptr=cell.querySelector('.ptr');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var n=norm();\n      arc.style.setProperty('--n',n);\n      ptr.style.setProperty('--n',n);\n      val.textContent=pct(n);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(n){ n=n<0?0:n>1?1:n; v=p.min+(p.max-p.min)*n; paint(); }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true;startY=e.clientY;startN=norm();\n      knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?700:230;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){drag=false;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){v=p.def;paint();});\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ---- swaying VU needle: estimate gain reduction from Input vs Threshold ----\n  var targetGR=0, curGR=0;\n  function onChange(){\n    var inp=state[0]!=null?state[0]:0.5;\n    var th =state[1]!=null?state[1]:0.5;\n    // more input + lower threshold => more reduction (0..1)\n    var amount=Math.max(0,(inp*0.9+0.1)-(th*0.85));\n    targetGR=Math.min(1,amount*1.4);\n  }\n\n  // continuous animation loop: needle sways toward target with valve drift\n  var t=0;\n  function loop(){\n    t+=0.05;\n    var tmN=state[2]!=null?state[2]:0.4;\n    // slower time-constant => slower, lazier needle motion\n    var ease=0.04+(1-tmN)*0.10;\n    curGR+=(targetGR-curGR)*ease;\n    // gentle program-dependent sway (breathing) on top\n    var sway=curGR*(0.10*Math.sin(t*1.7)+0.04*Math.sin(t*0.6));\n    var g=Math.max(0,Math.min(1,curGR+sway));\n    // map 0..1 reduction to needle angle: rest=-45deg (left), full=+45deg (right)\n    var deg=-45+g*90;\n    needle.setAttribute('transform','rotate('+deg.toFixed(2)+' 106 118)');\n    requestAnimationFrame(loop);\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ onChange(); requestAnimationFrame(loop); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VARI-MU — program-dependent variable-mu tube compressor\n//  Models the smooth, rising-ratio behaviour of a classic vari-mu valve\n//  limiter: the more the input level exceeds the threshold, the more the\n//  gain reduction tube \"bends\", so loud signals are squeezed harder than\n//  quiet ones (a soft, progressive knee with no fixed ratio). A slow,\n//  level-dependent attack and a DUAL time-constant release (a fast first\n//  stage feeding a slow tail) give the characteristic gentle recovery,\n//  and a touch of even-order tube harmonics adds valve warmth.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// envelope state: fast detector stage + slow release tail (shared sidechain,\n// stereo-linked so the image doesn't wander), plus a DC blocker per channel.\nlet envFast: f32 = 0.0;\nlet envSlow: f32 = 0.0;\nconst dcX: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst dcY: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_INPUT: i32 = 0;   // 0..1 -> input drive into the tube (gain)\nconst P_THRESH: i32 = 1;  // 0..1 -> threshold (high=less compression)\nconst P_TIME: i32 = 2;    // 0..1 -> time-constant pair (attack+release scale)\nconst P_OUTPUT: i32 = 3;  // 0..1 -> make-up / output trim\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  envFast = 0.0;\n  envSlow = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) { dcX[c] = 0.0; dcY[c] = 0.0; }\n  params[P_INPUT] = 0.5;\n  params[P_THRESH] = 0.5;\n  params[P_TIME] = 0.4;\n  params[P_OUTPUT] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  // ---- map params -------------------------------------------------\n  const inN: f32 = clampf(params[P_INPUT], 0.0, 1.0);\n  const thN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const tmN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const outN: f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n\n  // Input drive into the tube: 0.25x .. 4x (the harder we push, the more\n  // the program-dependent knee bites).\n  const inGain: f32 = f32(0.25) * f32(Mathf.pow(16.0, inN));\n  // Threshold in linear amplitude: 0.04 (squeeze a lot) .. 0.9 (barely).\n  const thresh: f32 = f32(0.04) + thN * f32(0.86);\n\n  // Time-constant pair. Vari-mu attack is slow; here ~3..40 ms. Release is\n  // dual-stage: a fast first coefficient and a much slower tail.\n  const atkMs: f32 = f32(3.0) + tmN * f32(37.0);\n  const relFastMs: f32 = f32(60.0) + tmN * f32(240.0);\n  const relSlowMs: f32 = f32(400.0) + tmN * f32(2600.0);\n  const atkC: f32  = f32(Mathf.exp(-1.0 / (f32(0.001) * atkMs * sampleRate)));\n  const relF: f32  = f32(Mathf.exp(-1.0 / (f32(0.001) * relFastMs * sampleRate)));\n  const relS: f32  = f32(Mathf.exp(-1.0 / (f32(0.001) * relSlowMs * sampleRate)));\n\n  // DC blocker pole.\n  const dcR: f32 = f32(0.999);\n\n  // Output make-up trim: 0.5x .. 2x. Slight bias toward unity so a loud\n  // squeezed signal stays bounded (peak < ~1.0).\n  const outGain: f32 = f32(0.5) * f32(Mathf.pow(4.0, outN));\n\n  let eF: f32 = envFast;\n  let eS: f32 = envSlow;\n\n  for (let f = 0; f < n; f++) {\n    // ---- stereo-linked detector (max of |L|,|R| after input drive) ----\n    let detect: f32 = 0.0;\n    for (let c = 0; c < channels; c++) {\n      const a: f32 = f32(Mathf.abs(inBuf[c * MAX_FRAMES + f] * inGain));\n      if (a > detect) detect = a;\n    }\n\n    // Fast envelope: slow attack (charge), fast release (first stage).\n    if (detect > eF) eF = atkC * eF + (f32(1.0) - atkC) * detect;\n    else             eF = relF * eF + (f32(1.0) - relF) * detect;\n    // Slow tail follows the fast stage -> dual time-constant recovery.\n    if (eF > eS) eS = atkC * eS + (f32(1.0) - atkC) * eF;\n    else         eS = relS * eS + (f32(1.0) - relS) * eF;\n\n    // Effective control envelope = blend of fast + slow stages.\n    const env: f32 = f32(0.55) * eF + f32(0.45) * eS;\n\n    // ---- program-dependent rising-ratio gain computer ----------------\n    // over = how far the envelope sits above threshold (in \"tube units\").\n    // We compute reduction as a smooth, bounded function whose local slope\n    // (ratio) GROWS with level: gentle near threshold, firmer when loud.\n    let gr: f32 = 1.0; // gain (1 = no reduction)\n    if (env > thresh) {\n      const over: f32 = env / thresh;                 // >1 when above thresh\n      const x: f32 = f32(Mathf.log(over));             // natural-log overshoot\n      // soft rising-ratio curve: reduction in log domain grows ~quadratically\n      // for small overshoot then is bounded by a tanh so it never collapses.\n      const bend: f32 = x + f32(0.6) * x * x;          // accelerating knee\n      const shaped: f32 = f32(2.4) * f32(Mathf.tanh(bend * f32(0.45)));\n      gr = f32(Mathf.exp(-shaped));                    // <1, bounded > ~0.09\n    }\n\n    // ---- apply gain reduction + gentle even-order tube warmth ---------\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      const driven: f32 = inBuf[base + f] * inGain;\n      let y: f32 = driven * gr;\n      // soft tube transfer: a small 2nd-harmonic bias + tanh saturation that\n      // only acts on the loud peaks (warmth, keeps peaks < ~1.0).\n      const warm: f32 = y + f32(0.08) * y * y;         // even-order asymmetry\n      y = f32(Mathf.tanh(warm * f32(0.9))) * f32(1.0526);\n      // DC blocker (removes the bias offset from the even-order term).\n      const yb: f32 = y - dcX[c] + dcR * dcY[c];\n      dcX[c] = y;\n      dcY[c] = yb;\n      outBuf[base + f] = clampf(yb * outGain, -1.0, 1.0);\n    }\n  }\n\n  envFast = eF;\n  envSlow = eS;\n}\n",
  "publishedAt": 1751000057000
}