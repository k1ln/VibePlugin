{
  "format": 1,
  "name": "Thrift Poly",
  "isInstrument": true,
  "explanation": "A lovable lo-fi eight-voice paraphonic synthesizer in the budget-classic tradition. Each voice is a DCO blending saw and square with a square sub an octave down, but all voices share ONE resonant low-pass filter and ONE envelope — so sweeping the Cutoff makes whole chords gurgle and breathe together, the signature paraphonic behaviour. A built-in stereo chorus adds width and a touch of wobble, while the gritty soft-clipped output keeps things charming rather than hi-fi. Controls: Cutoff, Resonance, Env Amount, Sub, Chorus, Release and Level.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "EnvAmount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Sub",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Chorus",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Thrift Poly</title>\n<style>\n  :root{\n    --mint:#5ad0a0;\n    --amber:#ffd24a;\n    --panel:#23262a;\n    --panel2:#1a1c1f;\n    --char:#2c3035;\n    --ink:#0c0d0e;\n    --lcd:#0a1410;\n    --lcdtxt:#7dffc4;\n    --label:#9aa3a0;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;}\n  html,body{height:100%;}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:radial-gradient(120% 120% at 30% -10%, #34383d 0%, #1c1e21 55%, #131416 100%);\n    color:var(--label);\n    display:flex;align-items:center;justify-content:center;\n    padding:14px;\n    -webkit-user-select:none;user-select:none;\n    overflow:hidden;\n  }\n  .unit{\n    width:680px;max-width:100%;\n    background:\n      linear-gradient(180deg,#2b2f34 0%, #24272b 8%, #202326 100%);\n    border-radius:14px;\n    padding:18px 20px 22px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.06) inset,\n      0 -2px 0 rgba(0,0,0,.5) inset,\n      0 18px 40px rgba(0,0,0,.55),\n      0 2px 6px rgba(0,0,0,.6);\n    border:1px solid #0e0f10;\n    position:relative;\n  }\n  /* faux ventilation / brand groove */\n  .unit::before{\n    content:\"\";position:absolute;left:20px;right:20px;top:0;height:6px;\n    background:repeating-linear-gradient(90deg,transparent 0 7px,rgba(0,0,0,.25) 7px 8px);\n    border-radius:14px 14px 0 0;opacity:.4;\n  }\n  .top{\n    display:flex;align-items:flex-end;justify-content:space-between;\n    margin-bottom:14px;gap:14px;\n  }\n  .brand{display:flex;flex-direction:column;gap:2px;}\n  .brand .name{\n    font-weight:800;letter-spacing:.14em;font-size:19px;\n    color:#e9efe9;text-transform:uppercase;\n    text-shadow:0 1px 0 #000;\n  }\n  .brand .name b{color:var(--mint);}\n  .brand .sub{\n    font-size:9px;letter-spacing:.35em;color:#6f7873;text-transform:uppercase;\n  }\n  /* numeric LCD */\n  .lcd{\n    background:linear-gradient(180deg,#0d1a14,#06100b);\n    border:1px solid #000;border-radius:6px;\n    padding:7px 12px;min-width:188px;\n    box-shadow:inset 0 2px 6px rgba(0,0,0,.8),0 0 0 2px #15181a;\n    position:relative;overflow:hidden;\n  }\n  .lcd::after{ /* scanline glass */\n    content:\"\";position:absolute;inset:0;\n    background:repeating-linear-gradient(0deg,rgba(255,255,255,.03) 0 1px,transparent 1px 3px);\n    pointer-events:none;\n  }\n  .lcd .pname{\n    font:700 9px/1 \"Courier New\",monospace;letter-spacing:.22em;\n    color:#3f7a5e;text-transform:uppercase;\n  }\n  .lcd .pval{\n    font:700 26px/1 \"Courier New\",monospace;letter-spacing:.04em;\n    color:var(--lcdtxt);\n    text-shadow:0 0 6px rgba(125,255,196,.55);\n    display:flex;align-items:baseline;gap:4px;margin-top:3px;\n  }\n  .lcd .pval small{font-size:11px;color:#4d9a76;}\n  .lcd .blink{\n    position:absolute;right:9px;top:9px;width:7px;height:7px;border-radius:50%;\n    background:var(--amber);box-shadow:0 0 8px var(--amber);\n    animation:beat 1.6s steps(1,end) infinite;\n  }\n  @keyframes beat{0%,55%{opacity:1}56%,100%{opacity:.15}}\n\n  /* main 2-column body */\n  .body{display:grid;grid-template-columns:218px 1fr;gap:18px;}\n\n  /* left: scope + chorus lamp */\n  .scopeWrap{\n    background:linear-gradient(180deg,#11241b,#081310);\n    border-radius:9px;border:1px solid #000;\n    box-shadow:inset 0 2px 8px rgba(0,0,0,.85),0 0 0 2px #15181a;\n    padding:10px;display:flex;flex-direction:column;gap:9px;\n  }\n  .scope{\n    width:100%;height:104px;border-radius:5px;display:block;\n    background:\n      repeating-linear-gradient(0deg,rgba(90,208,160,.06) 0 11px,transparent 11px 12px),\n      repeating-linear-gradient(90deg,rgba(90,208,160,.06) 0 11px,transparent 11px 12px),\n      #06100b;\n  }\n  .lampRow{display:flex;align-items:center;gap:9px;padding:0 2px 2px;}\n  .lamp{\n    width:14px;height:14px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff6cf 0%, var(--amber) 45%, #6a4f00 100%);\n    box-shadow:0 0 0 2px #0a0a0a, 0 0 12px var(--amber);\n    transition:opacity .2s, box-shadow .2s;\n  }\n  .lamp.on{animation:chorusPulse 1.7s ease-in-out infinite;}\n  @keyframes chorusPulse{\n    0%,100%{box-shadow:0 0 0 2px #0a0a0a,0 0 6px rgba(255,210,74,.5);opacity:.7}\n    50%{box-shadow:0 0 0 2px #0a0a0a,0 0 18px rgba(255,210,74,1);opacity:1}\n  }\n  .lampRow .lt{font:700 9px/1 \"Courier New\",monospace;letter-spacing:.2em;color:#8a8f8c;text-transform:uppercase;}\n\n  /* right: controls grid */\n  .controls{\n    display:grid;\n    grid-template-columns:repeat(3,1fr);\n    gap:14px 8px;\n    background:linear-gradient(180deg,#2a2e33,#212429);\n    border-radius:9px;padding:16px 12px 10px;\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.05),inset 0 -2px 4px rgba(0,0,0,.4);\n    border:1px solid #141618;\n  }\n  .cell{display:flex;flex-direction:column;align-items:center;gap:7px;}\n\n  /* the BIG shared filter dial spans full width on top */\n  .cell.big{grid-column:1 / -1;flex-direction:row;justify-content:center;gap:18px;align-items:center;}\n  .bigtxt{display:flex;flex-direction:column;gap:3px;max-width:150px;}\n  .bigtxt .t{font:800 12px/1 sans-serif;letter-spacing:.12em;color:var(--mint);text-transform:uppercase;}\n  .bigtxt .d{font:400 10px/1.35 sans-serif;color:#7f8784;}\n\n  .knob{\n    --val:0.5;\n    width:58px;height:58px;border-radius:50%;cursor:grab;position:relative;\n    background:\n      radial-gradient(circle at 38% 30%, #4a4f55 0%, #2e3237 55%, #191b1d 100%);\n    box-shadow:\n      0 2px 4px rgba(0,0,0,.6),\n      0 -1px 1px rgba(255,255,255,.06) inset,\n      0 4px 8px rgba(0,0,0,.5);\n    border:1px solid #0c0d0e;\n    touch-action:none;\n  }\n  .knob.dragging{cursor:grabbing;}\n  .knob::after{ /* pointer */\n    content:\"\";position:absolute;left:50%;top:7px;width:3px;height:18px;\n    margin-left:-1.5px;border-radius:2px;\n    background:var(--mint);\n    box-shadow:0 0 6px var(--mint);\n    transform-origin:50% 22px;\n    transform:rotate(calc((var(--val) * 270deg) - 135deg));\n    transition:transform .04s linear;\n  }\n  /* glowing ring driven by --val */\n  .knob .ring{\n    position:absolute;inset:-7px;border-radius:50%;pointer-events:none;\n    background:conic-gradient(from 225deg,\n      var(--mint) 0deg,\n      var(--mint) calc(var(--val) * 270deg),\n      rgba(255,255,255,.05) calc(var(--val) * 270deg),\n      rgba(255,255,255,.05) 270deg,\n      transparent 270deg);\n    -webkit-mask:radial-gradient(farthest-side,transparent calc(100% - 4px),#000 calc(100% - 4px));\n    mask:radial-gradient(farthest-side,transparent calc(100% - 4px),#000 calc(100% - 4px));\n    filter:drop-shadow(0 0 4px rgba(90,208,160,.6));\n    opacity:.9;\n  }\n  .knob.big2{width:96px;height:96px;}\n  .knob.big2::after{top:9px;height:30px;transform-origin:50% 39px;}\n  .knob.big2.glow .ring{\n    filter:drop-shadow(0 0 9px rgba(90,208,160,.95));\n    animation:filterGlow 2.4s ease-in-out infinite;\n  }\n  @keyframes filterGlow{0%,100%{opacity:.85}50%{opacity:1}}\n\n  .lab{font:700 9px/1 \"Courier New\",monospace;letter-spacing:.16em;color:var(--label);text-transform:uppercase;}\n\n  /* membrane buttons row (decorative voice indicators) */\n  .voices{\n    grid-column:1 / -1;\n    display:flex;gap:6px;justify-content:center;margin-top:4px;\n  }\n  .mbtn{\n    flex:1;max-width:54px;height:26px;border-radius:4px;\n    background:linear-gradient(180deg,#33373c,#202326);\n    border:1px solid #0c0d0e;\n    box-shadow:0 1px 0 rgba(255,255,255,.06) inset,0 2px 3px rgba(0,0,0,.5);\n    display:flex;align-items:center;justify-content:center;\n    font:700 9px/1 \"Courier New\",monospace;color:#5c6460;letter-spacing:.05em;\n    position:relative;overflow:hidden;\n  }\n  .mbtn .dot{\n    width:6px;height:6px;border-radius:50%;background:#2a3a33;margin-right:5px;\n    transition:background .08s, box-shadow .08s;\n  }\n  .mbtn.lit .dot{background:var(--mint);box-shadow:0 0 8px var(--mint);}\n  .mbtn.lit{color:#cdd4cf;}\n\n  .foot{\n    margin-top:13px;display:flex;justify-content:space-between;align-items:center;\n    font:600 8.5px/1 \"Courier New\",monospace;letter-spacing:.18em;color:#5a615d;\n    text-transform:uppercase;\n  }\n  .foot .para{color:var(--mint);}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"top\">\n      <div class=\"brand\">\n        <div class=\"name\">THRIFT<b>·</b>POLY</div>\n        <div class=\"sub\">8-Voice Paraphonic DCO</div>\n      </div>\n      <div class=\"lcd\">\n        <div class=\"blink\"></div>\n        <div class=\"pname\" id=\"lcdName\">CUTOFF</div>\n        <div class=\"pval\"><span id=\"lcdVal\">045</span><small id=\"lcdUnit\">%</small></div>\n      </div>\n    </div>\n\n    <div class=\"body\">\n      <div class=\"scopeWrap\">\n        <canvas class=\"scope\" id=\"scope\" width=\"380\" height=\"208\"></canvas>\n        <div class=\"lampRow\">\n          <div class=\"lamp\" id=\"chorusLamp\"></div>\n          <div class=\"lt\">Chorus</div>\n        </div>\n      </div>\n\n      <div class=\"controls\" id=\"controls\">\n        <div class=\"cell big\">\n          <div class=\"knob big2 glow\" data-idx=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.45\" id=\"kCut\">\n            <div class=\"ring\"></div>\n          </div>\n          <div class=\"bigtxt\">\n            <div class=\"t\">Shared Filter</div>\n            <div class=\"d\">One resonant low-pass for all voices — sweep it and whole chords gurgle together.</div>\n          </div>\n        </div>\n\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.4\"><div class=\"ring\"></div></div><div class=\"lab\">Reso</div></div>\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.6\"><div class=\"ring\"></div></div><div class=\"lab\">Env Amt</div></div>\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\"><div class=\"ring\"></div></div><div class=\"lab\">Sub</div></div>\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"4\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" id=\"kChor\"><div class=\"ring\"></div></div><div class=\"lab\">Chorus</div></div>\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"5\" data-min=\"0\" data-max=\"1\" data-def=\"0.35\"><div class=\"ring\"></div></div><div class=\"lab\">Release</div></div>\n        <div class=\"cell\"><div class=\"knob\" data-idx=\"6\" data-min=\"0\" data-max=\"1\" data-def=\"0.7\"><div class=\"ring\"></div></div><div class=\"lab\">Level</div></div>\n\n        <div class=\"voices\" id=\"voices\"></div>\n      </div>\n    </div>\n\n    <div class=\"foot\">\n      <span class=\"para\">◆ Paraphonic Architecture</span>\n      <span>Budget Classic · DCO + Sub + Chorus</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n  var LABELS = [\"CUTOFF\",\"RESONANCE\",\"ENV AMOUNT\",\"SUB\",\"CHORUS\",\"RELEASE\",\"LEVEL\"];\n  var host = null;\n\n  function setParam(i,v){\n    try{ if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, v); }catch(e){}\n  }\n\n  // ---- voice indicator buttons (decorative, animated on activity) ----\n  var voicesEl = document.getElementById(\"voices\");\n  for (var i=0;i<8;i++){\n    var b=document.createElement(\"div\");\n    b.className=\"mbtn\";\n    b.innerHTML='<span class=\"dot\"></span>V'+(i+1);\n    voicesEl.appendChild(b);\n  }\n  var voiceBtns = voicesEl.querySelectorAll(\".mbtn\");\n\n  // ---- knob wiring ----\n  var lcdName=document.getElementById(\"lcdName\");\n  var lcdVal=document.getElementById(\"lcdVal\");\n  var chorusLamp=document.getElementById(\"chorusLamp\");\n\n  var knobs=[].slice.call(document.querySelectorAll(\".knob\"));\n  var state={}; // idx -> norm value 0..1\n\n  function fmt(n){ var s=Math.round(n*100); return (s<10?\"00\":s<100?\"0\":\"\")+s; }\n\n  function showLcd(idx){\n    lcdName.textContent = LABELS[idx];\n    lcdVal.textContent = fmt(state[idx]);\n  }\n\n  function applyKnob(k, norm, show){\n    var idx=+k.getAttribute(\"data-idx\");\n    var mn=+k.getAttribute(\"data-min\"), mx=+k.getAttribute(\"data-max\");\n    norm = norm<0?0:norm>1?1:norm;\n    state[idx]=norm;\n    k.style.setProperty(\"--val\", norm.toFixed(4));\n    var real = mn + norm*(mx-mn);\n    setParam(idx, real);\n    if(show!==false) showLcd(idx);\n    if(idx===4){ // chorus lamp\n      if(norm>0.02){ chorusLamp.classList.add(\"on\"); chorusLamp.style.opacity=\"1\"; }\n      else { chorusLamp.classList.remove(\"on\"); chorusLamp.style.opacity=\".22\"; }\n    }\n  }\n\n  knobs.forEach(function(k){\n    var idx=+k.getAttribute(\"data-idx\");\n    var def=+k.getAttribute(\"data-def\");\n    applyKnob(k, def, false);\n\n    var dragging=false, lastY=0;\n    function down(e){\n      dragging=true; k.classList.add(\"dragging\");\n      lastY=(e.touches?e.touches[0].clientY:e.clientY);\n      showLcd(idx);\n      e.preventDefault();\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=lastY-y; lastY=y;\n      var step = e.shiftKey?0.0008:0.004;\n      applyKnob(k, state[idx]+dy*step, true);\n      e.preventDefault();\n    }\n    function up(){ dragging=false; k.classList.remove(\"dragging\"); }\n\n    k.addEventListener(\"mousedown\",down);\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"mouseup\",up);\n    k.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"touchend\",up);\n    k.addEventListener(\"dblclick\",function(e){ applyKnob(k,def,true); e.preventDefault(); });\n    k.addEventListener(\"wheel\",function(e){\n      applyKnob(k, state[idx] - (e.deltaY>0?0.03:-0.03), true);\n      e.preventDefault();\n    },{passive:false});\n  });\n\n  // ---- animated scope: stacked gurgly square/saw waves driven by params ----\n  var cv=document.getElementById(\"scope\");\n  var ctx=cv.getContext(\"2d\");\n  var W=cv.width, H=cv.height;\n  var t=0;\n\n  function draw(){\n    t+=0.018;\n    ctx.clearRect(0,0,W,H);\n    var cut=state[0], reso=state[1], sub=state[3], chor=state[4], lvl=state[6];\n\n    // gurgle: shared cutoff modulates how 'open' the waves look + a slow LFO wobble\n    var open = 0.18 + cut*0.82;\n    var wob = Math.sin(t*0.9)*chor*0.5;       // chorus wobble\n    var nLayers = 3;                           // stacked voices\n    for (var L=0; L<nLayers; L++){\n      var yMid = H*(0.28 + L*0.24);\n      var amp = (H*0.16) * open * (0.7+0.3*lvl);\n      var freq = 0.045 * (1 + L*0.45);\n      var alpha = 0.85 - L*0.18;\n      ctx.beginPath();\n      for (var x=0;x<=W;x+=2){\n        // square-ish core with saw lean + sub octave + chorus wobble\n        var ph = x*freq + t*1.3 + L*1.1 + wob;\n        var sq = Math.sin(ph) >= 0 ? 1 : -1;\n        var saw = ((ph/Math.PI)%2)-1;\n        var subw = (Math.sin(ph*0.5) >= 0 ? 1 : -1) * sub*0.5;\n        // resonance => ringing overshoot near edges\n        var ring = Math.sin(ph*6)*reso*0.22*Math.max(0,1-Math.abs(saw));\n        var v = (sq*0.6 + saw*0.4 + subw + ring);\n        var y = yMid - v*amp;\n        if(x===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);\n      }\n      ctx.strokeStyle = \"rgba(90,208,160,\"+alpha.toFixed(3)+\")\";\n      ctx.lineWidth = 2;\n      ctx.shadowColor=\"rgba(90,208,160,.7)\";\n      ctx.shadowBlur=6;\n      ctx.stroke();\n    }\n    ctx.shadowBlur=0;\n\n    // amber cutoff marker line\n    var cy = H - cut*H*0.92 - 4;\n    ctx.strokeStyle=\"rgba(255,210,74,.5)\";\n    ctx.lineWidth=1;\n    ctx.setLineDash([4,4]);\n    ctx.beginPath(); ctx.moveTo(0,cy); ctx.lineTo(W,cy); ctx.stroke();\n    ctx.setLineDash([]);\n\n    // animate voice lamps with a gentle running pattern\n    var lit = Math.floor((Math.sin(t*0.7)*0.5+0.5)*5)+3;\n    for (var vi=0; vi<8; vi++){\n      if(vi<lit) voiceBtns[vi].classList.add(\"lit\");\n      else voiceBtns[vi].classList.remove(\"lit\");\n    }\n\n    requestAnimationFrame(draw);\n  }\n  draw();\n\n  // init chorus lamp state\n  applyKnob(document.getElementById(\"kChor\"), state[4], false);\n  showLcd(0);\n\n  // ---- host contract ----\n  function boot(){\n    // re-push all current values so DSP matches GUI defaults\n    knobs.forEach(function(k){\n      var idx=+k.getAttribute(\"data-idx\");\n      applyKnob(k, state[idx], false);\n    });\n  }\n  if (window.vstai && typeof window.vstai.onReady === \"function\"){\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  THRIFT POLY — lo-fi 8-voice paraphonic DCO poly (budget-classic lineage)\n//\n//  Distinctive trait: ALL voices share ONE resonant low-pass filter and ONE\n//  envelope (paraphonic). Sweeping Cutoff makes whole chords gurgle together.\n//  Each voice is a band-limited-ish DCO (saw + square) plus a square sub an\n//  octave down. A single shared DEG-style envelope (fast attack, decay to\n//  sustain, release) gates the mixed signal and also modulates the shared\n//  filter cutoff. A built-in stereo chorus (two modulated delay lines) adds\n//  the characteristic budget width. Deliberately slightly gritty, not hi-fi.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst NVOICES: i32 = 8;\n\n// per-voice oscillator state\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NVOICES); // 0..1 saw phase\nconst vSubPh:  StaticArray<f32> = new StaticArray<f32>(NVOICES); // 0..1 sub phase\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NVOICES); // Hz\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NVOICES); // note id (-1 free)\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NVOICES); // 1 while held\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NVOICES); // 0..1\nlet voiceRR: i32 = 0; // round-robin alloc pointer\n\n// shared (paraphonic) envelope — one for the whole instrument\nlet env: f32 = 0.0;\nlet heldCount: i32 = 0;       // number of currently held notes\nlet envStage: i32 = 0;        // 0 idle, 1 attack, 2 decay/sustain, 3 release\n\n// shared resonant low-pass (state-variable), processed on the SUMMED voices\nlet svLP: f32 = 0.0;\nlet svBP: f32 = 0.0;\n\n// stereo chorus delay lines\nconst CHORUS_LEN: i32 = 2048; // ~42ms @48k\nconst chL: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nconst chR: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nlet chWrite: i32 = 0;\nlet chLfo: f32 = 0.0; // 0..1 phase\n\nconst PI2: f32 = 6.2831853;\n\nconst P_CUTOFF:  i32 = 0; // shared filter cutoff\nconst P_RES:     i32 = 1; // shared filter resonance\nconst P_ENVAMT:  i32 = 2; // env -> cutoff amount\nconst P_SUB:     i32 = 3; // sub oscillator level\nconst P_CHORUS:  i32 = 4; // chorus depth/mix\nconst P_RELEASE: i32 = 5; // release time\nconst P_LEVEL:   i32 = 6; // output level\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < NVOICES; i++) {\n    vPhase[i] = 0.0; vSubPh[i] = 0.0; vFreq[i] = 0.0;\n    vNote[i] = -1; vActive[i] = 0; vVel[i] = 0.0;\n  }\n  voiceRR = 0;\n  env = 0.0; heldCount = 0; envStage = 0;\n  svLP = 0.0; svBP = 0.0;\n  for (let i = 0; i < CHORUS_LEN; i++) { chL[i] = 0.0; chR[i] = 0.0; }\n  chWrite = 0; chLfo = 0.0;\n  params[P_CUTOFF] = 0.45; params[P_RES] = 0.4; params[P_ENVAMT] = 0.6;\n  params[P_SUB] = 0.5; params[P_CHORUS] = 0.5; params[P_RELEASE] = 0.35;\n  params[P_LEVEL] = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // round-robin steal so a new note always sounds (paraphonic env retrigs)\n  let slot: i32 = -1;\n  for (let i = 0; i < NVOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) { slot = voiceRR; voiceRR = (voiceRR + 1) % NVOICES; }\n  vNote[slot] = id;\n  vFreq[slot] = f;\n  vVel[slot] = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  // keep oscillator phase running for that lo-fi free-run feel (no reset)\n  heldCount++;\n  envStage = 1; // (re)trigger attack — shared, gurgly\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NVOICES; i++) {\n    if (vActive[i] == 1 && vNote[i] == id) {\n      vActive[i] = 0;\n      vNote[i] = -1;\n      if (heldCount > 0) heldCount--;\n    }\n  }\n  if (heldCount <= 0) { heldCount = 0; envStage = 3; }\n}\n\nexport function process(n: i32): void {\n  const cutoffN:  f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resN:     f32 = clampf(params[P_RES], 0.0, 1.0);\n  const envAmt:   f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const subLvl:   f32 = clampf(params[P_SUB], 0.0, 1.0) * 0.7;\n  const chorusN:  f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const releaseN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const level:    f32 = clampf(params[P_LEVEL], 0.0, 1.0) * 0.9;\n\n  // shared envelope rates (per-sample one-pole coefficients)\n  const atkCoef: f32 = 1.0 - Mathf.exp(-1.0 / (0.004 * sampleRate));        // ~4ms\n  const decCoef: f32 = 1.0 - Mathf.exp(-1.0 / (0.25 * sampleRate));          // ~250ms to sustain\n  const relTime: f32 = 0.03 + releaseN * releaseN * 2.5;                     // 30ms..~2.5s\n  const relCoef: f32 = 1.0 - Mathf.exp(-1.0 / (relTime * sampleRate));\n  const sustain: f32 = 0.75;\n\n  // chorus LFO ~0.6 Hz, depth scales delay modulation\n  const chRate: f32 = 0.6 / sampleRate;\n  const chDepth: f32 = 220.0 * chorusN;   // samples of sweep\n  const chBase: f32 = 320.0;              // base delay (~6.7ms @48k)\n  const chMix: f32 = chorusN * 0.5;\n\n  // mono voice sum scaling — keep big chords bounded\n  const voiceScale: f32 = 0.16;\n\n  for (let f = 0; f < n; f++) {\n    // ---- advance shared envelope ----\n    if (envStage == 1) {\n      env += atkCoef * (1.0 - env);\n      if (env >= 0.999) { env = 1.0; envStage = 2; }\n    } else if (envStage == 2) {\n      env += decCoef * (sustain - env);\n    } else if (envStage == 3) {\n      env += relCoef * (0.0 - env);\n      if (env < 0.0003) { env = 0.0; envStage = 0; }\n    }\n\n    // ---- sum all voices (paraphonic: shared filter downstream) ----\n    let mono: f32 = 0.0;\n    for (let i = 0; i < NVOICES; i++) {\n      const fr: f32 = vFreq[i];\n      if (fr <= 0.0) continue;\n      // skip fully released free voices to save cycles (env gone)\n      if (vActive[i] == 0 && envStage == 0) continue;\n\n      const inc: f32 = fr / sampleRate;\n      let ph: f32 = vPhase[i] + inc;\n      if (ph >= 1.0) ph -= 1.0;\n      vPhase[i] = ph;\n\n      // DCO saw + square blend (slightly gritty, not band-limited = lo-fi)\n      const saw: f32 = ph * 2.0 - 1.0;\n      const sq:  f32 = ph < 0.5 ? 1.0 : -1.0;\n      let osc: f32 = saw * 0.6 + sq * 0.4;\n\n      // square sub one octave down\n      let sp: f32 = vSubPh[i] + inc * 0.5;\n      if (sp >= 1.0) sp -= 1.0;\n      vSubPh[i] = sp;\n      const sub: f32 = sp < 0.5 ? 1.0 : -1.0;\n\n      osc += sub * subLvl;\n      // per-voice velocity weighting (use stored vel even after release)\n      mono += osc * (0.4 + 0.6 * vVel[i]);\n    }\n    mono *= voiceScale;\n\n    // ---- shared resonant low-pass (state-variable), env modulates cutoff ----\n    // base cutoff 40Hz.. caps ~ for lo-fi gurgle; env pushes it up\n    const cmod: f32 = clampf(cutoffN + envAmt * env * 0.6, 0.0, 1.0);\n    let fc: f32 = 40.0 + cmod * cmod * 9000.0;\n    if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n    const g: f32 = Mathf.tan(3.14159265 * fc / sampleRate);\n    const res: f32 = 0.05 + (1.0 - resN) * 1.4; // damping (lower = more resonant)\n    const denom: f32 = 1.0 + g * (g + res);\n    // SVF (Chamberlin-ish, zero-delay-ish)\n    const hp: f32 = (mono - (res + g) * svBP - svLP) / denom;\n    const bp: f32 = g * hp + svBP;\n    const lp: f32 = g * bp + svLP;\n    svBP = g * hp + bp;\n    svLP = g * bp + lp;\n\n    // gate by shared envelope + soft saturation for budget grit\n    let v: f32 = lp * env;\n    // soft clip\n    v = clampf(v, -1.4, 1.4);\n    v = 1.5 * v - 0.5 * v * v * v;\n    v *= level;\n\n    // ---- stereo chorus ----\n    chLfo += chRate; if (chLfo >= 1.0) chLfo -= 1.0;\n    const lfoL: f32 = Mathf.sin(PI2 * chLfo);\n    const lfoR: f32 = Mathf.sin(PI2 * chLfo + 1.5708); // 90deg for width\n\n    chL[chWrite] = v;\n    chR[chWrite] = v;\n\n    const dL: f32 = chBase + chDepth * (0.5 + 0.5 * lfoL);\n    const dR: f32 = chBase + chDepth * (0.5 + 0.5 * lfoR);\n\n    let rL: f32 = f32(chWrite) - dL;\n    let rR: f32 = f32(chWrite) - dR;\n    while (rL < 0.0) rL += f32(CHORUS_LEN);\n    while (rR < 0.0) rR += f32(CHORUS_LEN);\n\n    const iL0: i32 = i32(rL); const fracL: f32 = rL - f32(iL0);\n    const iR0: i32 = i32(rR); const fracR: f32 = rR - f32(iR0);\n    const iL1: i32 = (iL0 + 1) % CHORUS_LEN;\n    const iR1: i32 = (iR0 + 1) % CHORUS_LEN;\n\n    const wetL: f32 = chL[iL0] + fracL * (chL[iL1] - chL[iL0]);\n    const wetR: f32 = chR[iR0] + fracR * (chR[iR1] - chR[iR0]);\n\n    chWrite = (chWrite + 1) % CHORUS_LEN;\n\n    const outL: f32 = v * (1.0 - chMix) + wetL * chMix;\n    const outR: f32 = v * (1.0 - chMix) + wetR * chMix;\n\n    outBuf[f] = f32(Mathf.tanh(outL * 2.5));\n    if (channels > 1) outBuf[MAX_FRAMES + f] = f32(Mathf.tanh(outR * 2.5));\n  }\n}\n",
  "publishedAt": 1751000116000
}