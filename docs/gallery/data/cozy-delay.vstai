{
  "format": 1,
  "name": "Cozy Delay",
  "isInstrument": false,
  "explanation": "A warm, dark, short bucket-brigade-style analog delay. A compact interpolated delay line (~20-300 ms) feeds a bounded feedback path; each repeat is made progressively darker and softer by a cascaded low-pass inside the loop plus gentle per-pass saturation, so a string of echoes melts from a present slapback into a soft, intimate shadow. A faint wow drift adds vintage warmth. Controls: Time, Feedback, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Time",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Feedback",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Cozy Delay</title>\n<style>\n  :root{\n    --accent:#ff9a5a;\n    --accent2:#ffd86a;\n    --ink:#3a2418;\n    --shadow:rgba(40,18,8,.55);\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:'Avenir Next','Segoe UI',system-ui,sans-serif;\n    background:radial-gradient(120% 130% at 50% -10%, #2a1c14 0%, #1a110b 55%, #0d0805 100%);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100vh;overflow:hidden;color:#f3e6d8;\n  }\n\n  /* ===== ambient amber room glow ===== */\n  .room-glow{\n    position:fixed;inset:0;pointer-events:none;\n    background:radial-gradient(60% 50% at 50% 38%, rgba(255,154,90,.16), transparent 70%);\n    animation:roomBreathe 7s ease-in-out infinite;\n  }\n  @keyframes roomBreathe{0%,100%{opacity:.7}50%{opacity:1}}\n\n  /* ===== the pedal ===== */\n  .pedal{\n    position:relative;\n    width:330px;\n    padding:26px 26px 30px;\n    border-radius:22px;\n    background:\n      linear-gradient(160deg,#ffb878 0%,#ff9a5a 42%,#e87f3e 100%);\n    box-shadow:\n      0 2px 0 rgba(255,255,255,.35) inset,\n      0 -10px 26px rgba(120,50,15,.45) inset,\n      0 26px 50px -10px rgba(0,0,0,.7),\n      0 4px 0 #b85f28;\n    border:1px solid rgba(255,225,190,.4);\n  }\n  /* brushed-metal sheen */\n  .pedal::before{\n    content:\"\";position:absolute;inset:0;border-radius:22px;pointer-events:none;\n    background:\n      repeating-linear-gradient(115deg, rgba(255,255,255,.045) 0 2px, transparent 2px 5px);\n    mix-blend-mode:overlay;opacity:.5;\n  }\n  /* corner screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff4e6,#9a6a3c 70%,#5e3a18);\n    box-shadow:0 1px 2px rgba(0,0,0,.5),0 0 0 1px rgba(0,0,0,.15) inset}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,rgba(60,30,10,.7) 44% 56%,transparent 56%)}\n  .screw.tl{top:10px;left:10px}.screw.tr{top:10px;right:10px}\n  .screw.bl{bottom:10px;left:10px}.screw.br{bottom:10px;right:10px}\n\n  .brand{text-align:center;margin-bottom:14px}\n  .brand h1{\n    font-size:22px;font-weight:800;letter-spacing:.12em;text-transform:uppercase;\n    color:#fff6ec;\n    text-shadow:0 1px 0 rgba(255,255,255,.4),0 2px 5px rgba(90,40,15,.7);\n  }\n  .brand .sub{\n    font-size:9px;letter-spacing:.42em;text-transform:uppercase;\n    color:rgba(70,38,18,.85);margin-top:4px;font-weight:700;\n  }\n\n  /* ===== echo display window ===== */\n  .window{\n    position:relative;height:96px;border-radius:12px;margin:6px 4px 20px;\n    background:linear-gradient(#180e07,#241509);\n    box-shadow:0 0 0 3px rgba(120,60,25,.6),0 6px 14px rgba(0,0,0,.6) inset;\n    overflow:hidden;\n  }\n  .window .glassglow{position:absolute;inset:0;pointer-events:none;\n    background:radial-gradient(80% 120% at 18% 50%, rgba(255,154,90,.22), transparent 65%)}\n  svg{display:block;width:100%;height:100%}\n\n  /* ===== knob row ===== */\n  .knobs{display:flex;justify-content:space-between;gap:8px;padding:0 2px}\n  .knob-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:7px}\n  .knob{\n    --ang:-135deg;\n    position:relative;width:62px;height:62px;border-radius:50%;cursor:grab;\n    background:\n      radial-gradient(circle at 50% 38%, #4a3020, #2a1a0f 72%, #160d07);\n    box-shadow:\n      0 3px 7px rgba(0,0,0,.6),\n      0 1px 0 rgba(255,210,160,.25) inset,\n      0 -3px 8px rgba(0,0,0,.55) inset;\n    transition:transform .08s ease;\n  }\n  .knob:active{cursor:grabbing}\n  .knob:hover{transform:translateY(-1px)}\n  /* tick ring */\n  .knob .ring{\n    position:absolute;inset:-9px;border-radius:50%;pointer-events:none;\n    background:conic-gradient(from -135deg,\n      var(--accent2) 0deg, var(--accent) var(--fill,0deg),\n      rgba(255,255,255,.06) var(--fill,0deg) 270deg, transparent 270deg);\n    -webkit-mask:radial-gradient(circle, transparent 0 28px, #000 28px 31px, transparent 31px);\n    mask:radial-gradient(circle, transparent 0 28px, #000 28px 31px, transparent 31px);\n    filter:drop-shadow(0 0 5px rgba(255,154,90,.5));\n  }\n  .knob .pointer{\n    position:absolute;left:50%;top:50%;width:3px;height:24px;border-radius:2px;\n    background:linear-gradient(var(--accent2),var(--accent));\n    transform-origin:50% 100%;\n    transform:translate(-50%,-100%) rotate(var(--ang));\n    box-shadow:0 0 6px rgba(255,154,90,.8);\n  }\n  .knob .cap{position:absolute;inset:20px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#5a3a24,#241509);\n    box-shadow:0 1px 2px rgba(0,0,0,.6)}\n  .label{font-size:10px;letter-spacing:.18em;text-transform:uppercase;\n    color:rgba(60,32,16,.9);font-weight:800}\n  .val{font-size:11px;font-weight:700;color:#fff3e6;\n    background:rgba(30,16,8,.55);padding:2px 8px;border-radius:7px;\n    min-width:42px;text-align:center;letter-spacing:.04em;\n    box-shadow:0 1px 0 rgba(255,255,255,.15) inset}\n\n  /* ===== footswitch + LED ===== */\n  .footer{display:flex;align-items:center;justify-content:center;gap:18px;margin-top:22px}\n  .led{width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #fff0c0, var(--accent) 60%, #b9521f);\n    box-shadow:0 0 10px 2px rgba(255,170,80,.9),0 0 20px rgba(255,154,90,.5);\n    animation:ledPulse 2.4s ease-in-out infinite}\n  @keyframes ledPulse{0%,100%{opacity:.85;box-shadow:0 0 8px 1px rgba(255,170,80,.7)}\n    50%{opacity:1;box-shadow:0 0 16px 4px rgba(255,170,80,1)}}\n  .stomp{width:64px;height:64px;border-radius:50%;\n    background:radial-gradient(circle at 42% 32%,#e9e2d6,#9c948a 65%,#5d564d);\n    box-shadow:0 5px 10px rgba(0,0,0,.6),0 1px 0 rgba(255,255,255,.5) inset;\n    border:3px solid rgba(40,22,10,.4)}\n</style>\n</head>\n<body>\n<div class=\"room-glow\"></div>\n\n<div class=\"pedal\">\n  <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n  <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n  <div class=\"brand\">\n    <h1>Cozy Delay</h1>\n    <div class=\"sub\">Warm Analog Echo</div>\n  </div>\n\n  <div class=\"window\">\n    <div class=\"glassglow\"></div>\n    <svg id=\"viz\" viewBox=\"0 0 320 96\" preserveAspectRatio=\"none\">\n      <defs>\n        <linearGradient id=\"wv\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n          <stop offset=\"0\" stop-color=\"#ffd86a\"/>\n          <stop offset=\"1\" stop-color=\"#ff9a5a\"/>\n        </linearGradient>\n        <radialGradient id=\"src\" cx=\"0.5\" cy=\"0.5\" r=\"0.5\">\n          <stop offset=\"0\" stop-color=\"#fff3d0\"/>\n          <stop offset=\"1\" stop-color=\"#ff9a5a\" stop-opacity=\"0\"/>\n        </radialGradient>\n      </defs>\n      <g id=\"echoes\"></g>\n    </svg>\n  </div>\n\n  <div class=\"knobs\" id=\"knobs\"></div>\n\n  <div class=\"footer\">\n    <span class=\"led\"></span>\n    <span class=\"stomp\"></span>\n    <span class=\"led\"></span>\n  </div>\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- param model ----\n  var PARAMS = [\n    { name:\"Time\",     index:0, min:0, max:1, def:0.35, fmt:function(v){return Math.round(20+v*v*280)+\" ms\";} },\n    { name:\"Feedback\", index:1, min:0, max:1, def:0.45, fmt:function(v){return Math.round(v*100)+\" %\";} },\n    { name:\"Tone\",     index:2, min:0, max:1, def:0.4,  fmt:function(v){return Math.round(600+v*v*3600)+\" Hz\";} },\n    { name:\"Mix\",      index:3, min:0, max:1, def:0.4,  fmt:function(v){return Math.round(v*100)+\" %\";} }\n  ];\n  var state = PARAMS.map(function(p){return p.def;});\n\n  function host(){ return (typeof window!==\"undefined\" && window.vstai) ? window.vstai : null; }\n  function push(i){\n    var h=host();\n    if(h && typeof h.setParam===\"function\"){ try{ h.setParam(i, state[i]); }catch(e){} }\n  }\n\n  // ---- build knobs ----\n  var knobsEl = document.getElementById(\"knobs\");\n  var widgets = [];\n\n  PARAMS.forEach(function(p, i){\n    var wrap=document.createElement(\"div\"); wrap.className=\"knob-wrap\";\n    var knob=document.createElement(\"div\"); knob.className=\"knob\";\n    knob.innerHTML='<div class=\"ring\"></div><div class=\"cap\"></div><div class=\"pointer\"></div>';\n    var label=document.createElement(\"div\"); label.className=\"label\"; label.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    wrap.appendChild(knob); wrap.appendChild(label); wrap.appendChild(val);\n    knobsEl.appendChild(wrap);\n\n    var w={knob:knob,val:val,p:p,i:i};\n    widgets.push(w);\n\n    function render(){\n      var v=state[i];\n      var deg = -135 + v*270;\n      knob.querySelector(\".pointer\").style.setProperty(\"--ang\", deg+\"deg\");\n      knob.querySelector(\".ring\").style.setProperty(\"--fill\", (v*270)+\"deg\");\n      val.textContent = p.fmt(v);\n    }\n    w.render=render;\n\n    // drag (vertical)\n    var dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true; startY=(e.touches?e.touches[0].clientY:e.clientY); startV=state[i];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move); window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false}); window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/180;\n      var nv=Math.max(0,Math.min(1,startV+dv));\n      state[i]=nv; render(); push(i);\n      if(e.cancelable) e.preventDefault();\n    }\n    function up(){\n      dragging=false;\n      window.removeEventListener(\"mousemove\",move); window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move); window.removeEventListener(\"touchend\",up);\n    }\n    knob.addEventListener(\"mousedown\",down);\n    knob.addEventListener(\"touchstart\",down,{passive:false});\n    knob.addEventListener(\"dblclick\",function(){ state[i]=p.def; render(); push(i); });\n\n    render();\n  });\n\n  // ---- echo visualization ----\n  var g=document.getElementById(\"echoes\");\n  var NUM=7;\n  var bars=[];\n  for(var k=0;k<NUM;k++){\n    var el=document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n    el.setAttribute(\"fill\",\"none\");\n    el.setAttribute(\"stroke\",\"url(#wv)\");\n    el.setAttribute(\"stroke-linecap\",\"round\");\n    g.appendChild(el);\n    bars.push(el);\n  }\n  // a bright source blob on the left\n  var src=document.createElementNS(\"http://www.w3.org/2000/svg\",\"circle\");\n  src.setAttribute(\"cx\",\"18\"); src.setAttribute(\"cy\",\"48\"); src.setAttribute(\"r\",\"14\");\n  src.setAttribute(\"fill\",\"url(#src)\");\n  g.appendChild(src);\n\n  var t=0;\n  function frame(){\n    t+=0.045;\n    var time=state[0], fb=state[1], tone=state[2], mix=state[3];\n    // echo spacing grows with time; how many repeats with feedback; darkness with tone\n    var spacing = 24 + time*36;          // px between repeats\n    var alive = 1 + fb*5.5;              // visible repeats\n    for(var k=0;k<NUM;k++){\n      var x = 30 + k*spacing;\n      var decay = Math.pow(0.55+fb*0.42, k);          // amplitude falls per repeat\n      var visible = k < alive ? 1 : 0;\n      var amp = (4 + 26*decay) * (0.55+0.45*mix) * visible;\n      // each later repeat is darker/dimmer + slightly slower wobble (cosy)\n      var dark = Math.pow(0.5+tone*0.5, k*0.7);\n      var op = Math.max(0, decay * (0.35+0.65*mix) * (0.4+0.6*dark) * visible);\n      var wob = (1 - k*0.07*(1-tone));                 // higher repeats lose wiggle\n      // build a little fading sine packet\n      var d=\"M \"+x+\" 48\";\n      var span = 30;\n      for(var s=1;s<=span;s++){\n        var px = x + s*0.9;\n        if(px>318){ break; }\n        var env = Math.sin((s/span)*Math.PI);          // packet envelope\n        var py = 48 - Math.sin(s*0.6*wob + t - k*0.5)*amp*env;\n        d += \" L \"+px.toFixed(1)+\" \"+py.toFixed(1);\n      }\n      bars[k].setAttribute(\"d\",d);\n      bars[k].setAttribute(\"stroke-width\",(0.8+2.4*decay).toFixed(2));\n      bars[k].setAttribute(\"stroke-opacity\",op.toFixed(3));\n    }\n    var pulse=0.85+0.15*Math.sin(t*1.6);\n    src.setAttribute(\"r\",(13*pulse).toFixed(1));\n    src.setAttribute(\"opacity\",(0.7+0.3*mix).toFixed(2));\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- init host ----\n  function init(){\n    for(var i=0;i<PARAMS.length;i++){ push(i); }\n  }\n  var h=host();\n  if(h && typeof h.onReady===\"function\"){ h.onReady(init); } else { init(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  COZY DELAY — warm, dark, SHORT bucket-brigade-style analog delay\n//  A compact BBD slapback-to-short-echo in the ~20..300 ms range. Each\n//  repeat is rolled DARKER and SOFTER than the last: a one-pole low-pass\n//  AND a high-pass sit inside the feedback loop to model the bandwidth\n//  loss of a bucket-brigade chip, and the recirculating signal is gently\n//  saturated so it compresses and warms with every pass. A whisper of\n//  slow drift keeps it from sounding sterile. Short, intimate, cosy.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: short range, ~300 ms max + drift headroom. Sized for up to\n// 96 kHz so 0.34 s * 96000 ≈ 32640 samples; round up generously.\nconst DELAY_LEN: i32 = 36864; // ~384 ms @ 96k, plenty for 300 ms + mod\nconst delayL: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;\n\n// per-channel feedback filter states (BBD darkening per pass)\nlet fbLpL: f32 = 0.0; // low-pass: rolls off highs each repeat\nlet fbLpR: f32 = 0.0;\nlet fbHpL: f32 = 0.0; // high-pass state: trims sub each repeat (intimacy)\nlet fbHpR: f32 = 0.0;\n\n// smoothed delay time (samples) to avoid zipper noise\nlet smoothDelay: f32 = 3600.0;\n\n// gentle drift (single slow LFO, very shallow — not a chorus)\nlet driftPhase: f32 = 0.0;\n\nconst P_TIME: i32 = 0;     // 0..1 -> 20..300 ms (short/slap range)\nconst P_FEEDBACK: i32 = 1; // 0..1 -> 0..0.92 (clamped)\nconst P_TONE: i32 = 2;     // 0..1 -> repeat darkness (LP cutoff in loop)\nconst P_MIX: i32 = 3;      // 0..1 dry/wet\n\nconst TWO_PI: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  fbLpL = 0.0; fbLpR = 0.0;\n  fbHpL = 0.0; fbHpR = 0.0;\n  driftPhase = 0.0;\n  for (let i = 0; i < DELAY_LEN; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  smoothDelay = 0.12 * sampleRate; // ~120 ms default\n  params[P_TIME] = 0.38;     // ~120 ms cosy short echo\n  params[P_FEEDBACK] = 0.42;\n  params[P_TONE] = 0.4;      // leans dark by default\n  params[P_MIX] = 0.4;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// read a delay line at a fractional sample distance behind the write head,\n// linear interpolation, wrap-safe.\n@inline function readDelay(line: StaticArray<f32>, delaySamples: f32): f32 {\n  let rp: f32 = f32(writePos) - delaySamples;\n  while (rp < 0.0) rp += f32(DELAY_LEN);\n  while (rp >= f32(DELAY_LEN)) rp -= f32(DELAY_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1;\n  if (i1 >= DELAY_LEN) i1 = 0;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\n// soft, warm saturator — gentle, less aggressive than full tanh so quiet\n// repeats stay clean and only the hot recirculation compresses.\n@inline function warmSat(x: f32): f32 {\n  const c: f32 = clampf(x, -2.5, 2.5);\n  return f32(Mathf.tanh(c * 0.85)) * 1.12;\n}\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Time: 20..300 ms — short slapback to short echo only. Perceptual curve.\n  const timeMs: f32 = 20.0 + timeN * timeN * 280.0;\n  let targetDelay: f32 = timeMs * 0.001 * sampleRate;\n  const maxDelay: f32 = f32(DELAY_LEN - 8);\n  if (targetDelay > maxDelay) targetDelay = maxDelay;\n  if (targetDelay < 4.0) targetDelay = 4.0;\n\n  // Feedback gain — clamped to 0.92 so the repeats stack and ring but never\n  // run away. The in-loop darkening + level loss keeps it tidy below that.\n  const fbGain: f32 = clampf(fbN * 0.92, 0.0, 0.92);\n\n  // Feedback low-pass: darker overall than a long-delay echo. Cutoff sweeps\n  // ~520 Hz (very dark/cosy) .. ~4800 Hz (still soft, never bright/sizzly).\n  const toneHz: f32 = 520.0 + toneN * toneN * 4280.0;\n  let cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n  cTone = clampf(cTone, 0.0, 1.0);\n\n  // Feedback high-pass corner ~150 Hz — strips sub-bud from each repeat so\n  // they sit back intimately instead of building boom. (one-pole HP coeff)\n  const cHp: f32 = clampf(f32(1.0 - Mathf.exp(-TWO_PI * 150.0 / sampleRate)), 0.0, 1.0);\n\n  // Very gentle drift: shallow, slow — adds analog life, not pitch warble.\n  const driftDepth: f32 = 0.0009 * sampleRate; // ~0.9 ms max\n  const driftRate: f32 = 0.45; // Hz\n  const driftInc: f32 = TWO_PI * driftRate / sampleRate;\n\n  // one-pole smoothing coeff for delay time (~10 Hz)\n  const smoothCoeff: f32 = f32(1.0 - Mathf.exp(-TWO_PI * 10.0 / sampleRate));\n\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    driftPhase += driftInc; if (driftPhase >= TWO_PI) driftPhase -= TWO_PI;\n    const drift: f32 = Mathf.sin(driftPhase) * driftDepth;\n\n    smoothDelay += smoothCoeff * (targetDelay - smoothDelay);\n\n    // slight per-channel drift offset for a touch of width\n    let dL: f32 = smoothDelay + drift;\n    let dR: f32 = smoothDelay - drift * 0.7;\n    if (dL < 2.0) dL = 2.0; if (dL > maxDelay) dL = maxDelay;\n    if (dR < 2.0) dR = 2.0; if (dR > maxDelay) dR = maxDelay;\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = stereo ? inBuf[MAX_FRAMES + f] : xL;\n\n    // read the delayed (echo) signal\n    const echoL: f32 = readDelay(delayL, dL);\n    const echoR: f32 = readDelay(delayR, dR);\n\n    // --- progressive darkening in the feedback path ---\n    // low-pass: each pass loses highs\n    fbLpL += cTone * (echoL - fbLpL);\n    fbLpR += cTone * (echoR - fbLpR);\n    // high-pass: subtract a slow integrator -> trims sub each pass\n    fbHpL += cHp * (fbLpL - fbHpL);\n    fbHpR += cHp * (fbLpR - fbHpR);\n    const darkL: f32 = fbLpL - fbHpL; // band-limited, cosy repeat\n    const darkR: f32 = fbLpR - fbHpR;\n\n    // recirculate: dry input + warmly saturated, darkened feedback\n    const fbInL: f32 = warmSat(xL + darkL * fbGain);\n    const fbInR: f32 = warmSat(xR + darkR * fbGain);\n\n    delayL[writePos] = fbInL;\n    delayR[writePos] = fbInR;\n\n    // wet tap = the band-limited darkened repeat (cosy character on the\n    // first repeat too, not just deep in the tail)\n    const wetL: f32 = darkL;\n    const wetR: f32 = darkR;\n\n    let oL: f32 = f32(xL * (1.0 - mix) + wetL * mix);\n    let oR: f32 = f32(xR * (1.0 - mix) + wetR * mix);\n\n    // safety clamp — keep peaks under ~1.0\n    oL = clampf(oL, -1.0, 1.0);\n    oR = clampf(oR, -1.0, 1.0);\n\n    outBuf[f] = oL;\n    if (stereo) outBuf[MAX_FRAMES + f] = oR;\n    else outBuf[MAX_FRAMES + f] = oL;\n\n    writePos++;\n    if (writePos >= DELAY_LEN) writePos = 0;\n  }\n}\n",
  "publishedAt": 1751000136000
}