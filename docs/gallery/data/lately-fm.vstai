      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.2
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
