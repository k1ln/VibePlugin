      "max": 1,
      "default": 0.45
    },
    {
      "name": "Ratio",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "FM Depth",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
