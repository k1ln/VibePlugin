{
  "format": 1,
  "name": "Opto Trem",
  "isInstrument": false,
  "explanation": "An optical stereo tremolo: a low-frequency oscillator drives a smoothed photocell-style gain cell, modelling the gentle lag of a light-dependent resistor so even hard shapes pulse musically. Shape selects the LFO contour (sine, triangle, square or ramp), Rate and Depth set the throb, and Stereo morphs from a mono tremolo to an auto-pan where the L/R cells run in anti-phase to sweep the image side to side. Clean amplitude modulation with no distortion. Controls: Rate, Depth, Shape, Stereo and Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Shape",
      "index": 2,
      "min": 0,
      "max": 3,
      "default": 0
    },
    {
      "name": "Stereo",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Opto Trem</title>\n<style>\n  :root {\n    --accent: #62d6a0;\n    --accent2: #ffd86a;\n    --cream: #efe6d2;\n    --cream-d: #ddd0b3;\n    --ink: #2b2a26;\n    --ink-soft: #6a6555;\n    --panel: #f4ecda;\n    --shadow: rgba(40, 35, 20, 0.35);\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    height: 100%;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #3a4a3f 0%, #232a26 55%, #1a1f1c 100%);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .pedal {\n    width: 100%;\n    max-width: 430px;\n    border-radius: 22px;\n    padding: 22px 22px 26px;\n    background:\n      linear-gradient(180deg, var(--panel) 0%, var(--cream) 45%, var(--cream-d) 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.7) inset,\n      0 -3px 14px rgba(120,100,60,0.25) inset,\n      0 22px 50px -12px rgba(0,0,0,0.7),\n      0 4px 10px rgba(0,0,0,0.4);\n    border: 1px solid rgba(120,100,60,0.35);\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* faint speckled vintage texture */\n  .pedal::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      radial-gradient(rgba(120,100,60,0.06) 1px, transparent 1.4px);\n    background-size: 6px 6px;\n    pointer-events: none;\n    opacity: 0.6;\n  }\n\n  /* corner screws */\n  .screw {\n    position: absolute;\n    width: 13px; height: 13px;\n    border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #cfc3a4, #8c7f5d 70%, #6a5f42);\n    box-shadow: 0 1px 2px rgba(0,0,0,0.4), inset 0 1px 1px rgba(255,255,255,0.5);\n  }\n  .screw::after {\n    content: \"\";\n    position: absolute;\n    left: 2px; right: 2px; top: 50%;\n    height: 1.5px; margin-top: -0.75px;\n    background: rgba(60,50,30,0.6);\n    transform: rotate(35deg);\n  }\n  .screw.tl { top: 10px; left: 10px; }\n  .screw.tr { top: 10px; right: 10px; }\n  .screw.bl { bottom: 10px; left: 10px; }\n  .screw.br { bottom: 10px; right: 10px; }\n\n  header {\n    text-align: center;\n    position: relative;\n    z-index: 2;\n    margin-bottom: 14px;\n  }\n  .brand {\n    font-size: 11px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: var(--ink-soft);\n    font-weight: 700;\n  }\n  .title {\n    font-size: 30px;\n    font-weight: 800;\n    letter-spacing: 1px;\n    color: var(--ink);\n    line-height: 1;\n    margin-top: 2px;\n    text-shadow: 0 1px 0 rgba(255,255,255,0.6);\n  }\n  .title .o { color: var(--accent); }\n  .sub {\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-soft);\n    margin-top: 5px;\n  }\n\n  /* ---- lamp + meter window ---- */\n  .window {\n    position: relative;\n    z-index: 2;\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    background:\n      linear-gradient(180deg, #20251f, #161a15);\n    border-radius: 16px;\n    padding: 16px 18px;\n    margin-bottom: 18px;\n    box-shadow:\n      inset 0 2px 6px rgba(0,0,0,0.7),\n      inset 0 -1px 0 rgba(255,255,255,0.05),\n      0 1px 0 rgba(255,255,255,0.4);\n    border: 1px solid rgba(0,0,0,0.5);\n  }\n\n  .lamp-wrap {\n    position: relative;\n    width: 84px; height: 84px;\n    flex: 0 0 auto;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n  .lamp-glow {\n    position: absolute;\n    width: 100%; height: 100%;\n    border-radius: 50%;\n    background: radial-gradient(circle, var(--accent) 0%, rgba(98,214,160,0.35) 40%, transparent 70%);\n    filter: blur(4px);\n    opacity: var(--lamp, 0.4);\n    transition: opacity 0.04s linear;\n  }\n\n  /* Real CSS @keyframes: a slow breathing halo behind the photocell so the\n     lamp always has a living, optical shimmer even before the rAF loop runs.\n     This sits behind .lamp-glow (which carries the audio-reactive opacity). */\n  .lamp-halo {\n    position: absolute;\n    width: 132%; height: 132%;\n    left: -16%; top: -16%;\n    border-radius: 50%;\n    background: radial-gradient(circle, rgba(255,216,106,0.30) 0%, transparent 62%);\n    pointer-events: none;\n    animation: opto-breathe 3.4s ease-in-out infinite;\n  }\n  @keyframes opto-breathe {\n    0%   { transform: scale(0.86); opacity: 0.35; }\n    50%  { transform: scale(1.08); opacity: 0.7;  }\n    100% { transform: scale(0.86); opacity: 0.35; }\n  }\n\n  /* Real CSS @keyframes: the active shape button border glows in a steady\n     opto pulse, echoing the photocell's rhythmic light. */\n  @keyframes opto-shimmer {\n    0%   { box-shadow: 0 0 8px  rgba(98,214,160,0.35), inset 0 1px 0 rgba(255,255,255,0.08); }\n    50%  { box-shadow: 0 0 16px rgba(98,214,160,0.75), inset 0 1px 0 rgba(255,255,255,0.10); }\n    100% { box-shadow: 0 0 8px  rgba(98,214,160,0.35), inset 0 1px 0 rgba(255,255,255,0.08); }\n  }\n  .lamp {\n    position: relative;\n    width: 46px; height: 46px;\n    border-radius: 50%;\n    background:\n      radial-gradient(circle at 38% 34%, #fff 0%, var(--accent2) 18%, var(--accent) 60%, #2f7a59 100%);\n    box-shadow:\n      inset 0 0 8px rgba(255,255,255,0.6),\n      0 0 calc(14px + var(--lamp,0.4) * 26px) rgba(98,214,160, calc(0.3 + var(--lamp,0.4) * 0.7)),\n      0 0 calc(6px + var(--lamp,0.4) * 12px) rgba(255,216,106, calc(0.2 + var(--lamp,0.4) * 0.5));\n    filter: brightness(calc(0.55 + var(--lamp,0.4) * 0.9));\n  }\n  .lamp::after {\n    content: \"\";\n    position: absolute;\n    top: 8px; left: 11px;\n    width: 12px; height: 8px;\n    border-radius: 50%;\n    background: rgba(255,255,255,0.75);\n    filter: blur(1px);\n  }\n  .ldr-label {\n    position: absolute;\n    bottom: -2px;\n    width: 100%;\n    text-align: center;\n    font-size: 7.5px;\n    letter-spacing: 2px;\n    color: rgba(98,214,160,0.7);\n    text-transform: uppercase;\n  }\n\n  /* ---- L/R see-saw meter ---- */\n  .meter {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .ch {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n  }\n  .ch .lbl {\n    font-size: 9px;\n    font-weight: 700;\n    letter-spacing: 1px;\n    color: rgba(239,230,210,0.65);\n    width: 12px;\n  }\n  .bar {\n    flex: 1;\n    height: 12px;\n    border-radius: 6px;\n    background: rgba(0,0,0,0.55);\n    box-shadow: inset 0 1px 2px rgba(0,0,0,0.8);\n    overflow: hidden;\n    position: relative;\n  }\n  .fill {\n    position: absolute;\n    left: 0; top: 0; bottom: 0;\n    width: 50%;\n    border-radius: 6px;\n    background: linear-gradient(90deg, var(--accent) 0%, var(--accent2) 100%);\n    box-shadow: 0 0 8px rgba(98,214,160,0.5);\n    transition: width 0.04s linear;\n  }\n\n  /* ---- knob grid ---- */\n  .controls {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px 8px;\n    justify-items: center;\n  }\n\n  .knob-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n    user-select: none;\n  }\n  .knob {\n    width: 78px; height: 78px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { display: block; overflow: visible; }\n  .knob .cap {\n    transition: filter 0.15s ease;\n  }\n  .knob:hover .cap { filter: drop-shadow(0 0 5px rgba(98,214,160,0.55)); }\n\n  .knob-name {\n    font-size: 9.5px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-soft);\n  }\n  .knob-val {\n    font-size: 11px;\n    font-weight: 700;\n    color: var(--ink);\n    font-variant-numeric: tabular-nums;\n    background: rgba(255,255,255,0.45);\n    padding: 1px 7px;\n    border-radius: 5px;\n    box-shadow: inset 0 0 0 1px rgba(120,100,60,0.25);\n    min-width: 48px;\n    text-align: center;\n  }\n\n  /* ---- shape selector ---- */\n  .shape-cell {\n    grid-column: span 3;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n    margin-top: 2px;\n  }\n  .shape-cell .knob-name { color: var(--ink-soft); }\n  .shapes {\n    display: flex;\n    gap: 8px;\n    background: rgba(0,0,0,0.12);\n    padding: 6px;\n    border-radius: 12px;\n    box-shadow: inset 0 1px 3px rgba(120,100,60,0.3), 0 1px 0 rgba(255,255,255,0.5);\n  }\n  .shape-btn {\n    width: 56px; height: 40px;\n    border-radius: 9px;\n    border: 1px solid rgba(120,100,60,0.3);\n    background: linear-gradient(180deg, #f6efe0, #ddd0b3);\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.15s ease;\n    box-shadow: 0 1px 2px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,0.6);\n  }\n  .shape-btn svg { display: block; }\n  .shape-btn path, .shape-btn polyline {\n    stroke: var(--ink-soft);\n    stroke-width: 2.2;\n    fill: none;\n    stroke-linejoin: round;\n    stroke-linecap: round;\n    transition: stroke 0.15s ease;\n  }\n  .shape-btn.active {\n    background: linear-gradient(180deg, #2b332c, #1d231e);\n    border-color: var(--accent);\n    transform: translateY(1px);\n    animation: opto-shimmer 2.6s ease-in-out infinite;\n  }\n  .shape-btn.active path,\n  .shape-btn.active polyline { stroke: var(--accent); }\n\n  footer {\n    position: relative;\n    z-index: 2;\n    text-align: center;\n    margin-top: 16px;\n    font-size: 8px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: rgba(120,100,60,0.55);\n  }\n</style>\n</head>\n<body>\n  <div class=\"pedal\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <header>\n      <div class=\"brand\">Vibe Audio Labs</div>\n      <div class=\"title\"><span class=\"o\">Opto</span> Trem</div>\n      <div class=\"sub\">Optical Stereo Tremolo</div>\n    </header>\n\n    <div class=\"window\">\n      <div class=\"lamp-wrap\">\n        <div class=\"lamp-halo\"></div>\n        <div class=\"lamp-glow\"></div>\n        <div class=\"lamp\"></div>\n        <div class=\"ldr-label\">Photocell</div>\n      </div>\n      <div class=\"meter\">\n        <div class=\"ch\">\n          <span class=\"lbl\">L</span>\n          <div class=\"bar\"><div class=\"fill\" id=\"fillL\"></div></div>\n        </div>\n        <div class=\"ch\">\n          <span class=\"lbl\">R</span>\n          <div class=\"bar\"><div class=\"fill\" id=\"fillR\"></div></div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"controls\" id=\"controls\">\n      <!-- knobs injected -->\n      <div class=\"shape-cell\">\n        <div class=\"knob-name\">Shape</div>\n        <div class=\"shapes\" id=\"shapes\"></div>\n      </div>\n    </div>\n\n    <footer>Light • Cell • Motion</footer>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host bridge -------------------------------------------------\n  var bridge = {\n    setParam: function (i, v) {\n      if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n    }\n  };\n\n  // ---- parameter model --------------------------------------------\n  // Continuous knobs. Shape (index 2) handled separately as a selector.\n  var KNOBS = [\n    { idx: 0, name: \"Rate\",   min: 0, max: 1, def: 0.4, fmt: rateFmt },\n    { idx: 1, name: \"Depth\",  min: 0, max: 1, def: 0.7, fmt: pctFmt },\n    { idx: 3, name: \"Stereo\", min: 0, max: 1, def: 0.0, fmt: stereoFmt },\n    { idx: 4, name: \"Mix\",    min: 0, max: 1, def: 1.0, fmt: pctFmt }\n  ];\n\n  var SHAPES = [\"Sine\", \"Triangle\", \"Square\", \"Ramp\"];\n\n  var state = { rate: 0.4, depth: 0.7, stereo: 0.0, mix: 1.0, shape: 0 };\n\n  function pctFmt(v) { return Math.round(v * 100) + \"%\"; }\n  function rateFmt(v) {\n    var hz = 0.1 + v * v * 11.9;\n    return hz.toFixed(hz < 1 ? 2 : 1) + \" Hz\";\n  }\n  function stereoFmt(v) {\n    if (v < 0.02) return \"Mono\";\n    if (v > 0.98) return \"Auto-Pan\";\n    return Math.round(v * 100) + \"%\";\n  }\n\n  // ---- build knobs -------------------------------------------------\n  var controls = document.getElementById(\"controls\");\n  var shapeCell = controls.querySelector(\".shape-cell\");\n\n  function makeKnob(spec) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"knob-cell\";\n\n    var kn = document.createElement(\"div\");\n    kn.className = \"knob\";\n    kn.innerHTML =\n      '<svg viewBox=\"0 0 100 100\">' +\n      '<defs>' +\n      '<radialGradient id=\"g_' + spec.idx + '\" cx=\"38%\" cy=\"32%\" r=\"75%\">' +\n      '<stop offset=\"0%\" stop-color=\"#fbf6ea\"/>' +\n      '<stop offset=\"55%\" stop-color=\"#e7dcc1\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#bfb18d\"/>' +\n      '</radialGradient>' +\n      '</defs>' +\n      // track\n      '<circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"none\" stroke=\"rgba(60,50,30,0.18)\" stroke-width=\"6\"/>' +\n      // value arc\n      '<path class=\"arc\" fill=\"none\" stroke=\"url(#arcgrad_' + spec.idx + ')\" stroke-width=\"6\" stroke-linecap=\"round\"/>' +\n      // body\n      '<circle class=\"cap\" cx=\"50\" cy=\"50\" r=\"33\" fill=\"url(#g_' + spec.idx + ')\" ' +\n      'stroke=\"rgba(120,100,60,0.4)\" stroke-width=\"1\"/>' +\n      // pointer\n      '<line class=\"ptr\" x1=\"50\" y1=\"50\" x2=\"50\" y2=\"24\" stroke=\"#2b2a26\" ' +\n      'stroke-width=\"3.5\" stroke-linecap=\"round\"/>' +\n      '<circle cx=\"50\" cy=\"50\" r=\"3\" fill=\"#2b2a26\"/>' +\n      '</svg>';\n\n    var name = document.createElement(\"div\");\n    name.className = \"knob-name\";\n    name.textContent = spec.name;\n    var val = document.createElement(\"div\");\n    val.className = \"knob-val\";\n\n    cell.appendChild(kn);\n    cell.appendChild(name);\n    cell.appendChild(val);\n    controls.insertBefore(cell, shapeCell);\n\n    var arc = kn.querySelector(\".arc\");\n    var ptr = kn.querySelector(\".ptr\");\n\n    // arc gradient (shared def via first knob; just inline a linear gradient)\n    var svg = kn.querySelector(\"svg\");\n    var grad = document.createElementNS(\"http://www.w3.org/2000/svg\", \"linearGradient\");\n    grad.setAttribute(\"id\", \"arcgrad_\" + spec.idx);\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"0\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"1\");\n    grad.innerHTML =\n      '<stop offset=\"0%\" stop-color=\"#62d6a0\"/>' +\n      '<stop offset=\"100%\" stop-color=\"#ffd86a\"/>';\n    svg.querySelector(\"defs\").appendChild(grad);\n\n    var ARC_START = -135, ARC_SWEEP = 270;\n\n    function polar(cx, cy, r, deg) {\n      var a = (deg - 90) * Math.PI / 180;\n      return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n    }\n    function render(norm) {\n      var deg = ARC_START + ARC_SWEEP * norm;\n      // arc path\n      var endDeg = deg;\n      var s = polar(50, 50, 42, ARC_START);\n      var e = polar(50, 50, 42, endDeg);\n      var large = (endDeg - ARC_START) > 180 ? 1 : 0;\n      arc.setAttribute(\"d\", \"M \" + s[0].toFixed(2) + \" \" + s[1].toFixed(2) +\n        \" A 42 42 0 \" + large + \" 1 \" + e[0].toFixed(2) + \" \" + e[1].toFixed(2));\n      // pointer rotation\n      ptr.setAttribute(\"transform\", \"rotate(\" + deg + \" 50 50)\");\n    }\n\n    var cur = spec.def;\n    function commit(v) {\n      cur = Math.max(spec.min, Math.min(spec.max, v));\n      var norm = (cur - spec.min) / (spec.max - spec.min);\n      render(norm);\n      val.textContent = spec.fmt(cur);\n      bridge.setParam(spec.idx, cur);\n      setStateFor(spec.idx, cur);\n    }\n\n    // drag (vertical)\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var range = spec.max - spec.min;\n      commit(cur + dy * range / 200);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    kn.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    kn.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n    kn.addEventListener(\"dblclick\", function () { commit(spec.def); });\n    kn.addEventListener(\"wheel\", function (e) {\n      var range = spec.max - spec.min;\n      commit(cur - Math.sign(e.deltaY) * range * 0.02);\n      e.preventDefault();\n    }, { passive: false });\n\n    commit(spec.def);\n  }\n\n  function setStateFor(idx, v) {\n    if (idx === 0) state.rate = v;\n    else if (idx === 1) state.depth = v;\n    else if (idx === 3) state.stereo = v;\n    else if (idx === 4) state.mix = v;\n  }\n\n  // ---- shape selector ---------------------------------------------\n  var shapeSvgs = [\n    // sine\n    '<svg width=\"34\" height=\"20\" viewBox=\"0 0 34 20\"><path d=\"M2 10 Q8 0 13 10 T24 10 T32 10\"/></svg>',\n    // triangle\n    '<svg width=\"34\" height=\"20\" viewBox=\"0 0 34 20\"><polyline points=\"2,18 9,2 17,18 25,2 32,18\"/></svg>',\n    // square\n    '<svg width=\"34\" height=\"20\" viewBox=\"0 0 34 20\"><polyline points=\"2,18 2,3 12,3 12,18 22,18 22,3 32,3\"/></svg>',\n    // ramp\n    '<svg width=\"34\" height=\"20\" viewBox=\"0 0 34 20\"><polyline points=\"2,18 12,3 12,18 22,3 22,18 32,3\"/></svg>'\n  ];\n\n  var shapesEl = document.getElementById(\"shapes\");\n  var shapeBtns = [];\n  function selectShape(i) {\n    state.shape = i;\n    for (var k = 0; k < shapeBtns.length; k++) {\n      shapeBtns[k].classList.toggle(\"active\", k === i);\n    }\n    bridge.setParam(2, i); // real value 0..3\n  }\n  SHAPES.forEach(function (nm, i) {\n    var b = document.createElement(\"div\");\n    b.className = \"shape-btn\";\n    b.title = nm;\n    b.innerHTML = shapeSvgs[i];\n    b.addEventListener(\"click\", function () { selectShape(i); });\n    b.addEventListener(\"dblclick\", function () { selectShape(0); });\n    shapesEl.appendChild(b);\n    shapeBtns.push(b);\n  });\n\n  // ---- animated lamp + see-saw meter ------------------------------\n  var lampGlow = document.querySelector(\".lamp-glow\");\n  var lamp = document.querySelector(\".lamp\");\n  var fillL = document.getElementById(\"fillL\");\n  var fillR = document.getElementById(\"fillR\");\n  var phase = 0;\n  var cellL = 1, cellR = 1;\n  var lastT = 0;\n\n  function lfo(p, shape) {\n    if (shape === 0) return 0.5 - 0.5 * Math.cos(2 * Math.PI * p);\n    if (shape === 1) return p < 0.5 ? p * 2 : 2 - p * 2;\n    if (shape === 2) return p < 0.5 ? 1 : 0;\n    return 1 - p;\n  }\n\n  function frame(t) {\n    if (document.hidden) { lastT = t; requestAnimationFrame(frame); return; }\n    var dt = lastT ? Math.min(0.05, (t - lastT) / 1000) : 0.016;\n    lastT = t;\n\n    var hz = 0.1 + state.rate * state.rate * 11.9;\n    phase += hz * dt;\n    phase -= Math.floor(phase);\n\n    var pr = phase + 0.5 * state.stereo;\n    pr -= Math.floor(pr);\n\n    var bL = lfo(phase, state.shape);\n    var bR = lfo(pr, state.shape);\n    // cell lag (visual, eased)\n    var lag = Math.min(1, (25 + hz * 16) * dt * 0.6);\n    cellL += lag * (bL - cellL);\n    cellR += lag * (bR - cellR);\n\n    var gL = (1 - state.depth) + state.depth * cellL;\n    var gR = (1 - state.depth) + state.depth * cellR;\n    gL *= state.mix; gR *= state.mix;\n    gL += (1 - state.mix); gR += (1 - state.mix);\n\n    // lamp tracks the mono brightness when mono, the L cell when panning\n    var lampB = state.stereo < 0.5 ? cellL : (cellL + cellR) * 0.5;\n    lampB = (1 - state.depth) + state.depth * lampB;\n    var lv = (0.18 + lampB * 0.82);\n    lampGlow.style.setProperty(\"--lamp\", lv.toFixed(3));\n    lamp.style.setProperty(\"--lamp\", lv.toFixed(3));\n\n    fillL.style.width = (8 + gL * 92).toFixed(1) + \"%\";\n    fillR.style.width = (8 + gR * 92).toFixed(1) + \"%\";\n\n    requestAnimationFrame(frame);\n  }\n\n  // ---- init --------------------------------------------------------\n  function boot() {\n    KNOBS.forEach(makeKnob);\n    selectShape(0);\n    requestAnimationFrame(frame);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  OPTO TREM — optical multi-shape stereo tremolo (clean amplitude mod)\n//  A photocell-style amplitude modulator: an LFO drives a smoothed\n//  \"lamp brightness\" that opens/closes a gain cell. The cell smoothing\n//  models the lag of a real photo-resistor (LDR), so even a square LFO\n//  pulses musically rather than clicking. A selectable LFO SHAPE\n//  (sine / triangle / square / ramp), variable Rate and Depth, and a\n//  Stereo control that morphs from a mono tremolo to an auto-pan where\n//  the L/R cells run in anti-phase to sweep the image side to side.\n//  Pure algorithm, no samples, fully clean (no distortion).\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// LFO phase (0..1) shared; the R channel reads an offset phase in pan mode.\nlet phase: f32 = 0.0;\n// Per-channel smoothed photocell \"brightness\" (the LDR lag state).\nconst cellState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_RATE:   i32 = 0; // 0..1 -> 0.1 .. 12 Hz\nconst P_DEPTH:  i32 = 1; // 0..1 modulation depth\nconst P_SHAPE:  i32 = 2; // 0..3 stepped: 0 sine, 1 triangle, 2 square, 3 ramp\nconst P_STEREO: i32 = 3; // 0..1: 0 mono trem -> 1 auto-pan (anti-phase)\nconst P_MIX:    i32 = 4; // 0..1 dry/wet\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  phase = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) cellState[c] = 1.0;\n  params[P_RATE] = 0.4;\n  params[P_DEPTH] = 0.7;\n  params[P_SHAPE] = 0.0;\n  params[P_STEREO] = 0.0;\n  params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Evaluate the LFO shape at phase p (0..1) -> a unipolar 0..1 brightness,\n// where 1 = lamp fully bright (unity gain) and 0 = fully dimmed.\n@inline function lfoShape(p: f32, shape: i32): f32 {\n  if (shape == 0) {\n    // sine: smooth, glassy\n    return f32(0.5 - 0.5 * Mathf.cos(PI2 * p));\n  } else if (shape == 1) {\n    // triangle: linear up/down\n    return f32(p < 0.5 ? p * 2.0 : 2.0 - p * 2.0);\n  } else if (shape == 2) {\n    // square: on/off (cell lag softens the edges)\n    return f32(p < 0.5 ? 1.0 : 0.0);\n  } else {\n    // ramp (sawtooth): bright snap then linear fade down\n    return f32(1.0 - p);\n  }\n}\n\nexport function process(n: i32): void {\n  const rateN: f32  = clampf(params[P_RATE], 0.0, 1.0);\n  const depth: f32  = clampf(params[P_DEPTH], 0.0, 1.0);\n  const stereo: f32 = clampf(params[P_STEREO], 0.0, 1.0);\n  const mix: f32    = clampf(params[P_MIX], 0.0, 1.0);\n\n  // stepped shape selector -> integer 0..3\n  let shapeI: i32 = i32(clampf(params[P_SHAPE], 0.0, 3.0) + 0.5);\n  if (shapeI < 0) shapeI = 0;\n  if (shapeI > 3) shapeI = 3;\n\n  // Rate maps 0.1..12 Hz (perceptual, slightly curved for slow-end control)\n  const rate: f32 = f32(0.1 + rateN * rateN * 11.9);\n  const inc: f32 = rate / sampleRate;\n\n  // Photocell lag: faster smoothing as rate rises so fast settings stay\n  // crisp while slow settings stay buttery. ~25..220 Hz one-pole corner.\n  const lagHz: f32 = f32(25.0 + rate * 16.0);\n  const cellCoef: f32 = f32(1.0 - Mathf.exp(-PI2 * lagHz / sampleRate));\n\n  // In pan mode the R channel LFO is phase-shifted toward anti-phase (0.5).\n  const phaseOffR: f32 = f32(0.5 * stereo);\n  // Gentle gain make-up so a deep tremolo doesn't feel quieter overall.\n  const makeup: f32 = f32(1.0 + 0.35 * depth);\n\n  let cl: f32 = cellState[0];\n  let cr: f32 = cellState[1];\n  let ph: f32 = phase;\n\n  for (let f = 0; f < n; f++) {\n    // target brightness for each cell from the LFO\n    const bL: f32 = lfoShape(ph, shapeI);\n    let pr: f32 = ph + phaseOffR;\n    if (pr >= 1.0) pr -= 1.0;\n    const bR: f32 = lfoShape(pr, shapeI);\n\n    // smooth toward target (LDR lag)\n    cl = f32(cl + cellCoef * (bL - cl));\n    cr = f32(cr + cellCoef * (bR - cr));\n\n    // map brightness to a gain that dips by `depth` at minimum brightness\n    const gL: f32 = f32((1.0 - depth) + depth * cl);\n    const gR: f32 = f32((1.0 - depth) + depth * cr);\n\n    const xL: f32 = inBuf[f];\n    const xR: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : xL;\n\n    const wL: f32 = f32(xL * gL * makeup);\n    const wR: f32 = f32(xR * gR * makeup);\n\n    outBuf[f] = f32(xL * (1.0 - mix) + wL * mix);\n    outBuf[MAX_FRAMES + f] = f32(xR * (1.0 - mix) + wR * mix);\n\n    ph += inc;\n    if (ph >= 1.0) ph -= 1.0;\n  }\n\n  cellState[0] = cl;\n  cellState[1] = cr;\n  phase = ph;\n}\n",
  "publishedAt": 1751000105000
}