    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "HPF",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Env Amount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Chorus",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
