    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Env Amount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Detune",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.8
