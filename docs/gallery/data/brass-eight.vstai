  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Brass Eight</title>\n<style>\n  :root{ --acc:#ffae42; --acc2:#ff5a6a; --bg0:#0e0905; --bg1:#1c1208; --ink:#f6e9d8; --dim:#a8896a; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#2e1d0c 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#33240f,#140c06); border:1px solid rgba(255,174,66,.2);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,225,180,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px;\n    background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.4s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:92px; border-radius:9px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#160f06,#1c1208); border:1px solid rgba(255,174,66,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .mode{ position:absolute; right:12px; top:8px; font-size:10px; letter-spacing:.14em; color:var(--acc); z-index:2; font-weight:700; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,200,140,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,174,66,.6)); }\n  .pcap{ fill:#1a1106; stroke:rgba(255,174,66,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,174,66,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,174,66,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">BRASS&nbsp;EIGHT</span><span class=\"sub\">fat analog poly · multimode</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">FILTER</div><div class=\"mode\" id=\"modelbl\">LOW-PASS</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.62},{name:\"Reso\",idx:1,def:0.4},{name:\"Mode\",idx:2,def:0.0},{name:\"Env\",idx:3,def:0.55},{name:\"Detune\",idx:4,def:0.3},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var modelbl=document.getElementById(\"modelbl\");\n  function setMode(){ var m=vals[2]; modelbl.textContent = m<0.34?\"LOW-PASS\":(m<0.67?\"BAND-PASS\":\"HIGH-PASS\"); }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffae42\"/><stop offset=\"1\" stop-color=\"#ff5a6a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle>'+\n      '<line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=Math.round(v*100)+\"%\"; if(p.idx===2) setMode(); }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  // filter-response curve morphing LP->BP->HP\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H); var cut=vals[0], reso=vals[1], mode=vals[2]; var base=H-12;\n    ctx.strokeStyle=\"rgba(255,174,66,0.10)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(0,base); ctx.lineTo(W,base); ctx.stroke();\n    var fcx=cut*W*0.85; var peak=1+reso*2.4;\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=2){ var f=x/W; var fc=cut*0.85;\n      var lp=1/(1+Math.pow(Math.max(0,(f-fc))/0.10,2.2));\n      var hpf=1/(1+Math.pow(Math.max(0,(fc-f))/0.10,2.2));\n      var bp=Math.exp(-Math.pow((f-fc)/0.08,2));\n      var wL=Math.max(0,1-mode*2), wB=1-Math.abs(mode-0.5)*2, wH=Math.max(0,mode*2-1);\n      var mag=(lp*wL+bp*wB+hpf*wH);\n      var bump=peak*Math.exp(-Math.pow((f-fc)/0.05,2))*0.3;\n      mag=Math.min(1.4,mag+bump);\n      var y=base - mag*(H*0.62);\n      if(x===0) ctx.moveTo(x,y); else ctx.lineTo(x,y); }\n    ctx.strokeStyle=\"rgba(255,174,66,0.95)\"; ctx.lineWidth=2.4; ctx.shadowColor=\"#ff5a6a\"; ctx.shadowBlur=9; ctx.stroke(); ctx.shadowBlur=0;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; setMode(); P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BRASS EIGHT — a fat 8-voice analog poly (Oberheim OB-Xa lineage).\n//  Distinct from the OB-X-style Oberon by a brighter, harder character and\n//  a MULTIMODE filter that morphs low-pass -> band-pass -> high-pass: two\n//  detuned oscillators (saw + pulse) per voice for a thick unison, a\n//  resonant SVF whose Mode control blends LP/BP/HP, its own filter\n//  envelope, and a unison Detune. Built for big brass stabs and bright\n//  pads. No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst vP1: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vP2: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_CUTOFF: i32 = 0;\nconst P_RESO: i32 = 1;\nconst P_MODE: i32 = 2;   // LP -> BP -> HP morph\nconst P_ENV: i32 = 3;\nconst P_DETUNE: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vP1[i] = 0.0; vP2[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_CUTOFF] = 0.62; params[P_RESO] = 0.4; params[P_MODE] = 0.0; params[P_ENV] = 0.55; params[P_DETUNE] = 0.3; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vP1[slot] = 0.0; vP2[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0);\n  vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const modeN: f32 = clampf(params[P_MODE], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.004 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.35 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate)));\n  const baseCut: f32 = 55.0 * f32(Mathf.exp(cutoffN * 5.3));\n  const envSpan: f32 = envN * 8000.0;\n  const k: f32 = 2.0 - 1.92 * resoN;\n  const det: f32 = 1.0 + detuneN * 0.03;   // up to ~+/-3% detune (fat)\n  // multimode blend weights: mode 0=LP, 0.5=BP, 1=HP\n  const wLP: f32 = clampf(1.0 - modeN * 2.0, 0.0, 1.0);\n  const wBP: f32 = 1.0 - f32(Mathf.abs(modeN - 0.5)) * 2.0;\n  const wHP: f32 = clampf(modeN * 2.0 - 1.0, 0.0, 1.0);\n  const out: f32 = level * 0.4;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      const fr: f32 = vFreq[s];\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      // 2 detuned osc: saw + pulse\n      let p1: f32 = vP1[s] + fr / sampleRate; if (p1 >= 1.0) p1 -= 1.0; vP1[s] = p1;\n      let p2: f32 = vP2[s] + (fr * det) / sampleRate; if (p2 >= 1.0) p2 -= 1.0; vP2[s] = p2;\n      const saw: f32 = p1 * 2.0 - 1.0;\n      const pulse: f32 = p2 < 0.45 ? 1.0 : -1.0;\n      let osc: f32 = (saw + pulse * 0.7) * 0.5;\n      // SVF multimode\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const filt: f32 = lpN * wLP + bpN * wBP + hp * wHP;\n      mix += filt * vAmp[s] * vVel[s];\n    }\n    let o: f32 = mix * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000158000
}