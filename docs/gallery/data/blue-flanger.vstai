  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Blue Flanger</title>\n<style>\n  :root{ --acc:#3a8aff; --acc2:#5ae0d0; --bg0:#060a14; --bg1:#0b1428; --ink:#e6eefb; --dim:#6f83a8; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#122344 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#0e1c38,#060a14); border:1px solid rgba(58,138,255,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(230,238,251,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc2); box-shadow:0 0 10px var(--acc2); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:104px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0a1428,#060b16); border:1px solid rgba(58,138,255,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(210,224,248,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(58,138,255,.6)); }\n  .pcap{ fill:#0a1020; stroke:rgba(58,138,255,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(58,138,255,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(58,138,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">BLUE&nbsp;FLANGER</span><span class=\"sub\">deep stereo flange</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">COMB&nbsp;SWEEP</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Rate\",idx:0,def:0.28},{name:\"Depth\",idx:1,def:0.7},{name:\"Feedbk\",idx:2,def:0.6},{name:\"Manual\",idx:3,def:0.25},{name:\"Width\",idx:4,def:0.5},{name:\"Mix\",idx:5,def:0.5}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#3a8aff\"/><stop offset=\"1\" stop-color=\"#5ae0d0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function comb(x,delay,fb){ // magnitude response of feedforward+feedback comb at freq bin x(0..1)\n    var w=x*Math.PI*delay; var c=Math.cos(w);\n    return (1+fb)*0.5*(1+c)/(1+fb*fb-2*fb*c*0.9+0.05); }\n  function frame(ts){ ctx.clearRect(0,0,W,H); var rate=vals[0], depth=vals[1], fb=vals[2], man=vals[3], width=vals[4];\n    var lfo=0.5+0.5*Math.sin(ts/1000*(0.05+rate*6)); var tri=lfo;\n    var delay=(2+man*30)+(depth*40)*tri;   // notch spacing in display units\n    var baseY=H-14, top=20;\n    // draw comb response curves for L (blue) and R (teal, phase-offset by Width)\n    for(var ch=0;ch<2;ch++){ var lfo2=0.5+0.5*Math.sin(ts/1000*(0.05+rate*6)+(ch?width*Math.PI:0));\n      var dly=(2+man*30)+(depth*40)*lfo2;\n      ctx.beginPath();\n      for(var xx=0;xx<=W;xx+=2){ var t=xx/W; var m=comb(t,dly,fb*0.9); var y=baseY-(m/(1+fb))* (baseY-top); if(xx===0)ctx.moveTo(xx,y); else ctx.lineTo(xx,y); }\n      ctx.strokeStyle=ch? \"rgba(90,224,208,0.7)\":\"rgba(58,138,255,0.85)\"; ctx.lineWidth=ch?1.4:1.8;\n      ctx.shadowColor=ch?\"#5ae0d0\":\"#3a8aff\"; ctx.shadowBlur=6; ctx.stroke(); ctx.shadowBlur=0; }\n    // fill under blue curve faintly\n    ctx.globalAlpha=0.08; ctx.fillStyle=\"#3a8aff\"; ctx.fillRect(0,top,W,baseY-top); ctx.globalAlpha=1;\n    // stereo L/R orbit indicator (top-right)\n    var ox=W-24, oy=18, rr=8; ctx.strokeStyle=\"rgba(120,150,200,0.25)\"; ctx.beginPath(); ctx.arc(ox,oy,rr,0,Math.PI*2); ctx.stroke();\n    var aL=ts/1000*(0.05+rate*6)*2; ctx.fillStyle=\"#3a8aff\"; ctx.beginPath(); ctx.arc(ox+Math.cos(aL)*rr,oy+Math.sin(aL)*rr,2.4,0,Math.PI*2); ctx.fill();\n    ctx.fillStyle=\"#5ae0d0\"; ctx.beginPath(); ctx.arc(ox+Math.cos(aL+width*Math.PI)*rr,oy+Math.sin(aL+width*Math.PI)*rr,2.4,0,Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  BLUE FLANGER — a deep, resonant, wide-stereo flanger (Boss BF-2\n//  lineage). Distinct from the factory's other flangers by its lush,\n//  watery voice: a long swept fractional delay (~0.3..12 ms) with a\n//  strong RESONANT positive feedback that can ring into metallic\n//  territory, and a stereo WIDTH control that offsets the LFO between\n//  channels for the wide \"underwater\" spread. Triangle LFO around a\n//  Manual base delay. Pure algorithm, no samples.\n//  Controls: Rate, Depth, Feedback, Manual, Width, Mix.\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst DLY_LEN: i32 = 2048;\nconst dline:  StaticArray<f32> = new StaticArray<f32>(DLY_LEN * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst writePos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst lfoPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst fbState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst P_RATE: i32 = 0; const P_DEPTH: i32 = 1; const P_FB: i32 = 2; const P_MANUAL: i32 = 3; const P_WIDTH: i32 = 4; const P_MIX: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) { writePos[c] = 0; lfoPhase[c] = 0.0; fbState[c] = 0.0; }\n  for (let i = 0; i < DLY_LEN * MAX_CHANNELS; i++) dline[i] = 0.0;\n  params[P_RATE] = 0.28; params[P_DEPTH] = 0.7; params[P_FB] = 0.6; params[P_MANUAL] = 0.25; params[P_WIDTH] = 0.5; params[P_MIX] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function process(n: i32): void {\n  const rateN: f32   = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32  = clampf(params[P_DEPTH], 0.0, 1.0);\n  const fbN: f32     = clampf(params[P_FB], 0.0, 1.0);\n  const manualN: f32 = clampf(params[P_MANUAL], 0.0, 1.0);\n  const widthN: f32  = clampf(params[P_WIDTH], 0.0, 1.0);\n  const mixN: f32    = clampf(params[P_MIX], 0.0, 1.0);\n\n  const rate: f32 = 0.05 + rateN * 6.0;                    // Hz\n  const lfoInc: f32 = rate / sampleRate;\n  const baseMs: f32 = 0.3 + manualN * 7.0;\n  const depthMs: f32 = depthN * 5.5;\n  const fb: f32 = fbN * 0.92;                              // resonant positive feedback\n  const wet: f32 = mixN;\n  const dry: f32 = 1.0 - mixN * 0.5;\n  const chOff: f32 = widthN * 0.5;                         // stereo LFO phase offset\n\n  for (let c = 0; c < channels; c++) {\n    let wp: i32 = writePos[c];\n    let lp: f32 = lfoPhase[c] + (c == 1 ? chOff : 0.0); if (lp >= 1.0) lp -= 1.0;\n    let fbs: f32 = fbState[c];\n    const base: i32 = c * DLY_LEN;\n    for (let i = 0; i < n; i++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + i];\n      // triangle LFO 0..1\n      const tri: f32 = lp < 0.5 ? (lp * 2.0) : (2.0 - lp * 2.0);\n      const dms: f32 = baseMs + depthMs * tri;\n      let dsamp: f32 = dms * 0.001 * sampleRate;\n      if (dsamp < 1.0) dsamp = 1.0; if (dsamp > f32(DLY_LEN - 2)) dsamp = f32(DLY_LEN - 2);\n      // write with feedback\n      dline[base + wp] = x + fbs * fb;\n      // fractional read\n      let rp: f32 = f32(wp) - dsamp; if (rp < 0.0) rp += f32(DLY_LEN);\n      let ri0: i32 = i32(rp); const frac: f32 = rp - f32(ri0);\n      if (ri0 >= DLY_LEN) ri0 -= DLY_LEN;\n      let ri1: i32 = ri0 + 1; if (ri1 >= DLY_LEN) ri1 -= DLY_LEN;\n      const dl: f32 = dline[base + ri0] + (dline[base + ri1] - dline[base + ri0]) * frac;\n      fbs = dl;\n      let o: f32 = x * dry + dl * wet;\n      if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n      outBuf[c * MAX_FRAMES + i] = o;\n      wp += 1; if (wp >= DLY_LEN) wp -= DLY_LEN;\n      lp += lfoInc; if (lp >= 1.0) lp -= 1.0;\n    }\n    writePos[c] = wp;\n    lfoPhase[c] = lfoPhase[c] + lfoInc * f32(n);\n    while (lfoPhase[c] >= 1.0) lfoPhase[c] -= 1.0;\n    fbState[c] = fbs;\n  }\n}\n",
  "publishedAt": 1751306600000
}