  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Analog Bucket</title>\n<style>\n  :root{ --acc:#5ad0c4; --acc2:#7a86ff; --bg0:#070d0d; --bg1:#0e1a1c; --ink:#e2f2f0; --dim:#5e8284; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#102a2c 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(94vw,700px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#14302e,#070f0f); border:1px solid rgba(90,208,196,.2); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(200,255,245,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.4s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#0a1c1a,#0a1313); border:1px solid rgba(90,208,196,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(180,230,225,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(90,208,196,.6)); }\n  .pcap{ fill:#0a1614; stroke:rgba(90,208,196,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(90,208,196,.1); padding:1px 8px; border-radius:7px; border:1px solid rgba(90,208,196,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">ANALOG&nbsp;BUCKET</span><span class=\"sub\">bbd delay · chorus</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">BBD REPEATS</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Time\",idx:0,def:0.3},{name:\"Feedback\",idx:1,def:0.4},{name:\"Mod\",idx:2,def:0.35},{name:\"Tone\",idx:3,def:0.5},{name:\"Mix\",idx:4,def:0.4}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#5ad0c4\"/><stop offset=\"1\" stop-color=\"#7a86ff\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle><circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle><line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2));\n      val.textContent=(p.name===\"Time\")?Math.round(3+v*v*597)+\" ms\":Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def); return {render:render};\n  });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var time=vals[0], fb=vals[1], mod=vals[2], tone=vals[3]; var mid=H*0.6;\n    ctx.strokeStyle=\"rgba(90,208,196,0.10)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke();\n    // bucket \"taps\" marching right, darkening (tone), with mod wobble\n    var spacing=(W-30)*(0.12+time*0.6)/4;\n    for(var k=0;k<8;k++){ var x=14+spacing*(k+1); if(x>W-6) break;\n      var amp=Math.pow(0.5+fb*0.45,k+1); var wob=Math.sin(ts/300+k)*mod*8;\n      var h=amp*(H*0.34); var col=\"rgba(\"+Math.round(90+(1-tone)*40)+\",\"+Math.round(208*tone+60)+\",196,\"+amp+\")\";\n      ctx.fillStyle=col; ctx.shadowColor=\"#5ad0c4\"; ctx.shadowBlur=6*amp; ctx.fillRect(x-2, mid-h+wob, 4, h); ctx.shadowBlur=0; }\n    // input marker\n    ctx.fillStyle=\"rgba(122,134,255,0.8)\"; ctx.fillRect(11,mid-H*0.34,4,H*0.34);\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  ANALOG BUCKET — a generic bucket-brigade (BBD) model: short, dark,\n//  companded delay that doubles as a chorus/vibrato. A modulated BBD delay\n//  line with progressively darker repeats and gentle compander grit; at\n//  short times + high Mod it's a lush chorus, at longer times a warm\n//  analog echo. Controls: Time, Feedback, Mod (chorus depth), Tone (BBD\n//  darkness), Mix. No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst DLEN: i32 = 32768; const DMASK: i32 = DLEN - 1;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst dl: StaticArray<f32> = new StaticArray<f32>(DLEN);\nlet wp: i32 = 0;\nlet lpFb: f32 = 0.0;\nlet lfoPh: f32 = 0.0;\nlet curD: f32 = 1000.0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_TIME: i32 = 0; const P_FB: i32 = 1; const P_MOD: i32 = 2; const P_TONE: i32 = 3; const P_MIX: i32 = 4;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function satf(x: f32): f32 { const c: f32 = clampf(x, -2.5, 2.5); return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c)); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  wp = 0; lpFb = 0.0; lfoPh = 0.0; curD = 0.02 * sampleRate;\n  for (let i = 0; i < DLEN; i++) dl[i] = 0.0;\n  params[P_TIME] = 0.3; params[P_FB] = 0.4; params[P_MOD] = 0.35; params[P_TONE] = 0.5; params[P_MIX] = 0.4;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const timeN: f32 = clampf(params[P_TIME], 0.0, 1.0);\n  const fbN: f32 = clampf(params[P_FB], 0.0, 1.0);\n  const modN: f32 = clampf(params[P_MOD], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // BBD range: ~3 ms (chorus) .. ~600 ms (echo)\n  const tgtD: f32 = (0.003 + timeN * timeN * 0.6) * sampleRate;\n  const fb: f32 = fbN * 0.9;\n  const damp: f32 = 0.05 + (1.0 - toneN) * 0.8;          // darker = more BBD HF loss\n  const modDepth: f32 = modN * 0.004 * sampleRate;        // up to ~4 ms wobble\n  const lfoInc: f32 = 0.9 / sampleRate * 6.2831853;\n  const dry: f32 = 1.0 - mix * 0.5;\n  const wet: f32 = mix;\n  const stereo: i32 = 1;\n\n  for (let i = 0; i < n; i++) {\n    curD += (tgtD - curD) * 0.0005;\n    lfoPh += lfoInc; if (lfoPh > 6.2831853) lfoPh -= 6.2831853;\n    const d: f32 = curD + modDepth * f32(Mathf.sin(lfoPh));\n    const xl: f32 = inBuf[i];\n    const xr: f32 = stereo ? inBuf[MAX_FRAMES + i] : xl;\n    const x: f32 = (xl + xr) * 0.5;\n\n    const rp: f32 = f32(wp) - d;\n    let ri: i32 = i32(rp); const fr: f32 = rp - f32(ri);\n    const a0: i32 = ri & DMASK; const a1: i32 = (ri + 1) & DMASK;\n    let y: f32 = dl[a0] + (dl[a1] - dl[a0]) * fr;\n    // BBD darkening + compander grit in the feedback\n    lpFb += (y - lpFb) * (1.0 - damp); const yd: f32 = lpFb;\n    dl[wp] = clampf(satf(x + yd * fb), -1.5, 1.5);\n    wp = (wp + 1) & DMASK;\n\n    // stereo: slight L/R offset read for width\n    const rp2: f32 = f32(wp) - d * 0.97;\n    let ri2: i32 = i32(rp2); const fr2: f32 = rp2 - f32(ri2);\n    const b0: i32 = ri2 & DMASK; const b1: i32 = (ri2 + 1) & DMASK;\n    const y2: f32 = dl[b0] + (dl[b1] - dl[b0]) * fr2;\n\n    let ol: f32 = xl * dry + y * wet;\n    let orr: f32 = xr * dry + y2 * wet;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[i] = ol; outBuf[MAX_FRAMES + i] = orr;\n  }\n}\n",
  "publishedAt": 1751000174000
}