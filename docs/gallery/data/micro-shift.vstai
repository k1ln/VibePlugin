{
  "format": 1,
  "name": "Micro Shift",
  "isInstrument": false,
  "explanation": "A micro-pitch detune doubler that fattens and widens a source into a lush stereo double. Two pitch-shifted voices are detuned a few cents up and down (below a semitone), each given its own short delay tap, panned hard left/right and blended with the dry signal. Fractional delay-line pitch shifting keeps it smooth with no zipper noise. Controls: Detune (cent spread), Delay (tap time), Width (stereo spread), Feedback (subtle regen) and dry/wet Mix.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Delay",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Width",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.8
    },
    {
      "name": "Feedback",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Micro Shift</title>\n<style>\n:root{\n  --ac:#3de0c4;        /* teal */\n  --ac2:#6a8cff;       /* indigo */\n  --rack:#11161f;\n  --rack2:#0a0e15;\n  --panel:#161d29;\n  --ink:#cfe9f2;\n  --dim:#7f93a8;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(130% 100% at 50% -20%,#16202e 0%,#0a0e15 55%,#05070b 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:20px;min-height:100%;\n}\n\n/* ============ the rack unit ============ */\n.rack{\n  position:relative;\n  width:min(640px,94vw);\n  border-radius:16px;\n  padding:18px 20px 22px;\n  background:\n    linear-gradient(180deg,#1b2433 0%,var(--rack) 16%,var(--rack2) 100%);\n  box-shadow:\n    0 40px 90px -28px rgba(0,0,0,.85),\n    0 1px 0 rgba(255,255,255,.10) inset,\n    0 -30px 60px -30px rgba(0,0,0,.7) inset,\n    0 0 0 1px rgba(0,0,0,.6),\n    0 0 0 4px #0c1119,\n    0 0 0 5px rgba(61,224,196,.06);\n  animation:rise .7s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(22px) scale(.97)}to{opacity:1;transform:none}}\n/* rack ears with rivets */\n.ear{position:absolute;top:0;bottom:0;width:14px;\n  background:linear-gradient(90deg,#222d3d,#10151e);}\n.ear.l{left:0;border-radius:16px 0 0 16px}\n.ear.r{right:0;border-radius:0 16px 16px 0}\n.rivet{position:absolute;left:50%;width:7px;height:7px;margin-left:-3.5px;border-radius:50%;\n  background:radial-gradient(circle at 35% 30%,#cfe0ec,#5a6a7a 55%,#283340);\n  box-shadow:0 1px 1px rgba(0,0,0,.6),0 0 0 1px rgba(0,0,0,.4) inset}\n.rivet.a{top:14px}.rivet.b{bottom:14px}\n/* faint brushed sheen */\n.rack::before{content:\"\";position:absolute;inset:0;border-radius:16px;pointer-events:none;\n  background:\n    repeating-linear-gradient(98deg,rgba(255,255,255,.02) 0 1px,transparent 1px 3px),\n    radial-gradient(120% 60% at 25% 0%,rgba(120,200,255,.10),transparent 55%);\n  mix-blend-mode:screen}\n\n/* ============ header ============ */\n.head{display:flex;align-items:flex-end;justify-content:space-between;\n  margin:0 8px 14px;padding-left:6px}\n.brand{font-size:8.5px;letter-spacing:.4em;color:var(--dim);text-transform:uppercase}\nh1{margin:2px 0 0;font-size:23px;font-weight:800;letter-spacing:.04em;line-height:1;\n  background:linear-gradient(95deg,var(--ac) 0%,#bff6ec 35%,var(--ac2) 100%);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  filter:drop-shadow(0 2px 8px rgba(61,224,196,.25))}\n.tag{font-size:8px;letter-spacing:.26em;color:var(--dim);text-transform:uppercase;margin-top:4px}\n.power{display:flex;align-items:center;gap:8px}\n.led{width:9px;height:9px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#d9fff6,var(--ac) 50%,#0c4a40 90%);\n  box-shadow:0 0 12px var(--ac),0 0 3px #fff inset;animation:ledp 2.4s ease-in-out infinite}\n@keyframes ledp{0%,100%{opacity:.7;box-shadow:0 0 7px var(--ac),0 0 3px #fff inset}\n  50%{opacity:1;box-shadow:0 0 16px var(--ac),0 0 5px #fff inset}}\n.modelno{font-size:8px;letter-spacing:.2em;color:var(--dim);text-transform:uppercase}\n\n/* ============ stereo width field (signature visual) ============ */\n.field{\n  position:relative;height:150px;margin:0 6px 16px;border-radius:12px;overflow:hidden;\n  background:\n    radial-gradient(120% 130% at 50% 120%,#0e2a30 0%,#091018 65%,#05080d 100%);\n  box-shadow:0 0 0 1px rgba(0,0,0,.6),\n             0 0 0 2px rgba(61,224,196,.07),\n             inset 0 2px 14px rgba(0,0,0,.9),\n             inset 0 0 50px rgba(61,224,196,.06);\n}\n.field svg{position:absolute;inset:0;width:100%;height:100%}\n.field::after{content:\"\";position:absolute;inset:0;pointer-events:none;\n  background:linear-gradient(180deg,rgba(255,255,255,.07),transparent 26%)}\n.scan{position:absolute;inset:0;pointer-events:none;\n  background:repeating-linear-gradient(0deg,rgba(120,200,255,.04) 0 2px,transparent 2px 4px);\n  opacity:.5}\n/* axis labels */\n.flbl{position:absolute;font-size:7.5px;letter-spacing:.22em;color:var(--dim);\n  text-transform:uppercase;opacity:.8}\n.flbl.l{left:8px;top:6px}.flbl.r{right:8px;top:6px}\n.flbl.c{left:50%;transform:translateX(-50%);bottom:5px}\n\n.gridln{stroke:rgba(120,200,255,.10);stroke-width:1}\n.axis{stroke:rgba(61,224,196,.18);stroke-width:1}\n.dryline{fill:none;stroke:rgba(207,233,242,.45);stroke-width:1.6;stroke-linecap:round}\n.voice0{fill:none;stroke:var(--ac);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;\n  filter:drop-shadow(0 0 5px var(--ac))}\n.voice1{fill:none;stroke:var(--ac2);stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;\n  filter:drop-shadow(0 0 5px var(--ac2))}\n.dot{filter:drop-shadow(0 0 6px currentColor)}\n.cents{font:700 9px ui-sans-serif,system-ui;letter-spacing:.04em;\n  font-variant-numeric:tabular-nums}\n\n/* ============ knob deck ============ */\n.deck{display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin:0 4px}\n.pot{display:flex;flex-direction:column;align-items:center;gap:6px;\n  animation:pop .5s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}\n.knob{position:relative;width:74px;height:74px;cursor:ns-resize;touch-action:none;user-select:none}\n/* outer tick ring */\n.ring{position:absolute;inset:-2px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,rgba(170,210,235,.40) 0 1deg,transparent 1deg 16.875deg);\n  -webkit-mask:radial-gradient(circle,transparent 36px,#000 37px,#000 40px,transparent 41px);\n  mask:radial-gradient(circle,transparent 36px,#000 37px,#000 40px,transparent 41px)}\n/* glowing value arc */\n.arc{position:absolute;inset:2px;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--ac) 0,var(--ac2) calc(var(--n)*270deg),\n            rgba(255,255,255,.05) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*7px) var(--ac));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1)}\n.cap{position:absolute;top:10px;left:10px;width:54px;height:54px;border-radius:50%;\n  background:radial-gradient(circle at 50% 26%,#2a3646 0%,#141b25 62%,#0a0f16 100%);\n  box-shadow:inset 0 2px 6px rgba(255,255,255,.10),\n             inset 0 -6px 14px rgba(0,0,0,.85),\n             0 4px 10px rgba(0,0,0,.55)}\n.cap::after{content:\"\";position:absolute;inset:13px;border-radius:50%;\n  background:radial-gradient(circle at 50% 30%,#33414f,#121822);\n  box-shadow:inset 0 1px 2px rgba(255,255,255,.16)}\n.ptr{position:absolute;top:6px;left:50%;width:3.5px;height:20px;margin-left:-1.75px;border-radius:3px;\n  background:linear-gradient(var(--ac2),var(--ac));\n  box-shadow:0 0 8px var(--ac),0 0 2px #fff;\n  transform-origin:50% 31px;\n  transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.knob.act .cap{box-shadow:inset 0 2px 6px rgba(255,255,255,.10),\n  inset 0 -6px 14px rgba(0,0,0,.85),0 4px 16px rgba(61,224,196,.55)}\n.pname{font-size:9px;font-weight:800;letter-spacing:.16em;color:#0a141c;\n  background:linear-gradient(var(--ac),#8fe9dc);padding:2px 9px;border-radius:999px;\n  text-transform:uppercase;box-shadow:0 1px 0 rgba(255,255,255,.3) inset,0 2px 5px rgba(0,0,0,.4)}\n.pval{font-size:11px;font-weight:800;color:#eafffb;font-variant-numeric:tabular-nums;\n  min-height:13px;text-shadow:0 0 8px rgba(61,224,196,.4)}\n\n@media(max-width:560px){\n  .deck{grid-template-columns:repeat(3,1fr);gap:14px}\n  .knob{width:80px;height:80px}\n}\n</style>\n</head>\n<body>\n<div class=\"rack\">\n  <span class=\"ear l\"><i class=\"rivet a\"></i><i class=\"rivet b\"></i></span>\n  <span class=\"ear r\"><i class=\"rivet a\"></i><i class=\"rivet b\"></i></span>\n\n  <div class=\"head\">\n    <div>\n      <div class=\"brand\">Studio Rack Series</div>\n      <h1>Micro Shift</h1>\n      <div class=\"tag\">Micro-Pitch Detune Doubler</div>\n    </div>\n    <div class=\"power\">\n      <div style=\"text-align:right\">\n        <div class=\"modelno\">MS&middot;3000</div>\n        <div class=\"tag\" style=\"margin-top:2px\">Dual Voice</div>\n      </div>\n      <div class=\"led\" title=\"Powered\"></div>\n    </div>\n  </div>\n\n  <!-- stereo width field: two mirrored detuned voices over a doubled waveform -->\n  <div class=\"field\">\n    <div class=\"scan\"></div>\n    <span class=\"flbl l\">L &middot; Voice &minus;</span>\n    <span class=\"flbl r\">Voice + &middot; R</span>\n    <span class=\"flbl c\">Stereo Width Field</span>\n    <svg viewBox=\"0 0 600 150\" preserveAspectRatio=\"none\">\n      <line class=\"gridln\" x1=\"150\" y1=\"0\" x2=\"150\" y2=\"150\"/>\n      <line class=\"gridln\" x1=\"450\" y1=\"0\" x2=\"450\" y2=\"150\"/>\n      <line class=\"axis\"   x1=\"300\" y1=\"0\" x2=\"300\" y2=\"150\"/>\n      <line class=\"gridln\" x1=\"0\" y1=\"75\" x2=\"600\" y2=\"75\"/>\n      <!-- dry reference (centre) -->\n      <path id=\"dry\" class=\"dryline\" d=\"\"/>\n      <!-- two detuned voices -->\n      <path id=\"v0\" class=\"voice0\" d=\"\"/>\n      <path id=\"v1\" class=\"voice1\" d=\"\"/>\n      <!-- voice position dots on the width field -->\n      <circle id=\"d0\" class=\"dot\" style=\"color:#3de0c4\" cx=\"220\" cy=\"40\" r=\"5\" fill=\"#3de0c4\"/>\n      <circle id=\"d1\" class=\"dot\" style=\"color:#6a8cff\" cx=\"380\" cy=\"40\" r=\"5\" fill=\"#6a8cff\"/>\n      <text id=\"c0\" class=\"cents\" x=\"220\" y=\"26\" fill=\"#3de0c4\" text-anchor=\"middle\">-6c</text>\n      <text id=\"c1\" class=\"cents\" x=\"380\" y=\"26\" fill=\"#6a8cff\" text-anchor=\"middle\">+6c</text>\n    </svg>\n  </div>\n\n  <div class=\"deck\" id=\"deck\"></div>\n</div>\n\n<script>\n(function(){\n  var PARAMS=[\n    {name:\"Detune\",  index:0,min:0,max:1,def:0.4},\n    {name:\"Delay\",   index:1,min:0,max:1,def:0.3},\n    {name:\"Width\",   index:2,min:0,max:1,def:0.8},\n    {name:\"Feedback\",index:3,min:0,max:1,def:0.15},\n    {name:\"Mix\",     index:4,min:0,max:1,def:0.5}\n  ];\n  var state={};\n  var deck=document.getElementById('deck');\n\n  // ----- format helpers (real-world value readouts) -----\n  function fmtVal(p,v){\n    if(p.index===0) return (v*30).toFixed(1)+\" c\";      // total cent spread\n    if(p.index===1) return (1+v*39).toFixed(1)+\" ms\";   // delay tap\n    if(p.index===2) return Math.round(v*100)+\"%\";       // width\n    if(p.index===3) return Math.round(v*100)+\"%\";       // feedback\n    return Math.round(v*100)+\"%\";                       // mix\n  }\n\n  function buildKnob(p,i){\n    var cell=document.createElement('div');\n    cell.className='pot'; cell.style.setProperty('--d',(i*70)+'ms');\n    cell.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\" title=\"Drag vertically &middot; double-click resets\">'+\n        '<i class=\"ring\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>'+\n      '</div>'+\n      '<div class=\"pname\">'+p.name+'</div>'+\n      '<div class=\"pval\"></div>';\n    deck.appendChild(cell);\n\n    var knob=cell.querySelector('.knob');\n    var arc=cell.querySelector('.arc');\n    var ptr=cell.querySelector('.ptr');\n    var val=cell.querySelector('.pval');\n    var v=p.def;\n\n    function norm(){ return (v-p.min)/((p.max-p.min)||1); }\n    function paint(){\n      var nrm=norm();\n      arc.style.setProperty('--n',nrm);\n      ptr.style.setProperty('--n',nrm);\n      val.textContent=fmtVal(p,v);\n      state[p.index]=v;\n      if(window.vstai&&window.vstai.setParam) window.vstai.setParam(p.index,v);\n      onChange();\n    }\n    function setNorm(nrm){\n      nrm=nrm<0?0:nrm>1?1:nrm;\n      v=p.min+(p.max-p.min)*nrm;\n      paint();\n    }\n\n    var drag=false,startY=0,startN=0;\n    knob.addEventListener('pointerdown',function(e){\n      drag=true;startY=e.clientY;startN=norm();\n      knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    knob.addEventListener('pointermove',function(e){\n      if(!drag)return;\n      var speed=e.shiftKey?700:220;\n      setNorm(startN+(startY-e.clientY)/speed);\n    });\n    function end(){drag=false;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){v=p.def;paint();});\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();setNorm(norm()+(e.deltaY<0?0.025:-0.025));\n    },{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setNorm(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setNorm(norm()-0.02);e.preventDefault();}\n    });\n\n    paint();\n  }\n\n  // ----- live visual: two detuned voices drifting on the width field -----\n  var dryEl=document.getElementById('dry');\n  var v0El=document.getElementById('v0');\n  var v1El=document.getElementById('v1');\n  var d0=document.getElementById('d0'), d1=document.getElementById('d1');\n  var c0=document.getElementById('c0'), c1=document.getElementById('c1');\n  var t0=0;\n\n  function onChange(){ /* params changed — animation loop reads state live */ }\n\n  function buildPath(amp,phaseOff,centreY,centsRatio){\n    var pts=[],N=90;\n    for(var x=0;x<=N;x++){\n      var fr=x/N;\n      var ph=fr*Math.PI*5 + phaseOff;\n      // detune makes the two voices slowly drift in/out of phase -> beating\n      var y=Math.sin(ph*centsRatio)*amp;\n      var px=fr*600;\n      var py=centreY - y;\n      pts.push(px.toFixed(1)+\",\"+py.toFixed(1));\n    }\n    return 'M'+pts.join(' L');\n  }\n\n  function frame(){\n    if(document.hidden){ t0+=0.016; requestAnimationFrame(frame); return; }\n    t0+=0.016;\n    var detune=state[0]!=null?state[0]:0.4;\n    var width =state[2]!=null?state[2]:0.8;\n    var mix   =state[4]!=null?state[4]:0.5;\n    var fb    =state[3]!=null?state[3]:0.15;\n\n    var cents=detune*30;            // total spread\n    var half=cents*0.5;\n    // beating speed from detune; voices drift apart over time\n    var driftA=t0*(0.4+detune*2.2);\n    var amp=10+mix*18+fb*8;\n\n    // dry reference centred\n    dryEl.setAttribute('d',buildPath(amp*0.6,t0*0.6,75,1.0));\n    // voice 0 (down) sits in upper area, voice 1 (up) lower — mirrored\n    v0El.setAttribute('d',buildPath(amp,driftA,55,1-half*0.0008));\n    v1El.setAttribute('d',buildPath(amp,-driftA,95,1+half*0.0008));\n\n    // width: dots spread from centre (300) toward L(150)/R(450)\n    var spread=width*150;\n    var bob0=Math.sin(t0*1.3)*6;\n    var bob1=Math.cos(t0*1.1)*6;\n    var x0=300-spread, x1=300+spread;\n    d0.setAttribute('cx',x0.toFixed(1)); d0.setAttribute('cy',(46+bob0).toFixed(1));\n    d1.setAttribute('cx',x1.toFixed(1)); d1.setAttribute('cy',(46+bob1).toFixed(1));\n    var r=3+detune*4+Math.sin(t0*4)*0.6;\n    d0.setAttribute('r',r.toFixed(1)); d1.setAttribute('r',r.toFixed(1));\n    c0.setAttribute('x',x0.toFixed(1)); c0.setAttribute('y',(34+bob0).toFixed(1));\n    c1.setAttribute('x',x1.toFixed(1)); c1.setAttribute('y',(34+bob1).toFixed(1));\n    c0.textContent='-'+half.toFixed(1)+'c';\n    c1.textContent='+'+half.toFixed(1)+'c';\n\n    requestAnimationFrame(frame);\n  }\n\n  PARAMS.forEach(buildKnob);\n\n  function ready(){ requestAnimationFrame(frame); }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MICRO SHIFT — micro-pitch detune doubler / fattener\n//  Two pitch-shifted voices, detuned a few cents UP and DOWN below a\n//  semitone, each with its own short delay tap, panned hard L/R and\n//  blended with the dry signal — turning a mono source into a wide,\n//  thick, shimmering double. Pitch shifting is done with a fractional\n//  delay line read at a drifting rate, using two overlapping read taps\n//  crossfaded by a triangular window to avoid the wrap discontinuity\n//  (classic \"rotating delay\" pitch shifter — no FFT, no zipper noise).\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\n// Pitch-shift delay buffers, one per voice (mono input is summed in).\n// 4096 frames @48k ~= 85 ms — plenty for the grain window + Delay tap.\nconst DLEN: i32 = 4096;\nconst DMASK: i32 = 4095;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Two voice delay lines (voice 0 = pitched DOWN, voice 1 = pitched UP).\nconst ring0: StaticArray<f32> = new StaticArray<f32>(DLEN);\nconst ring1: StaticArray<f32> = new StaticArray<f32>(DLEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet wpos: i32 = 0;            // shared write head for both rings\nlet phase0: f32 = 0.0;        // grain phase for voice 0 (0..1)\nlet phase1: f32 = 0.5;        // grain phase for voice 1 (offset half a window)\nlet fb0: f32 = 0.0;           // feedback memory voice 0\nlet fb1: f32 = 0.0;           // feedback memory voice 1\n\n// smoothed control values (per-sample slew kills zipper noise)\nlet sDetune: f32 = 0.12;\nlet sDelay: f32 = 0.3;\nlet sWidth: f32 = 0.7;\nlet sFb: f32 = 0.0;\nlet sMix: f32 = 0.5;\n\nconst P_DETUNE: i32 = 0;   // 0..1 -> cents spread 0..30 (each voice ±half)\nconst P_DELAY: i32 = 1;    // 0..1 -> tap delay 1..40 ms\nconst P_WIDTH: i32 = 2;    // 0..1 -> stereo spread (0 mono, 1 hard L/R)\nconst P_FEEDBACK: i32 = 3; // 0..1 -> subtle regen 0..0.85\nconst P_MIX: i32 = 4;      // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DLEN; i++) { ring0[i] = 0.0; ring1[i] = 0.0; }\n  wpos = 0;\n  phase0 = 0.0; phase1 = 0.5;\n  fb0 = 0.0; fb1 = 0.0;\n  params[P_DETUNE] = 0.4;\n  params[P_DELAY] = 0.3;\n  params[P_WIDTH] = 0.8;\n  params[P_FEEDBACK] = 0.15;\n  params[P_MIX] = 0.5;\n  sDetune = 0.4; sDelay = 0.3; sWidth = 0.8; sFb = 0.15; sMix = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// linear-interpolated read from a ring buffer at a fractional sample offset\n// `back` (in samples) behind the write head.\n@inline function readRing(ring: StaticArray<f32>, back: f32): f32 {\n  let rp: f32 = f32(wpos) - back;\n  while (rp < 0.0) rp += f32(DLEN);\n  const i0: i32 = i32(rp) & DMASK;\n  const i1: i32 = (i0 + 1) & DMASK;\n  const frac: f32 = rp - Mathf.floor(rp);\n  const a: f32 = ring[i0];\n  const b: f32 = ring[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const detuneT: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const delayT: f32 = clampf(params[P_DELAY], 0.0, 1.0);\n  const widthT: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const fbT: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0);\n  const mixT: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // base delay tap, 1..40 ms, in samples\n  const baseDelay: f32 = (1.0 + delayT * 39.0) * sampleRate * 0.001;\n  // grain window length in samples (fixed-ish, scaled to avoid reading past buffer)\n  const winLen: f32 = sampleRate * 0.040; // 40 ms window\n  // cents spread: 0..30 cents total; each voice gets half, opposite signs\n  const cents: f32 = detuneT * 30.0;\n  const ratioUp: f32 = f32(Mathf.pow(2.0, (cents * 0.5) / 1200.0));\n  const ratioDn: f32 = f32(Mathf.pow(2.0, (-cents * 0.5) / 1200.0));\n  // for a delay-line pitch shifter the read pointer must move at\n  // (1 - ratio) relative to the write head; phase increment per sample:\n  const inc0: f32 = (ratioDn - 1.0) / winLen; // voice 0 (down): ratio<1 -> negative\n  const inc1: f32 = (ratioUp - 1.0) / winLen; // voice 1 (up):   ratio>1 -> positive\n\n  // mono-fold input for the doubler (it widens a mono source)\n  const smoothA: f32 = 0.002; // control slew per sample\n\n  for (let f = 0; f < n; f++) {\n    // smooth controls\n    sDetune += smoothStep(sDetune, detuneT, smoothA);\n    sDelay  += smoothStep(sDelay,  delayT,  smoothA);\n    sWidth  += smoothStep(sWidth,  widthT,  smoothA);\n    sFb     += smoothStep(sFb,     fbT,     smoothA);\n    sMix    += smoothStep(sMix,    mixT,    smoothA);\n\n    const inL: f32 = inBuf[f];\n    const inR: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : inL;\n    const mono: f32 = (inL + inR) * 0.5;\n\n    const fbAmt: f32 = sFb * 0.85;\n\n    // write input (+ feedback) into both rings at the shared write head\n    ring0[wpos] = mono + fb0 * fbAmt;\n    ring1[wpos] = mono + fb1 * fbAmt;\n\n    // advance grain phases (wrap 0..1)\n    phase0 += inc0; if (phase0 >= 1.0) phase0 -= 1.0; if (phase0 < 0.0) phase0 += 1.0;\n    phase1 += inc1; if (phase1 >= 1.0) phase1 -= 1.0; if (phase1 < 0.0) phase1 += 1.0;\n\n    // two overlapping read taps half a window apart, triangular crossfade\n    const v0: f32 = grainRead(ring0, phase0, baseDelay, winLen);\n    const v1: f32 = grainRead(ring1, phase1, baseDelay, winLen);\n\n    fb0 = v0;\n    fb1 = v1;\n\n    // pan voices: width spreads them L/R. voice0 -> left, voice1 -> right\n    const w: f32 = sWidth;\n    // voice0 mostly left, voice1 mostly right; at width 0 both centred\n    const v0L: f32 = v0 * (0.5 + 0.5 * w);\n    const v0R: f32 = v0 * (0.5 - 0.5 * w);\n    const v1L: f32 = v1 * (0.5 - 0.5 * w);\n    const v1R: f32 = v1 * (0.5 + 0.5 * w);\n\n    const wetL: f32 = (v0L + v1L);\n    const wetR: f32 = (v0R + v1R);\n\n    // equal-ish blend; wet scaled a touch so doubling doesn't blow level\n    const dry: f32 = 1.0 - sMix;\n    const wet: f32 = sMix;\n    let oL: f32 = inL * dry + wetL * wet * 0.9;\n    let oR: f32 = inR * dry + wetR * wet * 0.9;\n\n    outBuf[f] = clampf(oL, -1.2, 1.2);\n    if (channels > 1) outBuf[MAX_FRAMES + f] = clampf(oR, -1.2, 1.2);\n\n    wpos = (wpos + 1) & DMASK;\n  }\n}\n\n// one-pole-ish slew: returns the delta to add toward target\n@inline function smoothStep(cur: f32, target: f32, a: f32): f32 {\n  return (target - cur) * a;\n}\n\n// Read a pitch-shifted grain: two taps half a window apart, crossfaded by a\n// triangular window so the pointer wrap never clicks. `phase` 0..1 drives the\n// window position; `base` is the centre delay, `win` the window length.\n@inline function grainRead(ring: StaticArray<f32>, phase: f32, base: f32, win: f32): f32 {\n  // tap A at phase, tap B half a window out of phase\n  const phB: f32 = phase >= 0.5 ? phase - 0.5 : phase + 0.5;\n  const backA: f32 = base + phase * win;\n  const backB: f32 = base + phB * win;\n  // triangular gains: full at window centre, zero at the wrap edges\n  const gA: f32 = 1.0 - Mathf.abs(2.0 * phase - 1.0);\n  const gB: f32 = 1.0 - Mathf.abs(2.0 * phB - 1.0);\n  const a: f32 = readRing(ring, backA);\n  const b: f32 = readRing(ring, backB);\n  return f32(a * gA + b * gB);\n}\n",
  "publishedAt": 1751000102000
}