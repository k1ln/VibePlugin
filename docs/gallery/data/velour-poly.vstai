  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Velour Poly</title>\n<style>\n  :root {\n    --accent: #c87aff;\n    --accent2: #ffb0d0;\n    --panel: #1a1620;\n    --panel-hi: #261f30;\n    --ink: #ece6f3;\n    --ink-dim: #9a8fac;\n    --well: #120f17;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    width: 100%;\n    min-height: 100%;\n    background: #0d0a12;\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .shell {\n    width: 100%;\n    max-width: 760px;\n    border-radius: 22px;\n    padding: 22px 24px 26px;\n    position: relative;\n    overflow: hidden;\n    background:\n      radial-gradient(120% 90% at 12% -10%, rgba(200,122,255,0.22), transparent 55%),\n      radial-gradient(120% 90% at 92% 0%, rgba(255,176,208,0.18), transparent 55%),\n      linear-gradient(160deg, #221b2c 0%, #16121d 55%, #110d16 100%);\n    box-shadow:\n      0 30px 70px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,255,255,0.06),\n      inset 0 -2px 14px rgba(0,0,0,0.5);\n    border: 1px solid rgba(200,122,255,0.18);\n  }\n\n  /* soft moving velvet sheen */\n  .shell::before {\n    content: \"\";\n    position: absolute;\n    inset: -40%;\n    background:\n      radial-gradient(40% 30% at 30% 30%, rgba(200,122,255,0.10), transparent 60%),\n      radial-gradient(40% 30% at 70% 60%, rgba(255,176,208,0.10), transparent 60%);\n    filter: blur(20px);\n    animation: drift 16s ease-in-out infinite alternate;\n    pointer-events: none;\n  }\n  @keyframes drift {\n    0%   { transform: translate(-3%, -2%) scale(1.0); }\n    100% { transform: translate(3%, 2%) scale(1.08); }\n  }\n\n  header {\n    display: flex;\n    align-items: baseline;\n    justify-content: space-between;\n    position: relative;\n    z-index: 2;\n    margin-bottom: 14px;\n  }\n  .title {\n    font-size: 22px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n    background: linear-gradient(95deg, var(--accent2), var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 24px rgba(200,122,255,0.25);\n  }\n  .subtitle {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* ---- waveform scope ---- */\n  .scope-wrap {\n    position: relative;\n    z-index: 2;\n    border-radius: 14px;\n    padding: 8px;\n    background:\n      linear-gradient(180deg, rgba(0,0,0,0.35), rgba(0,0,0,0.5));\n    box-shadow: inset 0 2px 12px rgba(0,0,0,0.7), inset 0 0 0 1px rgba(200,122,255,0.12);\n    margin-bottom: 18px;\n  }\n  canvas#scope {\n    display: block;\n    width: 100%;\n    height: 96px;\n    border-radius: 8px;\n  }\n\n  /* ---- controls grid ---- */\n  .rack {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px 10px;\n    margin-bottom: 18px;\n  }\n  @media (max-width: 540px) {\n    .rack { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  .knob {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .knob .dial {\n    cursor: ns-resize;\n    touch-action: none;\n    filter: drop-shadow(0 6px 10px rgba(0,0,0,0.55));\n    transition: filter 0.18s ease;\n  }\n  .knob:hover .dial { filter: drop-shadow(0 6px 16px rgba(200,122,255,0.4)); }\n  .knob .label {\n    margin-top: 7px;\n    font-size: 10px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .knob .val {\n    margin-top: 3px;\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    font-weight: 600;\n  }\n\n  /* ---- bender ---- */\n  .bender-zone {\n    position: relative;\n    z-index: 2;\n    display: flex;\n    align-items: center;\n    gap: 14px;\n    padding: 12px 16px;\n    border-radius: 14px;\n    background: linear-gradient(180deg, var(--panel-hi), var(--panel));\n    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), inset 0 -3px 10px rgba(0,0,0,0.5);\n    margin-bottom: 16px;\n  }\n  .bender-zone .tag {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    white-space: nowrap;\n  }\n  .bender {\n    position: relative;\n    flex: 1;\n    height: 26px;\n    border-radius: 13px;\n    background: var(--well);\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.8);\n    cursor: ew-resize;\n    touch-action: none;\n    overflow: hidden;\n  }\n  .bender .center-line {\n    position: absolute;\n    left: 50%;\n    top: 4px; bottom: 4px;\n    width: 1px;\n    background: rgba(200,122,255,0.3);\n    transform: translateX(-0.5px);\n  }\n  .bender .cap {\n    position: absolute;\n    top: 3px; bottom: 3px;\n    width: 38px;\n    border-radius: 10px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: linear-gradient(180deg, #4a3b5e, #2a2238);\n    box-shadow: 0 2px 6px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.12);\n    border: 1px solid rgba(200,122,255,0.35);\n    transition: box-shadow 0.15s ease;\n  }\n  .bender:hover .cap { box-shadow: 0 2px 14px rgba(255,176,208,0.45), inset 0 1px 0 rgba(255,255,255,0.2); }\n\n  /* ---- keyboard ---- */\n  .keys {\n    position: relative;\n    z-index: 2;\n    display: flex;\n    height: 96px;\n    border-radius: 10px;\n    padding: 6px;\n    background: linear-gradient(180deg, #0a070e, #15101d);\n    box-shadow: inset 0 2px 10px rgba(0,0,0,0.7);\n  }\n  .keybed {\n    position: relative;\n    flex: 1;\n    height: 100%;\n  }\n  .wkey {\n    position: absolute;\n    top: 0; bottom: 0;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #e9e2f0 0%, #c7bdd6 100%);\n    box-shadow: inset 0 -6px 8px rgba(0,0,0,0.18), 0 1px 0 rgba(0,0,0,0.4);\n    cursor: pointer;\n    border: 1px solid #15101d;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2) 0%, var(--accent) 100%);\n    box-shadow: inset 0 -4px 10px rgba(0,0,0,0.3), 0 0 16px rgba(200,122,255,0.6);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    height: 60%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a2238 0%, #0c0911 100%);\n    box-shadow: inset 0 -3px 6px rgba(255,255,255,0.06), 0 2px 4px rgba(0,0,0,0.7);\n    cursor: pointer;\n    z-index: 3;\n    border: 1px solid #000;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #7a3fb0 100%);\n    box-shadow: 0 0 14px rgba(200,122,255,0.7);\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <header>\n      <div class=\"title\">Velour Poly</div>\n      <div class=\"subtitle\">DCO &nbsp;Velvet&nbsp; Polysynth</div>\n    </header>\n\n    <div class=\"scope-wrap\">\n      <canvas id=\"scope\"></canvas>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"bender-zone\">\n      <span class=\"tag\">Bender</span>\n      <div class=\"bender\" id=\"bender\">\n        <div class=\"center-line\"></div>\n        <div class=\"cap\" id=\"benderCap\"></div>\n      </div>\n      <span class=\"tag\" id=\"benderVal\">0.0 st</span>\n    </div>\n\n    <div class=\"keys\"><div class=\"keybed\" id=\"keybed\"></div></div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, def: 0.5  },\n    { name: \"Resonance\",  index: 1, def: 0.3  },\n    { name: \"Env Amount\", index: 2, def: 0.55 },\n    { name: \"Cross-Mod\",  index: 3, def: 0.25 },\n    { name: \"Chorus\",     index: 4, def: 0.45 },\n    { name: \"Attack\",     index: 5, def: 0.15 },\n    { name: \"Release\",    index: 6, def: 0.4  },\n    { name: \"Level\",      index: 7, def: 0.7  }\n  ];\n\n  var values = {};\n\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ===== KNOBS =====================================================\n  function makeKnob(spec) {\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"knob\";\n\n    var size = 66;\n    var svgNS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(svgNS, \"svg\");\n    svg.setAttribute(\"class\", \"dial\");\n    svg.setAttribute(\"width\", size);\n    svg.setAttribute(\"height\", size);\n    svg.setAttribute(\"viewBox\", \"0 0 \" + size + \" \" + size);\n\n    var cx = size / 2, cy = size / 2, r = 25;\n    var startA = 135, endA = 405; // degrees, sweep 270°\n\n    function defGrad(id, c1, c2) {\n      var g = document.createElementNS(svgNS, \"linearGradient\");\n      g.setAttribute(\"id\", id);\n      g.setAttribute(\"x1\", \"0\"); g.setAttribute(\"y1\", \"0\");\n      g.setAttribute(\"x2\", \"0\"); g.setAttribute(\"y2\", \"1\");\n      var s1 = document.createElementNS(svgNS, \"stop\");\n      s1.setAttribute(\"offset\", \"0\"); s1.setAttribute(\"stop-color\", c1);\n      var s2 = document.createElementNS(svgNS, \"stop\");\n      s2.setAttribute(\"offset\", \"1\"); s2.setAttribute(\"stop-color\", c2);\n      g.appendChild(s1); g.appendChild(s2);\n      return g;\n    }\n    var defs = document.createElementNS(svgNS, \"defs\");\n    defs.appendChild(defGrad(\"body\" + spec.index, \"#3a2f4d\", \"#1d1727\"));\n    defs.appendChild(defGrad(\"arc\" + spec.index, \"#ffb0d0\", \"#c87aff\"));\n    svg.appendChild(defs);\n\n    // outer well\n    var well = document.createElementNS(svgNS, \"circle\");\n    well.setAttribute(\"cx\", cx); well.setAttribute(\"cy\", cy);\n    well.setAttribute(\"r\", r + 5);\n    well.setAttribute(\"fill\", \"#100c16\");\n    svg.appendChild(well);\n\n    function arcPath(a0, a1) {\n      var rr = r + 2;\n      var x0 = cx + rr * Math.cos(a0 * Math.PI / 180);\n      var y0 = cy + rr * Math.sin(a0 * Math.PI / 180);\n      var x1 = cx + rr * Math.cos(a1 * Math.PI / 180);\n      var y1 = cy + rr * Math.sin(a1 * Math.PI / 180);\n      var large = (a1 - a0) > 180 ? 1 : 0;\n      return \"M \" + x0 + \" \" + y0 + \" A \" + rr + \" \" + rr + \" 0 \" + large + \" 1 \" + x1 + \" \" + y1;\n    }\n\n    // track arc\n    var track = document.createElementNS(svgNS, \"path\");\n    track.setAttribute(\"d\", arcPath(startA, endA));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(255,255,255,0.08)\");\n    track.setAttribute(\"stroke-width\", \"4\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(track);\n\n    // value arc\n    var valArc = document.createElementNS(svgNS, \"path\");\n    valArc.setAttribute(\"fill\", \"none\");\n    valArc.setAttribute(\"stroke\", \"url(#arc\" + spec.index + \")\");\n    valArc.setAttribute(\"stroke-width\", \"4\");\n    valArc.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(valArc);\n\n    // body\n    var body = document.createElementNS(svgNS, \"circle\");\n    body.setAttribute(\"cx\", cx); body.setAttribute(\"cy\", cy);\n    body.setAttribute(\"r\", r - 2);\n    body.setAttribute(\"fill\", \"url(#body\" + spec.index + \")\");\n    body.setAttribute(\"stroke\", \"rgba(255,255,255,0.08)\");\n    body.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(body);\n\n    // pointer\n    var ptr = document.createElementNS(svgNS, \"line\");\n    ptr.setAttribute(\"stroke\", \"#ffd9ec\");\n    ptr.setAttribute(\"stroke-width\", \"2.5\");\n    ptr.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(ptr);\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = spec.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    wrap.appendChild(svg);\n    wrap.appendChild(label);\n    wrap.appendChild(val);\n\n    function render(v) {\n      var a = startA + (endA - startA) * v;\n      valArc.setAttribute(\"d\", arcPath(startA, a));\n      var pr = r - 6;\n      var px = cx + pr * Math.cos(a * Math.PI / 180);\n      var py = cy + pr * Math.sin(a * Math.PI / 180);\n      ptr.setAttribute(\"x1\", cx); ptr.setAttribute(\"y1\", cy);\n      ptr.setAttribute(\"x2\", px); ptr.setAttribute(\"y2\", py);\n      val.textContent = Math.round(v * 100) + \"%\";\n    }\n\n    function setValue(v, push) {\n      v = Math.max(0, Math.min(1, v));\n      values[spec.index] = v;\n      render(v);\n      if (push) pushParam(spec.index, v);\n    }\n\n    // drag (vertical), wheel (fine), dblclick (reset)\n    var dragging = false, lastY = 0;\n    svg.addEventListener(\"pointerdown\", function (e) {\n      dragging = true; lastY = e.clientY;\n      svg.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    });\n    svg.addEventListener(\"pointermove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.clientY;\n      lastY = e.clientY;\n      setValue(values[spec.index] + dy * 0.005, true);\n    });\n    svg.addEventListener(\"pointerup\", function (e) {\n      dragging = false;\n      try { svg.releasePointerCapture(e.pointerId); } catch (err) {}\n    });\n    svg.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      setValue(values[spec.index] - e.deltaY * 0.0006, true);\n    }, { passive: false });\n    svg.addEventListener(\"dblclick\", function () {\n      setValue(spec.def, true);\n    });\n\n    setValue(spec.def, false);\n    return { el: wrap, setValue: setValue };\n  }\n\n  var rack = document.getElementById(\"rack\");\n  PARAMS.forEach(function (p) {\n    var k = makeKnob(p);\n    rack.appendChild(k.el);\n  });\n\n  // ===== SCOPE =====================================================\n  var canvas = document.getElementById(\"scope\");\n  var ctx = canvas.getContext(\"2d\");\n  var W = 0, H = 0, dpr = Math.max(1, window.devicePixelRatio || 1);\n\n  function sizeCanvas() {\n    var rect = canvas.getBoundingClientRect();\n    W = rect.width; H = rect.height;\n    canvas.width = Math.round(W * dpr);\n    canvas.height = Math.round(H * dpr);\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n  window.addEventListener(\"resize\", sizeCanvas);\n\n  var t0 = performance.now();\n  var activeNotes = 0;\n  var energy = 0;\n\n  function drawScope(now) {\n    if (!document.hidden) {\n      var t = (now - t0) / 1000;\n      ctx.clearRect(0, 0, W, H);\n\n      // velvet backlight bars\n      var grad = ctx.createLinearGradient(0, 0, W, 0);\n      grad.addColorStop(0, \"rgba(255,176,208,0.0)\");\n      grad.addColorStop(0.5, \"rgba(200,122,255,0.12)\");\n      grad.addColorStop(1, \"rgba(255,176,208,0.0)\");\n      ctx.fillStyle = grad;\n      ctx.fillRect(0, 0, W, H);\n\n      energy += ((activeNotes > 0 ? 1 : 0.12) - energy) * 0.05;\n\n      var cutoff = values[0] || 0;\n      var xmod = values[3] || 0;\n      var chorus = values[4] || 0;\n\n      // three plush chorus-shimmer waves\n      var layers = [\n        { c: \"rgba(200,122,255,0.9)\", ph: 0,    amp: 1.0 },\n        { c: \"rgba(255,176,208,0.55)\", ph: 1.7, amp: 0.7 },\n        { c: \"rgba(255,255,255,0.25)\", ph: 3.4, amp: 0.45 }\n      ];\n      var mid = H / 2;\n      var baseAmp = (0.18 + 0.55 * energy) * H * 0.5;\n      var freq = 2 + cutoff * 6;\n      var harm = 1 + xmod * 4;\n\n      for (var L = 0; L < layers.length; L++) {\n        var ly = layers[L];\n        ctx.beginPath();\n        ctx.lineWidth = 2 - L * 0.4;\n        ctx.strokeStyle = ly.c;\n        var shimmer = ly.ph + t * (0.6 + chorus * 1.6) + L * chorus * 0.8;\n        for (var x = 0; x <= W; x += 2) {\n          var u = x / W;\n          var s = Math.sin(u * Math.PI * 2 * freq + shimmer)\n                * Math.sin(u * Math.PI * harm + shimmer * 0.5);\n          var y = mid + s * baseAmp * ly.amp * (0.6 + 0.4 * Math.sin(t * 1.3 + L));\n          if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n        }\n        ctx.stroke();\n      }\n    }\n    requestAnimationFrame(drawScope);\n  }\n\n  // ===== BENDER ===================================================\n  var bender = document.getElementById(\"bender\");\n  var benderCap = document.getElementById(\"benderCap\");\n  var benderVal = document.getElementById(\"benderVal\");\n  var bendPos = 0.5; // 0..1, center = no bend\n  var benderDragging = false;\n\n  function renderBender() {\n    var pct = bendPos * 100;\n    benderCap.style.left = pct + \"%\";\n    var st = (bendPos - 0.5) * 4; // +/- 2 semitones display\n    benderVal.textContent = (st >= 0 ? \"+\" : \"\") + st.toFixed(1) + \" st\";\n  }\n  function setBend(p) {\n    bendPos = Math.max(0, Math.min(1, p));\n    renderBender();\n  }\n  function benderFromEvent(e) {\n    var rect = bender.getBoundingClientRect();\n    setBend((e.clientX - rect.left) / rect.width);\n  }\n  bender.addEventListener(\"pointerdown\", function (e) {\n    benderDragging = true;\n    bender.setPointerCapture(e.pointerId);\n    benderFromEvent(e);\n    e.preventDefault();\n  });\n  bender.addEventListener(\"pointermove\", function (e) {\n    if (benderDragging) benderFromEvent(e);\n  });\n  function releaseBender(e) {\n    benderDragging = false;\n    try { bender.releasePointerCapture(e.pointerId); } catch (err) {}\n    // spring back to center, like a real pitch bender\n    var animate = function () {\n      bendPos += (0.5 - bendPos) * 0.25;\n      if (Math.abs(bendPos - 0.5) < 0.002) bendPos = 0.5;\n      renderBender();\n      if (bendPos !== 0.5) requestAnimationFrame(animate);\n    };\n    animate();\n  }\n  bender.addEventListener(\"pointerup\", releaseBender);\n  bender.addEventListener(\"dblclick\", function () { setBend(0.5); });\n  renderBender();\n\n  // ===== KEYBOARD =================================================\n  var keybed = document.getElementById(\"keybed\");\n  var START = 48; // C3\n  var NUM_WHITE = 14;\n  var WHITE_SET = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK_AFTER = { 0: 1, 2: 1, 5: 1, 7: 1, 9: 1 }; // semitone offsets that have a black key after\n  var heldByKey = {};\n\n  function noteOnUI(midi, vel) {\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(midi, vel);\n    activeNotes++;\n  }\n  function noteOffUI(midi) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(midi);\n    activeNotes = Math.max(0, activeNotes - 1);\n  }\n\n  // build keys: walk chromatic from START, placing whites by running index\n  var whiteMidis = [];\n  var whiteCount = 0;\n  var chromatic = [];\n  var m = START;\n  while (whiteCount < NUM_WHITE) {\n    var pc = m % 12;\n    var isWhite = WHITE_SET.indexOf(pc) >= 0;\n    chromatic.push({ midi: m, pc: pc, white: isWhite });\n    if (isWhite) whiteCount++;\n    m++;\n  }\n\n  var whiteW = 100 / NUM_WHITE;\n  var widx = 0;\n  chromatic.forEach(function (nObj) {\n    if (nObj.white) {\n      var el = document.createElement(\"div\");\n      el.className = \"wkey\";\n      el.style.left = (widx * whiteW) + \"%\";\n      el.style.width = whiteW + \"%\";\n      bindKey(el, nObj.midi);\n      keybed.appendChild(el);\n      whiteMidis.push({ midi: nObj.midi, x: widx });\n      widx++;\n    }\n  });\n  // black keys positioned over the gaps\n  var lastWhiteX = -1;\n  chromatic.forEach(function (nObj) {\n    if (nObj.white) { lastWhiteX++; return; }\n    var el = document.createElement(\"div\");\n    el.className = \"bkey\";\n    var bw = whiteW * 0.62;\n    var center = (lastWhiteX + 1) * whiteW; // boundary between this and next white\n    el.style.left = (center - bw / 2) + \"%\";\n    el.style.width = bw + \"%\";\n    bindKey(el, nObj.midi);\n    keybed.appendChild(el);\n  });\n\n  function bindKey(el, midiNote) {\n    el.addEventListener(\"pointerdown\", function (e) {\n      e.preventDefault();\n      el.classList.add(\"down\");\n      heldByKey[midiNote] = true;\n      noteOnUI(midiNote, 0.9);\n      try { el.setPointerCapture(e.pointerId); } catch (err) {}\n    });\n    var release = function (e) {\n      if (heldByKey[midiNote]) {\n        heldByKey[midiNote] = false;\n        el.classList.remove(\"down\");\n        noteOffUI(midiNote);\n      }\n    };\n    el.addEventListener(\"pointerup\", release);\n    el.addEventListener(\"pointerleave\", function (e) {\n      // only release if dragged out while pressed and not captured\n      if (heldByKey[midiNote] && e.buttons === 0) release(e);\n    });\n    el.addEventListener(\"pointercancel\", release);\n  }\n\n  // computer keyboard row a..k -> white keys\n  var KEYMAP = { a: 0, s: 1, d: 2, f: 3, g: 4, h: 5, j: 6, k: 7, l: 8 };\n  document.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var k = e.key.toLowerCase();\n    if (KEYMAP[k] != null && whiteMidis[KEYMAP[k]]) {\n      var mn = whiteMidis[KEYMAP[k]].midi;\n      if (!heldByKey[mn]) { heldByKey[mn] = true; noteOnUI(mn, 0.85); }\n    }\n  });\n  document.addEventListener(\"keyup\", function (e) {\n    var k = e.key.toLowerCase();\n    if (KEYMAP[k] != null && whiteMidis[KEYMAP[k]]) {\n      var mn = whiteMidis[KEYMAP[k]].midi;\n      if (heldByKey[mn]) { heldByKey[mn] = false; noteOffUI(mn); }\n    }\n  });\n\n  // ===== INIT / READY =============================================\n  function start() {\n    // push every param at its default\n    PARAMS.forEach(function (p) {\n      pushParam(p.index, values[p.index] != null ? values[p.index] : p.def);\n    });\n    sizeCanvas();\n    requestAnimationFrame(drawScope);\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VELOUR POLY — a warm, velvety velocity-sensitive DCO polyphonic synth.\n//  In the lineage of the smooth mid-80s Roman DCO polysynths: each of its\n//  eight voices runs TWO digitally-clocked oscillators — a band-limited\n//  saw and a band-limited pulse — with a gentle CROSS-MODULATION (the saw\n//  bends the pulse's phase rate) for that slightly hollow, glassy bell-pad\n//  character. The pair feeds a smooth resonant low-pass driven by its OWN\n//  ADSR (Cutoff + Env Amount), then an amplitude ADSR whose level and\n//  brightness track key VELOCITY. A stereo three-tap chorus widens the\n//  whole thing into the famous lush velvet pad. Pure algorithm, no samples,\n//  no host imports. All math is f32 (Mathf.*); process() allocates nothing.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_CUTOFF:   i32 = 0;  // 0..1  -> base filter cutoff\nconst P_RESO:     i32 = 1;  // 0..1  -> filter resonance\nconst P_ENVAMT:   i32 = 2;  // 0..1  -> filter envelope amount (octaves)\nconst P_CROSSMOD: i32 = 3;  // 0..1  -> DCO cross-modulation depth\nconst P_CHORUS:   i32 = 4;  // 0..1  -> stereo chorus depth/width\nconst P_ATTACK:   i32 = 5;  // 0..1  -> seconds\nconst P_RELEASE:  i32 = 6;  // 0..1  -> seconds\nconst P_LEVEL:    i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhase1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // saw DCO phase\nconst vPhase2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // pulse DCO phase\n\n// amplitude envelope (ADSR; sustain fixed velvety, decay gentle)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 3 sus 4 rel\n// filter envelope\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// smooth resonant low-pass: 4 cascaded one-pole stages per voice\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// ---- stereo chorus delay lines (shared, not per-voice) --------------\nconst CHORUS_LEN: i32 = 2048; // ~42 ms at 48k, plenty for a lush chorus\nconst chL: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nconst chR: StaticArray<f32> = new StaticArray<f32>(CHORUS_LEN);\nlet chWrite: i32 = 0;\nlet lfoPhase: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhase1[v] = 0.0; vPhase2[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  for (let i = 0; i < CHORUS_LEN; i++) { chL[i] = 0.0; chR[i] = 0.0; }\n  chWrite = 0;\n  lfoPhase = 0.0;\n  ageCounter = 0;\n\n  params[P_CUTOFF]   = 0.5;\n  params[P_RESO]     = 0.3;\n  params[P_ENVAMT]   = 0.55;\n  params[P_CROSSMOD] = 0.25;\n  params[P_CHORUS]   = 0.45;\n  params[P_ATTACK]   = 0.15;\n  params[P_RELEASE]  = 0.4;\n  params[P_LEVEL]    = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // prefer a free voice, else steal the oldest\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  // offset phases so the saw/pulse pair starts coherent but not phase-locked\n  vPhase1[slot] = 0.0;\n  vPhase2[slot] = 0.33;\n  vAEnv[slot] = 0.0; vFEnv[slot] = 0.0;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\n// linear read of a chorus delay line, `delay` frames back from the write head\n@inline function readDelay(buf: StaticArray<f32>, write: i32, delay: f32): f32 {\n  let rp: f32 = f32(write) - delay;\n  while (rp < 0.0) rp += f32(CHORUS_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= CHORUS_LEN) i1 -= CHORUS_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = buf[i0];\n  const b: f32 = buf[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const xmodN: f32   = clampf(params[P_CROSSMOD], 0.0, 1.0);\n  const chorusN: f32 = clampf(params[P_CHORUS], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkS: f32 = 0.002 + clampf(params[P_ATTACK], 0.0, 1.0)  * 2.5;\n  const relS: f32 = 0.01  + clampf(params[P_RELEASE], 0.0, 1.0) * 3.0;\n\n  // velvety internal contour: gentle decay to a high sustain\n  const decS: f32 = 0.6;\n  const susL: f32 = 0.78;\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // cross-mod depth: the saw stage modulates the pulse phase increment\n  const xmod: f32 = xmodN * 0.6;\n\n  // base cutoff in Hz, exponential 80 Hz .. ~14 kHz (smooth, slightly dark)\n  const baseHz: f32 = 80.0 * f32(Mathf.pow(180.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~5 octaves\n  const envOct: f32 = envAmt * 5.0;\n  // resonance feedback 0..~3.4 (smooth, never harsh self-oscillation)\n  const reso: f32 = resoN * 3.4;\n\n  // ---- chorus setup -------------------------------------------------\n  // a slow ~0.5 Hz LFO; depth and a static stereo spread scale with Chorus\n  const lfoInc: f32 = 0.5 / sr;\n  const baseDelayMs: f32 = 12.0;                 // center tap\n  const baseDelay: f32 = baseDelayMs * 0.001 * sr;\n  const modDepth: f32 = (1.0 + chorusN * 5.0) * 0.001 * sr; // up to ~6 ms sweep\n  const chMix: f32 = chorusN;                    // 0 dry .. 1 wide\n\n  // headroom: 8 voices summed -> scale so a big chord stays < 1\n  const voiceScale: f32 = 0.42;\n\n  let lp: f32 = lfoPhase;\n  let wr: i32 = chWrite;\n\n  for (let f = 0; f < n; f++) {\n    let dry: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude ADSR ---------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // decay\n        aenv -= decRate * (1.0 - susL);\n        if (aenv <= susL) { aenv = susL; astg = 3; }\n      } else if (astg == 3) {     // sustain\n        aenv = susL;\n      } else if (astg == 4) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      // voice finished?\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter ADSR ------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * (1.0 - susL);\n        if (fenv <= susL) { fenv = susL; fstg = 3; }\n      } else if (fstg == 3) {\n        fenv = susL;\n      } else if (fstg == 4) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      const vel: f32 = vVel[v];\n\n      // ---- the two DCOs (saw + pulse) with cross-modulation -----\n      const baseInc: f32 = vFreq[v] / sr;\n\n      // saw DCO\n      let p1: f32 = vPhase1[v];\n      p1 += baseInc; if (p1 >= 1.0) p1 -= 1.0;\n      let saw: f32 = 2.0 * p1 - 1.0;\n      saw -= polyBlep(p1, baseInc);\n      vPhase1[v] = p1;\n\n      // cross-mod: the saw bends the pulse's instantaneous rate\n      let inc2: f32 = baseInc * (1.0 + xmod * saw);\n      if (inc2 < 0.0) inc2 = 0.0;\n      if (inc2 > 0.5) inc2 = 0.5;\n\n      // pulse DCO (50% duty) via two band-limited saws\n      let p2: f32 = vPhase2[v];\n      p2 += inc2; if (p2 >= 1.0) p2 -= 1.0;\n      const pw: f32 = 0.5;\n      let sq: f32 = p2 < pw ? 1.0 : -1.0;\n      sq += polyBlep(p2, inc2);\n      let p2b: f32 = p2 + (1.0 - pw);\n      if (p2b >= 1.0) p2b -= 1.0;\n      sq -= polyBlep(p2b, inc2);\n      vPhase2[v] = p2;\n\n      // velvety DCO mix: saw for body, pulse for the slightly hollow tone\n      let osc: f32 = saw * 0.55 + sq * 0.42;\n\n      // ---- smooth resonant low-pass -----------------------------\n      // velocity opens the filter a touch for expressive dynamics\n      const velBright: f32 = 0.5 + 0.5 * vel;\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv)) * velBright;\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      // resonance feedback from the last stage; tanh keeps it smooth\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      // velocity shapes loudness; squared for a gentle dynamic curve\n      const velAmp: f32 = 0.25 + 0.75 * vel * vel;\n      dry += s3 * aenv * velAmp;\n    }\n\n    dry *= voiceScale;\n\n    // ---- stereo chorus ----------------------------------------------\n    // write the mono dry voice sum into both delay lines\n    chL[wr] = dry;\n    chR[wr] = dry;\n\n    lp += lfoInc; if (lp >= 1.0) lp -= 1.0;\n    const lfoL: f32 = f32(Mathf.sin(TWO_PI * lp));\n    const lfoR: f32 = f32(Mathf.sin(TWO_PI * lp + PI * 0.5)); // 90° apart -> width\n\n    const dL: f32 = baseDelay + modDepth * (0.5 + 0.5 * lfoL);\n    const dR: f32 = baseDelay + modDepth * (0.5 + 0.5 * lfoR);\n\n    const wetL: f32 = readDelay(chL, wr, dL);\n    const wetR: f32 = readDelay(chR, wr, dR);\n\n    wr++; if (wr >= CHORUS_LEN) wr = 0;\n\n    // blend dry center with the widened wet taps\n    let outL: f32 = dry * (1.0 - 0.5 * chMix) + wetL * chMix;\n    let outR: f32 = dry * (1.0 - 0.5 * chMix) + wetR * chMix;\n\n    // final velvet glue + output level\n    outL = f32(Mathf.tanh(outL * 1.1)) * level;\n    outR = f32(Mathf.tanh(outR * 1.1)) * level;\n\n    outBuf[f] = outL;\n    outBuf[MAX_FRAMES + f] = outR;\n  }\n\n  lfoPhase = lp;\n  chWrite = wr;\n}\n",
  "publishedAt": 1751000139000
}