{
  "format": 1,
  "name": "Pearl Reverb",
  "isInstrument": false,
  "explanation": "A bright early-digital reverb: a dense feedback-delay network of combs diffused through cascaded allpass sections, with a subtly grainy, sparkly converter character. A Program selector reshapes the tail into a smooth Reverb, a longer wide Space, or a nonlinear Gate. Controls: Mix, Decay, Tone, Pre-Delay and Program.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Decay",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Pre-Delay",
      "index": 3,
      "min": 0,
      "max": 0.15,
      "default": 0.012
    },
    {
      "name": "Program",
      "index": 4,
      "min": 0,
      "max": 2,
      "default": 0
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pearl Reverb</title>\n<style>\n  :root {\n    --accent: #bfe3ff;\n    --accent2: #e6c6ff;\n    --ink: #eaf3ff;\n    --dim: #8da3bd;\n    --panel: #0e1422;\n    --panel2: #131b2e;\n    --glass: rgba(191, 227, 255, 0.06);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: #060911;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    align-items: flex-start;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  /* iridescent pearl background field */\n  .shell {\n    position: relative;\n    width: 100%;\n    max-width: 720px;\n    border-radius: 22px;\n    padding: 22px 24px 26px;\n    background:\n      radial-gradient(120% 90% at 12% -10%, rgba(230, 198, 255, 0.16), transparent 55%),\n      radial-gradient(120% 90% at 92% 0%, rgba(191, 227, 255, 0.18), transparent 52%),\n      linear-gradient(160deg, #131c30 0%, #0b1120 55%, #090d18 100%);\n    box-shadow:\n      0 30px 70px rgba(0, 0, 0, 0.55),\n      inset 0 1px 0 rgba(255, 255, 255, 0.08),\n      inset 0 0 0 1px rgba(191, 227, 255, 0.08);\n    overflow: hidden;\n  }\n\n  /* slow drifting pearl sheen */\n  .shell::before {\n    content: \"\";\n    position: absolute;\n    inset: -40%;\n    background:\n      conic-gradient(from 0deg,\n        rgba(191, 227, 255, 0.0) 0deg,\n        rgba(230, 198, 255, 0.10) 70deg,\n        rgba(191, 227, 255, 0.12) 140deg,\n        rgba(255, 255, 255, 0.06) 210deg,\n        rgba(230, 198, 255, 0.10) 290deg,\n        rgba(191, 227, 255, 0.0) 360deg);\n    filter: blur(40px);\n    opacity: 0.5;\n    animation: drift 26s linear infinite;\n    pointer-events: none;\n  }\n\n  @keyframes drift {\n    from { transform: rotate(0deg) scale(1.05); }\n    to   { transform: rotate(360deg) scale(1.05); }\n  }\n\n  .header {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    margin-bottom: 18px;\n  }\n\n  .brand {\n    display: flex;\n    align-items: center;\n    gap: 14px;\n  }\n\n  /* the pearl orb logo */\n  .pearl {\n    width: 46px;\n    height: 46px;\n    border-radius: 50%;\n    position: relative;\n    background:\n      radial-gradient(60% 55% at 35% 30%, #ffffff 0%, #dfeaff 18%, #bfe3ff 42%, #e6c6ff 70%, #9bb6e6 100%);\n    box-shadow:\n      0 6px 16px rgba(120, 160, 255, 0.45),\n      inset 0 -6px 12px rgba(70, 90, 140, 0.5),\n      inset 0 4px 8px rgba(255, 255, 255, 0.85);\n    flex: 0 0 auto;\n  }\n\n  .pearl::after {\n    content: \"\";\n    position: absolute;\n    top: 7px;\n    left: 11px;\n    width: 12px;\n    height: 8px;\n    border-radius: 50%;\n    background: rgba(255, 255, 255, 0.9);\n    filter: blur(1px);\n    animation: glint 5s ease-in-out infinite;\n  }\n\n  @keyframes glint {\n    0%, 100% { opacity: 0.85; transform: translate(0, 0) scale(1); }\n    50%      { opacity: 0.4;  transform: translate(2px, 2px) scale(0.85); }\n  }\n\n  .titles h1 {\n    margin: 0;\n    font-size: 19px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n    background: linear-gradient(90deg, #ffffff, var(--accent) 45%, var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n\n  .titles .sub {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--dim);\n    margin-top: 3px;\n  }\n\n  /* segmented digital readout */\n  .readout {\n    font-family: \"SFMono-Regular\", ui-monospace, Menlo, Consolas, monospace;\n    font-variant-numeric: tabular-nums;\n    text-align: right;\n    padding: 8px 12px;\n    border-radius: 10px;\n    background: linear-gradient(180deg, #04060c, #0a1120);\n    box-shadow:\n      inset 0 2px 6px rgba(0, 0, 0, 0.7),\n      inset 0 0 0 1px rgba(191, 227, 255, 0.12);\n    min-width: 132px;\n  }\n\n  .readout .big {\n    font-size: 20px;\n    color: var(--accent);\n    text-shadow: 0 0 10px rgba(191, 227, 255, 0.55);\n    letter-spacing: 1px;\n  }\n\n  .readout .small {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n    margin-top: 2px;\n  }\n\n  /* knob grid */\n  .grid {\n    position: relative;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n  }\n\n  @media (max-width: 560px) {\n    .grid { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  .cell {\n    position: relative;\n    border-radius: 16px;\n    padding: 16px 10px 12px;\n    background: linear-gradient(180deg, var(--glass), rgba(0, 0, 0, 0.18));\n    box-shadow:\n      inset 0 1px 0 rgba(255, 255, 255, 0.06),\n      inset 0 0 0 1px rgba(191, 227, 255, 0.07);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n  }\n\n  .knob {\n    width: 96px;\n    height: 96px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n\n  .label {\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  .value {\n    font-family: ui-monospace, Menlo, monospace;\n    font-variant-numeric: tabular-nums;\n    font-size: 13px;\n    color: var(--ink);\n    text-shadow: 0 0 8px rgba(191, 227, 255, 0.3);\n  }\n\n  /* program selector — glassy buttons spanning full width */\n  .program {\n    grid-column: 1 / -1;\n    display: flex;\n    gap: 10px;\n    margin-top: 4px;\n  }\n\n  .program .pgrp {\n    flex: 1;\n    display: flex;\n    gap: 10px;\n  }\n\n  .prog-label {\n    align-self: center;\n    font-size: 10px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n    padding-right: 4px;\n  }\n\n  .pbtn {\n    flex: 1;\n    position: relative;\n    border: none;\n    border-radius: 12px;\n    padding: 13px 8px;\n    cursor: pointer;\n    color: var(--dim);\n    font-size: 11px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    font-weight: 600;\n    background: linear-gradient(180deg, #182238, #0d1424);\n    box-shadow:\n      inset 0 1px 0 rgba(255, 255, 255, 0.06),\n      inset 0 0 0 1px rgba(191, 227, 255, 0.06),\n      0 4px 10px rgba(0, 0, 0, 0.4);\n    transition: color 0.18s, box-shadow 0.25s, transform 0.08s;\n    overflow: hidden;\n  }\n\n  .pbtn:hover { color: var(--ink); }\n  .pbtn:active { transform: translateY(1px); }\n\n  .pbtn::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(191, 227, 255, 0.18), rgba(230, 198, 255, 0.10));\n    opacity: 0;\n    transition: opacity 0.25s;\n  }\n\n  .pbtn.active {\n    color: #061018;\n  }\n\n  .pbtn.active::after { opacity: 1; }\n\n  .pbtn.active {\n    box-shadow:\n      inset 0 0 0 1px rgba(255, 255, 255, 0.35),\n      0 0 18px rgba(191, 227, 255, 0.5),\n      0 4px 12px rgba(0, 0, 0, 0.4);\n  }\n\n  .pbtn span { position: relative; z-index: 1; }\n\n  .footer {\n    margin-top: 16px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  .spark {\n    display: inline-block;\n    width: 6px; height: 6px;\n    border-radius: 50%;\n    background: var(--accent);\n    box-shadow: 0 0 8px var(--accent);\n    margin-right: 6px;\n    animation: pulse 2.4s ease-in-out infinite;\n  }\n\n  @keyframes pulse {\n    0%, 100% { opacity: 1; transform: scale(1); }\n    50%      { opacity: 0.35; transform: scale(0.6); }\n  }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <div class=\"header\">\n      <div class=\"brand\">\n        <div class=\"pearl\"></div>\n        <div class=\"titles\">\n          <h1>Pearl Reverb</h1>\n          <div class=\"sub\">Early-Digital Space Engine</div>\n        </div>\n      </div>\n      <div class=\"readout\">\n        <div class=\"big\" id=\"ro-big\">REVERB</div>\n        <div class=\"small\" id=\"ro-small\">Program</div>\n      </div>\n    </div>\n\n    <div class=\"grid\" id=\"grid\">\n      <!-- knobs injected by JS -->\n      <div class=\"program\">\n        <div class=\"prog-label\">Program</div>\n        <div class=\"pgrp\" id=\"pgrp\"></div>\n      </div>\n    </div>\n\n    <div class=\"footer\">\n      <div><span class=\"spark\"></span>Iridescent FDN reverberator</div>\n      <div>Drag to turn · double-click to reset</div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices match spec.json) ----------------------\n  var PARAMS = [\n    { name: \"Mix\",       index: 0, min: 0, max: 1,    def: 0.3,   fmt: pct },\n    { name: \"Decay\",     index: 1, min: 0, max: 1,    def: 0.6,   fmt: pct },\n    { name: \"Tone\",      index: 2, min: 0, max: 1,    def: 0.65,  fmt: pct },\n    { name: \"Pre-Delay\", index: 3, min: 0, max: 0.15, def: 0.012, fmt: ms }\n  ];\n\n  var PROG_INDEX = 4;\n  var PROGRAMS = [\"REVERB\", \"SPACE\", \"GATE\"];\n  var progDefault = 0;\n  var progValue = progDefault;\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function ms(v)  { return (v * 1000).toFixed(0) + \" ms\"; }\n\n  function clamp(v, lo, hi) { return v < lo ? lo : (v > hi ? hi : v); }\n\n  // ---- host bridge --------------------------------------------------\n  function setParam(idx, val) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(idx, val);\n    }\n  }\n\n  // ---- knob factory -------------------------------------------------\n  function makeKnob(spec) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var NS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n    svg.setAttribute(\"class\", \"knob\");\n\n    // soft outer well\n    var well = document.createElementNS(NS, \"circle\");\n    well.setAttribute(\"cx\", \"50\"); well.setAttribute(\"cy\", \"50\"); well.setAttribute(\"r\", \"44\");\n    well.setAttribute(\"fill\", \"rgba(0,0,0,0.35)\");\n    well.setAttribute(\"stroke\", \"rgba(191,227,255,0.08)\");\n    well.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(well);\n\n    // value arc background track\n    var trackR = 38;\n    var arcBg = document.createElementNS(NS, \"path\");\n    arcBg.setAttribute(\"fill\", \"none\");\n    arcBg.setAttribute(\"stroke\", \"rgba(191,227,255,0.12)\");\n    arcBg.setAttribute(\"stroke-width\", \"5\");\n    arcBg.setAttribute(\"stroke-linecap\", \"round\");\n    arcBg.setAttribute(\"d\", arcPath(trackR, 0));\n    svg.appendChild(arcBg);\n\n    // value arc (gradient)\n    var gradId = \"g\" + spec.index;\n    var defs = document.createElementNS(NS, \"defs\");\n    var lg = document.createElementNS(NS, \"linearGradient\");\n    lg.setAttribute(\"id\", gradId);\n    lg.setAttribute(\"x1\", \"0\"); lg.setAttribute(\"y1\", \"1\");\n    lg.setAttribute(\"x2\", \"1\"); lg.setAttribute(\"y2\", \"0\");\n    var s1 = document.createElementNS(NS, \"stop\");\n    s1.setAttribute(\"offset\", \"0\"); s1.setAttribute(\"stop-color\", \"#bfe3ff\");\n    var s2 = document.createElementNS(NS, \"stop\");\n    s2.setAttribute(\"offset\", \"1\"); s2.setAttribute(\"stop-color\", \"#e6c6ff\");\n    lg.appendChild(s1); lg.appendChild(s2);\n    defs.appendChild(lg);\n    svg.appendChild(defs);\n\n    var arc = document.createElementNS(NS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#\" + gradId + \")\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(arc);\n\n    // knob body (pearl)\n    var body = document.createElementNS(NS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"url(#pearlbody)\");\n    svg.appendChild(body);\n\n    // pearl body gradient (shared, define once)\n    if (!document.getElementById(\"pearlbody\")) {\n      var pdefs = document.createElementNS(NS, \"defs\");\n      var rg = document.createElementNS(NS, \"radialGradient\");\n      rg.setAttribute(\"id\", \"pearlbody\");\n      rg.setAttribute(\"cx\", \"0.38\"); rg.setAttribute(\"cy\", \"0.32\"); rg.setAttribute(\"r\", \"0.75\");\n      var p1 = document.createElementNS(NS, \"stop\");\n      p1.setAttribute(\"offset\", \"0\"); p1.setAttribute(\"stop-color\", \"#ffffff\");\n      var p2 = document.createElementNS(NS, \"stop\");\n      p2.setAttribute(\"offset\", \"0.45\"); p2.setAttribute(\"stop-color\", \"#c9dcf2\");\n      var p3 = document.createElementNS(NS, \"stop\");\n      p3.setAttribute(\"offset\", \"1\"); p3.setAttribute(\"stop-color\", \"#23304a\");\n      rg.appendChild(p1); rg.appendChild(p2); rg.appendChild(p3);\n      pdefs.appendChild(rg);\n      svg.appendChild(pdefs);\n    }\n\n    // pointer notch\n    var notch = document.createElementNS(NS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"28\");\n    notch.setAttribute(\"stroke\", \"#06101c\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    cell.appendChild(svg);\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = spec.name;\n    cell.appendChild(label);\n\n    var value = document.createElement(\"div\");\n    value.className = \"value\";\n    cell.appendChild(value);\n\n    var norm = (spec.def - spec.min) / (spec.max - spec.min);\n\n    function arcPath(r, frac) {\n      // 270deg sweep, from -225deg to +45deg (gap at bottom)\n      var a0 = (-225) * Math.PI / 180;\n      var a1 = a0 + frac * 270 * Math.PI / 180;\n      var x0 = 50 + r * Math.cos(a0), y0 = 50 + r * Math.sin(a0);\n      var x1 = 50 + r * Math.cos(a1), y1 = 50 + r * Math.sin(a1);\n      var large = (frac * 270) > 180 ? 1 : 0;\n      return \"M \" + x0.toFixed(2) + \" \" + y0.toFixed(2) +\n             \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n             x1.toFixed(2) + \" \" + y1.toFixed(2);\n    }\n\n    function redraw() {\n      var val = spec.min + norm * (spec.max - spec.min);\n      arc.setAttribute(\"d\", arcPath(trackR, Math.max(0.0001, norm)));\n      var ang = -225 + norm * 270;\n      notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n      value.textContent = spec.fmt(val);\n    }\n\n    function commit() {\n      var val = spec.min + norm * (spec.max - spec.min);\n      setParam(spec.index, val);\n      redraw();\n    }\n\n    // ---- drag interaction ----\n    var dragging = false, startY = 0, startNorm = 0;\n\n    function onDown(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startNorm = norm;\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = startY - y;\n      var fine = e.shiftKey ? 0.25 : 1.0;\n      norm = clamp(startNorm + (dy / 200) * fine, 0, 1);\n      commit();\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n\n    function onWheel(e) {\n      var step = e.shiftKey ? 0.005 : 0.02;\n      norm = clamp(norm - Math.sign(e.deltaY) * step, 0, 1);\n      commit();\n      e.preventDefault();\n    }\n\n    function onDbl() {\n      norm = (spec.def - spec.min) / (spec.max - spec.min);\n      commit();\n    }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    svg.addEventListener(\"wheel\", onWheel, { passive: false });\n    svg.addEventListener(\"dblclick\", onDbl);\n\n    redraw();\n    return { cell: cell, commit: commit };\n  }\n\n  // ---- program selector ---------------------------------------------\n  function buildProgram() {\n    var grp = document.getElementById(\"pgrp\");\n    var btns = [];\n\n    function select(i, push) {\n      progValue = i;\n      for (var b = 0; b < btns.length; b++) {\n        btns[b].classList.toggle(\"active\", b === i);\n      }\n      document.getElementById(\"ro-big\").textContent = PROGRAMS[i];\n      if (push) setParam(PROG_INDEX, i);\n    }\n\n    for (var i = 0; i < PROGRAMS.length; i++) {\n      (function (idx) {\n        var btn = document.createElement(\"button\");\n        btn.className = \"pbtn\";\n        btn.type = \"button\";\n        var sp = document.createElement(\"span\");\n        sp.textContent = PROGRAMS[idx];\n        btn.appendChild(sp);\n        btn.addEventListener(\"click\", function () { select(idx, true); });\n        // double-click any button resets to default program\n        btn.addEventListener(\"dblclick\", function () { select(progDefault, true); });\n        grp.appendChild(btn);\n        btns.push(btn);\n      })(i);\n    }\n\n    select(progDefault, false);\n    return { selectInit: function () { setParam(PROG_INDEX, progValue); } };\n  }\n\n  // ---- boot ---------------------------------------------------------\n  function boot() {\n    var grid = document.getElementById(\"grid\");\n    var program = document.querySelector(\".program\");\n    var knobs = [];\n    for (var i = 0; i < PARAMS.length; i++) {\n      var k = makeKnob(PARAMS[i]);\n      grid.insertBefore(k.cell, program);\n      knobs.push(k);\n    }\n    var prog = buildProgram();\n\n    // push all defaults to the engine once on load\n    for (var j = 0; j < knobs.length; j++) knobs[j].commit();\n    prog.selectInit();\n  }\n\n  function start() {\n    if (window.vstai && typeof window.vstai.onReady === \"function\") {\n      window.vstai.onReady(boot);\n    } else {\n      boot();\n    }\n  }\n\n  if (document.readyState === \"loading\") {\n    document.addEventListener(\"DOMContentLoaded\", start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  PEARL REVERB — a bright early-DIGITAL reverb engine\n//\n//  Original algorithm inspired by the late-1970s first generation of\n//  digital studio reverbs: a dense feedback-delay network (FDN) of four\n//  comb delays diffused through a chain of allpass sections, with a\n//  slightly grainy / sparkly character baked in (a gentle quantiser +\n//  sample-rate \"grit\" + a sparkle high-shelf). Three Programs reshape\n//  the tail: Reverb (smooth), Space (longer, wider, more diffuse) and a\n//  nonlinear Gate (a dense burst that slams shut). Pure algorithm.\n//\n//  Params: Mix, Decay, Tone (bright), Pre-Delay, Program (0..2 step 1).\n//  Mix = 0 is bit-exact dry. All maths in f32, no alloc in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- param indices (must match spec.json) ---------------------------\nconst P_MIX: i32 = 0;       // 0..1 dry/wet (0 == dry)\nconst P_DECAY: i32 = 1;     // 0..1 tail length\nconst P_TONE: i32 = 2;      // 0..1 dark..bright\nconst P_PREDELAY: i32 = 3;  // 0..0.15 seconds\nconst P_PROGRAM: i32 = 4;   // 0,1,2 : Reverb / Space / Gate\n\n// ---- delay-line storage ---------------------------------------------\n// All lines are sized for the longest case at 48 kHz-ish rates plus head-\n// room; we mod-index so a shorter rate just uses less of each buffer.\nconst PRE_LEN: i32 = 8192;     // up to ~0.17 s pre-delay @ 48k\nconst PRE_MASK: i32 = 8191;\n\n// Four parallel comb delays per channel (prime-ish lengths for density).\nconst NC: i32 = 4;\nconst COMB_LEN: i32 = 4096;    // max comb length (power of two for masking)\nconst COMB_MASK: i32 = 4095;\n\n// Three series allpass diffusers per channel.\nconst NA: i32 = 3;\nconst AP_LEN: i32 = 2048;\nconst AP_MASK: i32 = 2047;\n\nconst preBuf:  StaticArray<f32> = new StaticArray<f32>(PRE_LEN * MAX_CHANNELS);\nconst combBuf: StaticArray<f32> = new StaticArray<f32>(COMB_LEN * NC * MAX_CHANNELS);\nconst apBuf:   StaticArray<f32> = new StaticArray<f32>(AP_LEN * NA * MAX_CHANNELS);\n\n// write heads\nconst preWrite:  StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\nconst combWrite: StaticArray<i32> = new StaticArray<i32>(NC * MAX_CHANNELS);\nconst apWrite:   StaticArray<i32> = new StaticArray<i32>(NA * MAX_CHANNELS);\n\n// per-comb damping low-pass state (high-frequency loss in the tail)\nconst combDamp: StaticArray<f32> = new StaticArray<f32>(NC * MAX_CHANNELS);\n\n// tone shelf state + dc blocker state, per channel\nconst toneLp: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst dcX:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst dcY:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// gate envelope follower + countdown (shared, mono-controlled gate)\nlet gateEnv: f32 = 0.0;\nlet gateHold: f32 = 0.0;\n\n// base comb delay lengths (samples @ ~48k) — mutually prime-ish, slightly\n// different L/R via the channel spread applied below.\nconst combBase: StaticArray<i32> = new StaticArray<i32>(NC);\nconst apBase:   StaticArray<i32> = new StaticArray<i32>(NA);\n\n// effective (rate-scaled) lengths, recomputed in init()\nconst combDelay: StaticArray<i32> = new StaticArray<i32>(NC * MAX_CHANNELS);\nconst apDelay:   StaticArray<i32> = new StaticArray<i32>(NA * MAX_CHANNELS);\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n@inline function clampi(x: i32, lo: i32, hi: i32): i32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  // clear every buffer / state\n  for (let i = 0; i < PRE_LEN * MAX_CHANNELS; i++) preBuf[i] = 0.0;\n  for (let i = 0; i < COMB_LEN * NC * MAX_CHANNELS; i++) combBuf[i] = 0.0;\n  for (let i = 0; i < AP_LEN * NA * MAX_CHANNELS; i++) apBuf[i] = 0.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    preWrite[c] = 0;\n    toneLp[c] = 0.0; dcX[c] = 0.0; dcY[c] = 0.0;\n    for (let k = 0; k < NC; k++) { combWrite[c * NC + k] = 0; combDamp[c * NC + k] = 0.0; }\n    for (let k = 0; k < NA; k++) apWrite[c * NA + k] = 0;\n  }\n  gateEnv = 0.0; gateHold = 0.0;\n\n  // base lengths chosen for density without obvious flutter\n  combBase[0] = 1687; combBase[1] = 1997; combBase[2] = 2389; combBase[3] = 2797;\n  apBase[0] = 419; apBase[1] = 263; apBase[2] = 149;\n\n  // scale to actual sample rate, give R a small spread for width\n  const scale: f32 = sampleRate / 48000.0;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    const spread: f32 = c == 1 ? 1.037 : 1.0;   // detune the right field slightly\n    for (let k = 0; k < NC; k++) {\n      let d: i32 = i32(f32(combBase[k]) * scale * spread);\n      combDelay[c * NC + k] = clampi(d, 8, COMB_MASK - 1);\n    }\n    for (let k = 0; k < NA; k++) {\n      let d: i32 = i32(f32(apBase[k]) * scale * spread);\n      apDelay[c * NA + k] = clampi(d, 4, AP_MASK - 1);\n    }\n  }\n\n  // sensible defaults\n  params[P_MIX] = 0.3;\n  params[P_DECAY] = 0.6;\n  params[P_TONE] = 0.65;\n  params[P_PREDELAY] = 0.012;\n  params[P_PROGRAM] = 0.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// one allpass section (Schroeder), reads/writes its own slot of apBuf\n@inline function allpass(ch: i32, idx: i32, x: f32, g: f32): f32 {\n  const base: i32 = (ch * NA + idx) * AP_LEN;\n  const w: i32 = apWrite[ch * NA + idx];\n  const d: i32 = apDelay[ch * NA + idx];\n  const r: i32 = (w - d) & AP_MASK;\n  const buffered: f32 = apBuf[base + r];\n  const input: f32 = x + buffered * g;\n  apBuf[base + (w & AP_MASK)] = input;\n  apWrite[ch * NA + idx] = (w + 1) & AP_MASK;\n  return f32(buffered - input * g);\n}\n\nexport function process(n: i32): void {\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Mix == 0 => bit-exact dry passthrough (cheap, and the spec requires it).\n  if (mix <= 0.0) {\n    for (let c = 0; c < channels; c++) {\n      const base: i32 = c * MAX_FRAMES;\n      for (let f = 0; f < n; f++) outBuf[base + f] = inBuf[base + f];\n    }\n    return;\n  }\n\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const preSec: f32 = clampf(params[P_PREDELAY], 0.0, 0.15);\n  let prog: i32 = i32(params[P_PROGRAM] + 0.5);\n  prog = clampi(prog, 0, 2);\n\n  // pre-delay in samples\n  let preD: i32 = i32(preSec * sampleRate);\n  preD = clampi(preD, 0, PRE_MASK - 1);\n\n  // Program shaping ----------------------------------------------------\n  //  0 Reverb : balanced feedback, moderate diffusion\n  //  1 Space  : longer feedback, extra size, very diffuse + wide\n  //  2 Gate   : dense but feedback kept low; an envelope gate chops the tail\n  let fbBase: f32 = 0.78 + decayN * 0.20;        // 0.78..0.98\n  let sizeMul: f32 = 1.0;\n  let apG: f32 = 0.62;\n  let gateMode: bool = false;\n  if (prog == 1) {\n    fbBase = 0.84 + decayN * 0.149;              // up to ~0.989 = long\n    sizeMul = 1.0;\n    apG = 0.70;                                   // more diffusion\n  } else if (prog == 2) {\n    fbBase = 0.55 + decayN * 0.30;               // dense early energy, not endless\n    apG = 0.66;\n    gateMode = true;\n  }\n  fbBase = clampf(fbBase, 0.0, 0.991);\n\n  // damping: Tone bright => less HF loss in tail. coeff is a one-pole LP amt.\n  // dampAmt near 1 = bright (little smoothing), near 0 = dark.\n  const dampAmt: f32 = 0.18 + toneN * toneN * 0.80;   // 0.18..0.98\n  // sparkle high-shelf strength on the wet output (early-digital \"air\")\n  const sparkle: f32 = 0.15 + toneN * 0.55;\n\n  // output tone tilt low-pass coeff (post). bright => high cutoff.\n  const toneHz: f32 = 1200.0 + toneN * toneN * 12000.0;\n  let toneCoeff: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * toneHz / sampleRate));\n  toneCoeff = clampf(toneCoeff, 0.0, 1.0);\n\n  // dc-blocker coeff\n  const dcR: f32 = 0.9985;\n\n  // grainy early-digital quantiser: a coarse-ish step + tiny sample \"grit\".\n  // step gets a touch coarser when darker (older converter feel), but stays\n  // subtle so it sparkles rather than distorts.\n  const qStep: f32 = 1.0 / (8192.0 + toneN * 24576.0);   // ~13..15 bit\n  const invQ: f32 = 1.0 / qStep;\n\n  // gate timing (program 2): a fixed-ish window driven by Decay.\n  const gateThresh: f32 = 0.012;\n  const holdSamples: f32 = (0.06 + decayN * 0.45) * sampleRate;   // 60..510 ms\n  const gateRelease: f32 = f32(Mathf.exp(-1.0 / (0.012 * sampleRate)));  // ~12 ms close\n  const gateAttack: f32 = f32(Mathf.exp(-1.0 / (0.0015 * sampleRate))); // fast open\n\n  // overall wet trim so peaks stay < ~1.0 across programs\n  const wetTrim: f32 = 0.34;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n\n    // load per-channel state into locals\n    let pw: i32 = preWrite[c];\n    let tlp: f32 = toneLp[c];\n    let dx: f32 = dcX[c];\n    let dy: f32 = dcY[c];\n\n    for (let f = 0; f < n; f++) {\n      const dryIn: f32 = inBuf[base + f];\n\n      // ---- pre-delay ----\n      const preBase: i32 = c * PRE_LEN;\n      preBuf[preBase + (pw & PRE_MASK)] = dryIn;\n      const preRd: i32 = (pw - preD) & PRE_MASK;\n      const pre: f32 = preBuf[preBase + preRd];\n      pw = (pw + 1) & PRE_MASK;\n\n      // ---- parallel comb bank with per-line damping ----\n      let combSum: f32 = 0.0;\n      for (let k = 0; k < NC; k++) {\n        const ci: i32 = c * NC + k;\n        const cbase: i32 = ci * COMB_LEN;\n        const cw: i32 = combWrite[ci];\n        const cd: i32 = combDelay[ci];\n        const cr: i32 = (cw - cd) & COMB_MASK;\n        const y: f32 = combBuf[cbase + cr];\n\n        // damp the feedback path (one-pole LP), then feed back\n        let dz: f32 = combDamp[ci];\n        dz = dz + dampAmt * (y - dz);\n        combDamp[ci] = dz;\n\n        const fbIn: f32 = pre + dz * fbBase;\n        combBuf[cbase + (cw & COMB_MASK)] = fbIn;\n        combWrite[ci] = (cw + 1) & COMB_MASK;\n\n        combSum += y;\n      }\n      combSum *= 0.25;\n\n      // ---- series allpass diffusion ----\n      let dif: f32 = combSum;\n      for (let k = 0; k < NA; k++) dif = allpass(c, k, dif, apG);\n\n      // ---- grainy quantiser + grit (early-digital character) ----\n      // round to a coarse grid, add a tiny pseudo-random LSB dither.\n      let q: f32 = f32(Mathf.floor(dif * invQ + 0.5)) * qStep;\n      // cheap deterministic grit from the fractional residue\n      const grit: f32 = (dif * invQ - f32(Mathf.floor(dif * invQ))) - 0.5;\n      q += grit * qStep * 0.5;\n\n      // ---- sparkle high-shelf: emphasise (x - lowpassed x) ----\n      tlp = tlp + toneCoeff * (q - tlp);\n      const high: f32 = q - tlp;\n      let wet: f32 = tlp + high * (1.0 + sparkle);\n\n      // ---- dc blocker ----\n      const dcOut: f32 = wet - dx + dcR * dy;\n      dx = wet; dy = dcOut;\n      wet = dcOut;\n\n      // ---- gate program: chop the tail with an envelope ----\n      if (gateMode) {\n        if (c == 0) {\n          const env: f32 = wet < 0.0 ? -wet : wet;\n          // open on dry transient detected at input\n          const trig: f32 = dryIn < 0.0 ? -dryIn : dryIn;\n          if (trig > gateThresh) gateHold = holdSamples;\n          if (gateHold > 0.0) {\n            gateEnv = gateEnv + (1.0 - gateEnv) * (1.0 - gateAttack);\n            gateHold -= 1.0;\n          } else {\n            gateEnv *= gateRelease;\n          }\n        }\n        wet *= gateEnv;\n      }\n\n      wet *= wetTrim;\n\n      // ---- mix (equal-ish; Mix==1 still keeps a touch of dry-free wet) ----\n      outBuf[base + f] = dryIn * (1.0 - mix) + wet * mix;\n    }\n\n    // store state back\n    preWrite[c] = pw;\n    toneLp[c] = tlp;\n    dcX[c] = dx;\n    dcY[c] = dy;\n  }\n}\n",
  "publishedAt": 1751000040000
}