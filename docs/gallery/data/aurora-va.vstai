  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Aurora VA</title>\n<style>\n  :root{ --acc:#ff3d3d; --acc2:#ff9a5a; --bg0:#0c0606; --bg1:#1c0e0e; --ink:#f6e6e2; --dim:#9c7a76; }\n  *{ box-sizing:border-box; margin:0; padding:0; }\n  html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#2c1212 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none;\n    display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#3a1414,#160a0a); border:1px solid rgba(255,61,61,.22);\n    box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,220,210,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px;\n    background:linear-gradient(90deg,#fff,var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 12px var(--acc); animation:pulse 2.2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .screen{ height:100px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative;\n    background:linear-gradient(180deg,#1a0c0c,#160a0a); border:1px solid rgba(255,61,61,.18); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .shp{ position:absolute; right:12px; top:8px; font-size:10px; letter-spacing:.14em; color:var(--acc2); z-index:2; font-weight:700; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; }\n  .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,180,170,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,61,61,.6)); }\n  .pcap{ fill:#180a0a; stroke:rgba(255,61,61,.22); stroke-width:1; }\n  .ptr{ stroke:#fff; stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,61,61,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(255,61,61,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">AURORA&nbsp;VA</span><span class=\"sub\">virtual analog · morph</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">OSCILLATOR</div><div class=\"shp\" id=\"shp\">SAW</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Shape\",idx:0,def:0.6},{name:\"Cutoff\",idx:1,def:0.6},{name:\"Reso\",idx:2,def:0.35},{name:\"Sync\",idx:3,def:0.0},{name:\"Env\",idx:4,def:0.5},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  function morph(ph,sh){ var sine=Math.sin(ph*Math.PI*2), tri=1-4*Math.abs(ph-0.5), saw=ph*2-1, pulse=ph<0.5?0.85:-0.85;\n    if(sh<0.333){var t=sh/0.333;return sine*(1-t)+tri*t;} if(sh<0.666){var t2=(sh-0.333)/0.333;return tri*(1-t2)+saw*t2;}\n    var t3=(sh-0.666)/0.334;return saw*(1-t3)+pulse*t3; }\n  var shp=document.getElementById(\"shp\");\n  function shpName(){ var s=vals[0]; return s<0.2?\"SINE\":(s<0.45?\"TRI\":(s<0.72?\"SAW\":\"PULSE\")); }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\">'+\n      '<defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ff3d3d\"/><stop offset=\"1\" stop-color=\"#ff9a5a\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle>'+\n      '<circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle>'+\n      '<line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div>'+\n      '<span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2));\n      val.textContent=Math.round(v*100)+\"%\"; if(p.idx===0&&shp) shp.textContent=shpName(); }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; });\n    el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def);\n    return {render:render};\n  });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){\n    ctx.clearRect(0,0,W,H); var sh=vals[0], cut=vals[1], sync=vals[3]; var mid=H*0.55;\n    ctx.strokeStyle=\"rgba(255,61,61,0.10)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.moveTo(0,mid); ctx.lineTo(W,mid); ctx.stroke();\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=2){ var t=x/W; var ph=(t*3*(1+sync*2.5)+ts/700)%1; var y=morph(ph,sh)*(0.5+cut*0.5);\n      if(x===0) ctx.moveTo(x,mid-y*(H*0.34)); else ctx.lineTo(x,mid-y*(H*0.34)); }\n    ctx.strokeStyle=\"rgba(255,80,70,0.95)\"; ctx.lineWidth=2.4; ctx.shadowColor=\"#ff3d3d\"; ctx.shadowBlur=9; ctx.stroke(); ctx.shadowBlur=0;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  AURORA VA — a clean modern virtual-analog lead (Nord Lead lineage).\n//  Distinct from the hypersaw VA: a single morphable oscillator whose\n//  Shape control sweeps continuously sine -> triangle -> saw -> pulse,\n//  with oscillator SYNC for bite, a clean resonant low-pass with its own\n//  envelope, and a snappy amp envelope. 8-voice poly. No samples, no host\n//  imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NVOX: i32 = 8;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\nconst vDrift: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGL: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vGR: StaticArray<f32> = new StaticArray<f32>(NVOX);\n\nconst vPh: StaticArray<f32> = new StaticArray<f32>(NVOX);   // master phase\nconst vPhS: StaticArray<f32> = new StaticArray<f32>(NVOX);  // sync-slave phase\nconst vAmp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vFEnv: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vSt: StaticArray<i32> = new StaticArray<i32>(NVOX);\nconst vFreq: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vVel: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vLp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vBp: StaticArray<f32> = new StaticArray<f32>(NVOX);\nconst vNote: StaticArray<i32> = new StaticArray<i32>(NVOX);\nlet vNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\n\nconst P_SHAPE: i32 = 0;\nconst P_CUTOFF: i32 = 1;\nconst P_RESO: i32 = 2;\nconst P_SYNC: i32 = 3;\nconst P_ENV: i32 = 4;\nconst P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\nlet rngState: i32 = 0x2b9f17;\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\n// morph sine -> triangle -> saw -> pulse over shape 0..1\n@inline function morphWave(ph: f32, shape: f32): f32 {\n  const sine: f32 = f32(Mathf.sin(ph * 6.2831853));\n  const tri: f32 = 1.0 - 4.0 * f32(Mathf.abs(ph - 0.5));\n  const saw: f32 = ph * 2.0 - 1.0;\n  const pulse: f32 = ph < 0.5 ? 0.85 : -0.85;\n  if (shape < 0.333) { const t = shape / 0.333; return sine * (1.0 - t) + tri * t; }\n  if (shape < 0.666) { const t = (shape - 0.333) / 0.333; return tri * (1.0 - t) + saw * t; }\n  const t = (shape - 0.666) / 0.334; return saw * (1.0 - t) + pulse * t;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  vNext = 0;\n  for (let i = 0; i < NVOX; i++) { vSt[i] = 0; vPh[i] = 0.0; vPhS[i] = 0.0; vAmp[i] = 0.0; vFEnv[i] = 0.0; vFreq[i] = 220.0; vVel[i] = 0.0; vLp[i] = 0.0; vBp[i] = 0.0; vNote[i] = -1; }\n  params[P_SHAPE] = 0.6; params[P_CUTOFF] = 0.6; params[P_RESO] = 0.35; params[P_SYNC] = 0.0; params[P_ENV] = 0.5; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const slot: i32 = vNext; vNext = (vNext + 1) % NVOX;\n  vPh[slot] = 0.0; vPhS[slot] = 0.0; vAmp[slot] = 0.0; vFEnv[slot] = 1.0; vSt[slot] = 1;\n  vFreq[slot] = f > 0.0 ? f : 220.0; vVel[slot] = clampf(v, 0.05, 1.0); vLp[slot] = 0.0; vBp[slot] = 0.0; vNote[slot] = id;\n}\nexport function noteOff(id: i32): void { for (let i = 0; i < NVOX; i++) { if (vSt[i] != 0 && vNote[i] == id) vSt[i] = 2; } }\n\nexport function process(n: i32): void {\n  const shapeN: f32 = clampf(params[P_SHAPE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const syncN: f32 = clampf(params[P_SYNC], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkInc: f32 = 1.0 / (0.004 * sampleRate);\n  const relCoef: f32 = f32(Mathf.exp(-1.0 / (0.3 * sampleRate)));\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.45 * sampleRate)));\n  const baseCut: f32 = 50.0 * f32(Mathf.exp(cutoffN * 5.4));\n  const envSpan: f32 = envN * 8000.0;\n  const k: f32 = 2.0 - 1.92 * resoN;\n  const syncRatio: f32 = 1.0 + syncN * 2.5;   // sync-slave runs higher\n  const out: f32 = level * 0.5;\n\n    const _width: f32 = 0.55;\n  for (let _s = 0; _s < NVOX; _s++) { const _pr: i32 = (_s + 1) / 2; const _mg: f32 = _s == 0 ? 0.0 : (1.0 - f32(_pr - 1) / f32(NVOX)); const _pan: f32 = ((_s % 2 == 1) ? -_mg : _mg) * _width; vGL[_s] = f32(Mathf.sqrt(0.5 * (1.0 - _pan))); vGR[_s] = f32(Mathf.sqrt(0.5 * (1.0 + _pan))); }\n  const _dLeak: f32 = 0.9998; const _dStep: f32 = 0.00006;\n\n  for (let i = 0; i < n; i++) {\n    let mixL: f32 = 0.0; let mixR: f32 = 0.0;\n    for (let s = 0; s < NVOX; s++) {\n      if (vSt[s] == 0) continue;\n      vDrift[s] = vDrift[s] * _dLeak + rnd() * _dStep;\n      const fr: f32 = vFreq[s] * (1.0 + vDrift[s]);\n      if (vSt[s] == 1) { vAmp[s] += atkInc; if (vAmp[s] > 1.0) vAmp[s] = 1.0; }\n      else { vAmp[s] *= relCoef; if (vAmp[s] < 0.0004) { vSt[s] = 0; continue; } }\n      // master phase (controls sync reset)\n      let pm: f32 = vPh[s] + fr / sampleRate;\n      let reset: bool = false;\n      if (pm >= 1.0) { pm -= 1.0; reset = true; } vPh[s] = pm;\n      // sync slave\n      let ps: f32 = vPhS[s] + (fr * syncRatio) / sampleRate; if (ps >= 1.0) ps -= 1.0;\n      if (reset && syncN > 0.01) ps = 0.0;\n      vPhS[s] = ps;\n      const osc: f32 = morphWave(syncN > 0.01 ? ps : pm, shapeN);\n      // resonant SVF LP\n      vFEnv[s] *= fEnvCoef;\n      let fc: f32 = baseCut + envSpan * vFEnv[s];\n      if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n      const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n      const a1: f32 = 1.0 / (1.0 + g * (g + k));\n      const hp: f32 = (osc - (g + k) * vBp[s] - vLp[s]) * a1;\n      const bpN: f32 = g * hp + vBp[s]; const lpN: f32 = g * bpN + vLp[s];\n      vBp[s] = bpN; vLp[s] = lpN;\n      const _v: f32 = lpN * vAmp[s] * vVel[s]; mixL += _v * vGL[s]; mixR += _v * vGR[s];\n    }\n    let oL: f32 = mixL * out; let oR: f32 = mixR * out;\n    if (oL > 1.4) oL = 1.4; else if (oL < -1.4) oL = -1.4; if (oR > 1.4) oR = 1.4; else if (oR < -1.4) oR = -1.4;\n    outBuf[i] = oL; outBuf[MAX_FRAMES + i] = oR;\n  }\n}\n",
  "publishedAt": 1751000165000
}