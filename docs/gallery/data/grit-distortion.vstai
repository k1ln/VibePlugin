{
  "format": 1,
  "name": "Grit Distortion",
  "isInstrument": false,
  "explanation": "Hard-edged, high-gain diode distortion. A high-gain input stage drives an asymmetric hard/diode clipper for an aggressive, cutting character; the signature Filter control is a reversed tone low-pass that gets DARKER as you turn it up. Controls: Distortion, Filter, Volume and dry/wet Mix.",
  "params": [
    {
      "name": "Distortion",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Filter",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Volume",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --grind{syntax:'<number>';inherits:false;initial-value:0}\n@property --sludge{syntax:'<number>';inherits:false;initial-value:0}\n@property --vol{syntax:'<number>';inherits:false;initial-value:0}\n@property --mix{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --steel:#c0c8d0;--steel2:#9aa6b4;\n  --rust:#a5552a;--rust2:#6e3217;\n  --plate:#21211e;\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace;color:#d6dae0;\n  background:#0a0a09;display:flex;align-items:center;justify-content:center;padding:16px;\n  -webkit-user-select:none;user-select:none;overflow:hidden;\n}\n\n/* ===== RUSTED CONCRETE FACEPLATE ===== */\n.machine{\n  position:relative;width:100%;max-width:600px;border-radius:6px;overflow:hidden;\n  background:\n    /* rust bleed */\n    radial-gradient(140% 60% at 18% -8%,rgba(165,85,42,.40),transparent 55%),\n    radial-gradient(120% 70% at 92% 108%,rgba(110,50,23,.45),transparent 50%),\n    /* concrete mottle */\n    repeating-radial-gradient(circle at 30% 20%,rgba(0,0,0,.05) 0 2px,transparent 2px 5px),\n    repeating-radial-gradient(circle at 78% 72%,rgba(255,255,255,.025) 0 1px,transparent 1px 4px),\n    linear-gradient(160deg,#33332e,#1a1a17 60%,#111110);\n  box-shadow:\n    0 40px 80px rgba(0,0,0,.7),\n    inset 0 2px 0 rgba(255,255,255,.06),\n    inset 0 -3px 14px rgba(0,0,0,.8),\n    inset 0 0 0 2px rgba(0,0,0,.5);\n  border:1px solid #2c2c27;\n}\n/* grime/grain noise overlay */\n.machine::before{\n  content:\"\";position:absolute;inset:0;pointer-events:none;z-index:6;mix-blend-mode:overlay;opacity:.5;\n  background-image:\n    repeating-linear-gradient(43deg,rgba(255,255,255,.04) 0 1px,transparent 1px 3px),\n    repeating-linear-gradient(137deg,rgba(0,0,0,.06) 0 1px,transparent 1px 4px);\n}\n/* scratched diagonal hazard stripes top corner */\n.machine::after{\n  content:\"\";position:absolute;top:-30px;right:-30px;width:150px;height:150px;transform:rotate(45deg);z-index:1;pointer-events:none;\n  background:repeating-linear-gradient(90deg,rgba(180,120,30,.16) 0 12px,transparent 12px 24px);\n  -webkit-mask:radial-gradient(circle at 50% 120%,#000 40%,transparent 70%);\n  mask:radial-gradient(circle at 50% 120%,#000 40%,transparent 70%);\n}\n\n/* corner bolts */\n.bolt{position:absolute;width:18px;height:18px;border-radius:50%;z-index:5;\n  background:radial-gradient(circle at 38% 32%,#8d949c,#3c3f42 60%,#16181a);\n  box-shadow:inset 0 1px 1px rgba(255,255,255,.4),inset 0 -2px 3px rgba(0,0,0,.7),0 2px 3px rgba(0,0,0,.6);}\n.bolt::after{content:\"\";position:absolute;inset:5px;border-radius:1px;background:linear-gradient(#1c1e20,#0b0c0d);transform:rotate(22deg);\n  box-shadow:inset 0 0 2px rgba(0,0,0,.9);}\n.bolt.tl{top:10px;left:10px}.bolt.tr{top:10px;right:10px}\n.bolt.bl{bottom:10px;left:10px}.bolt.br{bottom:10px;right:10px}\n\n/* ===== HEADER PLATE ===== */\n.head{position:relative;z-index:4;display:flex;align-items:center;gap:12px;padding:18px 30px 12px}\n.stencil{\n  font-weight:800;font-size:26px;letter-spacing:.14em;line-height:1;\n  font-family:\"Arial Black\",\"Helvetica Neue\",sans-serif;text-transform:uppercase;\n  color:transparent;-webkit-text-stroke:1.4px #cdd2d8;\n  background:repeating-linear-gradient(90deg,#e2e6ea 0 14px,rgba(226,230,234,.45) 14px 17px);\n  -webkit-background-clip:text;background-clip:text;\n  filter:drop-shadow(0 2px 0 rgba(0,0,0,.6));\n}\n.stencil .x{-webkit-text-stroke-color:var(--rust);color:transparent;\n  background:repeating-linear-gradient(90deg,#c9692f 0 14px,rgba(201,105,47,.4) 14px 17px);-webkit-background-clip:text;background-clip:text;}\n.sub{margin-left:auto;text-align:right}\n.tag{font-size:9px;letter-spacing:.32em;color:#7d8489;text-transform:uppercase}\n.serial{font-size:9px;letter-spacing:.18em;color:#5d6266;margin-top:3px}\n.pwr{display:inline-block;width:8px;height:8px;border-radius:50%;background:var(--rust);margin-right:5px;\n  box-shadow:0 0 8px var(--rust),0 0 2px #ffae6e inset;animation:flick 3.3s infinite}\n@keyframes flick{0%,93%,97%{opacity:1}94%,96%{opacity:.25}}\n\n/* ===== MAIN DECK ===== */\n.deck{position:relative;z-index:4;display:grid;grid-template-columns:1.25fr 1fr;gap:18px;padding:6px 30px 8px}\n.rivetline{position:absolute;left:30px;right:30px;top:0;height:1px;z-index:4;\n  background:linear-gradient(90deg,transparent,rgba(0,0,0,.6),transparent)}\n\n/* ---- GRINDER (Distortion) ---- */\n.grinder{position:relative;display:flex;flex-direction:column;align-items:center;justify-content:center;\n  padding:14px 0 10px;border-radius:8px;\n  background:radial-gradient(circle at 50% 42%,rgba(0,0,0,.55),rgba(0,0,0,.15) 70%,transparent);\n  box-shadow:inset 0 0 30px rgba(0,0,0,.55),inset 0 0 0 1px rgba(255,255,255,.03)}\n.grind-wrap{position:relative;width:160px;height:160px;cursor:grab;touch-action:none}\n.grind-wrap:active{cursor:grabbing}\n/* sparks ring (intensifies with distortion) */\n.sparks{position:absolute;inset:-14px;border-radius:50%;pointer-events:none;opacity:calc(.15 + var(--grind)*.85);\n  background:\n    radial-gradient(circle at 50% -2%,rgba(255,160,60,.9),transparent 6%),\n    radial-gradient(circle at 100% 50%,rgba(255,120,40,.9),transparent 6%),\n    radial-gradient(circle at 50% 102%,rgba(255,180,80,.9),transparent 6%),\n    radial-gradient(circle at 0% 50%,rgba(255,140,50,.9),transparent 6%);\n  filter:blur(calc(1px + var(--grind)*3px));animation:spin calc(1.4s - var(--grind)*1s) linear infinite;}\n@keyframes spin{to{transform:rotate(360deg)}}\n/* heat glow */\n.heat{position:absolute;inset:6px;border-radius:50%;pointer-events:none;\n  box-shadow:0 0 calc(6px + var(--grind)*40px) calc(var(--grind)*8px) rgba(255,90,20,calc(.2 + var(--grind)*.55));\n  background:radial-gradient(circle,rgba(255,70,20,calc(var(--grind)*.30)),transparent 65%)}\n/* serrated grinding wheel — rotates while dragging */\n.wheel{position:absolute;inset:14px;border-radius:50%;\n  background:\n    conic-gradient(from 0deg,#4a4d52,#1d1f22 8%,#5b5f64 16%,#222428 24%,#54585d 32%,#1d1f22 40%,#5b5f64 48%,#222428 56%,#54585d 64%,#1d1f22 72%,#5b5f64 80%,#222428 88%,#4a4d52 100%);\n  box-shadow:inset 0 0 0 3px #0c0d0e,inset 0 4px 14px rgba(0,0,0,.8),0 2px 6px rgba(0,0,0,.6);\n  transform:rotate(calc(var(--grind)*900deg));transition:transform .12s linear;\n  animation:idle calc(7s - var(--grind)*5.5s) linear infinite}\n@keyframes idle{to{transform:rotate(360deg)}}\n/* teeth ring */\n.teeth{position:absolute;inset:8px;border-radius:50%;pointer-events:none;\n  background:repeating-conic-gradient(#7c8085 0 3deg,transparent 3deg 9deg);\n  -webkit-mask:radial-gradient(circle,transparent 64px,#000 65px,#000 72px,transparent 73px);\n  mask:radial-gradient(circle,transparent 64px,#000 65px,#000 72px,transparent 73px);}\n/* hub cap with the value */\n.hub{position:absolute;inset:46px;border-radius:50%;z-index:2;display:flex;align-items:center;justify-content:center;\n  background:radial-gradient(circle at 42% 34%,#3a3d42,#121315 72%);\n  box-shadow:inset 0 2px 5px rgba(255,255,255,.08),inset 0 -3px 8px rgba(0,0,0,.8),0 0 0 2px #0a0b0c,0 0 0 4px rgba(255,120,40,calc(var(--grind)*.6));}\n.hub b{font-size:20px;font-weight:800;color:#e9c6a4;font-variant-numeric:tabular-nums;\n  text-shadow:0 0 calc(2px + var(--grind)*12px) rgba(255,120,40,.9)}\n.dlabel{margin-top:10px;font-size:11px;letter-spacing:.3em;color:#b9bfc5;text-transform:uppercase}\n.dsub{font-size:9px;letter-spacing:.22em;color:#6e7479;margin-top:2px}\n\n/* ---- RIGHT COLUMN ---- */\n.side{display:flex;flex-direction:column;gap:14px;justify-content:center}\n\n/* SLUDGE filter gauge (vertical, fills DOWN/darker as value rises) */\n.gauge{position:relative;display:flex;gap:12px;align-items:stretch;\n  padding:10px 12px;border-radius:8px;background:linear-gradient(#16140f,#0c0b08);\n  box-shadow:inset 0 2px 6px rgba(0,0,0,.7),inset 0 0 0 1px rgba(255,255,255,.04)}\n.tube{position:relative;width:34px;border-radius:5px;overflow:hidden;cursor:ns-resize;touch-action:none;\n  background:linear-gradient(90deg,#2b2823,#3a362e,#26231e);\n  box-shadow:inset 0 0 0 1px rgba(0,0,0,.7),inset 2px 0 4px rgba(255,255,255,.05)}\n/* sludge fills from the TOP and darkens the signal as Filter rises (reversed tone) */\n.muck{position:absolute;left:0;right:0;top:0;height:calc(var(--sludge)*100%);\n  background:linear-gradient(180deg,#1a1610,#0c0a06);\n  box-shadow:inset 0 -6px 10px rgba(0,0,0,.8);transition:height .12s ease}\n.muck::after{content:\"\";position:absolute;left:0;right:0;bottom:-3px;height:7px;\n  background:repeating-linear-gradient(90deg,#3d342a 0 6px,#241e17 6px 12px);border-radius:0 0 3px 3px;\n  filter:blur(.4px);box-shadow:0 0 6px rgba(0,0,0,.6)}\n/* bubbles in the sludge */\n.bub{position:absolute;width:5px;height:5px;border-radius:50%;background:rgba(120,90,55,.5);\n  left:var(--bx);bottom:0;animation:rise var(--bt) linear infinite;opacity:calc(var(--sludge))}\n@keyframes rise{0%{transform:translateY(0);opacity:0}20%{opacity:.6}100%{transform:translateY(-90px);opacity:0}}\n.gmeta{display:flex;flex-direction:column;justify-content:center;flex:1;gap:4px}\n.gmeta .gn{font-size:11px;letter-spacing:.26em;color:#caa37a;text-transform:uppercase}\n.gmeta .gv{font-size:22px;font-weight:800;color:#e9d3b5;font-variant-numeric:tabular-nums}\n.gmeta .gd{font-size:9px;letter-spacing:.14em;color:#a99270;line-height:1.4}\n/* keyboard focus ring on custom controls */\n.grind-wrap:focus-visible,.tube:focus-visible,.track:focus-visible{\n  outline:2px solid #e8a25a;outline-offset:3px;border-radius:8px}\n.grind-wrap:focus-visible{border-radius:50%}\n\n/* CHUNKY industrial sliders for Volume + Mix */\n.fader{position:relative;padding:8px 12px 10px;border-radius:8px;\n  background:linear-gradient(#1b1b17,#0e0e0c);box-shadow:inset 0 2px 6px rgba(0,0,0,.6),inset 0 0 0 1px rgba(255,255,255,.03)}\n.fhead{display:flex;justify-content:space-between;align-items:baseline;margin-bottom:7px}\n.fhead .fn{font-size:10px;letter-spacing:.26em;color:#aab0b6;text-transform:uppercase}\n.fhead .fvv{font-size:14px;font-weight:800;color:var(--steel);font-variant-numeric:tabular-nums}\n.track{position:relative;height:14px;border-radius:7px;cursor:pointer;touch-action:none;\n  background:linear-gradient(#070707,#191917);box-shadow:inset 0 1px 3px rgba(0,0,0,.9),inset 0 0 0 1px rgba(255,255,255,.04)}\n.track .fill{position:absolute;left:0;top:0;bottom:0;border-radius:7px 0 0 7px;\n  background:linear-gradient(90deg,var(--rust2),var(--rust) 60%,var(--steel));box-shadow:0 0 10px rgba(165,85,42,.4);transition:width .1s ease}\n.track .grip{position:absolute;top:50%;width:22px;height:30px;margin-left:-11px;transform:translateY(-50%);border-radius:4px;\n  background:linear-gradient(#9aa0a6,#4b4f54 55%,#2a2d30);\n  box-shadow:0 2px 5px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.5),inset 0 -2px 3px rgba(0,0,0,.6);transition:left .1s ease}\n.track .grip::after{content:\"\";position:absolute;inset:5px 8px;border-radius:1px;\n  background:repeating-linear-gradient(90deg,#2c2f32 0 2px,#73787d 2px 4px)}\n\n/* footer plate */\n.plate{position:relative;z-index:4;margin:6px 30px 18px;padding-top:11px;\n  border-top:1px solid rgba(0,0,0,.55);box-shadow:0 -1px 0 rgba(255,255,255,.04);\n  font-size:10px;line-height:1.5;color:#7b7468;letter-spacing:.03em}\n.plate b{color:#b08a5e;font-weight:700}\n</style></head><body>\n<div class=\"machine\">\n  <span class=\"bolt tl\"></span><span class=\"bolt tr\"></span><span class=\"bolt bl\"></span><span class=\"bolt br\"></span>\n\n  <div class=\"head\">\n    <div class=\"stencil\">GR<span class=\"x\">I</span>T</div>\n    <div class=\"sub\">\n      <div class=\"tag\"><span class=\"pwr\"></span>diode clipper</div>\n      <div class=\"serial\">UNIT&nbsp;//&nbsp;HG-666</div>\n    </div>\n  </div>\n\n  <div class=\"deck\">\n    <div class=\"rivetline\"></div>\n\n    <!-- DISTORTION : the grinder -->\n    <div class=\"grinder\">\n      <div class=\"grind-wrap\" id=\"grind\" data-i=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\"\n           role=\"slider\" tabindex=\"0\" aria-label=\"Distortion\" aria-valuemin=\"0\" aria-valuemax=\"100\" aria-valuenow=\"50\" aria-valuetext=\"50%\">\n        <div class=\"sparks\"></div>\n        <div class=\"heat\"></div>\n        <div class=\"wheel\"></div>\n        <div class=\"teeth\"></div>\n        <div class=\"hub\"><b id=\"dval\">50</b></div>\n      </div>\n      <div class=\"dlabel\">Distortion</div>\n      <div class=\"dsub\">high-gain&nbsp;·&nbsp;asymmetric</div>\n    </div>\n\n    <div class=\"side\">\n\n      <!-- FILTER : sludge gauge (darker as you turn it up) -->\n      <div class=\"gauge\">\n        <div class=\"tube\" id=\"filt\" data-i=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.4\" data-step=\"0.001\"\n             role=\"slider\" tabindex=\"0\" aria-label=\"Filter, reversed tone (higher is darker)\" aria-orientation=\"vertical\" aria-valuemin=\"0\" aria-valuemax=\"1\" aria-valuenow=\"0.4\" aria-valuetext=\"0.40, darker\">\n          <div class=\"muck\" id=\"muck\">\n            <span class=\"bub\" style=\"--bx:6px;--bt:2.4s\"></span>\n            <span class=\"bub\" style=\"--bx:18px;--bt:3.1s\"></span>\n            <span class=\"bub\" style=\"--bx:12px;--bt:2.7s\"></span>\n          </div>\n        </div>\n        <div class=\"gmeta\">\n          <span class=\"gn\">Filter</span>\n          <span class=\"gv\" id=\"fval\">0.40</span>\n          <span class=\"gd\">reversed tone —<br>drag up = darker / muddier</span>\n        </div>\n      </div>\n\n      <!-- VOLUME -->\n      <div class=\"fader\" id=\"vol\" data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.6\" data-step=\"0.001\">\n        <div class=\"fhead\"><span class=\"fn\">Volume</span><span class=\"fvv\" id=\"vval\">0.60</span></div>\n        <div class=\"track\" id=\"vtrack\" role=\"slider\" tabindex=\"0\" aria-label=\"Volume\" aria-valuemin=\"0\" aria-valuemax=\"1\" aria-valuenow=\"0.6\" aria-valuetext=\"0.60\"><div class=\"fill\" id=\"vfill\"></div><div class=\"grip\" id=\"vgrip\"></div></div>\n      </div>\n\n      <!-- MIX -->\n      <div class=\"fader\" id=\"mix\" data-i=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"1\" data-step=\"0.001\">\n        <div class=\"fhead\"><span class=\"fn\">Mix · dry/wet</span><span class=\"fvv\" id=\"mval\">1.00</span></div>\n        <div class=\"track\" id=\"mtrack\" role=\"slider\" tabindex=\"0\" aria-label=\"Mix, dry to wet\" aria-valuemin=\"0\" aria-valuemax=\"1\" aria-valuenow=\"1\" aria-valuetext=\"1.00\"><div class=\"fill\" id=\"mfill\"></div><div class=\"grip\" id=\"mgrip\"></div></div>\n      </div>\n\n    </div>\n  </div>\n\n  <div class=\"plate\"><b>GRIT</b> — hard-edged high-gain diode distortion. Drives an asymmetric hard clipper for an aggressive, cutting character. Mind the heat.</div>\n</div>\n\n<script>\n(function(){\n  var root=document.querySelector('.machine');\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function clamp(n){ return n<0?0:(n>1?1:n); }\n  function fmt(v){ return (+v).toFixed(2); }\n  // arrow/home/end keyboard nudging for any role=slider; calls setN with the new value\n  function keyNudge(el,getN,setN,coarse){\n    var step=coarse?.05:.01;\n    el.addEventListener('keydown',function(e){\n      var n=getN(),k=e.key,h=0;\n      if(k==='ArrowUp'||k==='ArrowRight')h=step;\n      else if(k==='ArrowDown'||k==='ArrowLeft')h=-step;\n      else if(k==='PageUp')h=step*5;\n      else if(k==='PageDown')h=-step*5;\n      else if(k==='Home'){setN(0);e.preventDefault();return;}\n      else if(k==='End'){setN(1);e.preventDefault();return;}\n      else return;\n      setN(n+h);e.preventDefault();\n    });\n  }\n\n  // ---- DISTORTION grinder (rotary drag) ----\n  function grinder(){\n    var el=document.getElementById('grind'), val=+el.dataset.def, def=val, i=+el.dataset.i;\n    var dv=document.getElementById('dval');\n    function norm(){ return val; }\n    function paint(){\n      root.style.setProperty('--grind',val);\n      var pc=Math.round(val*100);\n      dv.textContent=pc;\n      el.setAttribute('aria-valuenow',pc);\n      el.setAttribute('aria-valuetext',pc+'%');\n      send(i,val);\n    }\n    function setN(n){ val=clamp(n); paint(); }\n    var dy=0,n0=0,drag=0;\n    el.addEventListener('pointerdown',function(e){drag=1;dy=e.clientY;n0=norm();el.setPointerCapture(e.pointerId);e.preventDefault();});\n    el.addEventListener('pointermove',function(e){ if(!drag)return; setN(n0+(dy-e.clientY)/220); });\n    el.addEventListener('pointerup',function(){drag=0;});\n    el.addEventListener('pointercancel',function(){drag=0;});\n    el.addEventListener('dblclick',function(){val=def;paint();});\n    el.addEventListener('wheel',function(e){e.preventDefault();setN(norm()+(e.deltaY<0?.03:-.03));},{passive:false});\n    keyNudge(el,norm,setN,false);\n    paint();\n  }\n\n  // ---- FILTER sludge tube (vertical drag) ----\n  function filter(){\n    var el=document.getElementById('filt'), val=+el.dataset.def, def=val, i=+el.dataset.i;\n    var muck=document.getElementById('muck'), fv=document.getElementById('fval');\n    function norm(){ return val; }\n    function paint(){\n      muck.style.height=(val*100)+'%';\n      root.style.setProperty('--sludge',val);\n      fv.textContent=fmt(val);\n      el.setAttribute('aria-valuenow',fmt(val));\n      el.setAttribute('aria-valuetext',fmt(val)+', '+(val>.5?'darker':'brighter'));\n      send(i,val);\n    }\n    function setN(n){ val=clamp(n); paint(); }\n    var drag=0;\n    // bottom-up mapping: dragging up raises the value (standard fader feel),\n    // the muck still fills visually from the top so \"higher = more sludge = darker\".\n    function fromY(e){ var r=el.getBoundingClientRect(); return clamp(1-(e.clientY-r.top)/r.height); }\n    el.addEventListener('pointerdown',function(e){drag=1;el.setPointerCapture(e.pointerId);\n      setN(fromY(e));e.preventDefault();});\n    el.addEventListener('pointermove',function(e){ if(!drag)return; setN(fromY(e)); });\n    el.addEventListener('pointerup',function(){drag=0;});\n    el.addEventListener('pointercancel',function(){drag=0;});\n    el.addEventListener('dblclick',function(){val=def;paint();});\n    el.addEventListener('wheel',function(e){e.preventDefault();setN(val+(e.deltaY<0?.03:-.03));},{passive:false});\n    keyNudge(el,norm,setN,false);\n    paint();\n  }\n\n  // ---- FADERS (Volume, Mix) ----\n  function fader(cellId,trackId,fillId,gripId,valId){\n    var el=document.getElementById(cellId), tr=document.getElementById(trackId),\n        fill=document.getElementById(fillId), grip=document.getElementById(gripId), vv=document.getElementById(valId);\n    var val=+el.dataset.def, def=val, i=+el.dataset.i;\n    function norm(){ return val; }\n    function paint(){\n      var pct=val*100;\n      fill.style.width=pct+'%';\n      grip.style.left=pct+'%';\n      vv.textContent=fmt(val);\n      tr.setAttribute('aria-valuenow',fmt(val));\n      tr.setAttribute('aria-valuetext',fmt(val));\n      send(i,val);\n    }\n    function setN(n){ val=clamp(n); paint(); }\n    function fromX(e){ var r=tr.getBoundingClientRect(); return clamp((e.clientX-r.left)/r.width); }\n    var drag=0;\n    tr.addEventListener('pointerdown',function(e){drag=1;tr.setPointerCapture(e.pointerId);setN(fromX(e));e.preventDefault();});\n    tr.addEventListener('pointermove',function(e){ if(!drag)return; setN(fromX(e)); });\n    tr.addEventListener('pointerup',function(){drag=0;});\n    tr.addEventListener('pointercancel',function(){drag=0;});\n    tr.addEventListener('dblclick',function(){val=def;paint();});\n    tr.addEventListener('wheel',function(e){e.preventDefault();setN(val+(e.deltaY<0?.02:-.02));},{passive:false});\n    keyNudge(tr,norm,setN,false);\n    paint();\n  }\n\n  function ready(){\n    grinder();\n    filter();\n    fader('vol','vtrack','vfill','vgrip','vval');\n    fader('mix','mtrack','mfill','mgrip','mval');\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  GRIT DISTORTION — hard-edged, high-gain diode distortion\n//  A high-gain input stage drives an asymmetric hard/diode clipper for an\n//  aggressive, cutting fuzz-into-distortion character. The signature\n//  \"Filter\" control is a REVERSED tone low-pass: turning it UP makes the\n//  sound DARKER (rolls off treble), the opposite of a normal tone knob.\n//  Followed by output Volume and a dry/wet Mix. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-clip DC/sub blocker\nconst filtState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post \"Filter\" LP (1)\nconst filtState2:StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post \"Filter\" LP (2, 2-pole)\n\nconst P_DIST: i32 = 0;   // 0..1 -> input gain 1..150 (high-gain stage)\nconst P_FILTER: i32 = 1; // 0..1 -> REVERSED tone: 0=bright(~12kHz), 1=dark(~500Hz)\nconst P_VOLUME: i32 = 2; // 0..1 -> 0..1 output level\nconst P_MIX: i32 = 3;    // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    dcState[c] = 0.0; filtState[c] = 0.0; filtState2[c] = 0.0;\n  }\n  params[P_DIST] = 0.5; params[P_FILTER] = 0.4; params[P_VOLUME] = 0.6; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Asymmetric hard/diode clipper: tanh soft knee blended toward a hard\n// diode-style clip. Asymmetry adds even harmonics for grit & bite.\n@inline function diodeClip(x: f32): f32 {\n  // tanh-style saturation gives the aggressive but smooth high-gain edge\n  const s: f32 = f32(Mathf.tanh(x));\n  // hard clip ceiling — the diodes pin the signal\n  const h: f32 = clampf(x, -1.0, 1.0);\n  // blend: mostly the hard diode pin, with tanh rounding for less fizz\n  return f32(0.78 * h + 0.22 * s);\n}\n\nexport function process(n: i32): void {\n  const distN: f32 = clampf(params[P_DIST], 0.0, 1.0);\n  const filterN: f32 = clampf(params[P_FILTER], 0.0, 1.0);\n  const volume: f32 = clampf(params[P_VOLUME], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // high-gain input stage: 1..150 (exponential feel)\n  const gain: f32 = f32(1.0 + distN * distN * 149.0);\n\n  // pre-clip DC/sub high-pass corner ~30 Hz keeps the low end tight\n  const cDc: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 30.0 / sampleRate));\n\n  // asymmetry bias scaled down at high gain so DC doesn't run away\n  const bias: f32 = f32(0.12);\n\n  // REVERSED tone: filterN 0 -> bright ~12kHz, filterN 1 -> dark ~500Hz.\n  // map exponentially so the darkening sweep feels smooth.\n  const fHz: f32 = f32(500.0 + (1.0 - filterN) * (1.0 - filterN) * 11500.0);\n  const fHzC: f32 = clampf(fHz, 200.0, sampleRate * 0.45);\n  const cFilt: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * fHzC / sampleRate));\n\n  // gain compensation: keep perceived level steady as Dist climbs, and\n  // hold the broadband peak well under 1.0.\n  const comp: f32 = f32(2.6 / Mathf.sqrt(gain));\n\n  const out: f32 = volume;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let dc: f32 = dcState[c];\n    let lp: f32 = filtState[c];\n    let lp2: f32 = filtState2[c];\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // pre-clip DC/sub blocker (high-pass)\n      dc = f32(dc + cDc * (x - dc));\n      const hp: f32 = f32(x - dc);\n\n      // high-gain stage + asymmetric bias into the diode clipper\n      const driven: f32 = f32(diodeClip(hp * gain + bias) - diodeClip(bias));\n      let y: f32 = f32(driven * comp);\n\n      // post \"Filter\" — 2-pole low-pass, darker as filterN rises\n      lp = f32(lp + cFilt * (y - lp));\n      lp2 = f32(lp2 + cFilt * (lp - lp2));\n      y = lp2;\n\n      const wet: f32 = f32(y * out);\n      outBuf[base + f] = f32(x * (1.0 - mix) + wet * mix);\n    }\n    dcState[c] = dc;\n    filtState[c] = lp;\n    filtState2[c] = lp2;\n  }\n}\n",
  "publishedAt": 1751000008000
}