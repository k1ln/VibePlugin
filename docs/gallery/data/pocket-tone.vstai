{
  "format": 1,
  "name": "Pocket Tone",
  "isInstrument": true,
  "explanation": "A lo-fi mini-digital pocket synth with a charming toy-instrument character. Six voices play one of five selectable single-cycle timbres (piano, fantasy, violin, flute, guitar), each built from a short additive or pulse formula, through a simple AR amplitude contour with a touch of pitch vibrato. A BITS control adds the unmistakable cheap-digital crunch via combined bit-depth and sample-rate reduction. Controls: Voice, Attack, Release, Vibrato, Bits and Level.",
  "params": [
    {
      "name": "Voice",
      "index": 0,
      "min": 0,
      "max": 4,
      "default": 0
    },
    {
      "name": "Attack",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.04
    },
    {
      "name": "Release",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Vibrato",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Bits",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Pocket Tone</title>\n<style>\n  @property --glow { syntax: '<number>'; inherits: false; initial-value: 0; }\n\n  :root {\n    --ac:  #ff5a9e;          /* pink accent  */\n    --ac2: #43d6ff;          /* cyan accent  */\n    --case:  #c9c8c2;        /* grey gadget body */\n    --case2: #aeaca4;\n    --case3: #8d8b83;\n    --ink:   #2a2a28;\n    --lcd:   #b7c6a0;        /* olive LCD glass */\n    --lcd2:  #9fb085;\n    --lcdink:#1d2614;\n    --rubber: #d7d6cf;\n  }\n\n  * { box-sizing: border-box; }\n  html, body { margin: 0; height: 100%; }\n  body {\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2c2f36 0%, #16181d 55%, #0b0c0f 100%);\n    display: flex; align-items: center; justify-content: center;\n    padding: 18px; min-height: 100%;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  /* ---------------- the gadget chassis ---------------- */\n  .gadget {\n    position: relative;\n    width: 100%; max-width: 440px;\n    border-radius: 20px 20px 26px 26px;\n    padding: 16px 16px 20px;\n    background:\n      linear-gradient(155deg, #e2e1da 0%, var(--case) 26%, var(--case2) 74%, var(--case3) 100%);\n    box-shadow:\n      0 30px 60px rgba(0,0,0,.55),\n      0 2px 0 rgba(255,255,255,.7) inset,\n      0 -6px 18px rgba(0,0,0,.28) inset,\n      0 0 0 1px rgba(0,0,0,.25);\n    animation: drop .6s cubic-bezier(.2,.9,.25,1) both;\n  }\n  @keyframes drop { from { opacity: 0; transform: translateY(20px) scale(.97); } to { opacity: 1; transform: none; } }\n\n  /* moulded speaker grille dots, top-right */\n  .grille {\n    position: absolute; top: 18px; right: 18px;\n    width: 54px; height: 30px; opacity: .55;\n    background-image: radial-gradient(circle, rgba(0,0,0,.4) 1px, transparent 1.4px);\n    background-size: 7px 7px;\n    border-radius: 4px;\n  }\n\n  /* ---------------- brand header ---------------- */\n  .head { display: flex; align-items: flex-end; gap: 8px; padding: 2px 4px 12px; }\n  .logo {\n    display: flex; flex-direction: column; line-height: 1;\n  }\n  .logo .mk {\n    font-size: 8px; letter-spacing: .4em; font-weight: 800;\n    color: #5d5c56; text-transform: uppercase;\n  }\n  .logo h1 {\n    margin: 3px 0 0; font-size: 22px; font-weight: 900; letter-spacing: -.01em;\n    color: #1f1f1d;\n    text-shadow: 0 1px 0 rgba(255,255,255,.6);\n  }\n  .logo h1 b { color: var(--ac); }\n  .logo h1 i { color: var(--ac2); font-style: normal; }\n  .model {\n    margin-left: auto; align-self: flex-start;\n    font-size: 8.5px; font-weight: 800; letter-spacing: .22em;\n    color: #44433e; padding: 3px 7px; border-radius: 5px;\n    background: linear-gradient(180deg, #d9d8d1, #bfbeb6);\n    box-shadow: 0 1px 0 rgba(255,255,255,.6) inset, 0 1px 2px rgba(0,0,0,.25);\n  }\n\n  /* ---------------- LCD screen ---------------- */\n  .lcd {\n    position: relative; border-radius: 9px; padding: 12px 14px 10px;\n    background: linear-gradient(180deg, var(--lcd) 0%, var(--lcd2) 100%);\n    box-shadow:\n      0 2px 0 rgba(255,255,255,.5),\n      0 0 0 3px #6f6e66,\n      0 0 0 4px rgba(0,0,0,.3),\n      0 6px 10px rgba(0,0,0,.25) inset;\n    overflow: hidden;\n  }\n  /* glass reflection sweep */\n  .lcd::after {\n    content: \"\"; position: absolute; inset: 0; pointer-events: none;\n    background: linear-gradient(120deg, rgba(255,255,255,.35) 0%, transparent 35%);\n    mix-blend-mode: screen; opacity: .5;\n  }\n  .lcd-top { display: flex; align-items: center; justify-content: space-between; }\n  .lcd-voice {\n    font-size: 13px; font-weight: 800; letter-spacing: .12em;\n    color: var(--lcdink); text-transform: uppercase;\n    font-variant-numeric: tabular-nums;\n  }\n  .lcd-readout {\n    font-size: 9px; font-weight: 700; letter-spacing: .08em;\n    color: #3a4a26; min-height: 11px;\n    font-variant-numeric: tabular-nums;\n  }\n  /* the blocky waveform window */\n  .scope { display: block; width: 100%; height: 46px; margin-top: 7px; }\n  .scope rect.bg { fill: transparent; }\n\n  /* tiny LCD segment-ish note string */\n  .lcd-notes {\n    margin-top: 5px; font-size: 8px; letter-spacing: .14em;\n    color: #46582c; font-weight: 700; min-height: 10px;\n    font-variant-numeric: tabular-nums; opacity: .85;\n  }\n\n  /* ---------------- control rows ---------------- */\n  .panel { margin-top: 14px; }\n\n  .row-label {\n    font-size: 8px; letter-spacing: .26em; font-weight: 800;\n    color: #5a5952; text-transform: uppercase; margin: 0 2px 6px;\n  }\n\n  /* voice selector pads */\n  .voices { display: grid; grid-template-columns: repeat(5, 1fr); gap: 7px; }\n  .vpad {\n    position: relative; cursor: pointer; user-select: none;\n    border: 0; border-radius: 9px; padding: 9px 2px 7px;\n    background: linear-gradient(180deg, var(--rubber), #b9b8b0);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.8) inset,\n      0 -2px 4px rgba(0,0,0,.18) inset,\n      0 3px 5px rgba(0,0,0,.28);\n    transition: transform .07s ease, box-shadow .15s ease, background .2s ease;\n    text-align: center;\n  }\n  .vpad .num {\n    display: block; font-size: 13px; font-weight: 900; color: #3a3a36;\n    font-variant-numeric: tabular-nums;\n  }\n  .vpad .nm {\n    display: block; font-size: 7px; letter-spacing: .08em; font-weight: 800;\n    color: #6a6962; text-transform: uppercase; margin-top: 2px;\n  }\n  .vpad:hover { transform: translateY(-1px); }\n  .vpad:active { transform: translateY(1px); box-shadow: 0 1px 2px rgba(0,0,0,.3) inset; }\n  .vpad.on {\n    background: linear-gradient(180deg, var(--ac), #e0407f);\n    box-shadow:\n      0 0 0 1px rgba(255,255,255,.35) inset,\n      0 0 14px rgba(255,90,158,calc(.5 + var(--glow) * .4)),\n      0 3px 6px rgba(0,0,0,.3);\n    animation: padlit .5s ease;\n  }\n  .vpad.on .num, .vpad.on .nm { color: #fff; text-shadow: 0 1px 2px rgba(0,0,0,.3); }\n  @keyframes padlit { 0% { --glow: 1; } 100% { --glow: 0; } }\n\n  /* knob bank */\n  .knobs { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-top: 14px; }\n  .knob-cell { display: flex; flex-direction: column; align-items: center; gap: 4px; }\n  .knob {\n    width: 56px; height: 56px; cursor: ns-resize; touch-action: none;\n    filter: drop-shadow(0 3px 4px rgba(0,0,0,.3));\n  }\n  .knob:focus { outline: none; }\n  .knob .face { transition: filter .15s ease; }\n  .knob:hover .face { filter: brightness(1.06); }\n  .k-name {\n    font-size: 7.5px; letter-spacing: .14em; font-weight: 800;\n    color: #5a5952; text-transform: uppercase;\n  }\n  .k-val {\n    font-size: 9px; font-weight: 800; color: #34332f;\n    font-variant-numeric: tabular-nums; min-width: 30px; text-align: center;\n  }\n\n  /* ---------------- mini keyboard ---------------- */\n  .kb-wrap { margin-top: 16px; }\n  .keys {\n    position: relative; display: flex; height: 92px;\n    border-radius: 8px; padding: 6px 6px 0;\n    background: linear-gradient(180deg, #6f6e66, #4d4c46);\n    box-shadow: 0 2px 5px rgba(0,0,0,.4) inset, 0 1px 0 rgba(255,255,255,.4);\n  }\n  .key {\n    position: relative; flex: 1; margin: 0 1.5px; cursor: pointer;\n    border-radius: 0 0 5px 5px; user-select: none; -webkit-user-select: none;\n    background: linear-gradient(180deg, #fbfbf7 0%, #ececdf 100%);\n    box-shadow: 0 1px 0 rgba(255,255,255,.9) inset, 0 4px 5px rgba(0,0,0,.3);\n    transition: background .06s ease, transform .06s ease;\n  }\n  .key.black {\n    position: absolute; top: 6px; width: 8.3%; height: 56px; z-index: 3;\n    margin: 0; border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2c2c28 0%, #444 100%);\n    box-shadow: 0 3px 4px rgba(0,0,0,.5);\n  }\n  .key.down {\n    background: linear-gradient(180deg, var(--ac2) 0%, #2bb6e0 100%);\n    transform: translateY(1px);\n  }\n  .key.black.down {\n    background: linear-gradient(180deg, var(--ac) 0%, #d63f7e 100%);\n  }\n\n  .hint {\n    margin-top: 9px; text-align: center; font-size: 8px; letter-spacing: .18em;\n    font-weight: 700; color: #57564f; text-transform: uppercase;\n  }\n</style>\n</head>\n<body>\n  <div class=\"gadget\" role=\"application\" aria-label=\"Pocket Tone synth\">\n    <div class=\"grille\"></div>\n\n    <div class=\"head\">\n      <div class=\"logo\">\n        <span class=\"mk\">Mini Digital Synthesizer</span>\n        <h1><b>POCKET</b> <i>TONE</i></h1>\n      </div>\n      <div class=\"model\">PT&middot;01</div>\n    </div>\n\n    <!-- LCD -->\n    <div class=\"lcd\">\n      <div class=\"lcd-top\">\n        <span class=\"lcd-voice\" id=\"lcdVoice\">1 PIANO</span>\n        <span class=\"lcd-readout\" id=\"lcdReadout\">READY</span>\n      </div>\n      <svg class=\"scope\" id=\"scope\" viewBox=\"0 0 220 46\" preserveAspectRatio=\"none\">\n        <rect class=\"bg\" x=\"0\" y=\"0\" width=\"220\" height=\"46\"></rect>\n        <polyline id=\"wave\" fill=\"none\" stroke=\"#2c3a18\" stroke-width=\"2\"\n                  stroke-linejoin=\"round\" points=\"\"></polyline>\n      </svg>\n      <div class=\"lcd-notes\" id=\"lcdNotes\">- - - - - - - -</div>\n    </div>\n\n    <!-- voice pads -->\n    <div class=\"panel\">\n      <div class=\"row-label\">Voice</div>\n      <div class=\"voices\" id=\"voices\"></div>\n    </div>\n\n    <!-- knobs -->\n    <div class=\"knobs\" id=\"knobs\"></div>\n\n    <!-- keyboard -->\n    <div class=\"kb-wrap\">\n      <div class=\"keys\" id=\"keys\"></div>\n      <div class=\"hint\">Play the keys &middot; A&ndash;K row on your keyboard</div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host param indices (must match assembly.ts / spec.json) ----\n  var P_VOICE = 0, P_ATTACK = 1, P_RELEASE = 2, P_VIBRATO = 3, P_BITS = 4, P_LEVEL = 5;\n\n  var VOICE_NAMES = [\"PIANO\", \"FANTASY\", \"VIOLIN\", \"FLUTE\", \"GUITAR\"];\n\n  // knob descriptors (continuous 0..1 params)\n  var KNOBS = [\n    { idx: P_ATTACK,  name: \"Attack\",  def: 0.04, unit: \"s\",  map: function (v) { return (0.001 + v * 0.6).toFixed(2); } },\n    { idx: P_RELEASE, name: \"Release\", def: 0.30, unit: \"s\",  map: function (v) { return (0.02 + v * 1.8).toFixed(2); } },\n    { idx: P_VIBRATO, name: \"Vibrato\", def: 0.25, unit: \"%\",  map: function (v) { return Math.round(v * 100); } },\n    { idx: P_BITS,    name: \"Bits\",    def: 0.35, unit: \"\",   map: function (v) { return Math.round(16 - v * 12) + \"b\"; } },\n    { idx: P_LEVEL,   name: \"Level\",   def: 0.6,  unit: \"%\",  map: function (v) { return Math.round(v * 100); } }\n  ];\n\n  var state = {};            // current param values\n  var voiceSel = 0;          // 0..4\n\n  function send(i, v) {\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n  }\n\n  // ====================================================================\n  //  LCD readout\n  // ====================================================================\n  var lcdVoice = document.getElementById(\"lcdVoice\");\n  var lcdReadout = document.getElementById(\"lcdReadout\");\n  var lcdNotes = document.getElementById(\"lcdNotes\");\n\n  function showReadout(txt) {\n    lcdReadout.textContent = txt;\n    clearTimeout(showReadout._t);\n    showReadout._t = setTimeout(function () { lcdReadout.textContent = \"READY\"; }, 1400);\n  }\n\n  function refreshVoiceLabel() {\n    lcdVoice.textContent = (voiceSel + 1) + \" \" + VOICE_NAMES[voiceSel];\n  }\n\n  // ====================================================================\n  //  Voice pads\n  // ====================================================================\n  var voicesEl = document.getElementById(\"voices\");\n\n  function buildVoices() {\n    for (var i = 0; i < 5; i++) {\n      (function (i) {\n        var pad = document.createElement(\"button\");\n        pad.className = \"vpad\";\n        pad.innerHTML = '<span class=\"num\">' + (i + 1) + '</span>' +\n                        '<span class=\"nm\">' + VOICE_NAMES[i] + '</span>';\n        pad.addEventListener(\"click\", function () { selectVoice(i); });\n        voicesEl.appendChild(pad);\n      })(i);\n    }\n  }\n\n  function selectVoice(i) {\n    voiceSel = i;\n    var pads = voicesEl.children;\n    for (var k = 0; k < pads.length; k++) {\n      pads[k].classList.toggle(\"on\", k === i);\n      if (k === i) {\n        // retrigger the lit animation\n        pads[k].style.animation = \"none\";\n        void pads[k].offsetWidth;\n        pads[k].style.animation = \"\";\n      }\n    }\n    state[P_VOICE] = i;\n    send(P_VOICE, i);           // stepped: send the integer value directly\n    refreshVoiceLabel();\n    showReadout(\"VOICE \" + (i + 1));\n    rebuildWavePreview();\n  }\n\n  // ====================================================================\n  //  Knobs (SVG, vertical drag, dbl-click reset, wheel fine tune)\n  // ====================================================================\n  var knobsEl = document.getElementById(\"knobs\");\n\n  function buildKnobs() {\n    KNOBS.forEach(function (k) {\n      var cell = document.createElement(\"div\");\n      cell.className = \"knob-cell\";\n\n      var ns = \"http://www.w3.org/2000/svg\";\n      var svg = document.createElementNS(ns, \"svg\");\n      svg.setAttribute(\"class\", \"knob\");\n      svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n      svg.setAttribute(\"tabindex\", \"0\");\n\n      // outer body\n      var body = document.createElementNS(ns, \"circle\");\n      body.setAttribute(\"class\", \"face\");\n      body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"40\");\n      body.setAttribute(\"fill\", \"url(#kg)\");\n      body.setAttribute(\"stroke\", \"#8b8a82\"); body.setAttribute(\"stroke-width\", \"2\");\n\n      // gradient + arc track defs (shared per-knob)\n      var defs = document.createElementNS(ns, \"defs\");\n      defs.innerHTML =\n        '<radialGradient id=\"kg\" cx=\"42%\" cy=\"34%\" r=\"75%\">' +\n          '<stop offset=\"0%\" stop-color=\"#f3f2ec\"/>' +\n          '<stop offset=\"58%\" stop-color=\"#d3d2cb\"/>' +\n          '<stop offset=\"100%\" stop-color=\"#a9a8a0\"/>' +\n        '</radialGradient>';\n      svg.appendChild(defs);\n\n      // value arc (background + filled)\n      var trackBg = document.createElementNS(ns, \"path\");\n      trackBg.setAttribute(\"d\", arcPath(0));\n      trackBg.setAttribute(\"fill\", \"none\");\n      trackBg.setAttribute(\"stroke\", \"rgba(0,0,0,.18)\");\n      trackBg.setAttribute(\"stroke-width\", \"5\");\n      trackBg.setAttribute(\"stroke-linecap\", \"round\");\n      trackBg.setAttribute(\"d\", arcPath(1, true));\n\n      var arc = document.createElementNS(ns, \"path\");\n      arc.setAttribute(\"fill\", \"none\");\n      arc.setAttribute(\"stroke\", k.idx === P_BITS ? \"var(--ac)\" : \"var(--ac2)\");\n      arc.setAttribute(\"stroke-width\", \"5\");\n      arc.setAttribute(\"stroke-linecap\", \"round\");\n\n      // pointer notch\n      var notch = document.createElementNS(ns, \"line\");\n      notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n      notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"20\");\n      notch.setAttribute(\"stroke\", \"#33322e\");\n      notch.setAttribute(\"stroke-width\", \"4\");\n      notch.setAttribute(\"stroke-linecap\", \"round\");\n      var pivot = document.createElementNS(ns, \"g\");\n      pivot.appendChild(notch);\n\n      svg.appendChild(body);\n      svg.appendChild(trackBg);\n      svg.appendChild(arc);\n      svg.appendChild(pivot);\n\n      var nameEl = document.createElement(\"div\");\n      nameEl.className = \"k-name\"; nameEl.textContent = k.name;\n      var valEl = document.createElement(\"div\");\n      valEl.className = \"k-val\";\n\n      cell.appendChild(svg);\n      cell.appendChild(valEl);\n      cell.appendChild(nameEl);\n      knobsEl.appendChild(cell);\n\n      k._arc = arc; k._pivot = pivot; k._val = valEl;\n      setKnob(k, k.def, false);\n      wireKnob(k, svg);\n    });\n  }\n\n  // arc from -135deg to +135deg (270deg sweep)\n  function arcPath(frac, full) {\n    var a0 = -135, a1 = -135 + 270 * (full ? 1 : frac);\n    var r = 33, cx = 50, cy = 50;\n    var p0 = polar(cx, cy, r, a0), p1 = polar(cx, cy, r, a1);\n    var large = (a1 - a0) > 180 ? 1 : 0;\n    return \"M \" + p0.x + \" \" + p0.y + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" + p1.x + \" \" + p1.y;\n  }\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) };\n  }\n\n  function setKnob(k, v, doSend) {\n    v = Math.max(0, Math.min(1, v));\n    state[k.idx] = v;\n    var ang = -135 + v * 270;\n    k._pivot.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n    k._arc.setAttribute(\"d\", arcPath(v));\n    var mapped = k.map(v);\n    k._val.textContent = mapped + (typeof mapped === \"number\" && k.unit ? k.unit : \"\");\n    if (doSend) {\n      send(k.idx, v);\n      showReadout(k.name.toUpperCase() + \" \" + k._val.textContent);\n    }\n  }\n\n  function wireKnob(k, svg) {\n    var dragging = false, startY = 0, startV = 0;\n\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dv = (startY - y) / 180;           // up = increase\n      setKnob(k, startV + dv, true);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n    function onDown(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = state[k.idx];\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n      e.preventDefault();\n    }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    svg.addEventListener(\"dblclick\", function () { setKnob(k, k.def, true); });\n    svg.addEventListener(\"wheel\", function (e) {\n      setKnob(k, state[k.idx] - Math.sign(e.deltaY) * 0.02, true);\n      e.preventDefault();\n    }, { passive: false });\n    svg.addEventListener(\"keydown\", function (e) {\n      if (e.key === \"ArrowUp\")   { setKnob(k, state[k.idx] + 0.02, true); e.preventDefault(); }\n      if (e.key === \"ArrowDown\") { setKnob(k, state[k.idx] - 0.02, true); e.preventDefault(); }\n    });\n  }\n\n  // ====================================================================\n  //  Keyboard\n  // ====================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var BASE = 60;                                  // middle C\n  // white-key offsets for one octave + a bit\n  var WHITE = [0, 2, 4, 5, 7, 9, 11, 12, 14, 16]; // C D E F G A B C D E\n  var BLACK = [                                   // {after white index, semitone}\n    { after: 0, semi: 1 }, { after: 1, semi: 3 },\n    { after: 3, semi: 6 }, { after: 4, semi: 8 }, { after: 5, semi: 10 },\n    { after: 7, semi: 13 }, { after: 8, semi: 15 }\n  ];\n  var heldNotes = {};\n\n  function buildKeys() {\n    var whites = [];\n    WHITE.forEach(function (semi, i) {\n      var key = document.createElement(\"div\");\n      key.className = \"key\";\n      key.dataset.note = BASE + semi;\n      keysEl.appendChild(key);\n      whites.push(key);\n      bindKey(key);\n    });\n    // position blacks relative to whites\n    var total = WHITE.length;\n    BLACK.forEach(function (b) {\n      var key = document.createElement(\"div\");\n      key.className = \"key black\";\n      key.dataset.note = BASE + b.semi;\n      // place between white[after] and white[after+1]\n      var leftPct = ((b.after + 1) / total) * 100;\n      key.style.left = \"calc(\" + leftPct + \"% - 4.15%)\";\n      keysEl.appendChild(key);\n      bindKey(key);\n    });\n  }\n\n  function bindKey(key) {\n    var note = parseInt(key.dataset.note, 10);\n    key.addEventListener(\"mousedown\", function (e) { noteDown(note, key); e.preventDefault(); });\n    key.addEventListener(\"mouseup\", function () { noteUp(note, key); });\n    key.addEventListener(\"mouseleave\", function () { noteUp(note, key); });\n    key.addEventListener(\"touchstart\", function (e) { noteDown(note, key); e.preventDefault(); }, { passive: false });\n    key.addEventListener(\"touchend\", function (e) { noteUp(note, key); e.preventDefault(); }, { passive: false });\n  }\n\n  function noteDown(note, key) {\n    if (heldNotes[note]) return;\n    heldNotes[note] = key;\n    if (key) key.classList.add(\"down\");\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(note, 0.9);\n    pulseWave();\n    showReadout(\"NOTE \" + noteName(note));\n    updateNotesLine();\n  }\n  function noteUp(note, key) {\n    if (!heldNotes[note]) return;\n    var k = heldNotes[note];\n    delete heldNotes[note];\n    if (k) k.classList.remove(\"down\");\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(note);\n    updateNotesLine();\n  }\n\n  function noteName(n) {\n    var names = [\"C\",\"C#\",\"D\",\"D#\",\"E\",\"F\",\"F#\",\"G\",\"G#\",\"A\",\"A#\",\"B\"];\n    return names[n % 12] + (Math.floor(n / 12) - 1);\n  }\n  function updateNotesLine() {\n    var ns = Object.keys(heldNotes).map(Number).sort(function (a, b) { return a - b; });\n    lcdNotes.textContent = ns.length ? ns.map(noteName).join(\" \") : \"- - - - - - - -\";\n  }\n\n  // computer-keyboard mapping (A S D F G H J K -> white keys)\n  var KEYMAP = { a: 0, w: 1, s: 2, e: 3, d: 4, f: 5, t: 6, g: 7, y: 8, h: 9, u: 10, j: 11, k: 12 };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var off = KEYMAP[e.key.toLowerCase()];\n    if (off === undefined) return;\n    var note = BASE + off;\n    var key = findKeyEl(note);\n    noteDown(note, key);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var off = KEYMAP[e.key.toLowerCase()];\n    if (off === undefined) return;\n    var note = BASE + off;\n    noteUp(note, findKeyEl(note));\n  });\n  function findKeyEl(note) {\n    var all = keysEl.querySelectorAll(\".key\");\n    for (var i = 0; i < all.length; i++) if (+all[i].dataset.note === note) return all[i];\n    return null;\n  }\n\n  // ====================================================================\n  //  Animated blocky waveform (reflects voice + a little \"energy\")\n  // ====================================================================\n  var waveEl = document.getElementById(\"wave\");\n  var energy = 0;            // 0..1 brightness/amplitude, eased\n  var rafId = null;\n  var phase = 0;\n\n  function voiceShape(sel, t) {\n    // crude visual analogues of the DSP timbres, t in 0..1 (one cycle)\n    var a = t * Math.PI * 2;\n    if (sel === 0) return (Math.sin(a) + 0.45 * Math.sin(2 * a) + 0.22 * Math.sin(3 * a)) * 0.6;\n    if (sel === 1) return (Math.sin(a) + 0.5 * Math.sin(3 * a) + 0.3 * Math.sin(5 * a)) * 0.5;\n    if (sel === 2) return (2 * t - 1) * 0.85;                       // saw\n    if (sel === 3) return Math.sin(a) * 0.9;                        // sine\n    return (t < 0.25 ? 1 : -1) * 0.7;                               // pulse\n  }\n\n  function buildWavePoints(sel, anim) {\n    var N = 56, pts = \"\";\n    var cycles = 2.0;\n    // BITS visually steps the wave (sample-and-hold blockiness)\n    var bits = state[P_BITS] || 0;\n    var steps = Math.max(2, Math.round(28 - bits * 22));\n    for (var i = 0; i <= N; i++) {\n      var x = (i / N) * 220;\n      var tt = (i / N) * cycles + (anim ? phase : 0);\n      var q = Math.floor((tt % 1) * steps) / steps;          // quantize phase = blocky\n      var y = 23 - voiceShape(sel, q) * 17 * (0.35 + energy * 0.65);\n      pts += x.toFixed(1) + \",\" + y.toFixed(1) + \" \";\n    }\n    return pts.trim();\n  }\n\n  function rebuildWavePreview() {\n    waveEl.setAttribute(\"points\", buildWavePoints(voiceSel, false));\n  }\n\n  function pulseWave() { energy = Math.min(1, energy + 0.7); }\n\n  function loop() {\n    if (document.hidden) { rafId = null; return; }\n    phase += 0.012;\n    energy *= 0.965;                          // ease back to rest\n    var held = Object.keys(heldNotes).length > 0;\n    if (held) energy = Math.max(energy, 0.55);\n    waveEl.setAttribute(\"points\", buildWavePoints(voiceSel, true));\n    // brighten the trace with energy (pink<->cyan blend)\n    var stroke = held ? \"#3a5018\" : \"#2c3a18\";\n    waveEl.setAttribute(\"stroke\", stroke);\n    rafId = requestAnimationFrame(loop);\n  }\n  function startLoop() { if (!rafId) rafId = requestAnimationFrame(loop); }\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden) startLoop();\n  });\n\n  // ====================================================================\n  //  Init\n  // ====================================================================\n  function ready() {\n    buildVoices();\n    buildKnobs();\n    buildKeys();\n\n    // push defaults to the engine\n    selectVoice(0);\n    KNOBS.forEach(function (k) { setKnob(k, k.def, true); });\n\n    rebuildWavePreview();\n    startLoop();\n    lcdReadout.textContent = \"READY\";\n  }\n\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  POCKET TONE — a lo-fi mini-digital pocket synth (Casio VL-1 lineage).\n//  Deliberately small and charming: six voices, five selectable single-\n//  cycle timbres (piano / fantasy / violin / flute / guitar) each built\n//  from a short additive or pulse formula, a simple AR amplitude contour,\n//  a touch of pitch vibrato, and a BITS lo-fi crunch (sample-rate + bit\n//  reduction) for the unmistakable cheap-digital character. Thin, toy-\n//  like, NOT lush. Pure algorithm, no samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_VOICE:   i32 = 0;  // 0..4 stepped -> timbre select\nconst P_ATTACK:  i32 = 1;  // 0..1 -> attack seconds\nconst P_RELEASE: i32 = 2;  // 0..1 -> release seconds\nconst P_VIBRATO: i32 = 3;  // 0..1 -> pitch vibrato depth\nconst P_BITS:    i32 = 4;  // 0..1 -> lo-fi crunch (sample-rate + bit reduction)\nconst P_LEVEL:   i32 = 5;  // 0..1 -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice steal\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // 0..1 cycle phase\n\n// AR amplitude envelope\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 attack 2 hold 3 release\n\nlet ageCounter: i32 = 0;\nlet lfoPhase: f32 = 0.0;\n\n// ---- bit-crusher sample-and-hold state ------------------------------\nlet crHoldL: f32 = 0.0;\nlet crHoldR: f32 = 0.0;\nlet crPhase: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0; vPhase[v] = 0.0;\n    vEnv[v] = 0.0; vStage[v] = 0;\n  }\n  ageCounter = 0;\n  lfoPhase = 0.0;\n  crHoldL = 0.0; crHoldR = 0.0; crPhase = 0.0;\n\n  params[P_VOICE]   = 0.0;   // piano\n  params[P_ATTACK]  = 0.04;\n  params[P_RELEASE] = 0.30;\n  params[P_VIBRATO] = 0.25;\n  params[P_BITS]    = 0.35;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vStage[slot]  = 1;     // attack\n  vPhase[slot]  = 0.0;\n  vEnv[slot]    = 0.0;\n  vAge[slot]    = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3;      // release\n    }\n  }\n}\n\n// =====================================================================\n//  VOICE TIMBRES — single-cycle waveshapes evaluated from phase (0..1).\n//  Kept cheap and THIN on purpose: a handful of harmonics or a pulse,\n//  so each preset has its own clear, toy-like character.\n//  Returns roughly [-1, 1].\n// =====================================================================\n@inline function voicePiano(ph: f32): f32 {\n  // bright narrow pulse-ish tone with a couple of harmonics (the VL-1 \"piano\")\n  const a: f32 = ph * TWO_PI;\n  let s: f32 = Mathf.sin(a);\n  s += 0.45 * Mathf.sin(2.0 * a);\n  s += 0.22 * Mathf.sin(3.0 * a);\n  s += 0.10 * Mathf.sin(5.0 * a);\n  return f32(s * 0.55);\n}\n\n@inline function voiceFantasy(ph: f32): f32 {\n  // hollow bell/fantasy tone: odd harmonics with an inharmonic shimmer\n  const a: f32 = ph * TWO_PI;\n  let s: f32 = Mathf.sin(a);\n  s += 0.5 * Mathf.sin(3.0 * a);\n  s += 0.3 * Mathf.sin(5.01 * a);   // slight inharmonic ring\n  s += 0.18 * Mathf.sin(7.0 * a);\n  return f32(s * 0.5);\n}\n\n@inline function voiceViolin(ph: f32): f32 {\n  // buzzy saw-like string (rich low harmonics)\n  const saw: f32 = 2.0 * ph - 1.0;             // raw saw\n  const a: f32 = ph * TWO_PI;\n  // soften the very top with a sine to keep it thin, not harsh\n  const s: f32 = saw * 0.7 + f32(Mathf.sin(a)) * 0.25;\n  return f32(s * 0.85);\n}\n\n@inline function voiceFlute(ph: f32): f32 {\n  // nearly pure sine with a whisper of 2nd harmonic — soft + breathy toy flute\n  const a: f32 = ph * TWO_PI;\n  let s: f32 = Mathf.sin(a);\n  s += 0.12 * Mathf.sin(2.0 * a);\n  return f32(s * 0.9);\n}\n\n@inline function voiceGuitar(ph: f32): f32 {\n  // plucky narrow pulse (25% duty) — the classic cheap-digital \"guitar\"\n  const duty: f32 = 0.25;\n  const sq: f32 = ph < duty ? 1.0 : -1.0;\n  // tilt with a little 1st harmonic so it has body, then scale down (pulse is loud)\n  const a: f32 = ph * TWO_PI;\n  const s: f32 = sq * 0.6 + f32(Mathf.sin(a)) * 0.2;\n  return f32(s * 0.8);\n}\n\n@inline function renderVoice(sel: i32, ph: f32): f32 {\n  if (sel <= 0) return voicePiano(ph);\n  if (sel == 1) return voiceFantasy(ph);\n  if (sel == 2) return voiceViolin(ph);\n  if (sel == 3) return voiceFlute(ph);\n  return voiceGuitar(ph);\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const sel: i32 = i32(clampf(params[P_VOICE] + 0.5, 0.0, 4.0)); // round to 0..4\n\n  const atkS: f32 = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0) * 0.6;   // 1 ms .. 0.6 s\n  const relS: f32 = 0.02  + clampf(params[P_RELEASE], 0.0, 1.0) * 1.8;  // 20 ms .. 1.8 s\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // vibrato: ~6 Hz pitch wobble, up to ~+/-1.2% (a small, charming amount)\n  const vibDepth: f32 = clampf(params[P_VIBRATO], 0.0, 1.0) * 0.012;\n  const vibRate: f32 = 6.0;\n  const lfoInc: f32 = vibRate / sr;\n\n  // BITS lo-fi crunch: maps 0..1 to (high SR + many bits) .. (low SR + few bits)\n  const bits: f32 = clampf(params[P_BITS], 0.0, 1.0);\n  // sample-rate reduction: hold every `crStep` samples. 1 (clean) .. ~28 (crunchy)\n  const crStep: f32 = 1.0 + bits * bits * 27.0;\n  const crInc: f32 = 1.0 / crStep;\n  // bit depth: 16 (clean) down to ~4 bits (crunchy)\n  const bitDepth: f32 = 16.0 - bits * 12.0;\n  const levels: f32 = f32(Mathf.pow(2.0, bitDepth));\n  const invLevels: f32 = 1.0 / levels;\n\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n  // six thin voices summed; scale so chords stay bounded\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    // ---- global vibrato LFO (shared, cheap) -------------------------\n    lfoPhase += lfoInc; if (lfoPhase >= 1.0) lfoPhase -= 1.0;\n    const vib: f32 = f32(Mathf.sin(lfoPhase * TWO_PI)) * vibDepth;\n    const pitchMul: f32 = 1.0 + vib;\n\n    let mono: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- AR amplitude envelope --------------------------------\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {                 // attack\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {          // hold (sustain at full while gated)\n        env = 1.0;\n      } else if (stg == 3) {          // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- oscillator (single-cycle timbre) ---------------------\n      const inc: f32 = (vFreq[v] * pitchMul) / sr;\n      let ph: f32 = vPhase[v] + inc;\n      if (ph >= 1.0) ph -= 1.0;\n      vPhase[v] = ph;\n\n      const wave: f32 = renderVoice(sel, ph);\n      mono += wave * env * vVel[v];\n    }\n\n    mono *= voiceScale * level;\n\n    // ---- BITS: bit-depth quantize + sample-rate hold ----------------\n    // bit reduction (always applied; at 16 bits it is transparent)\n    let crunched: f32 = mono;\n    crunched = f32(Mathf.floor(crunched * levels + 0.5)) * invLevels;\n\n    // sample-rate reduction via sample-and-hold (mono source -> both ch)\n    crPhase += crInc;\n    if (crPhase >= 1.0) {\n      crPhase -= 1.0;\n      crHoldL = crunched;\n      crHoldR = crunched;\n    }\n\n    let outv: f32 = crHoldL;\n    // gentle safety clip so a big chord + crunch never exceeds bounds\n    if (outv > 1.0) outv = 1.0;\n    if (outv < -1.0) outv = -1.0;\n\n    outBuf[f] = outv;\n    outBuf[MAX_FRAMES + f] = crHoldR > 1.0 ? 1.0 : (crHoldR < -1.0 ? -1.0 : crHoldR);\n  }\n}\n",
  "publishedAt": 1751000107000
}