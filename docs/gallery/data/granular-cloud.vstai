{
  "format": 1,
  "name": "Granular Cloud",
  "isInstrument": false,
  "explanation": "A granular delay / cloud processor. Incoming audio is captured into a ring buffer and resprayed as a swarm of overlapping Hann-windowed grains, each read from a delayed, spray-randomised position at a chosen pitch. Controls: Size, Density, Pitch, Spray, Feedback and Mix.",
  "params": [
    {
      "name": "Size",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Density",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Pitch",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Spray",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Feedback",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Mix",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Granular Cloud</title>\n<style>\n  :root {\n    --accent:  #a0b0ff;\n    --accent2: #d0c0ff;\n    --bg0: #07060f;\n    --bg1: #110d22;\n    --ink: #e8e6ff;\n    --ink-dim: #8d88b8;\n    --panel: rgba(22, 18, 44, 0.55);\n    --stroke: rgba(160, 176, 255, 0.16);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  /* ---------- ambient backdrop ---------- */\n  .stage {\n    position: relative;\n    min-height: 100vh;\n    overflow: hidden;\n    background:\n      radial-gradient(1200px 700px at 75% -10%, rgba(208,192,255,0.18), transparent 60%),\n      radial-gradient(900px 600px at 10% 110%, rgba(160,176,255,0.16), transparent 60%),\n      linear-gradient(180deg, var(--bg1), var(--bg0) 70%);\n  }\n\n  /* the particle cloud canvas sits behind everything */\n  #cloud {\n    position: absolute;\n    inset: 0;\n    width: 100%;\n    height: 100%;\n    display: block;\n    z-index: 0;\n  }\n\n  /* slow drifting nebula veils */\n  .veil {\n    position: absolute;\n    border-radius: 50%;\n    filter: blur(60px);\n    opacity: 0.5;\n    pointer-events: none;\n    z-index: 0;\n    mix-blend-mode: screen;\n  }\n  .veil.a {\n    width: 46vmax; height: 46vmax;\n    left: -8vmax; top: -10vmax;\n    background: radial-gradient(circle, rgba(160,176,255,0.45), transparent 65%);\n    animation: drift1 26s ease-in-out infinite alternate;\n  }\n  .veil.b {\n    width: 40vmax; height: 40vmax;\n    right: -10vmax; bottom: -12vmax;\n    background: radial-gradient(circle, rgba(208,192,255,0.45), transparent 65%);\n    animation: drift2 31s ease-in-out infinite alternate;\n  }\n  @keyframes drift1 {\n    from { transform: translate(0,0) scale(1); }\n    to   { transform: translate(8vmax, 6vmax) scale(1.15); }\n  }\n  @keyframes drift2 {\n    from { transform: translate(0,0) scale(1.1); }\n    to   { transform: translate(-7vmax, -5vmax) scale(0.95); }\n  }\n\n  .wrap {\n    position: relative;\n    z-index: 2;\n    max-width: 920px;\n    margin: 0 auto;\n    padding: 26px 22px 34px;\n  }\n\n  /* ---------- header ---------- */\n  header {\n    display: flex;\n    align-items: center;\n    gap: 16px;\n    margin-bottom: 22px;\n  }\n  .mark {\n    width: 46px; height: 46px;\n    flex: 0 0 auto;\n    filter: drop-shadow(0 0 10px rgba(160,176,255,0.6));\n  }\n  .title-block h1 {\n    margin: 0;\n    font-size: 21px;\n    font-weight: 650;\n    letter-spacing: 0.06em;\n    background: linear-gradient(90deg, var(--accent), var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .title-block .sub {\n    margin-top: 3px;\n    font-size: 10.5px;\n    letter-spacing: 0.28em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* ---------- control grid ---------- */\n  .panel {\n    background: var(--panel);\n    border: 1px solid var(--stroke);\n    border-radius: 20px;\n    padding: 26px 22px 20px;\n    backdrop-filter: blur(14px) saturate(1.2);\n    box-shadow:\n      0 30px 80px rgba(0,0,0,0.5),\n      inset 0 1px 0 rgba(255,255,255,0.05);\n  }\n  .grid {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 14px 10px;\n    justify-items: center;\n  }\n  @media (max-width: 560px) {\n    .grid { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  .knob {\n    position: relative;\n    width: 132px;\n    padding: 8px 4px 12px;\n    text-align: center;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .knob .dial {\n    cursor: ns-resize;\n    display: block;\n    margin: 0 auto;\n    touch-action: none;\n  }\n  .knob .name {\n    margin-top: 6px;\n    font-size: 10.5px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    transition: color 0.2s;\n  }\n  .knob .val {\n    margin-top: 2px;\n    font-size: 13px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    letter-spacing: 0.02em;\n  }\n  .knob:hover .name { color: var(--accent); }\n\n  .glow-ring { transition: opacity 0.2s; opacity: 0.5; }\n  .knob:hover .glow-ring,\n  .knob.dragging .glow-ring { opacity: 1; }\n\n  .hint {\n    margin-top: 16px;\n    text-align: center;\n    font-size: 10px;\n    letter-spacing: 0.12em;\n    text-transform: uppercase;\n    color: rgba(141,136,184,0.6);\n  }\n</style>\n</head>\n<body>\n  <div class=\"stage\">\n    <div class=\"veil a\"></div>\n    <div class=\"veil b\"></div>\n    <canvas id=\"cloud\"></canvas>\n\n    <div class=\"wrap\">\n      <header>\n        <svg class=\"mark\" viewBox=\"0 0 48 48\" fill=\"none\" aria-hidden=\"true\">\n          <defs>\n            <radialGradient id=\"mg\" cx=\"50%\" cy=\"40%\" r=\"60%\">\n              <stop offset=\"0%\" stop-color=\"#d0c0ff\"/>\n              <stop offset=\"100%\" stop-color=\"#a0b0ff\"/>\n            </radialGradient>\n          </defs>\n          <circle cx=\"16\" cy=\"22\" r=\"9\" fill=\"url(#mg)\" opacity=\"0.85\"/>\n          <circle cx=\"28\" cy=\"16\" r=\"7\" fill=\"url(#mg)\" opacity=\"0.7\"/>\n          <circle cx=\"33\" cy=\"27\" r=\"8\" fill=\"url(#mg)\" opacity=\"0.8\"/>\n          <circle cx=\"9\"  cy=\"12\" r=\"2.4\" fill=\"#fff\" opacity=\"0.9\"/>\n          <circle cx=\"40\" cy=\"36\" r=\"2\" fill=\"#fff\" opacity=\"0.8\"/>\n          <circle cx=\"22\" cy=\"36\" r=\"1.6\" fill=\"#fff\" opacity=\"0.7\"/>\n        </svg>\n        <div class=\"title-block\">\n          <h1>GRANULAR CLOUD</h1>\n          <div class=\"sub\">grain delay &middot; particle resynthesis</div>\n        </div>\n      </header>\n\n      <div class=\"panel\">\n        <div class=\"grid\" id=\"grid\"></div>\n        <div class=\"hint\">drag vertically &middot; double-click to reset</div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices match the DSP module) ----\n  var PARAMS = [\n    { name: \"Size\",     index: 0, min: 0, max: 1, def: 0.45, fmt: sizeFmt },\n    { name: \"Density\",  index: 1, min: 0, max: 1, def: 0.50, fmt: densFmt },\n    { name: \"Pitch\",    index: 2, min: 0, max: 1, def: 0.50, fmt: pitchFmt },\n    { name: \"Spray\",    index: 3, min: 0, max: 1, def: 0.40, fmt: pctFmt },\n    { name: \"Feedback\", index: 4, min: 0, max: 1, def: 0.35, fmt: pctFmt },\n    { name: \"Mix\",      index: 5, min: 0, max: 1, def: 0.60, fmt: pctFmt }\n  ];\n\n  function pctFmt(v)  { return Math.round(v * 100) + \"%\"; }\n  function sizeFmt(v) { return Math.round(20 + v * 380) + \" ms\"; }\n  function densFmt(v) { return Math.round(4 + v * v * 120) + \" gr/s\"; }\n  function pitchFmt(v){\n    var s = Math.round((v - 0.5) * 24);\n    return (s > 0 ? \"+\" : \"\") + s + \" st\";\n  }\n\n  // live state used by the particle cloud\n  var state = { size: 0.45, density: 0.5, pitch: 0.5, spray: 0.4, feedback: 0.35, mix: 0.6 };\n  var stateKey = [\"size\", \"density\", \"pitch\", \"spray\", \"feedback\", \"mix\"];\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- knob factory (SVG) ----\n  var R = 40, CX = 50, CY = 50;\n  var A0 = 135, A1 = 405;           // sweep degrees (270°)\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(r, fromDeg, toDeg) {\n    var p0 = polar(CX, CY, r, fromDeg);\n    var p1 = polar(CX, CY, r, toDeg);\n    var large = (toDeg - fromDeg) > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n           p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function makeKnob(p) {\n    var el = document.createElement(\"div\");\n    el.className = \"knob\";\n\n    var svg = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\");\n    svg.setAttribute(\"class\", \"dial\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n    svg.setAttribute(\"width\", \"104\");\n    svg.setAttribute(\"height\", \"104\");\n\n    var gid = \"grad\" + p.index;\n    svg.innerHTML =\n      '<defs>' +\n        '<linearGradient id=\"' + gid + '\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n          '<stop offset=\"0%\" stop-color=\"var(--accent)\"/>' +\n          '<stop offset=\"100%\" stop-color=\"var(--accent2)\"/>' +\n        '</linearGradient>' +\n        '<radialGradient id=\"body' + p.index + '\" cx=\"50%\" cy=\"38%\" r=\"65%\">' +\n          '<stop offset=\"0%\" stop-color=\"#2a2450\"/>' +\n          '<stop offset=\"100%\" stop-color=\"#0d0a1c\"/>' +\n        '</radialGradient>' +\n        '<filter id=\"gb' + p.index + '\" x=\"-50%\" y=\"-50%\" width=\"200%\" height=\"200%\">' +\n          '<feGaussianBlur stdDeviation=\"2.4\"/>' +\n        '</filter>' +\n      '</defs>' +\n      // outer track\n      '<path d=\"' + arcPath(R, A0, A1) + '\" stroke=\"rgba(160,176,255,0.14)\" stroke-width=\"6\" fill=\"none\" stroke-linecap=\"round\"/>' +\n      // glow under value arc\n      '<path class=\"glow-ring\" d=\"' + arcPath(R, A0, A0) + '\" stroke=\"url(#' + gid + ')\" stroke-width=\"7\" fill=\"none\" stroke-linecap=\"round\" filter=\"url(#gb' + p.index + ')\" data-arc=\"glow\"/>' +\n      // value arc\n      '<path d=\"' + arcPath(R, A0, A0) + '\" stroke=\"url(#' + gid + ')\" stroke-width=\"4\" fill=\"none\" stroke-linecap=\"round\" data-arc=\"val\"/>' +\n      // knob body\n      '<circle cx=\"50\" cy=\"50\" r=\"27\" fill=\"url(#body' + p.index + ')\" stroke=\"rgba(255,255,255,0.06)\" stroke-width=\"1\"/>' +\n      '<circle cx=\"50\" cy=\"42\" r=\"27\" fill=\"rgba(255,255,255,0.04)\"/>' +\n      // pointer\n      '<line data-pointer x1=\"50\" y1=\"50\" x2=\"50\" y2=\"28\" stroke=\"var(--accent2)\" stroke-width=\"3\" stroke-linecap=\"round\"/>' +\n      '<circle cx=\"50\" cy=\"50\" r=\"3.2\" fill=\"var(--accent)\"/>';\n\n    var name = document.createElement(\"div\");\n    name.className = \"name\";\n    name.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    el.appendChild(svg);\n    el.appendChild(name);\n    el.appendChild(val);\n\n    var glow = svg.querySelector('[data-arc=\"glow\"]');\n    var arc  = svg.querySelector('[data-arc=\"val\"]');\n    var ptr  = svg.querySelector('[data-pointer]');\n\n    var value = p.def;\n\n    function render() {\n      var t = (value - p.min) / (p.max - p.min);\n      t = Math.max(0, Math.min(1, t));\n      var deg = A0 + t * (A1 - A0);\n      var d = arcPath(R, A0, Math.max(A0 + 0.01, deg));\n      arc.setAttribute(\"d\", d);\n      glow.setAttribute(\"d\", d);\n      ptr.setAttribute(\"transform\", \"rotate(\" + (deg - 270) + \" 50 50)\");\n      val.textContent = p.fmt(value);\n      state[stateKey[p.index]] = t;\n    }\n\n    function commit(v) {\n      value = Math.max(p.min, Math.min(p.max, v));\n      render();\n      pushParam(p.index, value);\n    }\n\n    // ---- drag interaction ----\n    var dragging = false, lastY = 0, startVal = 0;\n\n    function onDown(e) {\n      dragging = true;\n      el.classList.add(\"dragging\");\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startVal = value;\n      e.preventDefault();\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchend\", onUp);\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      var span = p.max - p.min;\n      var fine = (e.shiftKey ? 0.25 : 1);\n      commit(value + dy * span / 200 * fine);\n      lastY = y;\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      el.classList.remove(\"dragging\");\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    svg.addEventListener(\"dblclick\", function () { commit(p.def); });\n    svg.addEventListener(\"wheel\", function (e) {\n      var span = p.max - p.min;\n      commit(value - Math.sign(e.deltaY) * span * 0.02);\n      e.preventDefault();\n    }, { passive: false });\n\n    // initialise\n    commit(p.def);\n    return el;\n  }\n\n  function buildUI() {\n    var grid = document.getElementById(\"grid\");\n    for (var i = 0; i < PARAMS.length; i++) {\n      grid.appendChild(makeKnob(PARAMS[i]));\n    }\n  }\n\n  // ---- generative grain-particle cloud ----\n  var canvas = document.getElementById(\"cloud\");\n  var ctx = canvas.getContext(\"2d\");\n  var W = 0, H = 0, DPR = 1;\n  var grains = [];\n  var MAXP = 130;\n\n  function resize() {\n    DPR = Math.min(2, window.devicePixelRatio || 1);\n    W = canvas.clientWidth;\n    H = canvas.clientHeight;\n    canvas.width = Math.max(1, Math.floor(W * DPR));\n    canvas.height = Math.max(1, Math.floor(H * DPR));\n    ctx.setTransform(DPR, 0, 0, DPR, 0, 0);\n  }\n\n  function spawnGrain() {\n    // pitch shifts hue toward warm (high) or cool (low)\n    var hue = 232 + (state.pitch - 0.5) * 70;     // ~ blue->violet\n    return {\n      x: Math.random() * W,\n      y: H * (0.35 + Math.random() * 0.6),\n      vx: (Math.random() - 0.5) * 0.4,\n      vy: -0.15 - Math.random() * 0.5,\n      life: 0,\n      ttl: 60 + Math.random() * 160,\n      r: 1 + Math.random() * 3,\n      hue: hue\n    };\n  }\n\n  function step() {\n    if (document.hidden) { requestAnimationFrame(step); return; }\n    ctx.clearRect(0, 0, W, H);\n    ctx.globalCompositeOperation = \"lighter\";\n\n    // density controls population; spray controls scatter; size controls grain radius\n    var target = Math.floor(20 + state.density * MAXP);\n    while (grains.length < target) grains.push(spawnGrain());\n\n    var sprayJ = 0.2 + state.spray * 2.2;\n    var sizeMul = 0.6 + state.size * 2.2;\n    var mixAlpha = 0.12 + state.mix * 0.35;\n    var fbDrag = 1 - state.feedback * 0.015;\n\n    for (var i = grains.length - 1; i >= 0; i--) {\n      var g = grains[i];\n      g.life++;\n      // brownian scatter driven by spray\n      g.vx += (Math.random() - 0.5) * 0.06 * sprayJ;\n      g.vy += (Math.random() - 0.5) * 0.05 * sprayJ;\n      g.vx *= fbDrag;\n      g.x += g.vx;\n      g.y += g.vy;\n\n      var t = g.life / g.ttl;\n      if (t >= 1 || g.x < -20 || g.x > W + 20 || g.y < -20) {\n        if (grains.length > target) { grains.splice(i, 1); continue; }\n        // recycle\n        var ng = spawnGrain();\n        grains[i] = ng;\n        continue;\n      }\n\n      // Hann-like envelope on alpha (grains fade in/out)\n      var env = Math.sin(Math.PI * t);\n      var a = env * mixAlpha;\n      var rr = g.r * sizeMul;\n\n      var grd = ctx.createRadialGradient(g.x, g.y, 0, g.x, g.y, rr * 4);\n      grd.addColorStop(0, \"hsla(\" + g.hue + \",90%,80%,\" + a + \")\");\n      grd.addColorStop(1, \"hsla(\" + g.hue + \",90%,70%,0)\");\n      ctx.fillStyle = grd;\n      ctx.beginPath();\n      ctx.arc(g.x, g.y, rr * 4, 0, Math.PI * 2);\n      ctx.fill();\n\n      // bright core\n      ctx.fillStyle = \"hsla(\" + g.hue + \",100%,92%,\" + (a * 1.4) + \")\";\n      ctx.beginPath();\n      ctx.arc(g.x, g.y, rr * 0.6, 0, Math.PI * 2);\n      ctx.fill();\n    }\n\n    ctx.globalCompositeOperation = \"source-over\";\n    requestAnimationFrame(step);\n  }\n\n  // ---- boot ----\n  function boot() {\n    resize();\n    buildUI();\n    requestAnimationFrame(step);\n  }\n\n  window.addEventListener(\"resize\", resize);\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(boot);\n  } else {\n    boot();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  GRANULAR CLOUD — a granular delay / cloud processor\n//  Incoming audio is captured into a stereo ring buffer. A fixed pool of\n//  overlapping grains (no allocation in process) is sprayed back out of\n//  that buffer with a Hann window, each grain reading from a slightly\n//  delayed, spray-randomised position at a chosen playback rate (Pitch).\n//  Density sets how often new grains are spawned; the wet cloud is fed\n//  back into the ring buffer (Feedback) and blended with the dry (Mix).\n//  Pure algorithm on the live input — no user sample file needed.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Ring buffer — ~2 seconds per channel of recent input (+ wet feedback).\nconst RING: i32 = 96000;                       // 2 s @ 48k, per channel\nconst ring: StaticArray<f32> = new StaticArray<f32>(RING * MAX_CHANNELS);\nlet writePos: i32 = 0;                          // shared write head\n\n// Fixed grain pool — NO allocation in process().\nconst MAX_GRAINS: i32 = 48;\nconst gActive: StaticArray<i32> = new StaticArray<i32>(MAX_GRAINS); // 0/1\nconst gPos:    StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS); // read head into ring (frames)\nconst gRate:   StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS); // playback rate (pitch)\nconst gPhase:  StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS); // 0..1 window phase\nconst gInc:    StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS); // window phase increment\nconst gPanL:   StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS); // equal-power pan\nconst gPanR:   StaticArray<f32> = new StaticArray<f32>(MAX_GRAINS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// grain spawn accounting + RNG state\nlet spawnAccum: f32 = 0.0;\nlet rngState: u32 = 0x2545f491;\n\nconst P_SIZE: i32 = 0;     // 0..1 -> grain length 20..400 ms\nconst P_DENSITY: i32 = 1;  // 0..1 -> grains/sec (overlap)\nconst P_PITCH: i32 = 2;    // 0..1 -> playback rate, -12..+12 semitones\nconst P_SPRAY: i32 = 3;    // 0..1 -> position randomisation depth\nconst P_FEEDBACK: i32 = 4; // 0..1 -> wet recirculation into the ring\nconst P_MIX: i32 = 5;      // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  writePos = 0;\n  spawnAccum = 0.0;\n  rngState = 0x2545f491;\n  for (let i = 0; i < MAX_GRAINS; i++) {\n    gActive[i] = 0; gPos[i] = 0.0; gRate[i] = 1.0;\n    gPhase[i] = 0.0; gInc[i] = 0.0; gPanL[i] = 0.7071; gPanR[i] = 0.7071;\n  }\n  for (let i = 0; i < RING * MAX_CHANNELS; i++) ring[i] = 0.0;\n  params[P_SIZE] = 0.45;\n  params[P_DENSITY] = 0.5;\n  params[P_PITCH] = 0.5;\n  params[P_SPRAY] = 0.4;\n  params[P_FEEDBACK] = 0.35;\n  params[P_MIX] = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// xorshift32 -> f32 in [0,1)\n@inline function rndf(): f32 {\n  let x: u32 = rngState;\n  x ^= x << 13; x ^= x >> 17; x ^= x << 5;\n  rngState = x;\n  return f32(x & 0x00ffffff) / f32(0x01000000);\n}\n\n// read the ring buffer for channel c at fractional frame position `pos`\n// (linear interpolation). pos is wrapped into [0,RING).\n@inline function readRing(c: i32, pos: f32): f32 {\n  let p: f32 = pos;\n  const rf: f32 = f32(RING);\n  while (p < 0.0) p += rf;\n  while (p >= rf) p -= rf;\n  const i0: i32 = i32(p);\n  let i1: i32 = i0 + 1; if (i1 >= RING) i1 = 0;\n  const frac: f32 = p - f32(i0);\n  const base: i32 = c * RING;\n  const a: f32 = ring[base + i0];\n  const b: f32 = ring[base + i1];\n  return f32(a + (b - a) * frac);\n}\n\n// pitch ratio for a 0..1 control mapped to -12..+12 semitones\n@inline function pitchRatio(n01: f32): f32 {\n  const semis: f32 = (n01 - 0.5) * 24.0;             // -12..+12\n  const ln2over12: f32 = 0.05776226504666;            // ln(2)/12\n  return f32(Mathf.exp(semis * ln2over12));\n}\n\nexport function process(n: i32): void {\n  const size01: f32 = clampf(params[P_SIZE], 0.0, 1.0);\n  const dens01: f32 = clampf(params[P_DENSITY], 0.0, 1.0);\n  const pitch01: f32 = clampf(params[P_PITCH], 0.0, 1.0);\n  const spray01: f32 = clampf(params[P_SPRAY], 0.0, 1.0);\n  const fb: f32 = clampf(params[P_FEEDBACK], 0.0, 1.0) * 0.85;\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // grain length in frames: 20..400 ms\n  const grainMs: f32 = 20.0 + size01 * 380.0;\n  const grainLen: f32 = clampf(grainMs * 0.001 * sampleRate, 32.0, f32(RING) * 0.45);\n  const winInc: f32 = 1.0 / grainLen;            // window phase per frame\n\n  // density -> spawn rate (grains/sec). Higher density = thicker cloud.\n  const rate: f32 = 4.0 + dens01 * dens01 * 120.0;\n  const spawnPerFrame: f32 = rate / sampleRate;\n\n  // base playback rate for this block\n  const baseRate: f32 = pitchRatio(pitch01);\n\n  // spray depth in frames: up to ~0.5 s of position scatter\n  const sprayFrames: f32 = spray01 * 0.5 * sampleRate;\n\n  // small fixed delay so grains read already-recorded audio (granular delay)\n  const baseDelay: f32 = 0.10 * sampleRate;      // 100 ms behind the write head\n\n  // gain compensation: with overlap the cloud can sum loud; scale by density.\n  const wetGain: f32 = 0.9 / f32(Mathf.sqrt(1.0 + rate * grainLen / sampleRate));\n\n  for (let f = 0; f < n; f++) {\n    const dryL: f32 = inBuf[f];\n    const dryR: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : dryL;\n\n    // --- spawn grains for this frame ---\n    spawnAccum += spawnPerFrame;\n    while (spawnAccum >= 1.0) {\n      spawnAccum -= 1.0;\n      // find a free slot\n      let slot: i32 = -1;\n      for (let g = 0; g < MAX_GRAINS; g++) {\n        if (gActive[g] == 0) { slot = g; break; }\n      }\n      if (slot >= 0) {\n        gActive[slot] = 1;\n        gPhase[slot] = 0.0;\n        gInc[slot] = winInc;\n        // read start: behind the write head by base delay + sprayed offset\n        const scatter: f32 = (rndf() * 2.0 - 1.0) * sprayFrames;\n        let start: f32 = f32(writePos) - baseDelay - scatter;\n        gPos[slot] = start;\n        // small per-grain pitch jitter for an organic cloud\n        const jitter: f32 = 1.0 + (rndf() * 2.0 - 1.0) * 0.01;\n        gRate[slot] = baseRate * jitter;\n        // random equal-power pan -> stereo spread\n        const pan: f32 = rndf();                  // 0..1\n        const ang: f32 = pan * 1.5707963;         // 0..pi/2\n        gPanL[slot] = f32(Mathf.cos(ang));\n        gPanR[slot] = f32(Mathf.sin(ang));\n      }\n    }\n\n    // --- render all active grains ---\n    let wetL: f32 = 0.0;\n    let wetR: f32 = 0.0;\n    for (let g = 0; g < MAX_GRAINS; g++) {\n      if (gActive[g] == 0) continue;\n      const ph: f32 = gPhase[g];\n      // Hann window 0..1\n      const win: f32 = f32(0.5 - 0.5 * Mathf.cos(6.2831853 * ph));\n      const pos: f32 = gPos[g];\n      const sL: f32 = readRing(0, pos);\n      const sR: f32 = channels > 1 ? readRing(1, pos) : sL;\n      const wv: f32 = win;\n      wetL += sL * wv * gPanL[g];\n      wetR += sR * wv * gPanR[g];\n      // advance grain read head + window\n      gPos[g] = pos + gRate[g];\n      const np: f32 = ph + gInc[g];\n      if (np >= 1.0) { gActive[g] = 0; } else { gPhase[g] = np; }\n    }\n\n    wetL *= wetGain;\n    wetR *= wetGain;\n\n    // soft saturation to keep the recirculating cloud bounded\n    wetL = f32(Mathf.tanh(wetL));\n    wetR = f32(Mathf.tanh(wetR));\n\n    // --- write input (+ feedback of the wet cloud) into the ring ---\n    const wIdx: i32 = writePos;\n    ring[wIdx] = clampf(dryL + wetL * fb, -1.5, 1.5);\n    ring[RING + wIdx] = clampf(dryR + wetR * fb, -1.5, 1.5);\n    writePos = wIdx + 1; if (writePos >= RING) writePos = 0;\n\n    // --- mix dry/wet ---\n    const outL: f32 = dryL * (1.0 - mix) + wetL * mix;\n    const outR: f32 = dryR * (1.0 - mix) + wetR * mix;\n    outBuf[f] = clampf(outL, -1.2, 1.2);\n    outBuf[MAX_FRAMES + f] = clampf(outR, -1.2, 1.2);\n  }\n}\n",
  "publishedAt": 1751000055000
}