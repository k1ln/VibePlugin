{
  "format": 1,
  "name": "Quad Dimension",
  "isInstrument": false,
  "explanation": "A clean, hi-fi dimensional stereo chorus with four fixed mode buttons instead of rate and depth knobs. Each mode (1 = subtle to 4 = widest) preselects a dimensional size that builds an anti-phase side signal from a pair of short, gently de-tuned delay taps per channel, widening and thickening the stereo image with almost no audible pitch wobble. The modulation is kept very slow and shallow so it shimmers rather than warbles; the mono sum stays stable. Controls: Mode (1..4), Width (stereo spread), Tone (dark to bright sparkle) and dry/wet Mix.",
  "params": [
    {
      "name": "Mode",
      "index": 0,
      "min": 0,
      "max": 3,
      "default": 0
    },
    {
      "name": "Width",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Quad Dimension</title>\n<style>\n  :root {\n    --accent: #5ad0ff;\n    --accent2: #c8a0ff;\n    --steel-1: #1a2740;\n    --steel-2: #0d1626;\n    --chrome-1: #e9f1fb;\n    --chrome-2: #8fa6c4;\n    --chrome-3: #3d536f;\n    --ink: #cfe2f6;\n    --ink-dim: #6f86a6;\n  }\n\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n\n  html, body {\n    width: 100%;\n    min-height: 100%;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #16243c 0%, #0a1120 55%, #060a14 100%);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    -webkit-font-smoothing: antialiased;\n    display: flex;\n    justify-content: center;\n    align-items: flex-start;\n    padding: 22px 14px 34px;\n    overflow-x: hidden;\n  }\n\n  /* ---------- the pedal chassis ---------- */\n  .pedal {\n    position: relative;\n    width: min(440px, 96vw);\n    border-radius: 22px;\n    padding: 20px 22px 24px;\n    background:\n      linear-gradient(180deg, #20355a 0%, #16284a 30%, #102040 70%, #0b1730 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.10) inset,\n      0 -2px 14px rgba(0,0,0,0.55) inset,\n      0 26px 60px rgba(0,0,0,0.65),\n      0 4px 12px rgba(0,0,0,0.5);\n    border: 1px solid rgba(120,160,220,0.18);\n  }\n\n  /* metal corner bolts */\n  .bolt {\n    position: absolute;\n    width: 20px; height: 20px;\n    border-radius: 50%;\n    background:\n      radial-gradient(circle at 35% 30%, var(--chrome-1) 0%, var(--chrome-2) 40%, var(--chrome-3) 75%, #1b2538 100%);\n    box-shadow: 0 1px 2px rgba(0,0,0,0.6), 0 0 0 1px rgba(0,0,0,0.4);\n  }\n  .bolt::after {\n    content: \"\";\n    position: absolute; inset: 6px;\n    border-radius: 50%;\n    background: linear-gradient(135deg, rgba(255,255,255,0.5), rgba(0,0,0,0.25));\n  }\n  .bolt.tl { top: 10px; left: 10px; }\n  .bolt.tr { top: 10px; right: 10px; }\n  .bolt.bl { bottom: 10px; left: 10px; }\n  .bolt.br { bottom: 10px; right: 10px; }\n\n  /* ---------- header ---------- */\n  .head {\n    text-align: center;\n    margin: 4px 0 16px;\n  }\n  .brand {\n    font-size: 11px;\n    letter-spacing: 4px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin-bottom: 3px;\n  }\n  .title {\n    font-size: 27px;\n    font-weight: 800;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    background: linear-gradient(180deg, var(--chrome-1), var(--chrome-2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.4);\n  }\n  .subtitle {\n    font-size: 9.5px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--accent);\n    opacity: 0.78;\n    margin-top: 4px;\n  }\n\n  /* ---------- stereo field visualiser ---------- */\n  .field-wrap {\n    position: relative;\n    margin: 4px 0 18px;\n    border-radius: 14px;\n    padding: 10px;\n    background: linear-gradient(180deg, #060c18, #03060e);\n    box-shadow:\n      0 2px 5px rgba(0,0,0,0.6) inset,\n      0 0 0 1px rgba(90,208,255,0.10) inset;\n  }\n  .field { display: block; width: 100%; height: 132px; border-radius: 9px; }\n  .field-labels {\n    position: absolute;\n    top: 14px; left: 18px; right: 18px;\n    display: flex; justify-content: space-between;\n    font-size: 8.5px; letter-spacing: 2px; color: var(--ink-dim);\n    pointer-events: none;\n  }\n\n  /* ---------- mode buttons ---------- */\n  .modes {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 12px;\n    margin-bottom: 8px;\n  }\n  .mode-btn {\n    position: relative;\n    aspect-ratio: 1 / 1;\n    border-radius: 12px;\n    cursor: pointer;\n    border: 1px solid rgba(120,160,220,0.22);\n    background: linear-gradient(180deg, #182a4a 0%, #0d1a32 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.08) inset,\n      0 -3px 8px rgba(0,0,0,0.5) inset,\n      0 4px 8px rgba(0,0,0,0.45);\n    transition: transform 0.12s ease, box-shadow 0.2s ease, background 0.2s ease;\n    user-select: none;\n    -webkit-user-select: none;\n  }\n  .mode-btn:hover { transform: translateY(-1px); }\n  .mode-btn:active { transform: translateY(1px); }\n\n  /* the little lamp inside each button */\n  .lamp {\n    position: absolute;\n    top: 12px; left: 50%; transform: translateX(-50%);\n    width: 16px; height: 16px; border-radius: 50%;\n    background: radial-gradient(circle at 40% 35%, #2c3a55, #101a2c);\n    box-shadow: 0 1px 2px rgba(0,0,0,0.6) inset;\n    transition: background 0.2s ease, box-shadow 0.25s ease;\n  }\n  .mode-num {\n    position: absolute;\n    bottom: 9px; left: 0; right: 0;\n    text-align: center;\n    font-size: 17px; font-weight: 700;\n    color: var(--ink-dim);\n    transition: color 0.2s ease, text-shadow 0.25s ease;\n  }\n\n  .mode-btn.active {\n    background: linear-gradient(180deg, #1e3358 0%, #0e1f3c 100%);\n    border-color: rgba(90,208,255,0.55);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.12) inset,\n      0 -3px 8px rgba(0,0,0,0.5) inset,\n      0 0 14px rgba(90,208,255,0.35),\n      0 4px 8px rgba(0,0,0,0.45);\n  }\n  .mode-btn.active .lamp {\n    background: radial-gradient(circle at 40% 35%, #d8f6ff, var(--accent) 55%, #1a6f99 100%);\n    box-shadow:\n      0 0 10px var(--accent),\n      0 0 18px rgba(90,208,255,0.55),\n      0 1px 2px rgba(0,0,0,0.4) inset;\n    animation: lampPulse 2.4s ease-in-out infinite;\n  }\n  .mode-btn.active .mode-num {\n    color: #eaf7ff;\n    text-shadow: 0 0 8px rgba(90,208,255,0.7);\n  }\n  @keyframes lampPulse {\n    0%, 100% { filter: brightness(1); }\n    50% { filter: brightness(1.28); }\n  }\n\n  .mode-caption {\n    text-align: center;\n    font-size: 9px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    margin: 2px 0 18px;\n  }\n  .mode-caption b { color: var(--accent2); font-weight: 600; }\n\n  /* ---------- knob row ---------- */\n  .knobs {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    gap: 8px;\n  }\n  .knob-cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n  }\n  .knob {\n    position: relative;\n    width: 78px; height: 78px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; }\n  .klabel {\n    font-size: 10px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .kval {\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    letter-spacing: 0.5px;\n  }\n\n  .footer {\n    margin-top: 16px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    gap: 8px;\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .pow {\n    width: 8px; height: 8px; border-radius: 50%;\n    background: var(--accent2);\n    box-shadow: 0 0 8px var(--accent2);\n    animation: lampPulse 2s ease-in-out infinite;\n  }\n</style>\n</head>\n<body>\n  <div class=\"pedal\">\n    <span class=\"bolt tl\"></span>\n    <span class=\"bolt tr\"></span>\n    <span class=\"bolt bl\"></span>\n    <span class=\"bolt br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">Stereo Dimension</div>\n      <div class=\"title\">Quad Dimension</div>\n      <div class=\"subtitle\">Button-Mode Chorus</div>\n    </div>\n\n    <div class=\"field-wrap\">\n      <div class=\"field-labels\"><span>L</span><span>STEREO FIELD</span><span>R</span></div>\n      <canvas class=\"field\" id=\"field\" width=\"800\" height=\"264\"></canvas>\n    </div>\n\n    <div class=\"modes\" id=\"modes\">\n      <div class=\"mode-btn\" data-mode=\"0\"><span class=\"lamp\"></span><span class=\"mode-num\">1</span></div>\n      <div class=\"mode-btn\" data-mode=\"1\"><span class=\"lamp\"></span><span class=\"mode-num\">2</span></div>\n      <div class=\"mode-btn\" data-mode=\"2\"><span class=\"lamp\"></span><span class=\"mode-num\">3</span></div>\n      <div class=\"mode-btn\" data-mode=\"3\"><span class=\"lamp\"></span><span class=\"mode-num\">4</span></div>\n    </div>\n    <div class=\"mode-caption\">Mode <b id=\"modeName\">1 · Subtle</b></div>\n\n    <div class=\"knobs\">\n      <div class=\"knob-cell\">\n        <div class=\"knob\" id=\"knobWidth\" data-index=\"1\"></div>\n        <div class=\"klabel\">Width</div>\n        <div class=\"kval\" id=\"valWidth\">70%</div>\n      </div>\n      <div class=\"knob-cell\">\n        <div class=\"knob\" id=\"knobTone\" data-index=\"2\"></div>\n        <div class=\"klabel\">Tone</div>\n        <div class=\"kval\" id=\"valTone\">50%</div>\n      </div>\n      <div class=\"knob-cell\">\n        <div class=\"knob\" id=\"knobMix\" data-index=\"3\"></div>\n        <div class=\"klabel\">Mix</div>\n        <div class=\"kval\" id=\"valMix\">60%</div>\n      </div>\n    </div>\n\n    <div class=\"footer\"><span class=\"pow\"></span><span>Quad Dimension · Hi-Fi Dimensional Widener</span></div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- host bridge --------------------------------------------------\n  var bridge = {\n    setParam: function (i, v) {\n      if (window.vstai && window.vstai.setParam) window.vstai.setParam(i, v);\n    }\n  };\n\n  // ---- parameter model ---------------------------------------------\n  // index: 0 Mode(0..3 step1), 1 Width, 2 Tone, 3 Mix\n  var state = { mode: 0, width: 0.7, tone: 0.5, mix: 0.6 };\n  var defaults = { mode: 0, width: 0.7, tone: 0.5, mix: 0.6 };\n\n  var MODE_NAMES = [\"1 · Subtle\", \"2 · Open\", \"3 · Wide\", \"4 · Widest\"];\n\n  // ---- MODE BUTTONS -------------------------------------------------\n  var modeBtns = Array.prototype.slice.call(document.querySelectorAll(\".mode-btn\"));\n  var modeNameEl = document.getElementById(\"modeName\");\n\n  function applyMode(m) {\n    state.mode = m;\n    for (var i = 0; i < modeBtns.length; i++) {\n      modeBtns[i].classList.toggle(\"active\", i === m);\n    }\n    modeNameEl.textContent = MODE_NAMES[m];\n    bridge.setParam(0, m); // real value 0..3\n  }\n\n  modeBtns.forEach(function (btn) {\n    btn.addEventListener(\"click\", function () {\n      applyMode(parseInt(btn.getAttribute(\"data-mode\"), 10));\n    });\n    btn.addEventListener(\"dblclick\", function () {\n      applyMode(defaults.mode);\n    });\n  });\n\n  // ---- KNOBS (SVG, drag vertical, dbl-click reset, wheel fine) ------\n  var A0 = -135, A1 = 135; // sweep range in degrees\n\n  function makeKnob(el, getVal, setVal, fmt) {\n    var ns = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(ns, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // track arc\n    var track = document.createElementNS(ns, \"path\");\n    track.setAttribute(\"d\", arcPath(50, 50, 38, A0, A1));\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(120,160,220,0.18)\");\n    track.setAttribute(\"stroke-width\", \"6\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(track);\n\n    // value arc\n    var arc = document.createElementNS(ns, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#kgrad)\");\n    arc.setAttribute(\"stroke-width\", \"6\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(arc);\n\n    // gradient defs\n    var defs = document.createElementNS(ns, \"defs\");\n    defs.innerHTML =\n      '<linearGradient id=\"kgrad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n      '<stop offset=\"0\" stop-color=\"#5ad0ff\"/>' +\n      '<stop offset=\"1\" stop-color=\"#c8a0ff\"/>' +\n      '</linearGradient>' +\n      '<radialGradient id=\"kbody\" cx=\"0.4\" cy=\"0.32\" r=\"0.85\">' +\n      '<stop offset=\"0\" stop-color=\"#2a3e63\"/>' +\n      '<stop offset=\"0.6\" stop-color=\"#162844\"/>' +\n      '<stop offset=\"1\" stop-color=\"#0a1426\"/>' +\n      '</radialGradient>';\n    svg.appendChild(defs);\n\n    // body\n    var body = document.createElementNS(ns, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"29\");\n    body.setAttribute(\"fill\", \"url(#kbody)\");\n    body.setAttribute(\"stroke\", \"rgba(255,255,255,0.10)\");\n    body.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(body);\n\n    // pointer notch\n    var notch = document.createElementNS(ns, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"26\");\n    notch.setAttribute(\"stroke\", \"#eaf7ff\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    el.appendChild(svg);\n\n    function render() {\n      var v = getVal();          // 0..1\n      var ang = A0 + (A1 - A0) * v;\n      arc.setAttribute(\"d\", arcPath(50, 50, 38, A0, ang));\n      notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n      fmt(v);\n    }\n\n    // dragging\n    var dragging = false, startY = 0, startV = 0;\n    function onDown(e) {\n      dragging = true;\n      startY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = getVal();\n      el.style.filter = \"drop-shadow(0 0 9px rgba(90,208,255,0.45))\";\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dv = (startY - y) / 200; // up = increase\n      var v = Math.max(0, Math.min(1, startV + dv));\n      setVal(v);\n      render();\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      el.style.filter = \"none\";\n    }\n    el.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    el.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    el.addEventListener(\"dblclick\", function () {\n      setVal(null); // signal: reset to default\n      render();\n    });\n    el.addEventListener(\"wheel\", function (e) {\n      var v = Math.max(0, Math.min(1, getVal() - Math.sign(e.deltaY) * 0.02));\n      setVal(v);\n      render();\n      e.preventDefault();\n    }, { passive: false });\n\n    return { render: render };\n  }\n\n  function polar(cx, cy, r, deg) {\n    var rad = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(rad), cy + r * Math.sin(rad)];\n  }\n  function arcPath(cx, cy, r, a0, a1) {\n    var p0 = polar(cx, cy, r, a0);\n    var p1 = polar(cx, cy, r, a1);\n    var large = Math.abs(a1 - a0) > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n           p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n\n  var valWidth = document.getElementById(\"valWidth\");\n  var valTone = document.getElementById(\"valTone\");\n  var valMix = document.getElementById(\"valMix\");\n\n  var kWidth = makeKnob(\n    document.getElementById(\"knobWidth\"),\n    function () { return state.width; },\n    function (v) { if (v === null) v = defaults.width; state.width = v; bridge.setParam(1, v); },\n    function (v) { valWidth.textContent = pct(v); }\n  );\n  var kTone = makeKnob(\n    document.getElementById(\"knobTone\"),\n    function () { return state.tone; },\n    function (v) { if (v === null) v = defaults.tone; state.tone = v; bridge.setParam(2, v); },\n    function (v) { valTone.textContent = pct(v); }\n  );\n  var kMix = makeKnob(\n    document.getElementById(\"knobMix\"),\n    function () { return state.mix; },\n    function (v) { if (v === null) v = defaults.mix; state.mix = v; bridge.setParam(3, v); },\n    function (v) { valMix.textContent = pct(v); }\n  );\n\n  // ---- STEREO FIELD VISUALISER -------------------------------------\n  var cv = document.getElementById(\"field\");\n  var ctx = cv.getContext(\"2d\");\n  var W = cv.width, H = cv.height;\n  var t0 = performance.now();\n\n  function draw(now) {\n    var t = (now - t0) / 1000;\n    ctx.clearRect(0, 0, W, H);\n\n    // background grid glow\n    var bg = ctx.createLinearGradient(0, 0, 0, H);\n    bg.addColorStop(0, \"rgba(12,24,44,0.6)\");\n    bg.addColorStop(1, \"rgba(4,8,16,0.9)\");\n    ctx.fillStyle = bg;\n    ctx.fillRect(0, 0, W, H);\n\n    var cx = W / 2, cy = H / 2;\n\n    // width drives how far the two lobes spread; mode adds extra spread;\n    // mix controls overall brightness/presence.\n    var spread = (0.18 + 0.62 * state.width) * (1 + state.mode * 0.22);\n    var presence = 0.25 + 0.75 * state.mix;\n    var sparkle = 0.35 + 0.65 * state.tone;\n\n    // center column (mono / mid)\n    ctx.strokeStyle = \"rgba(120,160,220,0.18)\";\n    ctx.lineWidth = 1;\n    ctx.beginPath(); ctx.moveTo(cx, 18); ctx.lineTo(cx, H - 18); ctx.stroke();\n\n    // two breathing lobes — left lobe and right lobe, anti-phase motion\n    for (var s = -1; s <= 1; s += 2) {\n      var phase = t * (0.6 + state.mode * 0.18) + (s > 0 ? Math.PI : 0);\n      var lobeX = cx + s * spread * (W * 0.40);\n      var breath = 1 + 0.12 * Math.sin(phase);\n      var rad = (40 + 30 * state.width) * breath;\n\n      var col = s < 0 ? \"90,208,255\" : \"200,160,255\";\n      var g = ctx.createRadialGradient(lobeX, cy, 4, lobeX, cy, rad);\n      g.addColorStop(0, \"rgba(\" + col + \",\" + (0.55 * presence) + \")\");\n      g.addColorStop(0.5, \"rgba(\" + col + \",\" + (0.18 * presence) + \")\");\n      g.addColorStop(1, \"rgba(\" + col + \",0)\");\n      ctx.fillStyle = g;\n      ctx.beginPath();\n      ctx.arc(lobeX, cy, rad, 0, Math.PI * 2);\n      ctx.fill();\n    }\n\n    // connecting wave between the lobes — anti-phase shimmer\n    ctx.lineWidth = 2;\n    var waveGrad = ctx.createLinearGradient(0, 0, W, 0);\n    waveGrad.addColorStop(0, \"rgba(90,208,255,\" + presence + \")\");\n    waveGrad.addColorStop(1, \"rgba(200,160,255,\" + presence + \")\");\n    ctx.strokeStyle = waveGrad;\n    ctx.beginPath();\n    var amp = (10 + 34 * state.width) * presence;\n    var freq = 5 + state.mode * 3;\n    for (var x = 24; x <= W - 24; x++) {\n      var u = (x - 24) / (W - 48);\n      var y = cy +\n        Math.sin(u * Math.PI * freq + t * 2.4) * amp * Math.sin(u * Math.PI) +\n        Math.sin(u * Math.PI * freq * 2.0 - t * 1.7) * amp * 0.35 * sparkle * Math.sin(u * Math.PI);\n      if (x === 24) ctx.moveTo(x, y); else ctx.lineTo(x, y);\n    }\n    ctx.stroke();\n\n    // sparkle dots driven by Tone\n    var dotCount = Math.round(6 + sparkle * 16);\n    for (var d = 0; d < dotCount; d++) {\n      var dp = (d / dotCount);\n      var dx = 24 + dp * (W - 48);\n      var dy = cy + Math.sin(dp * 22 + t * 3.1 + d) * (20 + 40 * state.width);\n      var tw = 0.4 + 0.6 * Math.abs(Math.sin(t * 4 + d * 1.7));\n      ctx.fillStyle = \"rgba(234,247,255,\" + (tw * sparkle * presence * 0.8) + \")\";\n      ctx.beginPath();\n      ctx.arc(dx, dy, 1.4 + sparkle * 1.6, 0, Math.PI * 2);\n      ctx.fill();\n    }\n\n    if (!document.hidden) requestAnimationFrame(draw);\n  }\n  requestAnimationFrame(draw);\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden) requestAnimationFrame(draw);\n  });\n\n  // ---- init: push every param to its default ------------------------\n  function initAll() {\n    applyMode(state.mode);\n    kWidth.render(); bridge.setParam(1, state.width);\n    kTone.render();  bridge.setParam(2, state.tone);\n    kMix.render();   bridge.setParam(3, state.mix);\n  }\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(initAll);\n  } else {\n    initAll();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  QUAD DIMENSION — button-mode dimensional stereo chorus\n//\n//  A clean, hi-fi dimensional widener with FOUR fixed MODE buttons instead\n//  of rate/depth knobs. Each mode (1 = subtle .. 4 = widest) preselects a\n//  dimensional \"size\": a pair of short, gently de-tuned delay taps per\n//  channel feed an ANTI-PHASE side signal that decorrelates and widens a\n//  source with almost no audible pitch wobble. The modulation is kept\n//  extremely slow and shallow on purpose — it shimmers, it does not warble.\n//\n//  The wet image is built as MID + WIDTH * SIDE, where SIDE is the\n//  anti-phase difference of the two modulated taps. This means even a mono\n//  source is thrown wide (the taps differ between L and R), while the mono\n//  sum stays stable. A tilt \"Tone\" adds top-end sparkle to the wet only.\n//\n//  Params:\n//    0  Mode   stepped 1..4  -> four dimensional width presets\n//    1  Width  0..1          -> stereo spread (scales the side signal)\n//    2  Tone   0..1          -> dark .. bright tilt on the wet\n//    3  Mix    0..1          -> dry/wet (Mix = 0 is exactly dry)\n//\n//  Pure algorithm, no samples. All f32, no alloc in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Two delay lines (one per channel). ~85 ms at 48 kHz — far more than needed.\nconst DLEN: i32 = 4096;\nconst DMASK: i32 = DLEN - 1;\nconst dlineL: StaticArray<f32> = new StaticArray<f32>(DLEN);\nconst dlineR: StaticArray<f32> = new StaticArray<f32>(DLEN);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet widx: i32 = 0;\n\n// Quadrature LFO phases — deliberately VERY slow so there is essentially no\n// audible pitch wobble; they only keep the comb from being perfectly static.\nlet phaseA: f32 = 0.0;\nlet phaseB: f32 = 0.25;\n\n// Wet tilt smoothers (one-pole low-pass per channel for the bright/dark tilt).\nlet lpL: f32 = 0.0;\nlet lpR: f32 = 0.0;\n\n// Smoothed control values (avoid zipper noise when a mode/knob changes).\nlet sSpread: f32 = 0.0;   // tap spread in samples\nlet sSweep:  f32 = 0.0;   // modulation depth in samples\nlet sSide:   f32 = 0.0;   // intrinsic anti-phase amount for the mode\n\nconst P_MODE:  i32 = 0;\nconst P_WIDTH: i32 = 1;\nconst P_TONE:  i32 = 2;\nconst P_MIX:   i32 = 3;\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DLEN; i++) { dlineL[i] = 0.0; dlineR[i] = 0.0; }\n  widx = 0;\n  phaseA = 0.0;\n  phaseB = 0.25;\n  lpL = 0.0;\n  lpR = 0.0;\n  sSpread = 0.0;\n  sSweep = 0.0;\n  sSide = 0.0;\n  params[P_MODE]  = 0.0;   // Mode 1 (presented 1..4, stored 0..3)\n  params[P_WIDTH] = 0.7;\n  params[P_TONE]  = 0.5;\n  params[P_MIX]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Fractional read from a delay line (linear interpolation). `delay` in samples.\n@inline function readDelay(line: StaticArray<f32>, wi: i32, delay: f32): f32 {\n  let d: f32 = delay;\n  if (d < 1.0) d = 1.0;\n  const rp: f32 = f32(wi) - d;\n  let i0: i32 = i32(Mathf.floor(rp));\n  const frac: f32 = rp - f32(i0);\n  i0 = i0 & DMASK; if (i0 < 0) i0 += DLEN;\n  const i1: i32 = (i0 + 1) & DMASK;\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const mode: i32 = i32(clampf(params[P_MODE], 0.0, 3.0) + 0.5);\n  const widthN: f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // Four dimensional presets. Each picks a base delay, a tap SPREAD (the\n  // L/R offset that builds the anti-phase side), an intrinsic side gain,\n  // and an LFO rate. Higher mode = wider + thicker (more spread + side),\n  // but the LFO stays slow throughout so the pitch stays clean.\n  let baseMs:  f32 = 8.0;\n  let spreadMs: f32 = 2.0;   // half-difference between the two taps (ms)\n  let sideAmt: f32 = 0.35;   // intrinsic anti-phase contribution\n  let sweepMs: f32 = 0.35;   // modulation depth (ms) — tiny on purpose\n  let rateHz:  f32 = 0.12;\n  if (mode == 1)      { baseMs = 9.0;  spreadMs = 3.2; sideAmt = 0.55; sweepMs = 0.45; rateHz = 0.16; }\n  else if (mode == 2) { baseMs = 11.0; spreadMs = 4.6; sideAmt = 0.78; sweepMs = 0.55; rateHz = 0.21; }\n  else if (mode == 3) { baseMs = 13.0; spreadMs = 6.2; sideAmt = 1.00; sweepMs = 0.65; rateHz = 0.27; }\n\n  const baseSmp:   f32 = baseMs   * 0.001 * sampleRate;\n  const spreadSmp: f32 = spreadMs * 0.001 * sampleRate;\n  const sweepSmp:  f32 = sweepMs  * 0.001 * sampleRate;\n  const inc: f32 = rateHz / sampleRate;\n\n  // Wet tilt: blend between a low-passed (dark) and a high-shelf-boosted\n  // (bright/sparkle) version of the wet. one-pole corner ~ tied to Tone.\n  const toneHz: f32 = 1200.0 + toneN * 6000.0;\n  const tc: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * toneHz / sampleRate)), 0.0, 1.0);\n  // sparkle gain on the high band; brighter Tone => more top\n  const hiGain: f32 = 0.6 + toneN * 1.1;\n\n  // Side gain: mode intrinsic amount scaled by Width. Bounded so the widest\n  // mode at full Width still keeps the mono sum and peaks in check.\n  const sideGain: f32 = sideAmt * (0.35 + 0.65 * widthN);\n\n  // one-pole smoothing of control values (per-block, gentle)\n  const smc: f32 = 0.002;\n  sSpread += smc * (spreadSmp - sSpread);\n  sSweep  += smc * (sweepSmp  - sSweep);\n  sSide   += smc * (sideGain  - sSide);\n\n  const baseL: i32 = 0;\n  const baseR: i32 = MAX_FRAMES;\n\n  let pA: f32 = phaseA;\n  let pB: f32 = phaseB;\n  let wi: i32 = widx;\n  let zL: f32 = lpL;\n  let zR: f32 = lpR;\n\n  for (let f = 0; f < n; f++) {\n    const inL: f32 = inBuf[baseL + f];\n    const inR: f32 = channels > 1 ? inBuf[baseR + f] : inL;\n\n    // write current input\n    dlineL[wi] = inL;\n    dlineR[wi] = inR;\n\n    // mid (mono sum) preserved straight through the wet path\n    const mid: f32 = 0.5 * (inL + inR);\n\n    // two quadrature, very slow LFOs\n    const modA: f32 = Mathf.sin(PI2 * pA);\n    const modB: f32 = Mathf.sin(PI2 * pB);\n\n    // The two taps sit on opposite sides of the base delay (spread) and\n    // move in opposite directions under the slow LFO. Their DIFFERENCE is\n    // the anti-phase side; their average tracks the mid colour.\n    const sp: f32 = sSpread;\n    const sw: f32 = sSweep;\n    const tap1: f32 = readDelay(dlineL, wi, baseSmp - sp + sw * modA);\n    const tap2: f32 = readDelay(dlineR, wi, baseSmp + sp - sw * modB);\n\n    // anti-phase side signal (decorrelated, opposite on L vs R)\n    const side: f32 = sSide * (tap1 - tap2) * 0.5;\n\n    // wet image = preserved mid +/- side\n    let wetL: f32 = mid + side;\n    let wetR: f32 = mid - side;\n\n    // Tone tilt applied to the wet: split into low (one-pole) and high\n    // (residual) bands and re-weight the highs for clean sparkle.\n    zL = zL + tc * (wetL - zL);\n    zR = zR + tc * (wetR - zR);\n    const hiL: f32 = wetL - zL;\n    const hiR: f32 = wetR - zR;\n    wetL = zL + hiL * hiGain;\n    wetR = zR + hiR * hiGain;\n\n    // gentle output trim so the widest mode stays comfortably below 1.0\n    wetL *= 0.85;\n    wetR *= 0.85;\n\n    outBuf[baseL + f] = inL * (1.0 - mix) + wetL * mix;\n    if (channels > 1) outBuf[baseR + f] = inR * (1.0 - mix) + wetR * mix;\n\n    wi = (wi + 1) & DMASK;\n    pA += inc; if (pA >= 1.0) pA -= 1.0;\n    pB += inc; if (pB >= 1.0) pB -= 1.0;\n  }\n\n  phaseA = pA;\n  phaseB = pB;\n  widx = wi;\n  lpL = zL;\n  lpR = zR;\n}\n",
  "publishedAt": 1751000133000
}