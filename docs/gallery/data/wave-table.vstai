{
  "format": 1,
  "name": "Wave Table",
  "isInstrument": true,
  "explanation": "A polyphonic wavetable synthesizer in the spirit of early-1980s German digital hardware. Eight single-cycle waves are generated in code, spanning a pure sine through ever richer harmonic spectra into bright, hollow formant shapes. A Wave Position control scans smoothly through the bank with linear interpolation between tables, morphing the timbre in real time. Each of up to eight voices runs a wavetable oscillator into a resonant 4-pole low-pass shaped by its own filter envelope and amount, then an amplitude envelope, so chords ring with independent contours. Controls: Wave Position, Cutoff, Resonance, Filter Env Amount, Attack, Release, Detune and Level.",
  "params": [
    {
      "name": "Wave Position",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "FilterEnvAmt",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Attack",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.02
    },
    {
      "name": "Release",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Detune",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.2
    },
    {
      "name": "Level",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n@property --p{syntax:'<number>';inherits:false;initial-value:0}\n:root{\n  --ac:#5a9cff; --ac2:#9a6aff;\n  --steel:#aeb6c4; --steel2:#8c95a6;\n  --panel:#1a2233; --panel2:#0e1320; --ink:#cdd7ec;\n}\n*{box-sizing:border-box}\nhtml,body{margin:0;height:100%}\nbody{\n  font:13px ui-monospace,\"SF Mono\",Menlo,Consolas,monospace;\n  color:var(--ink);\n  background:radial-gradient(130% 100% at 50% -8%,#1c2740 0%,#0a0f1a 58%,#05070d 100%);\n  display:flex;align-items:center;justify-content:center;padding:16px;-webkit-font-smoothing:antialiased;\n}\n\n/* ---- brushed-aluminium chassis ---- */\n.synth{\n  position:relative;width:100%;max-width:780px;border-radius:12px;padding:8px;\n  background:linear-gradient(150deg,#3a4252 0%,#222a38 100%);\n  box-shadow:0 34px 80px rgba(0,0,0,.66),0 1px 0 rgba(255,255,255,.08) inset,0 -3px 14px rgba(0,0,0,.55) inset;\n  animation:rise .7s cubic-bezier(.2,.8,.2,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(20px) scale(.985)}to{opacity:1;transform:none}}\n.surface{\n  position:relative;border-radius:7px;overflow:hidden;\n  background:linear-gradient(180deg,#161d2c,#0d1320 70%,#0a0f1a 100%);\n  box-shadow:0 1px 0 rgba(255,255,255,.06) inset,0 0 0 1px rgba(120,150,210,.12);\n}\n/* brushed-metal hairlines */\n.surface::before{\n  content:\"\";position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.5;\n  background:repeating-linear-gradient(90deg,rgba(150,180,240,.025) 0 2px,transparent 2px 4px);\n  mix-blend-mode:screen;\n}\n\n/* ---------------- header ---------------- */\n.head{position:relative;z-index:3;display:flex;align-items:flex-end;gap:14px;padding:14px 20px 11px;border-bottom:1px solid rgba(120,150,210,.16)}\n.brand{display:flex;flex-direction:column;line-height:1}\n.brand .mk{font-size:9px;letter-spacing:.46em;color:#6f86ad;font-weight:700;text-transform:uppercase}\n.brand h1{margin:4px 0 0;font-size:24px;font-weight:800;letter-spacing:.16em;color:#dde7fb;text-transform:uppercase}\n.brand h1 em{font-style:normal;background:linear-gradient(90deg,var(--ac),var(--ac2));-webkit-background-clip:text;background-clip:text;color:transparent}\n.tag{font-size:8.5px;letter-spacing:.3em;color:#5e7398;text-transform:uppercase;margin-top:4px}\n.serial{margin-left:auto;text-align:right;font-size:8px;letter-spacing:.26em;color:#566b91;text-transform:uppercase}\n.serial b{display:block;color:var(--ac);font-size:11px;letter-spacing:.18em;margin-top:3px}\n\n/* ---------------- the wavetable display ---------------- */\n.display{position:relative;z-index:2;margin:14px 16px 6px;border-radius:6px;overflow:hidden;\n  background:linear-gradient(180deg,#05080f,#070c16);\n  box-shadow:0 0 0 1px rgba(90,156,255,.2),0 8px 26px rgba(0,0,0,.6) inset, 0 0 24px rgba(90,156,255,.06) inset;\n  height:228px}\n.display::after{ /* CRT scan veil */\n  content:\"\";position:absolute;inset:0;pointer-events:none;z-index:5;\n  background:repeating-linear-gradient(0deg,rgba(0,0,0,.16) 0 2px,transparent 2px 4px);opacity:.5}\n.disp-svg{position:absolute;inset:0;width:100%;height:100%;display:block}\n.glabel{position:absolute;left:10px;top:8px;z-index:6;font-size:8px;letter-spacing:.3em;color:#4b6a9c;text-transform:uppercase}\n.posread{position:absolute;right:10px;top:8px;z-index:6;font-size:9px;letter-spacing:.18em;color:var(--ac);text-transform:uppercase;\n  text-shadow:0 0 8px var(--ac)}\n\n/* ---------------- controls ---------------- */\n.rack{position:relative;z-index:2;padding:6px 16px 18px}\n.group{display:flex;flex-direction:column;margin-top:10px}\n.gtitle{font-size:8px;letter-spacing:.32em;color:#6f86ad;text-transform:uppercase;margin:0 0 7px 2px;display:flex;align-items:center;gap:8px}\n.gtitle::after{content:\"\";flex:1;height:1px;background:linear-gradient(90deg,rgba(120,150,210,.22),transparent)}\n.row{display:flex;flex-wrap:wrap;gap:14px}\n.cell{display:flex;flex-direction:column;align-items:center;width:84px;animation:pop .5s both;animation-delay:var(--d)}\n@keyframes pop{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}\n\n/* knob */\n.knob{position:relative;width:60px;height:60px;cursor:ns-resize;touch-action:none}\n.knob i{position:absolute;inset:0;border-radius:50%}\n.knob .scale{inset:-4px;background:conic-gradient(from -135deg,rgba(120,150,210,.28) 0deg,rgba(120,150,210,.28) 270deg,transparent 270deg);\n  -webkit-mask:radial-gradient(circle,transparent 30px,#000 31px,#000 32px,transparent 33px);\n  mask:radial-gradient(circle,transparent 30px,#000 31px,#000 32px,transparent 33px)}\n.knob .arc{inset:-4px;background:conic-gradient(from -135deg,var(--ac) calc(var(--p)*270deg),transparent 0);\n  -webkit-mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33px,transparent 34px);\n  mask:radial-gradient(circle,transparent 30px,#000 31px,#000 33px,transparent 34px);\n  filter:drop-shadow(0 0 5px var(--ac))}\n.knob .cap{inset:8px;background:radial-gradient(circle at 38% 32%,#3a4658,#1b2230 70%,#10151f 100%);\n  box-shadow:0 4px 9px rgba(0,0,0,.6),0 1px 0 rgba(255,255,255,.1) inset,0 -2px 6px rgba(0,0,0,.5) inset}\n.knob .ptr{inset:8px;transform:rotate(calc(-135deg + var(--p)*270deg));transition:transform .04s linear}\n.knob .ptr::before{content:\"\";position:absolute;left:50%;top:6px;width:2.5px;height:13px;margin-left:-1.25px;border-radius:2px;\n  background:var(--ac);box-shadow:0 0 7px var(--ac)}\n.knob.act .cap{box-shadow:0 4px 9px rgba(0,0,0,.6),0 0 0 2px var(--ac) inset,0 1px 0 rgba(255,255,255,.1) inset}\n.cnm{margin-top:8px;font-size:8.5px;letter-spacing:.16em;color:#9fb1d0;text-transform:uppercase}\n.cval{margin-top:3px;font-size:10px;font-weight:700;color:var(--ac);letter-spacing:.04em}\n\n/* the big scan slider */\n.scanwrap{flex:1;min-width:230px;display:flex;flex-direction:column;gap:7px}\n.scanlbl{display:flex;justify-content:space-between;font-size:8.5px;letter-spacing:.16em;color:#9fb1d0;text-transform:uppercase}\n.scanlbl b{color:var(--ac);font-weight:700}\n.scan{position:relative;height:30px;border-radius:6px;cursor:ew-resize;touch-action:none;\n  background:linear-gradient(180deg,#0a0f1a,#070b14);\n  box-shadow:0 0 0 1px rgba(120,150,210,.2) inset,0 2px 6px rgba(0,0,0,.5) inset}\n.scan .ticks{position:absolute;inset:0;display:flex;justify-content:space-between;padding:0 9px;align-items:center;pointer-events:none}\n.scan .ticks span{width:1px;height:11px;background:rgba(120,150,210,.3)}\n.scan .fill{position:absolute;top:2px;bottom:2px;left:2px;border-radius:5px;width:calc(var(--p)*100%);\n  background:linear-gradient(90deg,rgba(90,156,255,.18),rgba(154,106,255,.32));pointer-events:none}\n.scan .head2{position:absolute;top:-3px;bottom:-3px;width:4px;margin-left:-2px;border-radius:3px;left:calc(var(--p)*100%);\n  background:linear-gradient(180deg,var(--ac),var(--ac2));box-shadow:0 0 10px var(--ac),0 0 18px var(--ac2);pointer-events:none}\n\n/* idle breathing glow on the brand dot */\n.dot{display:inline-block;width:7px;height:7px;border-radius:50%;background:var(--ac);margin-right:7px;vertical-align:middle;\n  box-shadow:0 0 8px var(--ac);animation:pulse 2.4s ease-in-out infinite}\n@keyframes pulse{0%,100%{opacity:.45;box-shadow:0 0 5px var(--ac)}50%{opacity:1;box-shadow:0 0 13px var(--ac)}}\n</style></head>\n<body>\n<div class=\"synth\"><div class=\"surface\">\n\n  <div class=\"head\">\n    <div class=\"brand\">\n      <div class=\"mk\"><span class=\"dot\"></span>Digital Wave Computer</div>\n      <h1>Wave <em>Table</em></h1>\n      <div class=\"tag\" id=\"sp\">Scanning wavetable synthesizer</div>\n    </div>\n    <div class=\"serial\">Model<br><b>WT-2.3</b></div>\n  </div>\n\n  <div class=\"display\">\n    <div class=\"glabel\">Wavetable Bank</div>\n    <div class=\"posread\" id=\"posread\">POS 0.00</div>\n    <svg class=\"disp-svg\" id=\"dsvg\" viewBox=\"0 0 600 228\" preserveAspectRatio=\"none\"></svg>\n  </div>\n\n  <div class=\"rack\">\n    <div class=\"group\">\n      <div class=\"gtitle\">Wave</div>\n      <div class=\"row\">\n        <div class=\"scanwrap\">\n          <div class=\"scanlbl\"><span>Wave Position</span><b id=\"scanval\">0.00</b></div>\n          <div class=\"scan\" id=\"scan\">\n            <div class=\"ticks\"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></div>\n            <div class=\"fill\" id=\"scanfill\"></div>\n            <div class=\"head2\" id=\"scanhead\"></div>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"group\">\n      <div class=\"gtitle\">Filter</div>\n      <div class=\"row\" id=\"filtK\"></div>\n    </div>\n\n    <div class=\"group\">\n      <div class=\"gtitle\">Envelope &amp; Voice</div>\n      <div class=\"row\" id=\"envK\"></div>\n    </div>\n  </div>\n\n</div></div>\n\n<script>(function(){\n  var P=[\n    {name:\"Wave Position\",index:0,min:0,max:1,def:0.0 },\n    {name:\"Cutoff\",       index:1,min:0,max:1,def:0.6 },\n    {name:\"Resonance\",    index:2,min:0,max:1,def:0.3 },\n    {name:\"FilterEnvAmt\", index:3,min:0,max:1,def:0.5 },\n    {name:\"Attack\",       index:4,min:0,max:1,def:0.02},\n    {name:\"Release\",      index:5,min:0,max:1,def:0.35},\n    {name:\"Detune\",       index:6,min:0,max:1,def:0.2 },\n    {name:\"Level\",        index:7,min:0,max:1,def:0.7 }\n  ];\n  var byName={}; P.forEach(function(p){byName[p.name]=p;});\n  var live={}; P.forEach(function(p){ live[p.name]=(p.def-p.min)/(p.max-p.min); });\n\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n  function fmtPct(v){ return Math.round(v*100)+\"%\"; }\n  function fmtMs(v){ var ms=Math.round((v*v)*3000)+1; return ms>=1000?(ms/1000).toFixed(2)+\"s\":ms+\"ms\"; }\n  function labelFor(p,v){\n    if(p.name===\"Attack\"||p.name===\"Release\") return fmtMs(v);\n    if(p.name===\"Cutoff\"){ var hz=Math.round(60*Math.pow(256,v)); return hz>=1000?(hz/1000).toFixed(1)+\"k\":hz+\"Hz\"; }\n    if(p.name===\"Detune\"){ return (v*0.14).toFixed(2)+\"st\"; }\n    return fmtPct(v);\n  }\n\n  // ---------- knobs ----------\n  function makeKnob(host,p){\n    var cell=document.createElement('div'); cell.className='cell';\n    cell.style.setProperty('--d',(p.index*55)+'ms');\n    cell.innerHTML='<div class=\"knob\"><i class=\"scale\"></i><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i></div>'+\n      '<div class=\"cnm\">'+p.name.replace(\"FilterEnvAmt\",\"Env Amt\")+'</div><div class=\"cval\"></div>';\n    host.appendChild(cell);\n    var knob=cell.querySelector('.knob'), val=cell.querySelector('.cval');\n    var v=p.def;\n    function norm(){ return (v-p.min)/(p.max-p.min||1); }\n    function paint(){ var n=norm(); knob.style.setProperty('--p',n); val.textContent=labelFor(p,n); live[p.name]=n; send(p.index,v); }\n    function setN(n){ n=n<0?0:n>1?1:n; v=p.min+(p.max-p.min)*n; paint(); }\n    knob.addEventListener('pointerdown',function(e){ knob._d=1;knob._y=e.clientY;knob._n=norm();knob.classList.add('act');knob.setPointerCapture(e.pointerId);e.preventDefault(); });\n    knob.addEventListener('pointermove',function(e){ if(!knob._d)return; var spd=e.shiftKey?640:200; setN(knob._n+(knob._y-e.clientY)/spd); });\n    function end(){ knob._d=0; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup',end); knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){ v=p.def; paint(); });\n    knob.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.025:-0.025)); },{passive:false});\n    paint();\n  }\n  makeKnob(document.getElementById('filtK'), byName[\"Cutoff\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"Resonance\"]);\n  makeKnob(document.getElementById('filtK'), byName[\"FilterEnvAmt\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Attack\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Release\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Detune\"]);\n  makeKnob(document.getElementById('envK'),  byName[\"Level\"]);\n\n  // ---------- wave position scan slider ----------\n  var scan=document.getElementById('scan'), fill=document.getElementById('scanfill'),\n      head=document.getElementById('scanhead'), scanval=document.getElementById('scanval'),\n      posread=document.getElementById('posread'), wp=byName[\"Wave Position\"];\n  var wv=wp.def;\n  function wnorm(){ return (wv-wp.min)/(wp.max-wp.min||1); }\n  function wpaint(){ var n=wnorm(); scan.style.setProperty('--p',n); fill.style.setProperty('--p',n);\n    head.style.setProperty('--p',n); scanval.textContent=n.toFixed(2); posread.textContent=\"POS \"+n.toFixed(2);\n    live[\"Wave Position\"]=n; send(wp.index,wv); renderBank(n); }\n  function wsetN(n){ n=n<0?0:n>1?1:n; wv=wp.min+(wp.max-wp.min)*n; wpaint(); }\n  function fromEvt(e){ var r=scan.getBoundingClientRect(); wsetN((e.clientX-r.left)/r.width); }\n  scan.addEventListener('pointerdown',function(e){ scan._d=1; scan.setPointerCapture(e.pointerId); fromEvt(e); e.preventDefault(); });\n  scan.addEventListener('pointermove',function(e){ if(scan._d) fromEvt(e); });\n  function send2(){ scan._d=0; } scan.addEventListener('pointerup',send2); scan.addEventListener('pointercancel',send2);\n  scan.addEventListener('dblclick',function(){ wv=wp.def; wpaint(); });\n  scan.addEventListener('wheel',function(e){ e.preventDefault(); wsetN(wnorm()+(e.deltaY<0?0.04:-0.04)); },{passive:false});\n\n  // ---------- 3D wavetable bank render (the centrepiece) ----------\n  var NT=8, NS=64, dsvg=document.getElementById('dsvg');\n  // model the same bank progression as the DSP: sine -> harmonic -> formant\n  function sampleWave(t,ph){\n    var m=t/(NT-1), s=0,h;\n    if(t===0){ s=Math.sin(ph); }\n    else if(t<5){ var nh=2+t*5, tilt=1-0.15*t; for(h=1;h<=nh;h++){ s+=Math.pow(1/h,tilt)*Math.sin(ph*h); } s*=0.5; }\n    else { var fo=3+(m-0.57)*14, w=2.5+(m-0.57)*4; for(h=1;h<=24;h++){ var d=(h-fo)/w; s+=(Math.exp(-d*d)+0.18/h)*Math.sin(ph*h+0.5*h*m); } s*=0.35; }\n    return s;\n  }\n  // pre-render path strings for each of the 8 tables\n  var W=600,Hd=228, paths=[];\n  function buildPaths(){\n    for(var t=0;t<NT;t++){\n      // perspective: deeper tables (higher t) shrink toward the back-top\n      var depth=t/(NT-1);\n      var baseY=Hd-26 - depth*(Hd-92);          // back tables higher\n      var scaleX=1-depth*0.34;                    // back tables narrower\n      var amp=22*(1-depth*0.45);\n      var x0=W*0.5*(1-scaleX), x1=W-x0;\n      var d=\"\";\n      for(var i=0;i<=NS;i++){\n        var fr=i/NS, ph=fr*Math.PI*2;\n        var y=baseY - sampleWave(t,ph)*amp;\n        var x=x0+(x1-x0)*fr;\n        d+=(i?\"L\":\"M\")+x.toFixed(1)+\" \"+y.toFixed(1)+\" \";\n      }\n      paths.push(d);\n    }\n  }\n  buildPaths();\n  // build the SVG layers once\n  function initSvg(){\n    var ns=\"http://www.w3.org/2000/svg\", frag=\"\";\n    // faint grid floor\n    for(var g=0;g<7;g++){ var gy=Hd-26-g*((Hd-92)/6.0); frag+='<line x1=\"40\" y1=\"'+gy.toFixed(1)+'\" x2=\"560\" y2=\"'+gy.toFixed(1)+'\" stroke=\"rgba(90,156,255,0.06)\" stroke-width=\"1\"/>'; }\n    for(t=NT-1;t>=0;t--){\n      frag+='<path id=\"wl'+t+'\" d=\"'+paths[t]+'\" fill=\"none\" stroke=\"rgba(120,150,210,0.32)\" stroke-width=\"1.4\" stroke-linejoin=\"round\"/>';\n    }\n    dsvg.innerHTML=frag;\n  }\n  initSvg();\n  // highlight tables near the scan position, draw a moving scan-line glow\n  function renderBank(pos){\n    var sel=pos*(NT-1);\n    for(var t=0;t<NT;t++){\n      var el=document.getElementById('wl'+t); if(!el)continue;\n      var dist=Math.abs(t-sel);\n      var lit=Math.max(0,1-dist);          // 1 at the exact table, fades to neighbours\n      if(lit>0.001){\n        var c=\"rgba(\"+Math.round(90+64*lit)+\",\"+Math.round(156+50*lit)+\",255,\"+(0.45+0.5*lit).toFixed(2)+\")\";\n        el.setAttribute('stroke',c);\n        el.setAttribute('stroke-width',(1.4+lit*1.6).toFixed(2));\n        el.style.filter=lit>0.5?'drop-shadow(0 0 6px rgba(90,156,255,0.9))':'none';\n      } else {\n        el.setAttribute('stroke','rgba(120,150,210,0.22)');\n        el.setAttribute('stroke-width','1.2');\n        el.style.filter='none';\n      }\n    }\n  }\n\n  // gentle idle breathing of the whole stack so it always feels alive\n  var t0=performance.now();\n  function idle(now){\n    requestAnimationFrame(idle);\n    var b=0.5+0.5*Math.sin((now-t0)*0.0011);\n    dsvg.style.transform='translateY('+(b*1.6-0.8).toFixed(2)+'px)';\n  }\n  requestAnimationFrame(idle);\n\n  function ready(){ wpaint(); }     // init scan + bank highlight + send default\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();</script>\n</body></html>\n",
  "assembly": "// =====================================================================\n//  WAVE TABLE — a polyphonic wavetable synthesizer instrument.\n//  Inspired by early-1980s German digital wavetable hardware: a bank of\n//  eight code-generated single-cycle waves spanning sine -> harmonically\n//  rich -> formant/vocal shapes. A Wave Position control SCANS smoothly\n//  through the bank with linear interpolation BETWEEN tables (the classic\n//  digital \"scanning\" timbre morph). Each of eight voices: a wavetable\n//  oscillator -> resonant 4-pole low-pass with its own filter ADSR and\n//  amount -> amplitude ADSR. Voices keyed by noteId so chords ring with\n//  independent contours. Pure algorithm, generated at init, no samples,\n//  no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst NUM_TABLES: i32 = 8;       // single-cycle waves in the bank\nconst TABLE_LEN: i32 = 2048;     // samples per single-cycle wave\nconst TABLE_MASK: i32 = 2047;    // TABLE_LEN - 1 (power of two)\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// the wavetable bank: NUM_TABLES contiguous single-cycle waves\nconst bank: StaticArray<f32> = new StaticArray<f32>(NUM_TABLES * TABLE_LEN);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_WAVEPOS: i32 = 0;  // 0..1  -> scan through the table bank\nconst P_CUTOFF:  i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:    i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT:  i32 = 3;  // 0..1  -> filter envelope amount\nconst P_ATTACK:  i32 = 4;  // 0..1  -> seconds\nconst P_RELEASE: i32 = 5;  // 0..1  -> seconds\nconst P_DETUNE:  i32 = 6;  // 0..1  -> subtle unison detune spread\nconst P_LEVEL:   i32 = 7;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhaseA: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc A phase 0..1\nconst vPhaseB: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc B (detuned) phase\n\n// amplitude AR envelope\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sus 3 rel\n// filter AR envelope\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// resonant 4-pole ladder state per voice\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- build the wavetable bank in code at init -----------------------\n// Each table is a single cycle, normalized to peak ~1. The bank progresses\n// from a pure sine, through ever richer harmonic spectra, into bright/odd\n// \"formant\"-style waves so scanning Wave Position clearly morphs timbre.\nfunction buildBank(): void {\n  for (let t = 0; t < NUM_TABLES; t++) {\n    const base: i32 = t * TABLE_LEN;\n    // morph factor 0..1 across the bank\n    const m: f32 = f32(t) / f32(NUM_TABLES - 1);\n\n    let peak: f32 = 0.0001;\n    for (let i = 0; i < TABLE_LEN; i++) {\n      const ph: f32 = TWO_PI * f32(i) / f32(TABLE_LEN);\n      let s: f32 = 0.0;\n\n      if (t == 0) {\n        // pure sine\n        s = Mathf.sin(ph);\n      } else if (t < 5) {\n        // additive harmonic series: more harmonics, gentler rolloff as t grows.\n        // t=1 few harmonics (soft), t=4 saw-ish bright.\n        const nh: i32 = 2 + t * 5;             // 7,12,17,22 harmonics\n        const tilt: f32 = 1.0 - 0.15 * f32(t); // brighter rolloff for higher t\n        for (let h = 1; h <= nh; h++) {\n          const amp: f32 = f32(Mathf.pow(f32(1.0) / f32(h), tilt));\n          s += amp * Mathf.sin(ph * f32(h));\n        }\n      } else {\n        // formant / vocal-ish waves: a low fundamental shaped by a moving\n        // formant peak (a windowed burst of harmonics) -> bright, hollow,\n        // resonant tones reminiscent of the digital bank's upper region.\n        const formant: f32 = 3.0 + (m - 0.57) * 14.0; // formant centre harmonic\n        const width: f32 = 2.5 + (m - 0.57) * 4.0;\n        const nh: i32 = 40;\n        for (let h = 1; h <= nh; h++) {\n          const d: f32 = (f32(h) - formant) / width;\n          const amp: f32 = f32(Mathf.exp(-d * d)) + 0.18 / f32(h);\n          s += amp * Mathf.sin(ph * f32(h) + 0.5 * f32(h) * m);\n        }\n      }\n\n      bank[base + i] = s;\n      const a: f32 = s < 0.0 ? -s : s;\n      if (a > peak) peak = a;\n    }\n    // normalize this table to peak ~0.98\n    const norm: f32 = 0.98 / peak;\n    for (let i = 0; i < TABLE_LEN; i++) {\n      bank[base + i] = bank[base + i] * norm;\n    }\n  }\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhaseA[v] = 0.0; vPhaseB[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n  }\n  ageCounter = 0;\n  buildBank();\n  params[P_WAVEPOS] = 0.0;\n  params[P_CUTOFF]  = 0.6;\n  params[P_RESO]    = 0.3;\n  params[P_ENVAMT]  = 0.5;\n  params[P_ATTACK]  = 0.02;\n  params[P_RELEASE] = 0.35;\n  params[P_DETUNE]  = 0.2;\n  params[P_LEVEL]   = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vPhaseA[slot] = 0.0;\n  vPhaseB[slot] = 0.13; // slight offset so the two oscillators don't phase-lock\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 3;  // release\n      vFStage[i] = 3;\n    }\n  }\n}\n\n// linearly-interpolated read of one table (index t) at phase 0..1\n@inline function readTable(t: i32, ph: f32): f32 {\n  const base: i32 = t * TABLE_LEN;\n  const fpos: f32 = ph * f32(TABLE_LEN);\n  let i0: i32 = i32(fpos);\n  const frac: f32 = fpos - f32(i0);\n  i0 = i0 & TABLE_MASK;\n  const i1: i32 = (i0 + 1) & TABLE_MASK;\n  const a: f32 = bank[base + i0];\n  const b: f32 = bank[base + i1];\n  return a + (b - a) * frac;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const wavePos: f32 = clampf(params[P_WAVEPOS], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const atkS: f32 = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0)  * 1.5;\n  const relS: f32 = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 2.5;\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // scan position -> table index + crossfade fraction\n  const scan: f32 = wavePos * f32(NUM_TABLES - 1);\n  let tIdx: i32 = i32(scan);\n  if (tIdx > NUM_TABLES - 2) tIdx = NUM_TABLES - 2;\n  if (tIdx < 0) tIdx = 0;\n  const tFrac: f32 = scan - f32(tIdx);\n\n  // envelope rates (linear AR)\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune in semitone fraction: up to ~ +/-0.14 semitone for gentle width\n  const detSemi: f32 = detuneN * 0.14;\n  const ratioUp: f32   = f32(Mathf.pow(2.0, detSemi / 12.0));\n  const ratioDown: f32 = f32(Mathf.pow(2.0, -detSemi / 12.0));\n\n  // base cutoff in Hz, exponential 60 Hz .. ~16 kHz\n  const baseHz: f32 = 60.0 * f32(Mathf.pow(256.0, cutoffN));\n  const envOct: f32 = envAmt * 6.0;          // envelope sweeps up to 6 octaves\n  const reso: f32 = resoN * 4.0;             // feedback 0..4\n\n  // headroom for up to 8 summed voices\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR ----------------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // sustain (held)\n        aenv = 1.0;\n      } else if (astg == 3) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter AR -------------------------------------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv = 1.0;\n      } else if (fstg == 3) {\n        fenv -= relRate;\n        if (fenv <= 0.0) { fenv = 0.0; fstg = 0; }\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- wavetable oscillator (two detuned reads) ------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const incA: f32 = baseInc * ratioDown;\n      const incB: f32 = baseInc * ratioUp;\n\n      let pa: f32 = vPhaseA[v];\n      pa += incA; if (pa >= 1.0) pa -= 1.0;\n      vPhaseA[v] = pa;\n\n      let pb: f32 = vPhaseB[v];\n      pb += incB; if (pb >= 1.0) pb -= 1.0;\n      vPhaseB[v] = pb;\n\n      // scan: crossfade between adjacent tables (the PPG character)\n      const a0: f32 = readTable(tIdx, pa);\n      const a1: f32 = readTable(tIdx + 1, pa);\n      const sA: f32 = a0 + (a1 - a0) * tFrac;\n\n      const b0: f32 = readTable(tIdx, pb);\n      const b1: f32 = readTable(tIdx + 1, pb);\n      const sB: f32 = b0 + (b1 - b0) * tFrac;\n\n      let osc: f32 = (sA + sB) * 0.5;\n\n      // ---- resonant 4-pole low-pass ----------------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = osc - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      outL += s3 * aenv * vVel[v];\n    }\n\n    let mix: f32 = outL * voiceScale * level;\n    mix = f32(Mathf.tanh(mix * 1.1));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000071000
}