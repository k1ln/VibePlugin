  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Micro Beat</title>\n<style>\n  :root{ --acc:#5ad0ff; --acc2:#aab4c0; --bg0:#0a0c0e; --bg1:#161a1e; --ink:#e6edf2; --dim:#74808c; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#22282e 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(92vw,680px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#242a30,#0c0f12); border:1px solid rgba(90,208,255,.18); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.05); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:19px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:9px; letter-spacing:.28em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:8px; height:8px; border-radius:50%; background:var(--acc); box-shadow:0 0 8px var(--acc); animation:pulse 2s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  /* LCD strip with voice lamps + step grid */\n  .lcd{ border-radius:7px; padding:8px 10px; margin-bottom:14px; background:linear-gradient(180deg,#0c2a26,#0a201d); border:1px solid rgba(90,255,200,.18); box-shadow:inset 0 2px 12px rgba(0,0,0,.5); }\n  .lamps{ display:grid; grid-template-columns:repeat(5,1fr); gap:6px; margin-bottom:8px; }\n  .lamp{ font-size:8px; letter-spacing:.04em; text-transform:uppercase; text-align:center; padding:3px 0; border-radius:4px; color:#3f6; background:rgba(0,0,0,.25); border:1px solid rgba(90,255,200,.18); transition:all .06s; }\n  .lamp.on{ background:rgba(90,255,200,.85); color:#04130f; box-shadow:0 0 10px rgba(90,255,200,.6); }\n  .grid{ display:grid; grid-template-columns:repeat(16,1fr); gap:3px; }\n  .cell{ height:8px; border-radius:2px; background:rgba(90,255,200,.12); }\n  .cell.play{ background:#6affce; box-shadow:0 0 6px #6affce; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:64px; height:64px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(180,205,225,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(90,208,255,.6)); }\n  .pcap{ fill:#10151a; stroke:rgba(90,208,255,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8px; letter-spacing:.08em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:10px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(90,208,255,.1); padding:1px 6px; border-radius:6px; border:1px solid rgba(90,208,255,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">MICRO&nbsp;BEAT</span><span class=\"sub\">budget drum box</span><span class=\"led\"></span></header>\n    <div class=\"lcd\"><div class=\"lamps\" id=\"lamps\"></div><div class=\"grid\" id=\"grid\"></div></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var VOICES=[\"Kick\",\"Snare\",\"Hat\",\"Clap\",\"Cym\"];\n  var P=[{name:\"Pitch\",idx:0,def:0.5},{name:\"Decay\",idx:1,def:0.4},{name:\"Click\",idx:2,def:0.6},{name:\"Hat\",idx:3,def:0.6},{name:\"Accent\",idx:4,def:0.5},{name:\"Level\",idx:5,def:0.85}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var lw=document.getElementById(\"lamps\");\n  var lamps=VOICES.map(function(nm){ var e=document.createElement(\"div\"); e.className=\"lamp\"; e.textContent=nm; lw.appendChild(e); return e; });\n  var gw=document.getElementById(\"grid\"), cells=[];\n  for(var i=0;i<16;i++){ var c=document.createElement(\"div\"); c.className=\"cell\"; gw.appendChild(c); cells.push(c); }\n  var PAT=[0,2,1,2, 0,2,1,2, 0,2,3,2, 0,2,1,4];\n  var R=29, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 72 72\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#5ad0ff\"/><stop offset=\"1\" stop-color=\"#aab4c0\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"36\" cy=\"36\" r=\"29\"></circle><circle class=\"arc\" cx=\"36\" cy=\"36\" r=\"29\" transform=\"rotate(135 36 36)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"36\" cy=\"36\" r=\"18\"></circle><line class=\"ptr\" x1=\"36\" y1=\"36\" x2=\"36\" y2=\"21\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(36+Math.sin(ang)*14).toFixed(2)); ptr.setAttribute(\"y2\",(36-Math.cos(ang)*14).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/160)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def); return {render:render};\n  });\n  var step=-1,last=0,acc=0;\n  function frame(ts){ if(!last)last=ts; var dt=ts-last; last=ts; acc+=dt; var ms=60000/115/4;\n    if(acc>=ms){ acc-=ms; if(step>=0) cells[step].classList.remove(\"play\"); step=(step+1)%16; cells[step].classList.add(\"play\");\n      var v=PAT[step]; for(var i=0;i<5;i++) lamps[i].classList.toggle(\"on\", i===v); }\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MICRO BEAT — a tiny budget analog drum box (Boss DR-110 lineage).\n//  Real-time analog synthesis, distinct from the factory's bigger boxes by\n//  a thin, clicky, bright budget character: a short clicky kick, a papery\n//  snare, sizzly \"tssh\" hats and a thin clap/cymbal. A MIDI note selects a\n//  voice (note % 5) into a 6-slot pool. Controls: Pitch, Decay, Click\n//  (attack snap), Hat (brightness/length), Accent, Level.\n//  No samples, no host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NV: i32 = 5;   // 0 kick,1 snare,2 hat,3 clap,4 cymbal\nconst POOL: i32 = 6;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst pType: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pPh: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pAEnv: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pPEnv: StaticArray<f32> = new StaticArray<f32>(POOL);\nconst pAct: StaticArray<i32> = new StaticArray<i32>(POOL);\nconst pVel: StaticArray<f32> = new StaticArray<f32>(POOL);\nlet pNext: i32 = 0;\nlet sampleRate: f32 = 48000.0;\nlet rngState: i32 = 33221;\nlet hpz: f32 = 0.0;\n\nconst P_PITCH: i32 = 0; const P_DECAY: i32 = 1; const P_CLICK: i32 = 2; const P_HAT: i32 = 3; const P_ACCENT: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n@inline function rnd(): f32 { rngState = (rngState * 1103515245 + 12345) & 0x7fffffff; return f32(rngState) / 1073741824.0 - 1.0; }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0; pNext = 0; hpz = 0.0;\n  for (let i = 0; i < POOL; i++) { pAct[i] = 0; pPh[i] = 0.0; pAEnv[i] = 0.0; pPEnv[i] = 0.0; pType[i] = 0; pVel[i] = 0.0; }\n  params[P_PITCH] = 0.5; params[P_DECAY] = 0.4; params[P_CLICK] = 0.6; params[P_HAT] = 0.6; params[P_ACCENT] = 0.5; params[P_LEVEL] = 0.85;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let t: i32 = id % NV; if (t < 0) t += NV;\n  const slot: i32 = pNext; pNext = (pNext + 1) % POOL;\n  pType[slot] = t; pPh[slot] = 0.0; pAEnv[slot] = 1.0; pPEnv[slot] = 1.0; pAct[slot] = 1; pVel[slot] = clampf(v, 0.05, 1.0);\n}\nexport function noteOff(id: i32): void { /* one-shots */ }\n\nexport function process(n: i32): void {\n  const pitchN: f32 = clampf(params[P_PITCH], 0.0, 1.0);\n  const decayN: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const clickN: f32 = clampf(params[P_CLICK], 0.0, 1.0);\n  const hatN: f32 = clampf(params[P_HAT], 0.0, 1.0);\n  const accentN: f32 = clampf(params[P_ACCENT], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const pitchMul: f32 = f32(Mathf.exp((pitchN - 0.5) * 1.0));\n  const kDec: f32 = f32(Mathf.exp(-1.0 / ((0.04 + decayN * 0.22) * sampleRate)));   // thin kick\n  const sDec: f32 = f32(Mathf.exp(-1.0 / ((0.04 + decayN * 0.14) * sampleRate)));\n  const hDec: f32 = f32(Mathf.exp(-1.0 / ((0.01 + hatN * 0.05) * sampleRate)));\n  const clapDec: f32 = f32(Mathf.exp(-1.0 / (0.07 * sampleRate)));\n  const cymDec: f32 = f32(Mathf.exp(-1.0 / ((0.1 + hatN * 0.3) * sampleRate)));\n  const pDec: f32 = f32(Mathf.exp(-1.0 / (0.01 * sampleRate)));\n  const accent: f32 = 0.7 + accentN * 0.6;\n  const out: f32 = level * 0.55;\n\n  for (let i = 0; i < n; i++) {\n    let mix: f32 = 0.0;\n    for (let s = 0; s < POOL; s++) {\n      if (pAct[s] == 0) continue;\n      const t: i32 = pType[s];\n      let v: f32 = 0.0;\n      pPEnv[s] *= pDec;\n      if (t == 0) {                 // thin clicky kick\n        const fr: f32 = 75.0 * pitchMul * (1.0 + 1.5 * pPEnv[s]);\n        let ph: f32 = pPh[s] + fr / sampleRate; if (ph >= 1.0) ph -= 1.0; pPh[s] = ph;\n        v = f32(Mathf.sin(ph * 6.2831853)) + (pPEnv[s] > 0.6 ? rnd() * clickN * 0.8 : 0.0);\n        pAEnv[s] *= kDec;\n      } else if (t == 1) {          // papery snare\n        const raw: f32 = rnd(); v = raw * 0.8 + f32(Mathf.sin((pPh[s] += 250.0 * pitchMul / sampleRate) * 6.2831853)) * 0.3;\n        if (pPh[s] >= 1.0) pPh[s] -= 1.0;\n        pAEnv[s] *= sDec;\n      } else if (t == 2) {          // sizzly hat\n        const raw: f32 = rnd(); hpz += (raw - hpz) * 0.75; v = (raw - hpz) * (0.6 + hatN * 0.5);\n        pAEnv[s] *= hDec;\n      } else if (t == 3) {          // clap\n        const raw: f32 = rnd(); v = raw * 0.7;\n        pAEnv[s] *= clapDec;\n      } else {                      // cymbal\n        const raw: f32 = rnd(); hpz += (raw - hpz) * 0.9; v = (raw - hpz) * 0.55;\n        pAEnv[s] *= cymDec;\n      }\n      mix += v * pAEnv[s] * pVel[s] * accent;\n      if (pAEnv[s] < 0.0004) pAct[s] = 0;\n    }\n    let o: f32 = mix * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751000171000
}