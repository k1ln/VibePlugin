  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Multi Mono</title>\n<style>\n  :root{ --acc:#f08a3c; --acc2:#5ad0e0; --bg0:#0c0905; --bg1:#1a130a; --ink:#f6efe6; --dim:#9a8468; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif; background:radial-gradient(120% 90% at 50% -10%,#2a1f10 0%,var(--bg1) 46%,var(--bg0) 100%); color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(95vw,760px); border-radius:15px; padding:16px 22px 20px; position:relative; overflow:hidden; background:linear-gradient(160deg,#241a0e,#0c0805); border:1px solid rgba(240,138,60,.22); box-shadow:0 22px 64px rgba(0,0,0,.62),inset 0 1px 0 rgba(255,235,210,.06); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:21px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 1.9s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4;} 50%{ opacity:1;} }\n  .screen{ height:96px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:linear-gradient(180deg,#160f07,#0b0805); border:1px solid rgba(240,138,60,.16); box-shadow:inset 0 2px 18px rgba(0,0,0,.55); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .scrlbl{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.22em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(6,1fr); gap:6px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:70px; height:70px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(235,220,200,.13); stroke-width:7; stroke-linecap:round; } .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(240,138,60,.6)); }\n  .pcap{ fill:#140d06; stroke:rgba(240,138,60,.22); stroke-width:1; } .ptr{ stroke:var(--acc2); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:8.5px; letter-spacing:.1em; text-transform:uppercase; color:var(--dim); } .kv{ font-size:10.5px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(240,138,60,.1); padding:1px 7px; border-radius:7px; border:1px solid rgba(240,138,60,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style></head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">MULTI&nbsp;MONO</span><span class=\"sub\">expressive vco mono</span><span class=\"led\"></span></header>\n    <div class=\"screen\"><div class=\"scrlbl\">OSC&nbsp;MOD</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\"use strict\";\n  var P=[{name:\"Cutoff\",idx:0,def:0.5},{name:\"Reso\",idx:1,def:0.4},{name:\"Env\",idx:2,def:0.6},{name:\"Osc Mod\",idx:3,def:0.3},{name:\"Sub\",idx:4,def:0.4},{name:\"Level\",idx:5,def:0.8}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; }); var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135; var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){ var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 80 80\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#f08a3c\"/><stop offset=\"1\" stop-color=\"#5ad0e0\"/></linearGradient></defs><circle class=\"track\" cx=\"40\" cy=\"40\" r=\"33\"></circle><circle class=\"arc\" cx=\"40\" cy=\"40\" r=\"33\" transform=\"rotate(135 40 40)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle><circle class=\"pcap\" cx=\"40\" cy=\"40\" r=\"20\"></circle><line class=\"ptr\" x1=\"40\" y1=\"40\" x2=\"40\" y2=\"23\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el); var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString()); var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(40+Math.sin(ang)*16).toFixed(2)); ptr.setAttribute(\"y2\",(40-Math.cos(ang)*16).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); }); render(p.def); return {render:render}; });\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); } window.addEventListener(\"resize\",resize); resize();\n  function frame(ts){ ctx.clearRect(0,0,W,H); var cut=vals[0], mod=vals[3], sub=vals[4]; var mid=H*0.54;\n    var lfo=Math.sin(ts/430); var vib=mod*0.5*lfo; var pw=0.5+mod*0.35*lfo;\n    // single VCO trace: saw+pulse, pitch wobbled by vibrato, with the sub underneath\n    ctx.beginPath();\n    for(var x=0;x<=W;x+=2){ var t=x/W; var ph=(t*3.4*(1+vib*0.12)+ts/900)%1;\n      var saw=(2*ph-1)*0.6; var pulse=(ph<pw?1:-1)*0.4; var v=(saw+pulse)*(0.45+cut*0.5);\n      ctx.lineTo(x, mid - v*(H*0.30)); }\n    ctx.strokeStyle=\"rgba(240,138,60,0.92)\"; ctx.lineWidth=2; ctx.shadowColor=\"#f08a3c\"; ctx.shadowBlur=8; ctx.stroke(); ctx.shadowBlur=0;\n    if(sub>0.02){ ctx.beginPath(); for(var x2=0;x2<=W;x2+=3){ var t2=x2/W; var sph=(t2*1.7+ts/900)%1; var sv=(sph<0.5?0.7:-0.7)*sub*(H*0.16);\n      ctx.lineTo(x2, mid - sv); } ctx.strokeStyle=\"rgba(90,208,224,0.45)\"; ctx.lineWidth=1.4; ctx.stroke(); }\n    // LFO orbit (top-right): a dot circling, radius = mod depth\n    var ox=W-26, oy=22, rr=4+mod*11; ctx.strokeStyle=\"rgba(90,208,224,0.25)\"; ctx.lineWidth=1; ctx.beginPath(); ctx.arc(ox,oy,rr,0,Math.PI*2); ctx.stroke();\n    var a=ts/430; ctx.fillStyle=\"#5ad0e0\"; ctx.beginPath(); ctx.arc(ox+Math.cos(a)*rr, oy+Math.sin(a)*rr, 2.6, 0, Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script></body></html>\n",
  "assembly": "// =====================================================================\n//  MULTI MONO — an expressive single-VCO mono (Multimoog lineage).\n//  One VCO (saw + variable pulse) + a square sub through a Moog-style\n//  resonant low-pass with its own envelope; the signature is an OSC MOD\n//  (LFO -> pitch vibrato + pulse-width) for the lip/aftertouch-style\n//  expression. Mono (last-note). No host imports, no allocation in process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet ph: f32 = 0.0; let phs: f32 = 0.0; let lfo: f32 = 0.0;\nlet targetFreq: f32 = 0.0; let curFreq: f32 = 0.0;\nlet gate: i32 = 0; let note: i32 = -1; let amp: f32 = 0.0; let fenv: f32 = 0.0;\nlet lp: f32 = 0.0; let bp: f32 = 0.0;\n\nconst P_CUTOFF: i32 = 0; const P_RESO: i32 = 1; const P_ENV: i32 = 2; const P_MOD: i32 = 3; const P_SUB: i32 = 4; const P_LEVEL: i32 = 5;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  ph = 0.0; phs = 0.0; lfo = 0.0; targetFreq = 0.0; curFreq = 0.0; gate = 0; note = -1; amp = 0.0; fenv = 0.0; lp = 0.0; bp = 0.0;\n  params[P_CUTOFF] = 0.5; params[P_RESO] = 0.4; params[P_ENV] = 0.6; params[P_MOD] = 0.3; params[P_SUB] = 0.4; params[P_LEVEL] = 0.8;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const nf: f32 = f > 0.0 ? f : 220.0;\n  if (gate == 0 && curFreq <= 0.0) curFreq = nf;\n  targetFreq = nf; note = id; gate = 1; fenv = 1.0; amp = clampf(v, 0.1, 1.0);\n}\nexport function noteOff(id: i32): void { if (id == note) gate = 0; }\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32 = clampf(params[P_RESO], 0.0, 1.0);\n  const envN: f32 = clampf(params[P_ENV], 0.0, 1.0);\n  const modN: f32 = clampf(params[P_MOD], 0.0, 1.0);\n  const subN: f32 = clampf(params[P_SUB], 0.0, 1.0);\n  const level: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const fEnvCoef: f32 = f32(Mathf.exp(-1.0 / (0.5 * sampleRate)));\n  const aRel: f32 = f32(Mathf.exp(-1.0 / (0.25 * sampleRate)));\n  const glideCoef: f32 = f32(Mathf.exp(-1.0 / (0.015 * sampleRate)));\n  const baseCut: f32 = 50.0 * f32(Mathf.exp(cutoffN * 5.3));\n  const envSpan: f32 = envN * 8000.0;\n  const k: f32 = 2.0 - 1.92 * resoN;\n  const lfoInc: f32 = 5.5 / sampleRate * 6.2831853;\n  const vibDepth: f32 = modN * 0.03;       // +/-3% pitch vibrato\n  const pwmDepth: f32 = modN * 0.35;\n  const out: f32 = level * 0.6;\n\n  for (let i = 0; i < n; i++) {\n    curFreq = targetFreq + (curFreq - targetFreq) * glideCoef;\n    if (gate != 0) { amp += (1.0 - amp) * 0.003; if (amp > 1.0) amp = 1.0; } else { amp *= aRel; }\n    fenv *= fEnvCoef;\n    lfo += lfoInc; if (lfo > 6.2831853) lfo -= 6.2831853;\n    const lfv: f32 = f32(Mathf.sin(lfo));\n    const f: f32 = curFreq * (1.0 + vibDepth * lfv);\n    let p: f32 = ph + f / sampleRate; if (p >= 1.0) p -= 1.0; ph = p;\n    let sp: f32 = phs + (f * 0.5) / sampleRate; if (sp >= 1.0) sp -= 1.0; phs = sp;\n    const pw: f32 = 0.5 + pwmDepth * lfv;\n    const saw: f32 = p * 2.0 - 1.0;\n    const pulse: f32 = p < pw ? 1.0 : -1.0;\n    const sub: f32 = sp < 0.5 ? 0.7 : -0.7;\n    let osc: f32 = (saw * 0.6 + pulse * 0.4 + sub * subN) * 0.5;\n    let fc: f32 = baseCut + envSpan * fenv;\n    if (fc < 30.0) fc = 30.0; if (fc > sampleRate * 0.45) fc = sampleRate * 0.45;\n    const g: f32 = f32(Mathf.tan(3.14159265 * fc / sampleRate));\n    const a1: f32 = 1.0 / (1.0 + g * (g + k));\n    const hp: f32 = (osc - (g + k) * bp - lp) * a1;\n    const bpN: f32 = g * hp + bp; const lpN: f32 = g * bpN + lp; bp = bpN; lp = lpN;\n    let o: f32 = lpN * amp * out;\n    if (o > 1.4) o = 1.4; else if (o < -1.4) o = -1.4;\n    outBuf[i] = o; outBuf[MAX_FRAMES + i] = o;\n  }\n}\n",
  "publishedAt": 1751300000000
}