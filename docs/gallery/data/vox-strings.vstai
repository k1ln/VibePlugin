{
  "format": 1,
  "name": "Vox Strings",
  "isInstrument": true,
  "explanation": "A paraphonic string + voice ensemble. Every held note stacks three slightly detuned sawtooth strings against a breathy, formant-filtered choir 'aah' layer; the two blend, swell through a slow attack/release contour, and pour into a lush three-phase ensemble chorus that spreads the section across the stereo field. Controls: Strings Level, Voice Level, Ensemble, Attack, Release, Tone and Level.",
  "params": [
    {
      "name": "Strings Level",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Voice Level",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Ensemble",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Attack",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Release",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Tone",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Vox Strings</title>\n<style>\n  :root {\n    --accent: #d8b0e0;\n    --accent2: #a0c0ff;\n    --cream: #efe6d2;\n    --cream-2: #e2d4b6;\n    --wood: #3a2c22;\n    --panel: #2a2230;\n    --panel-2: #1c1722;\n    --ink: #efe7df;\n    --ink-dim: #b6a9c4;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: radial-gradient(120% 90% at 50% -10%, #322a3a 0%, #1a1520 60%, #120e18 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .shell {\n    max-width: 880px;\n    margin: 0 auto;\n    padding: 18px 16px 26px;\n  }\n\n  /* ---- the cabinet: a soft vintage tilt panel ---- */\n  .cabinet {\n    position: relative;\n    border-radius: 18px;\n    padding: 16px 18px 20px;\n    background:\n      linear-gradient(180deg, #36293f 0%, #2a2030 48%, #221a28 100%);\n    border: 1px solid rgba(216,176,224,0.18);\n    box-shadow:\n      0 30px 60px -20px rgba(0,0,0,0.7),\n      inset 0 1px 0 rgba(255,255,255,0.07),\n      inset 0 -2px 14px rgba(0,0,0,0.5);\n    transform: perspective(1400px) rotateX(2.2deg);\n  }\n\n  /* warm ensemble glow that breathes behind everything */\n  .glow {\n    position: absolute;\n    inset: -2px;\n    border-radius: 18px;\n    pointer-events: none;\n    background: radial-gradient(60% 50% at 50% 30%,\n      rgba(216,176,224,0.20), rgba(160,192,255,0.10) 45%, transparent 70%);\n    filter: blur(8px);\n    opacity: 0.5;\n    animation: breathe 7s ease-in-out infinite;\n  }\n  @keyframes breathe {\n    0%, 100% { opacity: 0.35; transform: scale(1.0); }\n    50%      { opacity: 0.62; transform: scale(1.03); }\n  }\n\n  /* ---- header / brand ---- */\n  .header {\n    display: flex;\n    align-items: flex-end;\n    justify-content: space-between;\n    gap: 14px;\n    margin-bottom: 12px;\n    position: relative;\n    z-index: 2;\n  }\n  .brand { display: flex; flex-direction: column; gap: 2px; }\n  .brand .kicker {\n    font-size: 10px;\n    letter-spacing: 0.42em;\n    text-transform: uppercase;\n    color: var(--accent2);\n    opacity: 0.85;\n  }\n  .brand h1 {\n    margin: 0;\n    font-size: 30px;\n    font-weight: 800;\n    letter-spacing: 0.02em;\n    line-height: 1;\n    background: linear-gradient(180deg, #fff, var(--accent) 70%, #c79ad2);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.3);\n  }\n  .badge {\n    font-size: 9px;\n    letter-spacing: 0.3em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    border: 1px solid rgba(216,176,224,0.25);\n    border-radius: 999px;\n    padding: 5px 11px;\n    background: rgba(0,0,0,0.2);\n  }\n\n  /* ---- the choir scene above the strings ---- */\n  .scene {\n    position: relative;\n    z-index: 2;\n    height: 132px;\n    border-radius: 12px;\n    overflow: hidden;\n    margin-bottom: 14px;\n    background:\n      linear-gradient(180deg, #241b2c 0%, #1a1422 55%, #15101c 100%);\n    border: 1px solid rgba(0,0,0,0.4);\n    box-shadow: inset 0 2px 18px rgba(0,0,0,0.6);\n  }\n  .scene svg { display: block; width: 100%; height: 100%; }\n\n  /* ---- control bays ---- */\n  .bays {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(7, 1fr);\n    gap: 10px;\n  }\n  @media (max-width: 660px) {\n    .bays { grid-template-columns: repeat(4, 1fr); }\n  }\n  .bay {\n    background: linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.18));\n    border: 1px solid rgba(216,176,224,0.10);\n    border-radius: 12px;\n    padding: 12px 6px 9px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 7px;\n  }\n  .knob-wrap { position: relative; width: 72px; height: 72px; cursor: ns-resize; }\n  .knob-wrap svg { width: 72px; height: 72px; display: block; }\n  .klabel {\n    font-size: 9px;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n  }\n  .kval {\n    font-size: 11px;\n    font-variant-numeric: tabular-nums;\n    color: var(--accent);\n    font-weight: 700;\n    letter-spacing: 0.02em;\n  }\n\n  /* ---- cream tabs row ---- */\n  .tabs {\n    position: relative;\n    z-index: 2;\n    display: flex;\n    gap: 6px;\n    margin: 14px 0 12px;\n    flex-wrap: wrap;\n  }\n  .tab {\n    font-size: 10px;\n    letter-spacing: 0.14em;\n    text-transform: uppercase;\n    padding: 7px 13px;\n    border-radius: 7px 7px 3px 3px;\n    color: #4a3a2c;\n    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);\n    border: 1px solid rgba(0,0,0,0.25);\n    box-shadow: 0 2px 0 rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.6);\n    cursor: pointer;\n    user-select: none;\n    font-weight: 700;\n    transition: transform .12s ease, box-shadow .12s ease, filter .12s ease;\n  }\n  .tab:hover { filter: brightness(1.05); }\n  .tab.on {\n    transform: translateY(2px);\n    box-shadow: 0 0 0 rgba(0,0,0,0.3),\n      inset 0 2px 5px rgba(0,0,0,0.35),\n      0 0 14px var(--accent);\n    background: linear-gradient(180deg, #f6ecd6, #ead9b4);\n  }\n\n  /* ---- keyboard ---- */\n  .kbd {\n    position: relative;\n    z-index: 2;\n    margin-top: 8px;\n    height: 110px;\n    border-radius: 8px;\n    background: linear-gradient(180deg, #100c16, #1a1420);\n    padding: 8px 8px 0;\n    box-shadow: inset 0 2px 10px rgba(0,0,0,0.6);\n    overflow: hidden;\n  }\n  .keys { position: relative; height: 100%; display: flex; }\n  .wkey {\n    position: relative;\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #f3ece0 0%, #d9cfbe 100%);\n    box-shadow: inset 0 -6px 8px rgba(0,0,0,0.12), 0 2px 3px rgba(0,0,0,0.4);\n    cursor: pointer;\n    transition: background .06s ease, box-shadow .06s ease;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent) 0%, #b890c6 100%);\n    box-shadow: inset 0 -3px 10px rgba(0,0,0,0.3), 0 0 16px var(--accent);\n  }\n  .bkeys {\n    position: absolute;\n    top: 8px;\n    left: 8px;\n    right: 8px;\n    height: 62%;\n    display: flex;\n    pointer-events: none;\n  }\n  .bkey {\n    position: absolute;\n    width: 5%;\n    height: 100%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #2a2230, #0d0a12);\n    box-shadow: 0 3px 4px rgba(0,0,0,0.6), inset 0 1px 0 rgba(255,255,255,0.08);\n    cursor: pointer;\n    pointer-events: auto;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent2), #5e76b0);\n    box-shadow: 0 0 16px var(--accent2);\n  }\n\n  .foot {\n    position: relative;\n    z-index: 2;\n    margin-top: 10px;\n    font-size: 9px;\n    letter-spacing: 0.16em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n    text-align: center;\n    opacity: 0.7;\n  }\n</style>\n</head>\n<body>\n<div class=\"shell\">\n  <div class=\"cabinet\">\n    <div class=\"glow\"></div>\n\n    <div class=\"header\">\n      <div class=\"brand\">\n        <div class=\"kicker\">Ensemble Instrument</div>\n        <h1>Vox Strings</h1>\n      </div>\n      <div class=\"badge\">Strings &middot; Voice</div>\n    </div>\n\n    <!-- choir mouths above a bowed string section -->\n    <div class=\"scene\">\n      <svg viewBox=\"0 0 800 132\" preserveAspectRatio=\"none\">\n        <defs>\n          <radialGradient id=\"head\" cx=\"50%\" cy=\"40%\" r=\"60%\">\n            <stop offset=\"0%\" stop-color=\"#3a3048\"/>\n            <stop offset=\"100%\" stop-color=\"#241c2e\"/>\n          </radialGradient>\n          <linearGradient id=\"str\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0%\" stop-color=\"#d8b0e0\"/>\n            <stop offset=\"100%\" stop-color=\"#a0c0ff\"/>\n          </linearGradient>\n        </defs>\n\n        <!-- four choir singers with animated \"aah\" mouths -->\n        <g id=\"choir\"></g>\n\n        <!-- bowed string section: vibrating strings -->\n        <g id=\"strings\"></g>\n      </svg>\n    </div>\n\n    <div class=\"bays\" id=\"bays\"></div>\n\n    <div class=\"tabs\" id=\"tabs\"></div>\n\n    <div class=\"kbd\">\n      <div class=\"keys\" id=\"whiteKeys\"></div>\n      <div class=\"bkeys\" id=\"blackKeys\"></div>\n    </div>\n\n    <div class=\"foot\">Drag knobs vertically &middot; double-click to reset &middot; play the keys</div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Strings\",  idx: 0, def: 0.70, fmt: pct },\n    { name: \"Voice\",    idx: 1, def: 0.55, fmt: pct },\n    { name: \"Ensemble\", idx: 2, def: 0.60, fmt: pct },\n    { name: \"Attack\",   idx: 3, def: 0.35, fmt: secAtk },\n    { name: \"Release\",  idx: 4, def: 0.45, fmt: secRel },\n    { name: \"Tone\",     idx: 5, def: 0.60, fmt: pct },\n    { name: \"Level\",    idx: 6, def: 0.70, fmt: pct }\n  ];\n\n  var values = PARAMS.map(function (p) { return p.def; });\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function secAtk(v) { return (0.005 + v * 2.0).toFixed(2) + \"s\"; }\n  function secRel(v) { return (0.02 + v * 2.5).toFixed(2) + \"s\"; }\n\n  // ---- host bridge ----\n  function pushParam(i) {\n    if (window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(PARAMS[i].idx, values[i]);\n    }\n  }\n  function pushAll() { for (var i = 0; i < PARAMS.length; i++) pushParam(i); }\n\n  // ============================================================\n  //  KNOBS — hand-drawn SVG, drag vertical, dbl-click reset, wheel\n  // ============================================================\n  var bays = document.getElementById(\"bays\");\n  var knobEls = [];\n\n  function makeKnob(i) {\n    var p = PARAMS[i];\n\n    var bay = document.createElement(\"div\");\n    bay.className = \"bay\";\n\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"knob-wrap\";\n\n    var NS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // outer dish\n    var dish = document.createElementNS(NS, \"circle\");\n    dish.setAttribute(\"cx\", \"50\"); dish.setAttribute(\"cy\", \"50\"); dish.setAttribute(\"r\", \"44\");\n    dish.setAttribute(\"fill\", \"#1a1420\");\n    dish.setAttribute(\"stroke\", \"rgba(216,176,224,0.18)\");\n    dish.setAttribute(\"stroke-width\", \"1.5\");\n    svg.appendChild(dish);\n\n    // track arc (background)\n    var track = document.createElementNS(NS, \"path\");\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(255,255,255,0.10)\");\n    track.setAttribute(\"stroke-width\", \"5\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    track.setAttribute(\"d\", arcPath(0));\n    svg.appendChild(track);\n\n    // value arc (accent)\n    var arc = document.createElementNS(NS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#kgrad)\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(arc);\n\n    // gradient for arc\n    var defs = document.createElementNS(NS, \"defs\");\n    var grad = document.createElementNS(NS, \"linearGradient\");\n    grad.setAttribute(\"id\", \"kgrad\" + i);\n    grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"0\");\n    grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"1\");\n    var s1 = document.createElementNS(NS, \"stop\");\n    s1.setAttribute(\"offset\", \"0%\"); s1.setAttribute(\"stop-color\", \"#d8b0e0\");\n    var s2 = document.createElementNS(NS, \"stop\");\n    s2.setAttribute(\"offset\", \"100%\"); s2.setAttribute(\"stop-color\", \"#a0c0ff\");\n    grad.appendChild(s1); grad.appendChild(s2);\n    defs.appendChild(grad);\n    svg.appendChild(defs);\n    arc.setAttribute(\"stroke\", \"url(#kgrad\" + i + \")\");\n\n    // cap\n    var cap = document.createElementNS(NS, \"circle\");\n    cap.setAttribute(\"cx\", \"50\"); cap.setAttribute(\"cy\", \"50\"); cap.setAttribute(\"r\", \"30\");\n    cap.setAttribute(\"fill\", \"#2c2336\");\n    cap.setAttribute(\"stroke\", \"rgba(0,0,0,0.5)\");\n    cap.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(cap);\n\n    // pointer notch\n    var notch = document.createElementNS(NS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"24\");\n    notch.setAttribute(\"stroke\", \"#f0e7df\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    wrap.appendChild(svg);\n\n    var label = document.createElement(\"div\");\n    label.className = \"klabel\";\n    label.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"kval\";\n\n    bay.appendChild(wrap);\n    bay.appendChild(label);\n    bay.appendChild(val);\n    bays.appendChild(bay);\n\n    var ref = { arc: arc, notch: notch, val: val };\n    knobEls.push(ref);\n\n    function arcPath(frac) {\n      // 270-degree sweep from -225deg to +45deg\n      var a0 = (-225) * Math.PI / 180;\n      var a1 = (-225 + 270 * frac) * Math.PI / 180;\n      var r = 40;\n      var x0 = 50 + r * Math.cos(a0), y0 = 50 + r * Math.sin(a0);\n      var x1 = 50 + r * Math.cos(a1), y1 = 50 + r * Math.sin(a1);\n      var large = (270 * frac) > 180 ? 1 : 0;\n      return \"M \" + x0.toFixed(2) + \" \" + y0.toFixed(2) +\n             \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n             x1.toFixed(2) + \" \" + y1.toFixed(2);\n    }\n    track.setAttribute(\"d\", arcPath(1));\n\n    function render() {\n      var v = values[i];\n      arc.setAttribute(\"d\", arcPath(v <= 0 ? 0.001 : v));\n      var ang = -225 + 270 * v;\n      notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n      val.textContent = p.fmt(v);\n    }\n    ref.render = render;\n    render();\n\n    // ---- interaction ----\n    var dragging = false, lastY = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      wrap.style.filter = \"drop-shadow(0 0 8px var(--accent))\";\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      values[i] = clamp01(values[i] + dy / 180);\n      render();\n      pushParam(i);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      wrap.style.filter = \"\";\n    }\n    wrap.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    wrap.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    wrap.addEventListener(\"dblclick\", function () {\n      values[i] = p.def; render(); pushParam(i);\n    });\n    wrap.addEventListener(\"wheel\", function (e) {\n      values[i] = clamp01(values[i] - e.deltaY / 1500);\n      render(); pushParam(i);\n      e.preventDefault();\n    }, { passive: false });\n  }\n\n  function clamp01(v) { return v < 0 ? 0 : (v > 1 ? 1 : v); }\n\n  for (var i = 0; i < PARAMS.length; i++) makeKnob(i);\n\n  // ============================================================\n  //  CREAM TABS — quick voicing presets (purely client-side macros)\n  // ============================================================\n  var TABS = [\n    { name: \"Strings\", set: { 0: 0.85, 1: 0.20, 2: 0.55, 5: 0.55 } },\n    { name: \"Choir\",   set: { 0: 0.20, 1: 0.85, 2: 0.65, 5: 0.62 } },\n    { name: \"Ensemble\", set: { 0: 0.70, 1: 0.60, 2: 0.92, 5: 0.6 } },\n    { name: \"Pad\",     set: { 0: 0.65, 1: 0.55, 2: 0.7, 3: 0.7, 4: 0.75, 5: 0.5 } }\n  ];\n  var tabsEl = document.getElementById(\"tabs\");\n  var tabEls = [];\n  TABS.forEach(function (t, ti) {\n    var el = document.createElement(\"div\");\n    el.className = \"tab\";\n    el.textContent = t.name;\n    el.addEventListener(\"click\", function () {\n      Object.keys(t.set).forEach(function (k) {\n        var idx = +k;\n        values[idx] = clamp01(t.set[k]);\n        knobEls[idx].render();\n        pushParam(idx);\n      });\n      tabEls.forEach(function (e) { e.classList.remove(\"on\"); });\n      el.classList.add(\"on\");\n    });\n    tabsEl.appendChild(el);\n    tabEls.push(el);\n  });\n\n  // ============================================================\n  //  KEYBOARD\n  // ============================================================\n  var WHITE = [60, 62, 64, 65, 67, 69, 71, 72, 74, 76, 77, 79, 81, 83]; // 2 octaves C4..\n  var BLACK = [ // { note, leftFraction }\n    { n: 61, after: 0 }, { n: 63, after: 1 },\n    { n: 66, after: 3 }, { n: 68, after: 4 }, { n: 70, after: 5 },\n    { n: 73, after: 7 }, { n: 75, after: 8 },\n    { n: 78, after: 10 }, { n: 80, after: 11 }, { n: 82, after: 12 }\n  ];\n\n  var whiteRow = document.getElementById(\"whiteKeys\");\n  var blackRow = document.getElementById(\"blackKeys\");\n  var keyEls = {};\n  var heldCount = 0;\n\n  WHITE.forEach(function (note) {\n    var k = document.createElement(\"div\");\n    k.className = \"wkey\";\n    bindKey(k, note);\n    whiteRow.appendChild(k);\n    keyEls[note] = k;\n  });\n\n  var whiteW = 100 / WHITE.length;\n  BLACK.forEach(function (b) {\n    var k = document.createElement(\"div\");\n    k.className = \"bkey\";\n    k.style.left = ((b.after + 1) * whiteW - 2.5) + \"%\";\n    bindKey(k, b.n);\n    blackRow.appendChild(k);\n    keyEls[b.n] = k;\n  });\n\n  function noteOn(note) {\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(note, 0.9);\n    if (keyEls[note]) keyEls[note].classList.add(\"down\");\n    heldCount++;\n    setSinging(true);\n  }\n  function noteOff(note) {\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(note);\n    if (keyEls[note]) keyEls[note].classList.remove(\"down\");\n    heldCount = Math.max(0, heldCount - 1);\n    if (heldCount === 0) setSinging(false);\n  }\n\n  function bindKey(el, note) {\n    var active = false;\n    function down(e) { if (!active) { active = true; noteOn(note); } e.preventDefault(); }\n    function up(e) { if (active) { active = false; noteOff(note); } if (e) e.preventDefault(); }\n    el.addEventListener(\"mousedown\", down);\n    el.addEventListener(\"mouseup\", up);\n    el.addEventListener(\"mouseleave\", up);\n    el.addEventListener(\"touchstart\", down, { passive: false });\n    el.addEventListener(\"touchend\", up, { passive: false });\n  }\n\n  // computer keyboard mapping (one octave)\n  var KEYMAP = { a:60, w:61, s:62, e:63, d:64, f:65, t:66, g:67,\n                 y:68, h:69, u:70, j:71, k:72, o:73, l:74 };\n  var keyDownMap = {};\n  window.addEventListener(\"keydown\", function (e) {\n    var n = KEYMAP[e.key];\n    if (n != null && !keyDownMap[n]) { keyDownMap[n] = true; noteOn(n); }\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var n = KEYMAP[e.key];\n    if (n != null && keyDownMap[n]) { keyDownMap[n] = false; noteOff(n); }\n  });\n\n  // ============================================================\n  //  SCENE — choir mouths + bowed strings, requestAnimationFrame\n  // ============================================================\n  var NS = \"http://www.w3.org/2000/svg\";\n  var choir = document.getElementById(\"choir\");\n  var strings = document.getElementById(\"strings\");\n  var mouths = [];\n  var stringPaths = [];\n\n  // four singers\n  var headX = [150, 330, 470, 650];\n  headX.forEach(function (cx, k) {\n    var g = document.createElementNS(NS, \"g\");\n\n    var head = document.createElementNS(NS, \"ellipse\");\n    head.setAttribute(\"cx\", cx); head.setAttribute(\"cy\", \"34\");\n    head.setAttribute(\"rx\", \"26\"); head.setAttribute(\"ry\", \"30\");\n    head.setAttribute(\"fill\", \"url(#head)\");\n    head.setAttribute(\"stroke\", \"rgba(216,176,224,0.3)\");\n    head.setAttribute(\"stroke-width\", \"1\");\n    g.appendChild(head);\n\n    // eyes\n    [-9, 9].forEach(function (dx) {\n      var eye = document.createElementNS(NS, \"circle\");\n      eye.setAttribute(\"cx\", cx + dx); eye.setAttribute(\"cy\", \"28\");\n      eye.setAttribute(\"r\", \"2.4\");\n      eye.setAttribute(\"fill\", \"rgba(160,192,255,0.85)\");\n      g.appendChild(eye);\n    });\n\n    // open \"aah\" mouth (ellipse that grows when singing)\n    var mouth = document.createElementNS(NS, \"ellipse\");\n    mouth.setAttribute(\"cx\", cx); mouth.setAttribute(\"cy\", \"46\");\n    mouth.setAttribute(\"rx\", \"7\"); mouth.setAttribute(\"ry\", \"3\");\n    mouth.setAttribute(\"fill\", \"#160f1c\");\n    mouth.setAttribute(\"stroke\", \"rgba(216,176,224,0.5)\");\n    mouth.setAttribute(\"stroke-width\", \"1\");\n    g.appendChild(mouth);\n    mouths.push({ el: mouth, cy: 46, phase: k * 0.8 });\n\n    choir.appendChild(g);\n  });\n\n  // bowed string section — 7 strings across the lower band\n  for (var s = 0; s < 7; s++) {\n    var y = 78 + s * 7.2;\n    var path = document.createElementNS(NS, \"path\");\n    path.setAttribute(\"fill\", \"none\");\n    path.setAttribute(\"stroke\", \"url(#str)\");\n    path.setAttribute(\"stroke-width\", (1.6 - s * 0.06).toFixed(2));\n    path.setAttribute(\"opacity\", (0.85 - s * 0.06).toFixed(2));\n    strings.appendChild(path);\n    stringPaths.push({ el: path, y: y, phase: s * 0.9, amp: 0 });\n  }\n\n  var singing = false;\n  var singAmt = 0; // eased 0..1\n  function setSinging(on) { singing = on; }\n\n  var t0 = performance.now();\n  function frame(now) {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    var t = (now - t0) / 1000;\n\n    // ease the \"singing\" intensity\n    var target = singing ? 1 : 0;\n    singAmt += (target - singAmt) * 0.08;\n\n    // animate choir mouths (vowel shaping)\n    for (var m = 0; m < mouths.length; m++) {\n      var mo = mouths[m];\n      var wob = 0.5 + 0.5 * Math.sin(t * 2.2 + mo.phase);\n      var ry = 3 + singAmt * (5 + 7 * wob);\n      var rx = 7 + singAmt * 3 * (1 - wob * 0.4);\n      mo.el.setAttribute(\"ry\", ry.toFixed(2));\n      mo.el.setAttribute(\"rx\", rx.toFixed(2));\n      mo.el.setAttribute(\"fill\", singAmt > 0.05\n        ? \"rgba(40,24,52,\" + (0.6 + 0.4 * singAmt) + \")\" : \"#160f1c\");\n    }\n\n    // animate vibrating strings (ensemble shimmer)\n    var ens = (values[2] || 0);\n    for (var i2 = 0; i2 < stringPaths.length; i2++) {\n      var sp = stringPaths[i2];\n      var amp = (1.5 + ens * 5) * (0.3 + singAmt);\n      var freqMod = 1 + ens * 0.6;\n      var d = \"M 40 \" + sp.y;\n      var steps = 16;\n      for (var x = 1; x <= steps; x++) {\n        var px = 40 + (720 * x / steps);\n        var ph = (x / steps) * Math.PI * (3 + i2 * 0.4);\n        var py = sp.y + Math.sin(t * (5 + i2) * freqMod + sp.phase + ph) * amp\n                  * Math.sin(Math.PI * x / steps);\n        d += \" L \" + px.toFixed(1) + \" \" + py.toFixed(2);\n      }\n      sp.el.setAttribute(\"d\", d);\n    }\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ============================================================\n  //  INIT — push all defaults once the host is ready\n  // ============================================================\n  function start() {\n    pushAll();\n    for (var i = 0; i < knobEls.length; i++) knobEls[i].render();\n  }\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(start);\n  } else {\n    start();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  VOX STRINGS — a paraphonic STRING + VOICE ensemble instrument.\n//  Inspired by the classic 1970s string/voice ensemble keyboards: each\n//  held note runs a stack of detuned sawtooth \"strings\" PLUS a breathy\n//  formant-filtered \"choir aah\" voice layer. The two layers are blended,\n//  shaped by a slow attack/release envelope, then poured through a lush\n//  three-phase BBD-style ENSEMBLE chorus to spread the section across the\n//  stereo field. Pure algorithm, no samples, no host imports.\n//\n//  Host passes frequency in Hz to noteOn(id, freq, vel); noteOff(id).\n//  Paraphonic: every voice shares the same envelope/filter character but\n//  tracks its own pitch, so a held chord blooms into a full choir+strings\n//  pad. All math is f32 (Mathf.*), no allocation inside process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_STRINGS: i32 = 0;  // 0..1  -> sawtooth string layer level\nconst P_VOICE:   i32 = 1;  // 0..1  -> formant choir \"aah\" layer level\nconst P_ENSEMBLE: i32 = 2; // 0..1  -> ensemble chorus depth / width\nconst P_ATTACK:  i32 = 3;  // 0..1  -> slow attack seconds\nconst P_RELEASE: i32 = 4;  // 0..1  -> slow release seconds\nconst P_TONE:    i32 = 5;  // 0..1  -> master brightness (low-pass)\nconst P_LEVEL:   i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// per-note slow AR envelope (paraphonic — one contour per voice)\nconst vEnv:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vStage:  StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 sustain 3 rel\n\n// each voice stacks THREE slightly detuned sawtooths for the string body\nconst vP1a: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vP1b: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vP1c: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n// plus one phase for the voice/choir source (a softer pulse-ish glottal tone)\nconst vP2:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// ---- formant band-pass state for the choir \"aah\" vowel --------------\n// Two resonant band-passes (state-variable) shape a broadband source into\n// the two dominant formants of an \"ah\" vowel (~750 Hz and ~1150 Hz). One\n// shared bank processes the SUMMED voice-layer source (paraphonic).\nlet f1Lo: f32 = 0.0; let f1Bp: f32 = 0.0;\nlet f2Lo: f32 = 0.0; let f2Bp: f32 = 0.0;\n\n// ---- gentle breath noise for the choir air --------------------------\nlet noiseState: i32 = 0x1a2b3c4d;\n\n// ---- master tone one-pole low-pass (stereo) -------------------------\nlet toneL: f32 = 0.0; let toneR: f32 = 0.0;\n\n// ---- ENSEMBLE chorus: 3 modulated delay taps, BBD-style -------------\nconst DELAY_LEN: i32 = 2048; // ~42 ms at 48k — plenty for chorus\nconst dlyL: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nconst dlyR: StaticArray<f32> = new StaticArray<f32>(DELAY_LEN);\nlet dlyPos: i32 = 0;\n// three LFO phases at mutually detuned slow rates (the classic 3-phase ensemble)\nlet lfo1: f32 = 0.0;\nlet lfo2: f32 = 0.33;\nlet lfo3: f32 = 0.66;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vEnv[v] = 0.0; vStage[v] = 0;\n    vP1a[v] = 0.0; vP1b[v] = 0.0; vP1c[v] = 0.0; vP2[v] = 0.0;\n  }\n  ageCounter = 0;\n  f1Lo = 0.0; f1Bp = 0.0; f2Lo = 0.0; f2Bp = 0.0;\n  noiseState = 0x1a2b3c4d;\n  toneL = 0.0; toneR = 0.0;\n  for (let i = 0; i < DELAY_LEN; i++) { dlyL[i] = 0.0; dlyR[i] = 0.0; }\n  dlyPos = 0;\n  lfo1 = 0.0; lfo2 = 0.33; lfo3 = 0.66;\n\n  params[P_STRINGS]  = 0.7;\n  params[P_VOICE]    = 0.55;\n  params[P_ENSEMBLE] = 0.6;\n  params[P_ATTACK]   = 0.35;\n  params[P_RELEASE]  = 0.45;\n  params[P_TONE]     = 0.6;\n  params[P_LEVEL]    = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fast deterministic white noise in [-1,1] for the breath layer\n@inline function nextNoise(): f32 {\n  noiseState ^= noiseState << 13;\n  noiseState ^= noiseState >> 17;\n  noiseState ^= noiseState << 5;\n  return f32(noiseState) * f32(4.6566128e-10); // /2^31\n}\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vStage[slot]  = 1;   // attack\n  // offset the three string phases so the detuned saws never phase-lock\n  vP1a[slot] = 0.0;\n  vP1b[slot] = 0.37;\n  vP1c[slot] = 0.71;\n  vP2[slot]  = 0.15;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vStage[i] = 3;  // release\n    }\n  }\n}\n\n// linearly read the delay line at a fractional sample offset behind dlyPos\n@inline function readDelay(buf: StaticArray<f32>, delay: f32): f32 {\n  let rp: f32 = f32(dlyPos) - delay;\n  while (rp < 0.0) rp += f32(DELAY_LEN);\n  const i0: i32 = i32(rp);\n  let i1: i32 = i0 + 1; if (i1 >= DELAY_LEN) i1 -= DELAY_LEN;\n  const frac: f32 = rp - f32(i0);\n  const a: f32 = buf[i0];\n  const b: f32 = buf[i1];\n  return f32(a + (b - a) * frac);\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const strLvl: f32 = clampf(params[P_STRINGS], 0.0, 1.0);\n  const voxLvl: f32 = clampf(params[P_VOICE], 0.0, 1.0);\n  const ensN:   f32 = clampf(params[P_ENSEMBLE], 0.0, 1.0);\n  const atkN:   f32 = clampf(params[P_ATTACK], 0.0, 1.0);\n  const relN:   f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const outLvl: f32 = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  // slow attack/release (string-machine character): 5 ms .. ~2 s\n  const atkS: f32 = 0.005 + atkN * 2.0;\n  const relS: f32 = 0.02 + relN * 2.5;\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // detune spread for the three stacked saws (cents -> ratio)\n  const detUp:   f32 = f32(Mathf.pow(2.0,  6.5 / 1200.0));  // +6.5 cents\n  const detDown: f32 = f32(Mathf.pow(2.0, -7.0 / 1200.0));  // -7.0 cents\n\n  // master tone low-pass: 1.2 kHz .. ~14 kHz\n  const toneHz: f32 = 1200.0 + toneN * toneN * 12800.0;\n  let toneG: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * toneHz / sr));\n  if (toneG > 0.99) toneG = 0.99;\n\n  // formant band-pass coefficients (two \"ah\" formants), state-variable filter\n  const fHz1: f32 = 750.0;\n  const fHz2: f32 = 1150.0;\n  const fF1: f32 = 2.0 * f32(Mathf.sin(PI * fHz1 / sr));\n  const fF2: f32 = 2.0 * f32(Mathf.sin(PI * fHz2 / sr));\n  const fQ: f32 = 0.18; // damping (lower = more resonant/vowel-like)\n\n  // ensemble chorus: depth in samples and slow LFO increments\n  const depth: f32 = ensN * 9.0;          // up to ~9 samples modulation\n  const baseDelay: f32 = 12.0;            // ~0.25 ms center tap\n  const wet: f32 = 0.25 + ensN * 0.55;    // chorus presence\n  const inc1: f32 = 0.50 / sr;            // 0.50 Hz\n  const inc2: f32 = 0.71 / sr;            // 0.71 Hz\n  const inc3: f32 = 0.93 / sr;            // 0.93 Hz\n\n  // headroom: 8 voices x (strings+voice) summed -> keep peak < 1\n  const voiceScale: f32 = 0.16;\n\n  for (let f = 0; f < n; f++) {\n    let strSum: f32 = 0.0;   // summed string (saw stack) layer\n    let voxSum: f32 = 0.0;   // summed voice glottal source\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- slow AR envelope -------------------------------------\n      let env: f32 = vEnv[v];\n      let stg: i32 = vStage[v];\n      if (stg == 1) {              // attack\n        env += atkRate;\n        if (env >= 1.0) { env = 1.0; stg = 2; }\n      } else if (stg == 2) {       // sustain (held)\n        env = 1.0;\n      } else if (stg == 3) {       // release\n        env -= relRate;\n        if (env <= 0.0) { env = 0.0; stg = 0; }\n      }\n      vEnv[v] = env;\n      vStage[v] = stg;\n\n      if (stg == 0 && env <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      const amp: f32 = env * (0.5 + 0.5 * vVel[v]);\n      const baseInc: f32 = vFreq[v] / sr;\n\n      // ---- STRING layer: three detuned sawtooths ----------------\n      let a: f32 = vP1a[v]; a += baseInc;         if (a >= 1.0) a -= 1.0; vP1a[v] = a;\n      let b: f32 = vP1b[v]; b += baseInc * detUp; if (b >= 1.0) b -= 1.0; vP1b[v] = b;\n      let c: f32 = vP1c[v]; c += baseInc * detDown; if (c >= 1.0) c -= 1.0; vP1c[v] = c;\n      const saw: f32 = ((a * 2.0 - 1.0) + (b * 2.0 - 1.0) + (c * 2.0 - 1.0)) * f32(0.3333333);\n      strSum += saw * amp;\n\n      // ---- VOICE layer source: narrow pulse ~ glottal buzz -------\n      let p2: f32 = vP2[v]; p2 += baseInc; if (p2 >= 1.0) p2 -= 1.0; vP2[v] = p2;\n      // asymmetric pulse rich in harmonics -> good formant excitation\n      const glott: f32 = p2 < 0.18 ? 1.0 : -0.22;\n      voxSum += glott * amp;\n    }\n\n    // ---- choir \"aah\": formant band-passes on the summed source ----\n    // add a touch of breath noise (only matters when notes sound)\n    const breath: f32 = nextNoise() * 0.06;\n    const src: f32 = voxSum * 0.5 + breath * (voxSum != 0.0 ? 1.0 : 0.0);\n\n    // state-variable band-pass 1\n    f1Bp += fF1 * (src - f1Lo - fQ * f1Bp);\n    f1Lo += fF1 * f1Bp;\n    // band-pass 2\n    f2Bp += fF2 * (src - f2Lo - fQ * f2Bp);\n    f2Lo += fF2 * f2Bp;\n    // formant mix (\"ah\": F1 stronger than F2)\n    const vowel: f32 = f1Bp * 0.75 + f2Bp * 0.45;\n\n    // ---- blend the two layers -------------------------------------\n    let mono: f32 = strSum * strLvl + vowel * voxLvl * 1.4;\n    mono *= voiceScale;\n    // gentle saturation glues the section\n    mono = f32(Mathf.tanh(mono * 2.2));\n\n    // ---- write into the ensemble delay lines ----------------------\n    dlyL[dlyPos] = mono;\n    dlyR[dlyPos] = mono;\n\n    // ---- ENSEMBLE chorus: 3 phases, spread L/R --------------------\n    lfo1 += inc1; if (lfo1 >= 1.0) lfo1 -= 1.0;\n    lfo2 += inc2; if (lfo2 >= 1.0) lfo2 -= 1.0;\n    lfo3 += inc3; if (lfo3 >= 1.0) lfo3 -= 1.0;\n    const m1: f32 = f32(Mathf.sin(TWO_PI * lfo1));\n    const m2: f32 = f32(Mathf.sin(TWO_PI * lfo2));\n    const m3: f32 = f32(Mathf.sin(TWO_PI * lfo3));\n\n    const d1: f32 = baseDelay + depth * (1.0 + m1);\n    const d2: f32 = baseDelay + depth * (1.0 + m2);\n    const d3: f32 = baseDelay + depth * (1.0 + m3);\n\n    // L favours taps 1 & 3, R favours taps 2 & 3 -> wide stereo image\n    const chL: f32 = readDelay(dlyL, d1) * 0.6 + readDelay(dlyL, d3) * 0.5;\n    const chR: f32 = readDelay(dlyR, d2) * 0.6 + readDelay(dlyR, d3) * 0.5;\n\n    dlyPos++; if (dlyPos >= DELAY_LEN) dlyPos = 0;\n\n    let oL: f32 = mono * (1.0 - wet) + chL * wet;\n    let oR: f32 = mono * (1.0 - wet) + chR * wet;\n\n    // ---- master tone low-pass -------------------------------------\n    toneL += toneG * (oL - toneL); oL = toneL;\n    toneR += toneG * (oR - toneR); oR = toneR;\n\n    // ---- output level + safety clamp ------------------------------\n    oL *= outLvl * 1.3;\n    oR *= outLvl * 1.3;\n    if (oL > 1.0) oL = 1.0; else if (oL < -1.0) oL = -1.0;\n    if (oR > 1.0) oR = 1.0; else if (oR < -1.0) oR = -1.0;\n\n    outBuf[f] = oL;\n    outBuf[MAX_FRAMES + f] = oR;\n  }\n}\n",
  "publishedAt": 1751000076000
}