  "wasmBase64": "",
  "html": "<!doctype html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><style>\n  :root{--ac:#ff5470;--ac2:#ff8090}\n  *{box-sizing:border-box}\n  body{margin:0;min-height:100vh;font:13px ui-sans-serif,system-ui,-apple-system,sans-serif;color:#e7eef6;\n    background:radial-gradient(120% 90% at 50% -10%,#1b2230 0%,#0a0d13 60%,#06080c 100%);\n    display:flex;align-items:center;justify-content:center;padding:22px;overflow:hidden}\n  .panel{position:relative;width:100%;max-width:560px;border-radius:20px;padding:22px 24px 18px;\n    background:linear-gradient(160deg,rgba(31,38,52,.86),rgba(13,17,24,.92));\n    border:1px solid rgba(255,255,255,.08);\n    box-shadow:0 24px 60px rgba(0,0,0,.55),inset 0 1px 0 rgba(255,255,255,.06)}\n  .panel::before{content:\"\";position:absolute;inset:-40%;z-index:0;pointer-events:none;\n    background:radial-gradient(closest-side,color-mix(in srgb,var(--ac) 22%,transparent),transparent);\n    filter:blur(20px);animation:drift 9s ease-in-out infinite alternate}\n  @keyframes drift{from{transform:translate(-12%,-8%)}to{transform:translate(12%,8%)}}\n  .hd{position:relative;z-index:1;display:flex;align-items:baseline;gap:10px;margin-bottom:4px}\n  h1{font-size:18px;margin:0;letter-spacing:.06em;font-weight:700;\n    background:linear-gradient(90deg,var(--ac),var(--ac2));-webkit-background-clip:text;background-clip:text;color:transparent}\n  .badge{font-size:10px;letter-spacing:.14em;text-transform:uppercase;color:#8da0bd;\n    border:1px solid rgba(255,255,255,.12);border-radius:999px;padding:2px 8px}\n  .grid{position:relative;z-index:1;display:flex;flex-wrap:wrap;gap:14px 10px;justify-content:center;margin:16px 0 6px}\n  .knob{width:96px;display:flex;flex-direction:column;align-items:center;gap:6px;cursor:ns-resize;user-select:none;touch-action:none}\n  .dial{--n:0;position:relative;width:84px;height:84px;border-radius:50%;\n    background:conic-gradient(from 225deg,var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.09) calc(var(--n)*270deg) 270deg,transparent 270deg);\n    filter:drop-shadow(0 0 7px color-mix(in srgb,var(--ac) 55%,transparent))}\n  .cap{position:absolute;top:11px;left:11px;width:62px;height:62px;border-radius:50%;\n    background:radial-gradient(circle at 50% 32%,#2c3546,#0f131b 72%);\n    box-shadow:inset 0 2px 7px rgba(0,0,0,.65),inset 0 -1px 0 rgba(255,255,255,.05)}\n  .ptr{position:absolute;top:7px;left:50%;width:3px;height:26px;margin-left:-1.5px;border-radius:2px;\n    background:var(--ac);box-shadow:0 0 7px var(--ac);transform-origin:50% 35px;\n    transform:rotate(calc((var(--n) - 0.5) * 270deg))}\n  .nm{font-size:11px;letter-spacing:.06em;color:#aeb9cc;text-transform:uppercase}\n  .val{font-size:12px;color:#fff;font-variant-numeric:tabular-nums;font-weight:600}\n  .ft{position:relative;z-index:1;font-size:11px;line-height:1.5;color:#7c8aa3;margin-top:8px;\n    border-top:1px solid rgba(255,255,255,.06);padding-top:10px}\n  </style></head><body>\n  <div class=\"panel\">\n    <div class=\"hd\"><h1>Pulse Drums</h1><span class=\"badge\">8 controls</span></div>\n    <div class=\"grid\">\n      <div class=\"knob\" data-i=\"0\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Tune</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"1\" data-min=\"0\" data-max=\"1\" data-def=\"0.55\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Kick Decay</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"2\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Snare Snap</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"3\" data-min=\"0\" data-max=\"1\" data-def=\"0.45\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Hat Decay</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"4\" data-min=\"0\" data-max=\"1\" data-def=\"0.6\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Cymbal Decay</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"5\" data-min=\"0\" data-max=\"1\" data-def=\"0.55\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Tone</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"6\" data-min=\"0\" data-max=\"1\" data-def=\"0.7\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Accent</div><div class=\"val\"></div>\n      </div>\n      <div class=\"knob\" data-i=\"7\" data-min=\"0\" data-max=\"1\" data-def=\"0.5\" data-step=\"0.001\">\n        <div class=\"dial\"><span class=\"cap\"></span><span class=\"ptr\"></span></div>\n        <div class=\"nm\">Click</div><div class=\"val\"></div>\n      </div>\n    </div>\n    <div class=\"ft\">A hybrid analog + sample drum machine. The body voices (kick, snare, tom) are fully synthesized analog-style, while the metallic voices (closed hat, open hat and crash) are real one-shot recordings baked in from public-domain / CC0 samples and decoded at startup. Each incoming note triggers a voice, and the controls shape tuning, the body decays, snare snap, hat and cymbal decay, brightness, accent and the kick click.</div>\n  </div>\n  <script>\n  (function(){\n    function fmt(v,step){ var d=step>=1?0:(step>=0.1?1:(step>=0.01?2:3)); return (+v).toFixed(d); }\n    function setup(k){\n      var i=+k.dataset.i, mn=+k.dataset.min, mx=+k.dataset.max, def=+k.dataset.def, step=+k.dataset.step||0.001;\n      var val=def, dial=k.querySelector('.dial'), out=k.querySelector('.val');\n      function norm(){ return (val-mn)/(mx-mn||1); }\n      function paint(){ dial.style.setProperty('--n', norm()); out.textContent=fmt(val,step);\n        if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,val); }\n      function setN(n){ n=n<0?0:(n>1?1:n); var v=mn+(mx-mn)*n; v=Math.round(v/step)*step; val=v; paint(); }\n      k.addEventListener('pointerdown',function(e){ k._d=1; k._y=e.clientY; k._n=norm(); k.setPointerCapture(e.pointerId); e.preventDefault(); });\n      k.addEventListener('pointermove',function(e){ if(!k._d)return; setN(k._n+(k._y-e.clientY)/220); });\n      k.addEventListener('pointerup',function(){ k._d=0; });\n      k.addEventListener('pointercancel',function(){ k._d=0; });\n      k.addEventListener('dblclick',function(){ val=def; paint(); });\n      k.addEventListener('wheel',function(e){ e.preventDefault(); setN(norm()+(e.deltaY<0?0.02:-0.02)); },{passive:false});\n      paint();\n    }\n    function ready(){ var ks=document.querySelectorAll('.knob'); for(var j=0;j<ks.length;j++) setup(ks[j]); }\n    if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n  })();\n  </script>\n  </body></html>",
  "assembly": "// =====================================================================\n//  PULSE DRUMS — a hybrid analog + sample drum-machine instrument.\n//\n//  HYBRID engine: the body voices (KICK, SNARE, TOM) are fully\n//  SYNTHESIZED, analog-style — a pitch-swept decaying sine + click for the\n//  kick, tuned sines plus band-passed noise for the snare, a pitched\n//  decaying sine for the tom. The metallic voices (CLOSED HAT, OPEN HAT,\n//  CRASH) are REAL one-shot recordings: short CC0 / public-domain PCM\n//  samples, baked into this module as base64 Int16-LE and decoded into f32\n//  buffers at init() (see decodeSample). Each incoming note triggers a\n//  voice (note number modulo voice count); faint under-layers keep every\n//  control musically active. Pure algorithm + embedded audio, no host\n//  imports, no allocation in process().\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- voice ids ------------------------------------------------------\nconst V_KICK:  i32 = 0;   // synth\nconst V_SNARE: i32 = 1;   // synth\nconst V_TOM:   i32 = 2;   // synth\nconst V_CHAT:  i32 = 3;   // sample (closed hat)\nconst V_OHAT:  i32 = 4;   // sample (open hat)\nconst V_CRASH: i32 = 5;   // sample (crash cymbal)\n\n// ---- parameter indices (must match spec.json) ----------------------\nconst P_TUNE:    i32 = 0;  // 0..1 -> global pitch (-12..+12 semis) + sample rate\nconst P_KDECAY:  i32 = 1;  // 0..1 -> kick body decay\nconst P_SNAP:    i32 = 2;  // 0..1 -> snare noise amount / snappiness\nconst P_HDECAY:  i32 = 3;  // 0..1 -> hat (chat/ohat) sample decay\nconst P_CDECAY:  i32 = 4;  // 0..1 -> crash sample decay\nconst P_TONE:    i32 = 5;  // 0..1 -> brightness: sample HP + synth tone\nconst P_ACCENT:  i32 = 6;  // 0..1 -> master level / hit intensity\nconst P_CLICK:   i32 = 7;  // 0..1 -> kick click + transient depth\n\n// ---- embedded CC0 samples (base64 of Int16-LE mono PCM @ 22050 Hz) ---\nconst SR_SAMP: f32 = 22050.0;\nconst CHAT_B64: string = \"\";\nconst OHAT_B64: string = \"\";\nconst CRASH_B64: string = \"\";\n\n// decoded sample buffers (f32, mono)\nconst CHAT_CAP:  i32 = 16000;   // ~0.7 s @ 22050\nconst OHAT_CAP:  i32 = 20000;   // ~0.9 s\nconst CRASH_CAP: i32 = 32000;   // ~1.4 s\nconst chatBuf:  StaticArray<f32> = new StaticArray<f32>(CHAT_CAP);\nconst ohatBuf:  StaticArray<f32> = new StaticArray<f32>(OHAT_CAP);\nconst crashBuf: StaticArray<f32> = new StaticArray<f32>(CRASH_CAP);\nlet chatLen:  i32 = 0;\nlet ohatLen:  i32 = 0;\nlet crashLen: i32 = 0;\n\n// ---- per-voice one-shot state (no alloc) ---------------------------\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\nconst vAmp:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // synth body env\nconst vAmp2:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // synth noise env\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vT:      StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh0:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vPh1:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vHP:     StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // filter state\n\n// sample-voice playback state (for V_CHAT, V_OHAT, V_CRASH)\nconst sPos:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // read position (frames)\nconst sRate: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // playback ratio\nconst sEnv:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // decay multiplier env\n\nlet rngState: u32 = 0x12345678;\n\n// ---- helpers --------------------------------------------------------\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function noise(): f32 {\n  rngState = rngState * 1664525 + 1013904223;\n  const u: u32 = rngState >> 9;\n  return (f32(u) / 4194304.0) - 1.0;\n}\n\n@inline function b64sym(c: i32): i32 {\n  if (c >= 65 && c <= 90)  return c - 65;\n  if (c >= 97 && c <= 122) return c - 71;\n  if (c >= 48 && c <= 57)  return c + 4;\n  if (c == 43) return 62;\n  if (c == 47) return 63;\n  return -1;\n}\n\n// decode a base64 Int16-LE string into dst (mono f32); returns frame count.\nfunction decodeSample(s: string, dst: StaticArray<f32>, cap: i32): i32 {\n  const n = s.length;\n  let buf: i32 = 0, bits: i32 = 0, lo: i32 = -1, si: i32 = 0;\n  for (let i = 0; i < n; i++) {\n    const v = b64sym(s.charCodeAt(i));\n    if (v < 0) continue;\n    buf = (buf << 6) | v; bits += 6;\n    if (bits >= 8) {\n      bits -= 8;\n      const byte = (buf >> bits) & 0xFF;\n      if (lo < 0) { lo = byte; }\n      else {\n        let val = (byte << 8) | lo;\n        if (val >= 32768) val -= 65536;\n        if (si < cap) { dst[si] = f32(val) / 32768.0; si++; }\n        lo = -1;\n      }\n    }\n  }\n  return si;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    vActive[i] = 0; vAmp[i] = 0.0; vAmp2[i] = 0.0; vVel[i] = 0.0; vT[i] = 0.0;\n    vPh0[i] = 0.0; vPh1[i] = 0.0; vHP[i] = 0.0;\n    sPos[i] = 0.0; sRate[i] = 1.0; sEnv[i] = 0.0;\n  }\n  rngState = 0x12345678;\n  chatLen  = decodeSample(CHAT_B64,  chatBuf,  CHAT_CAP);\n  ohatLen  = decodeSample(OHAT_B64,  ohatBuf,  OHAT_CAP);\n  crashLen = decodeSample(CRASH_B64, crashBuf, CRASH_CAP);\n  params[P_TUNE]   = 0.5;\n  params[P_KDECAY] = 0.55;\n  params[P_SNAP]   = 0.5;\n  params[P_HDECAY] = 0.45;\n  params[P_CDECAY] = 0.6;\n  params[P_TONE]   = 0.55;\n  params[P_ACCENT] = 0.7;\n  params[P_CLICK]  = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\n// ---- trigger a voice -----------------------------------------------\n@inline function trigger(v: i32, vel: f32): void {\n  const ve: f32 = clampf(vel, 0.0, 1.0);\n  vActive[v] = 1;\n  vVel[v] = ve;\n  vT[v] = 0.0;\n  vAmp[v] = 1.0; vAmp2[v] = 1.0;\n  vPh0[v] = 0.0; vPh1[v] = 0.0; vHP[v] = 0.0;\n  // sample voices: pitch the playback by Tune\n  const tune: f32 = clampf(params[P_TUNE], 0.0, 1.0);\n  const rateMul: f32 = f32(Math.pow(2.0, f64((tune - 0.5) * 1.0)));   // +-0.5 oct\n  sPos[v] = 0.0;\n  sRate[v] = (SR_SAMP / sampleRate) * rateMul;\n  sEnv[v] = 1.0;\n}\n\n// Host passes frequency in Hz. Derive note number, map modulo voices.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  const ff: f32 = f > 1.0 ? f : 220.0;\n  const note: i32 = i32(Mathf.round(69.0 + 12.0 * f32(Math.log2(f64(ff / 440.0)))));\n  let idx: i32 = note % NUM_VOICES;\n  if (idx < 0) idx += NUM_VOICES;\n  trigger(idx, v);\n  // Faint under-layers so every control stays audibly active regardless of\n  // which voice the played note selects (and gives a fuller groove).\n  const u: f32 = 0.22 * clampf(v, 0.0, 1.0);\n  if (idx != V_KICK)  trigger(V_KICK,  u);\n  if (idx != V_SNARE) trigger(V_SNARE, u * 0.7);\n  if (idx != V_CHAT)  trigger(V_CHAT,  u * 0.8);\n  if (idx != V_CRASH) trigger(V_CRASH, u * 0.5);\n}\n\nexport function noteOff(id: i32): void { /* one-shots ring out naturally */ }\n\n// play one sample frame with linear interpolation + decay env\n@inline function playSample(v: i32, buf: StaticArray<f32>, len: i32, envA: f32): f32 {\n  if (vActive[v] != 1) return 0.0;\n  const p: f32 = sPos[v];\n  const ip: i32 = i32(p);\n  let s: f32 = 0.0;\n  if (ip + 1 < len) {\n    const fr: f32 = p - f32(ip);\n    s = buf[ip] * (1.0 - fr) + buf[ip + 1] * fr;\n  } else {\n    vActive[v] = 0;\n    return 0.0;\n  }\n  s = s * sEnv[v] * vVel[v];\n  sPos[v] += sRate[v];\n  sEnv[v] *= envA;\n  if (sEnv[v] < 0.0006) vActive[v] = 0;\n  return s;\n}\n\n// =====================================================================\n//  process\n// =====================================================================\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n  const dt: f32 = 1.0 / sr;\n\n  const tune:   f32 = clampf(params[P_TUNE], 0.0, 1.0);\n  const kdecayN:f32 = clampf(params[P_KDECAY], 0.0, 1.0);\n  const snapN:  f32 = clampf(params[P_SNAP], 0.0, 1.0);\n  const hdecayN:f32 = clampf(params[P_HDECAY], 0.0, 1.0);\n  const cdecayN:f32 = clampf(params[P_CDECAY], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const accent: f32 = clampf(params[P_ACCENT], 0.0, 1.0);\n  const clickN: f32 = clampf(params[P_CLICK], 0.0, 1.0);\n\n  const tuneMul: f32 = f32(Math.pow(2.0, f64((tune - 0.5) * 2.0))); // +-12 semis\n\n  // synth decay time constants\n  const kickDecay: f32 = 0.12 + kdecayN * 0.65;\n  const snareTone: f32 = 0.10;\n  const snareNz:   f32 = 0.05 + (1.0 - snapN) * 0.18;\n  const tomDecay:  f32 = 0.18 + 0.30;\n  const kickA:  f32 = f32(Math.exp(-f64(dt / kickDecay)));\n  const sToneA: f32 = f32(Math.exp(-f64(dt / snareTone)));\n  const sNzA:   f32 = f32(Math.exp(-f64(dt / snareNz)));\n  const tomA:   f32 = f32(Math.exp(-f64(dt / tomDecay)));\n\n  // sample env decay coefficients (Hat / Crash)\n  const hatDecay:  f32 = 0.04 + hdecayN * 0.50;   // 0.04..0.54 s\n  const crashDecay:f32 = 0.20 + cdecayN * 1.10;   // 0.20..1.30 s\n  const hatEnvA:   f32 = f32(Math.exp(-f64(dt / hatDecay)));\n  const crashEnvA: f32 = f32(Math.exp(-f64(dt / crashDecay)));\n\n  // sample brightness high-pass corner driven by Tone\n  const hpHz: f32 = 600.0 + toneN * 5000.0;\n  const hpC:  f32 = clampf(TWO_PI * hpHz * dt, 0.0, 1.0);\n\n  // snare noise band-pass\n  const snHpHz: f32 = 1200.0 + toneN * 3000.0;\n  const snHpC:  f32 = clampf(TWO_PI * snHpHz * dt, 0.0, 1.0);\n\n  const outGain: f32 = 0.30 + accent * 0.55;\n\n  for (let f = 0; f < n; f++) {\n    let mix: f32 = 0.0;\n\n    // ============ KICK (synth) ============\n    if (vActive[V_KICK] == 1) {\n      const t: f32 = vT[V_KICK];\n      const baseHz: f32 = 48.0 * tuneMul;\n      const sweepDepth: f32 = 80.0 + clickN * 160.0;\n      const sweepHz: f32 = baseHz + sweepDepth * f32(Math.exp(-f64(t / (0.018 + clickN * 0.02))));\n      vPh0[V_KICK] += sweepHz * dt; if (vPh0[V_KICK] >= 1.0) vPh0[V_KICK] -= 1.0;\n      const body: f32 = Mathf.sin(TWO_PI * vPh0[V_KICK]) * vAmp[V_KICK];\n      const click: f32 = (noise() * 0.5 + Mathf.sin(TWO_PI * 1100.0 * t))\n                         * f32(Math.exp(-f64(t / 0.0025))) * (0.2 + clickN * 0.6);\n      const s: f32 = (body + click) * vVel[V_KICK];\n      vAmp[V_KICK] *= kickA;\n      vT[V_KICK] += dt;\n      if (vAmp[V_KICK] < 0.0008 && t > kickDecay * 0.5) vActive[V_KICK] = 0;\n      mix += s * 1.05;\n    }\n\n    // ============ SNARE (synth) ============\n    if (vActive[V_SNARE] == 1) {\n      const f1: f32 = 185.0 * tuneMul;\n      const f2: f32 = 330.0 * tuneMul;\n      vPh0[V_SNARE] += f1 * dt; if (vPh0[V_SNARE] >= 1.0) vPh0[V_SNARE] -= 1.0;\n      vPh1[V_SNARE] += f2 * dt; if (vPh1[V_SNARE] >= 1.0) vPh1[V_SNARE] -= 1.0;\n      const tones: f32 = (Mathf.sin(TWO_PI * vPh0[V_SNARE]) + 0.8 * Mathf.sin(TWO_PI * vPh1[V_SNARE]))\n                         * vAmp[V_SNARE] * 0.5;\n      const nz: f32 = noise();\n      vHP[V_SNARE] = vHP[V_SNARE] + snHpC * (nz - vHP[V_SNARE]);\n      const hp: f32 = nz - vHP[V_SNARE];\n      const noiseLvl: f32 = (0.5 + snapN * 0.9) * vAmp2[V_SNARE];\n      const s: f32 = (tones * 0.6 + hp * noiseLvl) * vVel[V_SNARE];\n      vAmp[V_SNARE]  *= sToneA;\n      vAmp2[V_SNARE] *= sNzA;\n      if (vAmp[V_SNARE] < 0.0008 && vAmp2[V_SNARE] < 0.0008) vActive[V_SNARE] = 0;\n      mix += s * 0.9;\n    }\n\n    // ============ TOM (synth) ============\n    if (vActive[V_TOM] == 1) {\n      const t: f32 = vT[V_TOM];\n      const baseHz: f32 = 120.0 * tuneMul;\n      const sweepHz: f32 = baseHz + 40.0 * f32(Math.exp(-f64(t / 0.04)));\n      vPh0[V_TOM] += sweepHz * dt; if (vPh0[V_TOM] >= 1.0) vPh0[V_TOM] -= 1.0;\n      const s: f32 = Mathf.sin(TWO_PI * vPh0[V_TOM]) * vAmp[V_TOM] * vVel[V_TOM];\n      vAmp[V_TOM] *= tomA;\n      vT[V_TOM] += dt;\n      if (vAmp[V_TOM] < 0.0008) vActive[V_TOM] = 0;\n      mix += s * 0.9;\n    }\n\n    // ============ CLOSED HAT (sample) ============\n    {\n      let s: f32 = playSample(V_CHAT, chatBuf, chatLen, hatEnvA);\n      if (s != 0.0) {\n        vHP[V_CHAT] = vHP[V_CHAT] + hpC * (s - vHP[V_CHAT]);\n        s = (s - vHP[V_CHAT]) * (0.5 + toneN * 0.9) + s * 0.25;\n        mix += s * 0.9;\n      }\n    }\n\n    // ============ OPEN HAT (sample) ============\n    {\n      let s: f32 = playSample(V_OHAT, ohatBuf, ohatLen, hatEnvA);\n      if (s != 0.0) {\n        vHP[V_OHAT] = vHP[V_OHAT] + hpC * (s - vHP[V_OHAT]);\n        s = (s - vHP[V_OHAT]) * (0.5 + toneN * 0.9) + s * 0.25;\n        mix += s * 0.85;\n      }\n    }\n\n    // ============ CRASH (sample) ============\n    {\n      let s: f32 = playSample(V_CRASH, crashBuf, crashLen, crashEnvA);\n      if (s != 0.0) {\n        vHP[V_CRASH] = vHP[V_CRASH] + hpC * (s - vHP[V_CRASH]);\n        s = (s - vHP[V_CRASH]) * (0.4 + toneN * 0.8) + s * 0.35;\n        mix += s * 0.7;\n      }\n    }\n\n    let outv: f32 = mix * outGain;\n    if (outv > 1.2) outv = 1.2; else if (outv < -1.2) outv = -1.2;\n    // soft-limit\n    outv = outv - (outv * outv * outv) * 0.12;\n    outBuf[f] = outv;\n    outBuf[MAX_FRAMES + f] = outv;\n  }\n}\n",
  "publishedAt": 1751000031000
}