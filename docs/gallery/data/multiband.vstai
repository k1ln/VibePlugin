{
  "format": 1,
  "name": "Multiband",
  "isInstrument": false,
  "explanation": "A three-band dynamics processor for mastering. The signal is split into low, mid and high bands by two crossovers (~220 Hz and ~2.5 kHz), and each band is compressed independently with its own threshold so the lows can pump without dulling the highs. A shared ratio sets how hard each band squeezes; the bands recombine through a makeup/output trim. Controls: Low Thresh, Mid Thresh, High Thresh, Ratio and Output.",
  "params": [
    {
      "name": "Low Thresh",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mid Thresh",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "High Thresh",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Ratio",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<style>\n:root{\n  --ac:#ff8a5a;        /* warm coral accent */\n  --ac2:#ffd166;       /* amber highlight  */\n  --bg0:#0c0d12;\n  --bg1:#14161f;\n  --panel:#191c27;\n  --panel2:#1f2230;\n  --line:rgba(255,255,255,.07);\n  --ink:#eef1f7;\n  --dim:#8b91a6;\n  --low:#ff7a59;\n  --mid:#ffb24d;\n  --high:#ffd166;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,-apple-system,\"Segoe UI\",system-ui,sans-serif;\n  color:var(--ink);\n  background:\n    radial-gradient(130% 80% at 50% -10%,#1b1d28 0%,#0d0e14 55%,#070809 100%);\n  display:flex;align-items:center;justify-content:center;\n  padding:20px;min-height:100%;\n}\n\n.unit{\n  position:relative;\n  width:min(560px,96vw);\n  border-radius:18px;\n  padding:18px 20px 20px;\n  background:\n    linear-gradient(180deg,#20232f 0%,var(--panel) 18%,var(--bg1) 100%);\n  box-shadow:\n    0 30px 70px -22px rgba(0,0,0,.8),\n    0 1px 0 rgba(255,255,255,.06) inset,\n    0 0 0 1px rgba(0,0,0,.5),\n    0 0 0 1px var(--line) inset;\n  animation:rise .6s cubic-bezier(.2,.8,.25,1) both;\n}\n@keyframes rise{from{opacity:0;transform:translateY(18px) scale(.985)}to{opacity:1;transform:none}}\n\n/* faint top rack-rail texture */\n.unit::before{\n  content:\"\";position:absolute;inset:0;border-radius:18px;pointer-events:none;\n  background:\n    repeating-linear-gradient(180deg,rgba(255,255,255,.018) 0 1px,transparent 1px 4px);\n  opacity:.5;mix-blend-mode:screen;\n}\n\n/* ===== header ===== */\n.head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:14px}\n.brand{font-size:8.5px;letter-spacing:.4em;color:var(--dim);text-transform:uppercase}\nh1{\n  margin:2px 0 0;font-size:23px;font-weight:800;letter-spacing:.04em;line-height:1;\n  background:linear-gradient(90deg,var(--ac) 0%,var(--ac2) 100%);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n}\n.sub{font-size:8px;letter-spacing:.28em;color:var(--dim);text-transform:uppercase;margin-top:5px}\n.pwr{display:flex;align-items:center;gap:8px}\n.dot{width:9px;height:9px;border-radius:50%;\n  background:radial-gradient(circle at 38% 32%,#fff,var(--ac2) 45%,#a8521f 90%);\n  box-shadow:0 0 12px var(--ac2),0 0 3px #fff inset;\n  animation:beat 2.4s ease-in-out infinite}\n@keyframes beat{0%,100%{box-shadow:0 0 7px var(--ac2),0 0 3px #fff inset}50%{box-shadow:0 0 16px var(--ac2),0 0 5px #fff inset}}\n.pwr span{font-size:8px;letter-spacing:.24em;color:var(--dim);text-transform:uppercase}\n\n/* ===== band lanes ===== */\n.lanes{display:flex;flex-direction:column;gap:10px}\n.lane{\n  position:relative;\n  display:grid;\n  grid-template-columns:74px 1fr 96px;\n  gap:14px;align-items:center;\n  padding:12px 14px;border-radius:13px;\n  background:linear-gradient(180deg,var(--panel2),#171a24);\n  box-shadow:0 1px 0 rgba(255,255,255,.04) inset,0 0 0 1px rgba(0,0,0,.45),0 8px 18px -12px rgba(0,0,0,.7);\n  animation:pop .5s both;animation-delay:var(--d);\n}\n@keyframes pop{from{opacity:0;transform:translateX(-10px)}to{opacity:1;transform:none}}\n.lane::before{ /* left accent strip = band colour */\n  content:\"\";position:absolute;left:0;top:10px;bottom:10px;width:3px;border-radius:3px;\n  background:var(--bc);box-shadow:0 0 10px var(--bc);}\n\n/* band identity */\n.bid{display:flex;flex-direction:column;gap:3px}\n.bname{font-size:11px;font-weight:800;letter-spacing:.14em;color:var(--bc);text-transform:uppercase}\n.brange{font-size:8px;letter-spacing:.1em;color:var(--dim);font-variant-numeric:tabular-nums}\n\n/* ===== gain-reduction meter (the centrepiece, pumps independently) ===== */\n.meter{\n  position:relative;height:46px;border-radius:9px;overflow:hidden;\n  background:radial-gradient(120% 160% at 50% 130%,#0b0d13,#05060a 75%);\n  box-shadow:inset 0 2px 8px rgba(0,0,0,.85),inset 0 0 0 1px rgba(255,255,255,.03);\n}\n/* scale ticks (dB-ish) */\n.meter .scale{position:absolute;inset:0;pointer-events:none;\n  background:repeating-linear-gradient(90deg,rgba(255,255,255,.05) 0 1px,transparent 1px 10%);}\n/* spectrum bars across the lane, animated */\n.bars{position:absolute;inset:6px 8px;display:flex;align-items:flex-end;gap:2px}\n.bars i{flex:1;border-radius:2px 2px 0 0;transform-origin:bottom;\n  background:linear-gradient(180deg,var(--bc),rgba(255,255,255,.05));\n  opacity:.55;}\n/* gain-reduction fill: grows DOWN from the top in the band colour */\n.gr{position:absolute;top:0;left:0;right:0;height:0%;\n  background:linear-gradient(180deg,var(--bc),transparent);\n  box-shadow:0 0 14px var(--bc);opacity:.85;\n  transition:height .05s linear;}\n.gr::after{content:\"\";position:absolute;left:0;right:0;bottom:0;height:2px;\n  background:var(--ac2);box-shadow:0 0 8px var(--ac2);}\n.thrline{position:absolute;left:0;right:0;height:1px;background:rgba(255,255,255,.35);\n  box-shadow:0 0 5px rgba(255,255,255,.4);transition:top .12s ease;}\n.grtxt{position:absolute;right:6px;top:5px;font-size:9px;font-weight:700;letter-spacing:.06em;\n  color:#fff;font-variant-numeric:tabular-nums;opacity:.85;text-shadow:0 1px 3px #000}\n\n/* ===== per-lane threshold knob ===== */\n.knobwrap{display:flex;flex-direction:column;align-items:center;gap:5px}\n.knob{position:relative;width:54px;height:54px;cursor:ns-resize;touch-action:none;user-select:none}\n.arc{position:absolute;inset:0;border-radius:50%;\n  background:conic-gradient(from 215deg,var(--bc) calc(var(--n)*270deg),rgba(255,255,255,.05) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(1px + var(--n)*6px) var(--bc));\n  transition:filter .12s ease;}\n.cap{position:absolute;top:8px;left:8px;width:38px;height:38px;border-radius:50%;\n  background:radial-gradient(circle at 50% 30%,#3a3e4d 0%,#191c26 62%,#0e1016 100%);\n  box-shadow:inset 0 2px 5px rgba(255,255,255,.12),inset 0 -5px 10px rgba(0,0,0,.8),0 3px 7px rgba(0,0,0,.5);}\n.ptr{position:absolute;top:5px;left:50%;width:3px;height:15px;margin-left:-1.5px;border-radius:3px;\n  background:linear-gradient(var(--ac2),var(--bc));box-shadow:0 0 6px var(--bc),0 0 2px #fff;\n  transform-origin:50% 22px;transform:rotate(calc((var(--n) - .5) * 270deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1)}\n.klabel{font-size:8px;font-weight:700;letter-spacing:.14em;color:var(--dim);text-transform:uppercase}\n.kval{font-size:10px;font-weight:800;color:var(--ink);font-variant-numeric:tabular-nums}\n.knob.act .cap{box-shadow:inset 0 2px 5px rgba(255,255,255,.14),inset 0 -5px 10px rgba(0,0,0,.8),0 3px 11px var(--bc)}\n\n/* ===== bottom master row ===== */\n.master{display:flex;align-items:center;justify-content:space-between;gap:16px;\n  margin-top:14px;padding:14px 16px;border-radius:13px;\n  background:linear-gradient(180deg,#1d2030,#13151e);\n  box-shadow:0 1px 0 rgba(255,255,255,.04) inset,0 0 0 1px rgba(0,0,0,.45)}\n.mctl{display:flex;align-items:center;gap:12px}\n.bigknob{position:relative;width:64px;height:64px;cursor:ns-resize;touch-action:none;user-select:none}\n.bigknob .arc{background:conic-gradient(from 215deg,var(--ac) calc(var(--n)*270deg),rgba(255,255,255,.05) calc(var(--n)*270deg) 270deg,transparent 270deg);\n  filter:drop-shadow(0 0 calc(2px + var(--n)*8px) var(--ac));}\n.bigknob .cap{top:9px;left:9px;width:46px;height:46px}\n.bigknob .ptr{top:6px;height:18px;transform-origin:50% 26px;background:linear-gradient(var(--ac2),var(--ac));box-shadow:0 0 7px var(--ac),0 0 2px #fff}\n.mmeta{display:flex;flex-direction:column;gap:2px}\n.mmeta .t{font-size:9px;letter-spacing:.18em;color:var(--dim);text-transform:uppercase}\n.mmeta .v{font-size:16px;font-weight:800;color:var(--ink);font-variant-numeric:tabular-nums}\n.mmeta .v small{font-size:9px;color:var(--dim);font-weight:600;margin-left:2px}\n\n@media (max-width:460px){\n  .lane{grid-template-columns:60px 1fr 76px;gap:9px;padding:10px}\n  .master{flex-direction:column;align-items:stretch;gap:14px}\n}\n</style>\n</head>\n<body>\n<div class=\"unit\">\n\n  <div class=\"head\">\n    <div>\n      <div class=\"brand\">Mastering Series</div>\n      <h1>Multiband</h1>\n      <div class=\"sub\">3-Band Dynamics</div>\n    </div>\n    <div class=\"pwr\"><span>Active</span><span class=\"dot\"></span></div>\n  </div>\n\n  <div class=\"lanes\" id=\"lanes\"></div>\n\n  <div class=\"master\">\n    <div class=\"mctl\">\n      <div class=\"bigknob\" id=\"ratioKnob\" tabindex=\"0\">\n        <i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>\n      </div>\n      <div class=\"mmeta\">\n        <div class=\"t\">Ratio</div>\n        <div class=\"v\" id=\"ratioVal\">1.0<small>:1</small></div>\n      </div>\n    </div>\n    <div class=\"mctl\">\n      <div class=\"mmeta\" style=\"text-align:right;align-items:flex-end\">\n        <div class=\"t\">Output</div>\n        <div class=\"v\" id=\"outVal\">0.0<small>dB</small></div>\n      </div>\n      <div class=\"bigknob\" id=\"outKnob\" tabindex=\"0\">\n        <i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  var P = {\n    LOW:0, MID:1, HIGH:2, RATIO:3, OUT:4\n  };\n\n  var BANDS = [\n    { key:\"LOW\",  index:P.LOW,  name:\"Low\",  range:\"&lt; 220 Hz\",      colour:\"var(--low)\",  def:0.5 },\n    { key:\"MID\",  index:P.MID,  name:\"Mid\",  range:\"220 Hz – 2.5 kHz\", colour:\"var(--mid)\",  def:0.5 },\n    { key:\"HIGH\", index:P.HIGH, name:\"High\", range:\"&gt; 2.5 kHz\",     colour:\"var(--high)\", def:0.5 }\n  ];\n\n  var state = {};          // index -> raw 0..1 value\n  var lanesEl = document.getElementById('lanes');\n\n  function pushParam(index, value){\n    state[index] = value;\n    if (window.vstai && window.vstai.setParam) window.vstai.setParam(index, value);\n  }\n\n  // ---------------------------------------------------------------\n  //  Build the three band lanes\n  // ---------------------------------------------------------------\n  var laneRefs = [];   // { gr, bars[], grtxt, thr, arc, ptr, kval, threshold }\n\n  BANDS.forEach(function(b, i){\n    var lane = document.createElement('div');\n    lane.className = 'lane';\n    lane.style.setProperty('--bc', b.colour);\n    lane.style.setProperty('--d', (i*80)+'ms');\n\n    var barsHtml = '';\n    var NB = 14;\n    for (var k=0;k<NB;k++) barsHtml += '<i></i>';\n\n    lane.innerHTML =\n      '<div class=\"bid\">'+\n        '<div class=\"bname\">'+b.name+'</div>'+\n        '<div class=\"brange\">'+b.range+'</div>'+\n      '</div>'+\n      '<div class=\"meter\">'+\n        '<div class=\"scale\"></div>'+\n        '<div class=\"bars\">'+barsHtml+'</div>'+\n        '<div class=\"thrline\"></div>'+\n        '<div class=\"gr\"></div>'+\n        '<div class=\"grtxt\">0.0 dB</div>'+\n      '</div>'+\n      '<div class=\"knobwrap\">'+\n        '<div class=\"knob\" tabindex=\"0\"><i class=\"arc\"></i><i class=\"cap\"></i><i class=\"ptr\"></i></div>'+\n        '<div class=\"klabel\">Thresh</div>'+\n        '<div class=\"kval\"></div>'+\n      '</div>';\n\n    lanesEl.appendChild(lane);\n\n    var ref = {\n      gr:    lane.querySelector('.gr'),\n      bars:  Array.prototype.slice.call(lane.querySelectorAll('.bars i')),\n      grtxt: lane.querySelector('.grtxt'),\n      thr:   lane.querySelector('.thrline'),\n      arc:   lane.querySelector('.knob .arc'),\n      ptr:   lane.querySelector('.knob .ptr'),\n      kval:  lane.querySelector('.kval'),\n      knob:  lane.querySelector('.knob'),\n      env:   0,     // simulated band detector\n      grSmooth:0,   // smoothed gain reduction in dB (positive number)\n      phase: Math.random()*6.28,\n      colour:b.colour\n    };\n    laneRefs.push(ref);\n\n    var v = b.def;\n    function paintKnob(){\n      ref.arc.style.setProperty('--n', v);\n      ref.ptr.style.setProperty('--n', v);\n      // show as a threshold in dB: 0 -> -40 dB (aggressive), 1 -> -1 dB (open)\n      var thrDb = -40 + v*39;\n      ref.kval.textContent = thrDb.toFixed(0)+' dB';\n      // threshold guide line on the meter (top = 0 GR, lower = deeper)\n      ref.thr.style.top = ((1 - v) * 70 + 6) + '%';\n      pushParam(b.index, v);\n    }\n    function setNorm(n){ v = n<0?0:n>1?1:n; paintKnob(); }\n\n    var drag=false, startY=0, startN=0;\n    ref.knob.addEventListener('pointerdown', function(e){\n      drag=true; startY=e.clientY; startN=v;\n      ref.knob.classList.add('act'); ref.knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    ref.knob.addEventListener('pointermove', function(e){\n      if(!drag) return;\n      var speed = e.shiftKey?700:200;\n      setNorm(startN + (startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; ref.knob.classList.remove('act'); }\n    ref.knob.addEventListener('pointerup', end);\n    ref.knob.addEventListener('pointercancel', end);\n    ref.knob.addEventListener('dblclick', function(){ setNorm(b.def); });\n    ref.knob.addEventListener('wheel', function(e){\n      e.preventDefault(); setNorm(v + (e.deltaY<0?0.03:-0.03));\n    }, {passive:false});\n    ref.knob.addEventListener('keydown', function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){ setNorm(v+0.02); e.preventDefault(); }\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){ setNorm(v-0.02); e.preventDefault(); }\n    });\n\n    ref.getThresh = function(){ return v; };\n    paintKnob();\n  });\n\n  // ---------------------------------------------------------------\n  //  Master knobs (Ratio, Output)\n  // ---------------------------------------------------------------\n  function makeBigKnob(elId, index, def, onPaint){\n    var knob = document.getElementById(elId);\n    var arc = knob.querySelector('.arc');\n    var ptr = knob.querySelector('.ptr');\n    var v = def;\n    function paint(){\n      arc.style.setProperty('--n', v);\n      ptr.style.setProperty('--n', v);\n      pushParam(index, v);\n      onPaint(v);\n    }\n    function setNorm(n){ v = n<0?0:n>1?1:n; paint(); }\n    var drag=false, startY=0, startN=0;\n    knob.addEventListener('pointerdown', function(e){\n      drag=true; startY=e.clientY; startN=v;\n      knob.classList.add('act'); knob.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    knob.addEventListener('pointermove', function(e){\n      if(!drag) return;\n      var speed = e.shiftKey?700:200;\n      setNorm(startN + (startY-e.clientY)/speed);\n    });\n    function end(){ drag=false; knob.classList.remove('act'); }\n    knob.addEventListener('pointerup', end);\n    knob.addEventListener('pointercancel', end);\n    knob.addEventListener('dblclick', function(){ setNorm(def); });\n    knob.addEventListener('wheel', function(e){\n      e.preventDefault(); setNorm(v + (e.deltaY<0?0.03:-0.03));\n    }, {passive:false});\n    knob.addEventListener('keydown', function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){ setNorm(v+0.02); e.preventDefault(); }\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){ setNorm(v-0.02); e.preventDefault(); }\n    });\n    paint();\n    return { get:function(){ return v; } };\n  }\n\n  var ratioVal = document.getElementById('ratioVal');\n  var outVal = document.getElementById('outVal');\n\n  var ratioCtl = makeBigKnob('ratioKnob', P.RATIO, 0.5, function(v){\n    var r = 1 + v*11;\n    ratioVal.innerHTML = r.toFixed(1)+'<small>:1</small>';\n  });\n  var outCtl = makeBigKnob('outKnob', P.OUT, 0.6, function(v){\n    // 0..1 -> 0..1.6 linear -> dB\n    var lin = v*1.6;\n    var db = lin>0.0001 ? 20*Math.log10(lin) : -60;\n    outVal.innerHTML = (db>=0?'+':'')+db.toFixed(1)+'<small>dB</small>';\n  });\n\n  // ---------------------------------------------------------------\n  //  Animated visualiser — each band runs its OWN simulated detector\n  //  and compressor so the three GR meters pump independently. The low\n  //  band uses a slow release (big pumping swells); highs are snappy.\n  // ---------------------------------------------------------------\n  var BAND_RATE = [0.9, 1.7, 3.1];     // pseudo-modulation rates per band (Hz-ish)\n  var REL = [0.018, 0.045, 0.09];      // per-frame release toward target (low = slow)\n  var last = performance.now();\n\n  function frame(now){\n    var dt = Math.min(0.05, (now-last)/1000); last = now;\n    var ratioN = ratioCtl.get();\n    var ratio = 1 + ratioN*11;\n    var slope = 1 - 1/ratio;\n\n    for (var i=0;i<laneRefs.length;i++){\n      var L = laneRefs[i];\n      L.phase += dt * BAND_RATE[i] * 6.283;\n\n      // synthetic band energy: a couple of beating sines -> lively level 0..1\n      var drive = 0.55 + 0.40*Math.sin(L.phase) * Math.sin(L.phase*0.37+i);\n      drive = drive<0?0:drive>1?1:drive;\n      // peak detector follow (fast attack, slow-ish release per band)\n      if (drive > L.env) L.env += (drive - L.env) * 0.6;\n      else               L.env += (drive - L.env) * (REL[i]*4);\n\n      // static compression curve mirrors the DSP: thr knob sets threshold\n      var thrN = L.getThresh();\n      var thr = 0.02 + thrN*0.88;\n      var grDb = 0;\n      if (L.env > thr){\n        var over = L.env/thr;\n        var gain = Math.pow(over, -slope);          // linear gain <1\n        grDb = -20*Math.log10(Math.max(gain,0.02)); // positive dB of reduction\n      }\n      // smooth the displayed GR with band-dependent release\n      var k = grDb > L.grSmooth ? 0.55 : REL[i];\n      L.grSmooth += (grDb - L.grSmooth) * k;\n\n      // paint GR fill (0 dB -> 0 height, ~24 dB -> full)\n      var h = Math.min(100, (L.grSmooth/24)*100);\n      L.gr.style.height = h.toFixed(1)+'%';\n      L.grtxt.textContent = '-'+L.grSmooth.toFixed(1)+' dB';\n\n      // animate spectrum bars (driven by env + a little per-bar wobble)\n      var bars = L.bars, NB = bars.length;\n      for (var k2=0;k2<NB;k2++){\n        var w = 0.5 + 0.5*Math.sin(L.phase*1.3 + k2*0.7 + i);\n        var hgt = (0.25 + 0.75*L.env*w) * 100;\n        var b = bars[k2];\n        b.style.height = hgt.toFixed(0)+'%';\n        // dim a bar more when this band is being reduced (visual \"duck\")\n        b.style.opacity = (0.35 + 0.45*(1 - L.grSmooth/24)).toFixed(2);\n      }\n    }\n\n    if (!document.hidden) rafId = requestAnimationFrame(frame);\n    else rafId = 0;\n  }\n\n  var rafId = requestAnimationFrame(frame);\n  document.addEventListener('visibilitychange', function(){\n    if (!document.hidden && !rafId){ last = performance.now(); rafId = requestAnimationFrame(frame); }\n  });\n\n  // ---------------------------------------------------------------\n  function ready(){\n    // re-push every default so the engine matches the GUI on load\n    BANDS.forEach(function(b){ pushParam(b.index, state[b.index]); });\n    pushParam(P.RATIO, ratioCtl.get());\n    pushParam(P.OUT, outCtl.get());\n  }\n  if (window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MULTIBAND — three-band dynamics processor (mastering-style)\n//  The signal is split into LOW / MID / HIGH bands with two crossovers\n//  (state-variable filters, ~220 Hz and ~2.5 kHz). Each band runs its own\n//  peak-detecting compressor with an independent threshold, a shared ratio\n//  and per-band attack/release ballistics, so the low band can pump hard\n//  without dulling the highs. The compressed bands are recombined and a\n//  final makeup/output gain trims the result. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- crossover filter state (two cascaded SVF-ish one-poles per split, per ch) ---\n// We build the band split from a pair of one-pole low-passes per crossover.\n// lp1 = low/mid split ~220 Hz, lp2 = mid/high split ~2.5 kHz. Two stages each\n// (cascaded) give a steeper, cleaner Linkwitz-Riley-like slope.\nconst lpA1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low split, stage 1\nconst lpA2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // low split, stage 2\nconst lpB1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // high split, stage 1\nconst lpB2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // high split, stage 2\n\n// --- per-band compressor envelopes (one detector per band, mono-linked over ch) ---\nconst envLow:  StaticArray<f32> = new StaticArray<f32>(1);\nconst envMid:  StaticArray<f32> = new StaticArray<f32>(1);\nconst envHigh: StaticArray<f32> = new StaticArray<f32>(1);\n\n// --- live gain-reduction readout (linear gain 0..1), exposed for the GUI meters ---\nconst grLow:  StaticArray<f32> = new StaticArray<f32>(1);\nconst grMid:  StaticArray<f32> = new StaticArray<f32>(1);\nconst grHigh: StaticArray<f32> = new StaticArray<f32>(1);\n\nconst P_LOW:   i32 = 0; // 0..1 -> low-band threshold (1 = open, 0 = squash)\nconst P_MID:   i32 = 1; // 0..1 -> mid-band threshold\nconst P_HIGH:  i32 = 2; // 0..1 -> high-band threshold\nconst P_RATIO: i32 = 3; // 0..1 -> ratio 1:1 .. ~12:1\nconst P_OUT:   i32 = 4; // 0..1 -> output / makeup 0..2x\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lpA1[c] = 0.0; lpA2[c] = 0.0; lpB1[c] = 0.0; lpB2[c] = 0.0;\n  }\n  envLow[0] = 0.0; envMid[0] = 0.0; envHigh[0] = 0.0;\n  grLow[0] = 1.0; grMid[0] = 1.0; grHigh[0] = 1.0;\n  params[P_LOW]   = 0.5;\n  params[P_MID]   = 0.5;\n  params[P_HIGH]  = 0.5;\n  params[P_RATIO] = 0.5;\n  params[P_OUT]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n// gain-reduction getters for the GUI (0..1 linear gain; lower = more reduction)\nexport function getGrLow(): f32  { return grLow[0]; }\nexport function getGrMid(): f32  { return grMid[0]; }\nexport function getGrHigh(): f32 { return grHigh[0]; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function process(n: i32): void {\n  // --- thresholds: param 1 = open (high threshold), 0 = aggressive (low threshold) ---\n  // Map each band threshold knob to a linear amplitude threshold.\n  // 0 -> 0.02 (squashes almost everything), 1 -> 0.9 (barely touches peaks).\n  const thrLow:  f32 = 0.02 + clampf(params[P_LOW],  0.0, 1.0) * 0.88;\n  const thrMid:  f32 = 0.02 + clampf(params[P_MID],  0.0, 1.0) * 0.88;\n  const thrHigh: f32 = 0.02 + clampf(params[P_HIGH], 0.0, 1.0) * 0.88;\n\n  // shared ratio 1:1 .. ~12:1\n  const ratio: f32 = 1.0 + clampf(params[P_RATIO], 0.0, 1.0) * 11.0;\n  const slope: f32 = 1.0 - 1.0 / ratio; // amount of excess pulled back\n\n  const out: f32 = clampf(params[P_OUT], 0.0, 1.0) * 1.6;\n\n  // crossover coefficients (one-pole), cascaded twice for a steeper slope\n  const fLowHz:  f32 = 220.0;\n  const fHighHz: f32 = 2500.0;\n  const cLow:  f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * fLowHz  / sampleRate)), 0.0, 1.0);\n  const cHigh: f32 = clampf(f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * fHighHz / sampleRate)), 0.0, 1.0);\n\n  // ballistics: fast attack, band-dependent release (lows release slower → pump)\n  const atk: f32 = clampf(f32(1.0 - Mathf.exp(-1.0 / (0.004 * sampleRate))), 0.0, 1.0);\n  const relLow:  f32 = clampf(f32(1.0 - Mathf.exp(-1.0 / (0.180 * sampleRate))), 0.0, 1.0);\n  const relMid:  f32 = clampf(f32(1.0 - Mathf.exp(-1.0 / (0.090 * sampleRate))), 0.0, 1.0);\n  const relHigh: f32 = clampf(f32(1.0 - Mathf.exp(-1.0 / (0.040 * sampleRate))), 0.0, 1.0);\n\n  // makeup so reducing the threshold (more squash) still feels level-matched,\n  // scaled by ratio so high ratios don't just collapse the level.\n  const makeup: f32 = 1.0 + slope * 0.6;\n\n  let eLow:  f32 = envLow[0];\n  let eMid:  f32 = envMid[0];\n  let eHigh: f32 = envHigh[0];\n\n  // track the minimum (deepest) gain reduction across the block for the meters\n  let mGrLow:  f32 = 1.0;\n  let mGrMid:  f32 = 1.0;\n  let mGrHigh: f32 = 1.0;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let a1: f32 = lpA1[c];\n    let a2: f32 = lpA2[c];\n    let b1: f32 = lpB1[c];\n    let b2: f32 = lpB2[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // --- crossover split (cascaded one-pole low-passes) ---\n      a1 = a1 + cLow * (x - a1);\n      a2 = a2 + cLow * (a1 - a2);\n      const low: f32 = a2;                 // below ~220 Hz\n\n      b1 = b1 + cHigh * (x - b1);\n      b2 = b2 + cHigh * (b1 - b2);\n      const lowMid: f32 = b2;              // below ~2.5 kHz\n\n      const mid: f32  = lowMid - low;      // 220 Hz .. 2.5 kHz\n      const high: f32 = x - lowMid;        // above ~2.5 kHz\n\n      // --- per-band peak detection + static compression curve ---\n      // LOW band\n      const dl: f32 = low < 0.0 ? -low : low;\n      const cl: f32 = dl > eLow ? atk : relLow;\n      eLow = eLow + cl * (dl - eLow);\n      let gLow: f32 = 1.0;\n      if (eLow > thrLow) {\n        const over: f32 = eLow / thrLow;            // >1\n        gLow = f32(Mathf.pow(over, -slope));        // gain reduction\n      }\n      gLow = clampf(gLow, 0.02, 1.0);\n      if (gLow < mGrLow) mGrLow = gLow;\n\n      // MID band\n      const dm: f32 = mid < 0.0 ? -mid : mid;\n      const cm: f32 = dm > eMid ? atk : relMid;\n      eMid = eMid + cm * (dm - eMid);\n      let gMid: f32 = 1.0;\n      if (eMid > thrMid) {\n        const over: f32 = eMid / thrMid;\n        gMid = f32(Mathf.pow(over, -slope));\n      }\n      gMid = clampf(gMid, 0.02, 1.0);\n      if (gMid < mGrMid) mGrMid = gMid;\n\n      // HIGH band\n      const dh: f32 = high < 0.0 ? -high : high;\n      const ch2: f32 = dh > eHigh ? atk : relHigh;\n      eHigh = eHigh + ch2 * (dh - eHigh);\n      let gHigh: f32 = 1.0;\n      if (eHigh > thrHigh) {\n        const over: f32 = eHigh / thrHigh;\n        gHigh = f32(Mathf.pow(over, -slope));\n      }\n      gHigh = clampf(gHigh, 0.02, 1.0);\n      if (gHigh < mGrHigh) mGrHigh = gHigh;\n\n      // --- recombine + makeup + output ---\n      const y: f32 = (low * gLow + mid * gMid + high * gHigh) * makeup * out;\n      outBuf[base + f] = clampf(y, -1.0, 1.0);\n    }\n\n    lpA1[c] = a1; lpA2[c] = a2; lpB1[c] = b1; lpB2[c] = b2;\n  }\n\n  envLow[0] = eLow; envMid[0] = eMid; envHigh[0] = eHigh;\n  grLow[0]  = mGrLow; grMid[0]  = mGrMid; grHigh[0] = mGrHigh;\n}\n",
  "publishedAt": 1751000073000
}