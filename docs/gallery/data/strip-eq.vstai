{
  "format": 1,
  "name": "Strip EQ",
  "isInstrument": false,
  "explanation": "A four-band British console channel-strip equaliser. A low shelf and high shelf bookend two fully swept parametric mid bells (low-mid and high-mid, each with its own gain and frequency), and a sweepable high-pass filter cleans the bottom end before the EQ. Clean, surgical and punchy in the mixing-desk tradition. Controls: Low, Lo-Mid, Lo-Mid Freq, Hi-Mid, Hi-Mid Freq, High, HP and Output.",
  "params": [
    {
      "name": "Low",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Lo-Mid",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Lo-Mid Freq",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Hi-Mid",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Hi-Mid Freq",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "High",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "HP",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Output",
      "index": 7,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Strip EQ</title>\n<style>\n  :root{\n    --accent:#5ad0ff;      /* blue */\n    --accent2:#ff5a5a;     /* red  */\n    --green:#7fe6a8;\n    --panel:#0c0e11;\n    --panel2:#141821;\n    --metal:#1c2129;\n    --ink:#e7edf5;\n    --ink-dim:#7d8896;\n    --line:#2a313c;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none;}\n  html,body{margin:0;height:100%;}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:\n      radial-gradient(1200px 600px at 50% -10%, #1a2029 0%, #07090c 60%, #050608 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100%;padding:18px;overflow:auto;\n  }\n\n  /* ---- the console module ---- */\n  .strip{\n    position:relative;\n    width:560px;max-width:96vw;\n    background:linear-gradient(180deg,#171b22 0%,#0e1116 100%);\n    border:1px solid #000;\n    border-radius:14px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.05) inset,\n      0 40px 90px rgba(0,0,0,.65),\n      0 0 0 1px rgba(90,208,255,.04);\n    padding:18px 20px 22px;\n    display:flex;flex-direction:column;gap:14px;\n  }\n  /* screw decorations */\n  .screw{position:absolute;width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#3a414c,#10131a 70%);\n    box-shadow:0 1px 1px rgba(0,0,0,.6),0 0 0 1px #05070a;}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-top:1px solid #0a0c10;transform:rotate(35deg);}\n  .screw.tl{top:8px;left:8px}.screw.tr{top:8px;right:8px}\n  .screw.bl{bottom:8px;left:8px}.screw.br{bottom:8px;right:8px}\n\n  .head{display:flex;align-items:center;justify-content:space-between;padding:0 4px;}\n  .brand{display:flex;flex-direction:column;line-height:1;}\n  .brand b{font-size:19px;letter-spacing:.32em;font-weight:800;\n    background:linear-gradient(90deg,var(--accent),#bfefff);\n    -webkit-background-clip:text;background-clip:text;color:transparent;}\n  .brand span{font-size:9px;letter-spacing:.42em;color:var(--ink-dim);margin-top:5px;}\n  .model{font-size:9px;letter-spacing:.3em;color:var(--ink-dim);\n    border:1px solid var(--line);border-radius:4px;padding:5px 8px;}\n\n  /* ---- EQ curve display ---- */\n  .scope{\n    position:relative;height:148px;border-radius:9px;overflow:hidden;\n    background:linear-gradient(180deg,#070a0e,#0a0e13);\n    border:1px solid #000;\n    box-shadow:0 2px 8px rgba(0,0,0,.6) inset, 0 0 0 1px rgba(255,255,255,.03) inset;\n  }\n  .scope svg{position:absolute;inset:0;width:100%;height:100%;}\n  .scanline{position:absolute;left:0;right:0;height:34px;pointer-events:none;\n    background:linear-gradient(180deg,rgba(90,208,255,.10),transparent);\n    animation:scan 5s linear infinite;mix-blend-mode:screen;}\n  @keyframes scan{0%{top:-34px}100%{top:148px}}\n  .scope .lbl{position:absolute;bottom:4px;font-size:8px;color:var(--ink-dim);letter-spacing:.12em;}\n\n  /* ---- knob rows ---- */\n  .rack{display:flex;flex-direction:column;gap:18px;padding:2px 2px 0;}\n  .band{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;align-items:start;}\n  .cell{display:flex;flex-direction:column;align-items:center;gap:7px;}\n\n  .knob{\n    --col:var(--accent);\n    position:relative;width:74px;height:74px;border-radius:50%;\n    cursor:grab;touch-action:none;\n    background:\n      radial-gradient(circle at 50% 38%, #2b323d 0%, #161a21 62%, #0c0f14 100%);\n    box-shadow:\n      0 3px 7px rgba(0,0,0,.6),\n      0 0 0 1px #04060a,\n      0 1px 0 rgba(255,255,255,.06) inset;\n    transition:box-shadow .18s, transform .05s;\n  }\n  .knob:active{cursor:grabbing;transform:scale(.985);}\n  .knob:hover{box-shadow:0 3px 7px rgba(0,0,0,.6),0 0 0 1px #04060a,\n    0 1px 0 rgba(255,255,255,.06) inset, 0 0 16px -2px var(--col);}\n  /* coloured cap */\n  .knob .cap{\n    position:absolute;inset:13px;border-radius:50%;\n    background:radial-gradient(circle at 42% 32%, color-mix(in srgb,var(--col) 78%,#fff 0%) , color-mix(in srgb,var(--col) 38%, #0a0d12 70%));\n    box-shadow:0 2px 5px rgba(0,0,0,.5) inset, 0 -1px 1px rgba(255,255,255,.18) inset, 0 0 0 1px rgba(0,0,0,.4);\n  }\n  /* pointer */\n  .knob .ptr{\n    position:absolute;left:50%;top:7px;width:3px;height:24px;margin-left:-1.5px;\n    border-radius:2px;background:#0a0d12;\n    transform-origin:50% 30px;\n    box-shadow:0 0 0 1px rgba(255,255,255,.12);\n  }\n  /* tick ring */\n  .knob .ring{position:absolute;inset:-7px;border-radius:50%;pointer-events:none;}\n  .knob .ring svg{position:absolute;inset:0;width:100%;height:100%;}\n\n  .cap-lbl{font-size:9.5px;letter-spacing:.16em;color:var(--ink);text-transform:uppercase;font-weight:600;}\n  .val{font-size:10px;color:var(--ink-dim);font-variant-numeric:tabular-nums;letter-spacing:.04em;\n    background:#05080c;border:1px solid var(--line);border-radius:4px;padding:2px 7px;min-width:54px;text-align:center;}\n  .val b{color:var(--col,#fff);font-weight:600;}\n\n  .sect-tag{grid-column:1/-1;display:flex;align-items:center;gap:8px;margin-bottom:-6px;}\n  .sect-tag i{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--line),transparent);}\n  .sect-tag s{font-style:normal;font-size:8.5px;letter-spacing:.34em;color:var(--ink-dim);}\n\n  .foot{display:flex;justify-content:space-between;align-items:center;padding:2px 4px 0;font-size:8px;letter-spacing:.22em;color:#454f5b;}\n  .dot{display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--green);\n    box-shadow:0 0 8px var(--green);margin-right:6px;animation:pulse 2.4s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{opacity:.45}50%{opacity:1}}\n</style>\n</head>\n<body>\n  <div class=\"strip\">\n    <i class=\"screw tl\"></i><i class=\"screw tr\"></i><i class=\"screw bl\"></i><i class=\"screw br\"></i>\n\n    <div class=\"head\">\n      <div class=\"brand\"><b>STRIP&nbsp;EQ</b><span>4-BAND CHANNEL EQUALISER</span></div>\n      <div class=\"model\">BRITISH&nbsp;CONSOLE</div>\n    </div>\n\n    <div class=\"scope\">\n      <svg id=\"grid\" viewBox=\"0 0 560 148\" preserveAspectRatio=\"none\"></svg>\n      <svg id=\"curve\" viewBox=\"0 0 560 148\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"fill\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"var(--accent)\" stop-opacity=\".34\"/>\n            <stop offset=\"1\" stop-color=\"var(--accent)\" stop-opacity=\"0\"/>\n          </linearGradient>\n        </defs>\n        <path id=\"area\" fill=\"url(#fill)\"/>\n        <path id=\"line\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"2\"\n              stroke-linejoin=\"round\" stroke-linecap=\"round\"\n              style=\"filter:drop-shadow(0 0 6px rgba(90,208,255,.6))\"/>\n        <g id=\"nodes\"></g>\n      </svg>\n      <div class=\"scanline\"></div>\n      <div class=\"lbl\" style=\"left:8px\">20Hz</div>\n      <div class=\"lbl\" style=\"left:50%;transform:translateX(-50%)\">1k</div>\n      <div class=\"lbl\" style=\"right:8px\">20k</div>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"foot\">\n      <span><i class=\"dot\"></i>ACTIVE</span>\n      <span>SERIES&nbsp;BIQUAD&nbsp;·&nbsp;CLEAN</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- param model -------------------------------------------------\n  // group: which band tag, col: knob colour\n  const P = [\n    {i:0, name:\"Low\",     def:0.5, col:\"var(--accent2)\", grp:\"LF\",  unit:\"db\",  fmt:v=>fmtDb((v-0.5)*32)},\n    {i:1, name:\"Lo-Mid\",  def:0.5, col:\"var(--accent)\",  grp:\"LMF\", unit:\"db\",  fmt:v=>fmtDb((v-0.5)*32)},\n    {i:2, name:\"Freq\",    def:0.3, col:\"var(--accent)\",  grp:\"LMF\", unit:\"hz\",  fmt:v=>fmtHz(logmap(v,80,2000))},\n    {i:3, name:\"Hi-Mid\",  def:0.5, col:\"var(--green)\",   grp:\"HMF\", unit:\"db\",  fmt:v=>fmtDb((v-0.5)*32)},\n    {i:4, name:\"Freq\",    def:0.5, col:\"var(--green)\",   grp:\"HMF\", unit:\"hz\",  fmt:v=>fmtHz(logmap(v,600,15000))},\n    {i:5, name:\"High\",    def:0.5, col:\"var(--accent2)\", grp:\"HF\",  unit:\"db\",  fmt:v=>fmtDb((v-0.5)*32)},\n    {i:6, name:\"HP\",      def:0.0, col:\"#cdd6e0\",        grp:\"FILT\",unit:\"hp\",  fmt:v=>v<0.02?\"OFF\":fmtHz(logmap(v,16,400))},\n    {i:7, name:\"Output\",  def:0.5, col:\"#cdd6e0\",        grp:\"FILT\",unit:\"db\",  fmt:v=>v<=0.001?\"-∞\":fmtDb((v-0.5)*24)}\n  ];\n  const val = P.map(p=>p.def);\n\n  function logmap(t,lo,hi){t=Math.max(0,Math.min(1,t));return lo*Math.exp(t*Math.log(hi/lo));}\n  function fmtDb(d){return (d>=0?\"+\":\"\")+d.toFixed(1)+\" dB\";}\n  function fmtHz(h){return h>=1000?(h/1000).toFixed(h<10000?2:1)+\" k\":Math.round(h)+\" Hz\";}\n\n  // ---- layout the rack ---------------------------------------------\n  // rows: [Low | Lo-Mid Lo-Mid-F | Hi-Mid Hi-Mid-F | High | HP Output]\n  const rack=document.getElementById('rack');\n  const layout=[\n    {tag:\"LOW / LO-MID\",   idx:[0,1,2,null]},\n    {tag:\"HI-MID / HIGH\",  idx:[3,4,5,null]},\n    {tag:\"FILTER / TRIM\",  idx:[6,7,null,null]}\n  ];\n  const knobs=[];\n\n  layout.forEach(row=>{\n    const band=document.createElement('div');band.className='band';\n    const tag=document.createElement('div');tag.className='sect-tag';\n    tag.innerHTML='<i></i><s>'+row.tag+'</s><i></i>';\n    band.appendChild(tag);\n    row.idx.forEach(pi=>{\n      const cell=document.createElement('div');cell.className='cell';\n      if(pi===null){band.appendChild(cell);return;}\n      const p=P[pi];\n      cell.innerHTML=\n        '<div class=\"knob\" style=\"--col:'+p.col+'\">'+\n          '<div class=\"ring\"><svg viewBox=\"0 0 100 100\">'+ticks()+'</svg></div>'+\n          '<div class=\"cap\"></div>'+\n          '<div class=\"ptr\"></div>'+\n        '</div>'+\n        '<div class=\"cap-lbl\">'+p.name+'</div>'+\n        '<div class=\"val\" style=\"--col:'+p.col+'\"><b>'+p.fmt(val[pi])+'</b></div>';\n      band.appendChild(cell);\n      const kn=cell.querySelector('.knob');\n      kn.dataset.pi=pi;\n      knobs[pi]={el:kn,ptr:cell.querySelector('.ptr'),val:cell.querySelector('.val b')};\n      attach(kn,pi);\n    });\n    rack.appendChild(band);\n  });\n\n  function ticks(){\n    let s='';for(let k=0;k<=10;k++){\n      const a=(-135+k*27)*Math.PI/180;\n      const x1=50+Math.sin(a)*46,y1=50-Math.cos(a)*46;\n      const x2=50+Math.sin(a)*40,y2=50-Math.cos(a)*40;\n      s+='<line x1=\"'+x1.toFixed(1)+'\" y1=\"'+y1.toFixed(1)+'\" x2=\"'+x2.toFixed(1)+'\" y2=\"'+y2.toFixed(1)+\n         '\" stroke=\"#3a434f\" stroke-width=\"1.4\"/>';\n    }return s;\n  }\n\n  // ---- knob interaction --------------------------------------------\n  function render(pi){\n    const v=val[pi];const p=P[pi];\n    const ang=-135+v*270;\n    knobs[pi].ptr.style.transform='rotate('+ang+'deg)';\n    knobs[pi].val.textContent=p.fmt(v);\n    // active arc glow on cap intensity\n    knobs[pi].el.querySelector('.cap').style.filter='brightness('+(0.85+0.4*Math.abs(v-(p.unit==='db'?0.5:v?0:0)) ).toFixed(2)+')';\n  }\n  function setV(pi,v,push){\n    v=Math.max(0,Math.min(1,v));\n    val[pi]=v;render(pi);\n    if(push&&window.vstai&&window.vstai.setParam)window.vstai.setParam(P[pi].i,v);\n    drawCurve();\n  }\n  function attach(el,pi){\n    let drag=false,sy=0,sv=0;\n    el.addEventListener('pointerdown',e=>{\n      drag=true;sy=e.clientY;sv=val[pi];el.setPointerCapture(e.pointerId);e.preventDefault();\n    });\n    el.addEventListener('pointermove',e=>{\n      if(!drag)return;\n      const dy=sy-e.clientY;\n      const step=e.shiftKey?0.0008:0.004;\n      setV(pi,sv+dy*step,true);\n    });\n    el.addEventListener('pointerup',e=>{drag=false;el.releasePointerCapture(e.pointerId);});\n    el.addEventListener('dblclick',()=>setV(pi,P[pi].def,true));\n    el.addEventListener('wheel',e=>{e.preventDefault();setV(pi,val[pi]-Math.sign(e.deltaY)*0.02,true);},{passive:false});\n  }\n\n  // ---- EQ response curve -------------------------------------------\n  // frequency axis 20Hz..20kHz log across width\n  const W=560,H=148,N=160,SR=48000;\n  function bandResponse(freqs){\n    // mirror the DSP: HP, low shelf@110, loMid bell, hiMid bell, high shelf@9k\n    const out=new Array(freqs.length).fill(0); // dB\n    const lowDb=(val[0]-0.5)*32, loDb=(val[1]-0.5)*32, hiDb=(val[3]-0.5)*32, hsDb=(val[5]-0.5)*32;\n    const lmF=logmap(val[2],80,2000), hmF=logmap(val[4],600,15000);\n    const hpN=val[6];\n    for(let i=0;i<freqs.length;i++){\n      const f=freqs[i];let db=0;\n      db+=shelfMag(f,110,lowDb,true);\n      db+=peakMag(f,lmF,1.0,loDb);\n      db+=peakMag(f,hmF,1.0,hiDb);\n      db+=shelfMag(f,9000,hsDb,false);\n      if(hpN>=0.02){db+=hpMag(f,logmap(hpN,16,400));}\n      out[i]=db;\n    }\n    return out;\n  }\n  // analytic-ish magnitude approximations (smooth, visual)\n  function peakMag(f,fc,q,g){\n    const x=Math.log2(f/fc), bw=1/q;\n    return g/(1+ (x/(bw*0.7))*(x/(bw*0.7)) );\n  }\n  function shelfMag(f,fc,g,low){\n    const r=Math.log2(f/fc);\n    const t= low ? 1/(1+Math.exp(r*2.2)) : 1/(1+Math.exp(-r*2.2));\n    return g*t;\n  }\n  function hpMag(f,fc){\n    if(f<=0)return -60;\n    const r=f/fc;\n    // 2nd order ~ -12dB/oct\n    return 10*Math.log10( (r*r*r*r) / (1 + r*r*r*r) );\n  }\n\n  const gridSvg=document.getElementById('grid');\n  (function grid(){\n    let s='';\n    // horizontal dB lines (-18,-12,-6,0,+6,+12,+18 -> over ±20 range)\n    for(let d=-18;d<=18;d+=6){\n      const y=H/2 - (d/20)*(H/2-8);\n      const main=d===0;\n      s+='<line x1=\"0\" y1=\"'+y.toFixed(1)+'\" x2=\"'+W+'\" y2=\"'+y.toFixed(1)+\n         '\" stroke=\"'+(main?'#33424f':'#1a2129')+'\" stroke-width=\"'+(main?1.3:1)+'\"/>';\n    }\n    // vertical decade lines 100,1k,10k\n    [100,1000,10000].forEach(fc=>{\n      const x=fx(fc);\n      s+='<line x1=\"'+x.toFixed(1)+'\" y1=\"0\" x2=\"'+x.toFixed(1)+'\" y2=\"'+H+'\" stroke=\"#161d25\"/>';\n    });\n    gridSvg.innerHTML=s;\n  })();\n\n  function fx(f){return (Math.log10(f/20)/Math.log10(20000/20))*W;}\n  function fy(db){return H/2 - (db/20)*(H/2-8);}\n\n  const freqs=[];for(let i=0;i<N;i++){const t=i/(N-1);freqs.push(20*Math.pow(1000,t));}\n  const lineP=document.getElementById('line'),areaP=document.getElementById('area'),nodesG=document.getElementById('nodes');\n\n  function drawCurve(){\n    const mag=bandResponse(freqs);\n    let d='',a='';\n    for(let i=0;i<N;i++){\n      const x=(i/(N-1))*W, y=Math.max(2,Math.min(H-2,fy(mag[i])));\n      d+=(i?'L':'M')+x.toFixed(1)+' '+y.toFixed(1)+' ';\n    }\n    a='M0 '+H+' '+d.replace(/^M/,'L')+'L'+W+' '+H+' Z';\n    lineP.setAttribute('d',d);\n    areaP.setAttribute('d',a);\n    // band node markers (LF shelf, LMF bell, HMF bell, HF shelf)\n    const marks=[\n      {f:110, c:'var(--accent2)'},\n      {f:logmap(val[2],80,2000), c:'var(--accent)'},\n      {f:logmap(val[4],600,15000),c:'var(--green)'},\n      {f:9000, c:'var(--accent2)'}\n    ];\n    let g='';\n    marks.forEach(m=>{\n      // sample curve magnitude near f\n      const t=Math.log10(m.f/20)/Math.log10(1000);\n      const idx=Math.max(0,Math.min(N-1,Math.round(t*(N-1))));\n      const x=fx(m.f),y=Math.max(4,Math.min(H-4,fy(mag[idx])));\n      g+='<circle cx=\"'+x.toFixed(1)+'\" cy=\"'+y.toFixed(1)+'\" r=\"3.4\" fill=\"'+m.c+\n         '\" stroke=\"#05080c\" stroke-width=\"1\" style=\"filter:drop-shadow(0 0 5px '+m.c+')\"/>';\n    });\n    nodesG.innerHTML=g;\n  }\n\n  // ---- host wiring --------------------------------------------------\n  function start(){\n    for(let i=0;i<P.length;i++){\n      // init host param to default\n      if(window.vstai&&window.vstai.setParam)window.vstai.setParam(P[i].i,val[i]);\n      render(i);\n    }\n    drawCurve();\n  }\n  if(window.vstai&&typeof window.vstai.onReady==='function')window.vstai.onReady(start);\n  else start();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  STRIP EQ — British console channel-strip equaliser\n//  A full mixing-desk channel EQ: a low shelf, two swept parametric MID\n//  bells (low-mid + high-mid, each with gain + frequency), a high shelf,\n//  plus a sweepable high-pass filter to clean the bottom. Clean, surgical\n//  and punchy — RBJ biquads in series, all f32. Pure algorithm.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- Parameter indices ----------------------------------------------\nconst P_LOW:       i32 = 0; // low shelf gain      0..1 -> -16..+16 dB\nconst P_LOMID:     i32 = 1; // low-mid bell gain   0..1 -> -16..+16 dB\nconst P_LOMID_F:   i32 = 2; // low-mid frequency   0..1 -> 80..2000 Hz (log)\nconst P_HIMID:     i32 = 3; // high-mid bell gain  0..1 -> -16..+16 dB\nconst P_HIMID_F:   i32 = 4; // high-mid frequency  0..1 -> 600..15000 Hz (log)\nconst P_HIGH:      i32 = 5; // high shelf gain     0..1 -> -16..+16 dB\nconst P_HP:        i32 = 6; // high-pass freq      0..1 -> 16..400 Hz (log), <0.02 = off\nconst P_OUTPUT:    i32 = 7; // output trim         0..1 -> -inf..+12 dB\n\n// ---- Biquad state (per channel) -------------------------------------\n// 5 cascaded sections: HP, low shelf, low-mid bell, high-mid bell, high shelf\nconst NSEC: i32 = 5;\nconst z1: StaticArray<f32> = new StaticArray<f32>(NSEC * MAX_CHANNELS);\nconst z2: StaticArray<f32> = new StaticArray<f32>(NSEC * MAX_CHANNELS);\n\n// ---- Biquad coefficients (shared across channels, recomputed per block)\nconst cb0: StaticArray<f32> = new StaticArray<f32>(NSEC);\nconst cb1: StaticArray<f32> = new StaticArray<f32>(NSEC);\nconst cb2: StaticArray<f32> = new StaticArray<f32>(NSEC);\nconst ca1: StaticArray<f32> = new StaticArray<f32>(NSEC);\nconst ca2: StaticArray<f32> = new StaticArray<f32>(NSEC);\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// log map: t in [0,1] -> [lo,hi] geometrically\n@inline function logMap(t: f32, lo: f32, hi: f32): f32 {\n  return f32(lo * Mathf.exp(clampf(t, 0.0, 1.0) * f32(Mathf.log(hi / lo))));\n}\n\n@inline function dbToGain(db: f32): f32 {\n  return f32(Mathf.exp(db * 0.11512925)); // 10^(db/20) = e^(db*ln10/20)\n}\n\n// --- Coefficient setters (RBJ cookbook, normalised by a0) -------------\nfunction setPeaking(s: i32, freq: f32, q: f32, gainDb: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(gainDb)));\n  const w0: f32 = 2.0 * PI * freq / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw / (2.0 * q);\n  const a0: f32 = 1.0 + alpha / A;\n  const inv: f32 = 1.0 / a0;\n  cb0[s] = (1.0 + alpha * A) * inv;\n  cb1[s] = (-2.0 * cw) * inv;\n  cb2[s] = (1.0 - alpha * A) * inv;\n  ca1[s] = (-2.0 * cw) * inv;\n  ca2[s] = (1.0 - alpha / A) * inv;\n}\n\nfunction setLowShelf(s: i32, freq: f32, gainDb: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(gainDb)));\n  const w0: f32 = 2.0 * PI * freq / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt(2.0)); // Q ~ 0.707\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n  const ap1: f32 = A + 1.0;\n  const am1: f32 = A - 1.0;\n  const a0: f32 = ap1 + am1 * cw + tsa;\n  const inv: f32 = 1.0 / a0;\n  cb0[s] = (A * (ap1 - am1 * cw + tsa)) * inv;\n  cb1[s] = (2.0 * A * (am1 - ap1 * cw)) * inv;\n  cb2[s] = (A * (ap1 - am1 * cw - tsa)) * inv;\n  ca1[s] = (-2.0 * (am1 + ap1 * cw)) * inv;\n  ca2[s] = (ap1 + am1 * cw - tsa) * inv;\n}\n\nfunction setHighShelf(s: i32, freq: f32, gainDb: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(gainDb)));\n  const w0: f32 = 2.0 * PI * freq / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt(2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n  const ap1: f32 = A + 1.0;\n  const am1: f32 = A - 1.0;\n  const a0: f32 = ap1 - am1 * cw + tsa;\n  const inv: f32 = 1.0 / a0;\n  cb0[s] = (A * (ap1 + am1 * cw + tsa)) * inv;\n  cb1[s] = (-2.0 * A * (am1 + ap1 * cw)) * inv;\n  cb2[s] = (A * (ap1 + am1 * cw - tsa)) * inv;\n  ca1[s] = (2.0 * (am1 - ap1 * cw)) * inv;\n  ca2[s] = (ap1 - am1 * cw - tsa) * inv;\n}\n\nfunction setHighPass(s: i32, freq: f32, q: f32): void {\n  const w0: f32 = 2.0 * PI * freq / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw / (2.0 * q);\n  const a0: f32 = 1.0 + alpha;\n  const inv: f32 = 1.0 / a0;\n  cb0[s] = ((1.0 + cw) * 0.5) * inv;\n  cb1[s] = (-(1.0 + cw)) * inv;\n  cb2[s] = ((1.0 + cw) * 0.5) * inv;\n  ca1[s] = (-2.0 * cw) * inv;\n  ca2[s] = (1.0 - alpha) * inv;\n}\n\nfunction setBypass(s: i32): void {\n  cb0[s] = 1.0; cb1[s] = 0.0; cb2[s] = 0.0; ca1[s] = 0.0; ca2[s] = 0.0;\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < NSEC * MAX_CHANNELS; i++) { z1[i] = 0.0; z2[i] = 0.0; }\n  params[P_LOW] = 0.5; params[P_LOMID] = 0.5; params[P_LOMID_F] = 0.3;\n  params[P_HIMID] = 0.5; params[P_HIMID_F] = 0.5; params[P_HIGH] = 0.5;\n  params[P_HP] = 0.0; params[P_OUTPUT] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 8; }\n\nexport function process(n: i32): void {\n  // --- map params to physical values ---\n  const lowDb:   f32 = (clampf(params[P_LOW],   0.0, 1.0) - 0.5) * 32.0;  // -16..+16\n  const loMidDb: f32 = (clampf(params[P_LOMID], 0.0, 1.0) - 0.5) * 32.0;\n  const loMidF:  f32 = logMap(params[P_LOMID_F], 80.0, 2000.0);\n  const hiMidDb: f32 = (clampf(params[P_HIMID], 0.0, 1.0) - 0.5) * 32.0;\n  const hiMidF:  f32 = logMap(params[P_HIMID_F], 600.0, 15000.0);\n  const highDb:  f32 = (clampf(params[P_HIGH],  0.0, 1.0) - 0.5) * 32.0;\n  const hpN:     f32 = clampf(params[P_HP], 0.0, 1.0);\n\n  // output: 0->-inf-ish (silence), 0.5->0dB, 1->+12dB\n  const outN: f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n  let outGain: f32;\n  if (outN <= 0.001) outGain = 0.0;\n  else outGain = dbToGain((outN - 0.5) * 24.0);\n\n  // --- compute coefficients ---\n  // section 0: high-pass (or bypass when nearly off)\n  if (hpN < 0.02) setBypass(0);\n  else setHighPass(0, logMap(hpN, 16.0, 400.0), 0.707);\n  // section 1: low shelf @ 110 Hz\n  setLowShelf(1, 110.0, lowDb);\n  // section 2: low-mid bell (swept), moderate Q\n  setPeaking(2, loMidF, 1.0, loMidDb);\n  // section 3: high-mid bell (swept)\n  setPeaking(3, hiMidF, 1.0, hiMidDb);\n  // section 4: high shelf @ 9 kHz\n  setHighShelf(4, 9000.0, highDb);\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    for (let f = 0; f < n; f++) {\n      let x: f32 = inBuf[base + f];\n      // cascade of NSEC transposed-direct-form-II biquads\n      for (let s = 0; s < NSEC; s++) {\n        const si: i32 = s * MAX_CHANNELS + c;\n        const y: f32 = cb0[s] * x + z1[si];\n        z1[si] = cb1[s] * x - ca1[s] * y + z2[si];\n        z2[si] = cb2[s] * x - ca2[s] * y;\n        x = y;\n      }\n      x = x * outGain;\n      // safety clamp (clean — never clip in normal use)\n      outBuf[base + f] = clampf(x, -1.5, 1.5);\n    }\n  }\n}\n",
  "publishedAt": 1751000126000
}