{
  "format": 1,
  "name": "Wide Ensemble",
  "isInstrument": false,
  "explanation": "A lush bucket-brigade (BBD) stereo chorus ensemble with a vibrato mode. A mono-summed input is fanned into a wide stereo image by two modulated delay lines whose sweep runs in anti-phase on the left and right, so the channels swirl against each other for a big ensemble. The Mode control morphs from chorus (dry plus modulated taps) to vibrato (pure modulated tap, so the whole signal pitch-wobbles). A BBD-darkness Tone low-passes the wet path and a soft saturation emulates compander grit for warm analog character. Controls: Rate, Depth, Mode, Tone and dry/wet Mix.",
  "params": [
    {
      "name": "Rate",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.32
    },
    {
      "name": "Depth",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Mode",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.85
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Wide Ensemble</title>\n<style>\n  :root{\n    --acc:#5ad0ff; --acc2:#9a7bff;\n    --cream:#efe6d2; --cream2:#e3d6bb; --ink:#2a2418;\n    --chrome1:#fbfdff; --chrome2:#aeb6bf; --chrome3:#6c747d;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none}\n  html,body{height:100%}\n  body{\n    font-family:\"Avenir Next\",\"Helvetica Neue\",Arial,sans-serif;\n    background:radial-gradient(120% 140% at 50% -10%,#3a4350 0%,#1a1d22 55%,#0c0e11 100%);\n    color:var(--ink); display:flex; align-items:center; justify-content:center;\n    padding:18px; overflow:hidden;\n  }\n\n  /* ---------- the unit ---------- */\n  .unit{\n    width:560px; border-radius:18px; position:relative;\n    background:\n      linear-gradient(180deg,#f6efde 0%,var(--cream) 18%,var(--cream2) 82%,#cdbe9d 100%);\n    box-shadow:\n      0 26px 60px rgba(0,0,0,.55),\n      0 2px 0 rgba(255,255,255,.6) inset,\n      0 -3px 14px rgba(0,0,0,.22) inset;\n    border:1px solid #b7a884;\n    padding:18px 20px 22px;\n  }\n  /* faint speckled vintage texture */\n  .unit::before{\n    content:\"\"; position:absolute; inset:0; border-radius:18px; pointer-events:none;\n    background-image:radial-gradient(rgba(120,100,60,.10) 1px,transparent 1px);\n    background-size:5px 5px; opacity:.5; mix-blend-mode:multiply;\n  }\n  /* corner screws */\n  .screw{position:absolute;width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff,#9a9088 60%,#5c554b);\n    box-shadow:0 1px 2px rgba(0,0,0,.4),0 0 0 1px rgba(0,0,0,.15);}\n  .screw::after{content:\"\";position:absolute;inset:3px;border-top:1.5px solid #6a6258;transform:rotate(35deg);border-radius:2px}\n  .screw.tl{top:8px;left:8px}.screw.tr{top:8px;right:8px}\n  .screw.bl{bottom:8px;left:8px}.screw.br{bottom:8px;right:8px}\n\n  /* ---------- header ---------- */\n  .head{display:flex;align-items:center;justify-content:space-between;margin:2px 6px 14px}\n  .brand{display:flex;flex-direction:column;gap:1px}\n  .brand .mk{font-size:10px;letter-spacing:3px;color:#8a7c5c;font-weight:700}\n  .brand h1{\n    font-size:25px;font-weight:800;letter-spacing:.5px;\n    color:#23201a;text-shadow:0 1px 0 rgba(255,255,255,.55);\n  }\n  .brand h1 .b{\n    background:linear-gradient(90deg,var(--acc),var(--acc2));\n    -webkit-background-clip:text;background-clip:text;color:transparent;\n  }\n  .badge{\n    font-size:9px;letter-spacing:2px;color:#7a6e50;border:1px solid #b3a583;\n    padding:4px 8px;border-radius:20px;background:rgba(255,255,255,.35);text-align:right;line-height:1.5\n  }\n\n  /* ---------- stereo scope ---------- */\n  .scope{\n    position:relative;height:150px;border-radius:12px;overflow:hidden;margin:0 0 16px;\n    background:linear-gradient(180deg,#0c1620,#12202c 50%,#0a141c);\n    box-shadow:0 2px 10px rgba(0,0,0,.5) inset,0 0 0 1px #2b2316,0 1px 0 rgba(255,255,255,.4);\n    border:3px solid #1b160d;\n  }\n  .scope svg{position:absolute;inset:0;width:100%;height:100%}\n  .glass{position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(120deg,rgba(255,255,255,.10),transparent 40%);}\n  .lbl{position:absolute;font-size:9px;letter-spacing:2px;color:rgba(140,200,235,.55);top:7px}\n  .lbl.l{left:9px}.lbl.r{right:9px}\n  .lbl.mid{left:50%;transform:translateX(-50%);bottom:6px;top:auto;color:rgba(160,150,235,.55)}\n\n  /* ---------- mode rocker ---------- */\n  .moderow{display:flex;align-items:center;gap:14px;margin:0 4px 16px}\n  .rocker{\n    position:relative;width:188px;height:42px;border-radius:24px;cursor:pointer;\n    background:linear-gradient(180deg,#cfc09f,#b7a67f);\n    box-shadow:0 2px 5px rgba(0,0,0,.35) inset,0 1px 0 rgba(255,255,255,.5);\n    border:1px solid #9c8c66;overflow:hidden;flex:none;\n  }\n  .rocker .track{position:absolute;inset:4px;border-radius:20px;display:flex}\n  .rocker .opt{flex:1;display:flex;align-items:center;justify-content:center;\n    font-size:10px;letter-spacing:2px;font-weight:800;color:#6d6044;z-index:2;transition:color .25s}\n  .rocker .opt.on{color:#0b1a22}\n  .rocker .knobcap{\n    position:absolute;top:3px;left:3px;width:50%;height:calc(100% - 6px);border-radius:18px;\n    background:linear-gradient(180deg,var(--chrome1),var(--chrome2) 55%,var(--chrome3));\n    box-shadow:0 2px 6px rgba(0,0,0,.4),0 1px 0 rgba(255,255,255,.8) inset;\n    transition:transform .32s cubic-bezier(.5,1.6,.4,1),background .3s;z-index:1;\n  }\n  .rocker.vib .knobcap{transform:translateX(calc(100% - 6px));\n    background:linear-gradient(180deg,#dfe6ff,#b9a8ff 55%,#7c63d4);}\n  .modeval{font-size:10px;color:#6c5f44;letter-spacing:1px}\n  .modeval b{color:#3a3324}\n\n  /* ---------- knob row ---------- */\n  .knobs{display:flex;justify-content:space-between;gap:10px;padding:4px 2px 0}\n  .ctl{display:flex;flex-direction:column;align-items:center;gap:7px;flex:1}\n  .dial{\n    --a:135deg; position:relative;width:84px;height:84px;border-radius:50%;cursor:grab;\n    background:\n      radial-gradient(circle at 50% 38%,#fafafa,#dfe3e7 42%,#aab1b8 70%,#7d848b 100%);\n    box-shadow:0 6px 12px rgba(0,0,0,.4),0 1px 0 rgba(255,255,255,.9) inset,0 -3px 8px rgba(0,0,0,.25) inset;\n    border:1px solid #6b727a;touch-action:none;\n  }\n  .dial:active{cursor:grabbing}\n  .dial .ring{position:absolute;inset:-7px;border-radius:50%;pointer-events:none}\n  .dial .cap{position:absolute;inset:13px;border-radius:50%;\n    background:radial-gradient(circle at 42% 32%,#fff,#e7eaee 45%,#c2c8ce 78%,#9aa1a8);\n    box-shadow:0 1px 3px rgba(0,0,0,.3) inset;}\n  .dial .ptr{position:absolute;left:50%;top:9px;width:4px;height:24px;margin-left:-2px;\n    border-radius:3px;background:linear-gradient(180deg,var(--acc),var(--acc2));\n    transform-origin:50% 33px;box-shadow:0 0 7px var(--acc);}\n  .ctl .nm{font-size:10px;letter-spacing:2px;font-weight:800;color:#564a32}\n  .ctl .vl{font-size:11px;font-variant-numeric:tabular-nums;color:#2c2618;\n    background:rgba(255,255,255,.45);padding:1px 8px;border-radius:9px;min-width:46px;text-align:center;\n    border:1px solid rgba(120,100,60,.25)}\n\n  .foot{display:flex;justify-content:space-between;align-items:center;margin:16px 6px 0;\n    font-size:9px;letter-spacing:2px;color:#9a8c6c}\n  .led{display:inline-block;width:8px;height:8px;border-radius:50%;\n    background:var(--acc);box-shadow:0 0 8px var(--acc);animation:pulse 2.2s ease-in-out infinite;margin-right:6px;vertical-align:middle}\n  @keyframes pulse{0%,100%{opacity:.45}50%{opacity:1}}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n\n    <div class=\"head\">\n      <div class=\"brand\">\n        <div class=\"mk\">BBD STEREO CHORUS</div>\n        <h1>WIDE <span class=\"b\">ENSEMBLE</span></h1>\n      </div>\n      <div class=\"badge\">ANALOG<br>ENSEMBLE</div>\n    </div>\n\n    <div class=\"scope\">\n      <svg viewBox=\"0 0 560 150\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"gl\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#5ad0ff\" stop-opacity=\"0\"/>\n            <stop offset=\".5\" stop-color=\"#5ad0ff\" stop-opacity=\"1\"/>\n            <stop offset=\"1\" stop-color=\"#5ad0ff\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <linearGradient id=\"gr\" x1=\"0\" x2=\"1\">\n            <stop offset=\"0\" stop-color=\"#9a7bff\" stop-opacity=\"0\"/>\n            <stop offset=\".5\" stop-color=\"#9a7bff\" stop-opacity=\"1\"/>\n            <stop offset=\"1\" stop-color=\"#9a7bff\" stop-opacity=\"0\"/>\n          </linearGradient>\n        </defs>\n        <line x1=\"0\" y1=\"75\" x2=\"560\" y2=\"75\" stroke=\"rgba(120,160,190,.18)\" stroke-width=\"1\"/>\n        <path id=\"waveL\" fill=\"none\" stroke=\"url(#gl)\" stroke-width=\"2.2\" opacity=\".95\"/>\n        <path id=\"waveR\" fill=\"none\" stroke=\"url(#gr)\" stroke-width=\"2.2\" opacity=\".95\"/>\n        <path id=\"waveLg\" fill=\"none\" stroke=\"#5ad0ff\" stroke-width=\"6\" opacity=\".10\"/>\n        <path id=\"waveRg\" fill=\"none\" stroke=\"#9a7bff\" stroke-width=\"6\" opacity=\".10\"/>\n      </svg>\n      <div class=\"glass\"></div>\n      <div class=\"lbl l\">LEFT</div>\n      <div class=\"lbl r\">RIGHT</div>\n      <div class=\"lbl mid\" id=\"modetag\">CHORUS · WIDE</div>\n    </div>\n\n    <div class=\"moderow\">\n      <div class=\"rocker\" id=\"rocker\">\n        <div class=\"knobcap\"></div>\n        <div class=\"track\">\n          <div class=\"opt on\" data-m=\"0\">CHORUS</div>\n          <div class=\"opt\" data-m=\"1\">VIBRATO</div>\n        </div>\n      </div>\n      <div class=\"modeval\">MODE&nbsp; <b id=\"modeNum\">0%</b> &nbsp;swirl→wobble</div>\n    </div>\n\n    <div class=\"knobs\" id=\"knobs\"></div>\n\n    <div class=\"foot\">\n      <span><span class=\"led\"></span>BUCKET-BRIGADE</span>\n      <span>WIDE ENSEMBLE · MK I</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n  // host bridge ------------------------------------------------------\n  function send(i,v){ if(window.vstai&&window.vstai.setParam) window.vstai.setParam(i,v); }\n\n  // params: index, name, default, value-formatter -------------------\n  var SPEC=[\n    {i:0,nm:\"RATE\", def:0.32, fmt:function(v){return (0.05+v*v*5.95).toFixed(2)+\" Hz\";}},\n    {i:1,nm:\"DEPTH\",def:0.55, fmt:function(v){return Math.round(v*100)+\"%\";}},\n    {i:3,nm:\"TONE\", def:0.45, fmt:function(v){return Math.round(v*100)+\"%\";}},\n    {i:4,nm:\"MIX\",  def:0.85, fmt:function(v){return Math.round(v*100)+\"%\";}}\n  ];\n  var MODE={i:2,def:0,val:0};\n  var state={}; // index -> value\n  state[0]=SPEC[0].def; state[1]=SPEC[1].def; state[3]=SPEC[2].def; state[4]=SPEC[3].def;\n  state[2]=MODE.def;\n\n  // build knobs ------------------------------------------------------\n  var host=document.getElementById(\"knobs\");\n  var dials={};\n  SPEC.forEach(function(p){\n    var ctl=document.createElement(\"div\"); ctl.className=\"ctl\";\n    ctl.innerHTML=\n      '<div class=\"dial\"><div class=\"cap\"></div><div class=\"ptr\"></div></div>'+\n      '<div class=\"nm\">'+p.nm+'</div><div class=\"vl\"></div>';\n    host.appendChild(ctl);\n    var dial=ctl.querySelector(\".dial\");\n    var ptr =ctl.querySelector(\".ptr\");\n    var vl  =ctl.querySelector(\".vl\");\n    dials[p.i]={dial:dial,ptr:ptr,vl:vl,p:p};\n\n    function render(v){\n      var deg=-135+v*270;\n      ptr.style.transform=\"rotate(\"+deg+\"deg)\";\n      // conic progress ring\n      dial.style.background=\n        \"radial-gradient(circle at 50% 38%,#fafafa,#dfe3e7 42%,#aab1b8 70%,#7d848b 100%)\";\n      dial.querySelector('.cap');\n      var ring=dial.querySelector('.ring');\n      if(!ring){ring=document.createElement('div');ring.className='ring';dial.appendChild(ring);}\n      var a=v*270;\n      ring.style.background=\"conic-gradient(from 225deg,var(--acc) 0deg,var(--acc2) \"+a+\"deg,transparent \"+a+\"deg)\";\n      ring.style.mask=\"radial-gradient(circle,transparent 39px,#000 40px,#000 44px,transparent 45px)\";\n      ring.style.webkitMask=ring.style.mask;\n      ring.style.opacity=.85;\n      vl.textContent=p.fmt(v);\n    }\n    function set(v,silent){\n      v=Math.max(0,Math.min(1,v));\n      state[p.i]=v; render(v);\n      if(!silent) send(p.i,v);\n    }\n    p._set=set; p._render=render;\n    set(state[p.i],true);\n\n    // drag --------------------------------------------------------\n    var dragging=false,startY=0,startV=0;\n    function down(e){\n      dragging=true; startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startV=state[p.i]; e.preventDefault();\n      document.body.style.cursor=\"grabbing\";\n    }\n    function move(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/180;\n      set(startV+dv);\n      e.preventDefault();\n    }\n    function up(){dragging=false;document.body.style.cursor=\"\";}\n    dial.addEventListener(\"mousedown\",down);\n    dial.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"mouseup\",up);\n    window.addEventListener(\"touchend\",up);\n    dial.addEventListener(\"dblclick\",function(){set(p.def);});\n    dial.addEventListener(\"wheel\",function(e){\n      set(state[p.i]-e.deltaY*0.0012);e.preventDefault();\n    },{passive:false});\n  });\n\n  // mode rocker ------------------------------------------------------\n  var rocker=document.getElementById(\"rocker\");\n  var modeNum=document.getElementById(\"modeNum\");\n  var modetag=document.getElementById(\"modetag\");\n  var opts=rocker.querySelectorAll(\".opt\");\n  function setMode(v,silent){\n    v=Math.max(0,Math.min(1,v));\n    MODE.val=v; state[2]=v;\n    rocker.classList.toggle(\"vib\",v>=0.5);\n    opts[0].classList.toggle(\"on\",v<0.5);\n    opts[1].classList.toggle(\"on\",v>=0.5);\n    modeNum.textContent=Math.round(v*100)+\"%\";\n    modetag.textContent = v<0.5 ? \"CHORUS · WIDE\" : \"VIBRATO · WOBBLE\";\n    if(!silent) send(2,v);\n  }\n  // click toggles 0<->1; drag horizontally to blend\n  var rdrag=false,rsx=0,rsv=0,moved=false;\n  rocker.addEventListener(\"mousedown\",function(e){rdrag=true;moved=false;rsx=e.clientX;rsv=MODE.val;e.preventDefault();});\n  window.addEventListener(\"mousemove\",function(e){\n    if(!rdrag)return; var dv=(e.clientX-rsx)/170; if(Math.abs(e.clientX-rsx)>3)moved=true;\n    setMode(rsv+dv);\n  });\n  window.addEventListener(\"mouseup\",function(){\n    if(rdrag&&!moved){ setMode(MODE.val<0.5?1:0); }\n    rdrag=false;\n  });\n  rocker.addEventListener(\"dblclick\",function(){setMode(0);});\n\n  // ---------- animated stereo waveforms ----------\n  var wL=document.getElementById(\"waveL\"),wR=document.getElementById(\"waveR\");\n  var wLg=document.getElementById(\"waveLg\"),wRg=document.getElementById(\"waveRg\");\n  var W=560,H=150,MID=75,N=70;\n  var t0=performance.now();\n  function path(phaseSign,depth,extra){\n    var d=\"M0 \"+MID, amp=22*depth+4;\n    for(var k=0;k<=N;k++){\n      var x=k/N*W;\n      var env=Math.sin(Math.PI*k/N); // taper at edges\n      // base carrier + slow LFO swirl (anti-phase via phaseSign)\n      var y=MID\n        + Math.sin(k*0.55 + extra*3.0) * amp*env\n        + phaseSign*Math.sin(extra*1.0 + k*0.16) * (10+18*depth)*env;\n      d+=\" L\"+x.toFixed(1)+\" \"+y.toFixed(1);\n    }\n    return d;\n  }\n  function frame(now){\n    var t=(now-t0)/1000;\n    var rate=0.05+state[0]*state[0]*5.95;       // Hz, matches DSP\n    var depth=state[1]*(1+0.8*state[2]);         // vibrato deepens\n    var ph=t*rate;\n    var dl=path( 1,depth,ph), dr=path(-1,depth,ph);\n    wL.setAttribute(\"d\",dl); wLg.setAttribute(\"d\",dl);\n    wR.setAttribute(\"d\",dr); wRg.setAttribute(\"d\",dr);\n    // tone affects line brightness/opacity\n    var op=0.45+0.5*state[3];\n    wL.style.opacity=op; wR.style.opacity=op;\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---------- init / push defaults ----------\n  function ready(){\n    SPEC.forEach(function(p){ p._set(state[p.i]); });\n    setMode(MODE.def);\n  }\n  if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  WIDE ENSEMBLE — lush BBD stereo chorus ensemble + vibrato\n//\n//  A mono-summed input is fanned into a WIDE stereo chorus: two BBD-style\n//  modulated delay lines (L / R) swept by the SAME LFO but in ANTI-PHASE,\n//  so the two channels swirl against each other for a big ensemble image.\n//  A Mode control morphs from CHORUS (dry + modulated taps) to VIBRATO\n//  (pure modulated tap → the whole signal pitch-wobbles). A BBD-darkness\n//  Tone low-passes the delayed (wet) path for warm analog character, and\n//  a soft saturation on the delay line emulates BBD companding grit.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\n// modulated delay line length (per channel). BBD chorus uses short delays;\n// ~30 ms max @ 48k -> 1536 samples; round up generously.\nconst DLINE: i32 = 2048;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// two delay lines (L, R), each DLINE long\nconst dL: StaticArray<f32> = new StaticArray<f32>(DLINE);\nconst dR: StaticArray<f32> = new StaticArray<f32>(DLINE);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writeIdx: i32 = 0;\nlet lfoPhase: f32 = 0.0;\nlet toneL: f32 = 0.0;   // BBD tone low-pass state (wet path) per channel\nlet toneR: f32 = 0.0;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst P_RATE: i32 = 0;  // 0..1 -> LFO 0.05..6 Hz\nconst P_DEPTH: i32 = 1; // 0..1 -> sweep depth\nconst P_MODE: i32 = 2;  // 0..1 -> chorus(0) <-> vibrato(1) blend\nconst P_TONE: i32 = 3;  // 0..1 -> BBD darkness (wet LP 700..9000 Hz)\nconst P_MIX: i32 = 4;   // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DLINE; i++) { dL[i] = 0.0; dR[i] = 0.0; }\n  writeIdx = 0;\n  lfoPhase = 0.0;\n  toneL = 0.0; toneR = 0.0;\n  params[P_RATE] = 0.32; params[P_DEPTH] = 0.55; params[P_MODE] = 0.0;\n  params[P_TONE] = 0.45; params[P_MIX] = 0.85;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// soft saturation emulating BBD compander grit; bounded to ~±1\n@inline function bbdSat(x: f32): f32 {\n  const c: f32 = clampf(x, -1.5, 1.5);\n  return c - 0.16666667 * c * c * c;\n}\n\n// fractional read from a delay line, linear interpolation, wrapping\n@inline function readFrac(d: StaticArray<f32>, w: i32, delay: f32): f32 {\n  let rp: f32 = f32(w) - delay;\n  while (rp < 0.0) rp += f32(DLINE);\n  const i0: i32 = i32(rp);\n  const frac: f32 = rp - f32(i0);\n  let i1: i32 = i0 + 1; if (i1 >= DLINE) i1 -= DLINE;\n  let ii0: i32 = i0; if (ii0 >= DLINE) ii0 -= DLINE;\n  return d[ii0] + (d[i1] - d[ii0]) * frac;\n}\n\nexport function process(n: i32): void {\n  const rateN:  f32 = clampf(params[P_RATE], 0.0, 1.0);\n  const depthN: f32 = clampf(params[P_DEPTH], 0.0, 1.0);\n  const modeN:  f32 = clampf(params[P_MODE], 0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix:    f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // LFO rate: 0.05 .. 6 Hz, exponential feel\n  const rateHz: f32 = 0.05 + rateN * rateN * 5.95;\n  const phInc: f32 = TWO_PI * rateHz / sampleRate;\n\n  // BBD base delay (~7 ms) and sweep span. Vibrato deepens the sweep.\n  const baseMs: f32 = 7.0;\n  const baseSamp: f32 = baseMs * 0.001 * sampleRate;\n  // depth in samples; vibrato mode pushes a deeper sweep for stronger pitch wobble\n  const depthSamp: f32 = (0.6 + 3.4 * depthN) * 0.001 * sampleRate * (1.0 + 1.4 * modeN);\n\n  // BBD tone low-pass on the wet path: darker (700 Hz) .. brighter (9000 Hz)\n  const toneHz: f32 = 700.0 + toneN * toneN * 8300.0;\n  const cTone: f32 = f32(1.0 - Mathf.exp(-TWO_PI * toneHz / sampleRate));\n\n  // mode blend: chorus keeps dry-in-wet, vibrato removes it (pure modulated)\n  const dryInWet: f32 = 1.0 - modeN; // 1 at chorus, 0 at vibrato\n\n  let ph: f32 = lfoPhase;\n  let w: i32 = writeIdx;\n  let tL: f32 = toneL;\n  let tR: f32 = toneR;\n\n  const stereo: bool = channels > 1;\n\n  for (let f = 0; f < n; f++) {\n    const xl: f32 = inBuf[f];\n    const xr: f32 = stereo ? inBuf[MAX_FRAMES + f] : xl;\n    // mono sum drives the ensemble (a mono input fanned wide)\n    const mono: f32 = (xl + xr) * 0.5;\n\n    // write input (with gentle BBD saturation) into both delay lines\n    const din: f32 = bbdSat(mono);\n    dL[w] = din;\n    dR[w] = din;\n\n    // anti-phase LFO: L uses +sin, R uses -sin → opposite swirl = WIDE image\n    const sinv: f32 = f32(Mathf.sin(ph));\n    const delL: f32 = baseSamp + depthSamp * (0.5 + 0.5 * sinv);\n    const delR: f32 = baseSamp + depthSamp * (0.5 - 0.5 * sinv);\n\n    let wetL: f32 = readFrac(dL, w, delL);\n    let wetR: f32 = readFrac(dR, w, delR);\n\n    // BBD darkness tone shaping on the wet path\n    tL = tL + cTone * (wetL - tL);\n    tR = tR + cTone * (wetR - tR);\n    wetL = tL;\n    wetR = tR;\n\n    // chorus = dry + wet; vibrato = wet only. modeN morphs between them.\n    // normalise so chorus and vibrato sit at similar level (chorus ≈ /1.6).\n    const ensL: f32 = (dryInWet * mono + wetL) * (1.0 / (1.0 + 0.6 * dryInWet));\n    const ensR: f32 = (dryInWet * mono + wetR) * (1.0 / (1.0 + 0.6 * dryInWet));\n\n    // dry/wet mix against the ORIGINAL (true-stereo) input\n    outBuf[f]              = xl * (1.0 - mix) + ensL * mix;\n    if (stereo) outBuf[MAX_FRAMES + f] = xr * (1.0 - mix) + ensR * mix;\n\n    // advance\n    ph += phInc; if (ph >= TWO_PI) ph -= TWO_PI;\n    w++; if (w >= DLINE) w = 0;\n  }\n\n  lfoPhase = ph;\n  writeIdx = w;\n  toneL = tL;\n  toneR = tR;\n}\n",
  "publishedAt": 1751000129000
}