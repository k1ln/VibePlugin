{
  "format": 1,
  "name": "Iron Drive",
  "isInstrument": false,
  "explanation": "Transformer-style iron-core saturation. The iron saturates earliest in the lows, so a tunable low-end push is fed back into the drive stage, a hysteresis-flavoured soft saturator adds asymmetric even + odd harmonic warmth, and a gentle high-frequency rounding tames the top. A post Tone tilt, dry/wet Mix and Output trim finish it. Controls: Drive, Low, Tone, Mix and Output.",
  "params": [
    {
      "name": "Drive",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Low",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Tone",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Output",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.55
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Iron Drive</title>\n<style>\n  :root {\n    --accent: #cf7a3a;\n    --accent2: #e0a860;\n    --iron0: #1b1714;\n    --iron1: #261f19;\n    --iron2: #322820;\n    --copper: #b9763f;\n    --ink: #f3e4cf;\n    --ink-dim: #b39a7e;\n    --line: rgba(224,168,96,0.14);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    min-height: 100%;\n    background: #0d0a08;\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    display: flex;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .unit {\n    width: 100%;\n    max-width: 560px;\n    border-radius: 16px;\n    padding: 20px 22px 24px;\n    position: relative;\n    overflow: hidden;\n    background:\n      radial-gradient(120% 90% at 50% -10%, rgba(207,122,58,0.18), transparent 55%),\n      linear-gradient(160deg, var(--iron2), var(--iron1) 45%, var(--iron0));\n    border: 1px solid rgba(224,168,96,0.18);\n    box-shadow:\n      0 20px 50px rgba(0,0,0,0.6),\n      inset 0 1px 0 rgba(255,220,180,0.08),\n      inset 0 -2px 8px rgba(0,0,0,0.5);\n  }\n\n  /* faint brushed-iron texture */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image: repeating-linear-gradient(\n      90deg,\n      rgba(255,255,255,0.012) 0px,\n      rgba(255,255,255,0.012) 1px,\n      transparent 1px,\n      transparent 3px);\n    pointer-events: none;\n    mix-blend-mode: overlay;\n  }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .brand { display: flex; align-items: baseline; gap: 10px; }\n\n  .brand h1 {\n    margin: 0;\n    font-size: 22px;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    font-weight: 800;\n    background: linear-gradient(180deg, #f6e2c6, var(--accent2));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.4);\n  }\n\n  .brand .sub {\n    font-size: 9px;\n    letter-spacing: 0.32em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .badge {\n    font-size: 9px;\n    letter-spacing: 0.28em;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid var(--line);\n    padding: 5px 9px;\n    border-radius: 999px;\n    background: rgba(0,0,0,0.25);\n  }\n\n  /* ---- transformer core visual ---- */\n  .core {\n    position: relative;\n    margin: 16px auto 8px;\n    width: 100%;\n    height: 150px;\n    border-radius: 12px;\n    background:\n      radial-gradient(80% 120% at 50% 50%, rgba(40,30,22,0.9), rgba(12,9,7,0.95));\n    border: 1px solid rgba(224,168,96,0.12);\n    box-shadow: inset 0 2px 14px rgba(0,0,0,0.7);\n    overflow: hidden;\n  }\n\n  .core svg { display: block; width: 100%; height: 100%; }\n\n  /* warm low-end bloom that pulses with Low */\n  .bloom {\n    position: absolute;\n    left: 50%;\n    bottom: -40%;\n    width: 70%;\n    height: 90%;\n    transform: translateX(-50%);\n    background: radial-gradient(closest-side, rgba(207,122,58,0.5), transparent 70%);\n    filter: blur(14px);\n    opacity: 0.5;\n    animation: bloomPulse 3.4s ease-in-out infinite;\n    pointer-events: none;\n  }\n\n  @keyframes bloomPulse {\n    0%, 100% { opacity: 0.35; transform: translateX(-50%) scale(0.95); }\n    50%      { opacity: 0.7;  transform: translateX(-50%) scale(1.08); }\n  }\n\n  @keyframes fluxFlow {\n    to { stroke-dashoffset: -240; }\n  }\n\n  @keyframes spark {\n    0%, 100% { opacity: 0.25; }\n    50%      { opacity: 1; }\n  }\n\n  .flux {\n    stroke-dasharray: 8 14;\n    animation: fluxFlow 2.6s linear infinite;\n  }\n\n  .coilWire { filter: drop-shadow(0 0 4px rgba(207,122,58,0.5)); }\n\n  /* ---- controls ---- */\n  .rack {\n    position: relative;\n    z-index: 2;\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 8px;\n    margin-top: 14px;\n  }\n\n  @media (max-width: 460px) {\n    .rack { grid-template-columns: repeat(3, 1fr); row-gap: 16px; }\n  }\n\n  .cell {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 6px;\n    padding: 10px 4px 8px;\n    border-radius: 12px;\n    background: linear-gradient(180deg, rgba(255,255,255,0.025), rgba(0,0,0,0.18));\n    border: 1px solid rgba(224,168,96,0.08);\n  }\n\n  .cell .label {\n    font-size: 10px;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .knob {\n    position: relative;\n    width: 70px;\n    height: 70px;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n\n  .knob svg { display: block; width: 100%; height: 100%; overflow: visible; }\n\n  .knob:hover .ring { filter: drop-shadow(0 0 6px rgba(224,168,96,0.55)); }\n\n  .val {\n    font-variant-numeric: tabular-nums;\n    font-size: 11px;\n    color: var(--ink);\n    letter-spacing: 0.04em;\n    min-height: 14px;\n  }\n\n  footer {\n    position: relative;\n    z-index: 2;\n    margin-top: 16px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 9px;\n    letter-spacing: 0.22em;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  .led {\n    width: 8px; height: 8px; border-radius: 50%;\n    background: var(--accent2);\n    box-shadow: 0 0 8px var(--accent2);\n    animation: spark 1.8s ease-in-out infinite;\n    display: inline-block;\n    vertical-align: middle;\n    margin-right: 6px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header>\n      <div class=\"brand\">\n        <h1>Iron Drive</h1>\n        <span class=\"sub\">Transformer Saturator</span>\n      </div>\n      <div class=\"badge\">Iron&nbsp;Core</div>\n    </header>\n\n    <div class=\"core\">\n      <div class=\"bloom\" id=\"bloom\"></div>\n      <svg viewBox=\"0 0 520 150\" preserveAspectRatio=\"xMidYMid meet\">\n        <defs>\n          <linearGradient id=\"coreGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#4a3a2c\"/>\n            <stop offset=\"0.5\" stop-color=\"#2a211a\"/>\n            <stop offset=\"1\" stop-color=\"#14100c\"/>\n          </linearGradient>\n          <linearGradient id=\"copperGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#e0a860\"/>\n            <stop offset=\"0.5\" stop-color=\"#b9763f\"/>\n            <stop offset=\"1\" stop-color=\"#7d4a26\"/>\n          </linearGradient>\n        </defs>\n\n        <!-- iron core E-block -->\n        <rect x=\"190\" y=\"28\" width=\"140\" height=\"94\" rx=\"6\" fill=\"url(#coreGrad)\"\n              stroke=\"rgba(224,168,96,0.25)\" stroke-width=\"1\"/>\n        <rect x=\"214\" y=\"46\" width=\"92\" height=\"24\" rx=\"3\" fill=\"#0e0b08\"/>\n        <rect x=\"214\" y=\"80\" width=\"92\" height=\"24\" rx=\"3\" fill=\"#0e0b08\"/>\n\n        <!-- copper coil windings (left + right limbs) -->\n        <g class=\"coilWire\" stroke=\"url(#copperGrad)\" stroke-width=\"5\" fill=\"none\" stroke-linecap=\"round\">\n          <path d=\"M150 34 q24 0 24 14 q0 14 -24 14 q24 0 24 14 q0 14 -24 14 q24 0 24 14 q0 14 -24 14\"/>\n          <path d=\"M370 34 q-24 0 -24 14 q0 14 24 14 q-24 0 -24 14 q0 14 24 14 q-24 0 -24 14 q0 14 24 14\"/>\n        </g>\n\n        <!-- animated magnetic flux lines looping through the core -->\n        <g class=\"flux\" stroke=\"var(--accent2)\" stroke-width=\"2\" fill=\"none\" opacity=\"0.85\" id=\"fluxGroup\">\n          <path d=\"M260 122 C 120 122 120 28 260 28 C 400 28 400 122 260 122 Z\"/>\n          <path d=\"M260 110 C 150 110 150 40 260 40 C 370 40 370 110 260 110 Z\" opacity=\"0.55\"/>\n          <path d=\"M260 98 C 180 98 180 52 260 52 C 340 52 340 98 260 98 Z\" opacity=\"0.35\"/>\n        </g>\n\n        <!-- flux entry/exit sparks -->\n        <circle cx=\"260\" cy=\"28\" r=\"3.5\" fill=\"var(--accent2)\" style=\"animation:spark 1.4s ease-in-out infinite\"/>\n        <circle cx=\"260\" cy=\"122\" r=\"3.5\" fill=\"var(--accent)\" style=\"animation:spark 1.4s ease-in-out infinite 0.7s\"/>\n      </svg>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <footer>\n      <span><span class=\"led\"></span>Magnetised</span>\n      <span>Even + Odd Harmonics</span>\n    </footer>\n  </div>\n\n<script>\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Drive\",  index: 0, min: 0, max: 1, def: 0.45, fmt: pct },\n    { name: \"Low\",    index: 1, min: 0, max: 1, def: 0.5,  fmt: pct },\n    { name: \"Tone\",   index: 2, min: 0, max: 1, def: 0.5,  fmt: pct },\n    { name: \"Mix\",    index: 3, min: 0, max: 1, def: 1.0,  fmt: pct },\n    { name: \"Output\", index: 4, min: 0, max: 1, def: 0.55, fmt: db }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function db(v) {\n    // map 0..1 output trim (0..1.4x) to a dB-ish readout\n    var g = v * 1.4;\n    if (g <= 0.0001) return \"-∞ dB\";\n    var d = 20 * Math.log10(g);\n    return (d >= 0 ? \"+\" : \"\") + d.toFixed(1) + \" dB\";\n  }\n\n  // ---- host bridge (guard against missing vstai) ----\n  function setParam(i, v) {\n    if (window.vstai && window.vstai.setParam) {\n      try { window.vstai.setParam(i, v); } catch (e) {}\n    }\n  }\n\n  var state = {}; // index -> normalized 0..1\n  var bloomEl = document.getElementById(\"bloom\");\n  var fluxGroup = document.getElementById(\"fluxGroup\");\n\n  function reflectVisual() {\n    var drive = state[0] != null ? state[0] : 0.45;\n    var low   = state[1] != null ? state[1] : 0.5;\n    // low-end bloom intensity tracks Low + Drive\n    var glow = 0.3 + 0.7 * (0.5 * low + 0.5 * drive);\n    if (bloomEl) bloomEl.style.opacity = glow.toFixed(3);\n    // flux speed tracks Drive (more drive = faster magnetisation)\n    if (fluxGroup) {\n      var dur = (3.2 - drive * 2.2).toFixed(2);\n      fluxGroup.style.animationDuration = dur + \"s\";\n    }\n  }\n\n  // ---- build a knob ----\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.setAttribute(\"role\", \"slider\");\n    knob.setAttribute(\"aria-label\", p.name);\n\n    var NS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(NS, \"svg\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n    // outer body\n    var body = document.createElementNS(NS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"30\");\n    body.setAttribute(\"fill\", \"url(#kbody)\");\n    // track arc background\n    var track = document.createElementNS(NS, \"path\");\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(0,0,0,0.45)\");\n    track.setAttribute(\"stroke-width\", \"5\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    track.setAttribute(\"d\", arcPath(0));\n    track.setAttribute(\"class\", \"trackBg\");\n    track.setAttribute(\"d\", arcPath(1));\n    // value arc\n    var arc = document.createElementNS(NS, \"path\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"url(#kArc)\");\n    arc.setAttribute(\"stroke-width\", \"5\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    arc.setAttribute(\"class\", \"ring\");\n    // pointer\n    var ptr = document.createElementNS(NS, \"line\");\n    ptr.setAttribute(\"stroke\", \"#f6e2c6\");\n    ptr.setAttribute(\"stroke-width\", \"3\");\n    ptr.setAttribute(\"stroke-linecap\", \"round\");\n\n    // gradients (define once, attach per-knob via defs)\n    var defs = document.createElementNS(NS, \"defs\");\n    defs.innerHTML =\n      '<radialGradient id=\"kbody\" cx=\"0.4\" cy=\"0.3\" r=\"0.8\">' +\n      '<stop offset=\"0\" stop-color=\"#3a3027\"/>' +\n      '<stop offset=\"0.7\" stop-color=\"#211a14\"/>' +\n      '<stop offset=\"1\" stop-color=\"#0e0b08\"/></radialGradient>' +\n      '<linearGradient id=\"kArc\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">' +\n      '<stop offset=\"0\" stop-color=\"#cf7a3a\"/>' +\n      '<stop offset=\"1\" stop-color=\"#e0a860\"/></linearGradient>';\n\n    svg.appendChild(defs);\n    svg.appendChild(track);\n    svg.appendChild(body);\n    svg.appendChild(arc);\n    svg.appendChild(ptr);\n    knob.appendChild(svg);\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(label);\n    cell.appendChild(knob);\n    cell.appendChild(val);\n\n    // arc geometry: 270-degree sweep from 225 (lower-left) clockwise\n    var START = 135;   // degrees, measured from +x, going clockwise in screen space\n    var SWEEP = 270;\n\n    function polar(deg) {\n      var r = 30;\n      var rad = (deg) * Math.PI / 180;\n      return [50 + r * Math.cos(rad), 50 + r * Math.sin(rad)];\n    }\n\n    function arcPath(frac) {\n      var a0 = START;\n      var a1 = START + SWEEP * frac;\n      var p0 = polar(a0);\n      var p1 = polar(a1);\n      var large = (SWEEP * frac) > 180 ? 1 : 0;\n      if (frac <= 0.0001) {\n        return \"M \" + p0[0] + \" \" + p0[1];\n      }\n      return \"M \" + p0[0] + \" \" + p0[1] + \" A 30 30 0 \" + large + \" 1 \" + p1[0] + \" \" + p1[1];\n    }\n\n    function redraw(v) {\n      arc.setAttribute(\"d\", arcPath(v));\n      var a = START + SWEEP * v;\n      var rad = a * Math.PI / 180;\n      ptr.setAttribute(\"x1\", (50 + 10 * Math.cos(rad)).toFixed(2));\n      ptr.setAttribute(\"y1\", (50 + 10 * Math.sin(rad)).toFixed(2));\n      ptr.setAttribute(\"x2\", (50 + 24 * Math.cos(rad)).toFixed(2));\n      ptr.setAttribute(\"y2\", (50 + 24 * Math.sin(rad)).toFixed(2));\n      val.textContent = p.fmt(v);\n    }\n\n    function apply(v, push) {\n      v = Math.max(0, Math.min(1, v));\n      state[p.index] = v;\n      redraw(v);\n      if (push) setParam(p.index, p.min + v * (p.max - p.min));\n      reflectVisual();\n    }\n\n    // ---- drag interaction (vertical) ----\n    var dragging = false, lastY = 0;\n\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      knob.setPointerCapture && e.pointerId != null && knob.setPointerCapture(e.pointerId);\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var speed = e.shiftKey ? 0.0012 : 0.005; // shift = fine\n      apply((state[p.index] || 0) + dy * speed, true);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    knob.addEventListener(\"pointerdown\", onDown);\n    window.addEventListener(\"pointermove\", onMove);\n    window.addEventListener(\"pointerup\", onUp);\n    // touch fallback\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    // wheel fine-tune\n    knob.addEventListener(\"wheel\", function (e) {\n      var step = (e.deltaY < 0 ? 1 : -1) * (e.shiftKey ? 0.005 : 0.02);\n      apply((state[p.index] || 0) + step, true);\n      e.preventDefault();\n    }, { passive: false });\n\n    // double-click reset to default\n    knob.addEventListener(\"dblclick\", function () {\n      var dv = (p.def - p.min) / (p.max - p.min);\n      apply(dv, true);\n    });\n\n    // initialise to default\n    apply((p.def - p.min) / (p.max - p.min), true);\n\n    return cell;\n  }\n\n  function build() {\n    var rack = document.getElementById(\"rack\");\n    PARAMS.forEach(function (p) { rack.appendChild(makeKnob(p)); });\n    reflectVisual();\n  }\n\n  // pause animations when hidden to stay cheap\n  document.addEventListener(\"visibilitychange\", function () {\n    document.querySelectorAll(\".bloom, .flux, .led\").forEach(function (el) {\n      el.style.animationPlayState = document.hidden ? \"paused\" : \"running\";\n    });\n  });\n\n  function boot() {\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(build);\n    } else {\n      build();\n    }\n  }\n\n  boot();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  IRON DRIVE — transformer / iron-core saturation\n//  Models the warm nonlinearity of an audio output transformer: the\n//  iron core saturates earliest in the LOW frequencies (so a tunable\n//  low-end emphasis is summed back into the drive stage), a hysteresis-\n//  flavoured soft saturator adds asymmetric even + odd harmonics, a gentle\n//  high-frequency rounding tames fizz, and a post Tone tilt + dry/wet Mix\n//  and Output level finish it. Pure algorithm, no samples.\n//\n//  Params:\n//    0 Drive   0..1  -> input gain into the iron 1..18x\n//    1 Low     0..1  -> low-frequency iron push (extra LF into saturator)\n//    2 Tone    0..1  -> post tilt: dark<->bright HF rounding 1.2..8 kHz\n//    3 Mix     0..1  -> dry/wet\n//    4 Output  0..1  -> output trim 0..1.4\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel filter state\nconst lfState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // LF extractor for iron push\nconst hfState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // pre-sat HF rounding\nconst toneState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // post tone LP\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker (asymmetry adds DC)\nconst dcPrev:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker prev input\nconst hysState:  StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // hysteresis memory\n\nconst P_DRIVE:  i32 = 0;\nconst P_LOW:    i32 = 1;\nconst P_TONE:   i32 = 2;\nconst P_MIX:    i32 = 3;\nconst P_OUTPUT: i32 = 4;\n\nconst PI2: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    lfState[c] = 0.0; hfState[c] = 0.0; toneState[c] = 0.0;\n    dcState[c] = 0.0; dcPrev[c] = 0.0; hysState[c] = 0.0;\n  }\n  params[P_DRIVE] = 0.45;\n  params[P_LOW]   = 0.5;\n  params[P_TONE]  = 0.5;\n  params[P_MIX]   = 1.0;\n  params[P_OUTPUT] = 0.55;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// Transformer iron saturation: asymmetric soft clip giving strong odd\n// harmonics with a touch of even (the bias offset). tanh-style via a\n// fast rational approximation, then a small squared even-harmonic term.\n@inline function ironSat(x: f32): f32 {\n  const xc: f32 = clampf(x, -3.0, 3.0);\n  // odd-harmonic soft saturation (rational tanh approx, smooth, bounded ±1)\n  const x2: f32 = xc * xc;\n  const odd: f32 = xc * (27.0 + x2) / (27.0 + 9.0 * x2);\n  // gentle even-harmonic asymmetry (iron core bias) — bounded\n  const even: f32 = 0.12 * (odd * odd - 0.5);\n  return f32(odd + even);\n}\n\nexport function process(n: i32): void {\n  const driveN: f32 = clampf(params[P_DRIVE], 0.0, 1.0);\n  const lowN:   f32 = clampf(params[P_LOW],   0.0, 1.0);\n  const toneN:  f32 = clampf(params[P_TONE],  0.0, 1.0);\n  const mix:    f32 = clampf(params[P_MIX],   0.0, 1.0);\n  const outN:   f32 = clampf(params[P_OUTPUT], 0.0, 1.0);\n\n  // input gain into the iron\n  const drive: f32 = 1.0 + driveN * 17.0;\n  // extra low-frequency drive (transformers saturate first in the lows)\n  const lowPush: f32 = 0.4 + lowN * 2.2;\n  const outLevel: f32 = outN * 1.4;\n\n  // LF extractor ~150 Hz (the band we push into the core)\n  const cLf: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * 150.0 / sampleRate)), 0.0, 1.0);\n  // pre-sat HF rounding ~7 kHz (iron rolls off the extreme top before clipping)\n  const cHfPre: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * 7000.0 / sampleRate)), 0.0, 1.0);\n  // post tone low-pass 1.2..8 kHz (dark <-> bright)\n  const toneHz: f32 = 1200.0 + toneN * toneN * 6800.0;\n  const cTone: f32 = clampf(f32(1.0 - Mathf.exp(-PI2 * toneHz / sampleRate)), 0.0, 1.0);\n  // DC blocker coeff\n  const rDc: f32 = clampf(f32(1.0 - PI2 * 12.0 / sampleRate), 0.9, 0.99999);\n  // gain compensation so Drive doesn't simply get louder\n  const comp: f32 = f32(1.6 / Mathf.sqrt(drive));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    let lf: f32 = lfState[c];\n    let hf: f32 = hfState[c];\n    let tn: f32 = toneState[c];\n    let dz: f32 = dcState[c];\n    let dp: f32 = dcPrev[c];\n    let hy: f32 = hysState[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // pre-sat HF rounding (one-pole LP — rounds the very top before the iron)\n      hf = hf + cHfPre * (x - hf);\n      const rounded: f32 = hf;\n\n      // low-frequency component, emphasised and fed back into the drive\n      lf = lf + cLf * (rounded - lf);\n      const pushed: f32 = rounded + lf * (lowPush - 1.0);\n\n      // hysteresis: the core's magnetisation lags the signal slightly,\n      // which spreads the transfer curve and warms transients\n      hy = hy + 0.35 * (pushed - hy);\n      const drivenIn: f32 = (pushed * 0.7 + hy * 0.3) * drive;\n\n      // iron-core saturation\n      let sat: f32 = ironSat(drivenIn) * comp;\n\n      // DC blocker (asymmetry introduces DC) — high-pass at ~12 Hz\n      const dcOut: f32 = sat - dp + rDc * dz;\n      dp = sat;\n      dz = dcOut;\n      sat = dcOut;\n\n      // post tone low-pass (HF rounding / brightness)\n      tn = tn + cTone * (sat - tn);\n\n      const wet: f32 = clampf(tn * outLevel, -1.5, 1.5);\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    lfState[c] = lf;\n    hfState[c] = hf;\n    toneState[c] = tn;\n    dcState[c] = dz;\n    dcPrev[c] = dp;\n    hysState[c] = hy;\n  }\n}\n",
  "publishedAt": 1751000077000
}