      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Punch",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Snare",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Hat",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Decay",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.85
