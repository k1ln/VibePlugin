{
  "format": 1,
  "name": "Robot Voice",
  "isInstrument": false,
  "explanation": "A channel vocoder in the classic analog-bank style. Your input is the modulator: it is split into 8, 12 or 16 band-pass bands, each tracked by an envelope follower. An internal carrier — a buzzy sawtooth blended toward white noise — is filtered into the same bands and multiplied by those envelopes, so the carrier is forced to wear the spectral shape of your input. The result is the unmistakable talking, robotic timbre. Controls: Bands, Carrier (saw to noise), Formant band shift, Resonance and dry/wet Mix.",
  "params": [
    {
      "name": "Bands",
      "index": 0,
      "min": 0,
      "max": 2,
      "default": 1
    },
    {
      "name": "Carrier",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.15
    },
    {
      "name": "Formant",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 1
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Robot Voice</title>\n<style>\n  :root {\n    --accent:  #54ff9a;\n    --accent2: #54d1ff;\n    --bg0: #03100a;\n    --bg1: #06190f;\n    --panel: #07140d;\n    --line: rgba(84,255,154,0.16);\n    --dim: rgba(84,255,154,0.45);\n    --text: #baffda;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--text);\n    font-family: ui-monospace, \"SF Mono\", \"Roboto Mono\", Menlo, monospace;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  body {\n    min-height: 100vh;\n    display: flex;\n    align-items: flex-start;\n    justify-content: center;\n    padding: 18px;\n    background:\n      radial-gradient(120% 90% at 50% -10%, rgba(84,209,255,0.10), transparent 60%),\n      radial-gradient(140% 120% at 50% 120%, rgba(84,255,154,0.10), transparent 55%),\n      linear-gradient(180deg, var(--bg1), var(--bg0));\n  }\n\n  .shell {\n    width: 100%;\n    max-width: 720px;\n    border: 1px solid var(--line);\n    border-radius: 18px;\n    padding: 18px 20px 22px;\n    background:\n      linear-gradient(180deg, rgba(84,255,154,0.05), rgba(0,0,0,0)) ,\n      linear-gradient(180deg, #08160e, #050f09);\n    box-shadow:\n      0 0 0 1px rgba(0,0,0,0.6),\n      0 28px 70px rgba(0,0,0,0.7),\n      inset 0 1px 0 rgba(84,255,154,0.12);\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* faint moving scanlines for the CRT feel */\n  .shell::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n    background: repeating-linear-gradient(\n      0deg,\n      rgba(0,0,0,0) 0px,\n      rgba(0,0,0,0) 2px,\n      rgba(0,0,0,0.16) 3px,\n      rgba(0,0,0,0) 4px);\n    mix-blend-mode: multiply;\n    animation: scan 8s linear infinite;\n    opacity: 0.5;\n  }\n  @keyframes scan {\n    from { background-position: 0 0; }\n    to   { background-position: 0 80px; }\n  }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 12px;\n    margin-bottom: 14px;\n    position: relative;\n    z-index: 2;\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .glyph {\n    width: 38px;\n    height: 38px;\n    border-radius: 9px;\n    border: 1px solid var(--line);\n    display: grid;\n    place-items: center;\n    background: radial-gradient(circle at 50% 35%, rgba(84,255,154,0.22), transparent 70%);\n    box-shadow: inset 0 0 12px rgba(84,255,154,0.25);\n  }\n  .glyph svg { display: block; }\n\n  .titles h1 {\n    margin: 0;\n    font-size: 18px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #eafff2;\n    text-shadow: 0 0 10px rgba(84,255,154,0.55);\n  }\n  .titles p {\n    margin: 2px 0 0;\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n\n  .power {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid rgba(84,209,255,0.35);\n    border-radius: 999px;\n    padding: 5px 11px;\n    background: rgba(84,209,255,0.07);\n    text-shadow: 0 0 8px rgba(84,209,255,0.5);\n    animation: pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse {\n    0%, 100% { opacity: 0.55; }\n    50%      { opacity: 1; }\n  }\n\n  /* ---- the mouth / band meter display ---- */\n  .scope {\n    position: relative;\n    z-index: 2;\n    border-radius: 12px;\n    border: 1px solid var(--line);\n    background:\n      radial-gradient(120% 140% at 50% 0%, rgba(84,209,255,0.08), transparent 55%),\n      linear-gradient(180deg, #02110a, #010a06);\n    box-shadow: inset 0 0 30px rgba(0,0,0,0.8), inset 0 0 0 1px rgba(0,0,0,0.5);\n    padding: 14px 14px 8px;\n    overflow: hidden;\n  }\n\n  .mouth {\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    gap: 5px;\n    height: 122px;\n  }\n\n  .bar {\n    flex: 1 1 0;\n    max-width: 26px;\n    min-width: 5px;\n    height: 100%;\n    border-radius: 4px 4px 2px 2px;\n    background: linear-gradient(180deg, rgba(84,255,154,0.06), rgba(84,255,154,0.02));\n    position: relative;\n    overflow: hidden;\n    box-shadow: inset 0 0 0 1px rgba(84,255,154,0.10);\n  }\n  .bar > i {\n    position: absolute;\n    left: 2px;\n    right: 2px;\n    bottom: 0;\n    height: 4%;\n    border-radius: 3px;\n    background: linear-gradient(180deg, var(--accent2), var(--accent) 55%, #1f9c5d);\n    box-shadow: 0 0 12px rgba(84,255,154,0.7);\n    transition: height 0.06s linear;\n  }\n  /* lit grid texture on each bar (LED segments) */\n  .bar::after {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background: repeating-linear-gradient(\n      0deg, rgba(0,0,0,0.55) 0px, rgba(0,0,0,0.55) 2px, transparent 2px, transparent 7px);\n    pointer-events: none;\n  }\n\n  .wave {\n    margin-top: 8px;\n    height: 46px;\n    width: 100%;\n    display: block;\n  }\n\n  .readout {\n    position: relative;\n    z-index: 2;\n    margin-top: 10px;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    font-size: 10px;\n    letter-spacing: 2px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n  .readout b { color: var(--accent); text-shadow: 0 0 8px rgba(84,255,154,0.6); }\n\n  /* ---- controls ---- */\n  .controls {\n    position: relative;\n    z-index: 2;\n    margin-top: 18px;\n    display: grid;\n    grid-template-columns: repeat(5, 1fr);\n    gap: 12px;\n  }\n  @media (max-width: 560px) {\n    .controls { grid-template-columns: repeat(2, 1fr); }\n  }\n\n  .cell {\n    border: 1px solid var(--line);\n    border-radius: 12px;\n    padding: 12px 10px 10px;\n    background: linear-gradient(180deg, rgba(84,255,154,0.04), rgba(0,0,0,0));\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    user-select: none;\n  }\n  .cell .lab {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--dim);\n  }\n  .cell .val {\n    font-size: 11px;\n    letter-spacing: 1px;\n    color: var(--accent);\n    font-variant-numeric: tabular-nums;\n    text-shadow: 0 0 8px rgba(84,255,154,0.5);\n  }\n\n  .knob {\n    width: 64px;\n    height: 64px;\n    cursor: ns-resize;\n    touch-action: none;\n  }\n  .knob:focus { outline: none; }\n  .knob:hover .kglow { opacity: 1; }\n\n  /* segmented selector for Bands */\n  .seg {\n    display: flex;\n    gap: 4px;\n    width: 100%;\n  }\n  .seg button {\n    flex: 1;\n    font-family: inherit;\n    font-size: 10px;\n    letter-spacing: 1px;\n    color: var(--dim);\n    background: rgba(84,255,154,0.04);\n    border: 1px solid var(--line);\n    border-radius: 7px;\n    padding: 9px 0;\n    cursor: pointer;\n    transition: all 0.14s ease;\n  }\n  .seg button:hover { color: var(--text); border-color: var(--dim); }\n  .seg button.on {\n    color: #04140b;\n    background: linear-gradient(180deg, var(--accent), #2bbd6e);\n    border-color: var(--accent);\n    box-shadow: 0 0 14px rgba(84,255,154,0.55);\n    text-shadow: none;\n  }\n  .seg-wrap { width: 100%; display: flex; flex-direction: column; gap: 8px; align-items: center; }\n  .seg-icon { width: 64px; height: 64px; display: grid; place-items: center; }\n</style>\n</head>\n<body>\n  <div class=\"shell\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"glyph\">\n          <svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\">\n            <rect x=\"4\" y=\"3\" width=\"14\" height=\"12\" rx=\"3\" stroke=\"#54ff9a\" stroke-width=\"1.4\"/>\n            <circle cx=\"8\" cy=\"8\" r=\"1.5\" fill=\"#54d1ff\"/>\n            <circle cx=\"14\" cy=\"8\" r=\"1.5\" fill=\"#54d1ff\"/>\n            <rect x=\"7\" y=\"11\" width=\"8\" height=\"1.6\" rx=\"0.8\" fill=\"#54ff9a\"/>\n            <path d=\"M11 15v3M8 18h6\" stroke=\"#54ff9a\" stroke-width=\"1.4\" stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"titles\">\n          <h1>Robot Voice</h1>\n          <p>Channel Vocoder</p>\n        </div>\n      </div>\n      <div class=\"power\">● Online</div>\n    </header>\n\n    <div class=\"scope\">\n      <div class=\"mouth\" id=\"mouth\"></div>\n      <svg class=\"wave\" id=\"wave\" viewBox=\"0 0 600 46\" preserveAspectRatio=\"none\">\n        <polyline id=\"waveLine\" fill=\"none\" stroke=\"#54d1ff\" stroke-width=\"1.4\"\n                  stroke-linejoin=\"round\" points=\"\"/>\n      </svg>\n    </div>\n\n    <div class=\"readout\">\n      <span>SPECTRUM ENVELOPE</span>\n      <span><b id=\"bandCount\">12</b> BANDS</span>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter model (indices MUST match assembly.ts) -------------\n  var PARAMS = [\n    { name: \"Bands\",     index: 0, min: 0, max: 2, def: 1, type: \"seg\",\n      labels: [\"8\", \"12\", \"16\"] },\n    { name: \"Carrier\",   index: 1, min: 0, max: 1, def: 0.15, type: \"knob\",\n      fmt: function (v) { return v < 0.5\n        ? \"SAW \" + Math.round((1 - v * 2) * 100) + \"%\"\n        : \"NOISE \" + Math.round((v - 0.5) * 200) + \"%\"; } },\n    { name: \"Formant\",   index: 2, min: 0, max: 1, def: 0.5, type: \"knob\",\n      fmt: function (v) {\n        var semis = Math.round((v - 0.5) * 24);\n        return (semis > 0 ? \"+\" : \"\") + semis + \" st\"; } },\n    { name: \"Resonance\", index: 3, min: 0, max: 1, def: 0.6, type: \"knob\",\n      fmt: function (v) { return Math.round(v * 100) + \"%\"; } },\n    { name: \"Mix\",       index: 4, min: 0, max: 1, def: 1, type: \"knob\",\n      fmt: function (v) { return Math.round(v * 100) + \"%\"; } }\n  ];\n\n  var values = {};      // index -> current real value\n  var pending = [];     // [index,value] queued until vstai ready\n  var ready = false;\n\n  function push(index, value) {\n    values[index] = value;\n    if (ready && window.vstai && window.vstai.setParam) {\n      window.vstai.setParam(index, value);\n    } else {\n      pending.push([index, value]);\n    }\n  }\n\n  function flush() {\n    ready = true;\n    if (!window.vstai || !window.vstai.setParam) return;\n    for (var i = 0; i < pending.length; i++) {\n      window.vstai.setParam(pending[i][0], pending[i][1]);\n    }\n    pending.length = 0;\n  }\n\n  // ---- knob control --------------------------------------------------\n  function makeKnob(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var svgNS = \"http://www.w3.org/2000/svg\";\n    var svg = document.createElementNS(svgNS, \"svg\");\n    svg.setAttribute(\"class\", \"knob\");\n    svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n    svg.setAttribute(\"tabindex\", \"0\");\n\n    var glow = document.createElementNS(svgNS, \"circle\");\n    glow.setAttribute(\"class\", \"kglow\");\n    glow.setAttribute(\"cx\", \"50\"); glow.setAttribute(\"cy\", \"50\"); glow.setAttribute(\"r\", \"44\");\n    glow.setAttribute(\"fill\", \"none\");\n    glow.setAttribute(\"stroke\", \"var(--accent)\");\n    glow.setAttribute(\"stroke-width\", \"2\");\n    glow.setAttribute(\"opacity\", \"0\");\n    glow.style.transition = \"opacity 0.2s\";\n    glow.style.filter = \"drop-shadow(0 0 6px var(--accent))\";\n    svg.appendChild(glow);\n\n    var track = document.createElementNS(svgNS, \"circle\");\n    track.setAttribute(\"cx\", \"50\"); track.setAttribute(\"cy\", \"50\"); track.setAttribute(\"r\", \"38\");\n    track.setAttribute(\"fill\", \"none\");\n    track.setAttribute(\"stroke\", \"rgba(84,255,154,0.14)\");\n    track.setAttribute(\"stroke-width\", \"7\");\n    track.setAttribute(\"stroke-dasharray\", \"179 240\");\n    track.setAttribute(\"stroke-linecap\", \"round\");\n    track.setAttribute(\"transform\", \"rotate(135 50 50)\");\n    svg.appendChild(track);\n\n    var arc = document.createElementNS(svgNS, \"circle\");\n    arc.setAttribute(\"cx\", \"50\"); arc.setAttribute(\"cy\", \"50\"); arc.setAttribute(\"r\", \"38\");\n    arc.setAttribute(\"fill\", \"none\");\n    arc.setAttribute(\"stroke\", \"var(--accent)\");\n    arc.setAttribute(\"stroke-width\", \"7\");\n    arc.setAttribute(\"stroke-linecap\", \"round\");\n    arc.setAttribute(\"transform\", \"rotate(135 50 50)\");\n    arc.style.filter = \"drop-shadow(0 0 5px rgba(84,255,154,0.7))\";\n    svg.appendChild(arc);\n\n    var body = document.createElementNS(svgNS, \"circle\");\n    body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\"); body.setAttribute(\"r\", \"27\");\n    body.setAttribute(\"fill\", \"url(#kbody)\");\n    body.setAttribute(\"stroke\", \"rgba(0,0,0,0.6)\");\n    body.setAttribute(\"stroke-width\", \"1\");\n    svg.appendChild(body);\n\n    var notch = document.createElementNS(svgNS, \"line\");\n    notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n    notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"29\");\n    notch.setAttribute(\"stroke\", \"var(--accent)\");\n    notch.setAttribute(\"stroke-width\", \"3\");\n    notch.setAttribute(\"stroke-linecap\", \"round\");\n    svg.appendChild(notch);\n\n    // shared gradient def\n    if (!document.getElementById(\"kbody\")) {\n      var defs = document.createElementNS(svgNS, \"defs\");\n      var grad = document.createElementNS(svgNS, \"radialGradient\");\n      grad.setAttribute(\"id\", \"kbody\");\n      grad.setAttribute(\"cx\", \"0.5\"); grad.setAttribute(\"cy\", \"0.32\");\n      var s1 = document.createElementNS(svgNS, \"stop\");\n      s1.setAttribute(\"offset\", \"0%\"); s1.setAttribute(\"stop-color\", \"#123421\");\n      var s2 = document.createElementNS(svgNS, \"stop\");\n      s2.setAttribute(\"offset\", \"100%\"); s2.setAttribute(\"stop-color\", \"#04120a\");\n      grad.appendChild(s1); grad.appendChild(s2);\n      defs.appendChild(grad);\n      svg.appendChild(defs);\n    }\n\n    var lab = document.createElement(\"div\");\n    lab.className = \"lab\"; lab.textContent = p.name;\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    cell.appendChild(svg);\n    cell.appendChild(lab);\n    cell.appendChild(val);\n\n    var ARC_LEN = 179;       // dash length for 270deg sweep\n    var FULL = 238.76;       // circumference 2*pi*38\n\n    function render(v) {\n      var t = (v - p.min) / (p.max - p.min);\n      var ang = 135 + t * 270;\n      notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n      arc.setAttribute(\"stroke-dasharray\", (ARC_LEN * t) + \" \" + FULL);\n      val.textContent = p.fmt ? p.fmt(v) : v.toFixed(2);\n    }\n\n    function set(v) {\n      v = Math.max(p.min, Math.min(p.max, v));\n      render(v);\n      push(p.index, v);\n    }\n\n    // drag vertical\n    var dragging = false, lastY = 0, startV = 0;\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      startV = values[p.index];\n      svg.focus();\n      e.preventDefault();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var span = p.max - p.min;\n      set(values[p.index] + dy / 160 * span);\n      e.preventDefault();\n    }\n    function onUp() { dragging = false; }\n\n    svg.addEventListener(\"mousedown\", onDown);\n    window.addEventListener(\"mousemove\", onMove);\n    window.addEventListener(\"mouseup\", onUp);\n    svg.addEventListener(\"touchstart\", onDown, { passive: false });\n    window.addEventListener(\"touchmove\", onMove, { passive: false });\n    window.addEventListener(\"touchend\", onUp);\n\n    svg.addEventListener(\"dblclick\", function () { set(p.def); });\n    svg.addEventListener(\"wheel\", function (e) {\n      var span = p.max - p.min;\n      set(values[p.index] - Math.sign(e.deltaY) * span * 0.02);\n      e.preventDefault();\n    }, { passive: false });\n    svg.addEventListener(\"keydown\", function (e) {\n      var span = p.max - p.min;\n      if (e.key === \"ArrowUp\" || e.key === \"ArrowRight\") { set(values[p.index] + span * 0.02); e.preventDefault(); }\n      if (e.key === \"ArrowDown\" || e.key === \"ArrowLeft\") { set(values[p.index] - span * 0.02); e.preventDefault(); }\n    });\n\n    values[p.index] = p.def;\n    render(p.def);\n    push(p.index, p.def);\n    return cell;\n  }\n\n  // ---- segmented selector (Bands) -----------------------------------\n  var bandCountEl = document.getElementById(\"bandCount\");\n  function makeSeg(p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\";\n\n    var icon = document.createElement(\"div\");\n    icon.className = \"seg-icon\";\n    icon.innerHTML =\n      '<svg width=\"58\" height=\"58\" viewBox=\"0 0 58 58\">' +\n      '<g stroke=\"#54d1ff\" stroke-width=\"3\" stroke-linecap=\"round\">' +\n      '<line x1=\"14\" y1=\"40\" x2=\"14\" y2=\"24\"/>' +\n      '<line x1=\"22\" y1=\"40\" x2=\"22\" y2=\"14\"/>' +\n      '<line x1=\"30\" y1=\"40\" x2=\"30\" y2=\"28\"/>' +\n      '<line x1=\"38\" y1=\"40\" x2=\"38\" y2=\"18\"/>' +\n      '<line x1=\"46\" y1=\"40\" x2=\"46\" y2=\"32\"/>' +\n      '</g></svg>';\n\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"seg-wrap\";\n\n    var seg = document.createElement(\"div\");\n    seg.className = \"seg\";\n\n    var lab = document.createElement(\"div\");\n    lab.className = \"lab\"; lab.textContent = p.name;\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    var btns = [];\n    function select(i) {\n      for (var j = 0; j < btns.length; j++) btns[j].classList.toggle(\"on\", j === i);\n      val.textContent = p.labels[i] + \" BANDS\";\n      bandCountEl.textContent = p.labels[i];\n      push(p.index, i);\n    }\n\n    for (var i = 0; i < p.labels.length; i++) {\n      (function (i) {\n        var b = document.createElement(\"button\");\n        b.textContent = p.labels[i];\n        b.addEventListener(\"click\", function () { select(i); });\n        seg.appendChild(b);\n        btns.push(b);\n      })(i);\n    }\n\n    wrap.appendChild(seg);\n    cell.appendChild(icon);\n    cell.appendChild(wrap);\n    cell.appendChild(lab);\n    cell.appendChild(val);\n\n    values[p.index] = p.def;\n    select(p.def | 0);\n    return cell;\n  }\n\n  // ---- build controls ------------------------------------------------\n  var host = document.getElementById(\"controls\");\n  for (var i = 0; i < PARAMS.length; i++) {\n    var p = PARAMS[i];\n    host.appendChild(p.type === \"seg\" ? makeSeg(p) : makeKnob(p));\n  }\n\n  // ---- the animated robot mouth (band meters) -----------------------\n  var mouth = document.getElementById(\"mouth\");\n  var NBARS = 16;\n  var bars = [];\n  for (var i = 0; i < NBARS; i++) {\n    var bar = document.createElement(\"div\");\n    bar.className = \"bar\";\n    var fill = document.createElement(\"i\");\n    bar.appendChild(fill);\n    mouth.appendChild(bar);\n    bars.push(fill);\n  }\n\n  var waveLine = document.getElementById(\"waveLine\");\n  var levels = new Float32Array(NBARS);\n  var phase = 0;\n\n  function activeBands() {\n    var b = values[0] | 0;\n    return b === 0 ? 8 : (b === 1 ? 12 : 16);\n  }\n\n  function frame(t) {\n    if (document.hidden) { requestAnimationFrame(frame); return; }\n    phase += 0.045;\n\n    var nb = activeBands();\n    var carrier = values[1] || 0;\n    var reso = values[3] || 0;\n    var mix = values[4] || 0;\n    var formant = values[2] || 0.5;\n\n    // synthesize a lively \"talking\" envelope across the active bands\n    for (var i = 0; i < NBARS; i++) {\n      var on = i < nb;\n      var fi = i / Math.max(1, nb - 1);\n      // a roaming vowel-like formant hump that drifts over time\n      var hump = Math.exp(-Math.pow((fi - (0.4 + 0.3 * Math.sin(phase * 0.7))) * 3.2, 2));\n      var hump2 = 0.6 * Math.exp(-Math.pow((fi - (0.15 + 0.1 * Math.sin(phase * 1.1 + 1))) * 4.5, 2));\n      var syll = 0.5 + 0.5 * Math.sin(phase * 2.3 + i * 0.4); // syllable gate\n      var grain = carrier * (Math.random() * 0.5);            // noise carrier sparkle\n      var target = on ? ((hump + hump2) * syll * (0.55 + reso * 0.5) + grain) * mix : 0;\n      target = Math.max(0, Math.min(1, target));\n      levels[i] += (target - levels[i]) * 0.35;\n      var h = 4 + levels[i] * 94;\n      bars[i].style.height = h + \"%\";\n      bars[i].style.opacity = on ? \"1\" : \"0.12\";\n      // tint shift toward cyan with formant\n      bars[i].style.background =\n        \"linear-gradient(180deg, \" +\n        (formant > 0.55 ? \"var(--accent2)\" : \"var(--accent)\") + \", var(--accent) 55%, #1f9c5d)\";\n    }\n\n    // speech-style waveform: sum of band activity modulating a fast carrier\n    var pts = \"\";\n    var act = 0;\n    for (var k = 0; k < nb; k++) act += levels[k];\n    act = act / nb;\n    for (var x = 0; x <= 120; x++) {\n      var px = x / 120 * 600;\n      var car = Math.sin(x * 0.5 + phase * 6) + 0.5 * Math.sin(x * 1.3 - phase * 4);\n      var amp = (0.25 + act * (0.9 + carrier)) * mix;\n      var py = 23 - car * amp * 20;\n      pts += px.toFixed(1) + \",\" + py.toFixed(1) + \" \";\n    }\n    waveLine.setAttribute(\"points\", pts.trim());\n\n    requestAnimationFrame(frame);\n  }\n  requestAnimationFrame(frame);\n\n  // ---- host handshake ------------------------------------------------\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(flush);\n  } else {\n    flush();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  ROBOT VOICE — channel vocoder (EMS / analog-bank style)\n//  The input is the MODULATOR. It is split into a bank of band-pass\n//  filters, each followed by an envelope follower that measures how much\n//  energy lives in that band. An INTERNAL carrier (a bright sawtooth\n//  blended toward white noise) is split into the SAME band bank; each\n//  carrier band is then multiplied by the matching modulator envelope and\n//  the bands are summed. The carrier's flat, buzzy spectrum is forced to\n//  wear the spectral envelope of the input — the classic talking/robot\n//  timbre. Pure algorithm, no samples.\n//\n//  Bands     : 8 / 12 / 16 analysis bands (0..2, step 1)\n//  Carrier   : sawtooth  <->  white noise\n//  Formant   : shifts the carrier-band mapping up/down (vowel bending)\n//  Resonance : band-pass Q (narrow, resonant -> wide, smooth)\n//  Mix       : dry input  <->  full vocoded output\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst MAX_BANDS: i32 = 16;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// --- band-pass state (state-variable filter), per channel x band ------\n// Modulator analysis bank (one set per channel so stereo tracks correctly)\nconst modLP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * MAX_BANDS); // low / integrator 1\nconst modBP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * MAX_BANDS); // band / integrator 2\nconst modEnv: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * MAX_BANDS); // envelope follower\n\n// Carrier synthesis bank\nconst carLP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * MAX_BANDS);\nconst carBP: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * MAX_BANDS);\n\n// Per-band tuning, recomputed when band count / formant change\nconst bandF: StaticArray<f32> = new StaticArray<f32>(MAX_BANDS); // SVF freq coeff (modulator)\nconst bandFc: StaticArray<f32> = new StaticArray<f32>(MAX_BANDS); // SVF freq coeff (carrier, formant shifted)\n\n// Carrier oscillator + noise state (mono source, shared across channels)\nconst carPhase: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nlet noiseState: i32 = 0x12345678;\n\nlet curBands: i32 = 12;\nlet curFormant: f32 = -1.0;\n\nconst P_BANDS: i32 = 0;     // 0..2 step 1 -> 8 / 12 / 16\nconst P_CARRIER: i32 = 1;   // 0 = saw, 1 = noise\nconst P_FORMANT: i32 = 2;   // 0..1, 0.5 = neutral\nconst P_RES: i32 = 3;       // 0..1 resonance / Q\nconst P_MIX: i32 = 4;       // 0..1 dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < MAX_CHANNELS * MAX_BANDS; i++) {\n    modLP[i] = 0.0; modBP[i] = 0.0; modEnv[i] = 0.0;\n    carLP[i] = 0.0; carBP[i] = 0.0;\n  }\n  for (let c = 0; c < MAX_CHANNELS; c++) carPhase[c] = 0.0;\n  noiseState = 0x12345678;\n  curBands = 0; curFormant = -1.0; // force recompute on first process()\n  params[P_BANDS] = 1.0;    // 12 bands\n  params[P_CARRIER] = 0.15; // mostly saw\n  params[P_FORMANT] = 0.5;  // neutral\n  params[P_RES] = 0.6;      // fairly resonant\n  params[P_MIX] = 1.0;      // full vocoder\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// fast deterministic white noise in [-1, 1]\n@inline function nextNoise(): f32 {\n  noiseState ^= noiseState << 13;\n  noiseState ^= noiseState >> 17;\n  noiseState ^= noiseState << 5;\n  return f32(noiseState) * f32(4.6566129e-10);\n}\n\n// Lay out band centre frequencies on a log scale 180 Hz .. ~6.5 kHz and\n// convert to a state-variable-filter frequency coefficient f = 2*sin(pi*fc/sr).\nfunction rebuildBands(nBands: i32, formant: f32): void {\n  const lo: f32 = 180.0;\n  const hi: f32 = 6500.0;\n  const ratio: f32 = hi / lo;\n  // formant: 0.5 neutral; maps to a per-band frequency multiplier 0.5x .. 2x\n  const shift: f32 = f32(Mathf.pow(2.0, (formant - 0.5) * 2.0));\n  const denom: f32 = nBands > 1 ? f32(nBands - 1) : 1.0;\n  for (let b = 0; b < nBands; b++) {\n    const frac: f32 = f32(b) / denom;\n    const fc: f32 = lo * f32(Mathf.pow(ratio, frac));\n    let fcShift: f32 = fc * shift;\n    if (fcShift > sampleRate * 0.45) fcShift = sampleRate * 0.45;\n    const fMod: f32 = 2.0 * f32(Mathf.sin(3.14159265 * fc / sampleRate));\n    const fCar: f32 = 2.0 * f32(Mathf.sin(3.14159265 * fcShift / sampleRate));\n    bandF[b] = clampf(fMod, 0.0, 1.4);\n    bandFc[b] = clampf(fCar, 0.0, 1.4);\n  }\n}\n\nexport function process(n: i32): void {\n  // discrete band selector: 0->8, 1->12, 2->16\n  let sel: i32 = i32(clampf(params[P_BANDS], 0.0, 2.0) + 0.5);\n  const nBands: i32 = sel == 0 ? 8 : (sel == 1 ? 12 : 16);\n\n  const carrierMix: f32 = clampf(params[P_CARRIER], 0.0, 1.0); // 0 saw .. 1 noise\n  const formant: f32 = clampf(params[P_FORMANT], 0.0, 1.0);\n  const res: f32 = clampf(params[P_RES], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // recompute band table only when shape changes (no alloc, just writes)\n  if (nBands != curBands || formant != curFormant) {\n    rebuildBands(nBands, formant);\n    curBands = nBands; curFormant = formant;\n  }\n\n  // SVF damping: high res -> low damping -> narrow, resonant bands.\n  // map res 0..1 to q-damping 0.9 (wide) .. 0.06 (sharp)\n  const damp: f32 = 0.9 - res * 0.84;\n\n  // envelope follower coefficients (attack fast, release slower)\n  const atk: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 80.0 / sampleRate));\n  const rel: f32 = f32(1.0 - Mathf.exp(-2.0 * 3.14159265 * 12.0 / sampleRate));\n\n  // carrier saw frequency: a low buzzy fundamental ~ 90 Hz\n  const carHz: f32 = 90.0;\n  const carInc: f32 = carHz / sampleRate;\n\n  // output normalisation: more bands -> divide by sqrt(bands) so peak bounded\n  const norm: f32 = 2.4 / f32(Mathf.sqrt(f32(nBands)));\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n    const sb: i32 = c * MAX_BANDS;\n    let ph: f32 = carPhase[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f]; // modulator\n\n      // --- internal carrier: bright saw blended toward white noise ---\n      ph += carInc; if (ph >= 1.0) ph -= 1.0;\n      const saw: f32 = ph * 2.0 - 1.0;\n      const noise: f32 = nextNoise();\n      const carrier: f32 = saw * (1.0 - carrierMix) + noise * carrierMix;\n\n      let acc: f32 = 0.0;\n      for (let b = 0; b < nBands; b++) {\n        const idx: i32 = sb + b;\n\n        // --- modulator band-pass (state variable filter) ---\n        const fM: f32 = bandF[b];\n        let lpM: f32 = modLP[idx];\n        let bpM: f32 = modBP[idx];\n        let hpM: f32 = x - lpM - damp * bpM;\n        bpM = bpM + fM * hpM;\n        lpM = lpM + fM * bpM;\n        modLP[idx] = lpM; modBP[idx] = bpM;\n\n        // --- envelope follower on the modulator band ---\n        const rect: f32 = bpM < 0.0 ? -bpM : bpM;\n        let e: f32 = modEnv[idx];\n        const coef: f32 = rect > e ? atk : rel;\n        e = e + coef * (rect - e);\n        modEnv[idx] = e;\n\n        // --- carrier band-pass (formant-shifted centre) ---\n        const fC: f32 = bandFc[b];\n        let lpC: f32 = carLP[idx];\n        let bpC: f32 = carBP[idx];\n        let hpC: f32 = carrier - lpC - damp * bpC;\n        bpC = bpC + fC * hpC;\n        lpC = lpC + fC * bpC;\n        carLP[idx] = lpC; carBP[idx] = bpC;\n\n        // impose the modulator's band energy on the carrier band\n        acc += bpC * e;\n      }\n\n      const wet: f32 = clampf(acc * norm, -1.0, 1.0);\n      outBuf[base + f] = x * (1.0 - mix) + wet * mix;\n    }\n    carPhase[c] = ph;\n  }\n}\n",
  "publishedAt": 1751000066000
}