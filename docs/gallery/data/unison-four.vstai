{
  "format": 1,
  "name": "Unison Four",
  "isInstrument": true,
  "explanation": "A four-VCO unison mono/poly synthesizer. Every note stacks four band-limited saw/pulse oscillators that fan apart as Detune rises, piling into one fat, beating unison lead or bass — or spreading across a chord when several notes are held. Oscillator 1 hard-syncs the others (Sync) for resonant-formant grit, and the stack runs through a resonant 4-pole low-pass with its own decay envelope. Controls: Detune, Cutoff, Resonance, Env Amount, Sync, Decay and Level.",
  "params": [
    {
      "name": "Detune",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Cutoff",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Resonance",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "EnvAmount",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.6
    },
    {
      "name": "Sync",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.7
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Unison Four</title>\n<style>\n  :root {\n    --accent:  #ff6a3d;\n    --accent2: #ffe14a;\n    --bg0: #16100c;\n    --bg1: #221610;\n    --panel: #2a1c13;\n    --panel2: #34241a;\n    --ink: #ffdfc4;\n    --ink-dim: #c79877;\n    --line: #4a3322;\n    --glow: rgba(255,106,61,0.55);\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #3a2415 0%, var(--bg1) 45%, var(--bg0) 100%);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .shell {\n    max-width: 760px;\n    margin: 0 auto;\n    padding: 18px 18px 26px;\n  }\n\n  /* ---------- header ---------- */\n  .head {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    padding: 14px 18px;\n    border-radius: 16px 16px 0 0;\n    background: linear-gradient(180deg, var(--panel2), var(--panel));\n    border: 1px solid var(--line);\n    border-bottom: none;\n    box-shadow: inset 0 1px 0 rgba(255,225,74,0.12);\n  }\n  .brand { display: flex; align-items: baseline; gap: 12px; }\n  .logo {\n    font-weight: 800;\n    font-size: 26px;\n    letter-spacing: 1px;\n    background: linear-gradient(92deg, var(--accent2), var(--accent) 70%);\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n    text-shadow: 0 0 22px rgba(255,106,61,0.25);\n  }\n  .logo b { font-weight: 800; }\n  .sub {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n\n  /* mode toggle */\n  .mode {\n    display: flex;\n    border: 1px solid var(--line);\n    border-radius: 11px;\n    overflow: hidden;\n    background: #1c130d;\n    box-shadow: inset 0 2px 6px rgba(0,0,0,0.6);\n  }\n  .mode button {\n    appearance: none;\n    border: none;\n    background: transparent;\n    color: var(--ink-dim);\n    font: inherit;\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    padding: 8px 14px;\n    cursor: pointer;\n    transition: color .2s, background .2s, box-shadow .2s;\n  }\n  .mode button.on {\n    color: #1a0e06;\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: 0 0 16px var(--glow);\n  }\n\n  /* ---------- scope panel ---------- */\n  .scopewrap {\n    border: 1px solid var(--line);\n    border-top: none;\n    background:\n      linear-gradient(180deg, #150d08, #100a06);\n    padding: 0;\n    position: relative;\n    overflow: hidden;\n  }\n  svg.scope { display: block; width: 100%; height: 168px; }\n\n  /* the four oscillator bars overlay */\n  .vcobars {\n    position: absolute;\n    inset: 0;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    gap: 0;\n    pointer-events: none;\n  }\n\n  /* ---------- body ---------- */\n  .body {\n    border: 1px solid var(--line);\n    border-top: none;\n    border-radius: 0 0 16px 16px;\n    background: linear-gradient(180deg, var(--panel), #1d130c);\n    padding: 18px 16px 8px;\n  }\n\n  .row {\n    display: flex;\n    flex-wrap: wrap;\n    gap: 8px;\n    justify-content: center;\n  }\n\n  .knob {\n    width: 92px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 8px 4px 10px;\n    border-radius: 12px;\n    cursor: ns-resize;\n    user-select: none;\n    transition: background .2s;\n  }\n  .knob:hover { background: rgba(255,106,61,0.06); }\n  .knob .dial { position: relative; width: 70px; height: 70px; }\n  .knob .dial svg { display: block; }\n  .knob .label {\n    margin-top: 7px;\n    font-size: 9.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .knob .val {\n    margin-top: 3px;\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    font-weight: 600;\n  }\n\n  /* ---------- keyboard ---------- */\n  .keys {\n    margin-top: 14px;\n    position: relative;\n    height: 96px;\n    border-radius: 9px;\n    background: #0c0805;\n    border: 1px solid var(--line);\n    box-shadow: inset 0 3px 9px rgba(0,0,0,0.7);\n    overflow: hidden;\n    touch-action: none;\n  }\n  .wkey, .bkey {\n    position: absolute;\n    bottom: 0;\n    cursor: pointer;\n  }\n  .wkey {\n    top: 0;\n    background: linear-gradient(180deg, #efe2d2, #c9b59c);\n    border: 1px solid #2c1d12;\n    border-radius: 0 0 5px 5px;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent2), var(--accent));\n    box-shadow: inset 0 0 18px rgba(0,0,0,0.25);\n  }\n  .bkey {\n    top: 0;\n    height: 58%;\n    background: linear-gradient(180deg, #2a1c12, #100a06);\n    border: 1px solid #000;\n    border-radius: 0 0 4px 4px;\n    z-index: 3;\n    box-shadow: 0 3px 5px rgba(0,0,0,0.6);\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #b23a16);\n    box-shadow: 0 0 14px var(--glow);\n  }\n\n  .foot {\n    margin-top: 9px;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--ink-dim);\n  }\n  .stack-pill {\n    color: var(--accent2);\n    font-weight: 700;\n  }\n</style>\n</head>\n<body>\n<div class=\"shell\">\n\n  <div class=\"head\">\n    <div class=\"brand\">\n      <div class=\"logo\">UNISON<b>·</b>FOUR</div>\n      <div class=\"sub\">4&times;VCO Unison Monster</div>\n    </div>\n    <div class=\"mode\" id=\"mode\">\n      <button data-m=\"mono\" class=\"on\">Mono</button>\n      <button data-m=\"poly\">Poly</button>\n    </div>\n  </div>\n\n  <div class=\"scopewrap\">\n    <div class=\"vcobars\" id=\"vcobars\"></div>\n    <svg class=\"scope\" id=\"scope\" viewBox=\"0 0 600 168\" preserveAspectRatio=\"none\">\n      <defs>\n        <linearGradient id=\"gscope\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\"  stop-color=\"#ffe14a\"/>\n          <stop offset=\"100%\" stop-color=\"#ff6a3d\"/>\n        </linearGradient>\n        <filter id=\"fglow\" x=\"-20%\" y=\"-60%\" width=\"140%\" height=\"220%\">\n          <feGaussianBlur stdDeviation=\"2.4\" result=\"b\"/>\n          <feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge>\n        </filter>\n      </defs>\n      <line x1=\"0\" y1=\"84\" x2=\"600\" y2=\"84\" stroke=\"#3a2616\" stroke-width=\"1\"/>\n      <path id=\"wave\" fill=\"none\" stroke=\"url(#gscope)\" stroke-width=\"2.4\"\n            stroke-linejoin=\"round\" filter=\"url(#fglow)\"/>\n    </svg>\n  </div>\n\n  <div class=\"body\">\n    <div class=\"row\" id=\"knobs\"></div>\n\n    <div class=\"keys\" id=\"keys\"></div>\n\n    <div class=\"foot\">\n      <span>Korg&nbsp;Mono/Poly&nbsp;lineage</span>\n      <span class=\"stack-pill\" id=\"stacklabel\">STACK &times;4 &middot; SPREAD 0.45</span>\n    </div>\n  </div>\n\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----------------\n  var PARAMS = [\n    { name: \"Detune\",    index: 0, min: 0, max: 1, def: 0.45 },\n    { name: \"Cutoff\",    index: 1, min: 0, max: 1, def: 0.5  },\n    { name: \"Resonance\", index: 2, min: 0, max: 1, def: 0.4  },\n    { name: \"Env Amt\",   index: 3, min: 0, max: 1, def: 0.6  },\n    { name: \"Sync\",      index: 4, min: 0, max: 1, def: 0.0  },\n    { name: \"Decay\",     index: 5, min: 0, max: 1, def: 0.45 },\n    { name: \"Level\",     index: 6, min: 0, max: 1, def: 0.7  }\n  ];\n\n  var values = {};            // index -> current 0..1 value\n  var knobEls = {};           // index -> { arc, val, pointer }\n\n  function setParam(index, value) {\n    values[index] = value;\n    if (window.vstai && window.vstai.setParam) {\n      try { window.vstai.setParam(index, value); } catch (e) {}\n    }\n  }\n\n  // =====================================================================\n  //  KNOBS — hand-drawn SVG dials, drag vertically, dblclick reset, wheel\n  // =====================================================================\n  var KN = 70, CX = 35, CY = 35, R = 25;\n  var A0 = 135, A1 = 405;     // sweep arc in degrees (270 deg)\n\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(cx, cy, r, d0, d1) {\n    var p0 = polar(cx, cy, r, d0);\n    var p1 = polar(cx, cy, r, d1);\n    var large = (d1 - d0) > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \" +\n           p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function fmtVal(p, v) {\n    if (p.name === \"Sync\") return v < 0.02 ? \"off\" : Math.round(v * 100) + \"%\";\n    return Math.round(v * 100) + \"%\";\n  }\n\n  function buildKnob(p) {\n    var wrap = document.createElement(\"div\");\n    wrap.className = \"knob\";\n    wrap.innerHTML =\n      '<div class=\"dial\">' +\n        '<svg width=\"' + KN + '\" height=\"' + KN + '\" viewBox=\"0 0 ' + KN + ' ' + KN + '\">' +\n          '<defs>' +\n            '<radialGradient id=\"kb' + p.index + '\" cx=\"50%\" cy=\"38%\" r=\"65%\">' +\n              '<stop offset=\"0%\" stop-color=\"#4a3525\"/>' +\n              '<stop offset=\"100%\" stop-color=\"#1c130c\"/>' +\n            '</radialGradient>' +\n          '</defs>' +\n          '<path d=\"' + arcPath(CX, CY, R, A0, A1) + '\" fill=\"none\" ' +\n                'stroke=\"#3a2616\" stroke-width=\"5\" stroke-linecap=\"round\"/>' +\n          '<path class=\"karc\" d=\"\" fill=\"none\" stroke=\"url(#gscope)\" ' +\n                'stroke-width=\"5\" stroke-linecap=\"round\" ' +\n                'style=\"filter:drop-shadow(0 0 4px var(--glow))\"/>' +\n          '<circle cx=\"' + CX + '\" cy=\"' + CY + '\" r=\"18\" fill=\"url(#kb' + p.index + ')\" ' +\n                  'stroke=\"#0c0805\" stroke-width=\"1.5\"/>' +\n          '<line class=\"kpt\" x1=\"' + CX + '\" y1=\"' + CY + '\" x2=\"' + CX + '\" y2=\"' + (CY - 17) + '\" ' +\n                'stroke=\"#ffe14a\" stroke-width=\"2.5\" stroke-linecap=\"round\" ' +\n                'style=\"filter:drop-shadow(0 0 3px var(--glow))\"/>' +\n        '</svg>' +\n      '</div>' +\n      '<div class=\"label\">' + p.name + '</div>' +\n      '<div class=\"val\">' + fmtVal(p, p.def) + '</div>';\n\n    var svg = wrap.querySelector(\"svg\");\n    var arc = wrap.querySelector(\".karc\");\n    var ptr = wrap.querySelector(\".kpt\");\n    var val = wrap.querySelector(\".val\");\n\n    function render(v) {\n      var ang = A0 + (A1 - A0) * v;\n      arc.setAttribute(\"d\", arcPath(CX, CY, R, A0, ang));\n      ptr.setAttribute(\"transform\", \"rotate(\" + (ang - 270) + \" \" + CX + \" \" + CY + \")\");\n      val.textContent = fmtVal(p, v);\n    }\n    knobEls[p.index] = { render: render };\n    render(p.def);\n    setParam(p.index, p.def);\n\n    // ---- drag interaction ----\n    var dragging = false, lastY = 0;\n    function apply(v) {\n      v = Math.max(0, Math.min(1, v));\n      setParam(p.index, v);\n      render(v);\n      if (p.index === 0) updateStackVisual();\n    }\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var step = (e.shiftKey ? 0.0015 : 0.006);\n      apply((values[p.index] || 0) + dy * step);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      document.removeEventListener(\"mousemove\", onMove);\n      document.removeEventListener(\"mouseup\", onUp);\n      document.removeEventListener(\"touchmove\", onMove);\n      document.removeEventListener(\"touchend\", onUp);\n    }\n    function onDown(e) {\n      dragging = true;\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      document.addEventListener(\"mousemove\", onMove);\n      document.addEventListener(\"mouseup\", onUp);\n      document.addEventListener(\"touchmove\", onMove, { passive: false });\n      document.addEventListener(\"touchend\", onUp);\n      e.preventDefault();\n    }\n    wrap.addEventListener(\"mousedown\", onDown);\n    wrap.addEventListener(\"touchstart\", onDown, { passive: false });\n    wrap.addEventListener(\"dblclick\", function () { apply(p.def); });\n    wrap.addEventListener(\"wheel\", function (e) {\n      apply((values[p.index] || 0) - Math.sign(e.deltaY) * 0.03);\n      e.preventDefault();\n    }, { passive: false });\n\n    return wrap;\n  }\n\n  var knobRow = document.getElementById(\"knobs\");\n  PARAMS.forEach(function (p) { knobRow.appendChild(buildKnob(p)); });\n\n  // =====================================================================\n  //  VCO BARS — four glowing oscillator bars that fan out with Detune\n  // =====================================================================\n  var bars = [];\n  var barsWrap = document.getElementById(\"vcobars\");\n  for (var i = 0; i < 4; i++) {\n    var b = document.createElement(\"div\");\n    b.style.position = \"absolute\";\n    b.style.bottom = \"0\";\n    b.style.width = \"9px\";\n    b.style.height = \"0\";\n    b.style.borderRadius = \"4px 4px 0 0\";\n    b.style.background = \"linear-gradient(180deg, var(--accent2), var(--accent))\";\n    b.style.boxShadow = \"0 0 12px var(--glow)\";\n    b.style.left = \"50%\";\n    b.style.transition = \"left .18s ease, opacity .2s\";\n    b.style.opacity = \"0.9\";\n    barsWrap.appendChild(b);\n    bars.push(b);\n  }\n  var stackLabel = document.getElementById(\"stacklabel\");\n\n  function updateStackVisual() {\n    var d = values[0] || 0;\n    // fan the four bars symmetrically outward; offsets weighted like the DSP\n    var offs = [0, -1, 0.55, 1];\n    var spread = 16 + d * 150;      // px from center per unit\n    for (var i = 0; i < 4; i++) {\n      var px = offs[i] * spread;\n      bars[i].style.left = \"calc(50% + \" + px.toFixed(1) + \"px - 4.5px)\";\n    }\n    stackLabel.textContent = \"STACK ×4 · SPREAD \" + d.toFixed(2);\n  }\n  updateStackVisual();\n\n  // =====================================================================\n  //  MODE toggle (mono / poly) — visual character + held-note behaviour.\n  //  Mono retriggers a single fat unison stack; Poly lets notes ring.\n  // =====================================================================\n  var polyMode = false;\n  var modeWrap = document.getElementById(\"mode\");\n  modeWrap.addEventListener(\"click\", function (e) {\n    var btn = e.target.closest(\"button\");\n    if (!btn) return;\n    polyMode = btn.dataset.m === \"poly\";\n    Array.prototype.forEach.call(modeWrap.children, function (b) {\n      b.classList.toggle(\"on\", b === btn);\n    });\n  });\n\n  // =====================================================================\n  //  ANIMATED STACKED-SAW OSCILLOSCOPE — four detuned saws summed,\n  //  reshaped by the Sync / Cutoff knobs, drawn on rAF.\n  // =====================================================================\n  var wave = document.getElementById(\"wave\");\n  var t = 0;\n  var energy = 0;          // eased \"is something playing\" level\n\n  function frac(x) { return x - Math.floor(x); }\n\n  function draw() {\n    if (document.hidden) { return; }\n    t += 0.018;\n    var detune = values[0] || 0;\n    var cutoff = values[1] || 0;\n    var reso   = values[2] || 0;\n    var sync   = values[4] || 0;\n\n    energy += ((heldCount > 0 ? 1 : 0.32) - energy) * 0.06;\n\n    var W = 600, H = 168, mid = 84;\n    var amp = (24 + 46 * energy);\n    var pts = \"M 0 \" + mid;\n    var spread = detune * 0.06;\n    var offs = [0, -1, 0.55, 1];\n    for (var x = 0; x <= W; x += 4) {\n      var ph = x / W;\n      var s = 0;\n      for (var o = 0; o < 4; o++) {\n        var f = (1.0 + offs[o] * spread) * (3 + cutoff * 5);\n        var p = frac(ph * f + t * (0.6 + offs[o] * 0.12));\n        // hard-sync bend: pull phase toward 0 by sync amount each master cycle\n        if (sync > 0 && o > 0) p = frac(p * (1 - sync * 0.85) + ph * (3 + cutoff * 5) * sync * 0.0);\n        var saw = 2 * p - 1;                       // saw\n        // a little resonant ripple near the edge driven by Resonance\n        saw += reso * 0.5 * Math.sin(p * Math.PI * 2 * (2 + cutoff * 6));\n        s += saw;\n      }\n      s *= 0.25;\n      var y = mid - s * amp;\n      pts += \" L \" + x + \" \" + y.toFixed(1);\n    }\n    wave.setAttribute(\"d\", pts);\n\n    // pulse the bars with energy\n    for (var i = 0; i < 4; i++) {\n      var base = 30 + i * 6;\n      var h = base + energy * (60 + Math.sin(t * 4 + i) * 14);\n      bars[i].style.height = h.toFixed(0) + \"px\";\n    }\n    requestAnimationFrame(draw);\n  }\n  document.addEventListener(\"visibilitychange\", function () {\n    if (!document.hidden) requestAnimationFrame(draw);\n  });\n  requestAnimationFrame(draw);\n\n  // =====================================================================\n  //  ON-SCREEN KEYBOARD — plays via window.vstai.noteOn / noteOff\n  // =====================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var FIRST = 48;          // C3\n  var OCTAVES = 2;\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 }; // white-index -> black semitone\n  var heldCount = 0;\n  var pressed = {};\n\n  function buildKeyboard() {\n    keysEl.innerHTML = \"\";\n    var whiteCount = WHITE.length * OCTAVES;\n    var ww = 100 / whiteCount;     // percent width\n    var wi = 0;\n    for (var oc = 0; oc < OCTAVES; oc++) {\n      for (var k = 0; k < WHITE.length; k++) {\n        var note = FIRST + oc * 12 + WHITE[k];\n        var el = document.createElement(\"div\");\n        el.className = \"wkey\";\n        el.style.left = (wi * ww) + \"%\";\n        el.style.width = ww + \"%\";\n        el.dataset.note = note;\n        keysEl.appendChild(el);\n        bindKey(el, note);\n        // black key after this white?\n        if (BLACK.hasOwnProperty(k)) {\n          var bnote = FIRST + oc * 12 + BLACK[k];\n          var bk = document.createElement(\"div\");\n          bk.className = \"bkey\";\n          bk.style.left = \"calc(\" + ((wi + 1) * ww) + \"% - \" + (ww * 0.3) + \"%)\";\n          bk.style.width = (ww * 0.6) + \"%\";\n          bk.dataset.note = bnote;\n          keysEl.appendChild(bk);\n          bindKey(bk, bnote);\n        }\n        wi++;\n      }\n    }\n  }\n\n  function noteOn(note, el) {\n    if (pressed[note]) return;\n    pressed[note] = el;\n    el.classList.add(\"down\");\n    heldCount++;\n    if (window.vstai && window.vstai.noteOn) {\n      try { window.vstai.noteOn(note, 0.9); } catch (e) {}\n    }\n  }\n  function noteOff(note) {\n    var el = pressed[note];\n    if (!el) return;\n    el.classList.remove(\"down\");\n    delete pressed[note];\n    heldCount = Math.max(0, heldCount - 1);\n    if (window.vstai && window.vstai.noteOff) {\n      try { window.vstai.noteOff(note); } catch (e) {}\n    }\n  }\n\n  function bindKey(el, note) {\n    el.addEventListener(\"mousedown\", function (e) { noteOn(note, el); e.preventDefault(); });\n    el.addEventListener(\"mouseup\", function () { noteOff(note); });\n    el.addEventListener(\"mouseleave\", function () { if (mouseDown) noteOff(note); });\n    el.addEventListener(\"mouseenter\", function () { if (mouseDown) noteOn(note, el); });\n    el.addEventListener(\"touchstart\", function (e) { noteOn(note, el); e.preventDefault(); }, { passive: false });\n    el.addEventListener(\"touchend\", function (e) { noteOff(note); e.preventDefault(); });\n  }\n\n  var mouseDown = false;\n  document.addEventListener(\"mousedown\", function () { mouseDown = true; });\n  document.addEventListener(\"mouseup\", function () {\n    mouseDown = false;\n    for (var k in pressed) noteOff(+k);\n  });\n\n  buildKeyboard();\n\n  // computer keyboard: a..k row across two octaves\n  var KEYMAP = { a:48,w:49,s:50,e:51,d:52,f:53,t:54,g:55,y:56,h:57,u:58,j:59,k:60,o:61,l:62 };\n  document.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var n = KEYMAP[e.key];\n    if (n == null) return;\n    var el = keysEl.querySelector('[data-note=\"' + n + '\"]');\n    if (el) noteOn(n, el);\n  });\n  document.addEventListener(\"keyup\", function (e) {\n    var n = KEYMAP[e.key];\n    if (n != null) noteOff(n);\n  });\n\n  // =====================================================================\n  //  HOST CONTRACT — init params once vstai is ready\n  // =====================================================================\n  function pushAll() {\n    PARAMS.forEach(function (p) {\n      var v = (p.index in values) ? values[p.index] : p.def;\n      setParam(p.index, v);\n    });\n  }\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(pushAll);\n  } else {\n    pushAll();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  UNISON FOUR — a four-VCO unison mono/poly synthesizer instrument.\n//  (Korg Mono/Poly lineage, original implementation.)\n//\n//  Every held note drives a VOICE that stacks FOUR oscillators. Each\n//  oscillator is a band-limited saw/pulse blend; the four are spread\n//  apart by a Detune control so they pile into one fat, beating unison\n//  stack (a thick mono lead/bass) or, with several notes held, spread\n//  across a chord. Oscillator 1 hard-syncs oscillators 2..4 (Sync) for\n//  the classic resonant-formant grit. The summed stack feeds a resonant\n//  4-pole low-pass driven by its own decay envelope (Cutoff + Env Amount\n//  + Resonance), then an amplitude decay envelope. Pure algorithm, no\n//  samples, no host imports.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 6;   // notes held at once\nconst NUM_OSC: i32 = 4;      // the four VCOs per voice\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_DETUNE: i32 = 0;  // 0..1  -> unison spread / width of the 4-VCO stack\nconst P_CUTOFF: i32 = 1;  // 0..1  -> base filter cutoff\nconst P_RESO:   i32 = 2;  // 0..1  -> filter resonance\nconst P_ENVAMT: i32 = 3;  // 0..1  -> filter envelope amount (cutoff sweep)\nconst P_SYNC:   i32 = 4;  // 0..1  -> hard-sync amount (osc 2..4 reset to osc1)\nconst P_DECAY:  i32 = 5;  // 0..1  -> amp/filter decay time\nconst P_LEVEL:  i32 = 6;  // 0..1  -> output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\n// four oscillator phases per voice (flat array: voice * NUM_OSC + osc)\nconst vPhase:  StaticArray<f32> = new StaticArray<f32>(NUM_VOICES * NUM_OSC);\n\n// amplitude envelope (attack then decay-to-floor while held, release on lift)\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 0 idle 1 atk 2 dec 4 rel\n// filter envelope (attack then decay)\nconst vFEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vFStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// resonant ladder filter state (4 one-pole stages per voice)\nconst vF0: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF1: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF2: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vF3: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\n// fixed per-oscillator detune directions, in cents-fraction units, so the\n// stack fans symmetrically outward as Detune rises (osc0 is the anchor).\nconst OSC_SPREAD: StaticArray<f32> = new StaticArray<f32>(NUM_OSC);\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vFEnv[v] = 0.0; vFStage[v] = 0;\n    vF0[v] = 0.0; vF1[v] = 0.0; vF2[v] = 0.0; vF3[v] = 0.0;\n    for (let o = 0; o < NUM_OSC; o++) vPhase[v * NUM_OSC + o] = 0.0;\n  }\n  // osc0 anchor, the rest fan out: -1, +0.55, +1 (asymmetric -> richer beat)\n  OSC_SPREAD[0] = 0.0;\n  OSC_SPREAD[1] = -1.0;\n  OSC_SPREAD[2] = 0.55;\n  OSC_SPREAD[3] = 1.0;\n  ageCounter = 0;\n  params[P_DETUNE] = 0.45;\n  params[P_CUTOFF] = 0.5;\n  params[P_RESO]   = 0.4;\n  params[P_ENVAMT] = 0.6;\n  params[P_SYNC]   = 0.0;\n  params[P_DECAY]  = 0.45;\n  params[P_LEVEL]  = 0.7;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;   // attack\n  vFStage[slot] = 1;\n  vAEnv[slot]   = 0.0;\n  vFEnv[slot]   = 0.0;\n  // stagger the four oscillator phases so unison beating starts lively\n  vPhase[slot * NUM_OSC + 0] = 0.0;\n  vPhase[slot * NUM_OSC + 1] = 0.25;\n  vPhase[slot * NUM_OSC + 2] = 0.5;\n  vPhase[slot * NUM_OSC + 3] = 0.75;\n  vF0[slot] = 0.0; vF1[slot] = 0.0; vF2[slot] = 0.0; vF3[slot] = 0.0;\n  vAge[slot] = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 4;  // release\n      vFStage[i] = 4;\n    }\n  }\n}\n\n// polyBLEP correction removes the worst aliasing on saw/pulse edges\n@inline function polyBlep(t: f32, dt: f32): f32 {\n  if (dt <= 0.0) return 0.0;\n  if (t < dt) {\n    const x: f32 = t / dt;\n    return x + x - x * x - 1.0;\n  } else if (t > 1.0 - dt) {\n    const x: f32 = (t - 1.0) / dt;\n    return x * x + x + x + 1.0;\n  }\n  return 0.0;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const detune: f32  = clampf(params[P_DETUNE], 0.0, 1.0);\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN: f32   = clampf(params[P_RESO], 0.0, 1.0);\n  const envAmt: f32  = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const syncN: f32   = clampf(params[P_SYNC], 0.0, 1.0);\n  const decN: f32    = clampf(params[P_DECAY], 0.0, 1.0);\n  const level: f32   = clampf(params[P_LEVEL], 0.0, 1.0) * 1.1;\n\n  // envelope rates -----------------------------------------------------\n  const atkS: f32 = 0.004;                       // snappy attack (mono stab)\n  const decS: f32 = 0.02 + decN * decN * 2.4;    // decay time 20 ms .. ~2.4 s\n  const relS: f32 = 0.03 + decN * 1.2;           // release tracks decay\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const decRate: f32 = 1.0 / (decS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n  // while held the amp decays toward this floor (longer Decay -> louder avg)\n  const susFloor: f32 = 0.18 + decN * 0.62;\n\n  // unison spread: up to ~ +/-0.5 semitone across the stack -> fat & wide\n  const spreadSemi: f32 = detune * 0.5;\n\n  // base cutoff in Hz, exponential ~50 Hz .. ~17 kHz\n  const baseHz: f32 = 50.0 * f32(Mathf.pow(340.0, cutoffN));\n  // envelope sweeps cutoff up by up to ~6.5 octaves\n  const envOct: f32 = envAmt * 6.5;\n  // resonance feedback 0..~4.2 (screaming near top)\n  const reso: f32 = resoN * 4.2;\n\n  // sync depth: how strongly osc1's reset drags osc2..4 (0 = free, 1 = hard)\n  const sync: f32 = syncN;\n\n  // headroom: 6 voices * 4 oscillators summed -> scale so chords stay bounded\n  // pushed hot into the saturator so a single unison stack is thick, not thin\n  const voiceScale: f32 = 1.2;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude envelope (attack -> decay-to-floor -> release) -\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {\n        aenv -= decRate * (aenv - susFloor);\n        if (aenv < susFloor + 0.0005) aenv = susFloor;\n      } else if (astg == 4) {\n        aenv -= relRate * aenv + 0.000002;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- filter envelope (attack -> decay to zero) ----------------\n      let fenv: f32 = vFEnv[v];\n      let fstg: i32 = vFStage[v];\n      if (fstg == 1) {\n        fenv += atkRate;\n        if (fenv >= 1.0) { fenv = 1.0; fstg = 2; }\n      } else if (fstg == 2) {\n        fenv -= decRate * fenv;\n        if (fenv < 0.0008) fenv = 0.0;\n      } else if (fstg == 4) {\n        fenv -= relRate * fenv + 0.000002;\n        if (fenv <= 0.0) fenv = 0.0;\n      }\n      vFEnv[v] = fenv;\n      vFStage[v] = fstg;\n\n      // ---- the four unison oscillators ------------------------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const pbase: i32 = v * NUM_OSC;\n\n      // advance osc0 (the sync master) first, detect its wrap\n      let p0: f32 = vPhase[pbase + 0];\n      const inc0: f32 = baseInc;   // anchor pitch (OSC_SPREAD[0] == 0)\n      p0 += inc0;\n      let masterWrapped: bool = false;\n      if (p0 >= 1.0) { p0 -= 1.0; masterWrapped = true; }\n      vPhase[pbase + 0] = p0;\n\n      let stack: f32 = 0.0;\n      for (let o = 0; o < NUM_OSC; o++) {\n        // per-oscillator detune ratio (anchor osc0 unshifted)\n        const semi: f32 = spreadSemi * OSC_SPREAD[o];\n        const inc: f32 = baseInc * f32(Mathf.pow(2.0, semi / 12.0));\n\n        let p: f32;\n        if (o == 0) {\n          p = p0;\n        } else {\n          p = vPhase[pbase + o];\n          p += inc;\n          if (p >= 1.0) p -= 1.0;\n          // hard sync: when the master wraps, drag this osc's phase back\n          // toward 0 by the sync amount (1 = full reset -> bright formant)\n          if (masterWrapped && sync > 0.0) {\n            p = p * (1.0 - sync);\n          }\n          vPhase[pbase + o] = p;\n        }\n\n        // band-limited saw + pulse blend for a thick, edgy timbre\n        let saw: f32 = 2.0 * p - 1.0;\n        saw -= polyBlep(p, inc);\n\n        const pw: f32 = 0.42;\n        let sq: f32 = p < pw ? 1.0 : -1.0;\n        sq += polyBlep(p, inc);\n        let pb: f32 = p + (1.0 - pw);\n        if (pb >= 1.0) pb -= 1.0;\n        sq -= polyBlep(pb, inc);\n\n        stack += saw * 0.65 + sq * 0.42;\n      }\n      // average the four so adding oscillators fattens without exploding\n      stack *= 0.25;\n\n      // ---- resonant 4-pole low-pass (per voice) ---------------------\n      let fc: f32 = baseHz * f32(Mathf.pow(2.0, envOct * fenv));\n      if (fc > sr * 0.45) fc = sr * 0.45;\n      if (fc < 20.0) fc = 20.0;\n\n      let g: f32 = 1.0 - f32(Mathf.exp(-TWO_PI * fc / sr));\n      if (g > 0.99) g = 0.99;\n\n      let s0: f32 = vF0[v];\n      let s1: f32 = vF1[v];\n      let s2: f32 = vF2[v];\n      let s3: f32 = vF3[v];\n\n      let inp: f32 = stack - reso * s3;\n      inp = f32(Mathf.tanh(inp));\n\n      s0 += g * (inp - s0);\n      s1 += g * (s0 - s1);\n      s2 += g * (s1 - s2);\n      s3 += g * (s2 - s3);\n\n      vF0[v] = s0; vF1[v] = s1; vF2[v] = s2; vF3[v] = s3;\n\n      outL += s3 * aenv * vVel[v];\n    }\n\n    // ---- sum + soft saturate for analog-monster glue ----------------\n    let mix: f32 = outL * voiceScale * level;\n    mix = f32(Mathf.tanh(mix * 1.4));\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000099000
}