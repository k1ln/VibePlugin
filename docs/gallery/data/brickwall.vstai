{
  "format": 1,
  "name": "Brickwall",
  "isInstrument": false,
  "explanation": "A look-ahead brickwall limiter: a short look-ahead delay feeds a fast peak detector that pulls the gain down before each transient arrives, so the output never exceeds the Ceiling. Threshold drives the input into the limiter, Release sets how quickly the gain recovers, and Gain is a post makeup trim. Transparent on quiet input, an absolute wall on loud.",
  "params": [
    {
      "name": "Threshold",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Ceiling",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 1
    },
    {
      "name": "Release",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Gain",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <title>Brickwall</title>\n  <style>\n    :root {\n      --accent: #ff6b6b;\n      --accent2: #ffb36b;\n      --bg0: #0b0a0c;\n      --bg1: #161318;\n      --mortar: #1c1820;\n      --brick-a: #2a2229;\n      --brick-b: #322631;\n      --ink: #efe7ea;\n      --ink-dim: #9a8f96;\n      --line: rgba(255,255,255,0.06);\n    }\n\n    * { box-sizing: border-box; }\n\n    html, body {\n      margin: 0;\n      height: 100%;\n    }\n\n    body {\n      font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n      color: var(--ink);\n      background:\n        radial-gradient(120% 90% at 50% -10%, #241a22 0%, var(--bg1) 42%, var(--bg0) 100%);\n      min-height: 100%;\n      display: flex;\n      justify-content: center;\n      padding: 18px;\n      overflow-x: hidden;\n    }\n\n    .panel {\n      width: 100%;\n      max-width: 560px;\n      background:\n        linear-gradient(180deg, rgba(255,255,255,0.04), rgba(0,0,0,0.20)),\n        var(--bg1);\n      border: 1px solid rgba(255,255,255,0.08);\n      border-radius: 18px;\n      box-shadow:\n        0 24px 60px rgba(0,0,0,0.55),\n        inset 0 1px 0 rgba(255,255,255,0.07);\n      overflow: hidden;\n    }\n\n    /* ---------- header ---------- */\n    .header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      padding: 16px 20px 12px;\n      border-bottom: 1px solid var(--line);\n      background: linear-gradient(180deg, rgba(255,107,107,0.06), transparent);\n    }\n\n    .brand {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n    }\n\n    .logo {\n      width: 30px;\n      height: 30px;\n      border-radius: 7px;\n      position: relative;\n      background:\n        repeating-linear-gradient(0deg, #211a20 0 6px, #2c2230 6px 7px),\n        linear-gradient(180deg, var(--accent2), var(--accent));\n      box-shadow:\n        inset 0 0 0 1px rgba(0,0,0,0.4),\n        0 0 16px rgba(255,107,107,0.45);\n    }\n    .logo::after {\n      content: \"\";\n      position: absolute;\n      left: 4px; right: 4px; top: 9px;\n      height: 2px;\n      border-radius: 2px;\n      background: var(--accent);\n      box-shadow: 0 0 8px var(--accent), 0 0 16px var(--accent);\n    }\n\n    .title {\n      font-size: 17px;\n      font-weight: 700;\n      letter-spacing: 0.14em;\n      text-transform: uppercase;\n    }\n    .subtitle {\n      font-size: 10px;\n      letter-spacing: 0.32em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n      margin-top: 2px;\n    }\n\n    .led {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      font-size: 10px;\n      letter-spacing: 0.22em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n    }\n    .led-dot {\n      width: 11px;\n      height: 11px;\n      border-radius: 50%;\n      background: #3a2a2c;\n      box-shadow: inset 0 0 4px rgba(0,0,0,0.8);\n      transition: background 0.06s linear, box-shadow 0.06s linear;\n    }\n    .led-dot.hot {\n      background: var(--accent);\n      box-shadow: 0 0 10px var(--accent), 0 0 20px var(--accent), inset 0 0 4px rgba(255,255,255,0.4);\n    }\n\n    /* ---------- the wall / visualiser ---------- */\n    .stage {\n      position: relative;\n      height: 200px;\n      margin: 16px;\n      border-radius: 12px;\n      overflow: hidden;\n      background:\n        linear-gradient(180deg, #0d0a0e, #120e13);\n      box-shadow: inset 0 2px 18px rgba(0,0,0,0.7), inset 0 0 0 1px rgba(255,255,255,0.04);\n    }\n\n    /* the brick wall, drawn purely with gradients */\n    .wall {\n      position: absolute;\n      inset: 0;\n      background-color: var(--mortar);\n      background-image:\n        linear-gradient(335deg, rgba(255,107,107,0.05), transparent 60%),\n        linear-gradient(90deg, var(--brick-a) 0 49.3%, transparent 49.3% 50.7%, var(--brick-b) 50.7%),\n        linear-gradient(0deg, var(--mortar) 0 7%, transparent 7%);\n      background-size:\n        100% 100%,\n        96px 30px,\n        96px 30px;\n      background-position:\n        0 0,\n        0 0,\n        0 0;\n      opacity: 0.9;\n    }\n    /* offset every other row of bricks for the running-bond pattern */\n    .wall::before {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background-image:\n        linear-gradient(90deg, var(--brick-b) 0 49.3%, transparent 49.3% 50.7%, var(--brick-a) 50.7%);\n      background-size: 96px 30px;\n      background-position: 48px 15px;\n      -webkit-mask-image: repeating-linear-gradient(0deg, transparent 0 30px, #000 30px 60px);\n      mask-image: repeating-linear-gradient(0deg, transparent 0 30px, #000 30px 60px);\n      opacity: 0.85;\n    }\n    /* subtle top-light on the bricks */\n    .wall::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(180deg, rgba(255,255,255,0.05), transparent 30%, rgba(0,0,0,0.35));\n      pointer-events: none;\n    }\n\n    canvas#scope {\n      position: absolute;\n      inset: 0;\n      width: 100%;\n      height: 100%;\n    }\n\n    /* the glowing ceiling line */\n    .ceiling {\n      position: absolute;\n      left: 0; right: 0;\n      height: 2px;\n      background: var(--accent);\n      box-shadow: 0 0 10px var(--accent), 0 0 26px var(--accent), 0 0 50px rgba(255,107,107,0.5);\n      z-index: 4;\n      transition: top 0.08s ease, bottom 0.08s ease;\n    }\n    .ceiling .tag {\n      position: absolute;\n      right: 8px;\n      top: -9px;\n      font-size: 9px;\n      letter-spacing: 0.2em;\n      color: var(--accent);\n      text-shadow: 0 0 8px rgba(255,107,107,0.8);\n      background: rgba(11,10,12,0.7);\n      padding: 1px 5px;\n      border-radius: 4px;\n    }\n    .ceiling.bottom {\n      box-shadow: 0 0 10px var(--accent), 0 0 26px var(--accent);\n    }\n    /* impact flash animation when the wave slams the ceiling */\n    @keyframes slam {\n      0%   { opacity: 1; height: 2px; }\n      40%  { opacity: 1; height: 5px; }\n      100% { opacity: 1; height: 2px; }\n    }\n    .ceiling.hit {\n      animation: slam 0.18s ease-out;\n      box-shadow: 0 0 16px var(--accent2), 0 0 40px var(--accent), 0 0 80px var(--accent);\n    }\n\n    /* gain-reduction meter on the right edge of the stage */\n    .gr {\n      position: absolute;\n      top: 8px; bottom: 8px; right: 8px;\n      width: 8px;\n      border-radius: 5px;\n      background: rgba(0,0,0,0.45);\n      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.06);\n      z-index: 5;\n      overflow: hidden;\n    }\n    .gr-fill {\n      position: absolute;\n      left: 0; right: 0; top: 0;\n      height: 0%;\n      background: linear-gradient(180deg, var(--accent2), var(--accent));\n      box-shadow: 0 0 12px var(--accent);\n      transition: height 0.06s linear;\n    }\n    .gr-label {\n      position: absolute;\n      bottom: 6px; right: 20px;\n      font-size: 8px;\n      letter-spacing: 0.18em;\n      color: var(--ink-dim);\n      writing-mode: vertical-rl;\n      z-index: 5;\n    }\n\n    /* ---------- controls ---------- */\n    .controls {\n      display: grid;\n      grid-template-columns: repeat(4, 1fr);\n      gap: 12px;\n      padding: 4px 16px 22px;\n    }\n    @media (max-width: 460px) {\n      .controls { grid-template-columns: repeat(2, 1fr); }\n    }\n\n    .knobcell {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      gap: 8px;\n      padding: 12px 6px;\n      border-radius: 12px;\n      background: linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0.18));\n      box-shadow: inset 0 1px 0 rgba(255,255,255,0.05), 0 2px 8px rgba(0,0,0,0.35);\n    }\n    .knob {\n      position: relative;\n      width: 76px;\n      height: 76px;\n      cursor: ns-resize;\n      touch-action: none;\n      user-select: none;\n    }\n    .knob svg { display: block; width: 100%; height: 100%; }\n    .klabel {\n      font-size: 10px;\n      letter-spacing: 0.2em;\n      text-transform: uppercase;\n      color: var(--ink-dim);\n    }\n    .kval {\n      font-size: 13px;\n      font-weight: 600;\n      font-variant-numeric: tabular-nums;\n      color: var(--ink);\n      min-height: 16px;\n    }\n    .knobcell:hover .klabel { color: var(--accent2); }\n\n    .footer {\n      padding: 0 20px 16px;\n      font-size: 9px;\n      letter-spacing: 0.24em;\n      text-transform: uppercase;\n      color: rgba(154,143,150,0.5);\n      text-align: center;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"panel\">\n    <div class=\"header\">\n      <div class=\"brand\">\n        <div class=\"logo\"></div>\n        <div>\n          <div class=\"title\">Brickwall</div>\n          <div class=\"subtitle\">Look-Ahead Limiter</div>\n        </div>\n      </div>\n      <div class=\"led\">\n        <span id=\"ledtext\">limiting</span>\n        <span class=\"led-dot\" id=\"leddot\"></span>\n      </div>\n    </div>\n\n    <div class=\"stage\" id=\"stage\">\n      <div class=\"wall\"></div>\n      <canvas id=\"scope\"></canvas>\n      <div class=\"ceiling\" id=\"ceilTop\"><span class=\"tag\" id=\"ceilTag\">CEILING</span></div>\n      <div class=\"ceiling bottom\" id=\"ceilBot\"></div>\n      <div class=\"gr\"><div class=\"gr-fill\" id=\"grfill\"></div></div>\n      <div class=\"gr-label\">GR</div>\n    </div>\n\n    <div class=\"controls\" id=\"controls\"></div>\n    <div class=\"footer\">Original DSP &middot; Hard peak ceiling</div>\n  </div>\n\n  <script>\n    \"use strict\";\n\n    // ---- parameter definitions (indices match the DSP module) ----------\n    var PARAMS = [\n      { name: \"Threshold\", index: 0, min: 0, max: 1, def: 0.0,\n        fmt: function (v) { return \"+\" + (v * 24).toFixed(1) + \" dB\"; } },\n      { name: \"Ceiling\", index: 1, min: 0, max: 1, def: 1.0,\n        fmt: function (v) { var db = -24 + v * 24; return (db >= -0.05 ? \"0.0\" : db.toFixed(1)) + \" dB\"; } },\n      { name: \"Release\", index: 2, min: 0, max: 1, def: 0.25,\n        fmt: function (v) { return (1 + v * v * 599).toFixed(0) + \" ms\"; } },\n      { name: \"Gain\", index: 3, min: 0, max: 1, def: 0.5,\n        fmt: function (v) { var db = -12 + v * 24; return (db >= 0 ? \"+\" : \"\") + db.toFixed(1) + \" dB\"; } }\n    ];\n\n    var values = {};\n\n    function pushParam(p, v) {\n      values[p.index] = v;\n      if (window.vstai && window.vstai.setParam) {\n        window.vstai.setParam(p.index, v);\n      }\n      if (p.index === 1) updateCeilingLine();\n    }\n\n    // ---- knob builder --------------------------------------------------\n    function makeKnob(p) {\n      var cell = document.createElement(\"div\");\n      cell.className = \"knobcell\";\n\n      var knob = document.createElement(\"div\");\n      knob.className = \"knob\";\n\n      var NS = \"http://www.w3.org/2000/svg\";\n      var svg = document.createElementNS(NS, \"svg\");\n      svg.setAttribute(\"viewBox\", \"0 0 100 100\");\n\n      // static well / track\n      var track = document.createElementNS(NS, \"circle\");\n      track.setAttribute(\"cx\", \"50\"); track.setAttribute(\"cy\", \"50\");\n      track.setAttribute(\"r\", \"38\");\n      track.setAttribute(\"fill\", \"none\");\n      track.setAttribute(\"stroke\", \"rgba(255,255,255,0.08)\");\n      track.setAttribute(\"stroke-width\", \"7\");\n      track.setAttribute(\"stroke-linecap\", \"round\");\n      track.setAttribute(\"stroke-dasharray\", \"179 360\");\n      track.setAttribute(\"transform\", \"rotate(135 50 50)\");\n      svg.appendChild(track);\n\n      // value arc\n      var arc = document.createElementNS(NS, \"circle\");\n      arc.setAttribute(\"cx\", \"50\"); arc.setAttribute(\"cy\", \"50\");\n      arc.setAttribute(\"r\", \"38\");\n      arc.setAttribute(\"fill\", \"none\");\n      arc.setAttribute(\"stroke\", \"url(#g\" + p.index + \")\");\n      arc.setAttribute(\"stroke-width\", \"7\");\n      arc.setAttribute(\"stroke-linecap\", \"round\");\n      arc.setAttribute(\"transform\", \"rotate(135 50 50)\");\n      svg.appendChild(arc);\n\n      // gradient\n      var defs = document.createElementNS(NS, \"defs\");\n      var grad = document.createElementNS(NS, \"linearGradient\");\n      grad.setAttribute(\"id\", \"g\" + p.index);\n      grad.setAttribute(\"x1\", \"0\"); grad.setAttribute(\"y1\", \"0\");\n      grad.setAttribute(\"x2\", \"1\"); grad.setAttribute(\"y2\", \"1\");\n      var s1 = document.createElementNS(NS, \"stop\");\n      s1.setAttribute(\"offset\", \"0\"); s1.setAttribute(\"stop-color\", \"#ffb36b\");\n      var s2 = document.createElementNS(NS, \"stop\");\n      s2.setAttribute(\"offset\", \"1\"); s2.setAttribute(\"stop-color\", \"#ff6b6b\");\n      grad.appendChild(s1); grad.appendChild(s2);\n      defs.appendChild(grad);\n      svg.appendChild(defs);\n\n      // body\n      var body = document.createElementNS(NS, \"circle\");\n      body.setAttribute(\"cx\", \"50\"); body.setAttribute(\"cy\", \"50\");\n      body.setAttribute(\"r\", \"29\");\n      body.setAttribute(\"fill\", \"url(#b\" + p.index + \")\");\n      body.setAttribute(\"stroke\", \"rgba(0,0,0,0.5)\");\n      body.setAttribute(\"stroke-width\", \"1\");\n      var bgrad = document.createElementNS(NS, \"radialGradient\");\n      bgrad.setAttribute(\"id\", \"b\" + p.index);\n      bgrad.setAttribute(\"cx\", \"0.5\"); bgrad.setAttribute(\"cy\", \"0.35\");\n      var b1 = document.createElementNS(NS, \"stop\");\n      b1.setAttribute(\"offset\", \"0\"); b1.setAttribute(\"stop-color\", \"#3a323a\");\n      var b2 = document.createElementNS(NS, \"stop\");\n      b2.setAttribute(\"offset\", \"1\"); b2.setAttribute(\"stop-color\", \"#1a161c\");\n      bgrad.appendChild(b1); bgrad.appendChild(b2);\n      defs.appendChild(bgrad);\n\n      // pointer notch\n      var notch = document.createElementNS(NS, \"line\");\n      notch.setAttribute(\"x1\", \"50\"); notch.setAttribute(\"y1\", \"50\");\n      notch.setAttribute(\"x2\", \"50\"); notch.setAttribute(\"y2\", \"26\");\n      notch.setAttribute(\"stroke\", \"#ffd9c2\");\n      notch.setAttribute(\"stroke-width\", \"3\");\n      notch.setAttribute(\"stroke-linecap\", \"round\");\n      svg.appendChild(notch);\n\n      knob.appendChild(svg);\n\n      var label = document.createElement(\"div\");\n      label.className = \"klabel\";\n      label.textContent = p.name;\n\n      var val = document.createElement(\"div\");\n      val.className = \"kval\";\n\n      cell.appendChild(knob);\n      cell.appendChild(label);\n      cell.appendChild(val);\n\n      var ARC_LEN = 2 * Math.PI * 38 * (270 / 360);\n\n      function render(v) {\n        var t = (v - p.min) / (p.max - p.min);\n        if (t < 0) t = 0; if (t > 1) t = 1;\n        arc.setAttribute(\"stroke-dasharray\", (ARC_LEN * t).toFixed(1) + \" 360\");\n        var ang = 135 + t * 270;\n        notch.setAttribute(\"transform\", \"rotate(\" + ang + \" 50 50)\");\n        val.textContent = p.fmt(v);\n      }\n\n      function set(v, push) {\n        if (v < p.min) v = p.min; if (v > p.max) v = p.max;\n        render(v);\n        if (push) pushParam(p, v);\n      }\n\n      // drag interaction (vertical)\n      var dragging = false, startY = 0, startV = 0;\n      knob.addEventListener(\"pointerdown\", function (e) {\n        dragging = true; startY = e.clientY; startV = values[p.index];\n        knob.setPointerCapture(e.pointerId);\n        e.preventDefault();\n      });\n      knob.addEventListener(\"pointermove\", function (e) {\n        if (!dragging) return;\n        var dy = startY - e.clientY;\n        var range = p.max - p.min;\n        var v = startV + (dy / 200) * range;\n        set(v, true);\n      });\n      knob.addEventListener(\"pointerup\", function (e) {\n        dragging = false;\n        try { knob.releasePointerCapture(e.pointerId); } catch (err) {}\n      });\n      knob.addEventListener(\"dblclick\", function () { set(p.def, true); });\n      knob.addEventListener(\"wheel\", function (e) {\n        e.preventDefault();\n        var range = p.max - p.min;\n        var v = values[p.index] - Math.sign(e.deltaY) * range * 0.02;\n        set(v, true);\n      }, { passive: false });\n\n      p._set = set;\n      return cell;\n    }\n\n    var controlsEl = document.getElementById(\"controls\");\n    for (var i = 0; i < PARAMS.length; i++) {\n      controlsEl.appendChild(makeKnob(PARAMS[i]));\n    }\n\n    // ---- ceiling line position from the Ceiling param ------------------\n    var stage = document.getElementById(\"stage\");\n    var ceilTop = document.getElementById(\"ceilTop\");\n    var ceilBot = document.getElementById(\"ceilBot\");\n    var ceilTag = document.getElementById(\"ceilTag\");\n\n    function ceilingLin() {\n      var v = values[1];\n      var db = -24 + v * 24;\n      return Math.exp(db * 0.11512925); // 0.063..1.0\n    }\n\n    function updateCeilingLine() {\n      var lin = ceilingLin();\n      // map ceiling (0..1 lin) to a fraction of half the stage height from centre\n      var frac = lin; // portion of half-height the ceiling sits at\n      var halfPct = 50 * frac;\n      ceilTop.style.top = (50 - halfPct) + \"%\";\n      ceilBot.style.bottom = (50 - halfPct) + \"%\";\n      ceilTag.textContent = \"CEILING \" + (values[1] >= 0.999 ? \"0.0\" : (-24 + values[1] * 24).toFixed(1)) + \" dB\";\n    }\n\n    // ---- scope: an animated waveform that slams into the ceiling -------\n    var canvas = document.getElementById(\"scope\");\n    var ctx = canvas.getContext(\"2d\");\n    var phase = 0;\n    var grSmooth = 0;\n    var leddot = document.getElementById(\"leddot\");\n    var grfill = document.getElementById(\"grfill\");\n    var lastHit = 0;\n\n    function resize() {\n      var r = stage.getBoundingClientRect();\n      canvas.width = Math.max(2, r.width) * (window.devicePixelRatio || 1);\n      canvas.height = Math.max(2, r.height) * (window.devicePixelRatio || 1);\n    }\n    window.addEventListener(\"resize\", function () { resize(); updateCeilingLine(); });\n\n    function draw(ts) {\n      if (document.hidden) { requestAnimationFrame(draw); return; }\n      var W = canvas.width, H = canvas.height;\n      var dpr = window.devicePixelRatio || 1;\n      ctx.clearRect(0, 0, W, H);\n\n      var lin = ceilingLin();\n      var mid = H / 2;\n      var ceilPix = (lin) * (H / 2); // distance from centre to ceiling\n\n      // synthesize a lively signal driven by Threshold (drive) + Release feel\n      var drive = 1 + values[0] * 3.2;            // visual drive amount\n      var rel = values[2];\n      phase += 0.05 + 0.02 * drive;\n\n      ctx.lineWidth = 2 * dpr;\n      ctx.lineJoin = \"round\";\n\n      var hitNow = false;\n      var grPeak = 0;\n\n      // draw a filled waveform\n      ctx.beginPath();\n      var N = 140;\n      for (var x = 0; x <= N; x++) {\n        var px = (x / N) * W;\n        var tt = x / N;\n        // composite \"musical\" looking wave\n        var raw =\n          Math.sin(phase + tt * 22) * 0.6 +\n          Math.sin(phase * 1.7 + tt * 9) * 0.4 +\n          Math.sin(phase * 0.6 + tt * 40) * 0.22;\n        // an occasional transient spike\n        var spike = Math.exp(-Math.pow((tt - ((ts * 0.0004) % 1)) * 9, 2)) * 1.4;\n        var amp = (raw + spike) * 0.42 * drive;\n\n        // hard-limit to the ceiling — the brickwall behaviour, visualised\n        var limited = amp;\n        if (limited > lin) { limited = lin; hitNow = true; }\n        if (limited < -lin) { limited = -lin; hitNow = true; }\n        var reduced = Math.abs(amp) - Math.abs(limited);\n        if (reduced > grPeak) grPeak = reduced;\n\n        var py = mid - limited * (H / 2);\n        if (x === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);\n      }\n      // close down the centre for a soft fill\n      ctx.lineTo(W, mid); ctx.lineTo(0, mid); ctx.closePath();\n      var fill = ctx.createLinearGradient(0, 0, 0, H);\n      fill.addColorStop(0, \"rgba(255,179,107,0.28)\");\n      fill.addColorStop(0.5, \"rgba(255,107,107,0.10)\");\n      fill.addColorStop(1, \"rgba(255,179,107,0.28)\");\n      ctx.fillStyle = fill;\n      ctx.fill();\n\n      // crisp top stroke of the wave\n      ctx.beginPath();\n      for (var x2 = 0; x2 <= N; x2++) {\n        var px2 = (x2 / N) * W;\n        var tt2 = x2 / N;\n        var raw2 =\n          Math.sin(phase + tt2 * 22) * 0.6 +\n          Math.sin(phase * 1.7 + tt2 * 9) * 0.4 +\n          Math.sin(phase * 0.6 + tt2 * 40) * 0.22;\n        var spike2 = Math.exp(-Math.pow((tt2 - ((ts * 0.0004) % 1)) * 9, 2)) * 1.4;\n        var amp2 = (raw2 + spike2) * 0.42 * drive;\n        var lim2 = amp2; if (lim2 > lin) lim2 = lin; if (lim2 < -lin) lim2 = -lin;\n        var py2 = mid - lim2 * (H / 2);\n        if (x2 === 0) ctx.moveTo(px2, py2); else ctx.lineTo(px2, py2);\n      }\n      ctx.strokeStyle = \"#ffd0b0\";\n      ctx.shadowColor = \"rgba(255,107,107,0.6)\";\n      ctx.shadowBlur = 8 * dpr;\n      ctx.stroke();\n      ctx.shadowBlur = 0;\n\n      // gain-reduction meter + LED, eased\n      var grTarget = Math.min(1, grPeak * 2.2);\n      grSmooth += (grTarget - grSmooth) * (0.06 + rel * 0.0);\n      grfill.style.height = (grSmooth * 100).toFixed(1) + \"%\";\n      if (grTarget > 0.04) {\n        leddot.classList.add(\"hot\");\n      } else {\n        leddot.classList.remove(\"hot\");\n      }\n\n      // slam flash, throttled\n      if (hitNow && ts - lastHit > 140) {\n        lastHit = ts;\n        ceilTop.classList.remove(\"hit\"); ceilBot.classList.remove(\"hit\");\n        void ceilTop.offsetWidth;\n        ceilTop.classList.add(\"hit\"); ceilBot.classList.add(\"hit\");\n      }\n\n      requestAnimationFrame(draw);\n    }\n\n    // ---- init ----------------------------------------------------------\n    function ready() {\n      for (var i = 0; i < PARAMS.length; i++) {\n        var p = PARAMS[i];\n        var init = (window.vstai && window.vstai.getParam)\n          ? window.vstai.getParam(p.index) : undefined;\n        var v = (typeof init === \"number\" && isFinite(init)) ? init : p.def;\n        values[p.index] = v;\n        p._set(v, true); // initialise control + push default to engine\n      }\n      resize();\n      updateCeilingLine();\n      requestAnimationFrame(draw);\n    }\n\n    if (window.vstai && window.vstai.onReady) {\n      window.vstai.onReady(ready);\n    } else {\n      ready();\n    }\n  </script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  BRICKWALL — look-ahead brickwall limiter\n//  A short look-ahead delay feeds a fast peak detector that computes the\n//  exact gain reduction needed so the output never exceeds the Ceiling.\n//  The reduction is reached BEFORE the peak arrives (because the audio is\n//  delayed by the look-ahead window), then recovers over an adjustable\n//  Release. Threshold sets the input drive into the limiter and Gain is a\n//  post makeup trim. Transparent on quiet input, an absolute wall on loud.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// look-ahead ring buffer (per channel) + a shared envelope of the peak that\n// is \"coming up\" within the look-ahead window.\nconst LOOKAHEAD: i32 = 256;                 // ~5.3 ms @ 48k look-ahead window\nconst delayBuf: StaticArray<f32> = new StaticArray<f32>(LOOKAHEAD * MAX_CHANNELS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nlet writePos: i32 = 0;       // ring write index (0..LOOKAHEAD-1)\nlet gainEnv: f32 = 1.0;      // current applied gain (gain reduction, <= 1)\nlet attackCoef: f32 = 0.0;   // smoothing toward a deeper reduction\n\nconst P_THRESHOLD: i32 = 0;  // 0..1 -> input drive 0..+24 dB into the limiter\nconst P_CEILING: i32 = 1;    // 0..1 -> output ceiling -24..0 dB (linear 0.063..1.0)\nconst P_RELEASE: i32 = 2;    // 0..1 -> release 1..600 ms\nconst P_GAIN: i32 = 3;       // 0..1 -> makeup -12..+12 dB\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < LOOKAHEAD * MAX_CHANNELS; i++) delayBuf[i] = 0.0;\n  writePos = 0;\n  gainEnv = 1.0;\n  // attack reaches the target reduction across the look-ahead window so the\n  // gain is fully down by the time the peak emerges from the delay line.\n  attackCoef = f32(1.0 - Mathf.exp(-5.0 / f32(LOOKAHEAD)));\n  params[P_THRESHOLD] = 0.0;\n  params[P_CEILING] = 1.0;\n  params[P_RELEASE] = 0.25;\n  params[P_GAIN] = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// dB (decibels) -> linear amplitude\n@inline function dbToLin(db: f32): f32 { return f32(Mathf.exp(db * 0.11512925)); }\n\nexport function process(n: i32): void {\n  const thrN: f32 = clampf(params[P_THRESHOLD], 0.0, 1.0);\n  const ceilN: f32 = clampf(params[P_CEILING], 0.0, 1.0);\n  const relN: f32 = clampf(params[P_RELEASE], 0.0, 1.0);\n  const gainN: f32 = clampf(params[P_GAIN], 0.0, 1.0);\n\n  // input drive into the limiter: 0..+24 dB\n  const drive: f32 = dbToLin(thrN * 24.0);\n  // output ceiling: -24..0 dB  -> linear 0.0631..1.0\n  const ceiling: f32 = dbToLin(-24.0 + ceilN * 24.0);\n  // makeup: -12..+12 dB\n  const makeup: f32 = dbToLin(-12.0 + gainN * 24.0);\n\n  // release time 1..600 ms -> one-pole recovery coefficient\n  const relMs: f32 = 1.0 + relN * relN * 599.0;\n  const relSamples: f32 = clampf(relMs * 0.001 * sampleRate, 1.0, 1.0e6);\n  const releaseCoef: f32 = f32(1.0 - Mathf.exp(-1.0 / relSamples));\n\n  let g: f32 = gainEnv;\n  let wp: i32 = writePos;\n\n  for (let f = 0; f < n; f++) {\n    // 1) drive the (interleaved-by-channel) input and find this frame's peak\n    //    across channels, then push the driven samples into the delay line.\n    let peak: f32 = 0.0;\n    for (let c = 0; c < channels; c++) {\n      const x: f32 = inBuf[c * MAX_FRAMES + f] * drive;\n      delayBuf[c * LOOKAHEAD + wp] = x;\n      const a: f32 = x < 0.0 ? -x : x;\n      if (a > peak) peak = a;\n    }\n\n    // 2) target gain so the upcoming peak lands exactly on the ceiling.\n    let target: f32 = 1.0;\n    if (peak > ceiling) target = ceiling / peak;   // peak > 0 here, safe divide\n\n    // 3) attack instantly (over the look-ahead window) toward a deeper cut,\n    //    release slowly back up — classic limiter envelope.\n    if (target < g) {\n      g += attackCoef * (target - g);\n    } else {\n      g += releaseCoef * (target - g);\n    }\n\n    // 4) read the delayed sample (oldest in the ring) and apply gain + makeup.\n    //    the write just happened at wp, so the oldest is the NEXT slot.\n    const readPos: i32 = wp + 1 >= LOOKAHEAD ? 0 : wp + 1;\n    for (let c = 0; c < channels; c++) {\n      let y: f32 = delayBuf[c * LOOKAHEAD + readPos] * g * makeup;\n      // hard brickwall safety clamp: never let makeup push past the ceiling.\n      if (y > ceiling) y = ceiling;\n      else if (y < -ceiling) y = -ceiling;\n      outBuf[c * MAX_FRAMES + f] = y;\n    }\n\n    wp = wp + 1 >= LOOKAHEAD ? 0 : wp + 1;\n  }\n\n  gainEnv = g;\n  writePos = wp;\n}\n",
  "publishedAt": 1751000045000
}