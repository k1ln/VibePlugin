{
  "format": 1,
  "name": "Sub Station",
  "isInstrument": true,
  "explanation": "A modern virtual-analog acid/electro bass mono synth: a saw oscillator and a hard-synced pulse oscillator (the Sync control sets OSC2's pitch above OSC1, tearing out a screaming sync edge) plus a sub one octave down for weight. The mix drives a snappy resonant low-pass that squelches and screams under its decay envelope, then a post Overdrive stage adds aggressive, slightly-digital grit for in-your-face acid lines and squelchy leads.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.72
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.78
    },
    {
      "name": "Sync",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Overdrive",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Sub Station</title>\n<style>\n  :root {\n    --accent: #3dff9a;\n    --accent2: #ff3d6a;\n    --bg0: #07090c;\n    --bg1: #0e1218;\n    --panel: #11161d;\n    --panel2: #161c25;\n    --edge: #232c38;\n    --ink: #c9d6e2;\n    --dim: #6b7886;\n    --mono: ui-monospace, \"SF Mono\", \"Cascadia Code\", Menlo, Consolas, monospace;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background: var(--bg0);\n    color: var(--ink);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n\n  .wrap {\n    min-height: 100vh;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 18px;\n  }\n\n  .unit {\n    width: 100%;\n    max-width: 760px;\n    background:\n      radial-gradient(120% 90% at 18% -10%, rgba(61,255,154,0.07), transparent 55%),\n      radial-gradient(120% 90% at 95% 0%, rgba(255,61,106,0.06), transparent 55%),\n      linear-gradient(160deg, var(--bg1), var(--bg0) 70%);\n    border: 1px solid var(--edge);\n    border-radius: 18px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.04) inset,\n      0 30px 70px -28px rgba(0,0,0,0.9),\n      0 0 0 1px rgba(0,0,0,0.5);\n    padding: 20px 22px 22px;\n    position: relative;\n    overflow: hidden;\n  }\n\n  /* faint carbon texture */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background-image:\n      repeating-linear-gradient(45deg, rgba(255,255,255,0.012) 0 2px, transparent 2px 4px);\n    pointer-events: none;\n    opacity: 0.7;\n  }\n\n  header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 16px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .brand { display: flex; align-items: center; gap: 12px; }\n\n  .logo {\n    width: 40px; height: 40px;\n    border-radius: 11px;\n    background: linear-gradient(150deg, #1a2230, #0b0e13);\n    border: 1px solid var(--edge);\n    display: grid; place-items: center;\n    box-shadow: 0 0 18px -6px rgba(61,255,154,0.5);\n  }\n  .logo svg { display: block; }\n\n  .titles h1 {\n    margin: 0;\n    font-size: 19px;\n    letter-spacing: 3px;\n    font-weight: 800;\n    text-transform: uppercase;\n    background: linear-gradient(90deg, var(--accent), #d9fff0 60%, var(--accent));\n    -webkit-background-clip: text;\n    background-clip: text;\n    color: transparent;\n  }\n  .titles .sub {\n    margin-top: 2px;\n    font-size: 9.5px;\n    letter-spacing: 3.5px;\n    text-transform: uppercase;\n    color: var(--dim);\n    font-family: var(--mono);\n  }\n\n  .badge {\n    font-family: var(--mono);\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: var(--accent2);\n    border: 1px solid rgba(255,61,106,0.4);\n    padding: 5px 10px;\n    border-radius: 999px;\n    background: rgba(255,61,106,0.07);\n    box-shadow: 0 0 16px -8px var(--accent2) inset;\n  }\n\n  /* ---- scope ---- */\n  .scope {\n    position: relative;\n    z-index: 1;\n    height: 116px;\n    border-radius: 13px;\n    border: 1px solid var(--edge);\n    background:\n      radial-gradient(120% 140% at 50% -30%, rgba(61,255,154,0.10), transparent 60%),\n      linear-gradient(180deg, #090d12, #05070a);\n    overflow: hidden;\n    box-shadow: 0 2px 0 rgba(255,255,255,0.03) inset, 0 14px 30px -22px #000 inset;\n    margin-bottom: 18px;\n  }\n  .scope canvas { display: block; width: 100%; height: 100%; }\n  .scope .tag {\n    position: absolute;\n    top: 9px; left: 12px;\n    font-family: var(--mono);\n    font-size: 9px;\n    letter-spacing: 2px;\n    color: var(--dim);\n    text-transform: uppercase;\n  }\n  .scope .tag b { color: var(--accent); }\n\n  /* ---- controls ---- */\n  .rack {\n    position: relative;\n    z-index: 1;\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 14px;\n  }\n  @media (max-width: 560px) { .rack { grid-template-columns: repeat(2, 1fr); } }\n\n  .cell {\n    background: linear-gradient(170deg, var(--panel2), var(--panel));\n    border: 1px solid var(--edge);\n    border-radius: 13px;\n    padding: 13px 10px 11px;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 8px;\n    box-shadow: 0 1px 0 rgba(255,255,255,0.03) inset, 0 12px 22px -18px #000;\n    transition: border-color .18s, box-shadow .18s, transform .18s;\n  }\n  .cell.live {\n    border-color: rgba(61,255,154,0.55);\n    box-shadow: 0 0 22px -8px var(--accent), 0 1px 0 rgba(255,255,255,0.05) inset;\n  }\n  .cell.od.live {\n    border-color: rgba(255,61,106,0.6);\n    box-shadow: 0 0 24px -7px var(--accent2), 0 1px 0 rgba(255,255,255,0.05) inset;\n  }\n\n  .knob {\n    width: 84px; height: 84px;\n    position: relative;\n    cursor: ns-resize;\n    touch-action: none;\n    user-select: none;\n  }\n  .knob svg { display: block; width: 100%; height: 100%; }\n\n  .label {\n    font-size: 9.5px;\n    letter-spacing: 2.2px;\n    text-transform: uppercase;\n    color: var(--dim);\n    font-weight: 700;\n  }\n  .cell.live .label { color: var(--accent); }\n  .cell.od.live .label { color: var(--accent2); }\n\n  .value {\n    font-family: var(--mono);\n    font-size: 12px;\n    font-variant-numeric: tabular-nums;\n    color: var(--ink);\n    background: #070a0e;\n    border: 1px solid var(--edge);\n    border-radius: 6px;\n    padding: 2px 8px;\n    min-width: 56px;\n    text-align: center;\n    letter-spacing: 0.5px;\n  }\n\n  /* ---- overdrive stage glow ---- */\n  .od .knob::after {\n    content: \"\";\n    position: absolute;\n    inset: -8px;\n    border-radius: 50%;\n    pointer-events: none;\n    box-shadow: 0 0 0 transparent;\n    transition: box-shadow .2s;\n  }\n\n  /* ---- keyboard ---- */\n  .keys {\n    position: relative;\n    z-index: 1;\n    margin-top: 18px;\n    height: 96px;\n    display: flex;\n    border-radius: 11px;\n    overflow: hidden;\n    border: 1px solid var(--edge);\n    background: #05070a;\n    box-shadow: 0 12px 26px -20px #000 inset;\n    user-select: none;\n    touch-action: none;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    background: linear-gradient(180deg, #e7edf2, #aeb8c2);\n    border-right: 1px solid #2a323d;\n    cursor: pointer;\n  }\n  .wkey:last-child { border-right: none; }\n  .wkey.down {\n    background: linear-gradient(180deg, var(--accent), #1fcf7a);\n    box-shadow: 0 0 22px -4px var(--accent) inset;\n  }\n  .bkeys {\n    position: absolute;\n    inset: 0 0 auto 0;\n    height: 60%;\n    display: flex;\n    pointer-events: none;\n  }\n  .bk {\n    position: absolute;\n    top: 0;\n    width: 7.2%;\n    height: 100%;\n    background: linear-gradient(180deg, #1b222c, #05070a);\n    border: 1px solid #000;\n    border-radius: 0 0 5px 5px;\n    pointer-events: auto;\n    cursor: pointer;\n    box-shadow: 0 4px 8px -2px #000;\n  }\n  .bk.down {\n    background: linear-gradient(180deg, var(--accent2), #b21f43);\n    box-shadow: 0 0 20px -2px var(--accent2) inset;\n  }\n\n  .hint {\n    position: relative;\n    z-index: 1;\n    margin-top: 9px;\n    text-align: center;\n    font-family: var(--mono);\n    font-size: 8.5px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #4a5663;\n  }\n</style>\n</head>\n<body>\n<div class=\"wrap\">\n  <div class=\"unit\">\n    <header>\n      <div class=\"brand\">\n        <div class=\"logo\">\n          <svg width=\"22\" height=\"22\" viewBox=\"0 0 22 22\" fill=\"none\">\n            <path d=\"M2 14 L6 14 L6 7 L10 7 L10 16 L14 16 L14 5 L18 5 L18 14 L20 14\"\n                  stroke=\"#3dff9a\" stroke-width=\"1.8\" stroke-linejoin=\"round\" stroke-linecap=\"round\"/>\n          </svg>\n        </div>\n        <div class=\"titles\">\n          <h1>Sub Station</h1>\n          <div class=\"sub\">Virtual-Analog Acid Bass</div>\n        </div>\n      </div>\n      <div class=\"badge\">Mono · Sync · Drive</div>\n    </header>\n\n    <div class=\"scope\">\n      <div class=\"tag\">OSC SYNC · <b id=\"scopeMode\">SAW × PULSE</b></div>\n      <canvas id=\"scope\"></canvas>\n    </div>\n\n    <div class=\"rack\" id=\"rack\"></div>\n\n    <div class=\"keys\" id=\"keys\"></div>\n    <div class=\"hint\">drag knobs vertically · double-click resets · click / hold keys to play</div>\n  </div>\n</div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter definitions (index MUST match the DSP module) ----\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, def: 0.30, fmt: hz },\n    { name: \"Resonance\",  index: 1, def: 0.72, fmt: pct },\n    { name: \"Env Amount\", index: 2, def: 0.78, fmt: pct },\n    { name: \"Sync\",       index: 3, def: 0.45, fmt: sync },\n    { name: \"Overdrive\",  index: 4, def: 0.40, fmt: pct, od: true },\n    { name: \"Decay\",      index: 5, def: 0.35, fmt: ms },\n    { name: \"Level\",      index: 6, def: 0.80, fmt: pct }\n  ];\n\n  function pct(v) { return Math.round(v * 100) + \"%\"; }\n  function hz(v) {\n    var f = 70 * Math.exp(v * 4.96);\n    return f >= 1000 ? (f / 1000).toFixed(2) + \" kHz\" : Math.round(f) + \" Hz\";\n  }\n  function sync(v) { return (1 + v * 2.5).toFixed(2) + \"×\"; }\n  function ms(v) {\n    var s = 0.025 + v * v * 1.1;\n    return s >= 1 ? s.toFixed(2) + \" s\" : Math.round(s * 1000) + \" ms\";\n  }\n\n  var state = {};   // index -> current value\n  var cells = {};   // index -> {cell, arc, dot, valEl}\n\n  // ---- host bridge (guard against vstai being briefly absent) ----\n  function push(index, value) {\n    if (window.vstai && typeof window.vstai.setParam === \"function\") {\n      window.vstai.setParam(index, value);\n    }\n  }\n\n  // ---- build knobs ----\n  var rack = document.getElementById(\"rack\");\n\n  PARAMS.forEach(function (p) {\n    var cell = document.createElement(\"div\");\n    cell.className = \"cell\" + (p.od ? \" od\" : \"\");\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.innerHTML = knobSvg(p.od);\n\n    var label = document.createElement(\"div\");\n    label.className = \"label\";\n    label.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"value\";\n\n    cell.appendChild(knob);\n    cell.appendChild(label);\n    cell.appendChild(val);\n    rack.appendChild(cell);\n\n    var arc = knob.querySelector(\".arc\");\n    var dot = knob.querySelector(\".dot\");\n\n    cells[p.index] = { cell: cell, arc: arc, dot: dot, val: val, p: p };\n\n    attachDrag(knob, cell, p);\n    setValue(p.index, p.def, false);\n  });\n\n  function knobSvg(isOd) {\n    var col = isOd ? \"var(--accent2)\" : \"var(--accent)\";\n    // arc from -135deg to +135deg, radius 32, center 42,42\n    return ''\n      + '<svg viewBox=\"0 0 84 84\">'\n      + '  <defs>'\n      + '    <radialGradient id=\"g' + (isOd ? 'r' : 'g') + '\" cx=\"50%\" cy=\"38%\" r=\"62%\">'\n      + '      <stop offset=\"0%\" stop-color=\"#222b36\"/>'\n      + '      <stop offset=\"100%\" stop-color=\"#0a0e13\"/>'\n      + '    </radialGradient>'\n      + '  </defs>'\n      + '  <circle cx=\"42\" cy=\"42\" r=\"38\" fill=\"none\" stroke=\"#1b232e\" stroke-width=\"6\"/>'\n      + '  <path class=\"track\" d=\"\" fill=\"none\" stroke=\"#161d27\" stroke-width=\"6\" stroke-linecap=\"round\"/>'\n      + '  <path class=\"arc\" d=\"\" fill=\"none\" stroke=\"' + col + '\" stroke-width=\"6\" stroke-linecap=\"round\"/>'\n      + '  <circle cx=\"42\" cy=\"42\" r=\"27\" fill=\"url(#g' + (isOd ? 'r' : 'g') + ')\" stroke=\"#2a3340\" stroke-width=\"1\"/>'\n      + '  <circle cx=\"42\" cy=\"42\" r=\"27\" fill=\"none\" stroke=\"rgba(255,255,255,0.05)\" stroke-width=\"1\" transform=\"translate(0,-1)\"/>'\n      + '  <line class=\"dot\" x1=\"42\" y1=\"42\" x2=\"42\" y2=\"20\" stroke=\"' + col + '\" stroke-width=\"2.5\" stroke-linecap=\"round\"/>'\n      + '</svg>';\n  }\n\n  // polar arc helper\n  function polar(cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  }\n  function arcPath(r, frac) {\n    var start = -135, end = 135;\n    var a0 = start, a1 = start + (end - start) * frac;\n    var p0 = polar(42, 42, r, a0);\n    var p1 = polar(42, 42, r, a1);\n    var large = (a1 - a0) > 180 ? 1 : 0;\n    return \"M \" + p0[0].toFixed(2) + \" \" + p0[1].toFixed(2)\n      + \" A \" + r + \" \" + r + \" 0 \" + large + \" 1 \"\n      + p1[0].toFixed(2) + \" \" + p1[1].toFixed(2);\n  }\n\n  function setValue(index, v, doPush) {\n    v = Math.max(0, Math.min(1, v));\n    state[index] = v;\n    var c = cells[index];\n    // full track\n    c.arc.parentNode.querySelector(\".track\").setAttribute(\"d\", arcPath(34, 1));\n    c.arc.setAttribute(\"d\", arcPath(34, v));\n    // pointer rotation: -135..+135\n    var deg = -135 + 270 * v;\n    c.dot.setAttribute(\"transform\", \"rotate(\" + deg + \" 42 42)\");\n    c.val.textContent = c.p.fmt(v);\n    if (doPush) push(index, v);\n  }\n\n  // ---- knob drag / wheel / dblclick ----\n  function attachDrag(knob, cell, p) {\n    var dragging = false, lastY = 0;\n\n    function glow(on) {\n      cell.classList.toggle(\"live\", on);\n    }\n\n    function onMove(e) {\n      if (!dragging) return;\n      var y = (e.touches ? e.touches[0].clientY : e.clientY);\n      var dy = lastY - y;\n      lastY = y;\n      var fine = e.shiftKey ? 0.25 : 1;\n      setValue(p.index, state[p.index] + dy * 0.006 * fine, true);\n      e.preventDefault();\n    }\n    function onUp() {\n      dragging = false;\n      glow(false);\n      window.removeEventListener(\"mousemove\", onMove);\n      window.removeEventListener(\"mouseup\", onUp);\n      window.removeEventListener(\"touchmove\", onMove);\n      window.removeEventListener(\"touchend\", onUp);\n    }\n    function onDown(e) {\n      dragging = true;\n      glow(true);\n      lastY = (e.touches ? e.touches[0].clientY : e.clientY);\n      window.addEventListener(\"mousemove\", onMove);\n      window.addEventListener(\"mouseup\", onUp);\n      window.addEventListener(\"touchmove\", onMove, { passive: false });\n      window.addEventListener(\"touchend\", onUp);\n      e.preventDefault();\n    }\n\n    knob.addEventListener(\"mousedown\", onDown);\n    knob.addEventListener(\"touchstart\", onDown, { passive: false });\n\n    knob.addEventListener(\"wheel\", function (e) {\n      var fine = e.shiftKey ? 0.25 : 1;\n      setValue(p.index, state[p.index] - Math.sign(e.deltaY) * 0.03 * fine, true);\n      glow(true);\n      clearTimeout(knob._wt);\n      knob._wt = setTimeout(function () { glow(false); }, 240);\n      e.preventDefault();\n    }, { passive: false });\n\n    knob.addEventListener(\"dblclick\", function () {\n      setValue(p.index, p.def, true);\n    });\n  }\n\n  // =====================================================================\n  //  Animated osc-sync scope — draws the live saw × synced-pulse tearing\n  //  waveform, brightened by Overdrive, swept by Cutoff/Resonance.\n  // =====================================================================\n  var cv = document.getElementById(\"scope\");\n  var ctx = cv.getContext(\"2d\");\n  var scopeMode = document.getElementById(\"scopeMode\");\n\n  function fitCanvas() {\n    var r = cv.getBoundingClientRect();\n    var dpr = window.devicePixelRatio || 1;\n    cv.width = Math.max(1, Math.round(r.width * dpr));\n    cv.height = Math.max(1, Math.round(r.height * dpr));\n    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);\n  }\n  window.addEventListener(\"resize\", fitCanvas);\n  fitCanvas();\n\n  var t = 0;\n  function frame() {\n    if (document.hidden) { raf = requestAnimationFrame(frame); return; }\n    var r = cv.getBoundingClientRect();\n    var w = r.width, h = r.height, mid = h * 0.5;\n\n    ctx.clearRect(0, 0, w, h);\n\n    // grid\n    ctx.strokeStyle = \"rgba(255,255,255,0.04)\";\n    ctx.lineWidth = 1;\n    for (var gx = 0; gx <= w; gx += 28) {\n      ctx.beginPath(); ctx.moveTo(gx, 0); ctx.lineTo(gx, h); ctx.stroke();\n    }\n    ctx.beginPath(); ctx.moveTo(0, mid); ctx.lineTo(w, mid); ctx.stroke();\n\n    var cutoff = state[0], reso = state[1], env = state[2];\n    var syncR = 1 + state[3] * 2.5;\n    var od = state[4];\n\n    scopeMode.textContent = \"SAW × PULSE  \" + syncR.toFixed(2) + \"×\";\n\n    // scroll speed\n    t += 0.02 + cutoff * 0.03;\n\n    // synthesize the visual waveform: master saw + hard-synced pulse + sub\n    var cycles = 2;            // master cycles across the view\n    var amp = (0.30 + env * 0.5);\n    var glow = 6 + od * 18;\n\n    // red overdrive \"edge\" trace under the main green trace\n    drawWave(w, h, mid, cycles, syncR, reso, amp * (0.9 + od * 0.4),\n             \"rgba(255,61,106,\" + (0.25 + od * 0.5).toFixed(3) + \")\", 2 + od * 2, true);\n\n    // main green sync trace\n    ctx.shadowColor = \"var(--accent)\";\n    drawWave(w, h, mid, cycles, syncR, reso, amp,\n             \"#3dff9a\", 2.2, false, glow);\n\n    raf = requestAnimationFrame(frame);\n  }\n\n  function drawWave(w, h, mid, cycles, syncR, reso, amp, color, lw, jitter, glow) {\n    ctx.save();\n    ctx.beginPath();\n    ctx.lineWidth = lw;\n    ctx.strokeStyle = color;\n    if (glow) { ctx.shadowBlur = glow; ctx.shadowColor = color; }\n    var N = Math.max(160, Math.round(w));\n    for (var i = 0; i <= N; i++) {\n      var x = i / N;\n      var ph = (x * cycles + t) % 1;          // master phase 0..1\n      var saw = ph * 2 - 1;\n      var ph2 = (ph * syncR) % 1;              // synced (resets each master cycle)\n      var pulse = ph2 < 0.5 ? 1 : -1;\n      var sub = ((x * cycles * 0.5 + t * 0.5) % 1) < 0.5 ? 0.9 : -0.9;\n      var s = saw * 0.5 + pulse * 0.5 + sub * 0.35;\n      // resonance adds a ringy overshoot near the sync reset\n      s += Math.sin(ph * Math.PI * 2 * (2 + reso * 6)) * reso * 0.18 * (1 - ph);\n      if (jitter) s += (Math.random() - 0.5) * 0.04;\n      var px = x * w;\n      var py = mid - s * mid * amp;\n      if (i === 0) ctx.moveTo(px, py); else ctx.lineTo(px, py);\n    }\n    ctx.stroke();\n    ctx.restore();\n  }\n\n  var raf = requestAnimationFrame(frame);\n\n  // =====================================================================\n  //  Playable keyboard — two octaves, mouse + touch, calls noteOn/noteOff.\n  // =====================================================================\n  var keysEl = document.getElementById(\"keys\");\n  var START = 36;     // C2 — bass register\n  var WHITE = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 }; // white-index -> semitone offset\n  var OCTAVES = 2;\n\n  var whiteNotes = [];\n  for (var o = 0; o < OCTAVES; o++) {\n    for (var wi = 0; wi < WHITE.length; wi++) {\n      whiteNotes.push(START + o * 12 + WHITE[wi]);\n    }\n  }\n  // add final C\n  whiteNotes.push(START + OCTAVES * 12);\n\n  var down = {};\n\n  function noteOn(n, el) {\n    if (down[n]) return;\n    down[n] = el;\n    if (el) el.classList.add(\"down\");\n    if (window.vstai && window.vstai.noteOn) window.vstai.noteOn(n, 0.95);\n  }\n  function noteOff(n) {\n    var el = down[n];\n    if (!el && el !== null) return;\n    if (el) el.classList.remove(\"down\");\n    delete down[n];\n    if (window.vstai && window.vstai.noteOff) window.vstai.noteOff(n);\n  }\n\n  var mouseHeld = false;\n  window.addEventListener(\"mousedown\", function () { mouseHeld = true; });\n  window.addEventListener(\"mouseup\", function () {\n    mouseHeld = false;\n    for (var n in down) noteOff(+n);\n  });\n\n  // build white keys\n  whiteNotes.forEach(function (n) {\n    var k = document.createElement(\"div\");\n    k.className = \"wkey\";\n    bindKey(k, n);\n    keysEl.appendChild(k);\n  });\n\n  // black keys overlay\n  var bwrap = document.createElement(\"div\");\n  bwrap.className = \"bkeys\";\n  keysEl.appendChild(bwrap);\n\n  var nWhite = whiteNotes.length;\n  var unit = 100 / nWhite; // % width per white key\n  for (var o2 = 0; o2 < OCTAVES; o2++) {\n    for (var key in BLACK) {\n      var idx = o2 * 7 + (+key);\n      var semitone = START + o2 * 12 + BLACK[key];\n      var bk = document.createElement(\"div\");\n      bk.className = \"bk\";\n      bk.style.left = (unit * (idx + 1) - unit * 0.36) + \"%\";\n      bk.style.width = (unit * 0.72) + \"%\";\n      bindKey(bk, semitone);\n      bwrap.appendChild(bk);\n    }\n  }\n\n  function bindKey(el, n) {\n    el.addEventListener(\"mousedown\", function (e) { noteOn(n, el); e.preventDefault(); });\n    el.addEventListener(\"mouseenter\", function () { if (mouseHeld) noteOn(n, el); });\n    el.addEventListener(\"mouseleave\", function () { if (mouseHeld) noteOff(n); });\n    el.addEventListener(\"touchstart\", function (e) { noteOn(n, el); e.preventDefault(); }, { passive: false });\n    el.addEventListener(\"touchend\", function (e) { noteOff(n); e.preventDefault(); }, { passive: false });\n  }\n\n  // =====================================================================\n  //  Init: push all defaults once the host is ready.\n  // =====================================================================\n  function initAll() {\n    PARAMS.forEach(function (p) { setValue(p.index, state[p.index], true); });\n  }\n\n  if (window.vstai && typeof window.vstai.onReady === \"function\") {\n    window.vstai.onReady(initAll);\n  } else {\n    initAll();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SUB STATION — modern virtual-analog acid/electro bass mono synth\n//  A two-oscillator VA bass voice with an edgy, slightly digital bite:\n//    OSC1 (saw) + OSC2 (pulse) with hard OSCILLATOR SYNC (OSC2 phase\n//    reset by OSC1) for the screaming, tearing sync edge, plus a SUB\n//    square one octave down for weight. The mix drives a screaming 4-pole\n//    resonant low-pass with a snappy decay envelope (the squelch/scream),\n//    then a post OVERDRIVE waveshaper for aggressive grit. Mono, last-note\n//    priority, pitch tracks the host Hz. Pure algorithm, no samples.\n//\n//  Signal path:\n//    [saw + synced-pulse + sub] -> resonant LPF (cutoff + envAmt*env)\n//                               -> overdrive shaper -> level\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32 = 3.14159265358979;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF:   i32 = 0; // base cutoff 0..1\nconst P_RESO:     i32 = 1; // resonance 0..1 (screams near 1)\nconst P_ENVAMT:   i32 = 2; // filter envelope amount 0..1\nconst P_SYNC:     i32 = 3; // osc-sync edge: OSC2 pitch ratio above OSC1 0..1\nconst P_OVERDRIVE: i32 = 4; // post overdrive grit 0..1\nconst P_DECAY:    i32 = 5; // filter + amp decay 0..1\nconst P_LEVEL:    i32 = 6; // output level 0..1\n\n// ---- voice state ----\nlet phase1: f32 = 0.0;     // OSC1 (master saw) phase 0..1\nlet phase2: f32 = 0.0;     // OSC2 (synced pulse) phase 0..1\nlet subPhase: f32 = 0.0;   // sub oscillator phase 0..1\nlet curFreq: f32 = 0.0;    // current note frequency (Hz)\nlet gate: i32 = 0;         // 1 while a note is held\nlet note: i32 = -1;        // currently sounding note id\n\n// envelopes\nlet fenv: f32 = 0.0;       // filter envelope (decays 1 -> 0)\nlet aenv: f32 = 0.0;       // amplitude envelope\n\n// 4-pole resonant ladder filter state\nlet f0: f32 = 0.0;\nlet f1: f32 = 0.0;\nlet f2: f32 = 0.0;\nlet f3: f32 = 0.0;\n\n// DC blocker\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  phase1 = 0.0;\n  phase2 = 0.0;\n  subPhase = 0.0;\n  curFreq = 0.0;\n  gate = 0;\n  note = -1;\n  fenv = 0.0;\n  aenv = 0.0;\n  f0 = 0.0; f1 = 0.0; f2 = 0.0; f3 = 0.0;\n  dcX = 0.0; dcY = 0.0;\n\n  params[P_CUTOFF]    = 0.30;\n  params[P_RESO]      = 0.72;\n  params[P_ENVAMT]    = 0.78;\n  params[P_SYNC]      = 0.45;\n  params[P_OVERDRIVE] = 0.40;\n  params[P_DECAY]     = 0.35;\n  params[P_LEVEL]     = 0.80;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// fast tanh-ish soft saturator: bounded, smooth, cheap\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n// Host passes frequency in Hz. Last-note priority; new notes retrigger\n// the envelopes. Velocity not used for accent here (kept simple/punchy).\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  curFreq = f > 0.0 ? f : 0.0001;\n  note = id;\n  gate = 1;\n  fenv = 1.0;\n  aenv = 1.0;\n}\n\nexport function noteOff(id: i32): void {\n  if (id == note) gate = 0;\n}\n\nexport function process(n: i32): void {\n  const cutoffN:    f32 = clampf(params[P_CUTOFF],   0.0, 1.0);\n  const resoN:      f32 = clampf(params[P_RESO],     0.0, 1.0);\n  const envAmtN:    f32 = clampf(params[P_ENVAMT],   0.0, 1.0);\n  const syncN:      f32 = clampf(params[P_SYNC],     0.0, 1.0);\n  const overdriveN: f32 = clampf(params[P_OVERDRIVE], 0.0, 1.0);\n  const decayN:     f32 = clampf(params[P_DECAY],    0.0, 1.0);\n  const level:      f32 = clampf(params[P_LEVEL],    0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Filter-envelope decay: ~25 ms (snappy) up to ~1.1 s (long sweep).\n  const fdecaySec: f32 = 0.025 + decayN * decayN * 1.1;\n  const fenvCoef: f32 = f32(Mathf.exp(-1.0 / (fdecaySec * sampleRate)));\n\n  // Amp envelope: a touch longer so notes ring out.\n  const adecaySec: f32 = 0.05 + decayN * decayN * 1.5;\n  const aenvCoef: f32 = f32(Mathf.exp(-1.0 / (adecaySec * sampleRate)));\n\n  // Sync: OSC2 runs at 1.0 .. ~3.5x the master pitch; OSC1 resets its phase.\n  // Higher sync = brighter, more tearing formant sweep / metallic bite.\n  const syncRatio: f32 = 1.0 + syncN * 2.5;\n\n  // Resonance 0 .. ~4.0 (screams / approaches self-oscillation, bounded).\n  const reso: f32 = resoN * 4.0;\n\n  // Base cutoff in Hz (exponential, musical): ~70 Hz .. ~10 kHz.\n  const baseCut: f32 = f32(70.0 * Mathf.exp(cutoffN * 4.96));\n\n  // Envelope sweep span added on top of base.\n  const sweepSpan: f32 = envAmtN * 9000.0;\n\n  // Overdrive: pre-gain into the shaper 1 .. ~9, with output compensation.\n  const odGain: f32 = 1.0 + overdriveN * 8.0;\n  const odComp: f32 = f32(1.0 / Mathf.sqrt(odGain));\n  // overdrive also adds a hard-ish edge term as it increases\n  const odEdge: f32 = overdriveN * overdriveN;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  for (let i = 0; i < n; i++) {\n    // ---- amp/filter envelopes ----\n    fenv *= fenvCoef;\n    if (gate != 0) {\n      // sustain at a floor while held\n      aenv = aenv * aenvCoef;\n      if (aenv < 0.3) aenv = 0.3;\n    } else {\n      aenv *= aenvCoef;\n    }\n\n    // ---- oscillators ----\n    let inc1: f32 = curFreq / sampleRate;\n    if (inc1 < 0.0) inc1 = 0.0;\n    if (inc1 > 0.5) inc1 = 0.5;\n\n    // OSC1 master saw\n    let reset: i32 = 0;\n    phase1 += inc1;\n    if (phase1 >= 1.0) { phase1 -= 1.0; reset = 1; }\n    const saw: f32 = phase1 * 2.0 - 1.0;\n\n    // OSC2 synced pulse: runs faster, but its phase is hard-reset whenever\n    // OSC1 wraps — this is the classic osc-sync tearing edge.\n    let inc2: f32 = inc1 * syncRatio;\n    if (inc2 > 0.5) inc2 = 0.5;\n    if (reset != 0) {\n      phase2 = 0.0;\n    } else {\n      phase2 += inc2;\n      if (phase2 >= 1.0) phase2 -= 1.0;\n    }\n    const pulse: f32 = phase2 < 0.5 ? 1.0 : -1.0;\n\n    // SUB square one octave down for weight\n    let subInc: f32 = inc1 * 0.5;\n    subPhase += subInc;\n    if (subPhase >= 1.0) subPhase -= 1.0;\n    const sub: f32 = subPhase < 0.5 ? 0.9 : -0.9;\n\n    // Oscillator mix: saw body + synced pulse bite + sub weight.\n    // Sync amount also raises the pulse level so the edge is clearly audible.\n    const pulseLevel: f32 = 0.55 + syncN * 0.45;\n    let osc: f32 = saw * 0.7 + pulse * pulseLevel + sub * 0.6;\n    osc *= 0.6;\n\n    // ---- cutoff for this sample ----\n    let cutHz: f32 = baseCut + sweepSpan * fenv;\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- 4-pole resonant ladder ----\n    let fc: f32 = cutHz / nyq;\n    if (fc > 0.49) fc = 0.49;\n    const g: f32 = fc * (1.8 - 0.8 * fc);\n\n    const fb: f32 = reso * (1.0 - 0.15 * g);\n    const input: f32 = osc - fb * satf(f3);\n\n    f0 += g * (input - f0);\n    f1 += g * (f0 - f1);\n    f2 += g * (f1 - f2);\n    f3 += g * (f2 - f3);\n\n    let filtered: f32 = satf(f3 * 1.3);\n\n    // ---- amp envelope ----\n    let s: f32 = filtered * aenv;\n\n    // ---- post OVERDRIVE (aggressive grit) ----\n    // soft saturation blended with a harder edge for the modern bite\n    let driven: f32 = satf(s * odGain) * odComp;\n    const hard: f32 = clampf(s * odGain * 0.5, -1.0, 1.0);\n    driven = driven * (1.0 - 0.5 * odEdge) + hard * (0.5 * odEdge);\n    s = s * (1.0 - overdriveN) + driven * overdriveN;\n\n    // ---- DC blocker ----\n    const y: f32 = s - dcX + 0.9985 * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // ---- final level + headroom guard ----\n    s = satf(s * level * 1.25) * 0.85;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000124000
}