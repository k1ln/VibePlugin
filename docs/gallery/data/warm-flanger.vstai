{
  "format": 1,
  "name": "Warm Flanger",
  "isInstrument": false,
  "explanation": "A lush, warm analog-voiced flanger in the bucket-brigade tradition. A short fractional delay line is swept by a slow triangle LFO around a parked centre set by Manual; Width sets how far the comb sweeps, Rate the speed, and Regen the feedback. The feedback path is gently low-passed and softly saturated so heavy Regen thickens and resonates creamily instead of turning clangy. A small stereo LFO offset gives a gentle moving image. Controls: Manual, Width, Rate, Regen and dry/wet Mix.",
  "params": [
    {
      "name": "Manual",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Width",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Rate",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.25
    },
    {
      "name": "Regen",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mix",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Warm Flanger</title>\n<style>\n  :root{\n    --accent:#ffb86a;     /* honeyed orange */\n    --accent2:#6ad0ff;    /* cool cyan glint */\n    --cream:#f4e6cf;\n    --cream2:#e9d4ae;\n    --shell:#3a2a1c;\n    --shell2:#241710;\n    --ink:#2a1c10;\n  }\n  *{box-sizing:border-box;-webkit-user-select:none;user-select:none;}\n  html,body{margin:0;height:100%;}\n  body{\n    font-family:\"Avenir Next\",-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 100% at 50% -10%,#5a4126 0%,#2c1d11 55%,#170e07 100%);\n    color:var(--ink);\n    display:flex;align-items:center;justify-content:center;\n    min-height:100vh;padding:18px;overflow:hidden;\n  }\n\n  /* ---- pedal shell ---------------------------------------------------- */\n  .pedal{\n    position:relative;width:430px;border-radius:28px;\n    padding:22px 24px 26px;\n    background:\n      linear-gradient(160deg,#ffd9a0 0%,#ffc27e 34%,#f4a85a 64%,#e08f42 100%);\n    box-shadow:\n      0 28px 60px rgba(0,0,0,.55),\n      0 2px 0 rgba(255,255,255,.35) inset,\n      0 -18px 40px rgba(120,60,10,.28) inset;\n    border:1px solid rgba(120,60,10,.35);\n  }\n  /* honeycomb screws */\n  .screw{position:absolute;width:15px;height:15px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#fff6e6,#caa46e 60%,#7d5a30);\n    box-shadow:0 1px 2px rgba(0,0,0,.5);}\n  .screw::after{content:\"\";position:absolute;inset:4px;border-radius:1px;\n    background:linear-gradient(90deg,transparent 44%,#6b4a26 44%,#6b4a26 56%,transparent 56%);\n    transform:rotate(30deg);}\n  .screw.tl{top:12px;left:12px}.screw.tr{top:12px;right:12px}\n  .screw.bl{bottom:12px;left:12px}.screw.br{bottom:12px;right:12px}\n\n  .title{\n    text-align:center;margin:2px 0 4px;font-weight:800;letter-spacing:.16em;\n    font-size:13px;color:#5a3411;text-transform:uppercase;\n    text-shadow:0 1px 0 rgba(255,255,255,.4);\n  }\n  .sub{\n    text-align:center;font-size:9.5px;letter-spacing:.42em;margin-bottom:8px;\n    color:#8a5a28;text-transform:uppercase;font-weight:700;\n  }\n\n  /* ---- comb-sweep window --------------------------------------------- */\n  .window{\n    position:relative;height:118px;border-radius:14px;overflow:hidden;\n    margin:6px 2px 18px;\n    background:linear-gradient(180deg,#2a1a0d,#120a04);\n    box-shadow:0 3px 14px rgba(0,0,0,.6) inset,0 0 0 2px rgba(120,70,20,.5),\n      0 1px 0 rgba(255,220,170,.25);\n  }\n  .window svg{position:absolute;inset:0;width:100%;height:100%;display:block;}\n  .glass{position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(120deg,rgba(255,255,255,.10),transparent 40%);\n    border-radius:14px;}\n  .grain{position:absolute;inset:0;pointer-events:none;opacity:.07;mix-blend-mode:overlay;\n    background-image:radial-gradient(rgba(255,255,255,.7) .5px,transparent .6px);\n    background-size:3px 3px;}\n\n  /* ---- knob bank ------------------------------------------------------ */\n  .bank{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin:0 2px;}\n  .knobwrap{display:flex;flex-direction:column;align-items:center;}\n  .knob{\n    --ang:-135deg;position:relative;width:62px;height:62px;border-radius:50%;\n    cursor:grab;touch-action:none;\n    background:\n      radial-gradient(circle at 38% 30%,#fff3df,#e7c896 52%,#b88a4e 100%);\n    box-shadow:\n      0 5px 10px rgba(60,30,5,.5),\n      0 -2px 5px rgba(255,255,255,.5) inset,\n      0 3px 6px rgba(90,50,10,.4) inset;\n    transition:box-shadow .15s ease;\n  }\n  .knob:active{cursor:grabbing;}\n  .knob.grab{box-shadow:0 5px 14px rgba(0,0,0,.55),0 0 0 3px rgba(255,184,106,.55),\n      0 -2px 5px rgba(255,255,255,.5) inset;}\n  .knob .cap{position:absolute;inset:9px;border-radius:50%;\n    background:\n      radial-gradient(circle at 40% 32%,#5a3a1c,#321f0d 70%,#1c1108);\n    box-shadow:0 1px 2px rgba(255,220,170,.25) inset,0 2px 5px rgba(0,0,0,.6);}\n  .knob .pointer{\n    position:absolute;left:50%;top:50%;width:4px;height:24px;border-radius:3px;\n    background:linear-gradient(var(--accent),#ff8c3c);\n    transform-origin:50% 100%;\n    transform:translate(-50%,-100%) rotate(var(--ang));\n    box-shadow:0 0 7px rgba(255,184,106,.85);\n  }\n  /* tick ring */\n  .ring{position:absolute;inset:-7px;border-radius:50%;pointer-events:none;}\n  .ring svg{width:100%;height:100%;}\n  .name{margin-top:7px;font-size:9.5px;font-weight:800;letter-spacing:.12em;\n    text-transform:uppercase;color:#5a3411;text-shadow:0 1px 0 rgba(255,255,255,.4);}\n  .val{font-size:10px;font-weight:700;color:#7a4a18;margin-top:1px;\n    font-variant-numeric:tabular-nums;}\n\n  /* glow LED */\n  .led{position:absolute;top:18px;left:50%;transform:translateX(-50%);\n    width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 40% 35%,#fff,var(--accent2) 60%,#1f6f96);\n    box-shadow:0 0 12px var(--accent2),0 0 3px #fff;\n    animation:pulse 2.6s ease-in-out infinite;}\n  @keyframes pulse{0%,100%{opacity:.55;box-shadow:0 0 8px var(--accent2)}\n    50%{opacity:1;box-shadow:0 0 18px var(--accent2),0 0 5px #fff}}\n\n  .hint{text-align:center;font-size:8.5px;color:#8a5a28;letter-spacing:.18em;\n    margin-top:14px;text-transform:uppercase;opacity:.8;}\n</style>\n</head>\n<body>\n  <div class=\"pedal\" id=\"pedal\">\n    <span class=\"screw tl\"></span><span class=\"screw tr\"></span>\n    <span class=\"screw bl\"></span><span class=\"screw br\"></span>\n    <span class=\"led\"></span>\n\n    <div class=\"title\">Warm Flanger</div>\n    <div class=\"sub\">Analog &middot; BBD &middot; Sweep</div>\n\n    <div class=\"window\">\n      <svg id=\"comb\" viewBox=\"0 0 430 118\" preserveAspectRatio=\"none\">\n        <defs>\n          <linearGradient id=\"wg\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#ffb86a\" stop-opacity=\"0\"/>\n            <stop offset=\"0.5\" stop-color=\"#ffb86a\" stop-opacity=\".9\"/>\n            <stop offset=\"1\" stop-color=\"#6ad0ff\" stop-opacity=\"0\"/>\n          </linearGradient>\n          <linearGradient id=\"wg2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#6ad0ff\" stop-opacity=\"0\"/>\n            <stop offset=\"0.55\" stop-color=\"#ffd9a0\" stop-opacity=\".55\"/>\n            <stop offset=\"1\" stop-color=\"#ff8c3c\" stop-opacity=\"0\"/>\n          </linearGradient>\n        </defs>\n        <g id=\"combg\"></g>\n      </svg>\n      <div class=\"glass\"></div>\n      <div class=\"grain\"></div>\n    </div>\n\n    <div class=\"bank\" id=\"bank\"></div>\n    <div class=\"hint\">drag knobs &middot; double-click to reset</div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  var PARAMS = [\n    { name:\"Manual\", index:0, min:0, max:1, def:0.35 },\n    { name:\"Width\",  index:1, min:0, max:1, def:0.55 },\n    { name:\"Rate\",   index:2, min:0, max:1, def:0.25 },\n    { name:\"Regen\",  index:3, min:0, max:1, def:0.45 },\n    { name:\"Mix\",    index:4, min:0, max:1, def:0.50 }\n  ];\n  var vals = PARAMS.map(function(p){ return p.def; });\n\n  function send(i){\n    if(window.vstai && window.vstai.setParam) window.vstai.setParam(i, vals[i]);\n  }\n  function fmt(v){ return Math.round(v*100) + \"%\"; }\n\n  // ---- build tick ring svg ----\n  function ringSVG(){\n    var s='<svg viewBox=\"0 0 76 76\">';\n    for(var k=0;k<=10;k++){\n      var a=(-135 + k*27)*Math.PI/180;\n      var x1=38+30*Math.cos(a), y1=38+30*Math.sin(a);\n      var x2=38+34*Math.cos(a), y2=38+34*Math.sin(a);\n      s+='<line x1=\"'+x1.toFixed(1)+'\" y1=\"'+y1.toFixed(1)+'\" x2=\"'+x2.toFixed(1)+'\" y2=\"'+y2.toFixed(1)+'\" stroke=\"rgba(90,52,17,.55)\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>';\n    }\n    return s+'</svg>';\n  }\n\n  var knobEls=[], valEls=[];\n\n  function buildKnob(p){\n    var wrap=document.createElement(\"div\"); wrap.className=\"knobwrap\";\n    var ring=document.createElement(\"div\"); ring.className=\"ring\"; ring.innerHTML=ringSVG();\n    var knob=document.createElement(\"div\"); knob.className=\"knob\";\n    knob.innerHTML='<div class=\"cap\"></div><div class=\"pointer\"></div>';\n    ring.appendChild(knob);\n    var name=document.createElement(\"div\"); name.className=\"name\"; name.textContent=p.name;\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    wrap.appendChild(ring); wrap.appendChild(name); wrap.appendChild(val);\n\n    knobEls[p.index]=knob; valEls[p.index]=val;\n\n    function paint(){\n      var v=vals[p.index];\n      var ang=-135 + v*270;\n      knob.querySelector(\".pointer\").style.setProperty(\"--ang\", ang+\"deg\");\n      val.textContent=fmt(v);\n    }\n    knob._paint=paint; paint();\n\n    // drag handling (vertical)\n    var dragging=false, startY=0, startV=0;\n    function down(e){\n      dragging=true; knob.classList.add(\"grab\");\n      startY=(e.touches?e.touches[0].clientY:e.clientY);\n      startV=vals[p.index];\n      e.preventDefault();\n      window.addEventListener(\"mousemove\",move);\n      window.addEventListener(\"mouseup\",up);\n      window.addEventListener(\"touchmove\",move,{passive:false});\n      window.addEventListener(\"touchend\",up);\n    }\n    function move(e){\n      if(!dragging) return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dv=(startY-y)/180; // 180px = full sweep\n      var nv=Math.max(0,Math.min(1,startV+dv));\n      vals[p.index]=nv; paint(); send(p.index);\n      e.preventDefault();\n    }\n    function up(){\n      dragging=false; knob.classList.remove(\"grab\");\n      window.removeEventListener(\"mousemove\",move);\n      window.removeEventListener(\"mouseup\",up);\n      window.removeEventListener(\"touchmove\",move);\n      window.removeEventListener(\"touchend\",up);\n    }\n    knob.addEventListener(\"mousedown\",down);\n    knob.addEventListener(\"touchstart\",down,{passive:false});\n    knob.addEventListener(\"dblclick\",function(){\n      vals[p.index]=p.def; paint(); send(p.index);\n    });\n    // wheel fine-tune\n    knob.addEventListener(\"wheel\",function(e){\n      var nv=Math.max(0,Math.min(1,vals[p.index]-Math.sign(e.deltaY)*0.02));\n      vals[p.index]=nv; paint(); send(p.index); e.preventDefault();\n    },{passive:false});\n\n    return wrap;\n  }\n\n  var bank=document.getElementById(\"bank\");\n  PARAMS.forEach(function(p){ bank.appendChild(buildKnob(p)); });\n\n  // ---- animated honeyed comb sweep ----\n  var combg=document.getElementById(\"combg\");\n  var NBANDS=26, paths=[];\n  for(var i=0;i<NBANDS;i++){\n    var pth=document.createElementNS(\"http://www.w3.org/2000/svg\",\"path\");\n    pth.setAttribute(\"fill\",\"none\");\n    pth.setAttribute(\"stroke\", i%2 ? \"url(#wg2)\" : \"url(#wg)\");\n    pth.setAttribute(\"stroke-width\", (i%2?1.1:1.6).toFixed(1));\n    combg.appendChild(pth); paths.push(pth);\n  }\n\n  var t0=performance.now();\n  function frame(now){\n    var t=(now-t0)/1000;\n    var rate=0.05 + Math.pow(vals[2],2)*5.95;     // Hz, matches DSP feel\n    var width=vals[1];                            // sweep depth\n    var manual=vals[0];                           // parked centre\n    var regen=vals[3];                            // notch sharpness\n    var mix=vals[4];                              // wet visibility\n    var lfo=Math.sin(2*Math.PI*rate*0.18*t);      // slowed for the eye\n    var centre=215 + (manual-0.5)*150;            // horizontal park position\n    var sweep=lfo*width*150;\n    var W=430,H=118;\n\n    for(var b=0;b<NBANDS;b++){\n      var phase=b/NBANDS;\n      var d=\"M0 \"+(H/2);\n      var amp=(8 + regen*22) * (mix*0.6+0.4) * (1 - b/(NBANDS*1.6));\n      var notch=centre+sweep + (b- NBANDS/2)*3;\n      for(var x=0;x<=W;x+=10){\n        // comb-ish ripple whose density swells near the moving notch\n        var dist=Math.abs(x-notch);\n        var env=Math.exp(-dist*dist/(2*900));      // gaussian around notch\n        var freq=0.045 + env*0.10 + phase*0.01;\n        var y=H/2 + Math.sin(x*freq + t*(1.2+phase*2) + phase*6)*amp*(0.4+env)\n                  + Math.sin(x*0.012 + t*0.6)*4;\n        d+=\" L\"+x.toFixed(0)+\" \"+y.toFixed(1);\n      }\n      paths[b].setAttribute(\"d\",d);\n      paths[b].style.opacity = (0.12 + (1-b/NBANDS)*0.5).toFixed(2);\n    }\n    requestAnimationFrame(frame);\n  }\n\n  function ready(){\n    for(var i=0;i<PARAMS.length;i++){\n      if(knobEls[i]) knobEls[i]._paint();\n      send(i);                       // initialise host to defaults\n    }\n    requestAnimationFrame(frame);\n  }\n\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready); else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  WARM FLANGER — a lush, BBD-style analog flanger (effect)\n//\n//  A bucket-brigade-flavoured flanger: a short fractional delay line is\n//  swept by a slow triangle LFO around a parked centre (Manual). Width\n//  sets the sweep depth, Rate the LFO speed, Regen the feedback. The\n//  feedback path is gently low-passed (a \"warm\" BBD/companding flavour)\n//  and softly saturated so heavy Regen thickens and resonates without\n//  turning clangy or harsh — creamy rather than metallic. Stereo gets a\n//  small LFO phase offset for a gentle moving image. Pure algorithm.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\n// Delay line: up to ~12 ms per channel is plenty for a flanger.\n// 1024 samples @ 48k ~= 21.3 ms; comfortable headroom for centre+width.\nconst DLINE: i32 = 1024;\nconst DMASK: i32 = DLINE - 1;\nconst delayL: StaticArray<f32> = new StaticArray<f32>(DLINE);\nconst delayR: StaticArray<f32> = new StaticArray<f32>(DLINE);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// per-channel running state\nlet writePos: i32 = 0;\nlet lfoPhase: f32 = 0.0;            // 0..1 triangle phase (shared, R offset applied)\nlet fbLpL: f32 = 0.0;              // feedback low-pass memory (warmth)\nlet fbLpR: f32 = 0.0;\nlet fbStoreL: f32 = 0.0;           // last wet sample fed back\nlet fbStoreR: f32 = 0.0;\n\nconst P_MANUAL: i32 = 0;  // 0..1 -> centre delay 0.3..7.0 ms\nconst P_WIDTH:  i32 = 1;  // 0..1 -> sweep depth (fraction of headroom)\nconst P_RATE:   i32 = 2;  // 0..1 -> LFO 0.05..6 Hz\nconst P_REGEN:  i32 = 3;  // 0..1 -> feedback 0..0.9 (signed positive, warm)\nconst P_MIX:    i32 = 4;  // 0..1 dry/wet\n\nconst PI: f32 = 3.14159265;\nconst TWO_PI: f32 = 6.2831853;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let i = 0; i < DLINE; i++) { delayL[i] = 0.0; delayR[i] = 0.0; }\n  writePos = 0;\n  lfoPhase = 0.0;\n  fbLpL = 0.0; fbLpR = 0.0;\n  fbStoreL = 0.0; fbStoreR = 0.0;\n  params[P_MANUAL] = 0.35;\n  params[P_WIDTH]  = 0.55;\n  params[P_RATE]   = 0.25;\n  params[P_REGEN]  = 0.45;\n  params[P_MIX]    = 0.5;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// gentle soft clip for the feedback path — keeps heavy regen creamy\n@inline function softSat(x: f32): f32 {\n  const c: f32 = clampf(x, -1.5, 1.5);\n  return c - (c * c * c) * (1.0 / 6.75); // mild cubic, stays < |1|-ish, smooth\n}\n\n// triangle 0..1 phase -> -1..1 bipolar triangle (smoother than saw sweep)\n@inline function tri(p: f32): f32 {\n  // p in 0..1; triangle peaks at 0.5\n  const x: f32 = p < 0.5 ? p * 2.0 : (1.0 - p) * 2.0; // 0..1..0\n  return x; // 0..1 unipolar shape (we use it as positive depth modulator)\n}\n\n// fractional read from a delay line (linear interpolation)\n@inline function readFrac(line: StaticArray<f32>, wpos: i32, delaySamps: f32): f32 {\n  let rp: f32 = f32(wpos) - delaySamps;\n  while (rp < 0.0) rp += f32(DLINE);\n  const i0: i32 = i32(rp) & DMASK;\n  const i1: i32 = (i0 + 1) & DMASK;\n  const frac: f32 = rp - Mathf.floor(rp);\n  const a: f32 = line[i0];\n  const b: f32 = line[i1];\n  return a + (b - a) * frac;\n}\n\nexport function process(n: i32): void {\n  const manual: f32 = clampf(params[P_MANUAL], 0.0, 1.0);\n  const width:  f32 = clampf(params[P_WIDTH], 0.0, 1.0);\n  const rateN:  f32 = clampf(params[P_RATE], 0.0, 1.0);\n  const regenN: f32 = clampf(params[P_REGEN], 0.0, 1.0);\n  const mix:    f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // centre delay 0.3..7.0 ms (parked position) in samples\n  const centreMs: f32 = 0.3 + manual * 6.7;\n  const centreSamps: f32 = centreMs * 0.001 * sampleRate;\n  // sweep depth in samples: up to ~3.5 ms peak-to-base, scaled by Width.\n  // keep total read delay safely within [1 .. DLINE-2]\n  const depthMs: f32 = width * 3.5;\n  const depthSamps: f32 = depthMs * 0.001 * sampleRate;\n\n  // LFO 0.05 .. 6 Hz, exponential feel\n  const rateHz: f32 = 0.05 + rateN * rateN * 5.95;\n  const phaseInc: f32 = rateHz / sampleRate;\n\n  // feedback gain 0..0.9, kept musical\n  const fb: f32 = regenN * 0.9;\n  // feedback warmth low-pass coefficient ~ 4 kHz (tames metallic highs)\n  const lpHz: f32 = 4000.0;\n  const lpC: f32 = f32(1.0 - Mathf.exp(-TWO_PI * lpHz / sampleRate));\n\n  const maxRead: f32 = f32(DLINE - 2);\n\n  let ph: f32 = lfoPhase;\n\n  for (let f = 0; f < n; f++) {\n    // advance LFO\n    ph += phaseInc;\n    if (ph >= 1.0) ph -= 1.0;\n\n    // L channel uses ph, R channel a quarter-cycle offset for gentle stereo\n    let phR: f32 = ph + 0.25;\n    if (phR >= 1.0) phR -= 1.0;\n\n    const modL: f32 = tri(ph);   // 0..1\n    const modR: f32 = tri(phR);  // 0..1\n\n    // read delay grows from centre by depth*mod (sweeps \"up\" from parked centre)\n    let dL: f32 = centreSamps + depthSamps * modL;\n    let dR: f32 = centreSamps + depthSamps * modR;\n    if (dL < 1.0) dL = 1.0; if (dL > maxRead) dL = maxRead;\n    if (dR < 1.0) dR = 1.0; if (dR > maxRead) dR = maxRead;\n\n    // ---- LEFT ----\n    const xL: f32 = inBuf[f];\n    const wetReadL: f32 = readFrac(delayL, writePos, dL);\n    // feedback: warm low-passed + softly saturated previous wet\n    fbLpL = fbLpL + lpC * (fbStoreL - fbLpL);\n    const inputL: f32 = xL + softSat(fbLpL * fb);\n    delayL[writePos] = inputL;\n    fbStoreL = wetReadL;\n    const outL: f32 = xL * (1.0 - mix) + wetReadL * mix;\n\n    // ---- RIGHT ----\n    let xR: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : xL;\n    const wetReadR: f32 = readFrac(delayR, writePos, dR);\n    fbLpR = fbLpR + lpC * (fbStoreR - fbLpR);\n    const inputR: f32 = xR + softSat(fbLpR * fb);\n    delayR[writePos] = inputR;\n    fbStoreR = wetReadR;\n    const outR: f32 = xR * (1.0 - mix) + wetReadR * mix;\n\n    outBuf[f] = outL;\n    if (channels > 1) outBuf[MAX_FRAMES + f] = outR;\n\n    writePos = (writePos + 1) & DMASK;\n  }\n\n  lfoPhase = ph;\n}\n",
  "publishedAt": 1751000134000
}