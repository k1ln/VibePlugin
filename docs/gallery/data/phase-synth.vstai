{
  "format": 1,
  "name": "Phase Synth",
  "isInstrument": true,
  "explanation": "A polyphonic phase-distortion digital synthesizer. Instead of analog oscillators and filters, each of its up to eight voices reads a sine table through a warped phase ramp: a non-linear phase map bends the read so a pure sine morphs toward saw, square and resonant timbres. The warp depth is driven both by a static Shape control and by a per-voice distortion (DCW) envelope, so notes ring bright on the attack and settle toward a sine as they decay. Controls: Shape (sine to bright), DCW Amount, DCW Decay, Attack, Release, Detune and Level.",
  "params": [
    {
      "name": "Shape",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "DCW Amount",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "DCW Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Attack",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.02
    },
    {
      "name": "Release",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Detune",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.18
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.6
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<title>Phase Synth</title>\n<style>\n  :root{\n    --acc:#6affb0;\n    --acc2:#54d1ff;\n    --lcd:#0a2a14;\n    --lcd-grid:rgba(106,255,176,.10);\n    --case0:#11151a;\n    --case1:#1c232b;\n    --case2:#2a333d;\n    --case3:#3c4854;\n    --ink:#070a0c;\n    --label:#aebac4;\n  }\n  *{box-sizing:border-box;margin:0;padding:0;-webkit-user-select:none;user-select:none;-webkit-tap-highlight-color:transparent}\n  html,body{height:100%}\n  body{\n    background:radial-gradient(130% 100% at 50% -20%, #232d36 0%, #131920 48%, #080b0e 100%);\n    color:#e8eef2;\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    overflow:hidden;\n    display:flex;align-items:center;justify-content:center;\n    letter-spacing:.03em;\n  }\n\n  /* ============ CHASSIS ============ */\n  .unit{\n    position:relative;\n    width:780px;height:452px;\n    border-radius:16px;\n    padding:16px 20px 18px;\n    background:\n      linear-gradient(180deg,#3c4854 0%,#2a333d 5%,#1c232b 8%,#222a32 50%,#171d24 93%,#0d1116 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,.10) inset,\n      0 -3px 8px rgba(0,0,0,.6) inset,\n      0 34px 70px rgba(0,0,0,.7),\n      0 2px 0 #05080a;\n    overflow:hidden;\n  }\n  /* dotted ABS plastic texture */\n  .unit::before{\n    content:\"\";position:absolute;inset:0;border-radius:16px;pointer-events:none;\n    background-image:radial-gradient(rgba(255,255,255,.025) 1px,transparent 1px);\n    background-size:4px 4px;opacity:.6;mix-blend-mode:overlay;\n  }\n  /* angled top stripe (the classic deck color band) */\n  .unit::after{\n    content:\"\";position:absolute;left:0;right:0;top:0;height:7px;pointer-events:none;\n    background:linear-gradient(90deg,var(--acc2),var(--acc));\n    box-shadow:0 0 14px rgba(106,255,176,.55);\n  }\n\n  /* ============ TOP BAR ============ */\n  .topbar{display:flex;align-items:center;justify-content:space-between;height:34px;margin-bottom:10px}\n  .brand{display:flex;align-items:baseline;gap:10px}\n  .logo{\n    font-weight:800;font-size:19px;letter-spacing:.16em;\n    color:#eef4f7;text-shadow:0 1px 0 #000;\n  }\n  .logo b{color:var(--acc)}\n  .sub{font-size:9px;letter-spacing:.34em;color:var(--label);opacity:.7}\n  .modeltag{\n    font-size:9px;letter-spacing:.26em;color:#0a0d0f;\n    background:linear-gradient(180deg,var(--acc),var(--acc2));\n    padding:4px 9px;border-radius:3px;font-weight:700;\n    box-shadow:0 0 10px rgba(84,209,255,.4),0 1px 0 rgba(255,255,255,.5) inset;\n  }\n\n  /* ============ LAYOUT ============ */\n  .main{display:flex;gap:16px;height:330px}\n\n  /* ---- LCD ---- */\n  .lcdwrap{\n    flex:1;position:relative;border-radius:8px;\n    padding:9px;\n    background:linear-gradient(180deg,#05140b,#04210f);\n    box-shadow:\n      0 0 0 2px #0a0d0f,\n      0 0 0 4px #2a333d,\n      0 6px 18px rgba(0,0,0,.6) inset,\n      0 0 22px rgba(106,255,176,.10);\n  }\n  .lcd{position:relative;width:100%;height:100%;border-radius:5px;overflow:hidden;\n    background:radial-gradient(120% 130% at 50% 0%, #0d3a1d 0%, #082813 55%, #051d0d 100%);}\n  /* scanlines + flicker */\n  .lcd::before{\n    content:\"\";position:absolute;inset:0;pointer-events:none;z-index:5;\n    background:repeating-linear-gradient(0deg,rgba(0,0,0,.18) 0 1px,transparent 1px 3px);\n    animation:flick 5.5s steps(60) infinite;\n  }\n  @keyframes flick{0%,97%{opacity:.55}98%{opacity:.38}100%{opacity:.55}}\n  /* glass glare */\n  .lcd::after{\n    content:\"\";position:absolute;inset:0;pointer-events:none;z-index:6;border-radius:5px;\n    background:linear-gradient(135deg,rgba(255,255,255,.10) 0%,transparent 32%);\n  }\n  .scope{position:absolute;inset:0;width:100%;height:100%;display:block;z-index:2}\n  .lcdhud{position:absolute;z-index:4;font-family:\"Courier New\",monospace;color:var(--acc);\n    text-shadow:0 0 6px rgba(106,255,176,.7)}\n  .hud-tl{top:8px;left:10px;font-size:10px;letter-spacing:.18em}\n  .hud-tr{top:8px;right:10px;font-size:10px;letter-spacing:.18em;text-align:right;color:var(--acc2);text-shadow:0 0 6px rgba(84,209,255,.7)}\n  .hud-bl{bottom:8px;left:10px;font-size:22px;font-weight:700;letter-spacing:.06em}\n  .hud-bl small{font-size:10px;opacity:.7;letter-spacing:.2em}\n  .hud-br{bottom:9px;right:10px;font-size:9px;letter-spacing:.2em;opacity:.6}\n  .waveword{display:inline-block;min-width:64px}\n\n  /* ============ RIGHT: KNOB GRID ============ */\n  .panel{width:300px;display:flex;flex-direction:column;gap:12px}\n  .rack{display:grid;grid-template-columns:repeat(3,1fr);gap:10px 6px}\n  .cell{display:flex;flex-direction:column;align-items:center;gap:3px}\n  .knob{width:70px;height:70px;cursor:ns-resize;position:relative}\n  .knob svg{display:block;width:100%;height:100%;overflow:visible}\n  .knob.dragging .cap{filter:brightness(1.18)}\n  .label{font-size:8.5px;letter-spacing:.16em;color:var(--label);text-transform:uppercase}\n  .vbox{font-family:\"Courier New\",monospace;font-size:10px;color:var(--acc);\n    background:#0a0d0f;border:1px solid #2a333d;border-radius:3px;padding:1px 6px;min-width:48px;text-align:center;\n    box-shadow:0 1px 2px rgba(0,0,0,.5) inset}\n  .knob.dragging + .vbox, .cell:hover .vbox{color:var(--acc2);border-color:var(--acc2)}\n\n  /* ============ MEMBRANE BUTTON STRIP ============ */\n  .membrane{\n    display:flex;gap:6px;padding:9px;border-radius:7px;\n    background:linear-gradient(180deg,#0e1216,#171d23);\n    box-shadow:0 1px 0 rgba(255,255,255,.05) inset,0 4px 10px rgba(0,0,0,.5) inset;\n  }\n  .mbtn{\n    flex:1;height:36px;border-radius:4px;cursor:pointer;position:relative;\n    background:linear-gradient(180deg,#2c353f,#1a2128);\n    box-shadow:0 1px 0 rgba(255,255,255,.08) inset,0 2px 4px rgba(0,0,0,.5);\n    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;\n    transition:transform .05s ease,box-shadow .12s ease;\n  }\n  .mbtn:active{transform:translateY(1px)}\n  .mbtn .dot{width:6px;height:6px;border-radius:50%;background:#0a0d0f;box-shadow:0 0 0 1px #000 inset;transition:background .15s,box-shadow .15s}\n  .mbtn .mt{font-size:8px;letter-spacing:.12em;color:var(--label)}\n  .mbtn.on .dot{background:var(--acc);box-shadow:0 0 8px var(--acc)}\n  .mbtn.on .mt{color:var(--acc)}\n\n  /* power LED */\n  .pwr{display:flex;align-items:center;gap:6px;font-size:8px;letter-spacing:.2em;color:var(--label)}\n  .pled{width:8px;height:8px;border-radius:50%;background:var(--acc);box-shadow:0 0 10px var(--acc);animation:pulse 2.4s ease-in-out infinite}\n  @keyframes pulse{0%,100%{opacity:1;box-shadow:0 0 10px var(--acc)}50%{opacity:.55;box-shadow:0 0 4px var(--acc)}}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"topbar\">\n      <div class=\"brand\">\n        <div class=\"logo\">PHASE<b>·SYNTH</b></div>\n        <div class=\"sub\">PHASE DISTORTION · DIGITAL</div>\n      </div>\n      <div style=\"display:flex;align-items:center;gap:14px\">\n        <div class=\"pwr\"><span class=\"pled\"></span>POWER</div>\n        <div class=\"modeltag\">PD-8 VOICE</div>\n      </div>\n    </div>\n\n    <div class=\"main\">\n      <!-- LCD -->\n      <div class=\"lcdwrap\">\n        <div class=\"lcd\">\n          <canvas class=\"scope\" id=\"scope\" width=\"860\" height=\"640\"></canvas>\n          <div class=\"lcdhud hud-tl\" id=\"hudTL\">DCW ───</div>\n          <div class=\"lcdhud hud-tr\" id=\"hudTR\">VOICE 8</div>\n          <div class=\"lcdhud hud-bl\"><span class=\"waveword\" id=\"waveWord\">SINE</span><br><small id=\"hudWave\">SHAPE 055</small></div>\n          <div class=\"lcdhud hud-br\" id=\"hudBR\">48kHz · 16BIT</div>\n        </div>\n      </div>\n\n      <!-- KNOBS + MEMBRANE -->\n      <div class=\"panel\">\n        <div class=\"rack\" id=\"rack\"></div>\n        <div class=\"membrane\" id=\"membrane\"></div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function(){\n  var ACC=\"#6affb0\", ACC2=\"#54d1ff\";\n\n  // ----- param model (matches spec.json indices) -----\n  var PARAMS=[\n    {name:\"Shape\",     index:0, min:0,max:1, def:0.55, fmt:\"morph\"},\n    {name:\"DCW Amt\",   index:1, min:0,max:1, def:0.7,  fmt:\"pct\"},\n    {name:\"DCW Decay\", index:2, min:0,max:1, def:0.4,  fmt:\"ms\"},\n    {name:\"Attack\",    index:3, min:0,max:1, def:0.02, fmt:\"ms\"},\n    {name:\"Release\",   index:4, min:0,max:1, def:0.35, fmt:\"ms\"},\n    {name:\"Detune\",    index:5, min:0,max:1, def:0.18, fmt:\"cent\"},\n    {name:\"Level\",     index:6, min:0,max:1, def:0.6,  fmt:\"db\"}\n  ];\n\n  function clamp(v,a,b){return v<a?a:(v>b?b:v);}\n  function fmtVal(p,v){\n    var n=(v-p.min)/(p.max-p.min);\n    if(p.fmt===\"pct\") return Math.round(n*100)+\"%\";\n    if(p.fmt===\"ms\"){ var ms = p.index===3 ? (1+n*n*1200) : (20+n*n*2500); return ms<1000?Math.round(ms)+\"ms\":(ms/1000).toFixed(2)+\"s\"; }\n    if(p.fmt===\"cent\") return \"±\"+Math.round(n*12)+\"c\";\n    if(p.fmt===\"db\") return (n<=0?\"-∞\":((20*Math.log(n)/Math.LN10).toFixed(1)))+\"dB\";\n    if(p.fmt===\"morph\") return n<0.05?\"SINE\":n>0.95?\"BRIGHT\":Math.round(n*100)+\"%\";\n    return n.toFixed(2);\n  }\n\n  var STATE={};\n  PARAMS.forEach(function(p){STATE[p.index]=p.def;});\n\n  var host = window.vstai || null;\n  function send(i,v){ if(host&&host.setParam) host.setParam(i,v); }\n\n  // ===================== KNOBS =====================\n  var ns=\"http://www.w3.org/2000/svg\";\n  var rack=document.getElementById(\"rack\");\n  var SW=270; // sweep degrees\n\n  // shared defs once\n  (function(){\n    var svg=document.createElementNS(ns,\"svg\"); svg.setAttribute(\"width\",\"0\"); svg.setAttribute(\"height\",\"0\");\n    var defs=document.createElementNS(ns,\"defs\");\n    defs.innerHTML=\n      '<radialGradient id=\"cap\" cx=\"38%\" cy=\"28%\" r=\"85%\">'+\n        '<stop offset=\"0%\" stop-color=\"#586470\"/><stop offset=\"46%\" stop-color=\"#333d47\"/>'+\n        '<stop offset=\"100%\" stop-color=\"#10151a\"/></radialGradient>'+\n      '<linearGradient id=\"grad\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n        '<stop offset=\"0%\" stop-color=\"'+ACC2+'\"/><stop offset=\"100%\" stop-color=\"'+ACC+'\"/></linearGradient>'+\n      '<filter id=\"kblur\" x=\"-60%\" y=\"-60%\" width=\"220%\" height=\"220%\"><feGaussianBlur stdDeviation=\"2.6\"/></filter>'+\n      '<filter id=\"nglow\" x=\"-90%\" y=\"-90%\" width=\"280%\" height=\"280%\"><feGaussianBlur stdDeviation=\"1.0\" result=\"b\"/>'+\n        '<feMerge><feMergeNode in=\"b\"/><feMergeNode in=\"SourceGraphic\"/></feMerge></filter>';\n    svg.appendChild(defs); document.body.appendChild(svg);\n  })();\n\n  function buildKnob(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var knob=document.createElement(\"div\"); knob.className=\"knob\"; knob.title=\"drag · double-click resets\";\n    var lab=document.createElement(\"div\"); lab.className=\"label\"; lab.textContent=p.name;\n    var vbox=document.createElement(\"div\"); vbox.className=\"vbox\";\n\n    var svg=document.createElementNS(ns,\"svg\"); svg.setAttribute(\"viewBox\",\"0 0 60 60\");\n    var cx=30,cy=31,r=23;\n    function pt(deg,rr){var a=(deg-90)*Math.PI/180;return [cx+Math.cos(a)*rr, cy+Math.sin(a)*rr];}\n    function arc(a0,a1,rr){var s=pt(a0,rr),e=pt(a1,rr),large=(a1-a0)>180?1:0;\n      return \"M\"+s[0]+\" \"+s[1]+\" A\"+rr+\" \"+rr+\" 0 \"+large+\" 1 \"+e[0]+\" \"+e[1];}\n    var start=-(SW/2), end=(SW/2);\n\n    var glow=document.createElementNS(ns,\"path\");\n    glow.setAttribute(\"d\",arc(start,end,r+4)); glow.setAttribute(\"fill\",\"none\");\n    glow.setAttribute(\"stroke\",ACC); glow.setAttribute(\"stroke-width\",\"2\");\n    glow.setAttribute(\"stroke-linecap\",\"round\"); glow.setAttribute(\"filter\",\"url(#kblur)\"); glow.setAttribute(\"opacity\",\".8\"); svg.appendChild(glow);\n\n    var track=document.createElementNS(ns,\"path\");\n    track.setAttribute(\"d\",arc(start,end,r)); track.setAttribute(\"fill\",\"none\");\n    track.setAttribute(\"stroke\",\"#0b0f12\"); track.setAttribute(\"stroke-width\",\"3.4\");\n    track.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(track);\n\n    var val=document.createElementNS(ns,\"path\"); val.setAttribute(\"fill\",\"none\");\n    val.setAttribute(\"stroke\",\"url(#grad)\"); val.setAttribute(\"stroke-width\",\"3.4\");\n    val.setAttribute(\"stroke-linecap\",\"round\"); svg.appendChild(val);\n\n    var cap=document.createElementNS(ns,\"circle\"); cap.setAttribute(\"class\",\"cap\");\n    cap.setAttribute(\"cx\",cx); cap.setAttribute(\"cy\",cy); cap.setAttribute(\"r\",\"15.5\");\n    cap.setAttribute(\"fill\",\"url(#cap)\"); cap.setAttribute(\"stroke\",\"#222a32\"); cap.setAttribute(\"stroke-width\",\"1\"); svg.appendChild(cap);\n\n    var notch=document.createElementNS(ns,\"line\");\n    notch.setAttribute(\"stroke\",ACC); notch.setAttribute(\"stroke-width\",\"2.6\");\n    notch.setAttribute(\"stroke-linecap\",\"round\"); notch.setAttribute(\"filter\",\"url(#nglow)\"); svg.appendChild(notch);\n\n    knob.appendChild(svg);\n    cell.appendChild(knob); cell.appendChild(lab); cell.appendChild(vbox);\n    rack.appendChild(cell);\n\n    var cur=p.def;\n    function render(){\n      var n=(cur-p.min)/(p.max-p.min);\n      var ang=start+n*(end-start);\n      var a1=n<=0.0001?start+0.001:ang;\n      val.setAttribute(\"d\", arc(start,a1,r));\n      glow.setAttribute(\"d\", arc(start,a1,r+4));\n      var inner=pt(ang,5.5), outer=pt(ang,14);\n      notch.setAttribute(\"x1\",inner[0]); notch.setAttribute(\"y1\",inner[1]);\n      notch.setAttribute(\"x2\",outer[0]); notch.setAttribute(\"y2\",outer[1]);\n      vbox.textContent=fmtVal(p,cur);\n      STATE[p.index]=cur;\n    }\n    function setVal(v,push){ cur=clamp(v,p.min,p.max); render(); if(push) send(p.index,cur); }\n    render();\n\n    var dragging=false,startY=0,startV=0;\n    function onMove(e){\n      if(!dragging)return;\n      var y=(e.touches?e.touches[0].clientY:e.clientY);\n      var dy=startY-y, span=p.max-p.min, fine=e.shiftKey?0.25:1;\n      setVal(startV+dy/170*span*fine,true); e.preventDefault();\n    }\n    function onUp(){ if(!dragging)return; dragging=false; knob.classList.remove(\"dragging\");\n      window.removeEventListener(\"pointermove\",onMove); window.removeEventListener(\"pointerup\",onUp); }\n    knob.addEventListener(\"pointerdown\",function(e){\n      dragging=true; knob.classList.add(\"dragging\"); startY=e.clientY; startV=cur;\n      window.addEventListener(\"pointermove\",onMove); window.addEventListener(\"pointerup\",onUp); e.preventDefault();\n    });\n    knob.addEventListener(\"dblclick\",function(e){ setVal(p.def,true); e.preventDefault(); });\n    knob.addEventListener(\"wheel\",function(e){ setVal(cur-Math.sign(e.deltaY)*(p.max-p.min)*0.02,true); e.preventDefault(); },{passive:false});\n\n    return {set:setVal,get:function(){return cur;}};\n  }\n  var knobs=PARAMS.map(buildKnob);\n\n  // ===================== MEMBRANE BUTTONS (preset waveshapes) =====================\n  // Decorative tactile pad row that snaps the Shape control to characteristic\n  // phase-distortion waveshapes — wires to the real Shape param (index 0).\n  var membrane=document.getElementById(\"membrane\");\n  var WAVES=[\n    {mt:\"SINE\",  shape:0.0},\n    {mt:\"SAW\",   shape:0.42},\n    {mt:\"SQR\",   shape:0.66},\n    {mt:\"RESO 1\",shape:0.82},\n    {mt:\"RESO 2\",shape:1.0}\n  ];\n  var mbtns=[];\n  WAVES.forEach(function(w,i){\n    var b=document.createElement(\"div\"); b.className=\"mbtn\";\n    var dot=document.createElement(\"div\"); dot.className=\"dot\";\n    var t=document.createElement(\"div\"); t.className=\"mt\"; t.textContent=w.mt;\n    b.appendChild(dot); b.appendChild(t); membrane.appendChild(b); mbtns.push(b);\n    b.addEventListener(\"click\",function(){\n      knobs[0].set(w.shape,true);\n      refreshMembrane();\n    });\n  });\n  function refreshMembrane(){\n    var s=STATE[0];\n    // light the closest waveshape pad\n    var best=0,bd=1e9;\n    WAVES.forEach(function(w,i){ var d=Math.abs(w.shape-s); if(d<bd){bd=d;best=i;} });\n    mbtns.forEach(function(b,i){ b.classList.toggle(\"on\", i===best); });\n  }\n\n  // ===================== LCD ANIMATION =====================\n  var scope=document.getElementById(\"scope\");\n  var sx=scope.getContext(\"2d\");\n  var W=scope.width,H=scope.height;\n  var waveWord=document.getElementById(\"waveWord\");\n  var hudWave=document.getElementById(\"hudWave\");\n  var hudTL=document.getElementById(\"hudTL\");\n  var hudBR=document.getElementById(\"hudBR\");\n\n  function pad3(v){return (\"00\"+Math.round(v*100)).slice(-3);}\n\n  // phase-distortion phase warp (mirrors the DSP feel)\n  function pdWarp(p,d,knee){\n    var k=0.5+(knee-0.5)*d; if(k<0.02)k=0.02; if(k>0.98)k=0.98;\n    return p<k ? 0.5*(p/k) : 0.5+0.5*((p-k)/(1-k));\n  }\n\n  // simulated DCW envelope that re-triggers on a slow musical clock for life\n  var t0=performance.now(), trig=0, dcwEnv=1;\n  function loop(now){\n    var dt=(now-t0)/1000; t0=now;\n\n    var shape=STATE[0], dcwAmt=STATE[1], dcwDec=STATE[2], detune=STATE[5], level=STATE[6];\n\n    // auto re-trigger DCW so the LCD breathes like a played note\n    var decS=0.05+dcwDec*2.2;\n    dcwEnv*=Math.exp(-dt/decS);\n    trig+=dt;\n    if(trig> (0.7+dcwDec*1.4)){ trig=0; dcwEnv=1; }\n\n    var d = shape*0.35 + dcwAmt*dcwEnv; if(d>1)d=1;\n    var knee=0.5+shape*0.42;\n    var reso=shape*shape, resoMult=1+shape*6;\n\n    // HUD\n    waveWord.textContent = fmtVal(PARAMS[0],shape);\n    hudWave.textContent=\"SHAPE \"+pad3(shape);\n    var bars=Math.round(dcwEnv*7);\n    hudTL.textContent=\"DCW \"+(\"███████\".slice(0,bars)+\"───────\".slice(0,7-bars));\n    hudBR.textContent=(detune>0.01?\"DET \"+Math.round(detune*12)+\"c\":\"48kHz\")+\" · 16BIT\";\n\n    // ---- draw ----\n    sx.clearRect(0,0,W,H);\n\n    // faint grid\n    sx.strokeStyle=\"rgba(106,255,176,.10)\"; sx.lineWidth=1;\n    for(var gx=0;gx<=W;gx+=W/16){ sx.beginPath(); sx.moveTo(gx,0); sx.lineTo(gx,H); sx.stroke(); }\n    for(var gy=0;gy<=H;gy+=H/8){ sx.beginPath(); sx.moveTo(0,gy); sx.lineTo(W,gy); sx.stroke(); }\n    // center line\n    sx.strokeStyle=\"rgba(106,255,176,.22)\"; sx.beginPath(); sx.moveTo(0,H/2); sx.lineTo(W,H/2); sx.stroke();\n\n    // scroll offset so it feels alive\n    var scroll=(now/1000*0.35)%1;\n    var cycles=3;\n\n    // ghost (previous) trace in dim accent2\n    function trace(phaseOff,style,lw,glowc,blur,scaleY){\n      sx.beginPath();\n      for(var x=0;x<=W;x+=2){\n        var u=(x/W);\n        var p=((u*cycles)+phaseOff)%1;\n        var wa=pdWarp(p,d,knee);\n        var s=Math.sin(wa*Math.PI*2);\n        if(reso>0.001){\n          var win=1-p;\n          var rr=Math.sin(wa*Math.PI*2*resoMult)*win;\n          var rg=reso*(0.4+0.6*d);\n          s=s*(1-rg)+rr*rg;\n        }\n        var y=H/2 - s*(H*scaleY)*(0.5+level*0.5);\n        if(x===0) sx.moveTo(x,y); else sx.lineTo(x,y);\n      }\n      sx.strokeStyle=style; sx.lineWidth=lw;\n      sx.shadowColor=glowc; sx.shadowBlur=blur; sx.stroke(); sx.shadowBlur=0;\n    }\n\n    // detune ghost behind (slightly phase-shifted, cyan)\n    if(detune>0.01) trace(scroll+0.02+detune*0.05,\"rgba(84,209,255,.45)\",2,ACC2,6,0.40);\n    // main bright-green trace\n    trace(scroll,ACC,3,ACC,12,0.42);\n\n    // moving sweep highlight\n    var hp=((now/1000*0.5)%1)*W;\n    var g=sx.createLinearGradient(hp-40,0,hp+40,0);\n    g.addColorStop(0,\"rgba(106,255,176,0)\"); g.addColorStop(.5,\"rgba(106,255,176,.10)\"); g.addColorStop(1,\"rgba(106,255,176,0)\");\n    sx.fillStyle=g; sx.fillRect(hp-40,0,80,H);\n\n    requestAnimationFrame(loop);\n  }\n  requestAnimationFrame(loop);\n  refreshMembrane();\n\n  // ===================== HOST WIRING =====================\n  function ready(){\n    knobs.forEach(function(k,i){ send(PARAMS[i].index, k.get()); });\n    refreshMembrane();\n  }\n  if(host && host.onReady) host.onReady(ready); else ready();\n\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  PHASE SYNTH — a polyphonic phase-distortion digital synthesizer.\n//\n//  Inspired by classic 80s phase-distortion synths: instead of analog\n//  oscillators + filters, each voice reads a SINE wavetable through a\n//  WARPED phase ramp. A non-linear phase map bends the read so a pure\n//  sine morphs toward saw / square / resonant timbres. The amount of\n//  warp is driven both by a static Shape control and by a per-voice\n//  \"DCW\" (distortion control wave) envelope — the characteristic\n//  phase-distortion character where the tone is bright on the attack\n//  and decays toward a sine.\n//\n//  Per voice: PD oscillator -> amp ADSR-ish (AR + DCW decay). Voices\n//  are allocated per noteId so chords ring with independent contours.\n//  Pure algorithm, no samples, no host imports. All f32.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\nconst NUM_VOICES: i32 = 8;\n\nconst PI: f32 = 3.14159265358979;\nconst TWO_PI: f32 = 6.28318530717959;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet dcX: f32 = 0.0; let dcY: f32 = 0.0;   // DC blocker\n\n// ---- parameter indices (must match spec.json) -----------------------\nconst P_SHAPE:   i32 = 0;  // 0..1  sine <-> bright (saw/square/resonant blend)\nconst P_DCWAMT:  i32 = 1;  // 0..1  depth of the distortion envelope\nconst P_DCWDEC:  i32 = 2;  // 0..1  DCW decay time (how fast brightness falls)\nconst P_ATTACK:  i32 = 3;  // 0..1  amp attack seconds\nconst P_RELEASE: i32 = 4;  // 0..1  amp release seconds\nconst P_DETUNE:  i32 = 5;  // 0..1  twin-osc detune spread\nconst P_LEVEL:   i32 = 6;  // 0..1  output level\n\n// ---- per-voice state (StaticArrays at module scope, no alloc) -------\nconst vNote:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // noteId or -1\nconst vActive: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while sounding\nconst vGate:   StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // 1 while key held\nconst vAge:    StaticArray<i32> = new StaticArray<i32>(NUM_VOICES); // for oldest-voice stealing\n\nconst vFreq:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vVel:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nconst vPhaseA: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc 1 phase 0..1\nconst vPhaseB: StaticArray<f32> = new StaticArray<f32>(NUM_VOICES); // osc 2 (detuned) phase\n\n// amplitude envelope (AR): 0 idle, 1 attack, 2 sustain(hold), 3 release\nconst vAEnv:   StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\nconst vAStage: StaticArray<i32> = new StaticArray<i32>(NUM_VOICES);\n\n// DCW envelope: 1.0 at note-on, decays toward 0 -> brightness falls off\nconst vDcw:    StaticArray<f32> = new StaticArray<f32>(NUM_VOICES);\n\nlet ageCounter: i32 = 0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  dcX = 0.0; dcY = 0.0;\n  for (let v = 0; v < NUM_VOICES; v++) {\n    vNote[v] = -1; vActive[v] = 0; vGate[v] = 0; vAge[v] = 0;\n    vFreq[v] = 0.0; vVel[v] = 0.0;\n    vPhaseA[v] = 0.0; vPhaseB[v] = 0.0;\n    vAEnv[v] = 0.0; vAStage[v] = 0;\n    vDcw[v] = 0.0;\n  }\n  ageCounter = 0;\n  params[P_SHAPE]   = 0.55;\n  params[P_DCWAMT]  = 0.7;\n  params[P_DCWDEC]  = 0.4;\n  params[P_ATTACK]  = 0.02;\n  params[P_RELEASE] = 0.35;\n  params[P_DETUNE]  = 0.18;\n  params[P_LEVEL]   = 0.6;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// ---- voice allocation -----------------------------------------------\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  let slot: i32 = -1;\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 0) { slot = i; break; }\n  }\n  if (slot < 0) {\n    let oldest: i32 = 0;\n    let oldestAge: i32 = vAge[0];\n    for (let i = 1; i < NUM_VOICES; i++) {\n      if (vAge[i] < oldestAge) { oldestAge = vAge[i]; oldest = i; }\n    }\n    slot = oldest;\n  }\n\n  vNote[slot]   = id;\n  vFreq[slot]   = f > 0.0 ? f : 1.0;\n  vVel[slot]    = clampf(v, 0.0, 1.0);\n  vActive[slot] = 1;\n  vGate[slot]   = 1;\n  vAStage[slot] = 1;     // attack\n  vAEnv[slot]   = 0.0;\n  vDcw[slot]    = 1.0;   // full distortion at note-on\n  vPhaseA[slot] = 0.0;\n  vPhaseB[slot] = 0.0;\n  vAge[slot]    = ageCounter++;\n}\n\nexport function noteOff(id: i32): void {\n  for (let i = 0; i < NUM_VOICES; i++) {\n    if (vActive[i] == 1 && vGate[i] == 1 && vNote[i] == id) {\n      vGate[i] = 0;\n      vAStage[i] = 3;    // release\n    }\n  }\n}\n\n// ---- phase-distortion core ------------------------------------------\n// Given a linear phase p in 0..1 and a warp amount d in 0..1, bend the\n// phase so the sine read accelerates through one region and stalls in\n// another. With d=0 the map is identity (pure sine). As d rises the\n// \"knee\" moves and the read crowds energy into a fast sweep -> higher\n// harmonics, approaching saw/resonant timbres. `tilt` selects the kind\n// of warp (toward saw-ish vs resonant/formant-ish) for the Shape blend.\n@inline function pdWarp(p: f32, d: f32, knee: f32): f32 {\n  // knee in (0,1): fraction of the cycle spent in the first (slow) segment.\n  // two-piece linear phase map -> classic CZ \"saw\" shape when sine-read.\n  // d scales how far the knee is pushed away from 0.5 (no distortion at d=0).\n  let k: f32 = 0.5 + (knee - 0.5) * d;\n  if (k < 0.02) k = 0.02;\n  if (k > 0.98) k = 0.98;\n  let w: f32;\n  if (p < k) {\n    w = 0.5 * (p / k);\n  } else {\n    w = 0.5 + 0.5 * ((p - k) / (1.0 - k));\n  }\n  return w;\n}\n\nexport function process(n: i32): void {\n  const sr: f32 = sampleRate;\n\n  // ---- read + map parameters once per block -------------------------\n  const shapeN: f32 = clampf(params[P_SHAPE], 0.0, 1.0);\n  const dcwAmt: f32 = clampf(params[P_DCWAMT], 0.0, 1.0);\n  const dcwDecN: f32 = clampf(params[P_DCWDEC], 0.0, 1.0);\n  const atkS: f32   = 0.001 + clampf(params[P_ATTACK], 0.0, 1.0) * 1.2;\n  const relS: f32   = 0.005 + clampf(params[P_RELEASE], 0.0, 1.0) * 2.5;\n  const detuneN: f32 = clampf(params[P_DETUNE], 0.0, 1.0);\n  const level: f32  = clampf(params[P_LEVEL], 0.0, 1.0);\n\n  const atkRate: f32 = 1.0 / (atkS * sr);\n  const relRate: f32 = 1.0 / (relS * sr);\n\n  // DCW decay: per-sample multiplicative decay. Longer time => slower fall.\n  const dcwDecS: f32 = 0.02 + dcwDecN * 2.5;\n  const dcwCoef: f32 = f32(Mathf.exp(-1.0 / (dcwDecS * sr)));\n\n  // Shape picks where the phase knee sits AND blends in a second,\n  // resonant-style warp at the bright end for richer harmonics.\n  // shape 0 -> knee near 0.5 (gentle), shape 1 -> knee pushed to 0.9 (saw/bright).\n  const knee: f32 = 0.5 + shapeN * 0.42;\n  // resonant content: a windowed higher-harmonic burst, fades in at bright end.\n  const resoMix: f32 = shapeN * shapeN;        // 0..1\n  // how many cycles of the inner \"formant\" sine per phase window (2..7)\n  const resoMult: f32 = 1.0 + shapeN * 6.0;\n\n  // detune: up to ~ +/-0.12 semitone -> slow chorusy beating\n  const detSemi: f32 = detuneN * 0.12;\n  const ratioUp: f32   = f32(Mathf.pow(2.0, detSemi / 12.0));\n  const ratioDown: f32 = f32(Mathf.pow(2.0, -detSemi / 12.0));\n\n  // headroom: up to 8 voices, two oscillators each\n  const voiceScale: f32 = 0.42;\n\n  for (let f = 0; f < n; f++) {\n    let outL: f32 = 0.0;\n\n    for (let v = 0; v < NUM_VOICES; v++) {\n      if (vActive[v] == 0) continue;\n\n      // ---- amplitude AR envelope --------------------------------\n      let aenv: f32 = vAEnv[v];\n      let astg: i32 = vAStage[v];\n      if (astg == 1) {            // attack\n        aenv += atkRate;\n        if (aenv >= 1.0) { aenv = 1.0; astg = 2; }\n      } else if (astg == 2) {     // hold while gated\n        aenv = 1.0;\n      } else if (astg == 3) {     // release\n        aenv -= relRate;\n        if (aenv <= 0.0) { aenv = 0.0; astg = 0; }\n      }\n      vAEnv[v] = aenv;\n      vAStage[v] = astg;\n\n      if (astg == 0 && aenv <= 0.0) {\n        vActive[v] = 0; vGate[v] = 0; vNote[v] = -1;\n        continue;\n      }\n\n      // ---- DCW (distortion) envelope ----------------------------\n      let dcw: f32 = vDcw[v];\n      dcw *= dcwCoef;          // decays toward 0\n      vDcw[v] = dcw;\n      // effective distortion depth: base Shape always active, plus the\n      // decaying DCW contour scaled by its amount. Clamped to 0..1.\n      let d: f32 = shapeN * 0.35 + dcwAmt * dcw;\n      if (d > 1.0) d = 1.0;\n\n      // ---- twin phase-distortion oscillators --------------------\n      const baseInc: f32 = vFreq[v] / sr;\n      const incA: f32 = baseInc * ratioDown;\n      const incB: f32 = baseInc * ratioUp;\n\n      let pa: f32 = vPhaseA[v];\n      pa += incA; if (pa >= 1.0) pa -= 1.0;\n      vPhaseA[v] = pa;\n      let pb: f32 = vPhaseB[v];\n      pb += incB; if (pb >= 1.0) pb -= 1.0;\n      vPhaseB[v] = pb;\n\n      // warp each phase then read the sine table (Mathf.sin)\n      const waA: f32 = pdWarp(pa, d, knee);\n      const waB: f32 = pdWarp(pb, d, knee);\n\n      // primary saw-ish phase-distortion tone\n      let oscA: f32 = f32(Mathf.sin(waA * TWO_PI));\n      let oscB: f32 = f32(Mathf.sin(waB * TWO_PI));\n\n      // resonant/formant layer: a higher sine windowed by a falling ramp,\n      // gated by the bright end of Shape and the DCW depth -> the classic\n      // \"resonant\" CZ waveforms. Window = (1 - phase) so it rings then dies.\n      if (resoMix > 0.001) {\n        const winA: f32 = 1.0 - pa;\n        const winB: f32 = 1.0 - pb;\n        const rA: f32 = f32(Mathf.sin(waA * TWO_PI * resoMult)) * winA;\n        const rB: f32 = f32(Mathf.sin(waB * TWO_PI * resoMult)) * winB;\n        const rg: f32 = resoMix * (0.4 + 0.6 * d);\n        oscA = oscA * (1.0 - rg) + rA * rg;\n        oscB = oscB * (1.0 - rg) + rB * rg;\n      }\n\n      const osc: f32 = (oscA + oscB) * 0.5;\n      const voice: f32 = osc * aenv * vVel[v];\n      outL += voice;\n    }\n\n    // ---- sum + gentle soft-saturate for digital glue ------------\n    let mix: f32 = outL * voiceScale * level;\n    mix = f32(Mathf.tanh(mix * 1.1));\n    const dcO: f32 = mix - dcX + 0.9985 * dcY; dcX = mix; dcY = dcO; mix = dcO;\n\n    outBuf[f] = mix;\n    outBuf[MAX_FRAMES + f] = mix;\n  }\n}\n",
  "publishedAt": 1751000068000
}