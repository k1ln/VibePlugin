{
  "format": 1,
  "name": "Discrete EQ",
  "isInstrument": false,
  "explanation": "A punchy, forward discrete-electronics console equaliser. Three cascaded bands modelled on a vintage 500-series discrete-op-amp EQ: a low band that switches between musical shelf and bell, a sweepable mid bell with reciprocal proportional-Q (the bell sits wide at small boosts and narrows as you push it hard), and a high band that switches between shelf and bell. The whole strip is followed by a touch of discrete-stage drive for that forward console weight. Controls: Low Gain, Low Shape (shelf/bell), Mid Freq, Mid Gain, High Gain, High Shape (shelf/bell) and Drive.",
  "params": [
    {
      "name": "Low Gain",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Low Shape",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Mid Freq",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.45
    },
    {
      "name": "Mid Gain",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "High Gain",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "High Shape",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0
    },
    {
      "name": "Drive",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.25
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Discrete EQ</title>\n<style>\n  :root{\n    --accent:#ff5c5c;\n    --accent2:#ffb05c;\n    --panel:#1a1416;\n    --panel2:#120d0f;\n    --metal:#2a2024;\n    --metal-hi:#3a2e30;\n    --ink:#f3e7e2;\n    --ink-dim:#b09a93;\n  }\n  *{box-sizing:border-box;margin:0;padding:0}\n  html,body{height:100%}\n  body{\n    font-family:\"Helvetica Neue\",Arial,sans-serif;\n    background:\n      radial-gradient(120% 90% at 50% -10%, #2a1d1f 0%, #100b0c 60%, #080506 100%);\n    color:var(--ink);\n    display:flex; align-items:center; justify-content:center;\n    min-height:100%; padding:22px; overflow:hidden;\n    -webkit-user-select:none; user-select:none;\n  }\n\n  /* ===== chassis ===== */\n  .unit{\n    width:660px;\n    border-radius:14px;\n    background:\n      linear-gradient(180deg,#221819 0%, #170f11 100%);\n    border:1px solid #3a2c2e;\n    box-shadow:\n      0 30px 70px rgba(0,0,0,.7),\n      inset 0 1px 0 rgba(255,255,255,.06),\n      inset 0 -2px 6px rgba(0,0,0,.6);\n    position:relative;\n    overflow:hidden;\n  }\n  /* brushed-metal faceplate sheen */\n  .unit::before{\n    content:\"\"; position:absolute; inset:0; pointer-events:none;\n    background:\n      repeating-linear-gradient(90deg, rgba(255,255,255,.018) 0 2px, transparent 2px 4px);\n    mix-blend-mode:overlay; opacity:.5;\n  }\n\n  /* ===== header / brand strip ===== */\n  .brand{\n    display:flex; align-items:center; justify-content:space-between;\n    padding:14px 20px;\n    background:linear-gradient(180deg,#2c2022,#1d1416);\n    border-bottom:1px solid #000;\n    box-shadow:inset 0 -1px 0 rgba(255,255,255,.04);\n  }\n  .logo{display:flex; align-items:center; gap:12px}\n  .led{\n    width:11px;height:11px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%, #ffd0a0, var(--accent2) 55%, #7a2c14 100%);\n    box-shadow:0 0 10px var(--accent2), 0 0 20px rgba(255,176,92,.5);\n    animation:pulse 2.4s ease-in-out infinite;\n  }\n  @keyframes pulse{0%,100%{opacity:.55;box-shadow:0 0 6px var(--accent2)}50%{opacity:1;box-shadow:0 0 14px var(--accent2),0 0 26px rgba(255,176,92,.6)}}\n  .title{font-weight:800;letter-spacing:.16em;font-size:15px;text-transform:uppercase}\n  .title b{color:var(--accent)}\n  .model{font-size:10px;letter-spacing:.32em;color:var(--ink-dim);text-transform:uppercase}\n  .screws{display:flex;gap:8px}\n  .screw{width:13px;height:13px;border-radius:50%;\n    background:radial-gradient(circle at 35% 30%,#5a4a4c,#221a1c 70%);\n    box-shadow:inset 0 1px 1px rgba(255,255,255,.2),0 1px 2px #000;position:relative}\n  .screw::after{content:\"\";position:absolute;inset:0;margin:auto;width:9px;height:2px;background:#0a0708;border-radius:1px;transform:rotate(40deg)}\n\n  /* ===== response graph ===== */\n  .graph-wrap{padding:16px 20px 6px}\n  .graph{\n    position:relative;width:100%;height:150px;border-radius:8px;\n    background:linear-gradient(180deg,#0c0809,#140d0f);\n    border:1px solid #000;\n    box-shadow:inset 0 2px 10px rgba(0,0,0,.8), 0 0 0 1px rgba(255,92,92,.08);\n    overflow:hidden;\n  }\n  .graph svg{position:absolute;inset:0;width:100%;height:100%}\n  .scan{\n    position:absolute;inset:0;pointer-events:none;\n    background:linear-gradient(180deg,transparent 0%,rgba(255,92,92,.05) 50%,transparent 100%);\n    height:200%;animation:scan 5.5s linear infinite;\n  }\n  @keyframes scan{0%{transform:translateY(-50%)}100%{transform:translateY(0%)}}\n\n  /* ===== knob deck ===== */\n  .deck{\n    display:flex; justify-content:space-between; gap:8px;\n    padding:18px 20px 24px;\n    background:linear-gradient(180deg,#160f10,#0f0a0b);\n    border-top:1px solid #000;\n    box-shadow:inset 0 1px 0 rgba(255,255,255,.03);\n  }\n  .cell{display:flex;flex-direction:column;align-items:center;gap:10px;flex:1}\n  .cell .lab{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--ink-dim);font-weight:700}\n  .cell .val{font-size:11px;font-variant-numeric:tabular-nums;color:var(--accent2);min-height:14px;font-weight:700;letter-spacing:.04em}\n\n  /* ===== chunky stepped concentric knob ===== */\n  .knob{\n    width:78px;height:78px;border-radius:50%;cursor:grab;position:relative;\n    touch-action:none;\n  }\n  .knob:active{cursor:grabbing}\n  .knob svg{display:block;overflow:visible}\n  .knob .skirt{filter:drop-shadow(0 5px 6px rgba(0,0,0,.65))}\n  .knob:hover .glow{opacity:1}\n  .glow{transition:opacity .25s; opacity:0}\n\n  /* ===== segmented shape switch ===== */\n  .switch{\n    width:78px;height:78px;border-radius:50%;position:relative;cursor:pointer;\n    display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;\n    background:radial-gradient(circle at 50% 35%,#2c2123,#161011 72%);\n    border:1px solid #000;\n    box-shadow:0 5px 8px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.06);\n  }\n  .seg{display:flex;gap:5px}\n  .pip{\n    font-size:9px;letter-spacing:.1em;text-transform:uppercase;font-weight:800;\n    padding:3px 7px;border-radius:5px;color:var(--ink-dim);\n    background:#0c0809;border:1px solid #000;transition:all .18s;\n  }\n  .pip.on{\n    color:#1a0d0a;background:linear-gradient(180deg,var(--accent2),var(--accent));\n    box-shadow:0 0 10px rgba(255,92,92,.7),inset 0 1px 0 rgba(255,255,255,.4);\n  }\n  .switch .ring{position:absolute;inset:-1px;border-radius:50%;border:1px solid rgba(255,92,92,.12);pointer-events:none}\n\n  .foot{padding:9px 20px;display:flex;justify-content:space-between;align-items:center;\n    background:#0c0809;border-top:1px solid #000;font-size:9px;letter-spacing:.22em;color:#6e5a58;text-transform:uppercase}\n  .foot .vu{display:flex;gap:3px;align-items:flex-end;height:14px}\n  .foot .vu i{width:3px;background:var(--accent);border-radius:1px;opacity:.3;animation:vu 1.3s ease-in-out infinite}\n  .foot .vu i:nth-child(2){animation-delay:.15s}\n  .foot .vu i:nth-child(3){animation-delay:.3s}\n  .foot .vu i:nth-child(4){animation-delay:.45s}\n  .foot .vu i:nth-child(5){animation-delay:.6s}\n  @keyframes vu{0%,100%{height:4px;opacity:.3}50%{height:14px;opacity:.9}}\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <div class=\"brand\">\n      <div class=\"logo\">\n        <span class=\"led\"></span>\n        <div>\n          <div class=\"title\"><b>DISCRETE</b> EQ</div>\n          <div class=\"model\">3-band · proportional-q · discrete drive</div>\n        </div>\n      </div>\n      <div class=\"screws\"><span class=\"screw\"></span><span class=\"screw\"></span></div>\n    </div>\n\n    <div class=\"graph-wrap\">\n      <div class=\"graph\">\n        <div class=\"scan\"></div>\n        <svg viewBox=\"0 0 600 150\" preserveAspectRatio=\"none\">\n          <!-- grid -->\n          <g stroke=\"#2a1c1e\" stroke-width=\"1\">\n            <line x1=\"0\" y1=\"37.5\" x2=\"600\" y2=\"37.5\"/>\n            <line x1=\"0\" y1=\"75\"   x2=\"600\" y2=\"75\"/>\n            <line x1=\"0\" y1=\"112.5\" x2=\"600\" y2=\"112.5\"/>\n          </g>\n          <g stroke=\"#1f1517\" stroke-width=\"1\">\n            <line x1=\"120\" y1=\"0\" x2=\"120\" y2=\"150\"/>\n            <line x1=\"240\" y1=\"0\" x2=\"240\" y2=\"150\"/>\n            <line x1=\"360\" y1=\"0\" x2=\"360\" y2=\"150\"/>\n            <line x1=\"480\" y1=\"0\" x2=\"480\" y2=\"150\"/>\n          </g>\n          <line x1=\"0\" y1=\"75\" x2=\"600\" y2=\"75\" stroke=\"#4a3032\" stroke-width=\"1\" stroke-dasharray=\"3 4\"/>\n          <!-- filled response -->\n          <path id=\"fill\" fill=\"url(#grad)\" opacity=\"0.28\" d=\"\"/>\n          <path id=\"curve\" fill=\"none\" stroke=\"url(#stroke)\" stroke-width=\"2.4\" d=\"\"/>\n          <circle id=\"midDot\" r=\"4.5\" fill=\"#1a0d0a\" stroke=\"var(--accent)\" stroke-width=\"2\"/>\n          <defs>\n            <linearGradient id=\"grad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n              <stop offset=\"0\" stop-color=\"#ff5c5c\"/>\n              <stop offset=\"1\" stop-color=\"#ffb05c\" stop-opacity=\"0\"/>\n            </linearGradient>\n            <linearGradient id=\"stroke\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"0\">\n              <stop offset=\"0\" stop-color=\"#ffb05c\"/>\n              <stop offset=\"0.5\" stop-color=\"#ff5c5c\"/>\n              <stop offset=\"1\" stop-color=\"#ffb05c\"/>\n            </linearGradient>\n          </defs>\n        </svg>\n      </div>\n    </div>\n\n    <div class=\"deck\" id=\"deck\"></div>\n\n    <div class=\"foot\">\n      <span>discrete · class-a path</span>\n      <div class=\"vu\"><i></i><i></i><i></i><i></i><i></i></div>\n      <span>+24 dBu</span>\n    </div>\n  </div>\n\n<script>\n(function(){\n  \"use strict\";\n\n  // ---- host bridge -------------------------------------------------\n  var host = (window.vstai && typeof window.vstai.setParam === \"function\") ? window.vstai : null;\n  function send(i,v){ try{ if(host) host.setParam(i, v); }catch(e){} }\n\n  // ---- param model (mirrors spec.json) -----------------------------\n  // type: \"knob\" continuous, \"switch\" two-state discrete\n  var PARAMS = [\n    {i:0, name:\"Low Gain\",   type:\"knob\",   def:0.5,  fmt:dbFmt(24)},\n    {i:1, name:\"Low Shape\",  type:\"switch\", def:0,    opts:[\"Shelf\",\"Bell\"]},\n    {i:2, name:\"Mid Freq\",   type:\"knob\",   def:0.45, fmt:freqFmt},\n    {i:3, name:\"Mid Gain\",   type:\"knob\",   def:0.5,  fmt:dbFmt(30)},\n    {i:4, name:\"High Gain\",  type:\"knob\",   def:0.5,  fmt:dbFmt(27)},\n    {i:5, name:\"High Shape\", type:\"switch\", def:0,    opts:[\"Shelf\",\"Bell\"]},\n    {i:6, name:\"Drive\",      type:\"knob\",   def:0.25, fmt:pctFmt}\n  ];\n  var state = {}; // index -> 0..1 value\n\n  function dbFmt(span){ return function(v){ var d=(v-0.5)*span; return (d>=0?\"+\":\"\")+d.toFixed(1)+\" dB\"; }; }\n  function pctFmt(v){ return Math.round(v*100)+\" %\"; }\n  function freqFmt(v){\n    // 200 * (7000/200)^v\n    var hz = 200*Math.pow(35, v);\n    return hz>=1000 ? (hz/1000).toFixed(2)+\" kHz\" : Math.round(hz)+\" Hz\";\n  }\n\n  var deck = document.getElementById(\"deck\");\n\n  // ---- build a chunky stepped concentric knob ----------------------\n  function makeKnob(p){\n    var cell = document.createElement(\"div\"); cell.className=\"cell\";\n    var lab = document.createElement(\"div\"); lab.className=\"lab\"; lab.textContent=p.name;\n    var holder = document.createElement(\"div\"); holder.className=\"knob\"; holder.tabIndex=0;\n    var val = document.createElement(\"div\"); val.className=\"val\";\n\n    var NS=\"http://www.w3.org/2000/svg\";\n    var svg=document.createElementNS(NS,\"svg\");\n    svg.setAttribute(\"viewBox\",\"0 0 100 100\"); svg.setAttribute(\"width\",\"78\"); svg.setAttribute(\"height\",\"78\");\n\n    // outer stepped skirt with ridges (concentric ring)\n    var skirt=document.createElementNS(NS,\"g\"); skirt.setAttribute(\"class\",\"skirt\");\n    var ridges=14;\n    for(var k=0;k<ridges;k++){\n      var a=(k/ridges)*Math.PI*2;\n      var x1=50+Math.cos(a)*47, y1=50+Math.sin(a)*47;\n      var x2=50+Math.cos(a)*41, y2=50+Math.sin(a)*41;\n      var ln=document.createElementNS(NS,\"line\");\n      ln.setAttribute(\"x1\",x1);ln.setAttribute(\"y1\",y1);ln.setAttribute(\"x2\",x2);ln.setAttribute(\"y2\",y2);\n      ln.setAttribute(\"stroke\",\"#0c0708\");ln.setAttribute(\"stroke-width\",\"3\");\n      skirt.appendChild(ln);\n    }\n    var base=document.createElementNS(NS,\"circle\");\n    base.setAttribute(\"cx\",\"50\");base.setAttribute(\"cy\",\"50\");base.setAttribute(\"r\",\"44\");\n    base.setAttribute(\"fill\",\"#1c1416\");base.setAttribute(\"stroke\",\"#000\");base.setAttribute(\"stroke-width\",\"1.5\");\n    skirt.appendChild(base);\n    svg.appendChild(skirt);\n\n    // glow ring (hover)\n    var glow=document.createElementNS(NS,\"circle\");\n    glow.setAttribute(\"class\",\"glow\");\n    glow.setAttribute(\"cx\",\"50\");glow.setAttribute(\"cy\",\"50\");glow.setAttribute(\"r\",\"45\");\n    glow.setAttribute(\"fill\",\"none\");glow.setAttribute(\"stroke\",\"var(--accent)\");glow.setAttribute(\"stroke-width\",\"1.5\");\n    glow.setAttribute(\"filter\",\"drop-shadow(0 0 5px var(--accent))\");\n    svg.appendChild(glow);\n\n    // value arc track\n    var R=37, CX=50, CY=50, A0=135, A1=405; // degrees (270 sweep)\n    var track=document.createElementNS(NS,\"path\");\n    track.setAttribute(\"d\", arc(CX,CY,R,A0,A1));\n    track.setAttribute(\"fill\",\"none\");track.setAttribute(\"stroke\",\"#2c1f21\");track.setAttribute(\"stroke-width\",\"4\");\n    track.setAttribute(\"stroke-linecap\",\"round\");\n    svg.appendChild(track);\n\n    var fill=document.createElementNS(NS,\"path\");\n    fill.setAttribute(\"fill\",\"none\");fill.setAttribute(\"stroke\",\"url(#stroke)\");fill.setAttribute(\"stroke-width\",\"4\");\n    fill.setAttribute(\"stroke-linecap\",\"round\");\n    svg.appendChild(fill);\n\n    // inner cap (concentric, red)\n    var cap=document.createElementNS(NS,\"circle\");\n    cap.setAttribute(\"cx\",\"50\");cap.setAttribute(\"cy\",\"50\");cap.setAttribute(\"r\",\"26\");\n    cap.setAttribute(\"fill\",\"#241719\");\n    cap.setAttribute(\"stroke\",\"#3a2a2c\");cap.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(cap);\n    var capRing=document.createElementNS(NS,\"circle\");\n    capRing.setAttribute(\"cx\",\"50\");capRing.setAttribute(\"cy\",\"50\");capRing.setAttribute(\"r\",\"20\");\n    capRing.setAttribute(\"fill\",\"none\");capRing.setAttribute(\"stroke\",\"rgba(255,92,92,.25)\");capRing.setAttribute(\"stroke-width\",\"1\");\n    svg.appendChild(capRing);\n\n    // pointer\n    var ptr=document.createElementNS(NS,\"line\");\n    ptr.setAttribute(\"x1\",\"50\");ptr.setAttribute(\"y1\",\"50\");\n    ptr.setAttribute(\"stroke\",\"var(--accent2)\");ptr.setAttribute(\"stroke-width\",\"3.2\");ptr.setAttribute(\"stroke-linecap\",\"round\");\n    ptr.setAttribute(\"filter\",\"drop-shadow(0 0 3px var(--accent))\");\n    svg.appendChild(ptr);\n\n    holder.appendChild(svg);\n    cell.appendChild(lab); cell.appendChild(holder); cell.appendChild(val);\n    deck.appendChild(cell);\n\n    function render(){\n      var v=state[p.i];\n      var ang=A0+(A1-A0)*v;\n      var rad=(ang-90)*Math.PI/180;\n      ptr.setAttribute(\"x2\", 50+Math.cos(rad)*30);\n      ptr.setAttribute(\"y2\", 50+Math.sin(rad)*30);\n      fill.setAttribute(\"d\", arc(CX,CY,R,A0,ang));\n      val.textContent = p.fmt ? p.fmt(v) : Math.round(v*100)+\"%\";\n    }\n\n    // ---- drag ----\n    var dragging=false, startY=0, startV=0;\n    function down(e){ dragging=true; startY=clientY(e); startV=state[p.i]; holder.focus(); e.preventDefault(); }\n    function move(e){\n      if(!dragging) return;\n      var dy=startY-clientY(e);\n      var nv=clamp(startV + dy/200, 0, 1);\n      setVal(nv);\n      e.preventDefault();\n    }\n    function up(){ dragging=false; }\n    holder.addEventListener(\"mousedown\",down);\n    window.addEventListener(\"mousemove\",move);\n    window.addEventListener(\"mouseup\",up);\n    holder.addEventListener(\"touchstart\",down,{passive:false});\n    window.addEventListener(\"touchmove\",move,{passive:false});\n    window.addEventListener(\"touchend\",up);\n    holder.addEventListener(\"dblclick\",function(){ setVal(p.def); });\n    holder.addEventListener(\"wheel\",function(e){ setVal(clamp(state[p.i]-Math.sign(e.deltaY)*0.03,0,1)); e.preventDefault(); },{passive:false});\n\n    function setVal(v){ state[p.i]=v; render(); send(p.i, v); drawCurve(); }\n    p._set=setVal; p._render=render;\n    state[p.i]=p.def; render();\n  }\n\n  // ---- segmented shelf/bell switch (discrete) ----------------------\n  function makeSwitch(p){\n    var cell=document.createElement(\"div\"); cell.className=\"cell\";\n    var lab=document.createElement(\"div\"); lab.className=\"lab\"; lab.textContent=p.name;\n    var sw=document.createElement(\"div\"); sw.className=\"switch\"; sw.tabIndex=0;\n    var ring=document.createElement(\"div\"); ring.className=\"ring\"; sw.appendChild(ring);\n    var seg=document.createElement(\"div\"); seg.className=\"seg\";\n    var pips=[];\n    p.opts.forEach(function(o,idx){\n      var pip=document.createElement(\"span\"); pip.className=\"pip\"; pip.textContent=o;\n      pip.addEventListener(\"click\",function(ev){ ev.stopPropagation(); setVal(idx); });\n      seg.appendChild(pip); pips.push(pip);\n    });\n    sw.appendChild(seg);\n    var val=document.createElement(\"div\"); val.className=\"val\";\n    cell.appendChild(lab); cell.appendChild(sw); cell.appendChild(val);\n    deck.appendChild(cell);\n\n    function render(){\n      var v=Math.round(state[p.i]);\n      pips.forEach(function(pp,idx){ pp.classList.toggle(\"on\", idx===v); });\n      val.textContent=p.opts[v];\n    }\n    function setVal(v){ state[p.i]=v; render(); send(p.i, v); drawCurve(); }\n    sw.addEventListener(\"click\",function(){ setVal(Math.round(state[p.i])?0:1); });\n    sw.addEventListener(\"dblclick\",function(){ setVal(p.def); });\n    p._set=setVal; p._render=render;\n    state[p.i]=p.def; render();\n  }\n\n  // ---- helpers -----------------------------------------------------\n  function clamp(v,a,b){ return v<a?a:(v>b?b:v); }\n  function clientY(e){ return e.touches?e.touches[0].clientY:e.clientY; }\n  function polar(cx,cy,r,deg){ var a=(deg-90)*Math.PI/180; return [cx+r*Math.cos(a), cy+r*Math.sin(a)]; }\n  function arc(cx,cy,r,d0,d1){\n    var s=polar(cx,cy,r,d1), e=polar(cx,cy,r,d0);\n    var large=(d1-d0)<=180?0:1;\n    return \"M \"+s[0]+\" \"+s[1]+\" A \"+r+\" \"+r+\" 0 \"+large+\" 0 \"+e[0]+\" \"+e[1];\n  }\n\n  // ---- build deck --------------------------------------------------\n  PARAMS.forEach(function(p){ if(p.type===\"switch\") makeSwitch(p); else makeKnob(p); });\n\n  // ---- live response curve (the animated proportional-Q bell) ------\n  var curve=document.getElementById(\"curve\");\n  var fillP=document.getElementById(\"fill\");\n  var midDot=document.getElementById(\"midDot\");\n  var W=600,H=150,MID=75;\n\n  // map x (0..W) to log freq 20..20000\n  function xToHz(x){ return 20*Math.pow(1000, x/W); }\n  function db2y(db){ return MID - db*4.0; } // ~4px per dB, ±18dB fits\n\n  function bellGain(hz, fc, gainDb, Q){\n    // peaking biquad magnitude (RBJ) in dB at frequency hz\n    var A=Math.pow(10, gainDb/40);\n    var w=2*Math.PI*hz/48000, w0=2*Math.PI*fc/48000;\n    var cw=Math.cos(w0), sw=Math.sin(w0), alpha=sw/(2*Q);\n    var b0=1+alpha*A, b1=-2*cw, b2=1-alpha*A;\n    var a0=1+alpha/A, a1=-2*cw, a2=1-alpha/A;\n    return biquadDb(b0,b1,b2,a0,a1,a2,w);\n  }\n  function lowShelfGain(hz,fc,gainDb){\n    var A=Math.pow(10,gainDb/40), S=0.85;\n    var w=2*Math.PI*hz/48000, w0=2*Math.PI*fc/48000, cw=Math.cos(w0), sw=Math.sin(w0);\n    var alpha=sw/2*Math.sqrt((A+1/A)*(1/S-1)+2), tsa=2*Math.sqrt(A)*alpha;\n    var b0=A*((A+1)-(A-1)*cw+tsa), b1=2*A*((A-1)-(A+1)*cw), b2=A*((A+1)-(A-1)*cw-tsa);\n    var a0=(A+1)+(A-1)*cw+tsa, a1=-2*((A-1)+(A+1)*cw), a2=(A+1)+(A-1)*cw-tsa;\n    return biquadDb(b0,b1,b2,a0,a1,a2,w);\n  }\n  function highShelfGain(hz,fc,gainDb){\n    var A=Math.pow(10,gainDb/40), S=0.9;\n    var w=2*Math.PI*hz/48000, w0=2*Math.PI*fc/48000, cw=Math.cos(w0), sw=Math.sin(w0);\n    var alpha=sw/2*Math.sqrt((A+1/A)*(1/S-1)+2), tsa=2*Math.sqrt(A)*alpha;\n    var b0=A*((A+1)+(A-1)*cw+tsa), b1=-2*A*((A-1)+(A+1)*cw), b2=A*((A+1)+(A-1)*cw-tsa);\n    var a0=(A+1)-(A-1)*cw+tsa, a1=2*((A-1)-(A+1)*cw), a2=(A+1)-(A-1)*cw-tsa;\n    return biquadDb(b0,b1,b2,a0,a1,a2,w);\n  }\n  function biquadDb(b0,b1,b2,a0,a1,a2,w){\n    var cw=Math.cos(w), c2w=Math.cos(2*w), sw=Math.sin(w), s2w=Math.sin(2*w);\n    var nr=b0+b1*cw+b2*c2w, ni=-(b1*sw+b2*s2w);\n    var dr=a0+a1*cw+a2*c2w, di=-(a1*sw+a2*s2w);\n    var num=Math.sqrt(nr*nr+ni*ni), den=Math.sqrt(dr*dr+di*di);\n    return 20*Math.log10((num/den)||1e-9);\n  }\n\n  function drawCurve(){\n    var lowDb=(state[0]-0.5)*24;\n    var lowBell=Math.round(state[1])>=1;\n    var midN=state[2];\n    var midDb=(state[3]-0.5)*30;\n    var highDb=(state[4]-0.5)*27;\n    var hiBell=Math.round(state[5])>=1;\n\n    var midHz=Math.min(200*Math.exp(midN*3.555), 20000);\n    var adb=Math.abs(midDb);\n    var midQ=clamp(0.5+adb*0.18, 0.5, 4.0); // proportional-Q: widens at low boost\n\n    var d=\"\", df=\"M 0 \"+H+\" \";\n    for(var x=0;x<=W;x+=4){\n      var hz=xToHz(x);\n      var g=0;\n      if(lowBell) g+=bellGain(hz, 80*1.6, lowDb, 0.7); else g+=lowShelfGain(hz, 80, lowDb);\n      g+=bellGain(hz, midHz, midDb, midQ);\n      if(hiBell) g+=bellGain(hz, 12000*0.55, highDb, 0.7); else g+=highShelfGain(hz, 12000, highDb);\n      var y=clamp(db2y(g), 2, H-2);\n      d += (x===0?\"M \":\"L \")+x+\" \"+y+\" \";\n      df+= \"L \"+x+\" \"+y+\" \";\n    }\n    df+=\"L \"+W+\" \"+H+\" Z\";\n    curve.setAttribute(\"d\", d);\n    fillP.setAttribute(\"d\", df);\n    // mid marker dot on the curve\n    var mx=W*Math.log(midHz/20)/Math.log(1000);\n    var mg=bellGain(midHz,midHz,midDb,midQ)\n         + (lowBell?bellGain(midHz,128,lowDb,0.7):lowShelfGain(midHz,80,lowDb))\n         + (hiBell?bellGain(midHz,6600,highDb,0.7):highShelfGain(midHz,12000,highDb));\n    midDot.setAttribute(\"cx\", clamp(mx,4,W-4));\n    midDot.setAttribute(\"cy\", clamp(db2y(mg),4,H-4));\n  }\n\n  // ---- init / host ready -------------------------------------------\n  function boot(){\n    PARAMS.forEach(function(p){ send(p.i, state[p.i]); });\n    drawCurve();\n  }\n  if(host && typeof host.onReady===\"function\"){ host.onReady(boot); } else { boot(); }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  DISCRETE EQ — a punchy discrete-electronics console equaliser\n//  Three forward-sounding bands modelled on a vintage discrete-op-amp\n//  500-series console EQ:\n//    * LOW band  — switchable LOW SHELF / BELL, corner ~80 Hz\n//    * MID band  — sweepable BELL with PROPORTIONAL-Q: the bell is WIDE\n//                  at small boosts/cuts and NARROWS as you push it hard\n//                  (the signature reciprocal proportional Q)\n//    * HIGH band — switchable HIGH SHELF / BELL, corner ~12 kHz\n//  The whole strip is followed by a touch of discrete-stage DRIVE\n//  (asymmetric soft saturation) for that punchy, forward console weight.\n//  Stable RBJ biquads in Direct-Form I. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\n// ---- parameter indices (must match spec.json + the GUI) --------------\nconst P_LOW_GAIN:   i32 = 0; // 0..1 -> low band   -12..+12 dB  (corner ~80 Hz)\nconst P_LOW_SHAPE:  i32 = 1; // 0|1  -> 0 = shelf, 1 = bell        (DISCRETE)\nconst P_MID_FREQ:   i32 = 2; // 0..1 -> mid bell centre 200..7000 Hz (log)\nconst P_MID_GAIN:   i32 = 3; // 0..1 -> mid bell   -15..+15 dB  (proportional-Q)\nconst P_HIGH_GAIN:  i32 = 4; // 0..1 -> high band  -12..+15 dB  (corner ~12 kHz)\nconst P_HIGH_SHAPE: i32 = 5; // 0|1  -> 0 = shelf, 1 = bell        (DISCRETE)\nconst P_DRIVE:      i32 = 6; // 0..1 -> discrete-stage saturation amount\n\nconst PI: f32 = 3.14159265358979;\n\n// ---- per-channel Direct-Form I biquad state (x[n-1],x[n-2],y[n-1],y[n-2]) ----\n// three cascaded bands: low, mid, high\nconst loX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst loX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst loY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst loY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst mdX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst mdY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\nconst hiX1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hiX2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hiY1: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\nconst hiY2: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS);\n\n// ---- shared coefficient registers (recomputed once per process block) ----\nlet lo_b0: f32 = 1.0; let lo_b1: f32 = 0.0; let lo_b2: f32 = 0.0;\nlet lo_a1: f32 = 0.0; let lo_a2: f32 = 0.0;\nlet md_b0: f32 = 1.0; let md_b1: f32 = 0.0; let md_b2: f32 = 0.0;\nlet md_a1: f32 = 0.0; let md_a2: f32 = 0.0;\nlet hi_b0: f32 = 1.0; let hi_b1: f32 = 0.0; let hi_b2: f32 = 0.0;\nlet hi_a1: f32 = 0.0; let hi_a2: f32 = 0.0;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    loX1[c] = 0.0; loX2[c] = 0.0; loY1[c] = 0.0; loY2[c] = 0.0;\n    mdX1[c] = 0.0; mdX2[c] = 0.0; mdY1[c] = 0.0; mdY2[c] = 0.0;\n    hiX1[c] = 0.0; hiX2[c] = 0.0; hiY1[c] = 0.0; hiY2[c] = 0.0;\n  }\n  params[P_LOW_GAIN]   = 0.5;  // flat\n  params[P_LOW_SHAPE]  = 0.0;  // shelf\n  params[P_MID_FREQ]   = 0.45; // ~1 kHz region\n  params[P_MID_GAIN]   = 0.5;  // flat\n  params[P_HIGH_GAIN]  = 0.5;  // flat\n  params[P_HIGH_SHAPE] = 0.0;  // shelf\n  params[P_DRIVE]      = 0.25; // a touch of discrete weight\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n// dB -> linear amplitude\n@inline function dbToGain(db: f32): f32 {\n  return f32(Mathf.exp(db * 0.11512925)); // ln(10)/20\n}\n\n// discrete-stage asymmetric soft saturation: punchy, forward, with a touch\n// of even-harmonic colour. Bounded to roughly ±1.1 so it never runs away.\n@inline function saturate(x: f32, amt: f32): f32 {\n  const k: f32 = 1.0 + amt * 3.5;\n  const t: f32 = f32(Mathf.tanh(x * k));\n  const asym: f32 = amt * 0.12 * (t * t - 0.5); // even-harmonic asymmetry\n  const driven: f32 = (t + asym) / k;\n  return x + amt * (driven - x);\n}\n\n// ---- coefficient builders (RBJ cookbook, normalised by a0) -----------\nfunction computeLowShelf(f0: f32, dbGain: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const S: f32 = 0.85;\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / S - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) - (A - 1.0) * cw + tsa);\n  const b1: f32 =  2.0 * A * ((A - 1.0) - (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) - (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) + (A - 1.0) * cw + tsa;\n  const a1: f32 = -2.0 *    ((A - 1.0) + (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) + (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  lo_b0 = b0 * inv; lo_b1 = b1 * inv; lo_b2 = b2 * inv;\n  lo_a1 = a1 * inv; lo_a2 = a2 * inv;\n}\n\nfunction computeHighShelf(f0: f32, dbGain: f32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const S: f32 = 0.9;\n  const alpha: f32 = sw * 0.5 * f32(Mathf.sqrt((A + 1.0 / A) * (1.0 / S - 1.0) + 2.0));\n  const tsa: f32 = 2.0 * f32(Mathf.sqrt(A)) * alpha;\n\n  const b0: f32 =      A * ((A + 1.0) + (A - 1.0) * cw + tsa);\n  const b1: f32 = -2.0 * A * ((A - 1.0) + (A + 1.0) * cw);\n  const b2: f32 =      A * ((A + 1.0) + (A - 1.0) * cw - tsa);\n  const a0: f32 =           (A + 1.0) - (A - 1.0) * cw + tsa;\n  const a1: f32 =  2.0 *    ((A - 1.0) - (A + 1.0) * cw);\n  const a2: f32 =           (A + 1.0) - (A - 1.0) * cw - tsa;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  hi_b0 = b0 * inv; hi_b1 = b1 * inv; hi_b2 = b2 * inv;\n  hi_a1 = a1 * inv; hi_a2 = a2 * inv;\n}\n\n// generic peaking bell -> writes into the band selected by `band` (0=lo,1=md,2=hi)\nfunction computeBell(f0: f32, dbGain: f32, q: f32, band: i32): void {\n  const A: f32 = f32(Mathf.sqrt(dbToGain(dbGain)));\n  const w0: f32 = 2.0 * PI * f0 / sampleRate;\n  const cw: f32 = f32(Mathf.cos(w0));\n  const sw: f32 = f32(Mathf.sin(w0));\n  const alpha: f32 = sw / (2.0 * q);\n\n  const b0: f32 = 1.0 + alpha * A;\n  const b1: f32 = -2.0 * cw;\n  const b2: f32 = 1.0 - alpha * A;\n  const a0: f32 = 1.0 + alpha / A;\n  const a1: f32 = -2.0 * cw;\n  const a2: f32 = 1.0 - alpha / A;\n  const inv: f32 = a0 != 0.0 ? f32(1.0 / a0) : 1.0;\n\n  if (band == 0) {\n    lo_b0 = b0 * inv; lo_b1 = b1 * inv; lo_b2 = b2 * inv;\n    lo_a1 = a1 * inv; lo_a2 = a2 * inv;\n  } else if (band == 1) {\n    md_b0 = b0 * inv; md_b1 = b1 * inv; md_b2 = b2 * inv;\n    md_a1 = a1 * inv; md_a2 = a2 * inv;\n  } else {\n    hi_b0 = b0 * inv; hi_b1 = b1 * inv; hi_b2 = b2 * inv;\n    hi_a1 = a1 * inv; hi_a2 = a2 * inv;\n  }\n}\n\nexport function process(n: i32): void {\n  // --- map params to musical ranges -----------------------------------\n  const lowDb:   f32 = (clampf(params[P_LOW_GAIN],  0.0, 1.0) - 0.5) * 24.0;  // -12..+12\n  const lowBell: bool = clampf(params[P_LOW_SHAPE], 0.0, 1.0) >= 0.5;\n  const midN:    f32 = clampf(params[P_MID_FREQ],   0.0, 1.0);\n  const midDb:   f32 = (clampf(params[P_MID_GAIN],  0.0, 1.0) - 0.5) * 30.0;  // -15..+15\n  const highDb:  f32 = (clampf(params[P_HIGH_GAIN], 0.0, 1.0) - 0.5) * 27.0;  // -13.5..+13.5\n  const hiBell:  bool = clampf(params[P_HIGH_SHAPE], 0.0, 1.0) >= 0.5;\n  const drive:   f32 = clampf(params[P_DRIVE],      0.0, 1.0);\n\n  const nyq: f32 = sampleRate * 0.45;\n\n  // log-sweep the mid centre 200 Hz .. 7000 Hz, clamped below Nyquist\n  let midHz: f32 = f32(200.0 * Mathf.exp(midN * 3.555)); // 200 * (7000/200)^midN\n  if (midHz > nyq) midHz = nyq;\n  if (midHz < 20.0) midHz = 20.0;\n\n  // PROPORTIONAL-Q (reciprocal): WIDE bell at small gains, NARROW\n  // bell at large gains. The bandwidth shrinks ~ proportional to boost amount.\n  const adb: f32 = midDb < 0.0 ? -midDb : midDb;\n  const midQ: f32 = clampf(0.5 + adb * 0.18, 0.5, 4.0);\n\n  // band corners\n  let lowHz: f32 = 80.0;\n  let highHz: f32 = 12000.0;\n  if (highHz > nyq) highHz = nyq;\n  if (lowHz < 20.0) lowHz = 20.0;\n\n  // LOW band: shelf or wide bell (bell uses a broad, console-like Q)\n  if (lowBell) computeBell(lowHz * 1.6, lowDb, 0.7, 0);\n  else computeLowShelf(lowHz, lowDb);\n\n  // MID band: always a proportional-Q bell\n  computeBell(midHz, midDb, midQ, 1);\n\n  // HIGH band: shelf or wide bell\n  if (hiBell) computeBell(highHz * 0.55, highDb, 0.7, 2);\n  else computeHighShelf(highHz, highDb);\n\n  // output trim so heavy simultaneous boosts + drive stay <~1.0 peak\n  const outTrim: f32 = 0.82;\n\n  for (let c = 0; c < channels; c++) {\n    const base: i32 = c * MAX_FRAMES;\n\n    let ax1: f32 = loX1[c]; let ax2: f32 = loX2[c]; let ay1: f32 = loY1[c]; let ay2: f32 = loY2[c];\n    let bx1: f32 = mdX1[c]; let bx2: f32 = mdX2[c]; let by1: f32 = mdY1[c]; let by2: f32 = mdY2[c];\n    let cx1: f32 = hiX1[c]; let cx2: f32 = hiX2[c]; let cy1: f32 = hiY1[c]; let cy2: f32 = hiY2[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[base + f];\n\n      // low band\n      let y: f32 = lo_b0 * x + lo_b1 * ax1 + lo_b2 * ax2 - lo_a1 * ay1 - lo_a2 * ay2;\n      ax2 = ax1; ax1 = x; ay2 = ay1; ay1 = y;\n\n      // mid band\n      const mIn: f32 = y;\n      let ym: f32 = md_b0 * mIn + md_b1 * bx1 + md_b2 * bx2 - md_a1 * by1 - md_a2 * by2;\n      bx2 = bx1; bx1 = mIn; by2 = by1; by1 = ym;\n\n      // high band\n      const hIn: f32 = ym;\n      let yh: f32 = hi_b0 * hIn + hi_b1 * cx1 + hi_b2 * cx2 - hi_a1 * cy1 - hi_a2 * cy2;\n      cx2 = cx1; cx1 = hIn; cy2 = cy1; cy1 = yh;\n\n      // discrete-stage drive across the whole strip\n      let s: f32 = saturate(yh, drive);\n\n      outBuf[base + f] = clampf(s * outTrim, -1.2, 1.2);\n    }\n\n    loX1[c] = ax1; loX2[c] = ax2; loY1[c] = ay1; loY2[c] = ay2;\n    mdX1[c] = bx1; mdX2[c] = bx2; mdY1[c] = by1; mdY2[c] = by2;\n    hiX1[c] = cx1; hiX2[c] = cx2; hiY1[c] = cy1; hiY2[c] = cy2;\n  }\n}\n",
  "publishedAt": 1751000074000
}