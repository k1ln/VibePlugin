{
  "format": 1,
  "name": "Spring Verb",
  "isInstrument": false,
  "explanation": "An original model of a vintage spring-tank reverb. A long cascade of dispersive all-pass delays smears transients into the characteristic chirpy, twangy 'boing', wrapped in a damped feedback loop with two short comb reflections for body. Controls: Decay, Tension (dispersion/brightness), Drip (chirp amount) and dry/wet Mix.",
  "params": [
    {
      "name": "Decay",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Tension",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Drip",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.5
    },
    {
      "name": "Mix",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.35
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n/* ============================================================\n   SPRING VERB — a vintage spring-tank reverb.\n   Surf-amp tweed cabinet with a real, animated coiled-spring tank.\n   The springs wobble/boing in response to Decay, Tension, Drip.\n   ============================================================ */\n:root{\n  --ac:#4dd2a6;        /* tank accent (oxidised brass-green) */\n  --ac2:#7ee8c0;\n  --tweed:#c9a96a;     /* warm tweed weave */\n  --tweed-dk:#8a6f3e;\n  --cab:#3a2c1c;       /* cabinet wood */\n  --chrome:#cfd6dc;\n}\n*{box-sizing:border-box}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:#f3ead7;\n  display:flex;align-items:center;justify-content:center;\n  padding:18px;\n  background:\n    radial-gradient(120% 90% at 50% -10%,#2b2114 0%,#140d06 60%,#0a0603 100%);\n}\n\n/* ---- the amp cabinet ---------------------------------------------- */\n.amp{\n  position:relative;\n  width:100%;max-width:620px;\n  border-radius:18px;\n  padding:16px;\n  background:\n    linear-gradient(150deg,#4a3826,#2c2013 55%,#1d1409);\n  border:1px solid rgba(0,0,0,.6);\n  box-shadow:\n    0 34px 70px rgba(0,0,0,.65),\n    inset 0 2px 0 rgba(255,225,170,.10),\n    inset 0 0 0 2px rgba(0,0,0,.35),\n    inset 0 -18px 40px rgba(0,0,0,.45);\n}\n/* corner protectors */\n.amp::before,.amp::after{\n  content:\"\";position:absolute;width:30px;height:30px;border-radius:7px;\n  background:\n    radial-gradient(circle at 35% 30%,#e9eef2,#9aa3ab 45%,#4a5158 75%,#23282d);\n  box-shadow:0 2px 4px rgba(0,0,0,.55),inset 0 1px 1px rgba(255,255,255,.5);\n  z-index:5;\n}\n.amp::before{top:8px;left:8px}\n.amp::after{top:8px;right:8px}\n\n/* ---- header / faceplate ------------------------------------------- */\n.face{\n  position:relative;z-index:3;\n  display:flex;align-items:center;gap:12px;\n  padding:9px 16px 9px 46px;\n  margin:2px 4px 14px;\n  border-radius:11px;\n  background:linear-gradient(180deg,#1a120a,#0d0904);\n  border:1px solid rgba(255,210,150,.14);\n  box-shadow:inset 0 1px 0 rgba(255,220,170,.12),inset 0 -8px 16px rgba(0,0,0,.5);\n}\n.pilot{\n  position:absolute;left:16px;top:50%;transform:translateY(-50%);\n  width:16px;height:16px;border-radius:50%;\n  background:radial-gradient(circle at 40% 35%,#fff3c0,#ff8a3c 40%,#b53a10 80%);\n  box-shadow:0 0 14px #ff7a2c,0 0 3px #fff inset,0 0 30px rgba(255,120,40,.5);\n  animation:glow 3.4s ease-in-out infinite;\n}\n@keyframes glow{0%,100%{filter:brightness(.85)}50%{filter:brightness(1.35)}}\n.brand{flex:1;display:flex;flex-direction:column;line-height:1}\n.brand b{\n  font-size:20px;letter-spacing:.16em;font-weight:900;font-style:italic;\n  background:linear-gradient(180deg,#ffe9b0,#caa05a 60%,#7a5a28);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 1px 0 rgba(0,0,0,.4);\n}\n.brand small{\n  font-size:9px;letter-spacing:.42em;color:#9d7e4e;text-transform:uppercase;margin-top:4px;\n}\n.plate{\n  font-size:8.5px;letter-spacing:.2em;text-transform:uppercase;color:#0e0a05;\n  background:linear-gradient(180deg,#d9b772,#a07e3e);\n  border:1px solid #5e4622;border-radius:5px;padding:5px 9px;font-weight:800;\n  box-shadow:inset 0 1px 0 rgba(255,255,255,.5),0 1px 2px rgba(0,0,0,.5);\n}\n\n/* ---- the spring tank window --------------------------------------- */\n.tank{\n  position:relative;z-index:2;\n  margin:0 4px 16px;\n  height:176px;\n  border-radius:12px;\n  overflow:hidden;\n  background:\n    radial-gradient(140% 120% at 50% 0%,#10171a,#070b0d 70%);\n  border:1px solid rgba(120,232,192,.16);\n  box-shadow:\n    inset 0 2px 18px rgba(0,0,0,.85),\n    inset 0 0 0 1px rgba(0,0,0,.6),\n    0 0 0 4px rgba(0,0,0,.4);\n}\n/* mesh grille over the tank */\n.tank .mesh{\n  position:absolute;inset:0;pointer-events:none;z-index:4;opacity:.5;\n  background-image:\n    repeating-linear-gradient(45deg,rgba(0,0,0,.35) 0 1px,transparent 1px 5px),\n    repeating-linear-gradient(-45deg,rgba(0,0,0,.35) 0 1px,transparent 1px 5px);\n  -webkit-mask:radial-gradient(120% 120% at 50% 50%,#000 60%,transparent 100%);\n  mask:radial-gradient(120% 120% at 50% 50%,#000 60%,transparent 100%);\n}\n/* sweep of light passing the tank as it resonates */\n.tank .sheen{\n  position:absolute;top:-30%;left:-30%;width:60%;height:160%;z-index:3;\n  pointer-events:none;\n  background:linear-gradient(105deg,transparent,rgba(126,232,192,.10),transparent);\n  filter:blur(6px);\n  animation:sheen 7s linear infinite;\n}\n@keyframes sheen{0%{transform:translateX(-40%)}100%{transform:translateX(240%)}}\nsvg{position:absolute;inset:0;width:100%;height:100%;z-index:2;display:block}\n.post{ /* the end posts the springs anchor to */\n  position:absolute;top:0;bottom:0;width:14px;z-index:3;\n  background:linear-gradient(90deg,#1a1f22,#39434a 50%,#11161a);\n  box-shadow:inset 0 0 6px rgba(0,0,0,.8);\n}\n.post.l{left:0;border-right:1px solid rgba(126,232,192,.25)}\n.post.r{right:0;border-left:1px solid rgba(126,232,192,.25)}\n.boing{\n  position:absolute;right:24px;bottom:8px;z-index:5;\n  font-size:9px;letter-spacing:.3em;text-transform:uppercase;\n  color:var(--ac2);opacity:.7;pointer-events:none;\n  text-shadow:0 0 8px rgba(126,232,192,.6);\n}\n\n/* ---- knob row ----------------------------------------------------- */\n.row{\n  position:relative;z-index:2;\n  display:grid;grid-template-columns:repeat(4,1fr);gap:6px;\n  margin:0 4px;\n}\n.ctl{\n  display:flex;flex-direction:column;align-items:center;gap:8px;\n  padding:12px 4px 12px;border-radius:12px;\n  background:linear-gradient(180deg,rgba(255,225,170,.05),rgba(0,0,0,.18));\n  border:1px solid rgba(255,210,150,.10);\n  box-shadow:inset 0 1px 0 rgba(255,225,170,.10);\n  animation:rise .55s both;\n}\n.ctl:nth-child(1){animation-delay:.05s}\n.ctl:nth-child(2){animation-delay:.13s}\n.ctl:nth-child(3){animation-delay:.21s}\n.ctl:nth-child(4){animation-delay:.29s}\n@keyframes rise{from{opacity:0;transform:translateY(14px) scale(.94)}to{opacity:1;transform:none}}\n\n/* chicken-head amp knob */\n.knob{\n  position:relative;width:78px;height:78px;cursor:ns-resize;\n  user-select:none;touch-action:none;\n}\n.skirt{ /* numbered skirt + active arc */\n  position:absolute;inset:-2px;border-radius:50%;\n  background:\n    conic-gradient(from 215deg,\n      var(--ac) calc(var(--n,0)*290deg),\n      rgba(255,220,170,.10) calc(var(--n,0)*290deg) 290deg,\n      transparent 290deg);\n  -webkit-mask:radial-gradient(circle,transparent 35px,#000 36px,#000 40px,transparent 41px);\n  mask:radial-gradient(circle,transparent 35px,#000 36px,#000 40px,transparent 41px);\n  filter:drop-shadow(0 0 calc(2px + var(--n,0)*8px) color-mix(in srgb,var(--ac) 70%,transparent));\n  transition:--n .12s cubic-bezier(.2,.8,.25,1);\n}\n.ticks{\n  position:absolute;inset:-2px;border-radius:50%;\n  background:repeating-conic-gradient(from 215deg,\n     rgba(255,225,180,.35) 0 1.4deg,transparent 1.4deg 29deg);\n  -webkit-mask:radial-gradient(circle,transparent 41px,#000 42px,#000 45px,transparent 46px);\n  mask:radial-gradient(circle,transparent 41px,#000 42px,#000 45px,transparent 46px);\n}\n.body{\n  position:absolute;inset:12px;border-radius:50%;\n  background:\n    radial-gradient(circle at 42% 28%,#5a4226,#2a1d0e 70%,#160e05);\n  box-shadow:\n    inset 0 2px 6px rgba(255,225,170,.18),\n    inset 0 -4px 10px rgba(0,0,0,.7),\n    0 3px 6px rgba(0,0,0,.55);\n}\n/* the chicken-head pointer */\n.beak{\n  position:absolute;top:50%;left:50%;width:30px;height:9px;\n  transform-origin:6px 50%;\n  transform:translate(0,-50%) rotate(calc((var(--n,0) - .5) * 290deg));\n  transition:transform .12s cubic-bezier(.2,.8,.25,1);\n}\n.beak::before{\n  content:\"\";position:absolute;left:0;top:0;width:0;height:0;\n  border-top:4.5px solid transparent;border-bottom:4.5px solid transparent;\n  border-left:30px solid #1a1208;\n}\n.beak::after{ /* highlight ridge on the beak */\n  content:\"\";position:absolute;left:2px;top:50%;transform:translateY(-50%);\n  width:24px;height:2px;border-radius:2px;\n  background:linear-gradient(90deg,#caa05a,transparent);opacity:.8;\n}\n.cap{ /* center hub */\n  position:absolute;top:50%;left:50%;width:13px;height:13px;border-radius:50%;\n  transform:translate(-50%,-50%);\n  background:radial-gradient(circle at 40% 35%,#e8d29a,#6e5226 70%);\n  box-shadow:0 0 4px rgba(0,0,0,.6),inset 0 1px 1px rgba(255,255,255,.6);\n}\n.bub{\n  position:absolute;top:-12px;left:50%;\n  transform:translate(-50%,5px) scale(.8);opacity:0;pointer-events:none;\n  font-size:11px;font-weight:800;color:#0a0603;background:var(--ac);\n  padding:2px 7px;border-radius:6px;font-variant-numeric:tabular-nums;\n  box-shadow:0 4px 12px rgba(0,0,0,.5);transition:.15s;z-index:6;\n}\n.knob.act .bub,.ctl:hover .bub{opacity:1;transform:translate(-50%,0) scale(1)}\n\n.lbl{\n  font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;\n  color:#e7cf9a;font-weight:700;text-shadow:0 1px 0 rgba(0,0,0,.5);\n}\n.num{\n  font-size:13px;font-weight:800;color:#fff;font-variant-numeric:tabular-nums;\n  text-shadow:0 0 8px rgba(126,232,192,.4);\n}\n.ctl:nth-child(4) .num{color:var(--ac2)}\n</style>\n</head>\n<body>\n  <div class=\"amp\">\n    <div class=\"face\">\n      <span class=\"pilot\"></span>\n      <div class=\"brand\"><b>SPRING&nbsp;VERB</b><small>Reverberation Tank · Mk II</small></div>\n      <span class=\"plate\">2-Spring · Drip</span>\n    </div>\n\n    <div class=\"tank\">\n      <span class=\"post l\"></span>\n      <span class=\"post r\"></span>\n      <span class=\"sheen\"></span>\n      <svg viewBox=\"0 0 600 176\" preserveAspectRatio=\"none\" id=\"svg\">\n        <defs>\n          <linearGradient id=\"wire\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n            <stop offset=\"0\" stop-color=\"#eafff6\"/>\n            <stop offset=\".5\" stop-color=\"#4dd2a6\"/>\n            <stop offset=\"1\" stop-color=\"#1c5a45\"/>\n          </linearGradient>\n          <filter id=\"soft\"><feGaussianBlur stdDeviation=\"1.1\"/></filter>\n        </defs>\n        <!-- two coiled springs, paths rebuilt every frame in JS -->\n        <path id=\"sp0\" fill=\"none\" stroke=\"url(#wire)\" stroke-width=\"2.4\" stroke-linecap=\"round\" filter=\"url(#soft)\" opacity=\".95\"/>\n        <path id=\"sp1\" fill=\"none\" stroke=\"url(#wire)\" stroke-width=\"2.0\" stroke-linecap=\"round\" filter=\"url(#soft)\" opacity=\".8\"/>\n      </svg>\n      <span class=\"mesh\"></span>\n      <span class=\"boing\" id=\"boing\">boing</span>\n    </div>\n\n    <div class=\"row\" id=\"row\"></div>\n  </div>\n\n<!-- Single source of truth: mirrors spec.json \"params\" verbatim so the GUI\n     can never silently drift from the DSP. Edit spec.json + repack and this\n     block is the only place the names/defaults live in the GUI. -->\n<script type=\"application/json\" id=\"spec-params\">\n[\n  { \"name\": \"Decay\",   \"index\": 0, \"min\": 0, \"max\": 1, \"default\": 0.55 },\n  { \"name\": \"Tension\", \"index\": 1, \"min\": 0, \"max\": 1, \"default\": 0.5  },\n  { \"name\": \"Drip\",    \"index\": 2, \"min\": 0, \"max\": 1, \"default\": 0.5  },\n  { \"name\": \"Mix\",     \"index\": 3, \"min\": 0, \"max\": 1, \"default\": 0.35 }\n]\n</script>\n\n<script>\n(function(){\n  /* ---- params (read from the embedded spec island, never duplicated) --\n     spec order is Decay(0), Tension(1), Drip(2), Mix(3) — all [0,1].\n     Parsing from #spec-params means a spec.json edit (which the packer\n     mirrors into that block) can't drift from the GUI's knobs/animation. */\n  var SPEC=[];\n  try{ SPEC=JSON.parse(document.getElementById('spec-params').textContent)||[]; }catch(e){ SPEC=[]; }\n  var PARAMS=SPEC.map(function(p){\n    return {i:p.index,name:p.name,min:+p.min,max:+p.max,def:+p[\"default\"]};\n  });\n  /* live values keyed by param index, seeded from the spec defaults */\n  var state={};\n  PARAMS.forEach(function(p){ state[p.i]=p.def; });\n\n  function fmt(v){return (Math.round(v*100))+\"%\";}\n\n  /* ---- build knobs -------------------------------------------------- */\n  var row=document.getElementById('row');\n  PARAMS.forEach(function(p){\n    var ctl=document.createElement('div');ctl.className='ctl';\n    ctl.innerHTML=\n      '<div class=\"knob\" tabindex=\"0\">'+\n        '<i class=\"ticks\"></i><i class=\"skirt\"></i>'+\n        '<i class=\"body\"></i><i class=\"beak\"></i><i class=\"cap\"></i>'+\n        '<span class=\"bub\"></span>'+\n      '</div>'+\n      '<div class=\"lbl\">'+p.name+'</div>'+\n      '<div class=\"num\"></div>';\n    row.appendChild(ctl);\n\n    var knob=ctl.querySelector('.knob'),\n        skirt=ctl.querySelector('.skirt'),\n        beak=ctl.querySelector('.beak'),\n        num=ctl.querySelector('.num'),\n        bub=ctl.querySelector('.bub');\n    var val=p.def;\n    function norm(){return (val-p.min)/(p.max-p.min||1);}\n    function paint(){\n      var n=norm();\n      skirt.style.setProperty('--n',n);\n      beak.style.setProperty('--n',n);\n      var t=fmt(n);num.textContent=t;bub.textContent=t;\n      state[p.i]=val;\n      if(window.vstai&&window.vstai.setParam)window.vstai.setParam(p.i,val);\n    }\n    function setN(n){n=n<0?0:n>1?1:n;val=p.min+(p.max-p.min)*n;paint();}\n    knob.addEventListener('pointerdown',function(e){\n      knob._d=1;knob._y=e.clientY;knob._n=norm();knob.classList.add('act');\n      knob.setPointerCapture(e.pointerId);e.preventDefault();});\n    knob.addEventListener('pointermove',function(e){\n      if(!knob._d)return;setN(knob._n+(knob._y-e.clientY)/200);});\n    function end(){knob._d=0;knob.classList.remove('act');}\n    knob.addEventListener('pointerup',end);\n    knob.addEventListener('pointercancel',end);\n    knob.addEventListener('dblclick',function(){val=p.def;paint();});\n    knob.addEventListener('wheel',function(e){\n      e.preventDefault();setN(norm()+(e.deltaY<0?0.02:-0.02));},{passive:false});\n    knob.addEventListener('keydown',function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){setN(norm()+0.02);e.preventDefault();}\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){setN(norm()-0.02);e.preventDefault();}});\n    paint();\n  });\n\n  /* ---- animated coiled springs ------------------------------------- */\n  var sp=[document.getElementById('sp0'),document.getElementById('sp1')];\n  var boing=document.getElementById('boing');\n  var W=600,H=176;\n  var t0=performance.now();\n  /* per-spring phase so they wobble out of sync */\n  var cfg=[{y:H*0.40,coils:26,rad:13,ph:0},\n           {y:H*0.66,coils:20,rad:10,ph:1.7}];\n\n  function build(now){\n    var t=(now-t0)/1000;\n    var decay=state[0], tension=state[1], drip=state[2], mix=state[3];\n\n    /* Tension -> tighter, brighter coils + faster boing;\n       Decay   -> longer-lasting, larger swaying amplitude;\n       Drip    -> chirpy ripple travelling along the spring;\n       Mix     -> overall visible intensity (opacity).            */\n    var sway = 4 + decay*16;              // vertical sway amplitude\n    var speed = 1.2 + tension*3.4;        // oscillation speed\n    var ripAmp = drip*9;                  // chirp ripple amplitude\n    var ripFreq = 5 + tension*9;          // ripple density\n\n    /* envelope: a slowly pulsing \"ping\" that decays then re-pings,\n       so the tank looks alive even when nothing is touched.        */\n    var pingT = t % (1.6 - decay*0.7 + 0.4);\n    var env = Math.exp(-pingT*(4.5 - decay*3.2));\n\n    for(var s=0;s<2;s++){\n      var c=cfg[s], left=18, right=W-18, span=right-left;\n      var coils=Math.round(c.coils*(0.7+tension*0.6));\n      var d=\"M \"+left+\" \"+c.y+\" \";\n      var N=Math.max(60,coils*8);\n      for(var k=0;k<=N;k++){\n        var u=k/N;\n        var x=left+span*u;\n        /* coil spiral (projected) */\n        var ang=u*coils*Math.PI*2 + c.ph + t*speed;\n        var coilY=Math.sin(ang)*c.rad*(0.7+tension*0.5);\n        /* travelling drip ripple (the chirp) */\n        var rip=Math.sin(u*ripFreq*Math.PI - t*(6+drip*10)+c.ph)*ripAmp*env;\n        /* global sway of the whole spring (the boing) */\n        var bow=Math.sin(u*Math.PI)*Math.sin(t*speed*1.3+c.ph)*sway*env;\n        var y=c.y + coilY + rip + bow;\n        d+=(k?\"L \":\"\")+x.toFixed(1)+\" \"+y.toFixed(1)+\" \";\n      }\n      sp[s].setAttribute('d',d);\n      sp[s].style.opacity=(0.35+mix*0.6*(0.5+0.5*env)).toFixed(3);\n      sp[s].style.strokeWidth=((s?2.0:2.4)*(0.8+tension*0.5)).toFixed(2);\n    }\n    /* boing label flashes on each ping */\n    boing.style.opacity=(0.25+env*0.7*(0.4+mix)).toFixed(2);\n    requestAnimationFrame(build);\n  }\n  requestAnimationFrame(build);\n\n  /* ---- host ready --------------------------------------------------- */\n  function ready(){ /* knobs already initialised to defaults above */ }\n  if(window.vstai&&window.vstai.onReady)window.vstai.onReady(ready);else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SPRING VERB — original model of a 2/3-spring reverb tank\n//  The \"boing\": a long cascade of dispersive all-pass delays makes high\n//  frequencies travel faster than lows along the spring, so a transient\n//  smears into the characteristic chirpy \"drip\". That dispersive line is\n//  wrapped in a damped feedback loop (the springs' multiple reflections)\n//  plus two short comb taps for body, with gentle HF damping in the tail.\n//  Controls: Decay (tail length), Tension (dispersion / brightness),\n//  Drip (chirp / excitation amount), Mix. Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst TWO_PI: f32 = 6.2831855;\n\n// ---- dispersive all-pass chain (the \"spring\") ----------------------\n// A long cascade of short all-pass delays. Per-stage frequency-dependent\n// delay is what produces the chirp; we run it independently per channel.\nconst NAP: i32 = 10;          // stages of dispersion\nconst AP_CAP: i32 = 512;      // max samples per stage\nconst apBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NAP * AP_CAP);\nconst apPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NAP);\nconst apLen: StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apBase: StaticArray<i32> = new StaticArray<i32>(NAP); // base lengths @48k\n\n// ---- main spring feedback delay (the tank length) ------------------\nconst SPRING_CAP: i32 = 8192;\nconst springBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * SPRING_CAP);\nconst springPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS);\n\n// ---- two short comb reflections for body ---------------------------\nconst COMB_CAP: i32 = 4096;\nconst NCOMB: i32 = 2;\nconst combBuf: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS * NCOMB * COMB_CAP);\nconst combPos: StaticArray<i32> = new StaticArray<i32>(MAX_CHANNELS * NCOMB);\nconst combLen: StaticArray<i32> = new StaticArray<i32>(NCOMB);\nconst combBase: StaticArray<i32> = new StaticArray<i32>(NCOMB);\n\n// per-channel state\nconst dampState: StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // tail HF damping\nconst dcState:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker LP\nconst dcPrev:    StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // DC blocker prev in\nconst preEmph:   StaticArray<f32> = new StaticArray<f32>(MAX_CHANNELS); // input HP state\n\nconst P_DECAY:   i32 = 0;  // tail length\nconst P_TENSION: i32 = 1;  // dispersion / brightness\nconst P_DRIP:    i32 = 2;  // chirp / excitation amount\nconst P_MIX:     i32 = 3;  // dry/wet\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  // Mutually-prime-ish short all-pass lengths give a dense, chirpy\n  // dispersion without a fixed pitched ring.\n  apBase[0] = 71;  apBase[1] = 89;  apBase[2] = 113; apBase[3] = 131;\n  apBase[4] = 157; apBase[5] = 173; apBase[6] = 199; apBase[7] = 223;\n  apBase[8] = 251; apBase[9] = 277;\n\n  combBase[0] = 1117; combBase[1] = 1583;\n\n  for (let i = 0; i < NAP; i++) apLen[i] = apBase[i];\n  for (let i = 0; i < NCOMB; i++) combLen[i] = combBase[i];\n\n  for (let i = 0; i < MAX_CHANNELS * NAP; i++) apPos[i] = 0;\n  for (let i = 0; i < MAX_CHANNELS * NCOMB; i++) combPos[i] = 0;\n  for (let c = 0; c < MAX_CHANNELS; c++) {\n    springPos[c] = 0; dampState[c] = 0.0; dcState[c] = 0.0;\n    dcPrev[c] = 0.0; preEmph[c] = 0.0;\n  }\n  for (let i = 0; i < MAX_CHANNELS * NAP * AP_CAP; i++) apBuf[i] = 0.0;\n  for (let i = 0; i < MAX_CHANNELS * SPRING_CAP; i++) springBuf[i] = 0.0;\n  for (let i = 0; i < MAX_CHANNELS * NCOMB * COMB_CAP; i++) combBuf[i] = 0.0;\n\n  params[P_DECAY] = 0.55; params[P_TENSION] = 0.5;\n  params[P_DRIP] = 0.5;   params[P_MIX] = 0.35;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 4; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n// One dispersive all-pass stage for channel c, stage i, coefficient g.\n@inline function apStage(c: i32, i: i32, x: f32, g: f32): f32 {\n  const slot: i32 = c * NAP + i;\n  const base: i32 = slot * AP_CAP;\n  let p: i32 = apPos[slot];\n  const buffered: f32 = apBuf[base + p];\n  const y: f32 = -g * x + buffered;\n  apBuf[base + p] = x + g * y;\n  p++; if (p >= apLen[i]) p = 0;\n  apPos[slot] = p;\n  return y;\n}\n\nexport function process(n: i32): void {\n  const decay:   f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const tension: f32 = clampf(params[P_TENSION], 0.0, 1.0);\n  const drip:    f32 = clampf(params[P_DRIP], 0.0, 1.0);\n  const mix:     f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  const srRatio: f32 = sampleRate / 48000.0;\n\n  // Tension scales the dispersive all-pass coefficient and shortens the\n  // springs (tighter spring -> brighter, faster chirp).\n  const apG: f32 = 0.55 + tension * 0.4;            // 0.55..0.95\n  const apScale: f32 = 1.25 - tension * 0.55;       // longer (boingier) when slack\n\n  // spring loop length & comb lengths scale with tension/sr\n  let springLen: i32 = i32(f32(2400) * apScale * srRatio);\n  if (springLen < 64) springLen = 64;\n  if (springLen >= SPRING_CAP - 4) springLen = SPRING_CAP - 4;\n\n  for (let i = 0; i < NAP; i++) {\n    let L: i32 = i32(f32(apBase[i]) * apScale * srRatio);\n    if (L < 2) L = 2; if (L >= AP_CAP) L = AP_CAP - 1;\n    apLen[i] = L;\n  }\n  for (let i = 0; i < NCOMB; i++) {\n    let L: i32 = i32(f32(combBase[i]) * apScale * srRatio);\n    if (L < 2) L = 2; if (L >= COMB_CAP) L = COMB_CAP - 1;\n    combLen[i] = L;\n  }\n\n  // Decay -> feedback gain of the spring loop. Kept comfortably < 1 so the\n  // LINEAR loop is stable on its own (no reliance on the saturator). The\n  // round trip is: all-pass chain (unity gain) * combMix (<=1) * fb, so fb\n  // is the hard cap on loop gain and must stay below 1.\n  const fb: f32 = clampf(0.45 + decay * 0.47, 0.0, 0.92);     // 0.45..0.92\n  const combFb: f32 = clampf(0.10 + decay * 0.45, 0.0, 0.6);  // 0.10..0.55\n\n  // HF damping in the tail: brighter (more tension) -> less damping.\n  const dampCoef: f32 = clampf(0.12 + (1.0 - tension) * 0.55, 0.0, 0.95);\n\n  // Drip = how much we drive the dispersive chain (chirp/excitation).\n  const driveAmt: f32 = 0.5 + drip * 1.4;           // 0.5..1.9\n  // Drip also adds a touch of input pre-emphasis (sharper transient -> more chirp)\n  const emphAmt: f32 = drip * 0.85;\n\n  const outScale: f32 = 0.6;\n\n  for (let c = 0; c < channels; c++) {\n    const inBase: i32 = c * MAX_FRAMES;\n    const sBase: i32 = c * SPRING_CAP;\n    let sp: i32 = springPos[c];\n    let dmp: f32 = dampState[c];\n    let dcs: f32 = dcState[c];\n    let dcp: f32 = dcPrev[c];\n    let emp: f32 = preEmph[c];\n\n    for (let f = 0; f < n; f++) {\n      const x: f32 = inBuf[inBase + f];\n\n      // pre-emphasis: high-pass-ish transient boost driven by Drip\n      const hp: f32 = x - emp;\n      emp = emp + 0.6 * hp;\n      const exc: f32 = (x + emphAmt * hp) * driveAmt;\n\n      // read spring loop (one tank length behind write)\n      let rp: i32 = sp - springLen;\n      if (rp < 0) rp += SPRING_CAP;\n      const tap: f32 = springBuf[sBase + rp];\n\n      // damp the recirculating tail (one-pole LP)\n      dmp = dmp + dampCoef * (tap - dmp);\n\n      // excite the dispersive chain with input + damped feedback\n      let v: f32 = exc + dmp * fb;\n\n      // cascade of dispersive all-pass stages -> the chirpy \"boing\"\n      v = apStage(c, 0, v, apG);\n      v = apStage(c, 1, v, apG);\n      v = apStage(c, 2, v, apG);\n      v = apStage(c, 3, v, apG);\n      v = apStage(c, 4, v, apG);\n      v = apStage(c, 5, v, apG);\n      v = apStage(c, 6, v, apG);\n      v = apStage(c, 7, v, apG);\n      v = apStage(c, 8, v, apG);\n      v = apStage(c, 9, v, apG);\n\n      // two short comb reflections for body / multiple spring coupling.\n      // Each comb is its own stable recirculation (combFb < 1) fed by v.\n      // We BLEND the comb body into v (normalized convex mix) instead of\n      // ADDING it on top, so this stage never increases the loop's energy:\n      //   v <- (1-combMix)*v + combMix*(avg comb output)\n      // worst-case stage gain is therefore <= 1.\n      let combSum: f32 = 0.0;\n      for (let k = 0; k < NCOMB; k++) {\n        const cslot: i32 = c * NCOMB + k;\n        const cbase: i32 = cslot * COMB_CAP;\n        const cp: i32 = combPos[cslot];\n        const cTap: f32 = combBuf[cbase + cp];\n        combBuf[cbase + cp] = v + cTap * combFb;\n        let np: i32 = cp + 1; if (np >= combLen[k]) np = 0;\n        combPos[cslot] = np;\n        combSum += cTap;\n      }\n      // average the comb taps, then normalize by the comb's own steady-state\n      // gain (1/(1-combFb)) so the blended body stays at roughly unit level.\n      const combBody: f32 = combSum * (0.5 * (1.0 - combFb));\n      const combMix: f32 = 0.22;\n      v = (1.0 - combMix) * v + combMix * combBody;\n\n      // soft saturation keeps the loop bounded (\"spring overload\" character)\n      if (v > 1.2) v = 1.2; else if (v < -1.2) v = -1.2;\n      v = v - 0.18 * v * v * v;\n\n      // DC blocker before re-injecting into the loop\n      const dcOut: f32 = v - dcp + 0.9995 * dcs;\n      dcp = v; dcs = dcOut;\n\n      // write back into the spring loop\n      springBuf[sBase + sp] = dcOut;\n      sp++; if (sp >= SPRING_CAP) sp = 0;\n\n      const wet: f32 = dcOut * outScale;\n      outBuf[inBase + f] = x * (1.0 - mix) + wet * mix;\n    }\n\n    dampState[c] = dmp; dcState[c] = dcs; dcPrev[c] = dcp;\n    preEmph[c] = emp; springPos[c] = sp;\n  }\n\n  // mirror mono input to a silent second channel if host is mono-in/stereo-out\n  if (channels < 2) {\n    for (let f = 0; f < n; f++) outBuf[MAX_FRAMES + f] = outBuf[f];\n  }\n}\n",
  "publishedAt": 1751000014000
}