{"format":1,"name":"Warm Lowpass","isInstrument":false,"explanation":"A gentle one-pole low-pass with output gain. Feed it one of the royalty-free samples, a test tone, your mic, or your own file to hear it work.","params":[{"name":"Gain","index":0,"min":0,"max":2,"default":1},{"name":"Cutoff","index":1,"min":0,"max":1,"default":1}],"wasmBase64":"","html":"<!doctype html><html><head><meta charset=\"utf-8\"><style>\n    body{margin:0;font:14px ui-sans-serif,system-ui,sans-serif;background:#0b0e14;color:#e7eef6;\n      display:flex;flex-direction:column;gap:18px;padding:26px 28px}\n    h1{font-size:16px;margin:0 0 6px;letter-spacing:.04em;color:#ffb454}\n    label{display:flex;flex-direction:column;gap:6px;font-size:13px;color:#aeb9cc}\n    label span{color:#e7eef6;font-variant-numeric:tabular-nums}\n    input[type=range]{width:100%;accent-color:#ffb454}\n  </style></head><body>\n    <h1>Warm Lowpass</h1>\n    <label>Gain<span id=\"v0\"></span>\n      <input type=\"range\" data-i=\"0\" min=\"0\" max=\"2\" step=\"0.001\" value=\"1\">\n    </label>\n    <label>Cutoff<span id=\"v1\"></span>\n      <input type=\"range\" data-i=\"1\" min=\"0\" max=\"1\" step=\"0.001\" value=\"1\">\n    </label>\n    <script>\n      function ready(){\n        document.querySelectorAll('input[type=range]').forEach(function(r){\n          var i=+r.dataset.i, out=document.getElementById('v'+i);\n          function send(){ out.textContent=(+r.value).toFixed(2); window.vstai.setParam(i,+r.value); }\n          r.addEventListener('input',send); send();\n        });\n      }\n      if(window.vstai&&window.vstai.onReady) window.vstai.onReady(ready); else ready();\n    </script>\n  </body></html>","publishedAt":1750000001000}