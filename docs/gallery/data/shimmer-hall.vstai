{
  "format": 1,
  "name": "Shimmer Hall",
  "isInstrument": false,
  "explanation": "Bright, modulated digital hall reverb. An 8-line feedback delay network whose read taps are modulated by per-line LFOs (interpolated fractional delays) to dissolve metallic ringing into a lush, chorused tail. A Tone control trades a dark, damped decay for open high-frequency air. Controls: Mix, Size, Decay, Tone, Modulation depth and Pre-Delay.",
  "params": [
    {
      "name": "Mix",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.3
    },
    {
      "name": "Size",
      "index": 1,
      "min": 0.3,
      "max": 1,
      "default": 0.8
    },
    {
      "name": "Decay",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "Tone",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Modulation",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Pre-Delay",
      "index": 5,
      "min": 0,
      "max": 0.12,
      "default": 0.015
    }
  ],
  "wasmBase64": "",
  "html": "<!doctype html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width,initial-scale=1\">\n<style>\n:root{\n  --ac:#b08cff;\n  --ac2:#ff8cf0;\n  --glass:rgba(255,255,255,.06);\n}\n*{box-sizing:border-box;-webkit-user-select:none;user-select:none}\nhtml,body{height:100%}\nbody{\n  margin:0;\n  font:13px/1.4 ui-sans-serif,system-ui,-apple-system,\"Segoe UI\",sans-serif;\n  color:#eaf0fb;\n  background:#04060d;\n  overflow:hidden;\n}\n\n/* ---- night-sky stage ---- */\n.sky{\n  position:fixed;inset:0;\n  background:\n    radial-gradient(120% 80% at 50% 120%, #0a1430 0%, #060a18 45%, #03040b 100%);\n  overflow:hidden;\n}\n/* faint stars */\n.stars{position:absolute;inset:0;opacity:.8;\n  background-image:\n    radial-gradient(1px 1px at 12% 22%, #fff, transparent),\n    radial-gradient(1px 1px at 28% 64%, #cfe, transparent),\n    radial-gradient(1px 1px at 47% 18%, #fff, transparent),\n    radial-gradient(1px 1px at 63% 72%, #def, transparent),\n    radial-gradient(1px 1px at 78% 33%, #fff, transparent),\n    radial-gradient(1.4px 1.4px at 88% 58%, #fff, transparent),\n    radial-gradient(1px 1px at 8% 80%, #cdf, transparent),\n    radial-gradient(1px 1px at 38% 88%, #fff, transparent),\n    radial-gradient(1px 1px at 70% 12%, #fff, transparent),\n    radial-gradient(1px 1px at 92% 84%, #bdf, transparent);\n  animation:twinkle 6s ease-in-out infinite;\n}\n@keyframes twinkle{0%,100%{opacity:.55}50%{opacity:.95}}\n\n/* ---- aurora curtains (SVG, animated) ---- */\n.aurora{position:absolute;left:-10%;right:-10%;top:-15%;height:78%;width:120%;\n  filter:blur(2px);opacity:.92;mix-blend-mode:screen}\n.aurora svg{width:100%;height:100%}\n.curtain{transform-origin:50% 0;}\n.c1{animation:sway1 13s ease-in-out infinite}\n.c2{animation:sway2 17s ease-in-out infinite}\n.c3{animation:sway3 21s ease-in-out infinite}\n@keyframes sway1{0%,100%{transform:translateX(-3%) skewX(-4deg) scaleY(1)}50%{transform:translateX(4%) skewX(5deg) scaleY(1.08)}}\n@keyframes sway2{0%,100%{transform:translateX(3%) skewX(4deg) scaleY(1.05)}50%{transform:translateX(-4%) skewX(-5deg) scaleY(.95)}}\n@keyframes sway3{0%,100%{transform:translateX(-2%) skewX(-2deg) scaleY(.97)}50%{transform:translateX(5%) skewX(6deg) scaleY(1.1)}}\n/* shimmer bands that travel up the curtains */\n@keyframes glow{0%,100%{opacity:.35}50%{opacity:1}}\n\n/* ground reflection / horizon haze */\n.haze{position:absolute;left:0;right:0;bottom:0;height:46%;\n  background:linear-gradient(to top, rgba(176,140,255,.10), transparent);\n  pointer-events:none}\n\n/* ---- main glass console ---- */\n.wrap{position:relative;z-index:5;height:100%;display:flex;flex-direction:column;\n  align-items:center;justify-content:center;padding:18px}\n\n.console{\n  position:relative;width:100%;max-width:640px;border-radius:26px;padding:20px 22px 22px;\n  background:linear-gradient(160deg, rgba(28,34,58,.46), rgba(8,12,26,.62));\n  border:1px solid rgba(255,255,255,.12);\n  backdrop-filter:blur(14px) saturate(1.3);\n  -webkit-backdrop-filter:blur(14px) saturate(1.3);\n  box-shadow:\n    0 40px 90px rgba(0,0,0,.6),\n    inset 0 1px 0 rgba(255,255,255,.18),\n    inset 0 0 60px rgba(176,140,255,.05);\n}\n/* top sheen */\n.console::before{content:\"\";position:absolute;inset:0;border-radius:26px;pointer-events:none;\n  background:linear-gradient(180deg, rgba(255,255,255,.10), transparent 26%)}\n\n.head{display:flex;align-items:center;gap:13px;margin-bottom:4px}\n.orb{position:relative;width:15px;height:15px;border-radius:50%;flex:none;\n  background:radial-gradient(circle at 38% 32%, #fff, var(--ac) 55%, var(--ac2) 100%);\n  box-shadow:0 0 14px var(--ac),0 0 28px var(--ac2);\n  animation:breathe 4s ease-in-out infinite}\n@keyframes breathe{0%,100%{box-shadow:0 0 10px var(--ac),0 0 18px var(--ac2);transform:scale(.92)}\n  50%{box-shadow:0 0 20px var(--ac),0 0 40px var(--ac2);transform:scale(1.06)}}\n.title{flex:1;min-width:0}\n.title h1{margin:0;font-size:20px;font-weight:800;letter-spacing:.10em;line-height:1;\n  background:linear-gradient(95deg, #fff 0%, var(--ac) 45%, var(--ac2) 100%);\n  -webkit-background-clip:text;background-clip:text;color:transparent;\n  text-shadow:0 0 30px rgba(176,140,255,.25)}\n.title .sub{margin-top:5px;font-size:9.5px;letter-spacing:.34em;text-transform:uppercase;color:#8ea0c8}\n.tag{font-size:9px;letter-spacing:.2em;text-transform:uppercase;color:#aeb9d8;\n  border:1px solid rgba(255,255,255,.16);border-radius:999px;padding:4px 11px;white-space:nowrap;\n  background:rgba(255,255,255,.04)}\n\n.grid{margin-top:18px;display:grid;grid-template-columns:repeat(3,1fr);gap:14px 12px}\n\n/* ---- bespoke aurora knobs ---- */\n.cell{position:relative;display:flex;flex-direction:column;align-items:center;gap:9px;\n  padding:14px 6px 12px;border-radius:18px;\n  background:linear-gradient(165deg, rgba(255,255,255,.045), rgba(255,255,255,.012));\n  border:1px solid rgba(255,255,255,.07);\n  transition:transform .22s cubic-bezier(.2,.8,.2,1), border-color .22s, box-shadow .22s;\n  animation:rise .6s both;animation-delay:var(--d)}\n@keyframes rise{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}\n.cell:hover{transform:translateY(-4px);border-color:color-mix(in srgb,var(--ac) 50%,transparent);\n  box-shadow:0 16px 40px rgba(0,0,0,.45),0 0 30px color-mix(in srgb,var(--ac) 22%,transparent)}\n\n.dial{position:relative;width:96px;height:96px;cursor:grab;touch-action:none}\n.dial.drag{cursor:grabbing}\n.dial svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible}\n\n/* outer tick ring */\n.ring-bg{fill:none;stroke:rgba(255,255,255,.08);stroke-width:5}\n.ring-fg{fill:none;stroke:var(--ac);stroke-width:5;stroke-linecap:round;\n  filter:drop-shadow(0 0 4px var(--ac));transition:stroke-dashoffset .12s linear}\n\n/* glass cap */\n.cap{transition:filter .2s}\n.dial:hover .cap{filter:brightness(1.12)}\n\n/* shimmer sweep over the cap when active */\n.sweep{opacity:0;transition:opacity .2s}\n.dial.drag .sweep,.dial:hover .sweep{opacity:1;animation:sweep 1.8s linear infinite}\n@keyframes sweep{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}\n\n.nm{font-size:10px;letter-spacing:.16em;text-transform:uppercase;color:#9fb0d4;text-align:center}\n.val{font-size:14px;font-weight:800;font-variant-numeric:tabular-nums;\n  color:#fff;text-shadow:0 0 12px color-mix(in srgb,var(--ac) 70%,transparent);min-height:17px}\n.unit{font-size:9px;font-weight:600;color:#8ea0c8;margin-left:2px}\n\n.foot{margin-top:16px;font-size:10.5px;line-height:1.6;color:#7e8db0;\n  border-top:1px solid rgba(255,255,255,.07);padding-top:12px;letter-spacing:.01em}\n\n@media (max-width:520px){.grid{grid-template-columns:repeat(2,1fr)}}\n</style>\n</head>\n<body>\n<div class=\"sky\">\n  <div class=\"stars\"></div>\n  <div class=\"aurora\">\n    <svg viewBox=\"0 0 800 600\" preserveAspectRatio=\"none\">\n      <defs>\n        <linearGradient id=\"au1\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#b08cff\" stop-opacity=\"0\"/>\n          <stop offset=\"35%\" stop-color=\"#b08cff\" stop-opacity=\".55\"/>\n          <stop offset=\"100%\" stop-color=\"#7affd6\" stop-opacity=\".05\"/>\n        </linearGradient>\n        <linearGradient id=\"au2\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#ff8cf0\" stop-opacity=\"0\"/>\n          <stop offset=\"40%\" stop-color=\"#ff8cf0\" stop-opacity=\".5\"/>\n          <stop offset=\"100%\" stop-color=\"#b08cff\" stop-opacity=\".04\"/>\n        </linearGradient>\n        <linearGradient id=\"au3\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n          <stop offset=\"0%\" stop-color=\"#8affd6\" stop-opacity=\"0\"/>\n          <stop offset=\"45%\" stop-color=\"#9fa8ff\" stop-opacity=\".42\"/>\n          <stop offset=\"100%\" stop-color=\"#ff8cf0\" stop-opacity=\".04\"/>\n        </linearGradient>\n      </defs>\n      <g class=\"curtain c1\" style=\"animation:sway1 13s ease-in-out infinite,glow 7s ease-in-out infinite\">\n        <path d=\"M0,0 C120,180 60,360 160,540 L300,540 C220,340 280,170 200,0 Z\" fill=\"url(#au1)\"/>\n      </g>\n      <g class=\"curtain c2\" style=\"animation:sway2 17s ease-in-out infinite,glow 9s ease-in-out infinite .8s\">\n        <path d=\"M260,0 C400,160 320,380 440,560 L600,560 C500,360 560,180 460,0 Z\" fill=\"url(#au2)\"/>\n      </g>\n      <g class=\"curtain c3\" style=\"animation:sway3 21s ease-in-out infinite,glow 11s ease-in-out infinite 1.6s\">\n        <path d=\"M520,0 C660,200 600,380 700,560 L800,560 C740,360 800,170 720,0 Z\" fill=\"url(#au3)\"/>\n      </g>\n    </svg>\n  </div>\n  <div class=\"haze\"></div>\n</div>\n\n<div class=\"wrap\">\n  <div class=\"console\">\n    <div class=\"head\">\n      <span class=\"orb\"></span>\n      <div class=\"title\">\n        <h1>SHIMMER HALL</h1>\n        <div class=\"sub\">Aurora Reverb</div>\n      </div>\n      <span class=\"tag\">6 voices of light</span>\n    </div>\n\n    <div class=\"grid\" id=\"grid\"></div>\n\n    <div class=\"foot\">Bright, modulated digital hall — an 8-line feedback delay network whose\n      taps drift on slow LFOs, dissolving metallic ring into a chorused, shimmering tail.</div>\n  </div>\n</div>\n\n<!-- ===================================================================\n     PARAM SOURCE OF TRUTH — mirrors spec.json \"params\" verbatim\n     (name/index/min/max/default). This is the SAME shape spec.json uses,\n     so it is byte-checkable against it and cannot silently drift to a\n     different schema. Display hints (unit/format) are a separate, purely\n     cosmetic map keyed by index below. Edit spec.json -> mirror here.\n==================================================================== -->\n<script type=\"application/json\" id=\"vstai-params\">\n[\n  { \"name\": \"Mix\",        \"index\": 0, \"min\": 0,   \"max\": 1,    \"default\": 0.3 },\n  { \"name\": \"Size\",       \"index\": 1, \"min\": 0.3, \"max\": 1,    \"default\": 0.8 },\n  { \"name\": \"Decay\",      \"index\": 2, \"min\": 0,   \"max\": 1,    \"default\": 0.65 },\n  { \"name\": \"Tone\",       \"index\": 3, \"min\": 0,   \"max\": 1,    \"default\": 0.7 },\n  { \"name\": \"Modulation\", \"index\": 4, \"min\": 0,   \"max\": 1,    \"default\": 0.4 },\n  { \"name\": \"Pre-Delay\",  \"index\": 5, \"min\": 0,   \"max\": 0.12, \"default\": 0.015 }\n]\n</script>\n\n<script>\n(function(){\n  // ---- params parsed from the embedded JSON (mirrors spec.json) ----------\n  // Reading from a JSON block instead of a hand-written JS array keeps the\n  // canonical metadata in spec.json's exact schema, so a divergence is an\n  // obvious diff rather than a subtle code change. Per-index display hints\n  // (units / formatter) live in DISPLAY and are cosmetic only.\n  var DISPLAY = {\n    0: {unit:\"%\",  fmt:\"pct\"},   // Mix\n    1: {unit:\"\",   fmt:\"num\"},   // Size\n    2: {unit:\"%\",  fmt:\"pct\"},   // Decay\n    3: {unit:\"\",   fmt:\"num\"},   // Tone\n    4: {unit:\"%\",  fmt:\"pct\"},   // Modulation\n    5: {unit:\"ms\", fmt:\"ms\"}     // Pre-Delay\n  };\n  var SPEC = JSON.parse(document.getElementById('vstai-params').textContent);\n  var PARAMS = SPEC.map(function(p){\n    var d = DISPLAY[p.index] || {unit:\"\", fmt:\"num\"};\n    return { name:p.name, index:p.index, min:p.min, max:p.max, def:p[\"default\"],\n             unit:d.unit, fmt:d.fmt };\n  });\n\n  var SWEEP = 270;          // degrees of travel\n  var START = -135;         // degrees from top (12 o'clock = 0)\n  var R = 38;               // arc radius\n  var grid = document.getElementById('grid');\n\n  function fmt(p, v){\n    if(p.fmt===\"pct\") return Math.round(v*100) + \"\";\n    if(p.fmt===\"ms\")  return (v*1000).toFixed(0);\n    return v.toFixed(2);\n  }\n\n  function makeCell(p, i){\n    var cell = document.createElement('div');\n    cell.className = 'cell';\n    cell.style.setProperty('--d', (i*70)+'ms');\n    cell.innerHTML =\n      '<div class=\"dial\" tabindex=\"0\">'+\n        '<svg viewBox=\"0 0 96 96\">'+\n          '<defs>'+\n            '<linearGradient id=\"stroke'+i+'\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\">'+\n              '<stop offset=\"0%\" stop-color=\"var(--ac)\"/>'+\n              '<stop offset=\"100%\" stop-color=\"var(--ac2)\"/>'+\n            '</linearGradient>'+\n            '<radialGradient id=\"cap'+i+'\" cx=\"42%\" cy=\"34%\" r=\"72%\">'+\n              '<stop offset=\"0%\" stop-color=\"#3a3f63\"/>'+\n              '<stop offset=\"62%\" stop-color=\"#161a33\"/>'+\n              '<stop offset=\"100%\" stop-color=\"#080b1a\"/>'+\n            '</radialGradient>'+\n            '<radialGradient id=\"swp'+i+'\" cx=\"50%\" cy=\"14%\" r=\"60%\">'+\n              '<stop offset=\"0%\" stop-color=\"#ffffff\" stop-opacity=\".55\"/>'+\n              '<stop offset=\"55%\" stop-color=\"var(--ac2)\" stop-opacity=\".18\"/>'+\n              '<stop offset=\"100%\" stop-color=\"#ffffff\" stop-opacity=\"0\"/>'+\n            '</radialGradient>'+\n          '</defs>'+\n          // tick ring background arc\n          '<path class=\"ring-bg\" d=\"'+arcPath(48,48,R,START,START+SWEEP)+'\"/>'+\n          // value arc\n          '<path class=\"ring-fg\" d=\"'+arcPath(48,48,R,START,START+SWEEP)+'\" '+\n              'stroke=\"url(#stroke'+i+')\" pathLength=\"100\" '+\n              'stroke-dasharray=\"100\" stroke-dashoffset=\"100\"/>'+\n          // glass cap\n          '<circle class=\"cap\" cx=\"48\" cy=\"48\" r=\"27\" fill=\"url(#cap'+i+')\" '+\n              'stroke=\"rgba(255,255,255,.10)\" stroke-width=\"1\"/>'+\n          // shimmer sweep group (rotates)\n          '<g class=\"sweep\" style=\"transform-origin:48px 48px\">'+\n            '<circle cx=\"48\" cy=\"48\" r=\"26\" fill=\"url(#swp'+i+')\"/>'+\n          '</g>'+\n          // pointer\n          '<line class=\"ptr\" x1=\"48\" y1=\"48\" x2=\"48\" y2=\"27\" '+\n              'stroke=\"#fff\" stroke-width=\"2.4\" stroke-linecap=\"round\" '+\n              'style=\"filter:drop-shadow(0 0 5px var(--ac))\"/>'+\n          '<circle cx=\"48\" cy=\"48\" r=\"3\" fill=\"#fff\" style=\"filter:drop-shadow(0 0 4px var(--ac))\"/>'+\n        '</svg>'+\n      '</div>'+\n      '<div class=\"nm\">'+p.name+'</div>'+\n      '<div class=\"val\"><span class=\"v\"></span><span class=\"unit\">'+p.unit+'</span></div>';\n    grid.appendChild(cell);\n\n    var dial = cell.querySelector('.dial');\n    var fg   = cell.querySelector('.ring-fg');\n    var ptr  = cell.querySelector('.ptr');\n    var vEl  = cell.querySelector('.v');\n\n    var val = p.def;\n    function norm(){ var n=(val-p.min)/(p.max-p.min); return n<0?0:(n>1?1:n); }\n    function send(){ if(window.vstai && window.vstai.setParam) window.vstai.setParam(p.index, val); }\n    function paint(){\n      var n = norm();\n      // pathLength=100 normalises THIS arc's length to 100, so offset is just (1-n)*100\n      fg.setAttribute('stroke-dashoffset', (100*(1-n)).toFixed(2));\n      ptr.setAttribute('transform','rotate('+(START+SWEEP*n)+' 48 48)');\n      vEl.textContent = fmt(p, val);\n    }\n    function setNorm(n){ n=n<0?0:(n>1?1:n); val=p.min+(p.max-p.min)*n; paint(); send(); }\n\n    // --- pointer drag (vertical) ---\n    var dragY=0, dragN=0, dragging=false;\n    dial.addEventListener('pointerdown', function(e){\n      dragging=true; dragY=e.clientY; dragN=norm(); dial.classList.add('drag');\n      dial.setPointerCapture(e.pointerId); e.preventDefault();\n    });\n    dial.addEventListener('pointermove', function(e){\n      if(!dragging) return;\n      var dy = dragY - e.clientY;\n      var speed = e.shiftKey ? 600 : 200;   // hold shift for fine control\n      setNorm(dragN + dy/speed);\n    });\n    function end(){ dragging=false; dial.classList.remove('drag'); }\n    dial.addEventListener('pointerup', end);\n    dial.addEventListener('pointercancel', end);\n    dial.addEventListener('lostpointercapture', end);\n    dial.addEventListener('dblclick', function(){ val=p.def; paint(); send(); });\n    dial.addEventListener('wheel', function(e){\n      e.preventDefault();\n      setNorm(norm() + (e.deltaY<0?1:-1)*0.025);\n    }, {passive:false});\n    dial.addEventListener('keydown', function(e){\n      if(e.key==='ArrowUp'||e.key==='ArrowRight'){ setNorm(norm()+0.02); e.preventDefault(); }\n      else if(e.key==='ArrowDown'||e.key==='ArrowLeft'){ setNorm(norm()-0.02); e.preventDefault(); }\n    });\n\n    // init at default\n    paint(); send();\n  }\n\n  // SVG arc path helper (start/end in degrees, 0 = top, clockwise)\n  function arcPath(cx, cy, r, a0, a1){\n    var p0 = pt(cx,cy,r,a0), p1 = pt(cx,cy,r,a1);\n    var large = (a1-a0) > 180 ? 1 : 0;\n    return \"M\"+p0.x+\",\"+p0.y+\" A\"+r+\",\"+r+\" 0 \"+large+\" 1 \"+p1.x+\",\"+p1.y;\n  }\n  function pt(cx, cy, r, deg){\n    var rad = (deg-90)*Math.PI/180;\n    return { x:(cx+r*Math.cos(rad)).toFixed(2), y:(cy+r*Math.sin(rad)).toFixed(2) };\n  }\n\n  function ready(){\n    PARAMS.forEach(makeCell);\n  }\n  if(window.vstai && window.vstai.onReady) window.vstai.onReady(ready);\n  else ready();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SHIMMER HALL — bright, modulated digital hall reverb\n//  Same FDN backbone as a classic hall, but the delay-line read taps are\n//  modulated by per-line LFOs (fractional, interpolated) to break up\n//  metallic ringing and give the lush \"chorused\" tail of bright 1980s\n//  high-end studio halls. A Tone control trades darkness for air.\n//  Pure algorithm, no samples.\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet channels: i32 = 2;\n\nconst NLINES: i32 = 8;\nconst LINE_CAP: i32 = 16384;\nconst lines: StaticArray<f32> = new StaticArray<f32>(NLINES * LINE_CAP);\nconst linePos: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineLen: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst lineGain: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst damp: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst lfoPh: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst lfoInc: StaticArray<f32> = new StaticArray<f32>(NLINES);\nconst baseLen: StaticArray<i32> = new StaticArray<i32>(NLINES);\nconst outs: StaticArray<f32> = new StaticArray<f32>(NLINES);\n\nconst NAP: i32 = 4;\nconst AP_CAP: i32 = 2048;\nconst ap: StaticArray<f32> = new StaticArray<f32>(NAP * AP_CAP);\nconst apPos: StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apLen: StaticArray<i32> = new StaticArray<i32>(NAP);\nconst apBase: StaticArray<i32> = new StaticArray<i32>(NAP);\n\nconst PRE_CAP: i32 = 32768;\nconst preBuf: StaticArray<f32> = new StaticArray<f32>(PRE_CAP);\nlet prePos: i32 = 0;\n\nconst TWO_PI: f32 = 6.2831855;\n\nconst P_MIX: i32 = 0;\nconst P_SIZE: i32 = 1;\nconst P_DECAY: i32 = 2;\nconst P_TONE: i32 = 3;    // 0 dark .. 1 bright\nconst P_MOD: i32 = 4;     // 0..1 tail modulation depth\nconst P_PRE: i32 = 5;     // 0..0.12 s\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  channels = numChannels < MAX_CHANNELS ? numChannels : MAX_CHANNELS;\n\n  baseLen[0] = 887;  baseLen[1] = 1153; baseLen[2] = 1373; baseLen[3] = 1789;\n  baseLen[4] = 1993; baseLen[5] = 2143; baseLen[6] = 2477; baseLen[7] = 2917;\n  apBase[0] = 167; apBase[1] = 353; apBase[2] = 113; apBase[3] = 293;\n\n  for (let i = 0; i < NLINES; i++) {\n    linePos[i] = 0; damp[i] = 0.0; lineLen[i] = baseLen[i]; lineGain[i] = 0.0;\n    lfoPh[i] = f32(i) * 0.37;\n    lfoInc[i] = (0.4 + f32(i) * 0.13) * TWO_PI / sampleRate;  // 0.4..1.3 Hz\n  }\n  for (let i = 0; i < NAP; i++) { apPos[i] = 0; apLen[i] = apBase[i]; }\n  for (let i = 0; i < NLINES * LINE_CAP; i++) lines[i] = 0.0;\n  for (let i = 0; i < NAP * AP_CAP; i++) ap[i] = 0.0;\n  for (let i = 0; i < PRE_CAP; i++) preBuf[i] = 0.0;\n  prePos = 0;\n\n  params[P_MIX] = 0.30; params[P_SIZE] = 0.80; params[P_DECAY] = 0.65;\n  params[P_TONE] = 0.70; params[P_MOD] = 0.40; params[P_PRE] = 0.015;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 6; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\n@inline function allpass(i: i32, x: f32): f32 {\n  const base: i32 = i * AP_CAP;\n  let p: i32 = apPos[i];\n  const buffered: f32 = ap[base + p];\n  const y: f32 = buffered - x;\n  ap[base + p] = x + buffered * 0.5;\n  p++; if (p >= apLen[i]) p = 0;\n  apPos[i] = p;\n  return y;\n}\n\n// fractional, interpolated read from a line's ring buffer, `d` samples behind write\n@inline function readFrac(line: i32, d: f32): f32 {\n  const base: i32 = line * LINE_CAP;\n  const wp: i32 = linePos[line];\n  let di: i32 = i32(d);\n  const fr: f32 = d - f32(di);\n  let a: i32 = wp - di; while (a < 0) a += LINE_CAP; if (a >= LINE_CAP) a -= LINE_CAP;\n  let b: i32 = a - 1; if (b < 0) b += LINE_CAP;\n  return lines[base + a] * (1.0 - fr) + lines[base + b] * fr;\n}\n\nexport function process(n: i32): void {\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n  const size: f32 = clampf(params[P_SIZE], 0.3, 1.0);\n  const decay: f32 = clampf(params[P_DECAY], 0.0, 1.0);\n  const tone: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const modAmt: f32 = clampf(params[P_MOD], 0.0, 1.0);\n  const preSec: f32 = clampf(params[P_PRE], 0.0, 0.12);\n\n  const srRatio: f32 = sampleRate / 48000.0;\n  const rt60: f32 = 0.3 + decay * decay * 13.7;\n  const ln1000: f32 = 6.9077553;\n\n  for (let i = 0; i < NLINES; i++) {\n    let L: i32 = i32(f32(baseLen[i]) * size * srRatio);\n    if (L < 8) L = 8; if (L >= LINE_CAP - 4) L = LINE_CAP - 4;\n    lineLen[i] = L;\n    const tSec: f32 = f32(L) / sampleRate;\n    lineGain[i] = f32(Mathf.exp(-ln1000 * tSec / rt60));\n  }\n  for (let i = 0; i < NAP; i++) {\n    let L: i32 = i32(f32(apBase[i]) * srRatio);\n    if (L < 1) L = 1; if (L >= AP_CAP) L = AP_CAP - 1;\n    apLen[i] = L;\n  }\n\n  let preLen: i32 = i32(preSec * sampleRate);\n  if (preLen < 1) preLen = 1; if (preLen >= PRE_CAP) preLen = PRE_CAP - 1;\n\n  // brighter Tone -> less damping; modulation depth in samples\n  const dcoef: f32 = clampf(0.05 + (1.0 - tone) * 0.9, 0.0, 0.98);\n  const modDepth: f32 = modAmt * 22.0 * srRatio;\n  const outScale: f32 = 0.30;\n\n  for (let f = 0; f < n; f++) {\n    const l: f32 = inBuf[f];\n    const r: f32 = channels > 1 ? inBuf[MAX_FRAMES + f] : l;\n    let send: f32 = (l + r) * 0.5;\n\n    const rp: i32 = (prePos - preLen + PRE_CAP) % PRE_CAP;\n    preBuf[prePos] = send;\n    send = preBuf[rp];\n    prePos++; if (prePos >= PRE_CAP) prePos = 0;\n\n    send = allpass(0, send);\n    send = allpass(1, send);\n    send = allpass(2, send);\n    send = allpass(3, send);\n\n    for (let i = 0; i < NLINES; i++) {\n      let ph: f32 = lfoPh[i] + lfoInc[i];\n      if (ph >= TWO_PI) ph -= TWO_PI;\n      lfoPh[i] = ph;\n      const d: f32 = f32(lineLen[i]) + modDepth * Mathf.sin(ph);\n      let v: f32 = readFrac(i, d);\n      const dd: f32 = damp[i] + dcoef * (v - damp[i]);\n      damp[i] = dd;\n      outs[i] = dd;\n    }\n\n    let sum: f32 = 0.0;\n    for (let i = 0; i < NLINES; i++) sum += outs[i];\n    const corr: f32 = (2.0 / f32(NLINES)) * sum;\n\n    for (let i = 0; i < NLINES; i++) {\n      const base: i32 = i * LINE_CAP;\n      const inj: f32 = ((i & 1) == 0 ? send : -send) * 0.30;\n      const fb: f32 = (outs[i] - corr) * lineGain[i];\n      lines[base + linePos[i]] = inj + fb;\n      linePos[i]++; if (linePos[i] >= LINE_CAP) linePos[i] = 0;\n    }\n\n    const wetL: f32 = (outs[0] - outs[2] + outs[4] - outs[6]) * outScale;\n    const wetR: f32 = (outs[1] - outs[3] + outs[5] - outs[7]) * outScale;\n\n    outBuf[f] = l * (1.0 - mix) + wetL * mix;\n    outBuf[MAX_FRAMES + f] = r * (1.0 - mix) + wetR * mix;\n  }\n}\n",
  "publishedAt": 1751000002000
}