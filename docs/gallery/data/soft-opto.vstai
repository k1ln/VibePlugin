  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Soft Opto</title>\n<style>\n  :root{ --acc:#ffcf6a; --acc2:#e0d0b0; --bg0:#0d0a06; --bg1:#1d160c; --ink:#f5ecda; --dim:#a99467; }\n  *{ box-sizing:border-box; margin:0; padding:0; } html,body{ height:100%; }\n  body{ font-family:\"Inter\",system-ui,-apple-system,\"Segoe UI\",sans-serif;\n    background:radial-gradient(120% 90% at 50% -10%,#2c2113 0%,var(--bg1) 44%,var(--bg0) 100%);\n    color:var(--ink); overflow:hidden; user-select:none; -webkit-user-select:none; display:flex; align-items:center; justify-content:center; min-height:100%; }\n  .unit{ width:min(94vw,700px); border-radius:14px; padding:16px 22px 20px; position:relative; overflow:hidden;\n    background:linear-gradient(160deg,#2a2013,#0e0a06); border:1px solid rgba(255,207,106,.2); box-shadow:0 22px 64px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,235,200,.07); }\n  header{ display:flex; align-items:center; gap:12px; margin-bottom:12px; }\n  .logo{ font-weight:800; letter-spacing:.16em; font-size:20px; background:linear-gradient(90deg,var(--acc),var(--acc2)); -webkit-background-clip:text; background-clip:text; color:transparent; }\n  .sub{ font-size:10px; letter-spacing:.3em; text-transform:uppercase; color:var(--dim); }\n  .led{ margin-left:auto; width:9px; height:9px; border-radius:50%; background:var(--acc); box-shadow:0 0 10px var(--acc); animation:pulse 2.6s ease-in-out infinite; }\n  @keyframes pulse{ 0%,100%{ opacity:.4; transform:scale(.85);} 50%{ opacity:1; transform:scale(1.2);} }\n  .meter{ height:92px; border-radius:10px; overflow:hidden; margin-bottom:14px; position:relative; background:radial-gradient(circle at 50% 120%,#3a2c14,#160f06); border:1px solid rgba(255,207,106,.18); box-shadow:inset 0 2px 18px rgba(0,0,0,.5); }\n  canvas{ position:absolute; inset:0; width:100%; height:100%; display:block; }\n  .ml{ position:absolute; left:12px; top:8px; font-size:9px; letter-spacing:.24em; color:var(--dim); z-index:2; }\n  .knobs{ display:grid; grid-template-columns:repeat(5,1fr); gap:8px; }\n  .knob{ display:flex; flex-direction:column; align-items:center; gap:6px; padding:4px 1px; cursor:ns-resize; touch-action:none; }\n  .dial{ width:74px; height:74px; position:relative; } .dial svg{ width:100%; height:100%; display:block; overflow:visible; }\n  .track{ fill:none; stroke:rgba(255,210,160,.14); stroke-width:7; stroke-linecap:round; }\n  .arc{ fill:none; stroke:url(#g); stroke-width:7; stroke-linecap:round; filter:drop-shadow(0 0 5px rgba(255,207,106,.6)); }\n  .pcap{ fill:#160f06; stroke:rgba(255,207,106,.22); stroke-width:1; }\n  .ptr{ stroke:var(--acc); stroke-width:3; stroke-linecap:round; filter:drop-shadow(0 0 4px var(--acc)); }\n  .kn{ font-size:9px; letter-spacing:.13em; text-transform:uppercase; color:var(--dim); }\n  .kv{ font-size:11px; font-variant-numeric:tabular-nums; color:var(--ink); background:rgba(255,207,106,.1); padding:1px 8px; border-radius:7px; border:1px solid rgba(255,207,106,.2); }\n  .knob:hover .kn{ color:var(--acc); }\n</style>\n</head>\n<body>\n  <div class=\"unit\">\n    <header><span class=\"logo\">SOFT&nbsp;OPTO</span><span class=\"sub\">optical leveler</span><span class=\"led\"></span></header>\n    <div class=\"meter\"><div class=\"ml\">GAIN REDUCTION</div><canvas id=\"cv\"></canvas></div>\n    <div class=\"knobs\" id=\"knobs\"></div>\n  </div>\n<script>\n(function(){\n  \"use strict\";\n  var P=[{name:\"Threshold\",idx:0,def:0.45},{name:\"Ratio\",idx:1,def:0.5},{name:\"Makeup\",idx:2,def:0.55},{name:\"Tone\",idx:3,def:0.5},{name:\"Mix\",idx:4,def:1.0}];\n  var vals={}; P.forEach(function(p){ vals[p.idx]=p.def; });\n  var host=null; function send(i,v){ try{ if(host&&host.setParam) host.setParam(i,v); }catch(e){} }\n  var R=33, C=2*Math.PI*R, A0=-135, A1=135;\n  var kw=document.getElementById(\"knobs\");\n  var knobs=P.map(function(p){\n    var el=document.createElement(\"div\"); el.className=\"knob\";\n    el.innerHTML='<div class=\"dial\"><svg viewBox=\"0 0 86 86\"><defs><linearGradient id=\"g\" x1=\"0\" y1=\"0\" x2=\"1\" y2=\"1\"><stop offset=\"0\" stop-color=\"#ffcf6a\"/><stop offset=\"1\" stop-color=\"#e0d0b0\"/></linearGradient></defs>'+\n      '<circle class=\"track\" cx=\"43\" cy=\"43\" r=\"33\"></circle><circle class=\"arc\" cx=\"43\" cy=\"43\" r=\"33\" transform=\"rotate(135 43 43)\" stroke-dasharray=\"'+C+'\" stroke-dashoffset=\"'+C+'\"></circle>'+\n      '<circle class=\"pcap\" cx=\"43\" cy=\"43\" r=\"21\"></circle><line class=\"ptr\" x1=\"43\" y1=\"43\" x2=\"43\" y2=\"26\"></line></svg></div><span class=\"kn\">'+p.name+'</span><span class=\"kv\"></span>';\n    kw.appendChild(el);\n    var arc=el.querySelector(\".arc\"), ptr=el.querySelector(\".ptr\"), val=el.querySelector(\".kv\");\n    function render(v){ var sweep=(A1-A0)/360; arc.setAttribute(\"stroke-dashoffset\",(C*(1-sweep*v)).toString());\n      var ang=(A0+(A1-A0)*v)*Math.PI/180; ptr.setAttribute(\"x2\",(43+Math.sin(ang)*17).toFixed(2)); ptr.setAttribute(\"y2\",(43-Math.cos(ang)*17).toFixed(2)); val.textContent=Math.round(v*100)+\"%\"; }\n    var drag=null;\n    el.addEventListener(\"pointerdown\",function(e){ drag={y:e.clientY,v:vals[p.idx]}; el.setPointerCapture(e.pointerId); e.preventDefault(); });\n    el.addEventListener(\"pointermove\",function(e){ if(!drag)return; var nv=Math.max(0,Math.min(1,drag.v+(drag.y-e.clientY)/170)); vals[p.idx]=nv; render(nv); send(p.idx,nv); });\n    el.addEventListener(\"pointerup\",function(){ drag=null; }); el.addEventListener(\"pointercancel\",function(){ drag=null; });\n    el.addEventListener(\"dblclick\",function(){ vals[p.idx]=p.def; render(p.def); send(p.idx,p.def); });\n    render(p.def); return {render:render};\n  });\n  // swinging VU-style gain-reduction needle (driven by Threshold/Ratio + a fake program env)\n  var cv=document.getElementById(\"cv\"), ctx=cv.getContext(\"2d\"), W=0,H=0,DPR=Math.min(2,window.devicePixelRatio||1);\n  function resize(){ var r=cv.getBoundingClientRect(); W=r.width; H=r.height; cv.width=W*DPR; cv.height=H*DPR; ctx.setTransform(DPR,0,0,DPR,0,0); }\n  window.addEventListener(\"resize\",resize); resize();\n  var needle=0;\n  function frame(ts){ ctx.clearRect(0,0,W,H); var thr=vals[0], ratio=vals[1];\n    var prog=0.5+0.5*Math.sin(ts/500)+0.2*Math.sin(ts/170);\n    var grAmt=Math.max(0,(prog-(1-thr))) * (0.3+ratio*0.7); // 0..~1 reduction\n    needle += (grAmt - needle)*0.08;\n    var cx=W/2, cy=H+8;\n    // arc scale\n    ctx.strokeStyle=\"rgba(255,207,106,0.18)\"; ctx.lineWidth=1.5; ctx.beginPath(); ctx.arc(cx,cy,H*0.78,Math.PI*1.15,Math.PI*1.85); ctx.stroke();\n    // needle (more GR = swings left)\n    var ang=Math.PI*1.5 + (needle-0.5)* -0.6;\n    ctx.strokeStyle=\"rgba(255,207,106,0.95)\"; ctx.lineWidth=2.5; ctx.shadowColor=\"#ffcf6a\"; ctx.shadowBlur=8;\n    ctx.beginPath(); ctx.moveTo(cx,cy); ctx.lineTo(cx+Math.cos(ang)*H*0.72, cy+Math.sin(ang)*H*0.72); ctx.stroke(); ctx.shadowBlur=0;\n    ctx.fillStyle=\"rgba(255,207,106,0.6)\"; ctx.beginPath(); ctx.arc(cx,cy,3,0,Math.PI*2); ctx.fill();\n    requestAnimationFrame(frame); }\n  requestAnimationFrame(frame);\n  function boot(){ host=window.vstai||null; P.forEach(function(p,i){ send(p.idx,vals[p.idx]); knobs[i].render(vals[p.idx]); }); }\n  if(window.vstai&&window.vstai.onReady){ try{ window.vstai.onReady(boot); }catch(e){ boot(); } } else boot();\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  SOFT OPTO — a smooth optical leveling amplifier (generic opto-comp\n//  model). A slow photocell-style detector gives gentle, program-dependent\n//  gain reduction with a soft knee and a touch of warmth; gentler and\n//  slower than the factory's other compressors. Controls: Threshold,\n//  Ratio, Makeup, Tone (post tilt), Mix. No host imports, no allocation in\n//  process().\n// =====================================================================\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nlet sampleRate: f32 = 48000.0;\nlet env: f32 = 0.0;        // linked opto detector\nlet gr: f32 = 1.0;         // smoothed gain\nlet tiltL: f32 = 0.0; let tiltR: f32 = 0.0;\n\nconst P_THRESH: i32 = 0; const P_RATIO: i32 = 1; const P_MAKEUP: i32 = 2; const P_TONE: i32 = 3; const P_MIX: i32 = 4;\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 { return x < lo ? lo : (x > hi ? hi : x); }\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  env = 0.0; gr = 1.0; tiltL = 0.0; tiltR = 0.0;\n  params[P_THRESH] = 0.5; params[P_RATIO] = 0.5; params[P_MAKEUP] = 0.5; params[P_TONE] = 0.5; params[P_MIX] = 1.0;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 5; }\n\nexport function process(n: i32): void {\n  const threshN: f32 = clampf(params[P_THRESH], 0.0, 1.0);\n  const ratioN: f32 = clampf(params[P_RATIO], 0.0, 1.0);\n  const makeupN: f32 = clampf(params[P_MAKEUP], 0.0, 1.0);\n  const toneN: f32 = clampf(params[P_TONE], 0.0, 1.0);\n  const mix: f32 = clampf(params[P_MIX], 0.0, 1.0);\n\n  // threshold ~ -36..0 dB (linear), ratio 1.2:1 .. 8:1\n  const thr: f32 = f32(Mathf.exp((threshN - 1.0) * 4.0));   // 0.018 .. 1.0\n  const ratio: f32 = 1.2 + ratioN * 6.8;\n  const slope: f32 = 1.0 - 1.0 / ratio;\n  // opto-style smoothing (slow, program-dependent)\n  const atk: f32 = f32(Mathf.exp(-1.0 / (0.008 * sampleRate)));\n  const rel: f32 = f32(Mathf.exp(-1.0 / (0.18 * sampleRate)));\n  const makeup: f32 = 0.6 + makeupN * 1.7;\n  const tilt: f32 = (toneN - 0.5) * 1.4;\n  const tco: f32 = 0.2;\n  const dry: f32 = 1.0 - mix;\n  const stereo: i32 = 1;\n\n  for (let i = 0; i < n; i++) {\n    const xl: f32 = inBuf[i];\n    const xr: f32 = stereo ? inBuf[MAX_FRAMES + i] : xl;\n    const det: f32 = (xl < 0.0 ? -xl : xl) + (xr < 0.0 ? -xr : xr);\n    // smooth detector\n    env = det > env ? env * atk + det * (1.0 - atk) : env * rel + det * (1.0 - rel);\n    // soft-knee gain reduction (work in a gentle log-ish domain)\n    let target: f32 = 1.0;\n    if (env > thr) {\n      const over: f32 = env / thr;     // >1\n      target = f32(Mathf.pow(over, -slope));\n    }\n    gr += (target - gr) * 0.02;        // extra opto smoothing\n    let yl: f32 = xl * gr * makeup;\n    let yr: f32 = xr * gr * makeup;\n    // tone tilt\n    tiltL += (yl - tiltL) * tco; const hl: f32 = yl - tiltL;\n    yl = yl + (tilt > 0.0 ? hl * tilt : tiltL * (-tilt));\n    tiltR += (yr - tiltR) * tco; const hr: f32 = yr - tiltR;\n    yr = yr + (tilt > 0.0 ? hr * tilt : tiltR * (-tilt));\n    let ol: f32 = xl * dry + yl * mix;\n    let orr: f32 = xr * dry + yr * mix;\n    if (ol > 1.5) ol = 1.5; else if (ol < -1.5) ol = -1.5;\n    if (orr > 1.5) orr = 1.5; else if (orr < -1.5) orr = -1.5;\n    outBuf[i] = ol; outBuf[MAX_FRAMES + i] = orr;\n  }\n}\n",
  "publishedAt": 1751000173000
}