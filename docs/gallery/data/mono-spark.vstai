{
  "format": 1,
  "name": "Mono Spark",
  "isInstrument": true,
  "explanation": "A punchy, sub-heavy monophonic synthesizer in the classic ribbon-strip lineage. One main VCO blends a saw with a variable-width pulse (PWM) and is reinforced by a strong square SUB oscillator one and two octaves down plus a touch of noise, all driven into a snappy 4-pole resonant low-pass with its own decay envelope and an amp envelope. Last-note priority mono with a 4-note hold stack for tight chord stabs — built for weighty techno/acid basslines and zippy leads.",
  "params": [
    {
      "name": "Cutoff",
      "index": 0,
      "min": 0,
      "max": 1,
      "default": 0.4
    },
    {
      "name": "Resonance",
      "index": 1,
      "min": 0,
      "max": 1,
      "default": 0.55
    },
    {
      "name": "Env Amount",
      "index": 2,
      "min": 0,
      "max": 1,
      "default": 0.7
    },
    {
      "name": "Sub",
      "index": 3,
      "min": 0,
      "max": 1,
      "default": 0.65
    },
    {
      "name": "PWM",
      "index": 4,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Decay",
      "index": 5,
      "min": 0,
      "max": 1,
      "default": 0.35
    },
    {
      "name": "Level",
      "index": 6,
      "min": 0,
      "max": 1,
      "default": 0.8
    }
  ],
  "wasmBase64": "",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"utf-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n<title>Mono Spark</title>\n<style>\n  :root {\n    --accent: #ff5a4d;\n    --accent2: #3da0ff;\n    --panel: #c9cdd2;\n    --panel-dark: #a7acb2;\n    --ink: #23262b;\n    --slot: #1b1d21;\n    --led-off: #4a1714;\n    --led-on: #ff5a4d;\n  }\n\n  * { box-sizing: border-box; }\n\n  html, body {\n    margin: 0;\n    padding: 0;\n    background:\n      radial-gradient(120% 120% at 50% -10%, #2c3036 0%, #16181b 55%, #0c0d0f 100%);\n    font-family: ui-sans-serif, -apple-system, \"Segoe UI\", system-ui, sans-serif;\n    color: var(--ink);\n    min-height: 100vh;\n  }\n\n  .wrap {\n    max-width: 960px;\n    margin: 0 auto;\n    padding: 18px 14px 30px;\n  }\n\n  /* ------- the ribbon-strip body ------- */\n  .unit {\n    position: relative;\n    border-radius: 14px;\n    padding: 0;\n    background:\n      linear-gradient(180deg, #e7e9ec 0%, #c9cdd2 6%, #b7bcc2 50%, #a4a9af 94%, #c4c8cd 100%);\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.7) inset,\n      0 -3px 8px rgba(0,0,0,0.25) inset,\n      0 22px 48px rgba(0,0,0,0.55),\n      0 2px 0 rgba(0,0,0,0.4);\n    overflow: hidden;\n  }\n\n  /* brushed-metal sheen overlay */\n  .unit::before {\n    content: \"\";\n    position: absolute;\n    inset: 0;\n    background:\n      repeating-linear-gradient(90deg,\n        rgba(255,255,255,0.035) 0px,\n        rgba(255,255,255,0.035) 1px,\n        rgba(0,0,0,0.02) 2px,\n        rgba(0,0,0,0.02) 3px);\n    pointer-events: none;\n    mix-blend-mode: overlay;\n  }\n\n  /* red top rail */\n  .rail {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    padding: 10px 18px;\n    background:\n      linear-gradient(180deg, var(--accent) 0%, #e23e33 60%, #b62c23 100%);\n    color: #fff;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.35), 0 1px 0 rgba(255,255,255,0.4) inset;\n  }\n\n  .brand {\n    display: flex;\n    align-items: baseline;\n    gap: 10px;\n  }\n  .brand .logo {\n    font-weight: 900;\n    letter-spacing: 2px;\n    font-size: 20px;\n    text-shadow: 0 1px 0 rgba(0,0,0,0.35);\n  }\n  .brand .model {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    opacity: 0.85;\n    padding: 2px 7px;\n    border: 1px solid rgba(255,255,255,0.45);\n    border-radius: 4px;\n  }\n  .rail .tag {\n    font-size: 9.5px;\n    letter-spacing: 2.5px;\n    text-transform: uppercase;\n    opacity: 0.9;\n  }\n\n  /* main body grid */\n  .body {\n    position: relative;\n    display: grid;\n    grid-template-columns: 224px 1fr;\n    gap: 16px;\n    padding: 18px;\n  }\n  @media (max-width: 720px) {\n    .body { grid-template-columns: 1fr; }\n  }\n\n  /* ------- left: big filter knob + scope ------- */\n  .filter-bay {\n    background:\n      linear-gradient(180deg, #9da2a8, #babfc5);\n    border-radius: 10px;\n    padding: 14px 12px 12px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.6) inset,\n      0 -2px 6px rgba(0,0,0,0.2) inset,\n      0 2px 5px rgba(0,0,0,0.18);\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  .bay-label {\n    font-size: 10px;\n    letter-spacing: 3px;\n    text-transform: uppercase;\n    color: #3a3e44;\n    margin-bottom: 8px;\n    font-weight: 700;\n  }\n\n  .bigknob-wrap {\n    position: relative;\n    width: 160px;\n    height: 160px;\n    cursor: ns-resize;\n    user-select: none;\n  }\n  .bigknob-wrap svg { display: block; width: 100%; height: 100%; }\n\n  .knob-cap {\n    transition: filter 0.18s ease;\n  }\n  .bigknob-wrap:hover .knob-cap,\n  .bigknob-wrap.drag .knob-cap {\n    filter: drop-shadow(0 0 9px var(--accent));\n  }\n\n  .bigval {\n    margin-top: 6px;\n    font-variant-numeric: tabular-nums;\n    font-size: 15px;\n    font-weight: 800;\n    color: var(--ink);\n    letter-spacing: 0.5px;\n  }\n  .bigval span { color: var(--accent); }\n\n  /* sub/saw scope */\n  .scope {\n    margin-top: 12px;\n    width: 100%;\n    height: 64px;\n    border-radius: 7px;\n    background:\n      linear-gradient(180deg, #0f1114, #1b1f24);\n    box-shadow:\n      0 0 0 1px rgba(0,0,0,0.5) inset,\n      0 2px 4px rgba(0,0,0,0.4) inset;\n    display: block;\n  }\n\n  /* ------- right: knob row, sub fader, LED seq, keys ------- */\n  .right {\n    display: flex;\n    flex-direction: column;\n    gap: 14px;\n  }\n\n  .knob-strip {\n    display: grid;\n    grid-template-columns: repeat(6, 1fr);\n    gap: 8px;\n    background:\n      linear-gradient(180deg, #9da2a8, #b6bbc1);\n    border-radius: 10px;\n    padding: 12px 10px 10px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.6) inset,\n      0 -2px 6px rgba(0,0,0,0.2) inset,\n      0 2px 5px rgba(0,0,0,0.18);\n  }\n  @media (max-width: 540px) {\n    .knob-strip { grid-template-columns: repeat(3, 1fr); row-gap: 14px; }\n  }\n\n  .ctl {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 4px;\n  }\n  .ctl .knob {\n    width: 58px;\n    height: 58px;\n    cursor: ns-resize;\n    user-select: none;\n  }\n  .ctl .knob svg { display: block; width: 100%; height: 100%; }\n  .ctl .knob:hover .miniarc,\n  .ctl .knob.drag .miniarc { filter: drop-shadow(0 0 5px var(--accent)); }\n\n  .ctl .lbl {\n    font-size: 9px;\n    letter-spacing: 1.6px;\n    text-transform: uppercase;\n    color: #3a3e44;\n    font-weight: 700;\n  }\n  .ctl .val {\n    font-size: 10px;\n    font-variant-numeric: tabular-nums;\n    color: #56307a00; /* hidden until needed; we show on hover via .show */\n    color: #2c2f34;\n    opacity: 0.55;\n  }\n\n  /* LED sequencer strip (decorative + animated pulse meter) */\n  .seq {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    background:\n      linear-gradient(180deg, #2a2d31, #17191c);\n    border-radius: 9px;\n    padding: 10px 12px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.08) inset,\n      0 2px 5px rgba(0,0,0,0.4);\n  }\n  .seq .seq-lbl {\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #8b9097;\n    font-weight: 700;\n    white-space: nowrap;\n  }\n  .leds {\n    display: flex;\n    gap: 7px;\n    flex: 1;\n  }\n  .led {\n    flex: 1;\n    height: 14px;\n    border-radius: 3px;\n    background: var(--led-off);\n    box-shadow: 0 0 0 1px rgba(0,0,0,0.5) inset;\n    transition: background 0.06s linear, box-shadow 0.06s linear;\n  }\n  .led.on {\n    background: var(--led-on);\n    box-shadow:\n      0 0 0 1px rgba(0,0,0,0.4) inset,\n      0 0 10px var(--accent),\n      0 0 4px var(--accent);\n  }\n\n  /* power dot */\n  .power {\n    width: 12px; height: 12px; border-radius: 50%;\n    background: radial-gradient(circle at 35% 30%, #ffd5cf, var(--accent) 60%, #8e231b);\n    box-shadow: 0 0 8px var(--accent);\n    animation: breathe 2.4s ease-in-out infinite;\n  }\n  @keyframes breathe {\n    0%, 100% { opacity: 0.55; box-shadow: 0 0 4px var(--accent); }\n    50%      { opacity: 1;    box-shadow: 0 0 12px var(--accent); }\n  }\n\n  /* ------- keyboard ------- */\n  .keys {\n    position: relative;\n    height: 96px;\n    background:\n      linear-gradient(180deg, #2a2d31, #17191c);\n    border-radius: 9px;\n    padding: 8px;\n    box-shadow:\n      0 1px 0 rgba(255,255,255,0.08) inset,\n      0 2px 6px rgba(0,0,0,0.45);\n  }\n  .kbd {\n    position: relative;\n    height: 100%;\n    display: flex;\n  }\n  .wkey {\n    position: relative;\n    flex: 1;\n    margin: 0 1px;\n    border-radius: 0 0 5px 5px;\n    background: linear-gradient(180deg, #f4f5f6, #d9dbde 88%, #c2c5c8);\n    box-shadow: 0 2px 3px rgba(0,0,0,0.4), 0 -1px 0 rgba(255,255,255,0.6) inset;\n    cursor: pointer;\n    transition: background 0.05s ease, transform 0.04s ease;\n  }\n  .wkey.down {\n    background: linear-gradient(180deg, #ffc9c3, var(--accent) 90%);\n    transform: translateY(2px);\n  }\n  .bkey {\n    position: absolute;\n    top: 0;\n    width: 56%;\n    height: 60%;\n    margin-left: -28%;\n    border-radius: 0 0 4px 4px;\n    background: linear-gradient(180deg, #34373b, #15171a 90%);\n    box-shadow: 0 3px 4px rgba(0,0,0,0.6), 0 -1px 0 rgba(255,255,255,0.12) inset;\n    cursor: pointer;\n    z-index: 3;\n    transition: background 0.05s ease, transform 0.04s ease;\n  }\n  .bkey.down {\n    background: linear-gradient(180deg, var(--accent), #8e231b 95%);\n    transform: translateY(2px);\n  }\n\n  .hint {\n    text-align: center;\n    font-size: 9px;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    color: #777b81;\n    margin-top: 8px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <div class=\"unit\">\n      <div class=\"rail\">\n        <div class=\"brand\">\n          <span class=\"logo\">MONO&nbsp;SPARK</span>\n          <span class=\"model\">SUB SYNTHESIZER</span>\n        </div>\n        <div style=\"display:flex;align-items:center;gap:10px;\">\n          <span class=\"tag\">MONO &middot; LAST-NOTE</span>\n          <span class=\"power\" title=\"powered\"></span>\n        </div>\n      </div>\n\n      <div class=\"body\">\n        <!-- left filter bay -->\n        <div class=\"filter-bay\">\n          <div class=\"bay-label\">VCF&nbsp;&middot;&nbsp;CUTOFF</div>\n          <div class=\"bigknob-wrap\" id=\"cutoffKnob\" title=\"Cutoff — drag, double-click to reset\">\n            <svg viewBox=\"0 0 100 100\" aria-hidden=\"true\">\n              <defs>\n                <radialGradient id=\"capGrad\" cx=\"38%\" cy=\"32%\" r=\"75%\">\n                  <stop offset=\"0%\" stop-color=\"#4a4e54\"/>\n                  <stop offset=\"55%\" stop-color=\"#2b2e33\"/>\n                  <stop offset=\"100%\" stop-color=\"#141619\"/>\n                </radialGradient>\n                <linearGradient id=\"ringGrad\" x1=\"0\" y1=\"0\" x2=\"0\" y2=\"1\">\n                  <stop offset=\"0%\" stop-color=\"#e9ebed\"/>\n                  <stop offset=\"100%\" stop-color=\"#9aa0a6\"/>\n                </linearGradient>\n              </defs>\n              <!-- bezel -->\n              <circle cx=\"50\" cy=\"50\" r=\"46\" fill=\"url(#ringGrad)\"/>\n              <circle cx=\"50\" cy=\"50\" r=\"42\" fill=\"#1a1c1f\"/>\n              <!-- value arc track -->\n              <circle cx=\"50\" cy=\"50\" r=\"38\" fill=\"none\" stroke=\"#000\" stroke-width=\"4\" opacity=\"0.5\"/>\n              <path id=\"cutoffArc\" d=\"\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"4\" stroke-linecap=\"round\"/>\n              <!-- cap -->\n              <g class=\"knob-cap\">\n                <circle cx=\"50\" cy=\"50\" r=\"30\" fill=\"url(#capGrad)\"\n                        stroke=\"#0c0d0f\" stroke-width=\"1\"/>\n                <g id=\"cutoffPtr\">\n                  <rect x=\"48.6\" y=\"22\" width=\"2.8\" height=\"20\" rx=\"1.4\" fill=\"var(--accent)\"/>\n                </g>\n              </g>\n            </svg>\n          </div>\n          <div class=\"bigval\"><span id=\"cutoffHz\">—</span></div>\n          <canvas class=\"scope\" id=\"scope\" width=\"200\" height=\"64\"></canvas>\n        </div>\n\n        <!-- right column -->\n        <div class=\"right\">\n          <!-- small knobs -->\n          <div class=\"knob-strip\" id=\"knobStrip\"></div>\n\n          <!-- LED sequencer / pulse meter -->\n          <div class=\"seq\">\n            <span class=\"seq-lbl\">Step&nbsp;Pulse</span>\n            <div class=\"leds\" id=\"leds\"></div>\n          </div>\n\n          <!-- keyboard -->\n          <div class=\"keys\">\n            <div class=\"kbd\" id=\"kbd\"></div>\n          </div>\n          <div class=\"hint\">Play with mouse &middot; rows A–K and W–U &middot; drag knobs, double-click to reset</div>\n        </div>\n      </div>\n    </div>\n  </div>\n\n<script>\n(function () {\n  \"use strict\";\n\n  // ---- parameter map (indices MUST match assembly.ts) ----\n  var PARAMS = [\n    { name: \"Cutoff\",     index: 0, min: 0, max: 1, def: 0.40 },\n    { name: \"Resonance\",  index: 1, min: 0, max: 1, def: 0.55 },\n    { name: \"Env Amount\", index: 2, min: 0, max: 1, def: 0.70 },\n    { name: \"Sub\",        index: 3, min: 0, max: 1, def: 0.65 },\n    { name: \"PWM\",        index: 4, min: 0, max: 1, def: 0.35 },\n    { name: \"Decay\",      index: 5, min: 0, max: 1, def: 0.35 },\n    { name: \"Level\",      index: 6, min: 0, max: 1, def: 0.80 }\n  ];\n  var state = {};\n  PARAMS.forEach(function (p) { state[p.index] = p.def; });\n\n  // ---- host bridge ----\n  function pushParam(index, value) {\n    if (window.vstai && window.vstai.setParam) {\n      try { window.vstai.setParam(index, value); } catch (e) {}\n    }\n  }\n  function sendAll() {\n    PARAMS.forEach(function (p) { pushParam(p.index, state[p.index]); });\n  }\n\n  // ---------- big CUTOFF knob ----------\n  var POLAR = function (cx, cy, r, deg) {\n    var a = (deg - 90) * Math.PI / 180;\n    return [cx + r * Math.cos(a), cy + r * Math.sin(a)];\n  };\n  function arcPath(cx, cy, r, startDeg, endDeg) {\n    var s = POLAR(cx, cy, r, endDeg);\n    var e = POLAR(cx, cy, r, startDeg);\n    var large = (endDeg - startDeg) <= 180 ? 0 : 1;\n    return \"M \" + s[0].toFixed(2) + \" \" + s[1].toFixed(2) +\n           \" A \" + r + \" \" + r + \" 0 \" + large + \" 0 \" +\n           e[0].toFixed(2) + \" \" + e[1].toFixed(2);\n  }\n  var SWEEP = 270; // degrees of travel\n  var START = -135;\n\n  var cutEl = document.getElementById(\"cutoffKnob\");\n  var cutArc = document.getElementById(\"cutoffArc\");\n  var cutPtr = document.getElementById(\"cutoffPtr\");\n  var cutHz = document.getElementById(\"cutoffHz\");\n\n  function hzFromNorm(n) {\n    // mirrors assembly: 70 * e^(n*4.96)\n    var hz = 70 * Math.exp(n * 4.96);\n    if (hz >= 1000) return (hz / 1000).toFixed(2) + \" kHz\";\n    return Math.round(hz) + \" Hz\";\n  }\n\n  function renderCutoff() {\n    var n = state[0];\n    var deg = START + n * SWEEP;\n    cutArc.setAttribute(\"d\", arcPath(50, 50, 38, START, deg));\n    cutPtr.setAttribute(\"transform\", \"rotate(\" + deg + \" 50 50)\");\n    cutHz.textContent = hzFromNorm(n);\n  }\n\n  // ---------- small knobs ----------\n  var strip = document.getElementById(\"knobStrip\");\n  var miniRefs = {}; // index -> {arc, ptr, val}\n\n  PARAMS.filter(function (p) { return p.index !== 0; }).forEach(function (p) {\n    var ctl = document.createElement(\"div\");\n    ctl.className = \"ctl\";\n\n    var knob = document.createElement(\"div\");\n    knob.className = \"knob\";\n    knob.title = p.name + \" — drag, double-click to reset\";\n    knob.innerHTML =\n      '<svg viewBox=\"0 0 100 100\">' +\n        '<circle cx=\"50\" cy=\"50\" r=\"44\" fill=\"#1a1c1f\" stroke=\"#7d8288\" stroke-width=\"3\"/>' +\n        '<circle cx=\"50\" cy=\"50\" r=\"34\" fill=\"none\" stroke=\"#000\" stroke-width=\"5\" opacity=\"0.5\"/>' +\n        '<path class=\"miniarc\" fill=\"none\" stroke=\"var(--accent)\" stroke-width=\"5\" stroke-linecap=\"round\"/>' +\n        '<g class=\"miniptr\"><rect x=\"48\" y=\"16\" width=\"4\" height=\"20\" rx=\"2\" fill=\"#e7e9ec\"/></g>' +\n      '</svg>';\n\n    var lbl = document.createElement(\"div\");\n    lbl.className = \"lbl\";\n    lbl.textContent = p.name;\n\n    var val = document.createElement(\"div\");\n    val.className = \"val\";\n\n    ctl.appendChild(knob);\n    ctl.appendChild(lbl);\n    ctl.appendChild(val);\n    strip.appendChild(ctl);\n\n    var svg = knob.querySelector(\"svg\");\n    miniRefs[p.index] = {\n      knob: knob,\n      arc: svg.querySelector(\".miniarc\"),\n      ptr: svg.querySelector(\".miniptr\"),\n      val: val\n    };\n\n    attachDrag(knob, p);\n  });\n\n  function renderMini(p) {\n    var r = miniRefs[p.index];\n    if (!r) return;\n    var n = state[p.index];\n    var deg = START + n * SWEEP;\n    r.arc.setAttribute(\"d\", arcPath(50, 50, 34, START, deg));\n    r.ptr.setAttribute(\"transform\", \"rotate(\" + deg + \" 50 50)\");\n    r.val.textContent = Math.round(n * 100) + \"%\";\n  }\n\n  // ---------- shared drag behaviour ----------\n  function attachDrag(el, p) {\n    var dragging = false;\n    var lastY = 0;\n\n    function setNorm(n) {\n      n = Math.max(0, Math.min(1, n));\n      state[p.index] = n;\n      pushParam(p.index, n);\n      if (p.index === 0) renderCutoff(); else renderMini(p);\n    }\n\n    el.addEventListener(\"mousedown\", function (e) {\n      dragging = true;\n      lastY = e.clientY;\n      el.classList.add(\"drag\");\n      e.preventDefault();\n    });\n    window.addEventListener(\"mousemove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.clientY;\n      lastY = e.clientY;\n      var speed = e.shiftKey ? 0.0012 : 0.005; // shift = fine\n      setNorm(state[p.index] + dy * speed);\n    });\n    window.addEventListener(\"mouseup\", function () {\n      if (!dragging) return;\n      dragging = false;\n      el.classList.remove(\"drag\");\n    });\n    el.addEventListener(\"wheel\", function (e) {\n      e.preventDefault();\n      setNorm(state[p.index] - Math.sign(e.deltaY) * 0.02);\n    }, { passive: false });\n    el.addEventListener(\"dblclick\", function () {\n      setNorm(p.def);\n    });\n\n    // touch\n    el.addEventListener(\"touchstart\", function (e) {\n      dragging = true; lastY = e.touches[0].clientY; el.classList.add(\"drag\");\n    }, { passive: true });\n    el.addEventListener(\"touchmove\", function (e) {\n      if (!dragging) return;\n      var dy = lastY - e.touches[0].clientY;\n      lastY = e.touches[0].clientY;\n      setNorm(state[p.index] + dy * 0.005);\n      e.preventDefault();\n    }, { passive: false });\n    el.addEventListener(\"touchend\", function () { dragging = false; el.classList.remove(\"drag\"); });\n  }\n\n  attachDrag(cutEl, PARAMS[0]);\n\n  // ---------- LED sequencer / pulse meter ----------\n  var leds = document.getElementById(\"leds\");\n  var ledEls = [];\n  var NLED = 16;\n  for (var i = 0; i < NLED; i++) {\n    var d = document.createElement(\"div\");\n    d.className = \"led\";\n    leds.appendChild(d);\n    ledEls.push(d);\n  }\n\n  // ---------- keyboard ----------\n  var kbd = document.getElementById(\"kbd\");\n  // C3..C5, two octaves\n  var KEYS = [];\n  var BASE = 48; // C3\n  var WHITE_OFFS = [0, 2, 4, 5, 7, 9, 11];\n  var BLACK_OFFS = { 0: 1, 1: 3, 3: 6, 4: 8, 5: 10 };\n  var OCTAVES = 2;\n  var whiteCount = WHITE_OFFS.length * OCTAVES + 1;\n\n  var whiteEls = [];\n  var keyByNote = {};\n\n  for (var oct = 0; oct < OCTAVES; oct++) {\n    for (var wi = 0; wi < WHITE_OFFS.length; wi++) {\n      var note = BASE + oct * 12 + WHITE_OFFS[wi];\n      var w = document.createElement(\"div\");\n      w.className = \"wkey\";\n      w.dataset.note = note;\n      kbd.appendChild(w);\n      whiteEls.push(w);\n      keyByNote[note] = w;\n    }\n  }\n  // top C\n  var topC = BASE + OCTAVES * 12;\n  var wTop = document.createElement(\"div\");\n  wTop.className = \"wkey\";\n  wTop.dataset.note = topC;\n  kbd.appendChild(wTop);\n  whiteEls.push(wTop);\n  keyByNote[topC] = wTop;\n\n  // position black keys after layout\n  function placeBlacks() {\n    // remove old blacks\n    Array.prototype.slice.call(kbd.querySelectorAll(\".bkey\")).forEach(function (b) { b.remove(); });\n    var kbRect = kbd.getBoundingClientRect();\n    var wWidth = whiteEls[0].getBoundingClientRect().width;\n    var idx = 0;\n    for (var oct = 0; oct < OCTAVES; oct++) {\n      for (var wi = 0; wi < WHITE_OFFS.length; wi++) {\n        if (BLACK_OFFS.hasOwnProperty(wi)) {\n          var note = BASE + oct * 12 + BLACK_OFFS[wi];\n          var leftWhite = whiteEls[oct * WHITE_OFFS.length + wi];\n          var lr = leftWhite.getBoundingClientRect();\n          var b = document.createElement(\"div\");\n          b.className = \"bkey\";\n          b.dataset.note = note;\n          b.style.left = (lr.left - kbRect.left + wWidth) + \"px\";\n          b.style.width = (wWidth * 0.6) + \"px\";\n          b.style.marginLeft = (-wWidth * 0.3) + \"px\";\n          kbd.appendChild(b);\n          keyByNote[note] = b;\n        }\n        idx++;\n      }\n    }\n  }\n\n  var activeNotes = {};\n  function noteOn(note) {\n    if (activeNotes[note]) return;\n    activeNotes[note] = true;\n    if (window.vstai && window.vstai.noteOn) {\n      try { window.vstai.noteOn(note, 0.9); } catch (e) {}\n    }\n    var el = keyByNote[note];\n    if (el) el.classList.add(\"down\");\n  }\n  function noteOff(note) {\n    if (!activeNotes[note]) return;\n    delete activeNotes[note];\n    if (window.vstai && window.vstai.noteOff) {\n      try { window.vstai.noteOff(note); } catch (e) {}\n    }\n    var el = keyByNote[note];\n    if (el) el.classList.remove(\"down\");\n  }\n\n  var mouseHeld = null;\n  function noteFromEvent(e) {\n    var t = e.target;\n    if (t && t.dataset && t.dataset.note) return parseInt(t.dataset.note, 10);\n    return null;\n  }\n  kbd.addEventListener(\"mousedown\", function (e) {\n    var n = noteFromEvent(e);\n    if (n != null) { mouseHeld = n; noteOn(n); e.preventDefault(); }\n  });\n  kbd.addEventListener(\"mouseover\", function (e) {\n    if (mouseHeld == null) return;\n    var n = noteFromEvent(e);\n    if (n != null && n !== mouseHeld) { noteOff(mouseHeld); mouseHeld = n; noteOn(n); }\n  });\n  window.addEventListener(\"mouseup\", function () {\n    if (mouseHeld != null) { noteOff(mouseHeld); mouseHeld = null; }\n  });\n\n  // computer keyboard\n  var KEYMAP = {\n    \"a\": 48, \"w\": 49, \"s\": 50, \"e\": 51, \"d\": 52, \"f\": 53, \"t\": 54,\n    \"g\": 55, \"y\": 56, \"h\": 57, \"u\": 58, \"j\": 59, \"k\": 60, \"o\": 61,\n    \"l\": 62\n  };\n  window.addEventListener(\"keydown\", function (e) {\n    if (e.repeat) return;\n    var n = KEYMAP[e.key.toLowerCase()];\n    if (n != null) noteOn(n);\n  });\n  window.addEventListener(\"keyup\", function (e) {\n    var n = KEYMAP[e.key.toLowerCase()];\n    if (n != null) noteOff(n);\n  });\n\n  // ---------- animated scope + LED pulse ----------\n  var scope = document.getElementById(\"scope\");\n  var sctx = scope.getContext(\"2d\");\n  var t0 = performance.now();\n  var ledPhase = 0;\n\n  function draw(now) {\n    if (document.hidden) { requestAnimationFrame(draw); return; }\n    var t = (now - t0) / 1000;\n    var W = scope.width, H = scope.height;\n    sctx.clearRect(0, 0, W, H);\n\n    var anyNote = Object.keys(activeNotes).length > 0;\n    var amp = anyNote ? 1.0 : 0.35;\n    var pwm = state[4];           // pulse width\n    var subLvl = state[3];        // sub influence on lower trace\n    var speed = 1.6 + state[0] * 2.5; // cutoff brightens / quickens visual\n\n    // ---- saw trace (top, accent) ----\n    sctx.lineWidth = 2;\n    sctx.strokeStyle = getComputedStyle(document.documentElement)\n      .getPropertyValue(\"--accent\").trim() || \"#ff5a4d\";\n    sctx.beginPath();\n    for (var x = 0; x <= W; x++) {\n      var ph = (x / W) * 4 + t * speed;\n      var fr = ph - Math.floor(ph);\n      var saw = (fr * 2 - 1);\n      var y = H * 0.32 + saw * H * 0.18 * amp;\n      if (x === 0) sctx.moveTo(x, y); else sctx.lineTo(x, y);\n    }\n    sctx.stroke();\n\n    // ---- SUB square trace (bottom, blue, thumping wider/slower) ----\n    sctx.lineWidth = 2.5;\n    sctx.strokeStyle = getComputedStyle(document.documentElement)\n      .getPropertyValue(\"--accent2\").trim() || \"#3da0ff\";\n    sctx.globalAlpha = 0.55 + subLvl * 0.45;\n    sctx.beginPath();\n    var thump = 1 + 0.25 * Math.sin(t * 6.0) * subLvl; // weighty pulsing\n    for (var x2 = 0; x2 <= W; x2++) {\n      var ph2 = (x2 / W) * 2 + t * speed * 0.5; // one octave down\n      var fr2 = ph2 - Math.floor(ph2);\n      var sq = fr2 < (0.5) ? 1 : -1;\n      var y2 = H * 0.74 + sq * H * 0.16 * amp * thump * (0.4 + subLvl);\n      if (x2 === 0) sctx.moveTo(x2, y2); else sctx.lineTo(x2, y2);\n    }\n    sctx.stroke();\n    sctx.globalAlpha = 1;\n\n    // ---- LED chaser, faster with decay/cutoff, lights up while playing ----\n    ledPhase += (0.04 + state[5] * 0.10) * (anyNote ? 1.8 : 0.5);\n    var head = Math.floor(ledPhase) % NLED;\n    for (var i = 0; i < NLED; i++) {\n      var lit = (i === head) || (anyNote && i === (head + NLED - 1) % NLED);\n      if (lit) ledEls[i].classList.add(\"on\"); else ledEls[i].classList.remove(\"on\");\n    }\n\n    requestAnimationFrame(draw);\n  }\n  requestAnimationFrame(draw);\n\n  // ---------- init ----------\n  function init() {\n    renderCutoff();\n    PARAMS.filter(function (p) { return p.index !== 0; }).forEach(renderMini);\n    placeBlacks();\n    sendAll();\n  }\n\n  window.addEventListener(\"resize\", placeBlacks);\n\n  if (window.vstai && window.vstai.onReady) {\n    window.vstai.onReady(init);\n  } else {\n    // poll briefly in case vstai injects late, then run regardless\n    var tries = 0;\n    (function wait() {\n      if (window.vstai || tries > 40) { init(); return; }\n      tries++;\n      setTimeout(wait, 25);\n    })();\n  }\n})();\n</script>\n</body>\n</html>\n",
  "assembly": "// =====================================================================\n//  MONO SPARK — punchy sub-heavy monophonic synthesizer\n//  An SH-101-lineage techno/acid workhorse: ONE main VCO producing a saw\n//  plus a variable-width pulse (with PWM), reinforced by a strong square\n//  SUB oscillator one/two octaves down, plus a touch of white noise. The\n//  blend runs into a snappy 4-pole resonant low-pass driven by its OWN\n//  decay envelope (the punch), then an amp envelope and output level.\n//\n//  Mono with last-note priority. A small voice pool (4) lets fast chord\n//  stabs retrigger cleanly, but only the most-recent gated note sounds —\n//  classic mono behaviour with a fat, weighty low end from the sub.\n//\n//  Signal path:\n//    [ saw + pulse(PWM) + 2x square SUB + noise ]\n//      -> 4-pole resonant LPF (cutoff = base + envAmt * filterEnv)\n//      -> amp env -> soft clip -> level\n// =====================================================================\n\nconst MAX_FRAMES: i32 = 8192;\nconst MAX_CHANNELS: i32 = 2;\nconst MAX_PARAMS: i32 = 64;\n\nconst inBuf:  StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst outBuf: StaticArray<f32> = new StaticArray<f32>(MAX_FRAMES * MAX_CHANNELS);\nconst params: StaticArray<f32> = new StaticArray<f32>(MAX_PARAMS);\n\nconst PI: f32 = 3.14159265358979;\n\nlet sampleRate: f32 = 48000.0;\n\n// ---- parameter indices (must match spec.json) ----\nconst P_CUTOFF: i32 = 0; // base cutoff 0..1\nconst P_RESO:   i32 = 1; // resonance 0..1\nconst P_ENVAMT: i32 = 2; // filter envelope amount 0..1\nconst P_SUB:    i32 = 3; // sub-oscillator level 0..1\nconst P_PWM:    i32 = 4; // pulse width 0..1 (0.5 = square)\nconst P_DECAY:  i32 = 5; // filter + amp decay 0..1\nconst P_LEVEL:  i32 = 6; // output level 0..1\n\n// ---- mono voice state ----\nconst VOICES: i32 = 4;\nconst heldId:   StaticArray<i32> = new StaticArray<i32>(VOICES); // note ids currently held (-1 empty)\nconst heldFreq: StaticArray<f32> = new StaticArray<f32>(VOICES); // their freqs\nlet nHeld: i32 = 0;          // number of held notes in the stack\n\nlet mainPhase: f32 = 0.0;    // main VCO phase 0..1\nlet subPhase:  f32 = 0.0;    // sub oscillator phase 0..1\nlet curFreq:   f32 = 0.0;    // frequency currently sounding (Hz)\nlet gate: i32 = 0;           // 1 while any note held\n\n// envelopes (decay-style: snap to 1 on trigger, decay down)\nlet fenv: f32 = 0.0;         // filter envelope\nlet aenv: f32 = 0.0;         // amp envelope\nlet vel:  f32 = 0.8;         // velocity of the current note\n\n// 4-pole ladder filter state\nlet z0: f32 = 0.0;\nlet z1: f32 = 0.0;\nlet z2: f32 = 0.0;\nlet z3: f32 = 0.0;\n\n// noise + dc-block state\nlet rngState: u32 = 0x9e3779b9;\nlet dcX: f32 = 0.0;\nlet dcY: f32 = 0.0;\n\nexport function init(sr: f32, maxFrames: i32, numChannels: i32): void {\n  sampleRate = sr > 0.0 ? sr : 48000.0;\n  mainPhase = 0.0;\n  subPhase = 0.0;\n  curFreq = 0.0;\n  gate = 0;\n  fenv = 0.0;\n  aenv = 0.0;\n  vel = 0.8;\n  nHeld = 0;\n  z0 = 0.0; z1 = 0.0; z2 = 0.0; z3 = 0.0;\n  rngState = 0x9e3779b9;\n  dcX = 0.0; dcY = 0.0;\n  for (let i = 0; i < VOICES; i++) { heldId[i] = -1; heldFreq[i] = 0.0; }\n\n  params[P_CUTOFF] = 0.40;\n  params[P_RESO]   = 0.55;\n  params[P_ENVAMT] = 0.70;\n  params[P_SUB]    = 0.65;\n  params[P_PWM]    = 0.35;\n  params[P_DECAY]  = 0.35;\n  params[P_LEVEL]  = 0.80;\n}\n\nexport function getInputPtr(): usize  { return changetype<usize>(inBuf); }\nexport function getOutputPtr(): usize { return changetype<usize>(outBuf); }\nexport function getParamsPtr(): usize { return changetype<usize>(params); }\nexport function getNumParams(): i32   { return 7; }\n\n@inline function clampf(x: f32, lo: f32, hi: f32): f32 {\n  return x < lo ? lo : (x > hi ? hi : x);\n}\n\n// fast bounded soft-clipper (cubic-ish), saturates smoothly toward ±1\n@inline function satf(x: f32): f32 {\n  const c: f32 = clampf(x, -3.0, 3.0);\n  return f32(c * (27.0 + c * c) / (27.0 + 9.0 * c * c));\n}\n\n@inline function whiteNoise(): f32 {\n  rngState ^= rngState << 13;\n  rngState ^= rngState >> 17;\n  rngState ^= rngState << 5;\n  return f32(i32(rngState)) * f32(4.6566129e-10); // ~ -1..1\n}\n\n// Trigger the envelopes (re-strike) and reset the sub phase for a tight thump.\n@inline function strike(f: f32, v: f32): void {\n  curFreq = f > 0.0 ? f : 0.0001;\n  vel = clampf(v, 0.05, 1.0);\n  fenv = 1.0;\n  aenv = 1.0;\n  subPhase = 0.0; // align sub for a punchy attack transient\n}\n\n// Host passes frequency in Hz. Last-note priority: a new note steals the voice.\nexport function noteOn(id: i32, f: f32, v: f32): void {\n  // push onto the held stack (drop oldest if full)\n  if (nHeld >= VOICES) {\n    for (let i = 0; i < VOICES - 1; i++) { heldId[i] = heldId[i + 1]; heldFreq[i] = heldFreq[i + 1]; }\n    nHeld = VOICES - 1;\n  }\n  heldId[nHeld] = id;\n  heldFreq[nHeld] = f;\n  nHeld++;\n  gate = 1;\n  strike(f, v);\n}\n\nexport function noteOff(id: i32): void {\n  // remove from stack\n  let w: i32 = 0;\n  for (let i = 0; i < nHeld; i++) {\n    if (heldId[i] != id) {\n      heldId[w] = heldId[i];\n      heldFreq[w] = heldFreq[i];\n      w++;\n    }\n  }\n  nHeld = w;\n\n  if (nHeld <= 0) {\n    gate = 0; // release\n  } else {\n    // fall back to the previous held note (last-note priority), no re-strike\n    curFreq = heldFreq[nHeld - 1];\n  }\n}\n\nexport function process(n: i32): void {\n  const cutoffN: f32 = clampf(params[P_CUTOFF], 0.0, 1.0);\n  const resoN:   f32 = clampf(params[P_RESO],   0.0, 1.0);\n  const envAmtN: f32 = clampf(params[P_ENVAMT], 0.0, 1.0);\n  const subN:    f32 = clampf(params[P_SUB],    0.0, 1.0);\n  const pwmN:    f32 = clampf(params[P_PWM],    0.0, 1.0);\n  const decayN:  f32 = clampf(params[P_DECAY],  0.0, 1.0);\n  const level:   f32 = clampf(params[P_LEVEL],  0.0, 1.0);\n\n  // ---- derived coefficients ----\n\n  // Filter envelope decay: ~25 ms (snappy techno pluck) .. ~1.4 s (long sweep)\n  const fdecaySec: f32 = 0.025 + decayN * decayN * 1.4;\n  const fenvCoef: f32 = f32(Mathf.exp(f32(-1.0) / (fdecaySec * sampleRate)));\n\n  // Amp envelope: a touch longer so notes ring just past the filter close.\n  const adecaySec: f32 = 0.05 + decayN * decayN * 1.7;\n  const aenvCoef: f32 = f32(Mathf.exp(f32(-1.0) / (adecaySec * sampleRate)));\n\n  // Resonance 0..~4 (approaches self-oscillation but bounded by satf feedback).\n  const reso: f32 = resoN * 4.0;\n\n  // Base cutoff in Hz (exponential, musical): ~70 Hz .. ~10 kHz.\n  const baseCut: f32 = f32(70.0 * Mathf.exp(cutoffN * 4.96)); // 70 * e^4.96 ~ 10k\n\n  // Envelope sweep span (Hz) added on top of base.\n  const sweepSpan: f32 = envAmtN * 9000.0;\n\n  const nyq: f32 = sampleRate * 0.5;\n\n  // Pulse width: keep away from the degenerate 0/1 edges. 0.5 = square.\n  const pw: f32 = 0.08 + pwmN * 0.84; // 0.08..0.92\n\n  // Sub level (square one octave down + a quieter two-octave-down layer).\n  const subLvl: f32 = subN * 1.1;\n\n  for (let i = 0; i < n; i++) {\n    // ---- main oscillator ----\n    let inc: f32 = curFreq / sampleRate;\n    if (inc < 0.0) inc = 0.0;\n    if (inc > 0.5) inc = 0.5;\n    mainPhase += inc;\n    if (mainPhase >= 1.0) mainPhase -= 1.0;\n\n    const saw: f32 = mainPhase * 2.0 - 1.0;            // raw saw\n    const pulse: f32 = mainPhase < pw ? 1.0 : -1.0;     // variable-width pulse\n    // blend saw + pulse for the SH-style mixer feel\n    const main: f32 = 0.6 * saw + 0.55 * pulse;\n\n    // ---- sub oscillator (one octave down) + a softer 2-octave layer ----\n    subPhase += inc * 0.5;\n    if (subPhase >= 1.0) subPhase -= 1.0;\n    const sub1: f32 = subPhase < 0.5 ? 1.0 : -1.0;      // square, 1 oct down\n    // derive a 2-octave-down square from the same phase (period doubling)\n    const sub2: f32 = subPhase < 0.25 || subPhase >= 0.75 ? 1.0 : -1.0;\n    const sub: f32 = (sub1 * 0.85 + sub2 * 0.4) * subLvl;\n\n    // ---- noise (subtle grit, scales with sub a touch for body) ----\n    const noise: f32 = whiteNoise() * 0.04;\n\n    // ---- envelopes (decay toward 0; amp holds a small floor while gated) ----\n    fenv *= fenvCoef;\n    if (gate != 0) {\n      aenv = aenv * aenvCoef;\n      if (aenv < 0.35) aenv = 0.35; // sustain floor while held\n    } else {\n      aenv *= aenvCoef;\n    }\n\n    // ---- cutoff for this sample ----\n    let cutHz: f32 = baseCut + sweepSpan * fenv;\n    if (cutHz < 20.0) cutHz = 20.0;\n    if (cutHz > nyq * 0.49) cutHz = nyq * 0.49;\n\n    // ---- 4-pole resonant ladder ----\n    let fc: f32 = cutHz / nyq; // 0..0.49\n    if (fc > 0.49) fc = 0.49;\n    const g: f32 = fc * (1.8 - 0.8 * fc); // empirical tuning curve\n\n    const fb: f32 = reso * (1.0 - 0.15 * g);\n    const drive: f32 = (main + sub + noise) * (0.9 + 0.3 * vel);\n    let input: f32 = drive - fb * satf(z3);\n\n    z0 += g * (input - z0);\n    z1 += g * (z0 - z1);\n    z2 += g * (z1 - z2);\n    z3 += g * (z2 - z3);\n\n    let filtered: f32 = satf(z3 * 1.3);\n\n    // ---- amp + level ----\n    let s: f32 = filtered * aenv * vel;\n\n    // DC blocker (kills any sub-induced offset)\n    const y: f32 = s - dcX + f32(0.9985) * dcY;\n    dcX = s;\n    dcY = y;\n    s = y;\n\n    // final level + headroom guard (peak stays < ~1.0)\n    s = satf(s * level * 1.4) * 0.82;\n\n    outBuf[i] = s;\n    outBuf[MAX_FRAMES + i] = s;\n  }\n}\n",
  "publishedAt": 1751000115000
}